using System;
using Game.Foundation;

namespace Game.Cards;

class CardEffectKind {
    static int Damage() { return 1; }
    static int Block() { return 2; }
    static int Heal() { return 3; }
    static int Draw() { return 4; }
    static int Energy() { return 5; }
    static int Strength() { return 6; }
    static int Vulnerable() { return 7; }
}

class CardTarget {
    static int Self() { return 1; }
    static int Enemy() { return 2; }
}

class CardEffect {
    int kind;
    int amount;
    int target;

    static CardEffect Of(int kind, int amount, int target) {
        CardEffect effect = new CardEffect();
        effect.kind = kind;
        effect.amount = amount;
        effect.target = target;
        return effect;
    }

    int Kind() { return this.kind; }
    int Amount() { return this.amount; }
    int Target() { return this.target; }
}

class CardDefinition {
    string id;
    string name;
    int cost;
    string category;
    string art;
    List<CardEffect> effects;

    static CardDefinition Create(
        string id,
        string name,
        int cost,
        string category
    ) {
        CardDefinition card = new CardDefinition();
        card.id = id;
        card.name = name;
        card.cost = cost;
        card.category = category;
        card.art = "";
        card.effects = new List<CardEffect>();
        return card;
    }

    CardDefinition AddEffect(int kind, int amount, int target) {
        this.effects.Add(CardEffect.Of(kind, amount, target));
        return this;
    }

    CardDefinition SetArt(string resource) {
        this.art = resource;
        return this;
    }

    string Id() { return this.id; }
    string Name() { return this.name; }
    int Cost() { return this.cost; }
    string Category() { return this.category; }
    string Art() { return this.art; }
    int EffectCount() { return this.effects.Count; }
    CardEffect EffectAt(int index) { return this.effects[index]; }
}

class CardCatalog {
    List<CardDefinition> cards;

    static CardCatalog Create() {
        CardCatalog catalog = new CardCatalog();
        catalog.cards = new List<CardDefinition>();
        return catalog;
    }

    CardCatalog Add(CardDefinition card) {
        int index = this.IndexOf(card.Id());
        if (index >= 0) {
            this.cards[index] = card;
        } else {
            this.cards.Add(card);
        }
        return this;
    }

    int IndexOf(string id) {
        int i = 0;
        while (i < this.cards.Count) {
            if (this.cards[i].Id() == id) { return i; }
            i = i + 1;
        }
        return -1;
    }

    CardDefinition Find(string id) {
        int index = this.IndexOf(id);
        if (index < 0) { return null; }
        return this.cards[index];
    }

    int Count() { return this.cards.Count; }
    CardDefinition At(int index) { return this.cards[index]; }
}

class CardInstance {
    int instanceId;
    CardDefinition definition;
    int upgrade;
    bool retained;

    static CardInstance Create(int instanceId, CardDefinition definition) {
        CardInstance card = new CardInstance();
        card.instanceId = instanceId;
        card.definition = definition;
        card.upgrade = 0;
        card.retained = false;
        return card;
    }

    int InstanceId() { return this.instanceId; }
    CardDefinition Definition() { return this.definition; }
    int Upgrade() { return this.upgrade; }
    bool Retained() { return this.retained; }
    void SetUpgrade(int upgrade) { this.upgrade = upgrade; }
    void SetRetained(bool retained) { this.retained = retained; }
}

class CardZone {
    string name;
    List<CardInstance> cards;

    static CardZone Create(string name) {
        CardZone zone = new CardZone();
        zone.name = name;
        zone.cards = new List<CardInstance>();
        return zone;
    }

    void Add(CardInstance card) {
        if (card != null) { this.cards.Add(card); }
    }

    CardInstance TakeAt(int index) {
        if (index < 0 || index >= this.cards.Count) { return null; }
        CardInstance card = this.cards[index];
        this.cards.RemoveAt(index);
        return card;
    }

    CardInstance TakeLast() {
        return this.TakeAt(this.cards.Count - 1);
    }

    int IndexOfInstance(int instanceId) {
        int i = 0;
        while (i < this.cards.Count) {
            if (this.cards[i].InstanceId() == instanceId) { return i; }
            i = i + 1;
        }
        return -1;
    }

    void Shuffle(DeterministicRandom random) {
        if (random == null) { return; }
        int i = this.cards.Count - 1;
        while (i > 0) {
            int j = random.NextBelow(i + 1);
            CardInstance swap = this.cards[i];
            this.cards[i] = this.cards[j];
            this.cards[j] = swap;
            i = i - 1;
        }
    }

    string Name() { return this.name; }
    int Count() { return this.cards.Count; }
    CardInstance At(int index) { return this.cards[index]; }
    void Clear() { this.cards.Clear(); }
}

class CardDeck {
    CardZone draw;
    CardZone hand;
    CardZone discard;
    CardZone exhaust;
    DeterministicRandom random;
    int nextInstanceId;

    static CardDeck Create(int seed) {
        CardDeck deck = new CardDeck();
        deck.draw = CardZone.Create("draw");
        deck.hand = CardZone.Create("hand");
        deck.discard = CardZone.Create("discard");
        deck.exhaust = CardZone.Create("exhaust");
        deck.random = DeterministicRandom.Create(seed);
        deck.nextInstanceId = 1;
        return deck;
    }

    CardInstance Add(CardDefinition definition) {
        if (definition == null) { return null; }
        CardInstance card =
            CardInstance.Create(this.nextInstanceId, definition);
        this.nextInstanceId = this.nextInstanceId + 1;
        this.draw.Add(card);
        return card;
    }

    void ShuffleDraw() { this.draw.Shuffle(this.random); }

    void RecycleDiscard() {
        while (this.discard.Count() > 0) {
            this.draw.Add(this.discard.TakeLast());
        }
        this.ShuffleDraw();
    }

    CardInstance DrawOne() {
        if (this.draw.Count() == 0) { this.RecycleDiscard(); }
        if (this.draw.Count() == 0) { return null; }
        CardInstance card = this.draw.TakeLast();
        this.hand.Add(card);
        return card;
    }

    int Draw(int amount) {
        int drawn = 0;
        int i = 0;
        while (i < amount) {
            if (this.DrawOne() == null) { return drawn; }
            drawn = drawn + 1;
            i = i + 1;
        }
        return drawn;
    }

    CardInstance DiscardFromHand(int index) {
        CardInstance card = this.hand.TakeAt(index);
        if (card != null) { this.discard.Add(card); }
        return card;
    }

    CardInstance ExhaustFromHand(int index) {
        CardInstance card = this.hand.TakeAt(index);
        if (card != null) { this.exhaust.Add(card); }
        return card;
    }

    void DiscardHand() {
        int i = this.hand.Count() - 1;
        while (i >= 0) {
            CardInstance card = this.hand.At(i);
            if (!card.Retained()) {
                this.discard.Add(this.hand.TakeAt(i));
            }
            i = i - 1;
        }
    }

    CardZone DrawPile() { return this.draw; }
    CardZone Hand() { return this.hand; }
    CardZone DiscardPile() { return this.discard; }
    CardZone ExhaustPile() { return this.exhaust; }
    int RandomState() { return this.random.State(); }
}
