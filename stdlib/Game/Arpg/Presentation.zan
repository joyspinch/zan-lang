using System;

namespace Game.Arpg;

class ArpgGrowthLevel {
    int level;
    ArpgAttributes attributes;

    static ArpgGrowthLevel Create(int level, ArpgAttributes attributes) {
        ArpgGrowthLevel newValue = new ArpgGrowthLevel();
        newValue.level = level;
        newValue.attributes = attributes;
        return newValue;
    }

    int Level() { return this.level; }
    ArpgAttributes Attributes() { return this.attributes; }
}

class ArpgGrowthDefinition {
    string id;
    List<ArpgGrowthLevel> levels;

    static ArpgGrowthDefinition Create(string id) {
        ArpgGrowthDefinition growth = new ArpgGrowthDefinition();
        growth.id = id;
        growth.levels = new List<ArpgGrowthLevel>();
        return growth;
    }

    string Id() { return this.id; }
    void AddLevel(int level, ArpgAttributes attributes) {
        this.levels.Add(ArpgGrowthLevel.Create(level, attributes));
    }
    int LevelCount() { return this.levels.Count; }
    ArpgGrowthLevel LevelAt(int index) { return this.levels[index]; }
    ArpgAttributes AttributesFor(int level) {
        int i = 0;
        while (i < this.levels.Count) {
            if (this.levels[i].Level() == level) {
                return this.levels[i].Attributes();
            }
            i = i + 1;
        }
        return null;
    }

    void Validate(ArpgDiagnostics diagnostics) {
        string path = "growth." + this.id;
        ArpgValidation.Required(diagnostics, this.id, "growth", "L2GRW001");
        if (this.levels.Count == 0) {
            diagnostics.AddWarning(
                "L2GRW002", path + ".levels", "Growth definition has no levels.");
        }
        int i = 0;
        while (i < this.levels.Count) {
            if (this.levels[i].Level() <= 0) {
                diagnostics.AddError(
                    "L2GRW003", path + ".levels", "Growth levels must be positive.");
            }
            int j = i + 1;
            while (j < this.levels.Count) {
                if (this.levels[i].Level() == this.levels[j].Level()) {
                    diagnostics.AddError(
                        "L2GRW004", path + ".levels", "Duplicate growth level.");
                }
                j = j + 1;
            }
            i = i + 1;
        }
    }
}

class ArpgWindowDefinition {
    string id;
    string title;
    int x;
    int y;
    int width;
    int height;
    int borderWidth;
    ArpgColor borderColor;
    ArpgColor backgroundColor;
    bool alwaysOnTop;
    bool movable;
    bool clickThrough;
    bool visibleByDefault;
    int maskOpacity;
    string backgroundResource;
    string skinId;
    List<ArpgControlDefinition> controls;
    ArpgWindowEventHandlers events;

    static ArpgWindowDefinition Create(string id, int width, int height) {
        ArpgWindowDefinition window = new ArpgWindowDefinition();
        window.id = id;
        window.title = "";
        window.x = 0;
        window.y = 0;
        window.width = width;
        window.height = height;
        window.borderWidth = 0;
        window.borderColor = ArpgColor.Transparent();
        window.backgroundColor = ArpgColor.Transparent();
        window.alwaysOnTop = false;
        window.movable = false;
        window.clickThrough = false;
        window.visibleByDefault = false;
        window.maskOpacity = 0;
        window.backgroundResource = "";
        window.skinId = "";
        window.controls = new List<ArpgControlDefinition>();
        window.events = ArpgWindowEventHandlers.Create();
        return window;
    }

    string Id() { return this.id; }
    string Title() { return this.title; }
    int X() { return this.x; }
    int Y() { return this.y; }
    int Width() { return this.width; }
    int Height() { return this.height; }
    int BorderWidth() { return this.borderWidth; }
    ArpgColor BorderColor() { return this.borderColor; }
    ArpgColor BackgroundColor() { return this.backgroundColor; }
    bool AlwaysOnTop() { return this.alwaysOnTop; }
    bool Movable() { return this.movable; }
    bool ClickThrough() { return this.clickThrough; }
    bool VisibleByDefault() { return this.visibleByDefault; }
    int MaskOpacity() { return this.maskOpacity; }
    string BackgroundResource() { return this.backgroundResource; }
    string SkinId() { return this.skinId; }
    int ControlCount() { return this.controls.Count; }
    ArpgControlDefinition ControlAt(int index) { return this.controls[index]; }
    ArpgWindowEventHandlers Events() { return this.events; }

    void SetTitle(string newValue) { this.title = newValue; }
    void SetPosition(int x, int y) {
        this.x = x;
        this.y = y;
    }
    void SetBorder(int width, ArpgColor color) {
        this.borderWidth = width;
        this.borderColor = color;
    }
    void SetBackgroundColor(ArpgColor newValue) { this.backgroundColor = newValue; }
    void SetAlwaysOnTop(bool newValue) { this.alwaysOnTop = newValue; }
    void SetMovable(bool newValue) { this.movable = newValue; }
    void SetClickThrough(bool newValue) { this.clickThrough = newValue; }
    void SetVisibleByDefault(bool newValue) { this.visibleByDefault = newValue; }
    void SetMaskOpacity(int newValue) {
        this.maskOpacity = ArpgMath.Clamp(newValue, 0, 255);
    }
    void SetBackgroundResource(string newValue) { this.backgroundResource = newValue; }
    void SetSkinId(string newValue) { this.skinId = newValue; }
    void AddControl(ArpgControlDefinition control) { this.controls.Add(control); }

    void Validate(ArpgDiagnostics diagnostics) {
        string path = "windows." + this.id;
        ArpgValidation.Required(diagnostics, this.id, "windows", "L2WIN001");
        ArpgValidation.Positive(
            diagnostics, this.width, path + ".width", "L2WIN002");
        ArpgValidation.Positive(
            diagnostics, this.height, path + ".height", "L2WIN003");
        if (this.borderWidth < 0) {
            diagnostics.AddError(
                "L2WIN004", path + ".borderWidth", "Border width cannot be negative.");
        }
        int i = 0;
        while (i < this.controls.Count) {
            this.controls[i].Validate(diagnostics, path);
            int j = i + 1;
            while (j < this.controls.Count) {
                if (this.controls[i].Id() == this.controls[j].Id()) {
                    diagnostics.AddError(
                        "L2WIN005", path + ".controls", "Duplicate control id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }
    }
}

class ArpgPrefabProperty {
    string name;
    string defaultValue;

    static ArpgPrefabProperty Create(string name, string defaultValue) {
        ArpgPrefabProperty property = new ArpgPrefabProperty();
        property.name = name;
        property.defaultValue = defaultValue;
        return property;
    }

    string Name() { return this.name; }
    string DefaultValue() { return this.defaultValue; }
}

class ArpgPrefabDefinition {
    string id;
    int width;
    int height;
    double anchorX;
    double anchorY;
    ArpgColor backgroundColor;
    int borderWidth;
    ArpgColor borderColor;
    double scaleX;
    double scaleY;
    int order;
    int angle;
    double opacity;
    string backgroundResource;
    bool autoClip;
    bool mouseEvents;
    List<ArpgPrefabProperty> properties;
    List<ArpgNodeDefinition> nodes;
    ArpgControlEventHandlers events;

    static ArpgPrefabDefinition Create(string id, int width, int height) {
        ArpgPrefabDefinition prefab = new ArpgPrefabDefinition();
        prefab.id = id;
        prefab.width = width;
        prefab.height = height;
        prefab.anchorX = 0.0;
        prefab.anchorY = 0.0;
        prefab.backgroundColor = ArpgColor.Transparent();
        prefab.borderWidth = 0;
        prefab.borderColor = ArpgColor.Transparent();
        prefab.scaleX = 1.0;
        prefab.scaleY = 1.0;
        prefab.order = 0;
        prefab.angle = 0;
        prefab.opacity = 1.0;
        prefab.backgroundResource = "";
        prefab.autoClip = false;
        prefab.mouseEvents = false;
        prefab.properties = new List<ArpgPrefabProperty>();
        prefab.nodes = new List<ArpgNodeDefinition>();
        prefab.events = ArpgControlEventHandlers.Create();
        return prefab;
    }

    string Id() { return this.id; }
    int Width() { return this.width; }
    int Height() { return this.height; }
    double AnchorX() { return this.anchorX; }
    double AnchorY() { return this.anchorY; }
    ArpgColor BackgroundColor() { return this.backgroundColor; }
    int BorderWidth() { return this.borderWidth; }
    ArpgColor BorderColor() { return this.borderColor; }
    double ScaleX() { return this.scaleX; }
    double ScaleY() { return this.scaleY; }
    int Order() { return this.order; }
    int Angle() { return this.angle; }
    double Opacity() { return this.opacity; }
    string BackgroundResource() { return this.backgroundResource; }
    bool AutoClip() { return this.autoClip; }
    bool MouseEvents() { return this.mouseEvents; }
    int NodeCount() { return this.nodes.Count; }
    ArpgNodeDefinition NodeAt(int index) { return this.nodes[index]; }
    ArpgControlEventHandlers Events() { return this.events; }

    void SetAnchor(double x, double y) {
        this.anchorX = x;
        this.anchorY = y;
    }
    void SetBackgroundColor(ArpgColor newValue) { this.backgroundColor = newValue; }
    void SetBorder(int width, ArpgColor color) {
        this.borderWidth = width;
        this.borderColor = color;
    }
    void SetScale(double x, double y) {
        this.scaleX = x;
        this.scaleY = y;
    }
    void SetOrder(int newValue) { this.order = newValue; }
    void SetAngle(int newValue) { this.angle = newValue; }
    void SetOpacity(double newValue) {
        this.opacity = ArpgMath.ClampDouble(newValue, 0.0, 1.0);
    }
    void SetBackgroundResource(string newValue) { this.backgroundResource = newValue; }
    void SetAutoClip(bool newValue) { this.autoClip = newValue; }
    void SetMouseEvents(bool newValue) { this.mouseEvents = newValue; }
    void AddProperty(string name, string defaultValue) {
        this.properties.Add(ArpgPrefabProperty.Create(name, defaultValue));
    }
    int PropertyCount() { return this.properties.Count; }
    ArpgPrefabProperty PropertyAt(int index) { return this.properties[index]; }
    void AddNode(ArpgNodeDefinition node) { this.nodes.Add(node); }

    void Validate(ArpgDiagnostics diagnostics) {
        string path = "prefabs." + this.id;
        ArpgValidation.Required(diagnostics, this.id, "prefabs", "L2PFB001");
        ArpgValidation.Positive(
            diagnostics, this.width, path + ".width", "L2PFB002");
        ArpgValidation.Positive(
            diagnostics, this.height, path + ".height", "L2PFB003");
        if (this.scaleX <= 0.0 || this.scaleY <= 0.0) {
            diagnostics.AddError(
                "L2PFB004", path + ".scale", "Prefab scale must be greater than zero.");
        }
        int i = 0;
        while (i < this.properties.Count) {
            ArpgValidation.Required(
                diagnostics,
                this.properties[i].Name(),
                path + ".properties",
                "L2PFB005");
            int j = i + 1;
            while (j < this.properties.Count) {
                if (this.properties[i].Name() == this.properties[j].Name()) {
                    diagnostics.AddError(
                        "L2PFB006", path + ".properties", "Duplicate prefab property.");
                }
                j = j + 1;
            }
            i = i + 1;
        }
        i = 0;
        while (i < this.nodes.Count) {
            this.nodes[i].Validate(diagnostics, path);
            int j = i + 1;
            while (j < this.nodes.Count) {
                if (this.nodes[i].Id() == this.nodes[j].Id()) {
                    diagnostics.AddError(
                        "L2PFB007", path + ".nodes", "Duplicate node id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }
    }
}
