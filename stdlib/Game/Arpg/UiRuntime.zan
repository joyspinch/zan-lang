using System;

namespace Game.Arpg;

delegate void ArpgNodeCreated(string nodeId);
delegate void ArpgNodeUpdated(string nodeId, int deltaMilliseconds);
delegate bool ArpgNodePointerChanged(
    string nodeId,
    int button,
    int modifiers,
    double x,
    double y);
delegate void ArpgNodeFocusChanged(string nodeId, bool focused);
delegate void ArpgNodeCustomEvent(
    string nodeId,
    string name,
    string payload);

delegate void ArpgControlCreated(string controlId);
delegate void ArpgControlUpdated(string controlId, int deltaMilliseconds);
delegate bool ArpgControlPointerChanged(
    string controlId,
    string nodeId,
    int button,
    int modifiers,
    double x,
    double y);
delegate void ArpgControlFocusChanged(string controlId, bool focused);
delegate void ArpgControlDragged(
    string controlId,
    double deltaX,
    double deltaY);
delegate void ArpgControlLinkActivated(
    string controlId,
    string link);
delegate void ArpgControlCustomEvent(
    string controlId,
    string name,
    string payload);

delegate void ArpgWindowCreated(string windowId);
delegate void ArpgWindowVisibilityChanged(string windowId);
delegate void ArpgWindowUpdated(string windowId, int deltaMilliseconds);
delegate bool ArpgWindowPointerChanged(
    string windowId,
    string controlId,
    int button,
    int modifiers,
    double x,
    double y);
delegate void ArpgWindowCustomEvent(
    string windowId,
    string name,
    string payload);

class ArpgNodeEventHandlers {
    ArpgNodeCreated created;
    ArpgNodeUpdated updated;
    ArpgNodePointerChanged pointerDown;
    ArpgNodePointerChanged pointerUp;
    ArpgNodePointerChanged pointerMove;
    ArpgNodeFocusChanged focusChanged;
    ArpgNodeCustomEvent customEvent;

    static ArpgNodeEventHandlers Create() {
        return new ArpgNodeEventHandlers();
    }

    void OnCreated(ArpgNodeCreated handler) { this.created = handler; }
    void OnUpdated(ArpgNodeUpdated handler) { this.updated = handler; }
    void OnPointerDown(ArpgNodePointerChanged handler) {
        this.pointerDown = handler;
    }
    void OnPointerUp(ArpgNodePointerChanged handler) {
        this.pointerUp = handler;
    }
    void OnPointerMove(ArpgNodePointerChanged handler) {
        this.pointerMove = handler;
    }
    void OnFocusChanged(ArpgNodeFocusChanged handler) {
        this.focusChanged = handler;
    }
    void OnCustomEvent(ArpgNodeCustomEvent handler) {
        this.customEvent = handler;
    }

    void RaiseCreated(string nodeId) {
        ArpgNodeCreated handler = this.created;
        if (handler != null) { handler(nodeId); }
    }

    void RaiseUpdated(string nodeId, int deltaMilliseconds) {
        ArpgNodeUpdated handler = this.updated;
        if (handler != null) { handler(nodeId, deltaMilliseconds); }
    }

    bool RaisePointerDown(
        string nodeId,
        int button,
        int modifiers,
        double x,
        double y
    ) {
        ArpgNodePointerChanged handler = this.pointerDown;
        if (handler == null) { return false; }
        return handler(nodeId, button, modifiers, x, y);
    }

    bool RaisePointerUp(
        string nodeId,
        int button,
        int modifiers,
        double x,
        double y
    ) {
        ArpgNodePointerChanged handler = this.pointerUp;
        if (handler == null) { return false; }
        return handler(nodeId, button, modifiers, x, y);
    }

    bool RaisePointerMove(
        string nodeId,
        int button,
        int modifiers,
        double x,
        double y
    ) {
        ArpgNodePointerChanged handler = this.pointerMove;
        if (handler == null) { return false; }
        return handler(nodeId, button, modifiers, x, y);
    }

    void RaiseFocusChanged(string nodeId, bool focused) {
        ArpgNodeFocusChanged handler = this.focusChanged;
        if (handler != null) { handler(nodeId, focused); }
    }

    void RaiseCustom(string nodeId, string name, string payload) {
        ArpgNodeCustomEvent handler = this.customEvent;
        if (handler != null) { handler(nodeId, name, payload); }
    }
}
