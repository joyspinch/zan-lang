using System;
using Game.Arpg;
using SDL3;

namespace Game.Arpg.Fonts;

class ArpgGuiTextBackend {
    [DllImport("zan_gui")]
    static extern int zan_gui_create_surface(int width, int height);

    [DllImport("zan_gui")]
    static extern void zan_gui_destroy_surface(int id);

    [DllImport("zan_gui")]
    static extern void zan_gui_clear(int surfaceId, int color);

    [DllImport("zan_gui")]
    static extern void zan_gui_draw_text(
        int surfaceId,
        int x,
        int y,
        string text,
        int color,
        int fontSize);

    [DllImport("zan_gui")]
    static extern int zan_gui_measure_text(string text, int fontSize);

    [DllImport("zan_gui")]
    static extern int zan_gui_font_height(int fontSize);

    [DllImport("zan_gui")]
    static extern string zan_gui_get_pixels(int surfaceId);

    static int CanvasColor(ArpgColor color) {
        return (color.Alpha() << 24)
            | (color.Blue() << 16)
            | (color.Green() << 8)
            | color.Red();
    }

    static int Measure(string text, int fontSize) {
        return zan_gui_measure_text(text, fontSize);
    }

    static int FontHeight(int fontSize) {
        return zan_gui_font_height(fontSize);
    }

    static void Draw(
        SdlRenderer renderer,
        string text,
        ArpgColor color,
        int fontSize,
        int x,
        int y,
        int width,
        int height,
        int angle
    ) {
        if (text == "" || width <= 0 || height <= 0) { return; }
        int surface = zan_gui_create_surface(width, height);
        if (surface < 0) { return; }
        zan_gui_clear(surface, 0);
        zan_gui_draw_text(
            surface, 0, 0, text, CanvasColor(color), fontSize);
        SdlTexture texture = SdlTexture.CreateRgba32(
            renderer, width, height, true);
        if (texture.IsValid()) {
            texture.Update(zan_gui_get_pixels(surface), width * 4);
            texture.SetNearest(false);
            renderer.DrawTextureRotated(
                texture, x, y, width, height, angle);
            texture.Close();
        }
        zan_gui_destroy_surface(surface);
    }

    static void Install(ArpgUiRenderer renderer) {
        renderer.SetTextBackend(
            ArpgGuiTextBackend.Measure,
            ArpgGuiTextBackend.FontHeight,
            ArpgGuiTextBackend.Draw);
    }
}
