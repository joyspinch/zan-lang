using System;
using System.Collections.Generic;

namespace Game.Zgm;

class ZgmDiagnostic {
    string code;
    string path;
    string message;
    bool error;

    static ZgmDiagnostic Create(
        string code,
        string path,
        string message,
        bool error
    ) {
        ZgmDiagnostic d = new ZgmDiagnostic();
        d.code = code;
        d.path = path;
        d.message = message;
        d.error = error;
        return d;
    }

    string Code() { return this.code; }
    string Path() { return this.path; }
    string Message() { return this.message; }
    bool IsError() { return this.error; }
}

class ZgmDiagnostics {
    List<ZgmDiagnostic> items;

    static ZgmDiagnostics Create() {
        ZgmDiagnostics d = new ZgmDiagnostics();
        d.items = new List<ZgmDiagnostic>();
        return d;
    }

    void AddError(string code, string path, string message) {
        this.items.Add(ZgmDiagnostic.Create(code, path, message, true));
    }
    void AddWarning(string code, string path, string message) {
        this.items.Add(ZgmDiagnostic.Create(code, path, message, false));
    }
    int Count() { return this.items.Count; }
    ZgmDiagnostic At(int index) { return this.items[index]; }

    int ErrorCount() {
        int count = 0;
        int i = 0;
        while (i < this.items.Count) {
            if (this.items[i].IsError()) { count = count + 1; }
            i = i + 1;
        }
        return count;
    }
    bool HasErrors() { return this.ErrorCount() > 0; }
}

// In-memory ZGM component database. Registering a component with an existing
// name replaces the previous definition, matching the documented component
// overwrite behavior.
class ZgmProject {
    AppConfig app;
    List<MapConfig> maps;
    List<NpcConfig> npcs;
    List<ItemConfig> items;
    List<SkillConfig> skills;
    List<BuffConfig> buffs;
    List<WindowConfig> windows;
    List<LevelGrowth> growths;
    List<PrefabConfig> prefabs;
    List<Skin> skins;
    List<TcpClientConfig> tcpClients;
    List<WebSocketClientConfig> webSockets;
    List<SqliteComponentConfig> databases;
    ServerConfig server;

    static ZgmProject Create() {
        ZgmProject project = new ZgmProject();
        project.app = AppConfig.Create();
        project.maps = new List<MapConfig>();
        project.npcs = new List<NpcConfig>();
        project.items = new List<ItemConfig>();
        project.skills = new List<SkillConfig>();
        project.buffs = new List<BuffConfig>();
        project.windows = new List<WindowConfig>();
        project.growths = new List<LevelGrowth>();
        project.prefabs = new List<PrefabConfig>();
        project.skins = new List<Skin>();
        project.tcpClients = new List<TcpClientConfig>();
        project.webSockets = new List<WebSocketClientConfig>();
        project.databases = new List<SqliteComponentConfig>();
        project.server = null;
        return project;
    }

    ZgmProject SetApp(AppConfig app) {
        if (app != null) { this.app = app; }
        return this;
    }
    AppConfig App() { return this.app; }

    ZgmProject AddMap(MapConfig component) {
        int index = this.MapIndex(component.Name());
        if (index < 0) { this.maps.Add(component); } else { this.maps[index] = component; }
        return this;
    }
    ZgmProject AddNpc(NpcConfig component) {
        int index = this.NpcIndex(component.Name());
        if (index < 0) { this.npcs.Add(component); } else { this.npcs[index] = component; }
        return this;
    }
    ZgmProject AddItem(ItemConfig component) {
        int index = this.ItemIndex(component.Name());
        if (index < 0) { this.items.Add(component); } else { this.items[index] = component; }
        return this;
    }
    ZgmProject AddSkill(SkillConfig component) {
        int index = this.SkillIndex(component.Name());
        if (index < 0) { this.skills.Add(component); } else { this.skills[index] = component; }
        return this;
    }
    ZgmProject AddBuff(BuffConfig component) {
        int index = this.BuffIndex(component.Name());
        if (index < 0) { this.buffs.Add(component); } else { this.buffs[index] = component; }
        return this;
    }
    ZgmProject AddWindow(WindowConfig component) {
        int index = this.WindowIndex(component.Name());
        if (index < 0) { this.windows.Add(component); } else { this.windows[index] = component; }
        return this;
    }
    ZgmProject AddGrowth(LevelGrowth component) {
        int index = this.GrowthIndex(component.Name());
        if (index < 0) { this.growths.Add(component); } else { this.growths[index] = component; }
        return this;
    }
    ZgmProject AddPrefab(PrefabConfig component) {
        int index = this.PrefabIndex(component.Name());
        if (index < 0) { this.prefabs.Add(component); } else { this.prefabs[index] = component; }
        return this;
    }
    ZgmProject AddSkin(Skin component) {
        int index = this.SkinIndex(component.Name());
        if (index < 0) { this.skins.Add(component); } else { this.skins[index] = component; }
        return this;
    }
    ZgmProject AddTcpClient(TcpClientConfig component) {
        int index = this.TcpClientIndex(component.Name());
        if (index < 0) {
            this.tcpClients.Add(component);
        } else {
            this.tcpClients[index] = component;
        }
        return this;
    }
    ZgmProject AddWebSocket(WebSocketClientConfig component) {
        int index = this.WebSocketIndex(component.Name());
        if (index < 0) {
            this.webSockets.Add(component);
        } else {
            this.webSockets[index] = component;
        }
        return this;
    }
    ZgmProject AddDatabase(SqliteComponentConfig component) {
        int index = this.DatabaseIndex(component.Name());
        if (index < 0) {
            this.databases.Add(component);
        } else {
            this.databases[index] = component;
        }
        return this;
    }
    ZgmProject SetServer(ServerConfig component) {
        this.server = component;
        return this;
    }

    int MapIndex(string name) {
        int i = 0;
        while (i < this.maps.Count) {
            if (this.maps[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int NpcIndex(string name) {
        int i = 0;
        while (i < this.npcs.Count) {
            if (this.npcs[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int ItemIndex(string name) {
        int i = 0;
        while (i < this.items.Count) {
            if (this.items[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int SkillIndex(string name) {
        int i = 0;
        while (i < this.skills.Count) {
            if (this.skills[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int BuffIndex(string name) {
        int i = 0;
        while (i < this.buffs.Count) {
            if (this.buffs[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int WindowIndex(string name) {
        int i = 0;
        while (i < this.windows.Count) {
            if (this.windows[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int GrowthIndex(string name) {
        int i = 0;
        while (i < this.growths.Count) {
            if (this.growths[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int PrefabIndex(string name) {
        int i = 0;
        while (i < this.prefabs.Count) {
            if (this.prefabs[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int SkinIndex(string name) {
        int i = 0;
        while (i < this.skins.Count) {
            if (this.skins[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int TcpClientIndex(string name) {
        int i = 0;
        while (i < this.tcpClients.Count) {
            if (this.tcpClients[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int WebSocketIndex(string name) {
        int i = 0;
        while (i < this.webSockets.Count) {
            if (this.webSockets[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }
    int DatabaseIndex(string name) {
        int i = 0;
        while (i < this.databases.Count) {
            if (this.databases[i].Name() == name) { return i; }
            i = i + 1;
        }
        return -1;
    }

    MapConfig FindMap(string name) {
        int index = this.MapIndex(name);
        if (index < 0) { return null; }
        return this.maps[index];
    }
    NpcConfig FindNpc(string name) {
        int index = this.NpcIndex(name);
        if (index < 0) { return null; }
        return this.npcs[index];
    }
    ItemConfig FindItem(string name) {
        int index = this.ItemIndex(name);
        if (index < 0) { return null; }
        return this.items[index];
    }
    SkillConfig FindSkill(string name) {
        int index = this.SkillIndex(name);
        if (index < 0) { return null; }
        return this.skills[index];
    }
    BuffConfig FindBuff(string name) {
        int index = this.BuffIndex(name);
        if (index < 0) { return null; }
        return this.buffs[index];
    }
    WindowConfig FindWindow(string name) {
        int index = this.WindowIndex(name);
        if (index < 0) { return null; }
        return this.windows[index];
    }
    LevelGrowth FindGrowth(string name) {
        int index = this.GrowthIndex(name);
        if (index < 0) { return null; }
        return this.growths[index];
    }
    PrefabConfig FindPrefab(string name) {
        int index = this.PrefabIndex(name);
        if (index < 0) { return null; }
        return this.prefabs[index];
    }
    Skin FindSkin(string name) {
        int index = this.SkinIndex(name);
        if (index < 0) { return null; }
        return this.skins[index];
    }
    TcpClientConfig FindTcpClient(string name) {
        int index = this.TcpClientIndex(name);
        if (index < 0) { return null; }
        return this.tcpClients[index];
    }
    WebSocketClientConfig FindWebSocket(string name) {
        int index = this.WebSocketIndex(name);
        if (index < 0) { return null; }
        return this.webSockets[index];
    }
    SqliteComponentConfig FindDatabase(string name) {
        int index = this.DatabaseIndex(name);
        if (index < 0) { return null; }
        return this.databases[index];
    }

    MapConfig DefaultMap() {
        int i = 0;
        while (i < this.maps.Count) {
            if (this.maps[i].IsDefault()) { return this.maps[i]; }
            i = i + 1;
        }
        if (this.maps.Count > 0) { return this.maps[0]; }
        return null;
    }
    NpcConfig Hero() {
        int i = 0;
        while (i < this.npcs.Count) {
            if (this.npcs[i].IsHero()) { return this.npcs[i]; }
            i = i + 1;
        }
        return null;
    }

    int MapCount() { return this.maps.Count; }
    int NpcCount() { return this.npcs.Count; }
    int ItemCount() { return this.items.Count; }
    int SkillCount() { return this.skills.Count; }
    int BuffCount() { return this.buffs.Count; }
    int WindowCount() { return this.windows.Count; }
    int GrowthCount() { return this.growths.Count; }
    int PrefabCount() { return this.prefabs.Count; }
    int SkinCount() { return this.skins.Count; }
    int TcpClientCount() { return this.tcpClients.Count; }
    int WebSocketCount() { return this.webSockets.Count; }
    int DatabaseCount() { return this.databases.Count; }
    ServerConfig Server() { return this.server; }
    MapConfig MapAt(int index) { return this.maps[index]; }
    NpcConfig NpcAt(int index) { return this.npcs[index]; }
    ItemConfig ItemAt(int index) { return this.items[index]; }
    SkillConfig SkillAt(int index) { return this.skills[index]; }
    BuffConfig BuffAt(int index) { return this.buffs[index]; }
    WindowConfig WindowAt(int index) { return this.windows[index]; }
    LevelGrowth GrowthAt(int index) { return this.growths[index]; }
    PrefabConfig PrefabAt(int index) { return this.prefabs[index]; }
    Skin SkinAt(int index) { return this.skins[index]; }
    TcpClientConfig TcpClientAt(int index) {
        return this.tcpClients[index];
    }
    WebSocketClientConfig WebSocketAt(int index) {
        return this.webSockets[index];
    }
    SqliteComponentConfig DatabaseAt(int index) {
        return this.databases[index];
    }

    ZgmDiagnostics Validate() {
        ZgmDiagnostics diagnostics = ZgmDiagnostics.Create();
        if (this.app == null || !this.app.IsValid()) {
            diagnostics.AddError(
                "ZGM001", "app", "Application configuration is invalid.");
        }

        int defaults = 0;
        int i = 0;
        while (i < this.maps.Count) {
            MapConfig map = this.maps[i];
            if (map.IsDefault()) { defaults = defaults + 1; }
            if (map.Columns() <= 0 || map.Rows() <= 0) {
                diagnostics.AddError(
                    "ZGM002", "maps." + map.Name(),
                    "Map grid dimensions must be positive.");
            }
            int s = 0;
            while (s < map.SpawnCount()) {
                MapSpawn spawn = map.SpawnAt(s);
                if (this.FindNpc(spawn.Name()) == null) {
                    diagnostics.AddError(
                        "ZGM003", "maps." + map.Name() + ".spawns",
                        "Spawn references an unknown role component.");
                }
                if (!map.IsInside(spawn.X(), spawn.Y())) {
                    diagnostics.AddError(
                        "ZGM013", "maps." + map.Name() + ".spawns",
                        "Spawn position is outside the map grid.");
                }
                if (spawn.Range() < 0 || spawn.Count() <= 0) {
                    diagnostics.AddError(
                        "ZGM014", "maps." + map.Name() + ".spawns",
                        "Spawn range must be nonnegative and count positive.");
                }
                s = s + 1;
            }
            int p = 0;
            while (p < map.PortalCount()) {
                MapPortal portal = map.PortalAt(p);
                if (!map.IsInside(portal.X(), portal.Y())) {
                    diagnostics.AddError(
                        "ZGM015", "maps." + map.Name() + ".portals",
                        "Portal source position is outside the map grid.");
                }
                if (this.FindMap(portal.TargetMap()) == null) {
                    diagnostics.AddError(
                        "ZGM004", "maps." + map.Name() + ".portals",
                        "Portal references an unknown target map.");
                } else {
                    MapConfig target = this.FindMap(portal.TargetMap());
                    if (!target.IsInside(
                        portal.TargetX(), portal.TargetY())) {
                        diagnostics.AddError(
                            "ZGM016", "maps." + map.Name() + ".portals",
                            "Portal target position is outside the target map.");
                    }
                }
                p = p + 1;
            }
            i = i + 1;
        }
        if (this.maps.Count > 0 && defaults == 0) {
            diagnostics.AddWarning(
                "ZGM005", "maps", "No default map; the first map will be used.");
        }
        if (defaults > 1) {
            diagnostics.AddError(
                "ZGM006", "maps", "Only one map may be the default map.");
        }

        int heroes = 0;
        i = 0;
        while (i < this.npcs.Count) {
            NpcConfig npc = this.npcs[i];
            if (npc.IsHero()) { heroes = heroes + 1; }
            if (npc.DropChance() < 0 || npc.DropChance() > 100) {
                diagnostics.AddError(
                    "ZGM017", "roles." + npc.Name() + ".dropChance",
                    "Drop chance must be between 0 and 100.");
            }
            if (npc.Growth() != "" && this.FindGrowth(npc.Growth()) == null) {
                diagnostics.AddError(
                    "ZGM007", "roles." + npc.Name() + ".growth",
                    "Role references an unknown growth component.");
            }
            int e = 0;
            while (e < npc.EquipCount()) {
                if (this.FindItem(npc.EquipAt(e).ItemName()) == null) {
                    diagnostics.AddError(
                        "ZGM008", "roles." + npc.Name() + ".equipment",
                        "Equipment references an unknown item component.");
                }
                e = e + 1;
            }
            int s = 0;
            while (s < npc.SkillCount()) {
                if (this.FindSkill(npc.SkillAt(s)) == null) {
                    diagnostics.AddError(
                        "ZGM010", "roles." + npc.Name() + ".skills",
                        "Role references an unknown skill component.");
                }
                s = s + 1;
            }
            int d = 0;
            while (d < npc.DropCount()) {
                DropEntry drop = npc.DropAt(d);
                if (this.FindItem(drop.ItemName()) == null) {
                    diagnostics.AddError(
                        "ZGM018", "roles." + npc.Name() + ".drops",
                        "Drop references an unknown item component.");
                }
                if (drop.Count() <= 0 || drop.ChanceMax() <= 0) {
                    diagnostics.AddError(
                        "ZGM019", "roles." + npc.Name() + ".drops",
                        "Drop count and chance denominator must be positive.");
                }
                d = d + 1;
            }
            i = i + 1;
        }
        if (heroes > 1) {
            diagnostics.AddError(
                "ZGM009", "roles", "Only one role may be the default hero.");
        }
        if (this.app != null) {
            i = 0;
            while (i < this.app.EquipSetCount()) {
                EquipSet suit = this.app.EquipSetAt(i);
                int p = 0;
                while (p < suit.PartCount()) {
                    if (this.FindItem(suit.PartAt(p)) == null) {
                        diagnostics.AddError(
                            "ZGM012", "app.equipmentSets." + suit.Name(),
                            "Equipment set references an unknown item component.");
                    }
                    p = p + 1;
                }
                i = i + 1;
            }
        }
        i = 0;
        while (i < this.skills.Count) {
            SkillConfig skill = this.skills[i];
            int b = 0;
            while (b < skill.BuffCount()) {
                if (this.FindBuff(skill.BuffAt(b)) == null) {
                    diagnostics.AddError(
                        "ZGM011", "skills." + skill.Name() + ".buffs",
                        "Skill references an unknown status component.");
                }
                b = b + 1;
            }
            i = i + 1;
        }
        i = 0;
        while (i < this.windows.Count) {
            WindowConfig window = this.windows[i];
            if (window.Width() <= 0 || window.Height() <= 0) {
                diagnostics.AddError(
                    "ZGM020", "windows." + window.Name(),
                    "Window dimensions must be positive.");
            }
            if (window.SkinName() != ""
                && window.SkinName() != "无"
                && this.FindSkin(window.SkinName()) == null) {
                diagnostics.AddError(
                    "ZGM021", "windows." + window.Name() + ".skin",
                    "Window references an unknown skin component.");
            }
            int w = 0;
            while (w < window.WidgetCount()) {
                Widget widget = window.WidgetAt(w);
                if (widget.Name() == "") {
                    diagnostics.AddError(
                        "ZGM022", "windows." + window.Name() + ".widgets",
                        "Widget name must not be empty.");
                }
                int previous = 0;
                while (previous < w) {
                    if (window.WidgetAt(previous).Name() == widget.Name()) {
                        diagnostics.AddError(
                            "ZGM023",
                            "windows." + window.Name() + ".widgets",
                            "Widget names must be unique inside a window.");
                    }
                    previous = previous + 1;
                }
                w = w + 1;
            }
            int n = 0;
            while (n < window.NodeCount()) {
                Node node = window.NodeAt(n);
                if (node.Name() == "") {
                    diagnostics.AddError(
                        "ZGM024", "windows." + window.Name() + ".nodes",
                        "Node name must not be empty.");
                }
                int previousNode = 0;
                while (previousNode < n) {
                    if (window.NodeAt(previousNode).Name() == node.Name()) {
                        diagnostics.AddError(
                            "ZGM025",
                            "windows." + window.Name() + ".nodes",
                            "Node names must be unique inside a window.");
                    }
                    previousNode = previousNode + 1;
                }
                n = n + 1;
            }
            i = i + 1;
        }
        return diagnostics;
    }
    void Dispose() {
        if (this.app != null) { this.app.Dispose(); }
        int i = 0;
        while (i < this.growths.Count) {
            this.growths[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.items.Count) {
            this.items[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.skills.Count) {
            this.skills[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.buffs.Count) {
            this.buffs[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.npcs.Count) {
            this.npcs[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.maps.Count) {
            this.maps[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.windows.Count) {
            this.windows[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.prefabs.Count) {
            this.prefabs[i].Dispose();
            i = i + 1;
        }
        i = 0;
        while (i < this.skins.Count) {
            this.skins[i].Dispose();
            i = i + 1;
        }
        this.app = null;
        this.maps.Clear();
        this.npcs.Clear();
        this.items.Clear();
        this.skills.Clear();
        this.buffs.Clear();
        this.windows.Clear();
        this.growths.Clear();
        this.prefabs.Clear();
        this.skins.Clear();
        this.tcpClients.Clear();
        this.webSockets.Clear();
        this.databases.Clear();
        this.maps = null;
        this.npcs = null;
        this.items = null;
        this.skills = null;
        this.buffs = null;
        this.windows = null;
        this.growths = null;
        this.prefabs = null;
        this.skins = null;
        this.tcpClients = null;
        this.webSockets = null;
        this.databases = null;
        this.server = null;
    }
}
