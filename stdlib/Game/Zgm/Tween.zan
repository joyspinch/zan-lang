using System;
using System.Collections.Generic;

namespace Game.Zgm;

// 缓动类型 (easing curve). Created at runtime via 引擎.创建缓动; this enumerates
// the documented curve set. Each family has _in / _out / _inOut variants.
enum Easing {
    Linear,
    QuadIn, QuadOut, QuadInOut,           // 二次方
    CubicIn, CubicOut, CubicInOut,        // 三次方
    QuartIn, QuartOut, QuartInOut,        // 四次方
    QuintIn, QuintOut, QuintInOut,        // 五次方
    SineIn, SineOut, SineInOut,           // 正弦曲线
    ExpoIn, ExpoOut, ExpoInOut,           // 指数曲线
    CircIn, CircOut, CircInOut,           // 圆形曲线
    ElasticIn, ElasticOut, ElasticInOut,  // 曲线衰减
    BackIn, BackOut, BackInOut,           // 后移衰减
    BounceIn, BounceOut, BounceInOut      // 反弹衰减
}

// A single animated property target: name = final value (for `to`) or delta
// (for `by`).
class TweenTarget {
    string prop;   // property name, e.g. "x" / "y" / "透明度"
    double amount; // target value

    static TweenTarget Of(string prop, double amount) {
        TweenTarget t = new TweenTarget();
        t.prop = prop;
        t.amount = amount;
        return t;
    }
    string Prop() { return this.prop; }
    double Amount() { return this.amount; }
}

// One step in a 缓动 timeline. Kinds mirror the tween methods:
//   to   — animate a target object's properties to absolute values
//   by   — animate by relative deltas
//   wait — delay
//   call — invoke a named callback
class TweenStep {
    string op;               // "to" / "by" / "wait" / "call"
    string target;           // target object identifier (to/by)
    List<TweenTarget> props; // property targets (to/by)
    int duration;            // duration in ms (to/by/wait)
    Easing easing;           // 缓动类型 (to/by)
    string callback;         // callback id (call)

    static TweenStep To(string target, int duration, Easing easing) {
        TweenStep s = new TweenStep();
        s.op = "to";
        s.target = target;
        s.props = new List<TweenTarget>();
        s.duration = duration;
        s.easing = easing;
        s.callback = "";
        return s;
    }
    static TweenStep By(string target, int duration, Easing easing) {
        TweenStep s = TweenStep.To(target, duration, easing);
        s.op = "by";
        return s;
    }
    static TweenStep Wait(int duration) {
        TweenStep s = new TweenStep();
        s.op = "wait";
        s.target = "";
        s.props = new List<TweenTarget>();
        s.duration = duration;
        s.easing = Easing.Linear;
        s.callback = "";
        return s;
    }
    static TweenStep Call(string callback) {
        TweenStep s = new TweenStep();
        s.op = "call";
        s.target = "";
        s.props = new List<TweenTarget>();
        s.duration = 0;
        s.easing = Easing.Linear;
        s.callback = callback;
        return s;
    }

    TweenStep Set(string prop, double amount) {
        this.props.Add(TweenTarget.Of(prop, amount));
        return this;
    }
    string Op() { return this.op; }
    string Target() { return this.target; }
    int Duration() { return this.duration; }
    Easing Curve() { return this.easing; }
    string Callback() { return this.callback; }
    int PropCount() { return this.props.Count; }
    TweenTarget PropAt(int index) { return this.props[index]; }

    void Dispose() {
        this.props.Clear();
        this.props = null;
        this.op = null;
        this.target = null;
        this.callback = null;
    }
}

// 缓动 (tween timeline): a chain of steps executed in order.
class Tween {
    List<TweenStep> steps;

    static Tween Create() {
        Tween t = new Tween();
        t.steps = new List<TweenStep>();
        return t;
    }

    Tween Add(TweenStep step) { this.steps.Add(step); return this; }
    int StepCount() { return this.steps.Count; }
    TweenStep StepAt(int index) {
        if (index < 0 || index >= this.steps.Count) { return null; }
        return this.steps[index];
    }

    // Total scheduled duration across all steps (ms).
    int TotalDuration() {
        int total = 0;
        int i = 0;
        while (i < this.steps.Count) {
            TweenStep s = this.steps[i];
            total = total + s.Duration();
            i = i + 1;
        }
        return total;
    }

    void Dispose() {
        int i = 0;
        while (i < this.steps.Count) {
            this.steps[i].Dispose();
            i = i + 1;
        }
        this.steps.Clear();
        this.steps = null;
    }
}
