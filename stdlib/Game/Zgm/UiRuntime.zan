    bool BindHeroQuickBox(
        string windowName,
        string widgetName,
        string sourceKind,
        string sourceName
    ) {
        ZgmWidgetState widget = this.FindWidget(windowName, widgetName);
        if (widget == null) { return false; }
        this.RemoveWidgetBinding(windowName, widgetName);
        ZgmWidgetBinding binding = ZgmWidgetBinding.Create(
            windowName, widgetName, "quick");
        binding.sourceName = sourceKind + ":" + sourceName;
        this.bindings.Add(binding);
