    int ItemCooldown(ZgmActor actor, ItemConfig item) {
        if (actor == null || item == null || item.CooldownId() == "") {
            return 0;
        }
        return actor.Cooldowns().Remaining(
            "item:" + item.CooldownId());
    }
    bool MatchItem(
        ItemConfig item,
        string category,
        string subtype
    ) {
        if (item == null) { return false; }
        if (category != "" && item.Category() != category) {
            return false;
        }
        if (subtype != "" && item.SubtypeFine() != subtype) {
            return false;
        }
        return true;
    }
    ZgmWidgetBinding FindBinding(
        string windowName,
        string widgetName
    ) {
        int i = 0;
        while (i < this.bindings.Count) {
            ZgmWidgetBinding binding = this.bindings[i];
            if (binding.WindowName() == windowName
                && binding.WidgetName() == widgetName) {
                return binding;
            }
            i = i + 1;
        }
        return null;
    }
    ZgmInventory BoundBagInventory(
        string windowName,
        string widgetName
    ) {
        ZgmWidgetBinding binding = this.FindBinding(
            windowName, widgetName);
        if (binding == null || binding.Mode() != "bag") {
            return null;
        }
        ZgmActor hero = this.world.Hero();
        if (hero == null) { return null; }
        return hero.Inventory();
    }
    int BoundBagSlotCount(
        string windowName,
        string widgetName
    ) {
        ZgmWidgetBinding binding = this.FindBinding(
            windowName, widgetName);
        ZgmActor hero = this.world.Hero();
        if (binding == null || binding.Mode() != "bag"
            || hero == null) {
            return 0;
        }
        int count = 0;
        int i = 0;
        while (i < hero.Inventory().StackCount()) {
            if (this.MatchItem(
                hero.Inventory().StackAt(i).Item(),
                binding.limitCategory,
                binding.limitSubtype)) {
                count = count + 1;
            }
            i = i + 1;
        }
        return count;
    }
    string BoundBagItemNameAt(
        string windowName,
        string widgetName,
        int index
    ) {
        ZgmWidgetBinding binding = this.FindBinding(
            windowName, widgetName);
        ZgmActor hero = this.world.Hero();
        if (binding == null || binding.Mode() != "bag"
            || hero == null || index < 0) {
            return "";
        }
        int matchingIndex = 0;
        int i = 0;
        while (i < hero.Inventory().StackCount()) {
            ZgmItemStack stack = hero.Inventory().StackAt(i);
            if (this.MatchItem(
                stack.Item(),
                binding.limitCategory,
                binding.limitSubtype)) {
                if (matchingIndex == index) {
                    return stack.Item().Name();
                }
                matchingIndex = matchingIndex + 1;
            }
            i = i + 1;
        }
        return "";
    }
    int BoundBagQuantityAt(
        string windowName,
        string widgetName,
        int index
    ) {
        ZgmWidgetBinding binding = this.FindBinding(
            windowName, widgetName);
        ZgmActor hero = this.world.Hero();
        if (binding == null || binding.Mode() != "bag"
            || hero == null || index < 0) {
            return 0;
        }
        int matchingIndex = 0;
        int i = 0;
        while (i < hero.Inventory().StackCount()) {
            ZgmItemStack stack = hero.Inventory().StackAt(i);
            if (this.MatchItem(
                stack.Item(),
                binding.limitCategory,
                binding.limitSubtype)) {
                if (matchingIndex == index) {
                    return stack.Quantity();
                }
                matchingIndex = matchingIndex + 1;
            }
            i = i + 1;
        }
        return 0;
    }
    void ApplyWidgetBinding(ZgmWidgetBinding binding) {
        if (binding == null) { return; }
        ZgmWidgetState widget = this.FindWidget(
            binding.WindowName(), binding.WidgetName());
        ZgmActor hero = this.world.Hero();
        if (widget == null || hero == null) { return; }
        if (binding.Mode() == "progress") {
            int currentValue = hero.Attribute(binding.valueAttr);
            int maximum = hero.Attribute(binding.maximumAttr);
            widget.Data().SetProgress(
                binding.valueAttr, currentValue, maximum);
        } else if (binding.Mode() == "show") {
            widget.Data().SetActor(hero, binding.showType);
        } else if (binding.Mode() == "skill") {
            SkillConfig skill = this.project.FindSkill(
                binding.sourceName);
            if (skill != null) {
                widget.Data().SetSkill(
                    skill,
                    hero.HasSkill(skill.Name()),
                    hero.Cooldowns().Remaining(
                        "skill:" + skill.Name()),
                    hero.Id());
            } else {
                widget.ClearData();
            }
        } else if (binding.Mode() == "item") {
            ItemConfig item = this.project.FindItem(binding.sourceName);
            if (item != null) {
                widget.Data().SetItem(
                    item,
                    hero.Inventory().QuantityOf(item.Name()),
                    this.ItemCooldown(hero, item),
                    hero.Id());
            } else {
                widget.ClearData();
            }
        } else if (binding.Mode() == "bag") {
            int matchingCount = this.BoundBagSlotCount(
                binding.WindowName(), binding.WidgetName());
            widget.Data().SetBag(
                hero.Id(), matchingCount, hero.Inventory().Capacity());
        } else if (binding.Mode() == "quick") {
            int separator = binding.sourceName.IndexOf(":");
            if (separator < 0) {
                widget.ClearData();
                return;
            }
            string sourceKind = binding.sourceName.Substring(0, separator);
            string sourceName = binding.sourceName.Substring(separator + 1);
            if (sourceKind == "技能") {
                SkillConfig skill = this.project.FindSkill(sourceName);
                if (skill != null) {
                    widget.Data().SetSkill(
                        skill,
                        hero.HasSkill(skill.Name()),
                        hero.Cooldowns().Remaining(
                            "skill:" + skill.Name()),
                        hero.Id());
                }
            } else {
                ItemConfig item = this.project.FindItem(sourceName);
                if (item != null) {
                    widget.Data().SetItem(
                        item,
                        hero.Inventory().QuantityOf(item.Name()),
                        this.ItemCooldown(hero, item),
                        hero.Id());
                }
            }
        }
    }
    void RefreshWidgetBindings() {
        int i = 0;
        while (i < this.bindings.Count) {
            this.ApplyWidgetBinding(this.bindings[i]);
            i = i + 1;
        }
    }
    ZgmNodeState FindNode(string windowName, string nodeName) {
        ZgmWindowState window = this.FindWindow(windowName);
        if (window == null) { return null; }
        return window.FindNode(nodeName);
    }
    bool OpenWindow(string name) {
        ZgmWindowState window = this.FindWindow(name);
        if (window == null) { return false; }
        window.Open();
        this.events.RaiseCustomEvent(name, "打开", "");
        return true;
    }
    bool CloseWindow(string name) {
        ZgmWindowState window = this.FindWindow(name);
        if (window == null) { return false; }
        window.Close();
        this.events.RaiseCustomEvent(name, "关闭", "");
        return true;
    }
    bool ToggleWindow(string name) {
        ZgmWindowState window = this.FindWindow(name);
        if (window == null) { return false; }
        window.Toggle();
        this.events.RaiseCustomEvent(name, "开关", "");
        return true;
    }
    string Render(string template) { return this.vars.Render(template); }
    void SyncWorldVars() {
        ZgmActor hero = this.world.Hero();
        if (hero == null) { return; }
        this.vars.Set("id", hero.Id());
        this.vars.Set("name", hero.DisplayName());
        this.vars.Set("名称", hero.DisplayName());
        this.vars.SetInt("level", hero.Level());
        this.vars.SetInt("等级", hero.Level());
        this.vars.SetInt("hp", hero.Hp());
        this.vars.SetInt("mp", hero.Mp());
        this.vars.SetInt("maxhp", hero.Attribute("maxhp"));
        this.vars.SetInt("maxmp", hero.Attribute("maxmp"));
        ZgmAttributes attrs = hero.EffectiveAttributes();
        int i = 0;
        while (i < attrs.Count()) {
            this.vars.SetInt(attrs.NameAt(i), attrs.AmountAt(i));
            this.vars.SetInt(
                "属性." + attrs.NameAt(i), attrs.AmountAt(i));
            i = i + 1;
        }
        this.RefreshWidgetBindings();
    }
    ZgmWindowState HitWindow(int x, int y) {
        int i = this.windows.Count - 1;
        while (i >= 0) {
            ZgmWindowState window = this.windows[i];
            if (!window.Config().ClickThrough() && window.HitTest(x, y)) {
                return window;
            }
            i = i - 1;
        }
        return null;
    }
    bool PointerDown(int x, int y) {
        this.pointerX = x;
        this.pointerY = y;
        ZgmWindowState window = this.HitWindow(x, y);
        if (window == null) {
            this.focused = null;
            this.pressed = null;
            return false;
        }
        ZgmWidgetState widget = window.HitWidget(x, y);
        this.focused = widget;
        this.pressed = widget;
        if (widget == null && window.Config().Movable()) {
            this.dragWindow = window;
        }
        string widgetName = "";
        if (widget != null) { widgetName = widget.Name(); }
        this.events.RaiseWidgetEvent(
            window.Name(), widgetName, "按下", "");
        return true;
    }
    bool PointerMove(int x, int y) {
        int dx = x - this.pointerX;
        int dy = y - this.pointerY;
        this.pointerX = x;
        this.pointerY = y;
        if (this.dragWindow != null) {
            this.dragWindow.SetPosition(
                this.dragWindow.X() + dx,
                this.dragWindow.Y() + dy);
            return true;
        }
        return this.HitWindow(x, y) != null;
    }
    bool PointerUp(int x, int y) {
        ZgmWindowState window = this.HitWindow(x, y);
        ZgmWidgetState widget = null;
        if (window != null) { widget = window.HitWidget(x, y); }
        bool activate = widget != null && widget == this.pressed;
        if (activate) {
            if (widget.Kind() == "按钮" || widget.Kind() == "选择框") {
                widget.SetSelected(!widget.Selected());
            }
            this.events.RaiseWidgetEvent(
                window.Name(), widget.Name(), "单击", "");
        }
        this.pressed = null;
        this.dragWindow = null;
        return window != null;
    }
    void StartTween(Tween tween, ZgmTweenCallback callback) {
        this.tweens.Add(ZgmTweenPlayer.Create(tween, callback));
    }
    void SetTweenProperty(
        string target,
        string prop,
        double amount,
        bool relative
    ) {
        int i = 0;
        while (i < this.windows.Count) {
            ZgmWindowState window = this.windows[i];
            if (window.Name() == target) {
                window.SetProperty(prop, amount, relative);
                return;
            }
            ZgmWidgetState widget = window.FindWidget(target);
            if (widget != null) {
                widget.SetProperty(prop, amount, relative);
                return;
            }
            ZgmNodeState node = window.FindNode(target);
            if (node != null) {
                node.SetProperty(prop, amount, relative);
                return;
            }
            i = i + 1;
        }
        i = 0;
        while (i < this.prefabs.Count) {
            ZgmPrefabInstance prefab = this.prefabs[i];
            if (prefab.Name() == target) {
                prefab.SetProperty(prop, amount, relative);
                return;
            }
            ZgmNodeState node = prefab.FindNode(target);
            if (node != null) {
                node.SetProperty(prop, amount, relative);
                return;
            }
            i = i + 1;
        }
    }
    double GetTweenProperty(string target, string prop) {
        int i = 0;
        while (i < this.windows.Count) {
            ZgmWindowState window = this.windows[i];
            if (window.Name() == target) {
                if (prop == "x") { return (double)window.X(); }
                if (prop == "y") { return (double)window.Y(); }
                if (prop == "透明度" || prop == "alpha") {
                    return window.Alpha();
                }
                return 0.0;
            }
            ZgmWidgetState widget = window.FindWidget(target);
            if (widget != null) {
                if (prop == "x") { return (double)widget.X(); }
                if (prop == "y") { return (double)widget.Y(); }
                if (prop == "宽度" || prop == "width") {
                    return (double)widget.Width();
                }
                if (prop == "高度" || prop == "height") {
                    return (double)widget.Height();
                }
                if (prop == "位置" || prop == "position") {
                    return (double)widget.Position();
                }
                if (prop == "透明度" || prop == "alpha") {
                    return widget.Alpha();
                }
                return 0.0;
            }
            ZgmNodeState node = window.FindNode(target);
            if (node != null) {
                if (prop == "x") { return (double)node.X(); }
                if (prop == "y") { return (double)node.Y(); }
                if (prop == "透明度" || prop == "alpha") {
                    return node.Alpha();
                }
                return 0.0;
            }
            i = i + 1;
        }
        i = 0;
        while (i < this.prefabs.Count) {
            ZgmPrefabInstance prefab = this.prefabs[i];
            if (prefab.Name() == target) {
                if (prop == "x") { return (double)prefab.X(); }
                if (prop == "y") { return (double)prefab.Y(); }
                if (prop == "透明度" || prop == "alpha") {
                    return prefab.Alpha();
                }
                return 0.0;
            }
            ZgmNodeState node = prefab.FindNode(target);
            if (node != null) {
                if (prop == "x") { return (double)node.X(); }
                if (prop == "y") { return (double)node.Y(); }
                if (prop == "透明度" || prop == "alpha") {
                    return node.Alpha();
                }
                return 0.0;
            }
            i = i + 1;
        }
        return 0.0;
    }
    void Update(int deltaMilliseconds) {
        this.SyncWorldVars();
        int i = this.tweens.Count - 1;
        while (i >= 0) {
            ZgmTweenPlayer player = this.tweens[i];
            player.Update(this, deltaMilliseconds);
            if (player.Finished()) { this.tweens.RemoveAt(i); }
            i = i - 1;
        }
    }
    void Dispose() {
        this.windows.Clear();
        int i = this.prefabs.Count - 1;
        while (i >= 0) {
            this.prefabs[i].Dispose();
            i = i - 1;
        }
        this.prefabs.Clear();
        this.bindings.Clear();
        this.tweens.Clear();
        this.focused = null;
        this.pressed = null;
        this.dragWindow = null;
        this.vars = null;
        this.project = null;
        this.world = null;
        this.events = null;
    }
}
