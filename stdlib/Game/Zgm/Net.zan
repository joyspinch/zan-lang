using System;
using System.Collections.Generic;

namespace Game.Zgm;

// Default message packet cap shared by the TCP client/server: 2 * 1024 * 1024.
class ZgmNetDefaults {
    static int MaxMessageLength() { return 2097152; }
}

// SqliteDB 组件配置: { 类型="Sqlite", 名称=... }. A Sqlite database component
// referenced from 扩展组件. Runtime methods (打开/执行) act on the live object.
class SqliteComponentConfig {
    string kind;   // 类型: fixed "Sqlite"
    string name;   // 名称: globally unique id

    static SqliteComponentConfig Create(string name) {
        SqliteComponentConfig c = new SqliteComponentConfig();
        c.kind = "Sqlite";
        c.name = name;
        return c;
    }
    string Kind() { return this.kind; }
    string Name() { return this.name; }
}

// ZgmTcpClient 组件配置: the client that pairs with Server.lua's ZgmTcpServer.
// Auto heartbeat + auto reconnect. { 类型, 名称, ip, 端口, 消息长度, token }.
class TcpClientConfig {
    string kind;        // 类型: fixed "ZgmTcpClient"
    string name;        // 名称: globally unique id
    string ip;          // ip: server ip
    int port;           // 端口: server port
    int messageLength;  // 消息长度, default 2*1024*1024
    int token;          // token: from the server 连接 event, default 0

    static TcpClientConfig Create(string name, string ip, int port) {
        TcpClientConfig c = new TcpClientConfig();
        c.kind = "ZgmTcpClient";
        c.name = name;
        c.ip = ip;
        c.port = port;
        c.messageLength = ZgmNetDefaults.MaxMessageLength();
        c.token = 0;
        return c;
    }
    TcpClientConfig SetMessageLength(int amount) { this.messageLength = amount; return this; }
    TcpClientConfig SetToken(int t) { this.token = t; return this; }
    string Kind() { return this.kind; }
    string Name() { return this.name; }
    string Ip() { return this.ip; }
    int Port() { return this.port; }
    int MessageLength() { return this.messageLength; }
    int Token() { return this.token; }
}

// WebSocketClient 组件配置: { 类型, 名称, 地址 }. Connects to a ws:// / wss:// url.
class WebSocketClientConfig {
    string kind;   // 类型: fixed "WebSocketClient"
    string name;   // 名称: globally unique id
    string url;    // 地址: server url (ws:// or wss://)

    static WebSocketClientConfig Create(string name) {
        WebSocketClientConfig c = new WebSocketClientConfig();
        c.kind = "WebSocketClient";
        c.name = name;
        c.url = "";
        return c;
    }
    WebSocketClientConfig SetUrl(string url) { this.url = url; return this; }
    string Kind() { return this.kind; }
    string Name() { return this.name; }
    string Url() { return this.url; }
}
