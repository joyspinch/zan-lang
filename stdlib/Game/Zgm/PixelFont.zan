using System;

namespace Game.Zgm;

// Self-contained 8x8 bitmap glyph set for ASCII 32..126, shared by every UI
// backend so text is rasterized as real glyphs (no external font asset and no
// SDL dependency, hence safe to auto-include in software / headless builds).
//
// The atlas is stored as a hex string (8 row-bytes per glyph, glyph index =
// codepoint - 32) and decoded once into a flat int[] on first use. In each row
// byte, bit 7 is the leftmost pixel column and bit 0 the rightmost.
class PixelFont {
    static int[] rows;
    static bool ready;

    static int CellW() { return 8; }
    static int CellH() { return 8; }
    // Horizontal advance per glyph in source pixels (glyphs are 8px but the
    // DejaVu mono cells sit in ~6px, so 6 keeps text tight without overlap).
    static int Advance() { return 6; }

    static string Data() {
        return "";
    }

    static int HexVal(int ch) {
        if (ch >= 48 && ch <= 57) { return ch - 48; }
        if (ch >= 97 && ch <= 102) { return ch - 97 + 10; }
        if (ch >= 65 && ch <= 70) { return ch - 65 + 10; }
        return 0;
    }

    static void Ensure() {
        if (PixelFont.ready) { return; }
        string hex = PixelFont.Data();
        int n = hex.Length / 2;
        PixelFont.rows = new int[n];
        int i = 0;
        while (i < n) {
            int hi = PixelFont.HexVal(hex[i * 2] & 255);
            int lo = PixelFont.HexVal(hex[i * 2 + 1] & 255);
            PixelFont.rows[i] = hi * 16 + lo;
            i = i + 1;
        }
        PixelFont.ready = true;
    }

    // Returns the 8-bit row mask for a codepoint & row (0..7); bit 7 is the
    // leftmost column. Codepoints outside 32..126 render blank.
    static int Row(int codepoint, int row) {
        PixelFont.Ensure();
        if (codepoint < 32 || codepoint > 126) { return 0; }
        if (row < 0 || row >= 8) { return 0; }
        int idx = (codepoint - 32) * 8 + row;
        return PixelFont.rows[idx];
    }

    // Pixel width of a string rendered at the given integer scale (>= 1).
    static int Measure(string text, int scale) {
        if (text == null) { return 0; }
        if (scale < 1) { scale = 1; }
        return text.Length * PixelFont.Advance() * scale;
    }
}
