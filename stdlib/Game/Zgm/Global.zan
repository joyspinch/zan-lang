using System;
using System.Collections.Generic;

namespace Game.Zgm;

// One typed global variable: name, string-encoded value and a kind tag
// (0 = string, 1 = int, 2 = bool). One entity instead of parallel lists.
class GlobalEntry {
    string key;
    string val;
    int kind;

    GlobalEntry(string key, string val, int kind) {
        this.key = key;
        this.val = val;
        this.kind = kind;
    }
}

// Typed process/game state shared by gameplay, UI and adapters. Values are
// intentionally enumerable so an application can serialize them externally.
class ZgmGlobals {
    List<GlobalEntry> entries;

    static ZgmGlobals Create() {
        ZgmGlobals globals = new ZgmGlobals();
        globals.entries = new List<GlobalEntry>();
        return globals;
    }

    int IndexOf(string key) {
        int i = 0;
        while (i < this.entries.Count) {
            if (this.entries[i].key == key) { return i; }
            i = i + 1;
        }
        return -1;
    }

    ZgmGlobals Put(string key, string content, int kind) {
        int index = this.IndexOf(key);
        if (index < 0) {
            this.entries.Add(new GlobalEntry(key, content, kind));
        } else {
            this.entries[index].val = content;
            this.entries[index].kind = kind;
        }
        return this;
    }

    ZgmGlobals Set(string key, string content) {
        return this.Put(key, content, 0);
    }
    ZgmGlobals SetInt(string key, int amount) {
        return this.Put(key, Convert.ToString(amount), 1);
    }
    ZgmGlobals SetBool(string key, bool enabled) {
        string text = "0";
        if (enabled) { text = "1"; }
        return this.Put(key, text, 2);
    }

    bool Contains(string key) { return this.IndexOf(key) >= 0; }
    int Count() { return this.entries.Count; }
    string KeyAt(int index) { return this.entries[index].key; }
    string ValueAt(int index) { return this.entries[index].val; }
    int KindAt(int index) { return this.entries[index].kind; }

    string Get(string key, string fallback) {
        int index = this.IndexOf(key);
        if (index < 0) { return fallback; }
        return this.entries[index].val;
    }
    int GetInt(string key, int fallback) {
        int index = this.IndexOf(key);
        if (index < 0 || this.entries[index].kind != 1) { return fallback; }
        return Convert.ToInt32(this.entries[index].val);
    }
    bool GetBool(string key, bool fallback) {
        int index = this.IndexOf(key);
        if (index < 0 || this.entries[index].kind != 2) { return fallback; }
        return this.entries[index].val == "1";
    }

    bool Remove(string key) {
        int index = this.IndexOf(key);
        if (index < 0) { return false; }
        this.entries.RemoveAt(index);
        return true;
    }
    void Clear() {
        this.entries.Clear();
    }
}
