using System;

namespace Game.Zgm;

enum MusicState {
    Stopped,
    Playing,
    Paused
}

// Renderer/audio-backend-neutral music object. An audio adapter can observe
// this state and map Play/Pause/Stop to its native mixer.
class ZgmMusic {
    string resource;
    double volume;
    double pitch;
    int channel;
    int length;
    bool loop;
    MusicState state;

    static ZgmMusic Create(string resource) {
        ZgmMusic music = new ZgmMusic();
        music.resource = resource;
        music.volume = 1.0;
        music.pitch = 1.0;
        music.channel = -1;
        music.length = 0;
        music.loop = false;
        music.state = MusicState.Stopped;
        return music;
    }
    ZgmMusic SetVolume(double volume) {
        this.volume = volume;
        return this;
    }
    ZgmMusic SetPitch(double pitch) {
        this.pitch = pitch;
        return this;
    }
    ZgmMusic SetChannel(int channel) {
        this.channel = channel;
        return this;
    }
    ZgmMusic SetLoop(bool loop) {
        this.loop = loop;
        return this;
    }
    void Play() { this.state = MusicState.Playing; }
    void Pause() {
        if (this.state == MusicState.Playing) {
            this.state = MusicState.Paused;
        }
    }
    void Stop() { this.state = MusicState.Stopped; }
    string Resource() { return this.resource; }
    double Volume() { return this.volume; }
    double Pitch() { return this.pitch; }
    int Channel() { return this.channel; }
    int Length() { return this.length; }
    bool Loop() { return this.loop; }
    MusicState State() { return this.state; }

    void Dispose() {
        this.resource = null;
    }
}
