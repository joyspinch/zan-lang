using System;
using System.Collections.Generic;

namespace Game.Zgm;

// 组件 (nodes). A node is a lightweight drawable placed inside a 自定义组件
// (prefab) or a widget's node tree. Each has a fixed 类型 tag and a node-unique
// 名称 plus common transform/visibility fields. Concrete node types extend Node.
class Node {
    string kind;          // 类型
    string nname;         // 名称: node-unique id
    int x;                // x
    int y;                // y
    double anchorX;       // 锚点x
    double anchorY;       // 锚点y
    bool defaultVisible;  // 默认可视
    string tooltip;       // 气泡提示
    string tooltipSkin;   // 气泡皮肤
    bool mouseEvent;      // 鼠标事件

    void InitNode(string kind, string name) {
        this.kind = kind;
        this.nname = name;
        this.x = 0; this.y = 0;
        this.anchorX = 0.0; this.anchorY = 0.0;
        this.defaultVisible = true;
        this.tooltip = "";
        this.tooltipSkin = "";
        this.mouseEvent = false;
    }

    Node At(int x, int y) { this.x = x; this.y = y; return this; }
    Node Anchor(double ax, double ay) { this.anchorX = ax; this.anchorY = ay; return this; }
    Node Visible(bool v) { this.defaultVisible = v; return this; }
    Node Tip(string tip) { this.tooltip = tip; return this; }
    Node SetTooltipSkin(string skin) {
        this.tooltipSkin = skin;
        return this;
    }
    Node SetMouseEvent(bool enabled) {
        this.mouseEvent = enabled;
        return this;
    }

    string Kind() { return this.kind; }
    string Name() { return this.nname; }
    int X() { return this.x; }
    int Y() { return this.y; }
    double AnchorX() { return this.anchorX; }
    double AnchorY() { return this.anchorY; }
    bool DefaultVisible() { return this.defaultVisible; }
    bool MouseEvent() { return this.mouseEvent; }
}

// 文本 (text node).
class TextNode : Node {
    int width;         // 宽度
    int height;        // 高度
    string title;      // 标题
    string font;       // 字体
    int lineSpacing;   // 行距
    int letterSpacing; // 间距
    bool wordWrap;     // 自动换行
    int hAlign;        // 水平对齐
    int vAlign;        // 垂直对齐
    ZgmColor textColor; // 文本色
    ZgmColor strokeColor; // 描边色

    TextNode(string name) {
        this.InitNode("文本", name);
        this.width = 0; this.height = 0;
        this.title = "";
        this.font = "";
        this.lineSpacing = 0;
        this.letterSpacing = 0;
        this.wordWrap = false;
        this.hAlign = 0; this.vAlign = 0;
        this.textColor = null;
        this.strokeColor = null;
    }
    TextNode SetTitle(string t) { this.title = t; return this; }
    TextNode SetFont(string f) { this.font = f; return this; }
    TextNode SetAlign(int h, int v) { this.hAlign = h; this.vAlign = v; return this; }
    string Title() { return this.title; }
}

// 艺术字 (bitmap-font text node).
class BmpTextNode : Node {
    int width;         // 宽度
    int height;        // 高度
    string title;      // 标题
    string bmpFont;    // 艺术字: grouped bitmap font id
    int letterSpacing; // 间距
    int hAlign;        // 水平对齐
    int vAlign;        // 垂直对齐
    ZgmColor textColor; // 文本色

    BmpTextNode(string name) {
        this.InitNode("艺术字", name);
        this.width = 0; this.height = 0;
        this.title = "";
        this.bmpFont = "";
        this.letterSpacing = 0;
        this.hAlign = 0; this.vAlign = 0;
        this.textColor = null;
    }
    BmpTextNode SetTitle(string t) { this.title = t; return this; }
    BmpTextNode SetFont(string f) { this.bmpFont = f; return this; }
    string Title() { return this.title; }
}

// 精灵 (sprite node).
class SpriteNode : Node {
    int width;        // 宽度
    int height;       // 高度
    int angle;        // 角度
    string image;     // 图片
    ZgmColor color;    // 颜色
    double scaleX;    // 水平缩放
    double scaleY;    // 垂直缩放
    int blendMode;    // 混合模式: 0-3
    int displayMode;  // 显示方式: 0 scale / 1 fit-center

    SpriteNode(string name) {
        this.InitNode("精灵", name);
        this.width = 0; this.height = 0;
        this.angle = 0;
        this.image = "";
        this.color = ZgmColor.Rgb(255, 255, 255);
        this.scaleX = 1.0; this.scaleY = 1.0;
        this.blendMode = 0;
        this.displayMode = 0;
    }
    SpriteNode SetImage(string img) { this.image = img; return this; }
    SpriteNode SetColor(ZgmColor c) { this.color = c; return this; }
    SpriteNode SetScale(double sx, double sy) { this.scaleX = sx; this.scaleY = sy; return this; }
    string Image() { return this.image; }
}

// 矩形 (rectangle node).
class RectangleNode : Node {
    int width;        // 宽度
    int height;       // 高度
    ZgmColor backColor;// 背景色
    int borderWidth;  // 边框宽度
    ZgmColor borderColor; // 边框色
    int cornerRadius; // 圆角半径
    int cornerSides;  // 圆角边数
    int progress;     // 进度: 0-100
    string image;     // 图片

    RectangleNode(string name) {
        this.InitNode("矩形", name);
        this.width = 0; this.height = 0;
        this.backColor = null;
        this.borderWidth = 0;
        this.borderColor = null;
        this.cornerRadius = 0;
        this.cornerSides = 0;
        this.progress = 0;
        this.image = "";
    }
    RectangleNode SetSize(int w, int h) { this.width = w; this.height = h; return this; }
    RectangleNode SetBackground(ZgmColor c) { this.backColor = c; return this; }
    RectangleNode SetBorder(int width, ZgmColor c) {
        this.borderWidth = width; this.borderColor = c; return this;
    }
    int Width() { return this.width; }
}

// 圆形 (circle node).
class CircleNode : Node {
    int radius;       // 半径, default 16
    int sides;        // 边数, default 30
    int angle;        // 角度: 0-360
    ZgmColor color;    // 颜色
    int borderWidth;  // 边框宽度
    ZgmColor borderColor; // 边框色
    string image;     // 图片
    int progress;     // 进度: 0-100

    CircleNode(string name) {
        this.InitNode("圆形", name);
        this.radius = 16;
        this.sides = 30;
        this.angle = 0;
        this.color = null;
        this.borderWidth = 0;
        this.borderColor = null;
        this.image = "";
        this.progress = 0;
    }
    CircleNode SetRadius(int r) { this.radius = r; return this; }
    CircleNode SetColor(ZgmColor c) { this.color = c; return this; }
    int Radius() { return this.radius; }
}

// 动画 (animation node).
class AnimationNode : Node {
    string anim;      // 动画
    string action;    // 动作
    ZgmColor color;    // 颜色
    ZgmColor light;    // 灯光
    double alpha;     // 透明度: 0-1
    double frameRate; // 帧速: playback multiplier, default 1.0
    double angle;     // 角度
    double scaleX;    // 水平缩放
    double scaleY;    // 垂直缩放

    AnimationNode(string name) {
        this.InitNode("动画", name);
        this.anim = "";
        this.action = "";
        this.color = ZgmColor.Rgb(255, 255, 255);
        this.light = null;
        this.alpha = 1.0;
        this.frameRate = 1.0;
        this.angle = 0.0;
        this.scaleX = 1.0;
        this.scaleY = 1.0;
    }
    AnimationNode SetAnim(string anim, string action) {
        this.anim = anim; this.action = action; return this;
    }
    AnimationNode SetFrameRate(double r) { this.frameRate = r; return this; }
    string Anim() { return this.anim; }
}
