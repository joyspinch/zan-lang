namespace Game.Zgm;

delegate bool ZgmServerStarting(string bindHost);
delegate void ZgmServerStarted(ServerConfig config, string bindHost);
delegate bool ZgmServerStopping();
delegate void ZgmServerStopped(ServerConfig config);
delegate void ZgmServerClientChanged(ZgmServerClient client);
delegate void ZgmServerMessageReceived(
    ZgmServerClient client,
    ZgmMessage message);

// Typed server lifecycle and transport events. A host can reject startup or
// shutdown, while accepted connections and framed messages are observable.
class ZgmServerEvents {
    ZgmServerStarting starting;
    ZgmServerStarted started;
    ZgmServerStopping stopping;
    ZgmServerStopped stopped;
    ZgmServerClientChanged clientConnected;
    ZgmServerClientChanged clientDisconnected;
    ZgmServerMessageReceived messageReceived;

    static ZgmServerEvents Create() {
        return new ZgmServerEvents();
    }

    void OnStarting(ZgmServerStarting handler) {
        this.starting = handler;
    }
    void OnStarted(ZgmServerStarted handler) {
        this.started = handler;
    }
    void OnStopping(ZgmServerStopping handler) {
        this.stopping = handler;
    }
    void OnStopped(ZgmServerStopped handler) {
        this.stopped = handler;
    }
    void OnClientConnected(ZgmServerClientChanged handler) {
        this.clientConnected = handler;
    }
    void OnClientDisconnected(ZgmServerClientChanged handler) {
        this.clientDisconnected = handler;
    }
    void OnMessageReceived(ZgmServerMessageReceived handler) {
        this.messageReceived = handler;
    }

    bool RaiseStarting(string bindHost) {
        ZgmServerStarting handler = this.starting;
        if (handler == null) { return true; }
        return handler(bindHost);
    }
    void RaiseStarted(ServerConfig config, string bindHost) {
        ZgmServerStarted handler = this.started;
        if (handler != null) { handler(config, bindHost); }
    }
    bool RaiseStopping() {
        ZgmServerStopping handler = this.stopping;
        if (handler == null) { return true; }
        return handler();
    }
    void RaiseStopped(ServerConfig config) {
        ZgmServerStopped handler = this.stopped;
        if (handler != null) { handler(config); }
    }
    void RaiseClientConnected(ZgmServerClient client) {
        ZgmServerClientChanged handler = this.clientConnected;
        if (handler != null) { handler(client); }
    }
    void RaiseClientDisconnected(ZgmServerClient client) {
        ZgmServerClientChanged handler = this.clientDisconnected;
        if (handler != null) { handler(client); }
    }
    void RaiseMessageReceived(
        ZgmServerClient client,
        ZgmMessage message
    ) {
        ZgmServerMessageReceived handler = this.messageReceived;
        if (handler != null) { handler(client, message); }
    }
}
