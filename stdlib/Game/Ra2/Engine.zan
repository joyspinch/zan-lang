using System;
using SDL3;

namespace Game.Ra2;

/// <summary>
/// SDL3 host for the RA2-compatible engine.
///
/// Resource parsing, deterministic simulation and presentation remain separate
/// subsystems so original assets can be replaced by legal HD asset packs.
/// </summary>
class Ra2Engine {
    Ra2Config config;
    Ra2Install install;
    SdlWindow window;
    SdlRenderer renderer;
    bool running;
    int simulationTick;

    static Ra2Engine Create(Ra2Config config) {
        Ra2Engine engine = new Ra2Engine();
        engine.config = config;
        engine.install = Ra2Install.Inspect(config.InstallPath());
        engine.running = false;
        engine.simulationTick = 0;
        return engine;
    }

    bool Start() {
        if (!this.install.IsValid()) { return false; }
        if (!Sdl.Init(SdlInit.Video() + SdlInit.Events() + SdlInit.Audio())) {
            return false;
        }

        int flags = SdlWindowFlags.Resizable() + SdlWindowFlags.HighPixelDensity();
        this.window = SdlWindow.Create(
            this.config.Title(),
            this.config.WindowWidth(),
            this.config.WindowHeight(),
            flags);
        if (!this.window.IsValid()) {
            Sdl.Quit();
            return false;
        }

        this.renderer = SdlRenderer.Create(this.window);
        if (!this.renderer.IsValid()) {
            this.window.Close();
            Sdl.Quit();
            return false;
        }

        this.renderer.SetVSync(this.config.VerticalSync());
        this.renderer.SetLogicalSize(
            this.config.LogicalWidth(),
            this.config.LogicalHeight(),
            SdlLogicalPresentation.IntegerScale());
        this.running = true;
        return true;
    }

    void PumpEvents() {
        while (SdlEvent.Poll()) {
            if (SdlEvent.IsQuit()) {
                this.running = false;
            }
        }
    }

    void StepSimulation() {
        this.simulationTick = this.simulationTick + 1;
    }

    void RenderPlaceholder() {
        this.renderer.SetColor(18, 23, 27, 255);
        this.renderer.Clear();
        this.renderer.SetColor(202, 49, 42, 255);
        this.renderer.FillRect(24, 24, 128, 64);
        this.renderer.SetColor(212, 214, 205, 255);
        this.renderer.DrawRect(20, 20, 136, 72);
        this.renderer.Present();
    }

    bool IsRunning() { return this.running; }
    bool HasValidInstall() { return this.install.IsValid(); }
    int MissingAssetCount() { return this.install.MissingCount(); }
    string MissingAssetAt(int index) { return this.install.MissingAt(index); }
    int SimulationTick() { return this.simulationTick; }

    void Stop() {
        this.running = false;
        if (this.renderer != null) { this.renderer.Close(); }
        if (this.window != null) { this.window.Close(); }
        Sdl.Quit();
    }
}
