using System;

namespace Game.Legend2;

/// <summary>
/// In-memory component database. It is independent from file formats so tools
/// can generate it from JSON, Zan source, editors or other pipelines.
/// </summary>
class Legend2Project {
    Legend2Registry registry;
    List<Legend2MapDefinition> maps;
    List<Legend2ActorDefinition> actors;
    List<Legend2ItemDefinition> items;
    List<Legend2SkillDefinition> skills;
    List<Legend2BuffDefinition> buffs;
    List<Legend2WindowDefinition> windows;
    List<Legend2GrowthDefinition> growth;
    List<Legend2PrefabDefinition> prefabs;

    static Legend2Project Create() {
        Legend2Project project = new Legend2Project();
        project.registry = Legend2Registry.Create();
        project.maps = new List<Legend2MapDefinition>();
        project.actors = new List<Legend2ActorDefinition>();
        project.items = new List<Legend2ItemDefinition>();
        project.skills = new List<Legend2SkillDefinition>();
        project.buffs = new List<Legend2BuffDefinition>();
        project.windows = new List<Legend2WindowDefinition>();
        project.growth = new List<Legend2GrowthDefinition>();
        project.prefabs = new List<Legend2PrefabDefinition>();
        return project;
    }

    Legend2Registry Registry() { return this.registry; }

    void AddMap(Legend2MapDefinition newValue) { this.maps.Add(newValue); }
    void AddActor(Legend2ActorDefinition newValue) { this.actors.Add(newValue); }
    void AddItem(Legend2ItemDefinition newValue) { this.items.Add(newValue); }
    void AddSkill(Legend2SkillDefinition newValue) { this.skills.Add(newValue); }
    void AddBuff(Legend2BuffDefinition newValue) { this.buffs.Add(newValue); }
    void AddWindow(Legend2WindowDefinition newValue) { this.windows.Add(newValue); }
    void AddGrowth(Legend2GrowthDefinition newValue) { this.growth.Add(newValue); }
    void AddPrefab(Legend2PrefabDefinition newValue) { this.prefabs.Add(newValue); }

    int MapCount() { return this.maps.Count; }
    int ActorCount() { return this.actors.Count; }
    int ItemCount() { return this.items.Count; }
    int SkillCount() { return this.skills.Count; }
    int BuffCount() { return this.buffs.Count; }
    int WindowCount() { return this.windows.Count; }
    int GrowthCount() { return this.growth.Count; }
    int PrefabCount() { return this.prefabs.Count; }

    Legend2MapDefinition MapAt(int index) { return this.maps[index]; }
    Legend2ActorDefinition ActorAt(int index) { return this.actors[index]; }
    Legend2ItemDefinition ItemAt(int index) { return this.items[index]; }
    Legend2SkillDefinition SkillAt(int index) { return this.skills[index]; }
    Legend2BuffDefinition BuffAt(int index) { return this.buffs[index]; }
    Legend2WindowDefinition WindowAt(int index) { return this.windows[index]; }
    Legend2GrowthDefinition GrowthAt(int index) { return this.growth[index]; }
    Legend2PrefabDefinition PrefabAt(int index) { return this.prefabs[index]; }

    Legend2MapDefinition FindMap(string id) {
        int i = 0;
        while (i < this.maps.Count) {
            if (this.maps[i].Id() == id) { return this.maps[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2ActorDefinition FindActor(string id) {
        int i = 0;
        while (i < this.actors.Count) {
            if (this.actors[i].Id() == id) { return this.actors[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2ItemDefinition FindItem(string id) {
        int i = 0;
        while (i < this.items.Count) {
            if (this.items[i].Id() == id) { return this.items[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2SkillDefinition FindSkill(string id) {
        int i = 0;
        while (i < this.skills.Count) {
            if (this.skills[i].Id() == id) { return this.skills[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2BuffDefinition FindBuff(string id) {
        int i = 0;
        while (i < this.buffs.Count) {
            if (this.buffs[i].Id() == id) { return this.buffs[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2WindowDefinition FindWindow(string id) {
        int i = 0;
        while (i < this.windows.Count) {
            if (this.windows[i].Id() == id) { return this.windows[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2GrowthDefinition FindGrowth(string id) {
        int i = 0;
        while (i < this.growth.Count) {
            if (this.growth[i].Id() == id) { return this.growth[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2PrefabDefinition FindPrefab(string id) {
        int i = 0;
        while (i < this.prefabs.Count) {
            if (this.prefabs[i].Id() == id) { return this.prefabs[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2MapDefinition DefaultMap() {
        int i = 0;
        while (i < this.maps.Count) {
            if (this.maps[i].DefaultMap()) { return this.maps[i]; }
            i = i + 1;
        }
        return null;
    }

    Legend2ActorDefinition DefaultPlayer() {
        int i = 0;
        while (i < this.actors.Count) {
            if (this.actors[i].DefaultPlayer()) { return this.actors[i]; }
            i = i + 1;
        }
        return null;
    }

    void ValidateResource(
        Legend2Diagnostics diagnostics,
        string resourceId,
        string path
    ) {
        if (resourceId != "" && !this.registry.HasResource(resourceId)) {
            diagnostics.AddError(
                "L2PRJ017", path, "Referenced resource id was not found.");
        }
    }

    Legend2Diagnostics Validate() {
        Legend2Diagnostics diagnostics = this.registry.Validate();
        int i = 0;
        while (i < this.maps.Count) {
            this.maps[i].Validate(diagnostics);
            this.ValidateResource(
                diagnostics,
                this.maps[i].TemplateResource(),
                "maps." + this.maps[i].Id() + ".templateResource");
            this.ValidateResource(
                diagnostics,
                this.maps[i].MiniMapResource(),
                "maps." + this.maps[i].Id() + ".miniMapResource");
            int j = i + 1;
            while (j < this.maps.Count) {
                if (this.maps[i].Id() == this.maps[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ001", "maps." + this.maps[i].Id(), "Duplicate map id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }

        i = 0;
        while (i < this.actors.Count) {
            Legend2ActorDefinition actor = this.actors[i];
            actor.Validate(diagnostics);
            int j = i + 1;
            while (j < this.actors.Count) {
                if (actor.Id() == this.actors[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ002", "actors." + actor.Id(), "Duplicate actor id.");
                }
                j = j + 1;
            }
            if (actor.GrowthId() != "" && this.FindGrowth(actor.GrowthId()) == null) {
                diagnostics.AddError(
                    "L2PRJ003",
                    "actors." + actor.Id() + ".growth",
                    "Referenced growth definition was not found.");
            }
            int s = 0;
            while (s < actor.SkillCount()) {
                if (this.FindSkill(actor.SkillAt(s)) == null) {
                    diagnostics.AddError(
                        "L2PRJ004",
                        "actors." + actor.Id() + ".skills",
                        "Referenced skill definition was not found.");
                }
                s = s + 1;
            }
            int b = 0;
            while (b < actor.StartingBuffCount()) {
                if (this.FindBuff(actor.StartingBuffAt(b)) == null) {
                    diagnostics.AddError(
                        "L2PRJ005",
                        "actors." + actor.Id() + ".buffs",
                        "Referenced buff definition was not found.");
                }
                b = b + 1;
            }
            i = i + 1;
        }

        i = 0;
        while (i < this.items.Count) {
            this.items[i].Validate(diagnostics);
            this.ValidateResource(
                diagnostics,
                this.items[i].IconResource(),
                "items." + this.items[i].Id() + ".iconResource");
            int j = i + 1;
            while (j < this.items.Count) {
                if (this.items[i].Id() == this.items[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ006", "items." + this.items[i].Id(), "Duplicate item id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }

        i = 0;
        while (i < this.skills.Count) {
            Legend2SkillDefinition skill = this.skills[i];
            skill.Validate(diagnostics);
            this.ValidateResource(
                diagnostics,
                skill.IconResource(),
                "skills." + skill.Id() + ".iconResource");
            int b = 0;
            while (b < skill.BuffEffectCount()) {
                if (this.FindBuff(skill.BuffEffectAt(b)) == null) {
                    diagnostics.AddError(
                        "L2PRJ019",
                        "skills." + skill.Id() + ".buffEffects",
                        "Referenced buff definition was not found.");
                }
                b = b + 1;
            }
            int j = i + 1;
            while (j < this.skills.Count) {
                if (skill.Id() == this.skills[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ007", "skills." + skill.Id(), "Duplicate skill id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }

        i = 0;
        while (i < this.buffs.Count) {
            this.buffs[i].Validate(diagnostics);
            this.ValidateResource(
                diagnostics,
                this.buffs[i].IconResource(),
                "buffs." + this.buffs[i].Id() + ".iconResource");
            int j = i + 1;
            while (j < this.buffs.Count) {
                if (this.buffs[i].Id() == this.buffs[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ008", "buffs." + this.buffs[i].Id(), "Duplicate buff id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }

        i = 0;
        while (i < this.windows.Count) {
            this.windows[i].Validate(diagnostics);
            this.ValidateResource(
                diagnostics,
                this.windows[i].BackgroundResource(),
                "windows." + this.windows[i].Id() + ".backgroundResource");
            int j = i + 1;
            while (j < this.windows.Count) {
                if (this.windows[i].Id() == this.windows[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ009",
                        "windows." + this.windows[i].Id(),
                        "Duplicate window id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }

        i = 0;
        while (i < this.growth.Count) {
            this.growth[i].Validate(diagnostics);
            int j = i + 1;
            while (j < this.growth.Count) {
                if (this.growth[i].Id() == this.growth[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ010",
                        "growth." + this.growth[i].Id(),
                        "Duplicate growth id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }

        i = 0;
        while (i < this.prefabs.Count) {
            this.prefabs[i].Validate(diagnostics);
            this.ValidateResource(
                diagnostics,
                this.prefabs[i].BackgroundResource(),
                "prefabs." + this.prefabs[i].Id() + ".backgroundResource");
            int j = i + 1;
            while (j < this.prefabs.Count) {
                if (this.prefabs[i].Id() == this.prefabs[j].Id()) {
                    diagnostics.AddError(
                        "L2PRJ011",
                        "prefabs." + this.prefabs[i].Id(),
                        "Duplicate prefab id.");
                }
                j = j + 1;
            }
            i = i + 1;
        }

        int defaultMapCount = 0;
        i = 0;
        while (i < this.maps.Count) {
            Legend2MapDefinition map = this.maps[i];
            if (map.DefaultMap()) { defaultMapCount = defaultMapCount + 1; }
            int p = 0;
            while (p < map.PortalCount()) {
                Legend2MapPortal portal = map.PortalAt(p);
                Legend2MapDefinition targetMap =
                    this.FindMap(portal.TargetMapId());
                if (targetMap == null) {
                    diagnostics.AddError(
                        "L2PRJ012",
                        "maps." + map.Id() + ".portals",
                        "Portal target map was not found.");
                } else if (!targetMap.IsInside(
                    portal.TargetGridX(), portal.TargetGridY())) {
                    diagnostics.AddError(
                        "L2PRJ018",
                        "maps." + map.Id() + ".portals",
                        "Portal destination is outside the target map grid.");
                }
                p = p + 1;
            }
            int s = 0;
            while (s < map.SpawnCount()) {
                if (this.FindActor(map.SpawnAt(s).ActorId()) == null) {
                    diagnostics.AddError(
                        "L2PRJ013",
                        "maps." + map.Id() + ".spawns",
                        "Spawn actor definition was not found.");
                }
                s = s + 1;
            }
            i = i + 1;
        }
        if (this.maps.Count > 0 && defaultMapCount == 0) {
            diagnostics.AddWarning(
                "L2PRJ014", "maps", "Project has maps but no default map.");
        }
        if (defaultMapCount > 1) {
            diagnostics.AddError(
                "L2PRJ015", "maps", "Only one map can be the default map.");
        }

        int playerCount = 0;
        i = 0;
        while (i < this.actors.Count) {
            if (this.actors[i].DefaultPlayer()) { playerCount = playerCount + 1; }
            i = i + 1;
        }
        if (playerCount > 1) {
            diagnostics.AddError(
                "L2PRJ016", "actors", "Only one actor can be the default player.");
        }
        return diagnostics;
    }
}

/// <summary>Live map state kept separate from immutable component definitions.</summary>
class Legend2World {
    Legend2Project project;
    Legend2MapDefinition currentMap;
    List<Legend2Actor> actors;
    Legend2Actor player;
    int nextInstanceId;
    Legend2Events systemEvents;
    Legend2GameplayEvents gameplayEvents;
    Legend2Random random;

    static Legend2World Create(Legend2Project project) {
        return CreateWithEvents(
            project,
            Legend2Events.Create(),
            Legend2GameplayEvents.Create());
    }

    static Legend2World CreateWithEvents(
        Legend2Project project,
        Legend2Events systemEvents,
        Legend2GameplayEvents gameplayEvents
    ) {
        Legend2World world = new Legend2World();
        world.project = project;
        world.currentMap = null;
        world.actors = new List<Legend2Actor>();
        world.player = null;
        world.nextInstanceId = 1;
        world.systemEvents = systemEvents;
        world.gameplayEvents = gameplayEvents;
        world.random = Legend2Random.Create(19790327);
        return world;
    }

    Legend2Project Project() { return this.project; }
    Legend2MapDefinition CurrentMap() { return this.currentMap; }
    Legend2Actor Player() { return this.player; }
    Legend2GameplayEvents GameplayEvents() { return this.gameplayEvents; }
    int ActorCount() { return this.actors.Count; }
    Legend2Actor ActorAt(int index) { return this.actors[index]; }

    bool EnterDefaultMap() {
        Legend2MapDefinition map = this.project.DefaultMap();
        if (map == null) { return false; }
        return this.EnterMap(map.Id());
    }

    bool EnterMap(string mapId) {
        return this.LoadMap(mapId, null, -1);
    }

    bool LoadMap(string mapId, Legend2Actor preservedPlayer, int portalId) {
        Legend2MapDefinition map = this.project.FindMap(mapId);
        if (map == null) { return false; }
        string previousMapId = "";
        if (this.currentMap != null) { previousMapId = this.currentMap.Id(); }
        this.currentMap = map;
        this.actors = new List<Legend2Actor>();
        this.player = preservedPlayer;

        if (this.player == null) {
            Legend2ActorDefinition playerDefinition = this.project.DefaultPlayer();
            if (playerDefinition != null) {
                this.player = Legend2Actor.FromDefinition("player", playerDefinition);
                this.ApplyStartingBuffs(this.player, playerDefinition);
            }
        }
        if (this.player != null) {
            this.player.SetGridPosition(map.InitialGridX(), map.InitialGridY());
            this.actors.Add(this.player);
        }

        int i = 0;
        while (i < map.SpawnCount()) {
            Legend2MapSpawn spawn = map.SpawnAt(i);
            Legend2ActorDefinition definition = this.project.FindActor(spawn.ActorId());
            if (definition != null) {
                int n = 0;
                while (n < spawn.Count()) {
                    string instanceId =
                        definition.Id() + "#" + Convert.ToString(this.nextInstanceId);
                    this.nextInstanceId = this.nextInstanceId + 1;
                    Legend2Actor actor =
                        Legend2Actor.FromDefinition(instanceId, definition);
                    actor.SetGridPosition(spawn.GridX(), spawn.GridY());
                    actor.SetDirection(spawn.Direction());
                    actor.SetLevel(spawn.Level());
                    if (spawn.Faction() != "") {
                        actor.SetFaction(spawn.Faction());
                    }
                    this.ApplyStartingBuffs(actor, definition);
                    this.actors.Add(actor);
                    n = n + 1;
                }
            }
            i = i + 1;
        }
        this.gameplayEvents.RaiseMapChanged(
            previousMapId, this.currentMap.Id(), portalId);
        return true;
    }

    void ApplyStartingBuffs(
        Legend2Actor actor,
        Legend2ActorDefinition definition
    ) {
        int i = 0;
        while (i < definition.StartingBuffCount()) {
            this.ApplyBuff(actor, definition.StartingBuffAt(i), actor, true);
            i = i + 1;
        }
    }

    bool MoveActor(Legend2Actor actor, int x, int y) {
        if (this.currentMap == null || actor == null) { return false; }
        if (!actor.IsAlive() || this.HasMovementRestriction(actor)) {
            return false;
        }
        if (!this.currentMap.IsInside(x, y) || this.currentMap.IsBlocked(x, y)) {
            return false;
        }
        actor.SetGridPosition(x, y);
        this.RemoveConditionalBuffs(actor, 1);
        return true;
    }

    bool HasMovementRestriction(Legend2Actor actor) {
        int i = 0;
        while (i < actor.BuffCount()) {
            if (actor.BuffInstanceAt(i).Definition().MovementDisabled()) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    bool HasAttackRestriction(Legend2Actor actor) {
        int i = 0;
        while (i < actor.BuffCount()) {
            if (actor.BuffInstanceAt(i).Definition().AttackDisabled()) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    int AddItem(Legend2Actor actor, string itemId, int count) {
        if (actor == null || count <= 0) { return 0; }
        Legend2ItemDefinition item = this.project.FindItem(itemId);
        if (item == null) { return 0; }
        int added = actor.Inventory().Add(item, count);
        if (added > 0) {
            this.gameplayEvents.RaiseItemChanged(
                actor, item, actor.Inventory().QuantityOf(itemId));
        }
        if (added < count) {
            this.systemEvents.RaiseSystemPrompt(4, "Inventory is full.");
        }
        return added;
    }

    bool UseItem(Legend2Actor actor, string itemId) {
        if (actor == null || !actor.IsAlive()) { return false; }
        Legend2ItemDefinition item = this.project.FindItem(itemId);
        if (item == null
            || item.Category() == Legend2ItemCategory.Equipment()
            || actor.Inventory().QuantityOf(itemId) <= 0) {
            return false;
        }
        if (actor.Level() < item.RequiredLevel()) {
            this.systemEvents.RaiseSystemPrompt(
                3, "Actor level is too low for this item.");
            return false;
        }
        string cooldownName = item.CooldownGroup();
        if (cooldownName == "") { cooldownName = "item:" + item.Id(); }
        if (!actor.Cooldowns().IsReady(cooldownName)) {
            this.systemEvents.RaiseSystemPrompt(2, "Item is cooling down.");
            return false;
        }

        Legend2Attributes effective = actor.EffectiveAttributes();
        double hp = (double)item.RestoreHp()
            + effective.MaxHp() * item.RestoreHpPercent() / 100.0;
        double mp = (double)item.RestoreMp()
            + effective.MaxMp() * item.RestoreMpPercent() / 100.0;
        if (!actor.Inventory().Remove(itemId, 1)) { return false; }
        actor.Heal(hp, mp);
        actor.Cooldowns().Start(
            cooldownName, item.CooldownMilliseconds());
        this.gameplayEvents.RaiseItemChanged(
            actor, item, actor.Inventory().QuantityOf(itemId));
        this.gameplayEvents.RaiseItemUsed(actor, item);
        return true;
    }

    bool EquipItem(Legend2Actor actor, string itemId, string slot) {
        if (actor == null || actor.Level() < 1) { return false; }
        Legend2ItemDefinition item = this.project.FindItem(itemId);
        if (item == null || actor.Level() < item.RequiredLevel()) {
            if (item != null) {
                this.systemEvents.RaiseSystemPrompt(
                    3, "Actor level is too low for this item.");
            }
            return false;
        }
        bool equipped = actor.Equipment().Equip(
            slot, item, actor.Inventory());
        if (equipped) {
            actor.ClampVitals();
            this.gameplayEvents.RaiseItemChanged(
                actor, item, actor.Inventory().QuantityOf(itemId));
        }
        return equipped;
    }

    bool UnequipItem(Legend2Actor actor, string slot) {
        if (actor == null) { return false; }
        Legend2ItemDefinition item = actor.Equipment().Get(slot);
        if (item == null) { return false; }
        bool unequipped = actor.Equipment().Unequip(
            slot, actor.Inventory());
        if (unequipped) {
            actor.ClampVitals();
            this.gameplayEvents.RaiseItemChanged(
                actor, item, actor.Inventory().QuantityOf(item.Id()));
        }
        return unequipped;
    }

    Legend2BuffInstance ApplyBuff(
        Legend2Actor actor,
        string buffId,
        Legend2Actor source,
        bool unique
    ) {
        if (actor == null || !actor.IsAlive()) { return null; }
        Legend2BuffDefinition definition = this.project.FindBuff(buffId);
        if (definition == null) { return null; }
        Legend2BuffInstance instance =
            actor.ApplyBuff(definition, source, unique);
        if (instance != null) {
            actor.ClampVitals();
            this.gameplayEvents.RaiseBuffChanged(actor, instance, true);
        }
        return instance;
    }

    bool RemoveBuff(Legend2Actor actor, string buffId) {
        if (actor == null) { return false; }
        bool removed = false;
        int i = actor.BuffCount() - 1;
        while (i >= 0) {
            Legend2BuffInstance instance = actor.BuffInstanceAt(i);
            if (instance.Definition().Id() == buffId) {
                actor.RemoveBuffAt(i);
                this.gameplayEvents.RaiseBuffChanged(actor, instance, false);
                removed = true;
            }
            i = i - 1;
        }
        if (removed) { actor.ClampVitals(); }
        return removed;
    }

    Legend2SkillCastResult CastSkill(
        Legend2Actor caster,
        string skillId,
        Legend2Actor target
    ) {
        Legend2SkillDefinition skill = this.project.FindSkill(skillId);
        if (skill == null) {
            return this.ResolveCast(Legend2SkillCastResult.Create(
                Legend2SkillCastStatus.UnknownSkill(), caster, target, null));
        }
        if (caster == null || !caster.HasSkill(skillId)) {
            return this.ResolveCast(Legend2SkillCastResult.Create(
                Legend2SkillCastStatus.NotLearned(), caster, target, skill));
        }
        if (!caster.IsAlive() || this.HasAttackRestriction(caster)) {
            return this.ResolveCast(Legend2SkillCastResult.Create(
                Legend2SkillCastStatus.CasterDead(), caster, target, skill));
        }
        if (skill.TargetMode() == Legend2SkillTarget.Player()) {
            target = caster;
        }
        if (!Legend2Combat.IsValidTarget(
            caster, target, skill.TargetFaction())) {
            return this.ResolveCast(Legend2SkillCastResult.Create(
                Legend2SkillCastStatus.InvalidTarget(), caster, target, skill));
        }
        int distance = Legend2Combat.GridDistance(caster, target);
        if (distance < skill.MinimumRange()
            || distance > skill.AttackRange()) {
            return this.ResolveCast(Legend2SkillCastResult.Create(
                Legend2SkillCastStatus.OutOfRange(), caster, target, skill));
        }
        string cooldownName = "skill:" + skill.Id();
        if (!caster.Cooldowns().IsReady(cooldownName)) {
            this.systemEvents.RaiseSystemPrompt(1, "Skill is cooling down.");
            return this.ResolveCast(Legend2SkillCastResult.Create(
                Legend2SkillCastStatus.Cooldown(), caster, target, skill));
        }
        if (!caster.Spend(
            (double)skill.HpCost(), (double)skill.MpCost())) {
            return this.ResolveCast(Legend2SkillCastResult.Create(
                Legend2SkillCastStatus.InsufficientResources(),
                caster, target, skill));
        }

        caster.Cooldowns().Start(
            cooldownName, skill.CooldownMilliseconds());
        this.RemoveConditionalBuffs(caster, 2);
        bool hit = skill.AlwaysHit();
        if (!hit) {
            hit = this.random.NextPercent()
                <= Legend2Combat.HitChance(caster, target);
        }
        bool critical = false;
        double damage = 0.0;
        if (hit) {
            Legend2Attributes sourceAttributes = caster.EffectiveAttributes();
            critical = skill.AlwaysCritical();
            if (!critical) {
                int criticalChance = Legend2Math.Clamp(
                    (int)sourceAttributes.CriticalChance(), 0, 100);
                critical = this.random.NextPercent() <= criticalChance;
            }
            damage = Legend2Combat.Damage(
                caster, target, skill, critical);
            this.DamageActor(caster, target, damage, critical);
            int i = 0;
            while (i < skill.BuffEffectCount() && target.IsAlive()) {
                this.ApplyBuff(
                    target, skill.BuffEffectAt(i), caster, false);
                i = i + 1;
            }
        }
        Legend2SkillCastResult result = Legend2SkillCastResult.Create(
            Legend2SkillCastStatus.Success(), caster, target, skill);
        result.SetResolved(hit, critical, damage);
        return this.ResolveCast(result);
    }

    Legend2SkillCastResult ResolveCast(Legend2SkillCastResult result) {
        this.gameplayEvents.RaiseSkillResolved(result);
        return result;
    }

    double DamageActor(
        Legend2Actor source,
        Legend2Actor target,
        double amount,
        bool critical
    ) {
        if (target == null) { return 0.0; }
        bool wasAlive = target.IsAlive();
        double applied = target.TakeDamage(amount);
        if (applied > 0.0) {
            this.gameplayEvents.RaiseActorDamaged(
                source, target, applied, critical);
            this.RemoveConditionalBuffs(target, 3);
        }
        if (wasAlive && !target.IsAlive()) {
            this.RemoveConditionalBuffs(target, 4);
            this.gameplayEvents.RaiseActorDied(target, source);
        }
        return applied;
    }

    void RemoveConditionalBuffs(Legend2Actor actor, int condition) {
        int i = actor.BuffCount() - 1;
        while (i >= 0) {
            Legend2BuffInstance instance = actor.BuffInstanceAt(i);
            Legend2BuffDefinition definition = instance.Definition();
            bool remove = condition == 1 && definition.RemoveOnMove();
            if (condition == 2 && definition.RemoveOnAttack()) { remove = true; }
            if (condition == 3 && definition.RemoveOnDamage()) { remove = true; }
            if (condition == 4 && definition.RemoveOnDeath()) { remove = true; }
            if (remove) {
                actor.RemoveBuffAt(i);
                this.gameplayEvents.RaiseBuffChanged(actor, instance, false);
            }
            i = i - 1;
        }
        actor.ClampVitals();
    }

    void Update(int deltaMilliseconds) {
        if (deltaMilliseconds <= 0) { return; }
        int actorIndex = 0;
        while (actorIndex < this.actors.Count) {
            Legend2Actor actor = this.actors[actorIndex];
            actor.Cooldowns().Tick(deltaMilliseconds);
            int buffIndex = actor.BuffCount() - 1;
            while (buffIndex >= 0) {
                Legend2BuffInstance instance =
                    actor.BuffInstanceAt(buffIndex);
                int triggerCount = instance.Tick(deltaMilliseconds);
                while (triggerCount > 0 && actor.IsAlive()) {
                    Legend2Attributes attributes =
                        instance.Definition().Attributes();
                    if (attributes.Hp() < 0.0) {
                        this.DamageActor(
                            instance.Source(),
                            actor,
                            -attributes.Hp(),
                            false);
                    } else {
                        actor.Heal(attributes.Hp(), attributes.Mp());
                    }
                    triggerCount = triggerCount - 1;
                }
                if (buffIndex < actor.BuffCount()
                    && actor.BuffInstanceAt(buffIndex) == instance
                    && instance.IsExpired()) {
                    actor.RemoveBuffAt(buffIndex);
                    actor.ClampVitals();
                    this.gameplayEvents.RaiseBuffChanged(
                        actor, instance, false);
                }
                buffIndex = buffIndex - 1;
            }
            actorIndex = actorIndex + 1;
        }
    }

    bool TryUsePortal(Legend2Actor actor) {
        if (actor == null || actor != this.player || this.currentMap == null) {
            return false;
        }
        int i = 0;
        while (i < this.currentMap.PortalCount()) {
            Legend2MapPortal portal = this.currentMap.PortalAt(i);
            if (portal.GridX() == actor.GridX()
                && portal.GridY() == actor.GridY()) {
                Legend2Actor preservedPlayer = this.player;
                if (!this.LoadMap(
                    portal.TargetMapId(), preservedPlayer, portal.Id())) {
                    return false;
                }
                preservedPlayer.SetGridPosition(
                    portal.TargetGridX(), portal.TargetGridY());
                preservedPlayer.SetDirection(portal.TargetDirection());
                return true;
            }
            i = i + 1;
        }
        return false;
    }
}
