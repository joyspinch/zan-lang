using System;

namespace Game.Legend2;

class Legend2ItemCategory {
    static string Item() { return "item"; }
    static string Equipment() { return "equipment"; }
    static string Special() { return "special"; }
}

class Legend2ItemDefinition {
    string id;
    string displayName;
    string iconResource;
    string tooltip;
    string category;
    string subcategory;
    string detailCategory;
    string cooldownGroup;
    int cooldownMilliseconds;
    int maxStack;
    bool discardDisabled;
    int disappearMilliseconds;
    int requiredLevel;
    int restoreHp;
    int restoreMp;
    double restoreHpPercent;
    double restoreMpPercent;
    Legend2Attributes attributes;

    static Legend2ItemDefinition Create(string id, string displayName) {
        Legend2ItemDefinition item = new Legend2ItemDefinition();
        item.id = id;
        item.displayName = displayName;
        item.iconResource = "";
        item.tooltip = "";
        item.category = Legend2ItemCategory.Item();
        item.subcategory = "";
        item.detailCategory = "";
        item.cooldownGroup = "";
        item.cooldownMilliseconds = 0;
        item.maxStack = 1;
        item.discardDisabled = false;
        item.disappearMilliseconds = 40000;
        item.requiredLevel = 1;
        item.restoreHp = 0;
        item.restoreMp = 0;
        item.restoreHpPercent = 0.0;
        item.restoreMpPercent = 0.0;
        item.attributes = Legend2Attributes.Create();
        return item;
    }

    string Id() { return this.id; }
    string DisplayName() { return this.displayName; }
    string IconResource() { return this.iconResource; }
    string Tooltip() { return this.tooltip; }
    string Category() { return this.category; }
    string Subcategory() { return this.subcategory; }
    string DetailCategory() { return this.detailCategory; }
    string CooldownGroup() { return this.cooldownGroup; }
    int CooldownMilliseconds() { return this.cooldownMilliseconds; }
    int MaxStack() { return this.maxStack; }
    bool DiscardDisabled() { return this.discardDisabled; }
    int DisappearMilliseconds() { return this.disappearMilliseconds; }
    int RequiredLevel() { return this.requiredLevel; }
    int RestoreHp() { return this.restoreHp; }
    int RestoreMp() { return this.restoreMp; }
    double RestoreHpPercent() { return this.restoreHpPercent; }
    double RestoreMpPercent() { return this.restoreMpPercent; }
    Legend2Attributes Attributes() { return this.attributes; }

    void SetIconResource(string newValue) { this.iconResource = newValue; }
    void SetTooltip(string newValue) { this.tooltip = newValue; }
    void SetCategory(string newValue) { this.category = newValue; }
    void SetSubcategory(string newValue) { this.subcategory = newValue; }
    void SetDetailCategory(string newValue) { this.detailCategory = newValue; }
    void SetCooldown(string group, int milliseconds) {
        this.cooldownGroup = group;
        this.cooldownMilliseconds = milliseconds;
    }
    void SetMaxStack(int newValue) { this.maxStack = newValue; }
    void SetDiscardDisabled(bool newValue) { this.discardDisabled = newValue; }
    void SetDisappearMilliseconds(int newValue) { this.disappearMilliseconds = newValue; }
    void SetRequiredLevel(int newValue) { this.requiredLevel = newValue; }
    void SetRestore(int hp, int mp, double hpPercent, double mpPercent) {
        this.restoreHp = hp;
        this.restoreMp = mp;
        this.restoreHpPercent = hpPercent;
        this.restoreMpPercent = mpPercent;
    }

    void Validate(Legend2Diagnostics diagnostics) {
        string path = "items." + this.id;
        Legend2Validation.Required(diagnostics, this.id, "items", "L2ITM001");
        Legend2Validation.Required(
            diagnostics, this.displayName, path + ".displayName", "L2ITM002");
        Legend2Validation.Positive(
            diagnostics, this.maxStack, path + ".maxStack", "L2ITM003");
        Legend2Validation.Positive(
            diagnostics, this.requiredLevel, path + ".requiredLevel", "L2ITM004");
        if (this.cooldownMilliseconds < 0) {
            diagnostics.AddError(
                "L2ITM005", path + ".cooldown", "Cooldown cannot be negative.");
        }
        if (this.disappearMilliseconds < -1) {
            diagnostics.AddError(
                "L2ITM006",
                path + ".disappearMilliseconds",
                "Disappear time must be -1 or a non-negative value.");
        }
    }
}

class Legend2SkillTarget {
    static int Actor() { return 0; }
    static int MouseCell() { return 1; }
    static int ActorThenMouseCell() { return 2; }
    static int Player() { return 3; }
}

class Legend2SkillCastStatus {
    static int Success() { return 0; }
    static int UnknownSkill() { return 1; }
    static int NotLearned() { return 2; }
    static int CasterDead() { return 3; }
    static int Cooldown() { return 4; }
    static int InsufficientResources() { return 5; }
    static int OutOfRange() { return 6; }
    static int InvalidTarget() { return 7; }
}

class Legend2SkillCastResult {
    int status;
    Legend2Actor caster;
    Legend2Actor target;
    Legend2SkillDefinition skill;
    bool hit;
    bool critical;
    double damage;

    static Legend2SkillCastResult Create(
        int status,
        Legend2Actor caster,
        Legend2Actor target,
        Legend2SkillDefinition skill
    ) {
        Legend2SkillCastResult result = new Legend2SkillCastResult();
        result.status = status;
        result.caster = caster;
        result.target = target;
        result.skill = skill;
        result.hit = false;
        result.critical = false;
        result.damage = 0.0;
        return result;
    }

    int Status() { return this.status; }
    bool Success() { return this.status == Legend2SkillCastStatus.Success(); }
    Legend2Actor Caster() { return this.caster; }
    Legend2Actor Target() { return this.target; }
    Legend2SkillDefinition Skill() { return this.skill; }
    bool Hit() { return this.hit; }
    bool Critical() { return this.critical; }
    double Damage() { return this.damage; }

    void SetResolved(bool hit, bool critical, double damage) {
        this.hit = hit;
        this.critical = critical;
        this.damage = damage;
    }
}

class Legend2SkillDefinition {
    string id;
    string displayName;
    string iconResource;
    string tooltip;
    int level;
    double damageFactor;
    string targetFaction;
    int attackRange;
    int minimumRange;
    string action;
    int hpCost;
    int mpCost;
    int rageCost;
    int threat;
    int cooldownMilliseconds;
    int targetMode;
    double priority;
    int damageDelayMilliseconds;
    bool autoEndPrevious;
    bool alwaysHit;
    bool alwaysCritical;
    int startingDirectionMode;
    string damageFormula;
    List<string> buffEffects;

    static Legend2SkillDefinition Create(string id, string displayName) {
        Legend2SkillDefinition skill = new Legend2SkillDefinition();
        skill.id = id;
        skill.displayName = displayName;
        skill.iconResource = "";
        skill.tooltip = "";
        skill.level = 1;
        skill.damageFactor = 1.0;
        skill.targetFaction = Legend2Faction.Hostile();
        skill.attackRange = 1;
        skill.minimumRange = 0;
        skill.action = "";
        skill.hpCost = 0;
        skill.mpCost = 0;
        skill.rageCost = 0;
        skill.threat = 0;
        skill.cooldownMilliseconds = 0;
        skill.targetMode = Legend2SkillTarget.Actor();
        skill.priority = -1.0;
        skill.damageDelayMilliseconds = 0;
        skill.autoEndPrevious = false;
        skill.alwaysHit = false;
        skill.alwaysCritical = false;
        skill.startingDirectionMode = 0;
        skill.damageFormula = "";
        skill.buffEffects = new List<string>();
        return skill;
    }

    string Id() { return this.id; }
    string DisplayName() { return this.displayName; }
    string IconResource() { return this.iconResource; }
    string Tooltip() { return this.tooltip; }
    int Level() { return this.level; }
    double DamageFactor() { return this.damageFactor; }
    string TargetFaction() { return this.targetFaction; }
    int AttackRange() { return this.attackRange; }
    int MinimumRange() { return this.minimumRange; }
    string Action() { return this.action; }
    int HpCost() { return this.hpCost; }
    int MpCost() { return this.mpCost; }
    int RageCost() { return this.rageCost; }
    int Threat() { return this.threat; }
    int CooldownMilliseconds() { return this.cooldownMilliseconds; }
    int TargetMode() { return this.targetMode; }
    double Priority() { return this.priority; }
    int DamageDelayMilliseconds() { return this.damageDelayMilliseconds; }
    bool AutoEndPrevious() { return this.autoEndPrevious; }
    bool AlwaysHit() { return this.alwaysHit; }
    bool AlwaysCritical() { return this.alwaysCritical; }
    int StartingDirectionMode() { return this.startingDirectionMode; }
    string DamageFormula() { return this.damageFormula; }
    int BuffEffectCount() { return this.buffEffects.Count; }
    string BuffEffectAt(int index) { return this.buffEffects[index]; }

    void SetIconResource(string newValue) { this.iconResource = newValue; }
    void SetTooltip(string newValue) { this.tooltip = newValue; }
    void SetLevel(int newValue) { this.level = newValue; }
    void SetDamageFactor(double newValue) { this.damageFactor = newValue; }
    void SetTargetFaction(string newValue) { this.targetFaction = newValue; }
    void SetRange(int minimum, int maximum) {
        this.minimumRange = minimum;
        this.attackRange = maximum;
    }
    void SetAction(string newValue) { this.action = newValue; }
    void SetCosts(int hp, int mp, int rage) {
        this.hpCost = hp;
        this.mpCost = mp;
        this.rageCost = rage;
    }
    void SetThreat(int newValue) { this.threat = newValue; }
    void SetCooldownMilliseconds(int newValue) { this.cooldownMilliseconds = newValue; }
    void SetTargetMode(int newValue) { this.targetMode = newValue; }
    void SetPriority(double newValue) { this.priority = newValue; }
    void SetDamageDelayMilliseconds(int newValue) {
        this.damageDelayMilliseconds = newValue;
    }
    void SetAutoEndPrevious(bool newValue) { this.autoEndPrevious = newValue; }
    void SetAlwaysHit(bool newValue) { this.alwaysHit = newValue; }
    void SetAlwaysCritical(bool newValue) { this.alwaysCritical = newValue; }
    void SetStartingDirectionMode(int newValue) {
        this.startingDirectionMode = newValue;
    }
    void SetDamageFormula(string newValue) { this.damageFormula = newValue; }
    void AddBuffEffect(string buffId) { this.buffEffects.Add(buffId); }

    void Validate(Legend2Diagnostics diagnostics) {
        string path = "skills." + this.id;
        Legend2Validation.Required(diagnostics, this.id, "skills", "L2SKL001");
        Legend2Validation.Required(
            diagnostics, this.displayName, path + ".displayName", "L2SKL002");
        Legend2Validation.Positive(
            diagnostics, this.level, path + ".level", "L2SKL003");
        if (this.minimumRange < 0 || this.attackRange < this.minimumRange) {
            diagnostics.AddError(
                "L2SKL004",
                path + ".range",
                "Skill range must be non-negative and maximum must cover minimum.");
        }
        if (this.cooldownMilliseconds < 0) {
            diagnostics.AddError(
                "L2SKL005", path + ".cooldown", "Cooldown cannot be negative.");
        }
        if (this.targetMode < Legend2SkillTarget.Actor()
            || this.targetMode > Legend2SkillTarget.Player()) {
            diagnostics.AddError(
                "L2SKL006", path + ".targetMode", "Target mode must be between 0 and 3.");
        }
    }
}

class Legend2BuffDefinition {
    string id;
    string displayName;
    string iconResource;
    string title;
    string tooltip;
    int durationMilliseconds;
    int triggerIntervalMilliseconds;
    bool removeOnDeath;
    bool removeOnMove;
    bool removeOnAttack;
    bool removeOnDamage;
    bool movementDisabled;
    bool attackDisabled;
    bool blinded;
    bool runningAllowed;
    Legend2Attributes attributes;

    static Legend2BuffDefinition Create(string id, string displayName) {
        Legend2BuffDefinition buff = new Legend2BuffDefinition();
        buff.id = id;
        buff.displayName = displayName;
        buff.iconResource = "";
        buff.title = "";
        buff.tooltip = "";
        buff.durationMilliseconds = -1;
        buff.triggerIntervalMilliseconds = 0;
        buff.removeOnDeath = true;
        buff.removeOnMove = false;
        buff.removeOnAttack = false;
        buff.removeOnDamage = false;
        buff.movementDisabled = false;
        buff.attackDisabled = false;
        buff.blinded = false;
        buff.runningAllowed = true;
        buff.attributes = Legend2Attributes.Create();
        return buff;
    }

    string Id() { return this.id; }
    string DisplayName() { return this.displayName; }
    string IconResource() { return this.iconResource; }
    string Title() { return this.title; }
    string Tooltip() { return this.tooltip; }
    int DurationMilliseconds() { return this.durationMilliseconds; }
    int TriggerIntervalMilliseconds() { return this.triggerIntervalMilliseconds; }
    bool RemoveOnDeath() { return this.removeOnDeath; }
    bool RemoveOnMove() { return this.removeOnMove; }
    bool RemoveOnAttack() { return this.removeOnAttack; }
    bool RemoveOnDamage() { return this.removeOnDamage; }
    bool MovementDisabled() { return this.movementDisabled; }
    bool AttackDisabled() { return this.attackDisabled; }
    bool Blinded() { return this.blinded; }
    bool RunningAllowed() { return this.runningAllowed; }
    Legend2Attributes Attributes() { return this.attributes; }

    void SetIconResource(string newValue) { this.iconResource = newValue; }
    void SetTitle(string newValue) { this.title = newValue; }
    void SetTooltip(string newValue) { this.tooltip = newValue; }
    void SetDurationMilliseconds(int newValue) { this.durationMilliseconds = newValue; }
    void SetTriggerIntervalMilliseconds(int newValue) {
        this.triggerIntervalMilliseconds = newValue;
    }
    void SetRemoveConditions(
        bool death,
        bool move,
        bool attack,
        bool damage
    ) {
        this.removeOnDeath = death;
        this.removeOnMove = move;
        this.removeOnAttack = attack;
        this.removeOnDamage = damage;
    }
    void SetRestrictions(
        bool movementDisabled,
        bool attackDisabled,
        bool blinded,
        bool runningAllowed
    ) {
        this.movementDisabled = movementDisabled;
        this.attackDisabled = attackDisabled;
        this.blinded = blinded;
        this.runningAllowed = runningAllowed;
    }

    void Validate(Legend2Diagnostics diagnostics) {
        string path = "buffs." + this.id;
        Legend2Validation.Required(diagnostics, this.id, "buffs", "L2BUF001");
        Legend2Validation.Required(
            diagnostics, this.displayName, path + ".displayName", "L2BUF002");
        if (this.durationMilliseconds < -1) {
            diagnostics.AddError(
                "L2BUF003",
                path + ".durationMilliseconds",
                "Duration must be -1 or a non-negative value.");
        }
        if (this.triggerIntervalMilliseconds < 0) {
            diagnostics.AddError(
                "L2BUF004",
                path + ".triggerIntervalMilliseconds",
                "Trigger interval cannot be negative.");
        }
    }
}

class Legend2BuffInstance {
    Legend2BuffDefinition definition;
    Legend2Actor source;
    int remainingMilliseconds;
    int triggerElapsedMilliseconds;

    static Legend2BuffInstance Create(Legend2BuffDefinition definition) {
        return CreateFrom(definition, null);
    }

    static Legend2BuffInstance CreateFrom(
        Legend2BuffDefinition definition,
        Legend2Actor source
    ) {
        Legend2BuffInstance instance = new Legend2BuffInstance();
        instance.definition = definition;
        instance.source = source;
        instance.remainingMilliseconds = definition.DurationMilliseconds();
        instance.triggerElapsedMilliseconds = 0;
        return instance;
    }

    Legend2BuffDefinition Definition() { return this.definition; }
    Legend2Actor Source() { return this.source; }
    int RemainingMilliseconds() { return this.remainingMilliseconds; }
    bool IsInfinite() { return this.remainingMilliseconds < 0; }
    bool IsExpired() { return this.remainingMilliseconds == 0; }

    int Tick(int deltaMilliseconds) {
        if (deltaMilliseconds <= 0) { return 0; }
        if (this.remainingMilliseconds > 0) {
            this.remainingMilliseconds = this.remainingMilliseconds - deltaMilliseconds;
            if (this.remainingMilliseconds < 0) { this.remainingMilliseconds = 0; }
        }
        int interval = this.definition.TriggerIntervalMilliseconds();
        if (interval <= 0) { return 0; }
        this.triggerElapsedMilliseconds =
            this.triggerElapsedMilliseconds + deltaMilliseconds;
        int triggerCount = this.triggerElapsedMilliseconds / interval;
        this.triggerElapsedMilliseconds =
            this.triggerElapsedMilliseconds % interval;
        return triggerCount;
    }
}
