using System;
using System.IO;

namespace Game.Rts.Formats;

// Little-endian reader over an in-memory byte buffer. RTS asset formats
// (MIX, PAL, SHP, TMP, VXL, ...) are little-endian and routinely contain
// embedded NUL bytes, so the length is tracked explicitly instead of relying
// on string termination. Out-of-range reads return -1 rather than trapping so
// callers can validate a header before trusting the rest of a file.
class BinaryReader {
    string data;
    int length;
    int pos;

    static BinaryReader FromBuffer(string data, int length) {
        BinaryReader r = new BinaryReader();
        r.data = data;
        r.length = length;
        r.pos = 0;
        return r;
    }

    static BinaryReader FromFile(string path, int length) {
        string buf = File.ReadBytes(path, 0, length);
        return BinaryReader.FromBuffer(buf, length);
    }

    int Length() { return this.length; }
    int Position() { return this.pos; }
    bool Eof() { return this.pos >= this.length; }
    void Seek(int offset) { this.pos = offset; }
    void Skip(int count) { this.pos = this.pos + count; }

    // Unsigned byte at an absolute index without moving the cursor.
    int ByteAt(int index) {
        if (index < 0 || index >= this.length) { return -1; }
        int b = this.data[index];
        return b & 0xFF;
    }

    int ReadU8() {
        int b = this.ByteAt(this.pos);
        if (b >= 0) { this.pos = this.pos + 1; }
        return b;
    }

    int ReadU16() {
        int b0 = this.ReadU8();
        int b1 = this.ReadU8();
        return (b1 << 8) | b0;
    }

    // 32-bit little-endian value returned as long so the full unsigned range
    // survives (a plain int would go negative once bit 31 is set).
    long ReadU32() {
        long b0 = this.ReadU8();
        long b1 = this.ReadU8();
        long b2 = this.ReadU8();
        long b3 = this.ReadU8();
        return (b3 << 24) | (b2 << 16) | (b1 << 8) | b0;
    }

    // 32-bit little-endian signed value (used for offsets that fit in int).
    int ReadI32() {
        int b0 = this.ReadU8();
        int b1 = this.ReadU8();
        int b2 = this.ReadU8();
        int b3 = this.ReadU8();
        return (b3 << 24) | (b2 << 16) | (b1 << 8) | b0;
    }
}
