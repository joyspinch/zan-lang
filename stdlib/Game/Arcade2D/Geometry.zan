using System;

namespace Game.Arcade2D;

class Vector2 {
    double x;
    double y;

    static Vector2 Create(double x, double y) {
        Vector2 vector = new Vector2();
        vector.x = x;
        vector.y = y;
        return vector;
    }

    double X() { return this.x; }
    double Y() { return this.y; }
    void Set(double x, double y) { this.x = x; this.y = y; }
    void Add(double x, double y) { this.x = this.x + x; this.y = this.y + y; }
}

class Rect2 {
    double x;
    double y;
    double width;
    double height;

    static Rect2 Create(double x, double y, double width, double height) {
        Rect2 rect = new Rect2();
        rect.x = x;
        rect.y = y;
        rect.width = width;
        rect.height = height;
        return rect;
    }

    double X() { return this.x; }
    double Y() { return this.y; }
    double Width() { return this.width; }
    double Height() { return this.height; }
    double Right() { return this.x + this.width; }
    double Bottom() { return this.y + this.height; }
}

class Circle2 {
    double x;
    double y;
    double radius;

    static Circle2 Create(double x, double y, double radius) {
        Circle2 circle = new Circle2();
        circle.x = x;
        circle.y = y;
        circle.radius = radius;
        return circle;
    }

    double X() { return this.x; }
    double Y() { return this.y; }
    double Radius() { return this.radius; }
}

class Collision2D {
    static bool PointInRect(double x, double y, Rect2 rect) {
        return rect != null
            && x >= rect.X()
            && y >= rect.Y()
            && x <= rect.Right()
            && y <= rect.Bottom();
    }

    static bool Rects(Rect2 a, Rect2 b) {
        if (a == null || b == null) { return false; }
        return a.X() < b.Right()
            && a.Right() > b.X()
            && a.Y() < b.Bottom()
            && a.Bottom() > b.Y();
    }

    static bool Circles(Circle2 a, Circle2 b) {
        if (a == null || b == null) { return false; }
        double dx = a.X() - b.X();
        double dy = a.Y() - b.Y();
        double radius = a.Radius() + b.Radius();
        return dx * dx + dy * dy <= radius * radius;
    }

    static double DistanceSquared(
        double ax,
        double ay,
        double bx,
        double by
    ) {
        double dx = ax - bx;
        double dy = ay - by;
        return dx * dx + dy * dy;
    }
}

class Camera2D {
    double x;
    double y;
    double zoom;
    int viewportWidth;
    int viewportHeight;

    static Camera2D Create(int viewportWidth, int viewportHeight) {
        Camera2D camera = new Camera2D();
        camera.x = 0.0;
        camera.y = 0.0;
        camera.zoom = 1.0;
        camera.viewportWidth = viewportWidth;
        camera.viewportHeight = viewportHeight;
        return camera;
    }

    void CenterOn(double x, double y) {
        this.x = x - (double)this.viewportWidth / this.zoom / 2.0;
        this.y = y - (double)this.viewportHeight / this.zoom / 2.0;
    }

    void SetPosition(double x, double y) { this.x = x; this.y = y; }
    void SetZoom(double zoom) {
        if (zoom < 0.1) { zoom = 0.1; }
        if (zoom > 8.0) { zoom = 8.0; }
        this.zoom = zoom;
    }

    int ScreenX(double worldX) {
        return (int)((worldX - this.x) * this.zoom);
    }

    int ScreenY(double worldY) {
        return (int)((worldY - this.y) * this.zoom);
    }

    double WorldX(double screenX) { return screenX / this.zoom + this.x; }
    double WorldY(double screenY) { return screenY / this.zoom + this.y; }
    double X() { return this.x; }
    double Y() { return this.y; }
    double Zoom() { return this.zoom; }
}
