using System;
using System.Collections.Generic;

namespace Game.Dm;

// A 地图物件 (map object): image/animation placed on the ground or object layer.
class MapObject {
    int layer;      // 显示位置: 0 bottom / 1 ground1 / 2 ground2 / 3 object(sorted) / 4 top
    int x;          // 坐标 x (map coordinate)
    int y;          // 坐标 y (map coordinate)
    string res;     // 资源标识: "anim,action" for animations
    int anchorX;    // 锚点 x (also anim sync group when nonzero)
    int anchorY;    // 锚点 y

    static MapObject Of(int layer, int x, int y, string res, int anchorX, int anchorY) {
        MapObject o = new MapObject();
        o.layer = layer; o.x = x; o.y = y;
        o.res = res; o.anchorX = anchorX; o.anchorY = anchorY;
        return o;
    }
    int Layer() { return this.layer; }
    string Res() { return this.res; }
}

// A 地图格子 (grid cell) marking obstacle/transparent info.
class MapCell {
    int x;      // 格子 x
    int y;      // 格子 y
    int flags;  // 类型: 1 obstacle / 2 transparent / 3 both

    static MapCell Of(int x, int y, int flags) {
        MapCell c = new MapCell();
        c.x = x; c.y = y; c.flags = flags;
        return c;
    }
    bool IsObstacle() { return (this.flags == 1) || (this.flags == 3); }
    bool IsTransparent() { return (this.flags == 2) || (this.flags == 3); }
}

// A 地图角色 (map spawn) entry.
class MapSpawn {
    string name;      // 名称: npc component name
    Faction faction;  // 阵营
    int x;            // 格子 x: spawn center
    int y;            // 格子 y: spawn center
    int range;        // 范围: spawn range
    int count;        // 数量: spawn count
    int level;        // 等级

    static MapSpawn Of(string name, Faction faction, int x, int y, int range, int count) {
        MapSpawn s = new MapSpawn();
        s.name = name; s.faction = faction;
        s.x = x; s.y = y; s.range = range; s.count = count;
        s.level = 0;
        return s;
    }
    MapSpawn SetLevel(int level) { this.level = level; return this; }
    string Name() { return this.name; }
    Faction Camp() { return this.faction; }
    int Count() { return this.count; }
}

// 地图 (map) component. A rectangular grid of cells; may be built from config
// items or from a 地图模板 (map template). Config: { 类型="地图", 名称=..., ... }.
class MapConfig {
    string kind;        // 类型: fixed "地图"
    string name;        // 名称
    int cellWidth;      // 格子宽度
    int cellHeight;     // 格子高度
    int columns;        // 格子列数
    int rows;           // 格子行数
    bool defaultMap;    // 默认地图
    int startX;         // 初始位置 x
    int startY;         // 初始位置 y
    string template;    // 地图模板: template id (empty when config-built)

    List<DmResource> resources; // 资源表
    List<MapObject> objects;    // 地图物件
    List<MapCell> cells;        // 地图格子
    List<MapSpawn> spawns;      // 地图角色

    static MapConfig Create(string name) {
        MapConfig m = new MapConfig();
        m.kind = "地图";
        m.name = name;
        m.cellWidth = 64;
        m.cellHeight = 32;
        m.columns = 0;
        m.rows = 0;
        m.defaultMap = false;
        m.startX = 0;
        m.startY = 0;
        m.template = "";
        m.resources = new List<DmResource>();
        m.objects = new List<MapObject>();
        m.cells = new List<MapCell>();
        m.spawns = new List<MapSpawn>();
        return m;
    }

    MapConfig SetGrid(int cellW, int cellH, int cols, int rows) {
        this.cellWidth = cellW; this.cellHeight = cellH;
        this.columns = cols; this.rows = rows;
        return this;
    }
    MapConfig SetDefault(bool v) { this.defaultMap = v; return this; }
    MapConfig SetStart(int x, int y) { this.startX = x; this.startY = y; return this; }
    MapConfig SetTemplate(string t) { this.template = t; return this; }
    MapConfig AddResource(string id, string file) {
        this.resources.Add(DmResource.Of(id, file));
        return this;
    }
    MapConfig AddObject(MapObject o) { this.objects.Add(o); return this; }
    MapConfig AddCell(MapCell c) { this.cells.Add(c); return this; }
    MapConfig AddSpawn(MapSpawn s) { this.spawns.Add(s); return this; }

    string Kind() { return this.kind; }
    string Name() { return this.name; }
    int Columns() { return this.columns; }
    int Rows() { return this.rows; }
    bool IsDefault() { return this.defaultMap; }
    bool UsesTemplate() { return this.template.Length > 0; }
    int ObjectCount() { return this.objects.Count; }
    int CellCount() { return this.cells.Count; }
    int SpawnCount() { return this.spawns.Count; }
}
