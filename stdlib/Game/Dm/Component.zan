using System;
using System.Collections.Generic;

namespace Game.Dm;

// Shared types for DM3 (Dream Mod 3.0) component configs. Every component
// (地图/角色/道具/技能/状态/窗口/成长) is a config table whose first field is
// 类型 (a fixed type tag) and 名称 (a globally unique id). These typed helpers
// model the config items documented for those components.

// 阵营 (faction) used by 地图角色 / 角色 configs.
enum Faction {
    Friendly, // 友方
    Neutral,  // 中立
    Enemy     // 敌方
}

// An 内观/外观 entry (paperdoll layer): 位置 (slot) plus an image or animation
// and an optional offset/scale/color.
class Appearance {
    string slot;    // 位置: slot name, "-1" means draw underneath
    string image;   // 图片
    string anim;    // 动画
    int x;          // 显示偏移 x
    int y;          // 显示偏移 y
    string scale;   // 缩放
    DmColor color;  // 颜色 (optional; null when unset)

    static Appearance Image(string slot, string image) {
        Appearance a = new Appearance();
        a.slot = slot; a.image = image; a.anim = "";
        a.x = 0; a.y = 0; a.scale = ""; a.color = null;
        return a;
    }
    static Appearance Anim(string slot, string anim) {
        Appearance a = new Appearance();
        a.slot = slot; a.image = ""; a.anim = anim;
        a.x = 0; a.y = 0; a.scale = ""; a.color = null;
        return a;
    }
    Appearance At(int x, int y) { this.x = x; this.y = y; return this; }
    Appearance Scaled(string scale) { this.scale = scale; return this; }
    Appearance Tint(DmColor c) { this.color = c; return this; }

    string Slot() { return this.slot; }
    string ImagePath() { return this.image; }
    string AnimPath() { return this.anim; }
}

// A named sound binding (音效): an event name mapped to a resource id.
class DmSound {
    string event;     // 事件 (发现/使用/攻击/命中/开/关/...)
    string resource;  // 素材标识

    static DmSound Of(string event, string resource) {
        DmSound s = new DmSound();
        s.event = event;
        s.resource = resource;
        return s;
    }
    string Event() { return this.event; }
    string Resource() { return this.resource; }
}

// 血条效果 (health bar overlay) on a 角色.
class HealthBar {
    string skin;        // 皮肤
    int offsetY;        // 显示偏移: y offset from foot position
    DmColor barColor;   // 血条颜色
    DmColor fadeColor;  // 过渡色
    int barShow;        // 血条显示: -1 hidden / 0 focus / 1 always / 2 hurt / 3 non-zero
    int valueShow;      // 血量显示: same enumeration
    int valueMode;      // 血量模式: 0 actual / 1 percent
    string bindMin;     // 属性绑定 最小值 (default "hp")
    string bindMax;     // 属性绑定 最大值 (default "maxhp")

    static HealthBar Create(string skin) {
        HealthBar h = new HealthBar();
        h.skin = skin;
        h.offsetY = 0;
        h.barColor = DmColor.Rgb(0, 222, 0);
        h.fadeColor = DmColor.Rgb(222, 222, 0);
        h.barShow = 0;
        h.valueShow = -1;
        h.valueMode = 0;
        h.bindMin = "hp";
        h.bindMax = "maxhp";
        return h;
    }
    HealthBar Offset(int y) { this.offsetY = y; return this; }
    HealthBar Bar(DmColor c) { this.barColor = c; return this; }
    HealthBar Bind(string minAttr, string maxAttr) {
        this.bindMin = minAttr; this.bindMax = maxAttr; return this;
    }
    HealthBar Show(int barShow, int valueShow) {
        this.barShow = barShow; this.valueShow = valueShow; return this;
    }
    string Skin() { return this.skin; }
    string BindMin() { return this.bindMin; }
    string BindMax() { return this.bindMax; }
}
