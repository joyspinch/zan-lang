using System;

namespace System.Collections;

/// <summary>A node in a <see cref="LinkedList{T}"/>, exposing its neighbours.</summary>
class LinkedListNode<T> {
    T item;
    LinkedListNode<T> prev;
    LinkedListNode<T> next;

    LinkedListNode(T v) { item = v; prev = null; next = null; }

    /// <summary>The value stored in this node.</summary>
    T Value() { return item; }

    /// <summary>The next node, or null at the tail.</summary>
    LinkedListNode<T> Next() { return next; }

    /// <summary>The previous node, or null at the head.</summary>
    LinkedListNode<T> Prev() { return prev; }
}

/// <summary>
/// A doubly-linked list. Insertion and removal at either end are O(1). Works
/// for value types (int, double, bool) and reference types alike. Traverse it
/// with <see cref="Head"/> and <see cref="LinkedListNode{T}.Next"/>.
///
/// The end accessors (<see cref="First"/>, <see cref="Last"/>,
/// <see cref="RemoveFirst"/>, <see cref="RemoveLast"/>) require a non-empty
/// list; guard with <see cref="IsEmpty"/> or <see cref="Count"/> first.
/// </summary>
class LinkedList<T> {
    LinkedListNode<T> head;
    LinkedListNode<T> tail;
    int count;

    LinkedList() { head = null; tail = null; count = 0; }

    /// <summary>Appends an item at the tail. O(1).</summary>
    void AddLast(T v) {
        LinkedListNode<T> n = new LinkedListNode<T>(v);
        if (tail == null) { head = n; tail = n; }
        else { n.prev = tail; tail.next = n; tail = n; }
        count = count + 1;
    }

    /// <summary>Prepends an item at the head. O(1).</summary>
    void AddFirst(T v) {
        LinkedListNode<T> n = new LinkedListNode<T>(v);
        if (head == null) { head = n; tail = n; }
        else { n.next = head; head.prev = n; head = n; }
        count = count + 1;
    }

    /// <summary>Removes and returns the head item. O(1).</summary>
    T RemoveFirst() {
        T v = head.item;
        head = head.next;
        if (head == null) { tail = null; } else { head.prev = null; }
        count = count - 1;
        return v;
    }

    /// <summary>Removes and returns the tail item. O(1).</summary>
    T RemoveLast() {
        T v = tail.item;
        tail = tail.prev;
        if (tail == null) { head = null; } else { tail.next = null; }
        count = count - 1;
        return v;
    }

    /// <summary>The head item without removing it.</summary>
    T First() { return head.item; }

    /// <summary>The tail item without removing it.</summary>
    T Last() { return tail.item; }

    /// <summary>The head node (null when empty), for traversal.</summary>
    LinkedListNode<T> Head() { return head; }

    /// <summary>The tail node (null when empty), for traversal.</summary>
    LinkedListNode<T> Tail() { return tail; }

    /// <summary>The number of items.</summary>
    int Count() { return count; }

    /// <summary>Whether the list has no items.</summary>
    bool IsEmpty() { return count == 0; }

    /// <summary>Removes all items.</summary>
    void Clear() { head = null; tail = null; count = 0; }
}
