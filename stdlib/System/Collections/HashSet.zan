using System;

namespace System.Collections;

/// <summary>
/// A collection of unique items, backed by a dynamic <c>List</c> with a linear
/// scan (O(n) per <see cref="Add"/>, <see cref="Contains"/> and
/// <see cref="Remove"/>; a hashed store awaits a generic hashing facility).
///
/// Equality: because a generic element type is erased to a reference at
/// runtime, uniqueness compares
/// <list type="bullet">
///   <item>value types (int, long, double, bool, enum) by value — exact; and</item>
///   <item>reference types, INCLUDING string, by identity (same instance) —
///         two equal-but-distinct strings are treated as different.</item>
/// </list>
/// For content-based string sets today, use a <c>Dictionary</c> keyed by the
/// string, whose intrinsic comparison is content-aware. (Content equality for
/// reference elements here would require generic monomorphization.)
/// </summary>
class HashSet<T> {
    List<T> items;

    HashSet() { items = new List<T>(); }

    /// <summary>
    /// Adds an item if not already present. Returns true when the item was
    /// added, false when an equal item already existed.
    /// </summary>
    bool Add(T v) {
        if (items.Contains(v)) { return false; }
        items.Add(v);
        return true;
    }

    /// <summary>Whether an equal item is present.</summary>
    bool Contains(T v) { return items.Contains(v); }

    /// <summary>Removes an equal item if present; returns whether one was removed.</summary>
    bool Remove(T v) {
        int i = items.IndexOf(v);
        if (i < 0) { return false; }
        items.RemoveAt(i);
        return true;
    }

    /// <summary>The number of distinct items.</summary>
    int Count() { return items.Count; }

    /// <summary>Whether the set has no items.</summary>
    bool IsEmpty() { return items.Count == 0; }

    /// <summary>Removes all items.</summary>
    void Clear() { items.Clear(); }

    /// <summary>
    /// The item at insertion index <paramref name="i"/> (0-based), for
    /// enumeration. Order reflects insertion with removals compacted.
    /// </summary>
    T ElementAt(int i) { return items[i]; }
}
