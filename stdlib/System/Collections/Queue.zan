using System;

namespace System.Collections;

/// <summary>A single link in a <see cref="Queue{T}"/>'s singly-linked chain.</summary>
class QueueNode<T> {
    T item;
    QueueNode<T> next;
    QueueNode(T v) { item = v; next = null; }
}

/// <summary>
/// A first-in, first-out (FIFO) collection. Backed by a singly-linked chain
/// with head/tail pointers, so <see cref="Enqueue"/> and <see cref="Dequeue"/>
/// are both O(1). Works for value types (int, double, bool) and reference
/// types alike.
///
/// <see cref="Dequeue"/> and <see cref="Peek"/> require a non-empty queue;
/// guard with <see cref="IsEmpty"/> or <see cref="Count"/> first.
/// </summary>
class Queue<T> {
    QueueNode<T> head;
    QueueNode<T> tail;
    int count;

    Queue() { head = null; tail = null; count = 0; }

    /// <summary>Appends an item to the back of the queue. O(1).</summary>
    void Enqueue(T v) {
        QueueNode<T> n = new QueueNode<T>(v);
        if (tail == null) { head = n; tail = n; }
        else { tail.next = n; tail = n; }
        count = count + 1;
    }

    /// <summary>Removes and returns the item at the front. O(1).</summary>
    T Dequeue() {
        T v = head.item;
        head = head.next;
        if (head == null) { tail = null; }
        count = count - 1;
        return v;
    }

    /// <summary>Returns the front item without removing it.</summary>
    T Peek() { return head.item; }

    /// <summary>The number of items in the queue.</summary>
    int Count() { return count; }

    /// <summary>Whether the queue has no items.</summary>
    bool IsEmpty() { return count == 0; }

    /// <summary>Removes all items.</summary>
    void Clear() { head = null; tail = null; count = 0; }
}
