using System;

namespace System.Data;

/// <summary>
/// Minimal execution contract shared by database connections that support
/// synchronous SQL. Any implementing connection can drive the FreeSQL-style
/// ORM (System.Data.Orm.Model / QueryBuilder), so the ORM works identically
/// over the ODBC DbConnection and the native SQLite / PostgreSQL drivers.
/// </summary>
interface IDbExecutor {
    DbResult Query(string sql, DbParams prms);
    int Execute(string sql, DbParams prms);
    DbResult Query(string sql);
    int Execute(string sql);
    string ExecuteScalar(string sql);
    int GetProvider();
}
