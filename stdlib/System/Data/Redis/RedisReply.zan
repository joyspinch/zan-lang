using System;

namespace System.Data.Redis;

/// <summary>
/// A parsed RESP (REdis Serialization Protocol) reply.
///
/// Redis replies are self-describing; <see cref="kind"/> tells you which field
/// carries the value:
///   - <c>STR</c>   : simple string (<c>+OK</c>)        -> <see cref="str"/>
///   - <c>ERROR</c> : error string (<c>-ERR ...</c>)    -> <see cref="str"/>
///   - <c>INT</c>   : integer (<c>:42</c>)              -> <see cref="integer"/>
///   - <c>BULK</c>  : bulk string (<c>$3\r\nfoo</c>)    -> <see cref="str"/> / <see cref="len"/>
///   - <c>NIL</c>   : null bulk / null array (<c>$-1</c>)
///   - <c>ARRAY</c> : array (<c>*2 ...</c>)             -> <see cref="items"/>
///
/// <see cref="len"/> is the true byte length of a BULK payload; use it instead
/// of <c>str.Length</c> when a value may contain NUL bytes (binary-safe).
/// </summary>
class RedisReply {
    static int STR   = 1;
    static int ERROR = 2;
    static int INT   = 3;
    static int BULK  = 4;
    static int NIL   = 5;
    static int ARRAY = 6;

    int kind;
    string str;
    int len;
    int integer;
    List<RedisReply> items;

    RedisReply() {
        this.kind = RedisReply.NIL;
        this.str = "";
        this.len = 0;
        this.integer = 0;
        this.items = null;
    }

    /// <summary>True if this reply is a null bulk string or null array.</summary>
    bool IsNil() {
        return this.kind == RedisReply.NIL;
    }

    /// <summary>True if this reply is a server error (<c>-ERR ...</c>).</summary>
    bool IsError() {
        return this.kind == RedisReply.ERROR;
    }

    /// <summary>True for a simple or bulk string reply.</summary>
    bool IsString() {
        return this.kind == RedisReply.STR || this.kind == RedisReply.BULK;
    }

    /// <summary>Returns the string payload (empty for nil / non-string kinds).</summary>
    string AsString() {
        if (this.kind == RedisReply.STR || this.kind == RedisReply.BULK ||
            this.kind == RedisReply.ERROR) {
            return this.str;
        }
        if (this.kind == RedisReply.INT) {
            return Convert.ToString(this.integer);
        }
        return "";
    }

    /// <summary>Returns the integer payload (0 for non-integer kinds).</summary>
    int AsInt() {
        if (this.kind == RedisReply.INT) {
            return this.integer;
        }
        if ((this.kind == RedisReply.STR || this.kind == RedisReply.BULK) &&
            this.len > 0) {
            return Convert.ToInt(this.str);
        }
        return 0;
    }

    /// <summary>Number of elements for an ARRAY reply (0 otherwise).</summary>
    int Count() {
        if (this.kind == RedisReply.ARRAY && this.items != null) {
            return this.items.Count;
        }
        return 0;
    }

    /// <summary>Element at <paramref name="i"/> for an ARRAY reply.</summary>
    RedisReply At(int i) {
        return this.items[i];
    }
}
