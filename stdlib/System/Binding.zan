using System;

namespace System;

/// Accessor pair behind a two-way data binding: reads/writes one field of
/// `target`. The compiler synthesises matching functions when a field lvalue
/// is assigned to a Binding<T>-typed slot (`input.data = user.name;`).
delegate T BindGet<T>(object target);
delegate void BindSet<T>(object target, T v);

/// A two-way data binding to a value of type T.
///
/// Component authors declare bindable properties as `Binding<T>` fields.
/// Assigning a field lvalue to such a property is lowered by the compiler
/// into a live binding (Get reads the field, Set writes it back); assigning
/// any other expression produces a constant binding that stores the value.
///
///     class User { string name; }
///     input.data = user.name;   // live: model <-> UI
///     input.data = "hello";     // const: fixed value, still settable
///
/// `version` increments on every Set, so a widget can cheaply detect writes.
class Binding<T> {
    object target;
    BindGet<T> getter;
    BindSet<T> setter;
    bool live;
    T constVal;
    int version;

    /// Current value of the bound field (live) or the stored value (const).
    T Get() {
        if (live) { return getter(target); }
        return constVal;
    }

    /// Write back through the binding (UI -> model for live bindings).
    void Set(T v) {
        version = version + 1;
        if (live) { setter(target, v); return; }
        constVal = v;
    }

    /// Number of writes made through this binding.
    int Version() { return version; }

    /// True when bound to a model field (as opposed to a constant value).
    bool IsLive() { return live; }
}
