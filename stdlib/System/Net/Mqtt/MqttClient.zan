using System;
using System.Net.Sockets;

namespace System.Net.Mqtt;

class MqttPacketType {
    static int CONNECT     = 1;
    static int CONNACK     = 2;
    static int PUBLISH     = 3;
    static int PUBACK      = 4;
    static int SUBSCRIBE   = 8;
    static int SUBACK      = 9;
    static int UNSUBSCRIBE = 10;
    static int UNSUBACK    = 11;
    static int PINGREQ     = 12;
    static int PINGRESP    = 13;
    static int DISCONNECT  = 14;
}

class MqttQos {
    static int AtMostOnce  = 0;
    static int AtLeastOnce = 1;
    static int ExactlyOnce = 2;
}

/// <summary>
/// MQTT v3.1.1 client.
///
/// Coroutine-friendly: every network operation is an <c>async</c> method that
/// awaits the underlying non-blocking socket via <see cref="TcpClient"/>, so an
/// MQTT client used inside a coroutine suspends on the IO reactor (yielding the
/// worker to other coroutines) instead of blocking the OS thread while it waits
/// for a broker reply or an incoming PUBLISH.
///
/// Usage:
///   MqttClient c = await MqttClient.ConnectAsync("broker", 1883, "client-1");
///   int s = await c.SubscribeAsync("sensors/temp", MqttQos.AtLeastOnce);
///   int p = await c.PublishAsync("sensors/temp", "21.5", MqttQos.AtLeastOnce);
///   string msg = await c.ReceiveAsync();   // suspends until a PUBLISH arrives
///   int d = await c.DisconnectAsync();
/// </summary>
class MqttClient {
    TcpClient conn;
    string clientId;
    string host;
    int port;
    bool connected;
    int nextPacketId;
    int keepAlive;

    [DllImport("crt")]
    static extern string calloc(int count, int size);

    [DllImport("crt")]
    static extern void free(string ptr);

    [DllImport("crt")]
    static extern int strlen(string str);

    MqttClient() {
        this.clientId = "";
        this.host = "";
        this.port = 1883;
        this.connected = false;
        this.nextPacketId = 1;
        this.keepAlive = 60;
    }

    // ---- framing helpers ----
    //
    // A single Socket recv returns whatever bytes are currently available, which
    // may be fewer than a whole MQTT packet (TCP is a byte stream). These helpers
    // await the reactor and re-read until an exact count / a full packet has been
    // assembled, so control-packet parsing and payload extraction stay aligned
    // regardless of how the broker's writes are segmented.

    // These read via Socket.Recv (which returns the actual byte count) rather
    // than TcpClient.RecvAsync (which returns a NUL-terminated string): MQTT
    // packets contain NUL bytes, so a string length can't be trusted to report
    // how many bytes arrived. We still suspend on the reactor via ReadReady.

    /// <summary>Reads exactly one byte, or -1 if the peer closed.</summary>
    async int ReadByteAsync() {
        int sock = this.conn.GetSocket();
        string b = calloc(2, 1);
        while (true) {
            await Socket.ReadReady(sock);
            int n = Socket.Recv(sock, b, 1);
            if (n == 0) {
                this.connected = false;
                return -1;
            }
            if (n > 0) {
                return b[0] & 255;
            }
        }
        return -1;
    }

    /// <summary>Reads exactly <paramref name="need"/> bytes, suspending on the IO
    /// reactor across as many recvs as it takes.</summary>
    async string ReadBytesAsync(int need) {
        string buf = calloc(need + 1, 1);
        string tmp = calloc(need + 1, 1);
        int sock = this.conn.GetSocket();
        int got = 0;
        while (got < need) {
            await Socket.ReadReady(sock);
            int n = Socket.Recv(sock, tmp, need - got);
            if (n == 0) {
                this.connected = false;
                return buf;
            }
            if (n > 0) {
                int i = 0;
                while (i < n) {
                    buf[got] = tmp[i];
                    got = got + 1;
                    i = i + 1;
                }
            }
        }
        return buf;
    }

    /// <summary>Decodes the MQTT "remaining length" varint (1-4 bytes).</summary>
    async int ReadRemainingLenAsync() {
        int multiplier = 1;
        int acc = 0;
        int encoded = 128;
        while ((encoded & 128) != 0) {
            encoded = await ReadByteAsync();
            if (encoded < 0) {
                return acc;
            }
            acc = acc + (encoded & 127) * multiplier;
            multiplier = multiplier * 128;
        }
        return acc;
    }

    /// <summary>Reads and discards one whole control packet (e.g. SUBACK / PUBACK),
    /// returning its packet type so the stream stays framed.</summary>
    async int DrainPacketAsync() {
        int b0 = await ReadByteAsync();
        if (b0 < 0) {
            return -1;
        }
        int remainLen = await ReadRemainingLenAsync();
        if (remainLen > 0) {
            string body = await ReadBytesAsync(remainLen);
        }
        return (b0 >> 4) & 15;
    }

    /// <summary>Connects to the broker and performs the MQTT CONNECT/CONNACK
    /// handshake, suspending on the IO reactor for each network step.</summary>
    static async MqttClient ConnectAsync(string host, int port, string clientId) {
        MqttClient mqtt = new MqttClient();
        mqtt.host = host;
        mqtt.port = port;
        mqtt.clientId = clientId;

        mqtt.conn = await TcpClient.ConnectAsync(host, port);

        string packet = mqtt.BuildConnectPacket();
        int sent = await mqtt.conn.SendBytesAsync(packet, mqtt.CalcConnectLen());

        // CONNACK: fixed header (2 bytes) + variable header (2 bytes); byte 2 of
        // the body is the connect return code (0 = accepted).
        int b0 = await mqtt.ReadByteAsync();
        int remainLen = await mqtt.ReadRemainingLenAsync();
        string body = await mqtt.ReadBytesAsync(remainLen);
        int packetType = (b0 >> 4) & 15;
        if (packetType == MqttPacketType.CONNACK && remainLen >= 2) {
            int returnCode = body[1] & 255;
            if (returnCode == 0) {
                mqtt.connected = true;
            }
        }

        return mqtt;
    }

    /// <summary>Publishes a message, suspending on the IO reactor. For QoS 1 it
    /// also awaits the PUBACK. Returns the number of bytes sent.</summary>
    async int PublishAsync(string topic, string message, int qos) {
        int topicLen = strlen(topic);
        int msgLen = strlen(message);

        int byte0 = (MqttPacketType.PUBLISH << 4);
        if (qos > 0) {
            byte0 = byte0 + (qos << 1);
        }

        int remainLen = 2 + topicLen + msgLen;
        if (qos > 0) {
            remainLen = remainLen + 2;
        }

        string packet = calloc(remainLen + 2, 1);
        int offset = 0;
        packet[offset] = byte0;
        offset = offset + 1;
        packet[offset] = remainLen;
        offset = offset + 1;

        packet[offset] = (topicLen >> 8) & 255;
        offset = offset + 1;
        packet[offset] = topicLen & 255;
        offset = offset + 1;

        int i = 0;
        while (i < topicLen) {
            packet[offset] = topic[i];
            offset = offset + 1;
            i = i + 1;
        }

        if (qos > 0) {
            int pid = this.nextPacketId;
            this.nextPacketId = this.nextPacketId + 1;
            packet[offset] = (pid >> 8) & 255;
            offset = offset + 1;
            packet[offset] = pid & 255;
            offset = offset + 1;
        }

        i = 0;
        while (i < msgLen) {
            packet[offset] = message[i];
            offset = offset + 1;
            i = i + 1;
        }

        int sent = await this.conn.SendBytesAsync(packet, offset);

        if (qos == MqttQos.AtLeastOnce) {
            int acked = await DrainPacketAsync();
        }

        return sent;
    }

    /// <summary>Subscribes to a topic and awaits the SUBACK, suspending on the
    /// IO reactor. Returns the number of bytes sent.</summary>
    async int SubscribeAsync(string topic, int qos) {
        int topicLen = strlen(topic);
        int pid = this.nextPacketId;
        this.nextPacketId = this.nextPacketId + 1;

        int remainLen = 2 + 2 + topicLen + 1;
        string packet = calloc(remainLen + 2, 1);
        int offset = 0;

        packet[offset] = (MqttPacketType.SUBSCRIBE << 4) + 2;
        offset = offset + 1;
        packet[offset] = remainLen;
        offset = offset + 1;

        packet[offset] = (pid >> 8) & 255;
        offset = offset + 1;
        packet[offset] = pid & 255;
        offset = offset + 1;

        packet[offset] = (topicLen >> 8) & 255;
        offset = offset + 1;
        packet[offset] = topicLen & 255;
        offset = offset + 1;

        int i = 0;
        while (i < topicLen) {
            packet[offset] = topic[i];
            offset = offset + 1;
            i = i + 1;
        }

        packet[offset] = qos;
        offset = offset + 1;

        int sent = await this.conn.SendBytesAsync(packet, offset);
        int acked = await DrainPacketAsync();
        return sent;
    }

    /// <summary>Unsubscribes from a topic and awaits the UNSUBACK, suspending on
    /// the IO reactor. Returns the number of bytes sent.</summary>
    async int UnsubscribeAsync(string topic) {
        int topicLen = strlen(topic);
        int pid = this.nextPacketId;
        this.nextPacketId = this.nextPacketId + 1;

        int remainLen = 2 + 2 + topicLen;
        string packet = calloc(remainLen + 2, 1);
        int offset = 0;

        packet[offset] = (MqttPacketType.UNSUBSCRIBE << 4) + 2;
        offset = offset + 1;
        packet[offset] = remainLen;
        offset = offset + 1;

        packet[offset] = (pid >> 8) & 255;
        offset = offset + 1;
        packet[offset] = pid & 255;
        offset = offset + 1;

        packet[offset] = (topicLen >> 8) & 255;
        offset = offset + 1;
        packet[offset] = topicLen & 255;
        offset = offset + 1;

        int i = 0;
        while (i < topicLen) {
            packet[offset] = topic[i];
            offset = offset + 1;
            i = i + 1;
        }

        int sent = await this.conn.SendBytesAsync(packet, offset);
        int acked = await DrainPacketAsync();
        return sent;
    }

    /// <summary>Awaits the next inbound PUBLISH and returns its payload,
    /// suspending on the IO reactor until data arrives. Responds to broker
    /// PINGREQ transparently and keeps waiting for a real message.</summary>
    async string ReceiveAsync() {
        int byte0 = await ReadByteAsync();
        if (byte0 < 0) {
            this.connected = false;
            return "";
        }
        int remainLen = await ReadRemainingLenAsync();
        string body = await ReadBytesAsync(remainLen);

        int packetType = (byte0 >> 4) & 15;

        if (packetType == MqttPacketType.PUBLISH) {
            // body: topic length (2) + topic + [packet id (2) if qos>0] + payload
            int topicLen = ((body[0] & 255) << 8) + (body[1] & 255);
            int offset = 2 + topicLen;

            int qos = (byte0 >> 1) & 3;
            if (qos > 0) {
                offset = offset + 2;
            }

            int payloadLen = remainLen - offset;
            string payload = body.Substring(offset, payloadLen);
            return payload;
        } else if (packetType == MqttPacketType.PINGREQ) {
            string pong = calloc(2, 1);
            pong[0] = MqttPacketType.PINGRESP << 4;
            pong[1] = 0;
            int sent = await this.conn.SendBytesAsync(pong, 2);
            return await ReceiveAsync();
        }

        return body;
    }

    /// <summary>Sends a PINGREQ keep-alive, suspending on the IO reactor.
    /// Returns the number of bytes sent.</summary>
    async int PingAsync() {
        string packet = calloc(2, 1);
        packet[0] = MqttPacketType.PINGREQ << 4;
        packet[1] = 0;
        int sent = await this.conn.SendBytesAsync(packet, 2);
        return sent;
    }

    /// <summary>Sends DISCONNECT and closes the connection, suspending on the IO
    /// reactor for the send. Returns the number of bytes sent.</summary>
    async int DisconnectAsync() {
        string packet = calloc(2, 1);
        packet[0] = MqttPacketType.DISCONNECT << 4;
        packet[1] = 0;
        int sent = await this.conn.SendBytesAsync(packet, 2);
        this.conn.Close();
        this.connected = false;
        return sent;
    }

    bool IsConnected() {
        return this.connected;
    }

    string BuildConnectPacket() {
        int clientIdLen = strlen(this.clientId);
        int remainLen = 10 + 2 + clientIdLen;

        string packet = calloc(remainLen + 2, 1);
        int offset = 0;

        packet[offset] = MqttPacketType.CONNECT << 4;
        offset = offset + 1;
        packet[offset] = remainLen;
        offset = offset + 1;

        packet[offset] = 0;
        offset = offset + 1;
        packet[offset] = 4;
        offset = offset + 1;
        packet[offset] = 77;
        offset = offset + 1;
        packet[offset] = 81;
        offset = offset + 1;
        packet[offset] = 84;
        offset = offset + 1;
        packet[offset] = 84;
        offset = offset + 1;

        packet[offset] = 4;
        offset = offset + 1;

        packet[offset] = 2;
        offset = offset + 1;

        packet[offset] = (this.keepAlive >> 8) & 255;
        offset = offset + 1;
        packet[offset] = this.keepAlive & 255;
        offset = offset + 1;

        packet[offset] = (clientIdLen >> 8) & 255;
        offset = offset + 1;
        packet[offset] = clientIdLen & 255;
        offset = offset + 1;

        int i = 0;
        while (i < clientIdLen) {
            packet[offset] = this.clientId[i];
            offset = offset + 1;
            i = i + 1;
        }

        return packet;
    }

    int CalcConnectLen() {
        int clientIdLen = strlen(this.clientId);
        return 2 + 10 + 2 + clientIdLen;
    }
}
