using System;
using System.Net.Sockets;

namespace System.Net;

/// <summary>
/// Legacy pure-socket HTTP client kept under System.Net. The maintained
/// client lives at System.Net.Http.HttpClient; this one is renamed to
/// SocketHttpClient to avoid a duplicate type declaration when both the
/// System.Net and System.Net.Http modules are compiled together (e.g. via
/// the Worker module, which pulls both).
/// </summary>
class SocketHttpClient {
    /// <summary>Performs a simple GET request and returns the response body.</summary>
    static string Get(string host, int port, string path) {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.Connect(sock, host, port);

        StringBuilder sb = new StringBuilder();
        sb.Append("GET ");
        sb.Append(path);
        sb.Append(" HTTP/1.1\r\n");
        sb.Append("Host: ");
        sb.Append(host);
        sb.Append("\r\n");
        sb.Append("Connection: close\r\n");
        sb.Append("\r\n");

        Socket.SendString(sock, sb.ToString());

        StringBuilder response = new StringBuilder();
        bool reading = true;
        while (reading) {
            string buf = Socket.Receive(sock, 4096);
            if (buf.Length == 0) {
                reading = false;
            } else {
                response.Append(buf);
            }
        }

        Socket.Close(sock);

        // Skip HTTP headers, return body
        string raw = response.ToString();
        int bodyStart = 0;
        int len = raw.Length;
        int i = 0;
        while (i < len - 3) {
            if (raw.Substring(i, 4) == "\r\n\r\n") {
                bodyStart = i + 4;
                break;
            }
            i = i + 1;
        }
        if (bodyStart > 0) {
            return raw.Substring(bodyStart);
        }
        return raw;
    }

    /// <summary>Performs a simple POST request.</summary>
    static string Post(string host, int port, string path, string body) {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.Connect(sock, host, port);

        StringBuilder sb = new StringBuilder();
        sb.Append("POST ");
        sb.Append(path);
        sb.Append(" HTTP/1.1\r\n");
        sb.Append("Host: ");
        sb.Append(host);
        sb.Append("\r\n");
        sb.Append("Content-Length: ");
        sb.Append(Convert.ToString(body.Length));
        sb.Append("\r\n");
        sb.Append("Content-Type: application/x-www-form-urlencoded\r\n");
        sb.Append("Connection: close\r\n");
        sb.Append("\r\n");
        sb.Append(body);

        Socket.SendString(sock, sb.ToString());

        StringBuilder response = new StringBuilder();
        bool reading = true;
        while (reading) {
            string buf = Socket.Receive(sock, 4096);
            if (buf.Length == 0) {
                reading = false;
            } else {
                response.Append(buf);
            }
        }

        Socket.Close(sock);

        string raw = response.ToString();
        int bodyStart = 0;
        int len = raw.Length;
        int idx = 0;
        while (idx < len - 3) {
            if (raw.Substring(idx, 4) == "\r\n\r\n") {
                bodyStart = idx + 4;
                break;
            }
            idx = idx + 1;
        }
        if (bodyStart > 0) {
            return raw.Substring(bodyStart);
        }
        return raw;
    }
}

/// <summary>
/// Cross-platform TCP socket wrapper.
/// Replaces the Windows-only Winsock2 TcpSocket.
/// </summary>
class TcpSocket {
    /// <summary>Initializes the socket subsystem.</summary>
    static void Initialize() {
        Socket.Initialize();
    }

    /// <summary>Creates a TCP socket. Returns socket handle.</summary>
    static int Create() {
        return Socket.CreateTcp();
    }

    /// <summary>Sends data on a connected socket.</summary>
    static int Send(int sock, string data) {
        return Socket.SendString(sock, data);
    }

    /// <summary>Receives data from a socket into a buffer.</summary>
    static string Receive(int sock, int bufSize) {
        return Socket.Receive(sock, bufSize);
    }

    /// <summary>Closes a socket.</summary>
    static void Close(int sock) {
        Socket.Close(sock);
    }

    /// <summary>Cleans up the socket subsystem.</summary>
    static void Cleanup() {
        Socket.Cleanup();
    }
}

/// <summary>
/// DNS resolution utility.
/// </summary>
class Dns {
    /// <summary>Resolves a hostname to an IP address.</summary>
    static string Resolve(string hostname) {
        return Socket.Resolve(hostname);
    }
}

/// <summary>
/// IP address utilities.
/// </summary>
class IPAddress {
    static string Any       = "0.0.0.0";
    static string Loopback  = "127.0.0.1";
    static string Broadcast = "255.255.255.255";

    /// <summary>Checks if a string looks like an IPv4 address.</summary>
    static bool IsIPv4(string str) {
        int dotCount = 0;
        int i = 0;
        int len = str.Length;
        while (i < len) {
            string ch = str.Substring(i, 1);
            if (ch == ".") {
                dotCount = dotCount + 1;
            } else if (ch < "0" || ch > "9") {
                return false;
            }
            i = i + 1;
        }
        return dotCount == 3;
    }
}
