using System;

namespace System.Net;

/// <summary>
/// HTTP client using WinHTTP API.
/// </summary>
class HttpClient {
    [DllImport("winhttp", EntryPoint = "WinHttpOpen")]
    static extern int WinHttpOpen(string userAgent, int accessType, string proxy, string proxyBypass, int flags);

    [DllImport("winhttp", EntryPoint = "WinHttpConnect")]
    static extern int WinHttpConnect(int session, string serverName, int port, int reserved);

    [DllImport("winhttp", EntryPoint = "WinHttpOpenRequest")]
    static extern int WinHttpOpenRequest(int connect, string verb, string objectName, string version, string referrer, int acceptTypes, int flags);

    [DllImport("winhttp", EntryPoint = "WinHttpSendRequest")]
    static extern int WinHttpSendRequest(int request, string headers, int headersLen, string optional, int optionalLen, int totalLen, int context);

    [DllImport("winhttp", EntryPoint = "WinHttpReceiveResponse")]
    static extern int WinHttpReceiveResponse(int request, int reserved);

    [DllImport("winhttp", EntryPoint = "WinHttpReadData")]
    static extern int WinHttpReadData(int request, string buffer, int bufferSize, string bytesRead);

    [DllImport("winhttp", EntryPoint = "WinHttpCloseHandle")]
    static extern int WinHttpCloseHandle(int handle);

    [DllImport("msvcrt")]
    static extern string calloc(int count, int size);

    [DllImport("msvcrt")]
    static extern void free(string ptr);

    [DllImport("msvcrt")]
    static extern string strcat(string dest, string src);

    [DllImport("msvcrt")]
    static extern int strlen(string str);
}

/// <summary>
/// Simple TCP socket wrapper using Winsock2.
/// </summary>
class TcpSocket {
    [DllImport("ws2_32", EntryPoint = "WSAStartup")]
    static extern int WSAStartup(int version, string wsaData);

    [DllImport("ws2_32")]
    static extern int socket(int af, int type, int protocol);

    [DllImport("ws2_32")]
    static extern int closesocket(int s);

    [DllImport("ws2_32")]
    static extern int send(int s, string buf, int len, int flags);

    [DllImport("ws2_32")]
    static extern int recv(int s, string buf, int len, int flags);

    [DllImport("ws2_32", EntryPoint = "WSACleanup")]
    static extern int WSACleanup();

    [DllImport("msvcrt")]
    static extern string calloc(int count, int size);

    /// <summary>Initializes Winsock.</summary>
    static void Initialize() {
        string wsaData = calloc(512, 1);
        WSAStartup(514, wsaData);
    }

    /// <summary>Creates a TCP socket. Returns socket handle.</summary>
    static int Create() {
        return socket(2, 1, 6);
    }

    /// <summary>Sends data on a connected socket.</summary>
    static int Send(int sock, string data) {
        int len = 0;
        // Calculate string length
        string p = data;
        while (p.Substring(len, 1) != "\0" && len < 65536) {
            len = len + 1;
        }
        return send(sock, data, len, 0);
    }

    /// <summary>Receives data from a socket into a buffer.</summary>
    static string Receive(int sock, int bufSize) {
        string buf = calloc(bufSize + 1, 1);
        recv(sock, buf, bufSize, 0);
        return buf;
    }

    /// <summary>Closes a socket.</summary>
    static void Close(int sock) {
        closesocket(sock);
    }

    /// <summary>Cleans up Winsock.</summary>
    static void Cleanup() {
        WSACleanup();
    }
}
