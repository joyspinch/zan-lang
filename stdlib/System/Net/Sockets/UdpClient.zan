using System;
using System.Net.Sockets;

namespace System.Net.Sockets;

/// <summary>
/// Cross-platform async UDP client/server.
/// UDP is connectionless: one socket can send to and receive from
/// multiple peers. Integrates with the coroutine scheduler.
///
/// Usage (server):
///   var udp = UdpClient.Bind("0.0.0.0", 9999);
///   while (true) {
///       string data = await udp.RecvFromAsync(4096);
///       // process data
///   }
///
/// Usage (client):
///   var udp = UdpClient.Create();
///   await udp.SendToAsync("Hello", "127.0.0.1", 9999);
/// </summary>
class UdpClient {
    int sock;
    string host;
    int port;
    bool bound;

    [DllImport("crt")]
    static extern int strlen(string str);

    [DllImport("crt")]
    static extern string calloc(int count, int size);

    UdpClient() {
        this.sock = -1;
        this.host = "";
        this.port = 0;
        this.bound = false;
    }

    /// <summary>Creates an unbound UDP socket.</summary>
    static UdpClient Create() {
        Socket.Initialize();
        UdpClient client = new UdpClient();
        client.sock = Socket.CreateUdp();
        Socket.SetNonBlocking(client.sock);
        return client;
    }

    /// <summary>Creates a UDP socket bound to a local address and port.</summary>
    static UdpClient Bind(string host, int port) {
        Socket.Initialize();
        UdpClient client = new UdpClient();
        client.host = host;
        client.port = port;
        client.sock = Socket.CreateUdp();
        Socket.SetReuseAddr(client.sock);
        Socket.Bind(client.sock, host, port);
        Socket.SetNonBlocking(client.sock);
        client.bound = true;
        return client;
    }

    /// <summary>Sends a datagram to the specified address.</summary>
    int SendTo(string data, string ip, int port) {
        int len = strlen(data);
        return Socket.SendTo(this.sock, data, len, ip, port);
    }

    /// <summary>Sends a datagram, suspending on the IO reactor until writable.</summary>
    async int SendToAsync(string data, string ip, int port) {
        int len = strlen(data);
        int r = await Socket.SendToAsync(this.sock, data, len, ip, port);
        return r;
    }

    /// <summary>Sends raw bytes.</summary>
    int SendBytesTo(string data, int len, string ip, int port) {
        return Socket.SendTo(this.sock, data, len, ip, port);
    }

    /// <summary>Receives a datagram synchronously.</summary>
    string RecvFrom(int bufSize) {
        return Socket.RecvFrom(this.sock, bufSize);
    }

    /// <summary>Receives a datagram, suspending on the IO reactor until one
    /// arrives.</summary>
    async string RecvFromAsync(int bufSize) {
        string r = await Socket.RecvFromAsync(this.sock, bufSize);
        return r;
    }

    /// <summary>Receives with default buffer size.</summary>
    async string RecvFromAsync() {
        string r = await Socket.RecvFromAsync(this.sock, 65536);
        return r;
    }

    /// <summary>Closes the UDP socket.</summary>
    void Close() {
        if (this.sock >= 0) {
            Socket.Close(this.sock);
            this.sock = -1;
        }
    }

    /// <summary>Returns the underlying socket handle.</summary>
    int GetSocket() {
        return this.sock;
    }

    /// <summary>Returns whether this socket is bound.</summary>
    bool IsBound() {
        return this.bound;
    }

    /// <summary>Enables broadcast on the socket.</summary>
    void EnableBroadcast() {
        Socket.SetBroadcast(this.sock);
    }
}
