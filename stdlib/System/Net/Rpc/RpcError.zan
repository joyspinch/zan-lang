using System;

namespace System.Net.Rpc;

/// <summary>
/// A transport/protocol-agnostic RPC error. `code == 0` means "no error"; the
/// well-known negative codes mirror JSON-RPC 2.0 so any codec can map onto them
/// (XML-RPC faults, DMTP status codes, ...). This is the single error model the
/// kernel and every adapter share, so callers handle failures uniformly.
/// </summary>
class RpcError {
    int code;
    string message;

    RpcError(int c, string m) {
        code = c;
        message = m;
    }

    /// The canonical "no error" value.
    static RpcError None() { return new RpcError(0, ""); }

    // Well-known JSON-RPC 2.0 codes, reused as the shared vocabulary.
    static RpcError ParseError(string m) { return new RpcError(-32700, m); }
    static RpcError InvalidRequest(string m) { return new RpcError(-32600, m); }
    static RpcError MethodNotFound(string m) { return new RpcError(-32601, m); }
    static RpcError InvalidParams(string m) { return new RpcError(-32602, m); }
    static RpcError Internal(string m) { return new RpcError(-32603, m); }
    static RpcError Transport(string m) { return new RpcError(-32000, m); }
    static RpcError Timeout(string m) { return new RpcError(-32001, m); }

    bool IsError() { return code != 0; }
}
