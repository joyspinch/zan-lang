using System;

namespace System.Net.Rpc;

/// <summary>
/// The wire-format axis of the RPC stack: turns the neutral request/response
/// model into a framed string and back. JSON-RPC, XML-RPC and DMTP each provide
/// one implementation; the kernel (<see cref="RpcClient"/> / a server loop)
/// depends only on this contract, so a new protocol is a new codec, not a new
/// client. Codecs are pure and synchronous -- all IO lives in the transport.
/// </summary>
interface IRpcCodec {
    /// Human-readable protocol name (e.g. "json-rpc-2.0").
    string Name();

    /// Serializes a request to its on-the-wire text form (no framing bytes).
    string EncodeRequest(RpcRequest req);

    /// Parses a reply frame into a response (errors surface via RpcError).
    RpcResponse DecodeResponse(string frame);

    /// Server side: parses an inbound request frame.
    RpcRequest DecodeRequest(string frame);

    /// Server side: serializes a response to its on-the-wire text form.
    string EncodeResponse(RpcResponse resp);
}
