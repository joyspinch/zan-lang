using System;

namespace System.Security.Cryptography;

/// <summary>GM/T 0004-2012 SM3 (Chinese national cryptographic hash), 256-bit
/// output. Pure Zan, operates on raw byte buffers.</summary>
class Sm3 {
    [DllImport("crt")] static extern string calloc(int count, int size);
    [DllImport("crt")] static extern void free(string ptr);

    static int p0(int x) { return (x ^ Bits.Rotl32(x,9) ^ Bits.Rotl32(x,17)) & 4294967295; }
    static int p1(int x) { return (x ^ Bits.Rotl32(x,15) ^ Bits.Rotl32(x,23)) & 4294967295; }

    /// <summary>Computes SM3; returns a freshly allocated 32-byte digest.</summary>
    static string Hash(string msg, int len) {
        int a0=1937774191; int b0=1226093241; int c0=388252375; int d0=3666478592;
        int e0=2842636476; int f0=372324522; int g0=3817729613; int h0=2969243214;
        int total = len + 1 + 8;
        int rem = total % 64; int pad = 0; if (rem != 0) { pad = 64 - rem; }
        int plen = total + pad;
        string m = calloc(plen + 1, 1);
        int i = 0; while (i < len) { m[i] = msg[i] & 255; i = i + 1; }
        m[len] = 128;
        int bits = len * 8; int bi = plen - 8;
        m[bi+0]=(bits>>56)&255; m[bi+1]=(bits>>48)&255; m[bi+2]=(bits>>40)&255; m[bi+3]=(bits>>32)&255;
        m[bi+4]=(bits>>24)&255; m[bi+5]=(bits>>16)&255; m[bi+6]=(bits>>8)&255; m[bi+7]=bits&255;
        int blocks = plen / 64; int bl = 0;
        while (bl < blocks) {
            int off = bl * 64;
            List<int> w = new List<int>();
            int t = 0;
            while (t < 16) {
                int j = off + t*4;
                w.Add((((m[j]&255)<<24)|((m[j+1]&255)<<16)|((m[j+2]&255)<<8)|(m[j+3]&255)) & 4294967295);
                t = t + 1;
            }
            t = 16;
            while (t < 68) {
                int x = w[t-16] ^ w[t-9] ^ Bits.Rotl32(w[t-3],15);
                w.Add((p1(x) ^ Bits.Rotl32(w[t-13],7) ^ w[t-6]) & 4294967295);
                t = t + 1;
            }
            List<int> w1 = new List<int>();
            t = 0; while (t < 64) { w1.Add((w[t] ^ w[t+4]) & 4294967295); t = t + 1; }
            int A=a0; int B=b0; int C=c0; int D=d0; int E=e0; int F=f0; int G=g0; int H=h0;
            int j2 = 0;
            while (j2 < 64) {
                int tj; if (j2 < 16) { tj = 2043430169; } else { tj = 2055708042; }
                int ss1 = Bits.Rotl32((Bits.Rotl32(A,12) + E + Bits.Rotl32(tj, j2 % 32)) & 4294967295, 7);
                int ss2 = ss1 ^ Bits.Rotl32(A,12);
                int ff; int gg;
                if (j2 < 16) { ff = A ^ B ^ C; gg = E ^ F ^ G; }
                else { ff = (A&B)|(A&C)|(B&C); gg = (E&F)|(((E^4294967295)&4294967295)&G); }
                int tt1 = (ff + D + ss2 + w1[j2]) & 4294967295;
                int tt2 = (gg + H + ss1 + w[j2]) & 4294967295;
                D = C; C = Bits.Rotl32(B,9); B = A; A = tt1;
                H = G; G = Bits.Rotl32(F,19); F = E; E = p0(tt2);
                j2 = j2 + 1;
            }
            a0=(a0^A)&4294967295; b0=(b0^B)&4294967295; c0=(c0^C)&4294967295; d0=(d0^D)&4294967295;
            e0=(e0^E)&4294967295; f0=(f0^F)&4294967295; g0=(g0^G)&4294967295; h0=(h0^H)&4294967295;
            bl = bl + 1;
        }
        free(m);
        string o = calloc(33, 1);
        wBE(o,0,a0); wBE(o,4,b0); wBE(o,8,c0); wBE(o,12,d0);
        wBE(o,16,e0); wBE(o,20,f0); wBE(o,24,g0); wBE(o,28,h0);
        return o;
    }
    static void wBE(string b, int o, int v) { b[o]=(v>>24)&255; b[o+1]=(v>>16)&255; b[o+2]=(v>>8)&255; b[o+3]=v&255; }
}
