using System;

namespace System.Security.Cryptography;

/// <summary>Lower-case hexadecimal encode/decode over raw byte buffers
/// (Zan strings used as byte arrays).</summary>
class Hex {
    [DllImport("crt")] static extern string calloc(int count, int size);

    /// <summary>Encodes <paramref name="len"/> bytes of <paramref name="buf"/>
    /// as a lower-case hex string.</summary>
    static string Encode(string buf, int len) {
        string h = "0123456789abcdef";
        StringBuilder sb = new StringBuilder();
        int i = 0;
        while (i < len) {
            int v = buf[i] & 255;
            sb.Append(h.Substring(v >> 4, 1));
            sb.Append(h.Substring(v & 15, 1));
            i = i + 1;
        }
        return sb.ToString();
    }

    static int nibble(int c) {
        if (c >= 48 && c <= 57) { return c - 48; }
        if (c >= 97 && c <= 102) { return c - 87; }
        if (c >= 65 && c <= 70) { return c - 55; }
        return 0;
    }

    /// <summary>Decodes a hex string into a freshly allocated byte buffer.
    /// The number of bytes produced equals <c>hex.Length / 2</c>.</summary>
    static string Decode(string hex) {
        int n = hex.Length / 2;
        string outb = calloc(n + 1, 1);
        int i = 0;
        while (i < n) {
            outb[i] = ((nibble(hex[2*i] & 255) << 4) | nibble(hex[2*i+1] & 255)) & 255;
            i = i + 1;
        }
        return outb;
    }
}
