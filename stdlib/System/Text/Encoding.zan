using System;

namespace System.Text;

/// <summary>
/// Cross-platform text encoding and conversion utilities.
/// Uses C runtime functions available on all platforms.
/// </summary>
class Encoding {
    [DllImport("crt")]
    static extern int strlen(string str);

    [DllImport("crt")]
    static extern string calloc(int count, int size);

    [DllImport("crt")]
    static extern void free(string ptr);

    [DllImport("crt")]
    static extern int sprintf(string buf, string fmt, int val);

    [DllImport("crt")]
    static extern int atoi(string str);

    [DllImport("crt")]
    static extern double atof(string str);

    [DllImport("crt")]
    static extern int snprintf(string buf, int size, string fmt, int val);

    /// <summary>Converts an integer to a string.</summary>
    static string IntToString(int val) {
        string buf = calloc(32, 1);
        sprintf(buf, "%lld", val);
        return buf;
    }

    /// <summary>Converts a double to a string.</summary>
    static string DoubleToString(double val) {
        string buf = calloc(64, 1);
        sprintf(buf, "%g", val);
        return buf;
    }

    /// <summary>Parses a string to an integer.</summary>
    static int ParseInt(string text) {
        return atoi(text);
    }

    /// <summary>Parses a string to a double.</summary>
    static double ParseDouble(string text) {
        return atof(text);
    }

    /// <summary>Gets the byte count of a UTF-8 string.</summary>
    static int GetByteCount(string text) {
        return strlen(text);
    }

    /// <summary>Converts a byte value to a hex string (two characters).</summary>
    static string ByteToHex(int b) {
        string buf = calloc(4, 1);
        sprintf(buf, "%02x", b);
        return buf;
    }

    /// <summary>URL-encodes a string.</summary>
    static string UrlEncode(string text) {
        StringBuilder sb = new StringBuilder();
        int i = 0;
        int len = text.Length;
        while (i < len) {
            string ch = text.Substring(i, 1);
            if ((ch >= "A" && ch <= "Z") || (ch >= "a" && ch <= "z") ||
                (ch >= "0" && ch <= "9") || ch == "-" || ch == "_" ||
                ch == "." || ch == "~") {
                sb.Append(ch);
            } else if (ch == " ") {
                sb.Append("+");
            } else {
                sb.Append("%");
                // Simplified: append hex of the char
                sb.Append(ByteToHex(ch[0]));
            }
            i = i + 1;
        }
        return sb.ToString();
    }

    /// <summary>URL-decodes a string.</summary>
    static string UrlDecode(string text) {
        StringBuilder sb = new StringBuilder();
        int i = 0;
        int len = text.Length;
        while (i < len) {
            string ch = text.Substring(i, 1);
            if (ch == "+" ) {
                sb.Append(" ");
            } else if (ch == "%" && i + 2 < len) {
                string hex = text.Substring(i + 1, 2);
                // Parse hex to char (simplified)
                sb.Append(hex);
                i = i + 2;
            } else {
                sb.Append(ch);
            }
            i = i + 1;
        }
        return sb.ToString();
    }

    /// <summary>Base64 encodes a string.</summary>
    static string Base64Encode(string text) {
        string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
        StringBuilder sb = new StringBuilder();
        int i = 0;
        int len = strlen(text);
        while (i < len) {
            int b0 = text[i] & 255;
            int b1 = 0;
            int b2 = 0;
            int pad = 0;
            if (i + 1 < len) {
                b1 = text[i + 1] & 255;
            } else {
                pad = pad + 1;
            }
            if (i + 2 < len) {
                b2 = text[i + 2] & 255;
            } else {
                pad = pad + 1;
            }
            int triple = (b0 << 16) + (b1 << 8) + b2;
            sb.Append(chars.Substring((triple >> 18) & 63, 1));
            sb.Append(chars.Substring((triple >> 12) & 63, 1));
            if (pad < 2) {
                sb.Append(chars.Substring((triple >> 6) & 63, 1));
            } else {
                sb.Append("=");
            }
            if (pad < 1) {
                sb.Append(chars.Substring(triple & 63, 1));
            } else {
                sb.Append("=");
            }
            i = i + 3;
        }
        return sb.ToString();
    }
}
