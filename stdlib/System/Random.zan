using System;

namespace System;

/// <summary>
/// A general-purpose (non-cryptographic) pseudo-random number generator.
/// Uses a 64-bit linear congruential sequence (Knuth MMIX constants); it is
/// fast and reproducible from a seed but must NOT be used for security — see
/// <c>System.Security.Cryptography.RandomNumberGenerator</c> for that.
/// </summary>
class Random {
    [DllImport("crt")]
    static extern int time(int ptr);

    int state;

    /// <summary>Seeds from the current time.</summary>
    Random() {
        state = time(0);
        if (state == 0) { state = 1; }
    }

    /// <summary>Creates a generator with an explicit seed (reproducible).</summary>
    static Random Seeded(int seed) {
        Random r = new Random();
        r.state = seed;
        if (r.state == 0) { r.state = 1; }
        return r;
    }

    /// <summary>Advances the state and returns the raw 64-bit draw.</summary>
    int NextRaw() {
        state = state * 6364136223846793005 + 1442695040888963407;
        return state;
    }

    /// <summary>A non-negative pseudo-random integer.</summary>
    int Next() {
        int r = NextRaw();
        if (r < 0) { r = -r; }
        if (r < 0) { r = 0; }   // guard the single non-negatable value
        return r;
    }

    /// <summary>A non-negative integer in the range [0, bound).</summary>
    int NextBelow(int bound) {
        if (bound <= 0) { return 0; }
        int r = Next();
        return r - (r / bound) * bound;
    }

    /// <summary>An integer in the range [lo, hi).</summary>
    int Between(int lo, int hi) {
        if (hi <= lo) { return lo; }
        return lo + NextBelow(hi - lo);
    }

    /// <summary>A double in the range [0.0, 1.0).</summary>
    double NextDouble() {
        int r = Next();
        int m = r - (r / 1000000) * 1000000;
        return (double)m / 1000000.0;
    }

    /// <summary>A pseudo-random boolean.</summary>
    bool NextBool() {
        int r = Next();
        return (r - (r / 2) * 2) == 1;
    }
}
