using System;

namespace SDL3;

/// <summary>
/// Access to the most recently polled SDL event.
/// Poll and read events on the main thread.
/// </summary>
class SdlEvent {
    static bool Poll() { return SdlNative.zan_sdl_poll_event() != 0; }
    static int Type() { return SdlNative.zan_sdl_event_type(); }
    static int Timestamp() { return SdlNative.zan_sdl_event_timestamp(); }
    static int WindowId() { return SdlNative.zan_sdl_event_window_id(); }
    static int Data1() { return SdlNative.zan_sdl_event_data1(); }
    static int Data2() { return SdlNative.zan_sdl_event_data2(); }
    static int Scancode() { return SdlNative.zan_sdl_event_scancode(); }
    static int Keycode() { return SdlNative.zan_sdl_event_keycode(); }
    static int Keymod() { return SdlNative.zan_sdl_event_keymod(); }
    static bool IsRepeat() { return SdlNative.zan_sdl_event_repeat() != 0; }
    static double MouseX() { return SdlNative.zan_sdl_event_mouse_x(); }
    static double MouseY() { return SdlNative.zan_sdl_event_mouse_y(); }
    static double MouseDeltaX() { return SdlNative.zan_sdl_event_mouse_dx(); }
    static double MouseDeltaY() { return SdlNative.zan_sdl_event_mouse_dy(); }
    static int MouseButton() { return SdlNative.zan_sdl_event_mouse_button(); }
    static int MouseClicks() { return SdlNative.zan_sdl_event_mouse_clicks(); }
    static string Text() { return SdlNative.zan_sdl_event_text(); }

    static bool IsQuit() {
        int type = Type();
        return type == SdlEventType.Quit() || type == SdlEventType.WindowCloseRequested();
    }
}

class SdlEventType {
    static int Quit() { return 256; }
    static int WindowShown() { return 514; }
    static int WindowHidden() { return 515; }
    static int WindowMoved() { return 517; }
    static int WindowResized() { return 518; }
    static int WindowPixelSizeChanged() { return 519; }
    static int WindowMinimized() { return 521; }
    static int WindowMaximized() { return 522; }
    static int WindowRestored() { return 523; }
    static int WindowFocusGained() { return 526; }
    static int WindowFocusLost() { return 527; }
    static int WindowCloseRequested() { return 528; }
    static int KeyDown() { return 768; }
    static int KeyUp() { return 769; }
    static int TextEditing() { return 770; }
    static int TextInput() { return 771; }
    static int MouseMotion() { return 1024; }
    static int MouseButtonDown() { return 1025; }
    static int MouseButtonUp() { return 1026; }
    static int MouseWheel() { return 1027; }
}

class SdlScancode {
    static int A() { return 4; }
    static int D() { return 7; }
    static int S() { return 22; }
    static int W() { return 26; }
    static int Enter() { return 40; }
    static int Escape() { return 41; }
    static int Space() { return 44; }
    static int F1() { return 58; }
    static int F5() { return 62; }
    static int F11() { return 68; }
    static int Delete() { return 76; }
    static int Right() { return 79; }
    static int Left() { return 80; }
    static int Down() { return 81; }
    static int Up() { return 82; }

    static bool IsDown(int scancode) {
        return SdlNative.zan_sdl_key_down(scancode) != 0;
    }
}

class SdlKeymod {
    static int LeftShift() { return 1; }
    static int RightShift() { return 2; }
    static int LeftControl() { return 64; }
    static int RightControl() { return 128; }
    static int LeftAlt() { return 256; }
    static int RightAlt() { return 512; }

    static bool HasShift(int modifiers) { return (modifiers & 3) != 0; }
    static bool HasControl(int modifiers) { return (modifiers & 192) != 0; }
    static bool HasAlt(int modifiers) { return (modifiers & 768) != 0; }
}

class SdlMouseButton {
    static int Left() { return 1; }
    static int Middle() { return 2; }
    static int Right() { return 3; }
    static int Side1() { return 4; }
    static int Side2() { return 5; }
}
