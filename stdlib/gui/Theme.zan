        t.textSecondary  = -13420999;
        t.textTertiary   = -9012094;
        t.textDisabled   = -4013374;
        t.textInverse    = -1;

        t.bgPrimary      = -1;
        t.bgSecondary    = -328964;
        t.bgTertiary     = -789515;
        t.bgHover        = -789515;
        t.bgActive       = -1184275;
        t.bgDisabled     = -328964;

        t.borderPrimary   = -2039578;
        t.borderSecondary = -1052683;
        t.borderHover     = -13193878;
        t.borderFocus     = -15163304;
        t.divider         = -1052683;
        t.overlay         = 1291845632;
        t.glass           = 0;
        t.gradient        = 0;
