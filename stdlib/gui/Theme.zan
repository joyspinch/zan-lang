        t.fontSizeTiny   = 12;
        t.fontSizeSmall  = 13;
        t.fontSizeMedium = 14;
        t.fontSizeLarge  = 16;
        t.fontSizeHuge   = 20;

        t.heightTiny  = 22;
        t.heightSmall = 28;
        t.heightMedium = 34;
        t.heightLarge = 40;

        t.paddingTiny  = 4;
        t.paddingSmall = 8;
        t.paddingMedium = 12;
        t.paddingLarge = 16;

