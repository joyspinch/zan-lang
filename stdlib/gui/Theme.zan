        return Theme.Preset(false,
            Theme.Rgb(255, 255, 255), Theme.Rgb(250, 249, 248), Theme.Rgb(243, 242, 241),
            Theme.Rgb(32, 31, 30), Theme.Rgb(96, 94, 92), Theme.Rgb(161, 159, 157),
