        t.textPrimary    = -1;
        t.textSecondary  = -6380632;
        t.textTertiary   = -9012094;
        t.textDisabled   = -11184811;
        t.textInverse    = -14736859;

        t.bgPrimary      = -15198180;
        t.bgSecondary    = -14671836;
        t.bgTertiary     = -13882318;
        t.bgHover        = -13487560;
