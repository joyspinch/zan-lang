    /// Modern "AI" style: a deep indigo->blue gradient wallpaper with vivid
    /// violet accent and translucent panels floating over it.
    static Theme AiGradient() {
        Theme t = Theme.Preset(true,
            Theme.Rgb(17, 14, 34),
            Theme.Rgba(32, 27, 60, 205), Theme.Rgba(56, 46, 96, 150),
            Theme.Rgb(242, 238, 255), Theme.Rgb(198, 186, 232), Theme.Rgb(146, 132, 190),
            Theme.Rgb(139, 92, 246), Theme.Rgb(167, 139, 250), Theme.Rgb(124, 58, 237),
            Theme.Rgb(56, 189, 248), Theme.Rgb(52, 211, 153),
            Theme.Rgb(251, 191, 36), Theme.Rgb(251, 113, 133),
            Theme.Rgba(255, 255, 255, 34));
        t.gradient     = 1;
        t.bgGradTop    = Theme.Rgb(44, 22, 84);
        t.bgGradBottom = Theme.Rgb(12, 16, 52);
        t.bgHover      = Theme.Rgba(255, 255, 255, 26);
        t.bgActive     = Theme.Rgba(255, 255, 255, 42);
        t.borderHover  = Theme.Rgba(255, 255, 255, 120);
        t.divider      = Theme.Rgba(255, 255, 255, 26);
        t.scrollbar    = Theme.Rgba(255, 255, 255, 46);
        t.scrollbarHover = Theme.Rgba(255, 255, 255, 96);
        return t;
    }

    /// Aurora borealis: a teal-night -> violet gradient wallpaper with a bright
