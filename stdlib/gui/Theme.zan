        t.divider         = -13092802;
        t.overlay         = 1291845632;
        t.glass           = 0;
        t.gradient        = 0;
        t.bgGradTop       = 0;
        t.bgGradBottom    = 0;

        t.scrollbar       = -12237491;
        t.scrollbarHover  = -10197908;

        t.borderRadiusSmall  = 3;
        t.borderRadiusMedium = 3;
        t.borderRadiusLarge  = 6;
