            Theme.Rgb(46, 52, 64), Theme.Rgb(59, 66, 82), Theme.Rgb(67, 76, 94),
            Theme.Rgb(236, 239, 244), Theme.Rgb(216, 222, 233), Theme.Rgb(143, 153, 173),
            Theme.Rgb(136, 192, 208), Theme.Rgb(150, 205, 220), Theme.Rgb(120, 175, 190),
            Theme.Rgb(129, 161, 193), Theme.Rgb(163, 190, 140),
            Theme.Rgb(235, 203, 139), Theme.Rgb(191, 97, 106),
            Theme.Rgb(76, 86, 106));
    }

