using System;

namespace Gui;

/// <summary>
/// Small pure string helpers shared by text-editing widgets (Input, CodeEditor,
/// filter boxes). Keeping them here means each widget no longer re-implements
/// character decoding and edit primitives.
/// </summary>
class Text {
    /// Maps a printable ASCII code (32..126) to a one-character string.
    /// Returns "" for control/non-printable codes so callers can ignore them.
    static string CharStr(int code) {
        if (code < 32) { return ""; }
        if (code > 126) { return ""; }
        string tbl = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~";
        return tbl.Substring(code - 32, 1);
    }

    /// True when `code` is a printable ASCII character.
    static bool IsPrintable(int code) {
        if (code < 32) { return false; }
        if (code > 126) { return false; }
        return true;
    }

    /// Removes the last character of `s` (empty string stays empty).
    static string DropLast(string s) {
        if (s.Length <= 1) { return ""; }
        return s.Substring(0, s.Length - 1);
    }

    /// Left slice [0, pos) of `s`, clamped to valid bounds.
    static string Left(string s, int pos) {
        if (pos <= 0) { return ""; }
        if (pos >= s.Length) { return s; }
        return s.Substring(0, pos);
    }

    /// Right slice [pos, len) of `s`, clamped to valid bounds.
    static string Right(string s, int pos) {
        if (pos <= 0) { return s; }
        if (pos >= s.Length) { return ""; }
        return s.Substring(pos, s.Length - pos);
    }

    /// Inserts `ins` into `s` at index `pos` (0..len).
    static string InsertAt(string s, int pos, string ins) {
        return Text.Left(s, pos) + ins + Text.Right(s, pos);
    }

    /// Removes the single character at index `pos` (no-op if out of range).
    static string RemoveAt(string s, int pos) {
        if (pos < 0) { return s; }
        if (pos >= s.Length) { return s; }
        return Text.Left(s, pos) + Text.Right(s, pos + 1);
    }
}
