using System;

namespace Gui;

/// Registry of project-defined custom components discovered at build time.
///
/// This file is REGENERATED by `scripts/scan_components.ps1`, which scans a
/// project's sources for component classes (a `class X : Control` preceded by a
/// `/// @component [Group] [icon]` doc marker) and rewrites the three tables
/// below so the designer palette, the deserializer (ControlFactory) and the
/// JSON loader (UiDoc) all pick the component up automatically — no runtime
/// reflection required.
///
/// The checked-in version is intentionally empty; a build that runs the scan
/// replaces it. Keep the method shapes stable — the generator only fills the
/// bodies.
class CustomComponents {
    /// Discovered component type tags, in palette order.
    static List<string> Kinds() {
        return new List<string>();
    }

    /// Palette group label for a discovered `kind` ("" when none / unknown).
    static string GroupOf(string kind) {
        return "";
    }

    /// Palette icon name for a discovered `kind` ("" when none / unknown).
    static string IconOf(string kind) {
        return "";
    }

    /// Instantiates a discovered component by tag, or null when `kind` is not a
    /// known custom component (callers then fall back to built-ins).
    static Control Create(string kind) {
        return null;
    }
}
