using System;
using Gui;

namespace Gui.Widget;

/// A floating panel anchored below a point, with a small pointer notch.
/// Render this in the deferred overlay pass so it draws above other widgets.
class Popover {
    static void Render(App app, int anchorX, int anchorY, int w, int h, string title, string body) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int x = anchorX - w / 2;
        int y = anchorY + app.Scale(8);
        if (x < app.Scale(4)) { x = app.Scale(4); }

        int notch = app.Scale(6);
        c.FillRoundRect(x + 1, y + 2, w, h, t.borderRadiusMedium, t.shadowColor);
        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(x, y, w, h, t.borderSecondary, 1);
        Tooltip.TriUp(c, anchorX, y - notch, notch, notch, t.bgPrimary);

        int pad = t.paddingMedium;
        int ty = y + pad;
        if (title != "") {
            c.DrawText(x + pad, ty, title, t.textPrimary, t.fontSizeMedium);
            ty = ty + Canvas.FontHeight(t.fontSizeMedium) + t.gapSmall;
        }
        c.DrawText(x + pad, ty, body, t.textSecondary, t.fontSizeSmall);
    }
}
