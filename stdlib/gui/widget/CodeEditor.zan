using System;
using Gui;

namespace Gui.Widget;

/// <summary>
/// A multi-line, line-numbered plain-text code editor. Holds its own buffer
/// (a list of lines) and cursor, and edits itself in response to keyboard input
/// while it has focus — the editing surface of the IDE. Immediate-mode: create
/// one, keep it across frames, and call Render(app, area) each frame.
///
///   CodeEditor ed = CodeEditor.Create();      // once
///   ed.LoadText("using System;\n\nclass Main {}");
///   ...
///   ed.Render(app, editorRect);               // every frame
/// </summary>
class CodeEditor {
    List<string> lines;
    int curLine;
    int curCol;
    int scrollLine;
    int lastId;

    // ---- autocomplete popup state ----
    List<string> acItems;   // current candidate list (filtered by prefix)
    List<string> acFull;    // full unfiltered candidates (for dot-mode re-filter)
    int acSel;              // selected candidate index
    bool acActive;          // popup currently shown
    int acStart;            // column where the in-progress word begins
    bool acDot;             // true when popup was triggered by '.' (member completion)
    List<string> acKinds;   // kind tag per item: "M"=method, "P"=property, "T"=type, "K"=keyword, "S"=snippet, "F"=field

    // ---- popup geometry (set during Render, read during click) ----
    int popX;
    int popY;
    int popW;
    int popH;
    int popItemH;
    int popFirst;
    int popShown;

    // ---- selection ----
    bool selActive;
    int selAnchorLine;
    int selAnchorCol;

    // ---- clipboard & undo ----
    string clipboard;
    List<string> undoStack;
    List<int> undoLines;
    List<int> undoCols;

    // ---- error diagnostics ----
    List<int> errorLines;
    List<string> errorMsgs;

    // ---- debugging ----
    List<int> bps;
    int execLine;
    List<string> dbgVars;   // tab-separated "name\ttype\tvalue" entries for hover tooltip
    string hoverTip;        // current hover tooltip text
    int hoverTipX;
    int hoverTipY;

    static CodeEditor Create() {
        CodeEditor e = new CodeEditor();
        e.lines = new List<string>();
        e.lines.Add("");
        e.curLine = 0;
        e.curCol = 0;
        e.scrollLine = 0;
        e.lastId = -1;
        e.acItems = new List<string>();
        e.acFull = new List<string>();
        e.acSel = 0;
        e.acActive = false;
        e.acStart = 0;
        e.acDot = false;
        e.acKinds = new List<string>();
        e.popX = 0; e.popY = 0; e.popW = 0; e.popH = 0;
        e.popItemH = 0; e.popFirst = 0; e.popShown = 0;
        e.selActive = false;
        e.selAnchorLine = 0;
        e.selAnchorCol = 0;
        e.clipboard = "";
        e.undoStack = new List<string>();
        e.undoLines = new List<int>();
        e.undoCols = new List<int>();
        e.errorLines = new List<int>();
        e.errorMsgs = new List<string>();
        e.bps = new List<int>();
        e.execLine = -1;
        e.dbgVars = new List<string>();
        e.hoverTip = "";
        e.hoverTipX = 0;
        e.hoverTipY = 0;
        return e;
    }

    /// Splits a string into lines on '\n' (stripping '\r').
    static List<string> SplitLines(string s) {
        List<string> outLines = new List<string>();
        string cur = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\n") {
                outLines.Add(cur);
                cur = "";
            } else if (ch == "\r") {
                cur = cur;
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        outLines.Add(cur);
        return outLines;
    }

    void SetLines(List<string> ls) {
        lines = ls;
        if (lines.Count == 0) { lines.Add(""); }
        curLine = 0;
        curCol = 0;
        scrollLine = 0;
    }

    void LoadText(string s) {
        SetLines(CodeEditor.SplitLines(s));
    }

    string GetText() {
        string outText = "";
        int i = 0;
        while (i < lines.Count) {
            outText = outText + lines[i];
            if (i + 1 < lines.Count) { outText = outText + "\n"; }
            i = i + 1;
        }
        return outText;
    }

    int LineCount() {
        return lines.Count;
    }

    int CurLine() { return curLine; }
    int CurCol() { return curCol; }

    void SetDebugVars(List<string> vars) { dbgVars = vars; }

    void GoToLine(int line) {
        if (line < 0) { line = 0; }
        if (line >= lines.Count) { line = lines.Count - 1; }
        curLine = line;
        curCol = 0;
        selActive = false;
    }

    void GoToLineCol(int line, int col) {
        GoToLine(line);
        curCol = col;
        ClampCol();
    }

    // ---- edit primitives ----
    void InsertStr(string ins) {
        string ln = lines[curLine];
        lines[curLine] = Text.InsertAt(ln, curCol, ins);
        curCol = curCol + ins.Length;
    }

    void NewLine() {
        string ln = lines[curLine];
        string left = Text.Left(ln, curCol);
        string right = Text.Right(ln, curCol);
        lines[curLine] = left;
        lines.Insert(curLine + 1, right);
        curLine = curLine + 1;
        curCol = 0;
    }

    void BackspaceEdit() {
        if (curCol > 0) {
            string ln = lines[curLine];
            lines[curLine] = Text.RemoveAt(ln, curCol - 1);
            curCol = curCol - 1;
        } else if (curLine > 0) {
            string prev = lines[curLine - 1];
            string cur = lines[curLine];
            int newCol = prev.Length;
            lines[curLine - 1] = prev + cur;
            lines.RemoveAt(curLine);
            curLine = curLine - 1;
            curCol = newCol;
        }
    }

    void DeleteEdit() {
        string ln = lines[curLine];
        if (curCol < ln.Length) {
            lines[curLine] = Text.RemoveAt(ln, curCol);
        } else if (curLine + 1 < lines.Count) {
            string next = lines[curLine + 1];
            lines[curLine] = ln + next;
            lines.RemoveAt(curLine + 1);
        }
    }

    void ClampCol() {
        string ln = lines[curLine];
        if (curCol > ln.Length) { curCol = ln.Length; }
        if (curCol < 0) { curCol = 0; }
    }

    void MoveLeft() {
        if (curCol > 0) {
            curCol = curCol - 1;
        } else if (curLine > 0) {
            curLine = curLine - 1;
            curCol = lines[curLine].Length;
        }
    }

    void MoveRight() {
        string ln = lines[curLine];
        if (curCol < ln.Length) {
            curCol = curCol + 1;
        } else if (curLine + 1 < lines.Count) {
            curLine = curLine + 1;
            curCol = 0;
        }
    }

    void MoveUp() {
        if (curLine > 0) {
            curLine = curLine - 1;
            ClampCol();
        }
    }

    void MoveDown() {
        if (curLine + 1 < lines.Count) {
            curLine = curLine + 1;
            ClampCol();
        }
    }

    // ---- undo ----
    void SaveUndo() {
        string snap = GetText();
        undoStack.Add(snap);
        undoLines.Add(curLine);
        undoCols.Add(curCol);
        if (undoStack.Count > 50) {
            undoStack.RemoveAt(0);
            undoLines.RemoveAt(0);
            undoCols.RemoveAt(0);
        }
    }

    void Undo() {
        if (undoStack.Count == 0) { return; }
        int last = undoStack.Count - 1;
        string snap = undoStack[last];
        int sl = undoLines[last];
        int sc = undoCols[last];
        undoStack.RemoveAt(last);
        undoLines.RemoveAt(last);
        undoCols.RemoveAt(last);
        LoadText(snap);
        curLine = sl;
        curCol = sc;
        ClampCol();
        selActive = false;
    }

    // ---- selection ----
    void SelectAll() {
        selAnchorLine = 0;
        selAnchorCol = 0;
        curLine = lines.Count - 1;
        curCol = lines[curLine].Length;
        selActive = true;
    }

    void ClearSelection() { selActive = false; }

    void StartSelection() {
        if (!selActive) {
            selAnchorLine = curLine;
            selAnchorCol = curCol;
            selActive = true;
        }
    }

    string GetSelectedText() {
        if (!selActive) { return ""; }
        int sL = selAnchorLine;
        int sC = selAnchorCol;
        int eL = curLine;
        int eC = curCol;
        if (sL > eL || (sL == eL && sC > eC)) {
            int tmpL = sL; sL = eL; eL = tmpL;
            int tmpC = sC; sC = eC; eC = tmpC;
        }
        if (sL == eL) {
            string ln = lines[sL];
            if (sC > ln.Length) { sC = ln.Length; }
            if (eC > ln.Length) { eC = ln.Length; }
            return ln.Substring(sC, eC - sC);
        }
        string result = "";
        string firstLn = lines[sL];
        if (sC <= firstLn.Length) {
            result = firstLn.Substring(sC, firstLn.Length - sC);
        }
        int mi = sL + 1;
        while (mi < eL) {
            result = result + "\n" + lines[mi];
            mi = mi + 1;
        }
        string lastLn = lines[eL];
        if (eC > lastLn.Length) { eC = lastLn.Length; }
        result = result + "\n" + lastLn.Substring(0, eC);
        return result;
    }

    void DeleteSelection() {
        if (!selActive) { return; }
        int sL = selAnchorLine;
        int sC = selAnchorCol;
        int eL = curLine;
        int eC = curCol;
        if (sL > eL || (sL == eL && sC > eC)) {
            int tmpL = sL; sL = eL; eL = tmpL;
            int tmpC = sC; sC = eC; eC = tmpC;
        }
        SaveUndo();
        if (sL == eL) {
            string ln = lines[sL];
            if (sC > ln.Length) { sC = ln.Length; }
            if (eC > ln.Length) { eC = ln.Length; }
            lines[sL] = ln.Substring(0, sC) + ln.Substring(eC, ln.Length - eC);
        } else {
            string firstLn = lines[sL];
            string lastLn = lines[eL];
            if (sC > firstLn.Length) { sC = firstLn.Length; }
            if (eC > lastLn.Length) { eC = lastLn.Length; }
            string keep = firstLn.Substring(0, sC) + lastLn.Substring(eC, lastLn.Length - eC);
            lines[sL] = keep;
            int ri = eL;
            while (ri > sL) {
                lines.RemoveAt(ri);
                ri = ri - 1;
            }
        }
        curLine = sL;
        curCol = sC;
        selActive = false;
    }

    void CopySelection() {
        if (!selActive) { return; }
        clipboard = GetSelectedText();
    }

    void CutSelection() {
        if (!selActive) { return; }
        clipboard = GetSelectedText();
        DeleteSelection();
    }

    void PasteClipboard() {
        if (clipboard.Length == 0) { return; }
        if (selActive) { DeleteSelection(); }
        else { SaveUndo(); }
        List<string> pLines = CodeEditor.SplitLines(clipboard);
        if (pLines.Count == 1) {
            InsertStr(pLines[0]);
        } else {
            string ln = lines[curLine];
            string left = ln.Substring(0, curCol);
            string right = "";
            if (curCol < ln.Length) {
                right = ln.Substring(curCol, ln.Length - curCol);
            }
            lines[curLine] = left + pLines[0];
            int pi = 1;
            while (pi < pLines.Count - 1) {
                lines.Insert(curLine + pi, pLines[pi]);
                pi = pi + 1;
            }
            int lastIdx = pLines.Count - 1;
            string lastP = pLines[lastIdx];
            lines.Insert(curLine + lastIdx, lastP + right);
            curLine = curLine + lastIdx;
            curCol = lastP.Length;
        }
    }

    // ---- error diagnostics ----
    void CheckErrors() {
        errorLines = new List<int>();
        errorMsgs = new List<string>();
        int braceDepth = 0;
        int parenDepth = 0;
        int li = 0;
        while (li < lines.Count) {
            string ln = lines[li];
            string tr = ln;
            // Trim leading whitespace
            int si = 0;
            while (si < tr.Length) {
                string sch = tr.Substring(si, 1);
                if (sch == " " || sch == "\t") { si = si + 1; }
                else { break; }
            }
            if (si > 0) { tr = tr.Substring(si, tr.Length - si); }
            // Skip empty/comment lines
            if (tr.Length > 0 && tr.Substring(0, 1) != "/" && tr.Substring(0, 1) != "*") {
                // Check brace/paren balance per line
                int ci = 0;
                while (ci < ln.Length) {
                    string ch = ln.Substring(ci, 1);
                    if (ch == "{") { braceDepth = braceDepth + 1; }
                    if (ch == "}") { braceDepth = braceDepth - 1; }
                    if (ch == "(") { parenDepth = parenDepth + 1; }
                    if (ch == ")") { parenDepth = parenDepth - 1; }
                    ci = ci + 1;
                }
                if (braceDepth < 0) {
                    errorLines.Add(li);
                    errorMsgs.Add("Unexpected '}'");
                    braceDepth = 0;
                }
                if (parenDepth < 0) {
                    errorLines.Add(li);
                    errorMsgs.Add("Unexpected ')'");
                    parenDepth = 0;
                }
                // Check for missing semicolon on statement lines
                if (tr.Length > 2) {
                    string lastCh = tr.Substring(tr.Length - 1, 1);
                    string firstCh = tr.Substring(0, 1);
                    bool needsSemi = true;
                    if (lastCh == "{" || lastCh == "}" || lastCh == ";" || lastCh == ",") { needsSemi = false; }
                    if (firstCh == "/" || firstCh == "*" || firstCh == "#") { needsSemi = false; }
                    if (CodeEditor.StartsWithP(tr, "using ") && lastCh != ";") {
                        errorLines.Add(li);
                        errorMsgs.Add("Missing ';' after using");
                    }
                    if (CodeEditor.StartsWithP(tr, "class ") || CodeEditor.StartsWithP(tr, "struct ")) { needsSemi = false; }
                    if (CodeEditor.StartsWithP(tr, "if ") || CodeEditor.StartsWithP(tr, "if(")) { needsSemi = false; }
                    if (CodeEditor.StartsWithP(tr, "else") || CodeEditor.StartsWithP(tr, "while") || CodeEditor.StartsWithP(tr, "for")) { needsSemi = false; }
                    if (CodeEditor.StartsWithP(tr, "namespace") || CodeEditor.StartsWithP(tr, "static void") || CodeEditor.StartsWithP(tr, "void ")) { needsSemi = false; }
                }
            }
            li = li + 1;
        }
        if (braceDepth > 0) {
            errorLines.Add(lines.Count - 1);
            errorMsgs.Add("Missing closing '}'");
        }
        if (parenDepth > 0) {
            errorLines.Add(lines.Count - 1);
            errorMsgs.Add("Missing closing ')'");
        }
    }

    // ---- autocomplete ----

    /// True when list `xs` already contains `v`.
    static bool Has(List<string> xs, string v) {
        int i = 0;
        while (i < xs.Count) {
            if (xs[i] == v) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `s` begins with `pre`.
    static bool StartsWithP(string s, string pre) {
        if (pre.Length > s.Length) { return false; }
        return s.Substring(0, pre.Length) == pre;
    }

    /// Appends the language keywords to `outk`.
    static void KeywordList(List<string> outk) {
        string kws = "using namespace class struct enum interface static void int string bool float double char long short byte uint new return if else while for foreach do in break continue true false null this base public private protected internal override virtual abstract sealed const readonly var switch case default try catch finally throw is as typeof sizeof ref out params get set operator async await yield from where select orderby group join let into ascending descending on equals when and or not with record init required global file scoped allows value partial event delegate fixed lock checked unchecked unsafe stackalloc nameof";
        string cur = "";
        int i = 0;
        int n = kws.Length;
        while (i < n) {
            string ch = kws.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0) { outk.Add(cur); cur = ""; }
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        if (cur.Length > 0) { outk.Add(cur); }
    }

    /// Appends common standard library types and members for completion.
    static void StdlibList(List<string> outk) {
        string types = "Console List Dictionary StringBuilder String Math File Directory Path Environment Process Convert Array DateTime TimeSpan Task Thread App Canvas Theme Rect Button Label Input Panel Split Modal TreeView TabView CodeEditor Ribbon Icon SignalInt SignalBool SignalString Window TreeNode RibbonCmd TabHit HitRegion Point Size";
        string methods = "WriteLine ReadLine Write ToString Add Remove RemoveAt Insert IndexOf Contains Count Length Clear Sort Reverse Join Split Substring Replace Trim StartsWith EndsWith ToUpper ToLower Format Concat Exists ReadAllText WriteAllText CreateDirectory GetFiles GetDirectories Append AppendLine Max Min Abs Round Sqrt Floor Ceiling Pow Parse TryParse GetText LoadText Render Create SetText";
        string snippets = "Program Main InitializeComponent EventArgs Dispose Override";
        string all = types + " " + methods + " " + snippets;
        string cur = "";
        int i = 0;
        int n = all.Length;
        while (i < n) {
            string ch = all.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); cur = ""; }
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); }
    }

    /// Collects unique identifier tokens (length >= 2) appearing anywhere in the
    /// buffer, so the editor can complete symbols the user has already typed.
    static void CollectWords(List<string> ls, List<string> outw) {
        string idstart = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_";
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int li = 0;
        while (li < ls.Count) {
            string line = ls[li];
            int n = line.Length;
            int i = 0;
            while (i < n) {
                string ch = line.Substring(i, 1);
                if (CodeEditor.InSet(idstart, ch)) {
                    int j = i;
                    string w = "";
                    while (j < n) {
                        string cj = line.Substring(j, 1);
                        if (CodeEditor.InSet(idrest, cj)) { w = w + cj; j = j + 1; }
                        else { break; }
                    }
                    if (w.Length >= 2 && !CodeEditor.Has(outw, w)) { outw.Add(w); }
                    i = j;
                } else {
                    i = i + 1;
                }
            }
            li = li + 1;
        }
    }

    /// Recomputes the completion popup from the word immediately left of the
    /// cursor; closes the popup when there is no prefix or no candidate.
    void UpdateCompletion() {
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string ln = lines[curLine];

        // If in dot-mode, filter the full member list by the typed prefix
        if (acDot) {
            string prefix = ln.Substring(acStart, curCol - acStart);
            acItems = new List<string>();
            acKinds = new List<string>();
            if (prefix.Length == 0) {
                int fi = 0;
                while (fi < acFull.Count) {
                    acItems.Add(acFull[fi]);
                    acKinds.Add("M");
                    fi = fi + 1;
                }
            } else {
                int fi = 0;
                while (fi < acFull.Count) {
                    if (CodeEditor.StartsWithI(acFull[fi], prefix)) {
                        acItems.Add(acFull[fi]);
                        acKinds.Add("M");
                    }
                    fi = fi + 1;
                }
            }
            if (acItems.Count > 0) { acActive = true; acSel = 0; }
            else { acActive = false; acDot = false; }
            return;
        }

        // Regular word completion
        int st = curCol;
        while (st > 0) {
            string ch = ln.Substring(st - 1, 1);
            if (CodeEditor.InSet(idrest, ch)) { st = st - 1; }
            else { break; }
        }
        acStart = st;
        string pfx = ln.Substring(st, curCol - st);
        acItems = new List<string>();
        if (pfx.Length < 1) { acActive = false; return; }

        List<string> cand = new List<string>();
        List<string> candKinds = new List<string>();
        CodeEditor.KeywordListK(cand, candKinds);
        CodeEditor.StdlibListK(cand, candKinds);
        CodeEditor.CollectWordsK(lines, cand, candKinds);
        acKinds = new List<string>();
        int i = 0;
        while (i < cand.Count) {
            string w = cand[i];
            if (w != pfx && CodeEditor.StartsWithI(w, pfx) && !CodeEditor.Has(acItems, w)) {
                acItems.Add(w);
                if (i < candKinds.Count) { acKinds.Add(candKinds[i]); }
                else { acKinds.Add("W"); }
                if (acItems.Count >= 20) { i = cand.Count; }
            }
            i = i + 1;
        }
        if (acItems.Count > 0) { acActive = true; acSel = 0; }
        else { acActive = false; }
    }

    static void KeywordListK(List<string> outk, List<string> kinds) {
        List<string> tmp = new List<string>();
        CodeEditor.KeywordList(tmp);
        int i = 0;
        while (i < tmp.Count) {
            outk.Add(tmp[i]);
            kinds.Add("K");
            i = i + 1;
        }
    }

    static void StdlibListK(List<string> outk, List<string> kinds) {
        string types = "Console List Dictionary StringBuilder String Math File Directory Path Environment Process Convert Array DateTime TimeSpan Task Thread App Canvas Theme Rect Button Label Input Panel Split Modal TreeView TabView CodeEditor Ribbon Icon SignalInt SignalBool SignalString Window TreeNode RibbonCmd TabHit HitRegion Point Size Color Font Graphics Bitmap Image Stream StreamReader StreamWriter HttpClient JsonSerializer Regex Match Timer Socket WebSocket";
        string methods = "WriteLine ReadLine Write ToString Add Remove RemoveAt Insert IndexOf Contains Count Length Clear Sort Reverse Join Split Substring Replace Trim StartsWith EndsWith ToUpper ToLower Format Concat Exists ReadAllText WriteAllText CreateDirectory GetFiles GetDirectories Append AppendLine Max Min Abs Round Sqrt Floor Ceiling Pow Parse TryParse GetText LoadText Render Create SetText Where Select OrderBy GroupBy First Last Any All Sum Skip Take Distinct Aggregate";
        string all = types;
        string cur = "";
        int i = 0;
        while (i < all.Length) {
            string ch = all.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("T"); }
                cur = "";
            } else { cur = cur + ch; }
            i = i + 1;
        }
        if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("T"); }
        cur = "";
        i = 0;
        while (i < methods.Length) {
            string ch = methods.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("M"); }
                cur = "";
            } else { cur = cur + ch; }
            i = i + 1;
        }
        if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("M"); }
    }

    static void CollectWordsK(List<string> ls, List<string> outw, List<string> kinds) {
        List<string> tmp = new List<string>();
        CodeEditor.CollectWords(ls, tmp);
        int i = 0;
        while (i < tmp.Count) {
            if (!CodeEditor.Has(outw, tmp[i])) {
                outw.Add(tmp[i]);
                kinds.Add("W");
            }
            i = i + 1;
        }
    }

    /// Case-insensitive StartsWith check.
    static bool StartsWithI(string s, string pre) {
        if (pre.Length > s.Length) { return false; }
        string lower = "abcdefghijklmnopqrstuvwxyz";
        string upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        int i = 0;
        while (i < pre.Length) {
            string a = s.Substring(i, 1);
            string b = pre.Substring(i, 1);
            // Normalize both to same case
            string la = a;
            string lb = b;
            int ai = 0;
            while (ai < 26) {
                if (upper.Substring(ai, 1) == a) { la = lower.Substring(ai, 1); }
                if (upper.Substring(ai, 1) == b) { lb = lower.Substring(ai, 1); }
                ai = ai + 1;
            }
            if (la != lb) { return false; }
            i = i + 1;
        }
        return true;
    }

    /// Replaces the in-progress word with the selected candidate.
    void AcceptCompletion() {
        if (!acActive) { return; }
        if (acSel < 0 || acSel >= acItems.Count) { acActive = false; return; }
        string ln = lines[curLine];
        string chosen = acItems[acSel];
        string left = Text.Left(ln, acStart);
        string right = Text.Right(ln, curCol);
        lines[curLine] = left + chosen + right;
        curCol = acStart + chosen.Length;
        acActive = false;
        acDot = false;
    }

    /// Triggered when user types '.'. Looks at the word before the dot and
    /// suggests known members for that type, or the chain return type.
    void DotCompletion() {
        string ln = lines[curLine];
        int dotPos = curCol - 1;
        if (dotPos < 0) { acActive = false; return; }

        // Walk backwards through the chain: skip matched parens and identifiers
        string idchars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int pos = dotPos;
        // Skip over closing paren groups (for chained calls like .Where(...).Select)
        if (pos > 0 && ln.Substring(pos - 1, 1) == ")") {
            int depth = 1;
            pos = pos - 1;
            while (pos > 0 && depth > 0) {
                pos = pos - 1;
                string pc = ln.Substring(pos, 1);
                if (pc == ")") { depth = depth + 1; }
                else if (pc == "(") { depth = depth - 1; }
            }
        }
        // Now get the word (method or variable name) before the paren or dot
        int end = pos;
        while (pos > 0) {
            string pc = ln.Substring(pos - 1, 1);
            if (CodeEditor.InSet(idchars, pc)) { pos = pos - 1; }
            else { break; }
        }
        string lastWord = ln.Substring(pos, end - pos);

        // Walk further back to find the owner (e.g. "Console" in "Console.Xxx")
        string owner = lastWord;
        if (pos > 0 && ln.Substring(pos - 1, 1) == ".") {
            int ownerEnd = pos - 1;
            int ownerStart = ownerEnd;
            while (ownerStart > 0) {
                string pc = ln.Substring(ownerStart - 1, 1);
                if (CodeEditor.InSet(idchars, pc)) { ownerStart = ownerStart - 1; }
                else { break; }
            }
            owner = ln.Substring(ownerStart, ownerEnd - ownerStart);
        }

        // Build member list based on identified type
        acStart = curCol;
        acFull = new List<string>();
        acDot = true;

        // Known static types
        if (owner == "Console" || lastWord == "Console") {
            CodeEditor.AddMembers(acFull, "Console");
        } else if (owner == "Math" || lastWord == "Math") {
            CodeEditor.AddMembers(acFull, "Math");
        } else if (owner == "File" || lastWord == "File") {
            CodeEditor.AddMembers(acFull, "File");
        } else if (owner == "Directory" || lastWord == "Directory") {
            CodeEditor.AddMembers(acFull, "Directory");
        } else if (owner == "Path" || lastWord == "Path") {
            CodeEditor.AddMembers(acFull, "Path");
        } else if (owner == "Convert" || lastWord == "Convert") {
            CodeEditor.AddMembers(acFull, "Convert");
        } else if (owner == "Environment" || lastWord == "Environment") {
            CodeEditor.AddMembers(acFull, "Environment");
        } else if (owner == "string" || lastWord == "string" || owner == "String" || lastWord == "String") {
            CodeEditor.AddMembers(acFull, "string");
        } else if (owner == "List" || lastWord == "List") {
            CodeEditor.AddMembers(acFull, "List");
        } else if (owner == "Dictionary" || lastWord == "Dictionary") {
            CodeEditor.AddMembers(acFull, "Dictionary");
        } else if (owner == "StringBuilder" || lastWord == "StringBuilder") {
            CodeEditor.AddMembers(acFull, "StringBuilder");
        } else if (owner == "DateTime" || lastWord == "DateTime") {
            CodeEditor.AddMembers(acFull, "DateTime");
        } else if (owner == "Array" || lastWord == "Array") {
            CodeEditor.AddMembers(acFull, "Array");
        } else if (owner == "Process" || lastWord == "Process") {
            CodeEditor.AddMembers(acFull, "Process");
        } else if (owner == "App" || lastWord == "App") {
            CodeEditor.AddMembers(acFull, "App");
        } else if (owner == "Canvas" || lastWord == "Canvas") {
            CodeEditor.AddMembers(acFull, "Canvas");
        } else if (owner == "Theme" || lastWord == "Theme") {
            CodeEditor.AddMembers(acFull, "Theme");
        } else if (owner == "Window" || lastWord == "Window") {
            CodeEditor.AddMembers(acFull, "Window");
        } else {
            // Unknown type - show all common instance members + LINQ chain methods
            CodeEditor.AddMembers(acFull, "_instance");
        }

        acItems = new List<string>();
        acKinds = new List<string>();
        int fi = 0;
        while (fi < acFull.Count) {
            acItems.Add(acFull[fi]);
            acKinds.Add("M");
            fi = fi + 1;
        }
        if (acItems.Count > 0) { acActive = true; acSel = 0; }
        else { acActive = false; acDot = false; }
    }

    /// Populates member lists for known types.
