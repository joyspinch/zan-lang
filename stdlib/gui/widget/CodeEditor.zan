    // ---- breakpoints ----

    /// True when integer list `xs` contains `v`.
    static bool HasInt(List<int> xs, int v) {
        int i = 0;
        while (i < xs.Count) {
            if (xs[i] == v) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when line `line` (0-based) has a breakpoint.
    bool HasBreakpoint(int line) {
        return CodeEditor.HasInt(bps, line);
    }

    /// Toggles a breakpoint on `line`.
    void ToggleBreakpoint(int line) {
        int idx = -1;
        int i = 0;
        while (i < bps.Count) {
            if (bps[i] == line) { idx = i; }
            i = i + 1;
        }
        if (idx >= 0) { bps.RemoveAt(idx); }
        else { bps.Add(line); }
    }

    /// The set of breakpoint line numbers (0-based).
    List<int> Breakpoints() {
        return bps;
    }

    /// Highlights `line` as the currently paused execution line (-1 clears).
    void SetExecLine(int line) {
        execLine = line;
        if (line >= 0) {
            curLine = line;
            if (curLine < scrollLine) { scrollLine = curLine; }
        }
    }

    void HandleInput(App app) {
        int kind = app.window.EventKind();
        if (kind == 6) {
            int code = app.window.EventKeyCode();
            // Ctrl+A = select all (code 1)
            if (code == 1) {
                SelectAll();
                app.RequestRedraw();
                return;
            }
            // Ctrl+C = copy (code 3)
            if (code == 3) {
                CopySelection();
                app.RequestRedraw();
                return;
            }
            // Ctrl+X = cut (code 24)
            if (code == 24) {
                CutSelection();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            // Ctrl+V = paste (code 22)
            if (code == 22) {
                PasteClipboard();
                CheckErrors();
                UpdateCompletion();
                app.RequestRedraw();
                return;
            }
            // Ctrl+Z = undo (code 26)
            if (code == 26) {
                Undo();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            if (code == 8) {
                if (selActive) { DeleteSelection(); }
                else { SaveUndo(); BackspaceEdit(); }
                CheckErrors();
                UpdateCompletion();
                app.RequestRedraw();
            } else if (code == 13) {
                if (acActive) { AcceptCompletion(); }
                else {
                    if (selActive) { DeleteSelection(); }
                    else { SaveUndo(); }
                    NewLine();
                    CheckErrors();
                }
                app.RequestRedraw();
            } else if (code == 9) {
                if (acActive) { AcceptCompletion(); }
                else {
                    if (selActive) { DeleteSelection(); }
                    InsertStr("    ");
                }
                app.RequestRedraw();
            } else if (code == 27) {
                acActive = false;
                selActive = false;
                app.RequestRedraw();
            } else if (code > 31) {
                string ch = Text.CharStr(code);
                if (ch.Length > 0) {
                    if (selActive) { DeleteSelection(); }
                    else { SaveUndo(); }
                    InsertStr(ch);
                    selActive = false;
                    if (ch == ".") {
                        DotCompletion();
                    } else {
                        UpdateCompletion();
                    }
                    CheckErrors();
                    app.RequestRedraw();
                }
            }
        } else if (kind == 4) {
            int kc = app.window.EventKeyCode();
            if (acActive && kc == 38) {
                acSel = acSel - 1;
                if (acSel < 0) { acSel = acItems.Count - 1; }
                app.RequestRedraw();
            } else if (acActive && kc == 40) {
                acSel = acSel + 1;
                if (acSel >= acItems.Count) { acSel = 0; }
                app.RequestRedraw();
            } else if (kc == 27) { acActive = false; selActive = false; app.RequestRedraw(); }
            else if (kc == 37) { acActive = false; selActive = false; MoveLeft(); app.RequestRedraw(); }
            else if (kc == 39) { acActive = false; selActive = false; MoveRight(); app.RequestRedraw(); }
            else if (kc == 38) { selActive = false; MoveUp(); app.RequestRedraw(); }
            else if (kc == 40) { selActive = false; MoveDown(); app.RequestRedraw(); }
            else if (kc == 36) { curCol = 0; acActive = false; selActive = false; app.RequestRedraw(); }
            else if (kc == 35) { curCol = lines[curLine].Length; acActive = false; selActive = false; app.RequestRedraw(); }
            else if (kc == 46) {
                if (selActive) { DeleteSelection(); }
                else { SaveUndo(); DeleteEdit(); }
                acActive = false;
                CheckErrors();
                app.RequestRedraw();
            }
        }
    }

    /// Maps a pixel x-offset (relative to the text origin) to a column index by
    /// measuring successive prefixes.
    static int ColFromX(string s, int px, int fontSize) {
        if (px <= 0) { return 0; }
        int i = 1;
        while (i <= s.Length) {
            int w = Canvas.MeasureText(Text.Left(s, i), fontSize);
            if (w >= px) { return i; }
            i = i + 1;
        }
        return s.Length;
    }

    // ---- syntax highlighting ----

    /// True when the one-character string `ch` occurs in `set`.
    static bool InSet(string chars, string ch) {
        int i = 0;
        while (i < chars.Length) {
            if (chars.Substring(i, 1) == ch) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `hay` contains the substring `needle`.
    static bool ContainsSub(string hay, string needle) {
        int n = hay.Length;
        int m = needle.Length;
        if (m == 0) { return true; }
        int i = 0;
        while (i + m <= n) {
            if (hay.Substring(i, m) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `w` is a Zan/C#-style language keyword.
    static bool IsKeyword(string w) {
        string kws = " using namespace class struct enum interface static void int string bool float double char long short byte uint new return if else while for foreach do in break continue true false null this base public private protected internal override virtual abstract sealed const readonly var switch case default try catch finally throw is as typeof sizeof ref out params get set operator async await yield from where select orderby group join let into ascending descending on equals when and or not with record init required global file scoped allows value partial event delegate fixed lock checked unchecked unsafe stackalloc nameof ";
        return CodeEditor.ContainsSub(kws, " " + w + " ");
    }

    /// Splits `line` into colored segments (parallel outT/outC lists): keywords,
    /// types (Capitalized identifiers), strings, line comments and numbers get
    /// distinct colors; everything else uses the default text color.
    static void Highlight(string line, Theme t, List<string> outT, List<int> outC) {
        int kwC = 0xFF569CD6;
        int tyC = 0xFF4EC9B0;
        int strC = 0xFFCE9178;
        int comC = 0xFF6A9955;
        int numC = 0xFFB5CEA8;
        int def = t.textPrimary;
        string lower = "abcdefghijklmnopqrstuvwxyz";
        string upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        string digits = "0123456789";
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int n = line.Length;
        int i = 0;
        string pending = "";
        while (i < n) {
            string ch = line.Substring(i, 1);
            if (ch == "/" && i + 1 < n && line.Substring(i + 1, 1) == "/") {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                outT.Add(line.Substring(i, n - i)); outC.Add(comC);
                i = n;
            } else if (ch == "\"") {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i + 1;
                string s = "\"";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (cj == "\\" && j + 1 < n) {
                        s = s + cj + line.Substring(j + 1, 1);
                        j = j + 2;
                    } else if (cj == "\"") {
                        s = s + cj;
                        j = j + 1;
                        break;
                    } else {
                        s = s + cj;
                        j = j + 1;
                    }
                }
                outT.Add(s); outC.Add(strC);
                i = j;
            } else if (CodeEditor.InSet(digits, ch)) {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i;
                string num = "";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (CodeEditor.InSet(digits, cj) || cj == "." || cj == "x"
                        || CodeEditor.InSet("abcdefABCDEF", cj)) {
                        num = num + cj; j = j + 1;
                    } else { break; }
                }
                outT.Add(num); outC.Add(numC);
                i = j;
            } else if (CodeEditor.InSet(lower + upper + "_", ch)) {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i;
                string w = "";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (CodeEditor.InSet(idrest, cj)) { w = w + cj; j = j + 1; }
                    else { break; }
                }
                int col = def;
                if (CodeEditor.IsKeyword(w)) { col = kwC; }
                else if (CodeEditor.InSet(upper, line.Substring(i, 1))) { col = tyC; }
                outT.Add(w); outC.Add(col);
                i = j;
            } else {
                pending = pending + ch;
                i = i + 1;
            }
        }
        if (pending.Length > 0) { outT.Add(pending); outC.Add(def); }
    }

    static void DrawSelHighlight(Canvas c, App app,
            int aL, int aC, int cL, int cC,
            int ln, string text, int textX, int rowY, int lineH, int fontSize, Rect area) {
        int sL = aL; int sC = aC; int eL = cL; int eC = cC;
        if (sL > eL || (sL == eL && sC > eC)) {
            int tL = sL; sL = eL; eL = tL;
            int tC = sC; sC = eC; eC = tC;
        }
        if (ln < sL || ln > eL) { return; }
        int startC = 0;
        int endC = text.Length;
        if (ln == sL) { startC = sC; }
        if (ln == eL) { endC = eC; }
        if (startC > text.Length) { startC = text.Length; }
        if (endC > text.Length) { endC = text.Length; }
        if (startC >= endC && ln != sL && ln != eL) {
            startC = 0; endC = text.Length;
        }
        if (startC >= endC) { return; }
        int xStart = textX + Canvas.MeasureText(Text.Left(text, startC), fontSize);
        int xEnd = textX + Canvas.MeasureText(Text.Left(text, endC), fontSize);
        c.FillRect(xStart, rowY, xEnd - xStart, lineH, 0x40264F78);
    }

    static string GetErrorMsg(List<int> errLines, List<string> errMsgs, int line) {
        int i = 0;
        while (i < errLines.Count) {
            if (errLines[i] == line && i < errMsgs.Count) {
                return errMsgs[i];
            }
            i = i + 1;
        }
        return "";
    }

    int Render(App app, Rect area) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        lastId = id;
        bool focused = app.focus.IsFocused(id);

        int fontSize = t.fontSizeMedium;
        int lineH = Canvas.FontHeight(fontSize) + app.Scale(4);
        if (lineH < 1) { lineH = 1; }
        int gutterW = app.Scale(48);

        c.FillRect(area.x, area.y, area.width, area.height, t.bgPrimary);
        c.FillRect(area.x, area.y, gutterW, area.height, t.bgSecondary);
        c.FillRect(area.x + gutterW, area.y, 1, area.height, t.divider);

        app.CaptureWheel(area.x, area.y, area.width, area.height);

        int visLines = area.height / lineH;
        if (visLines < 1) { visLines = 1; }

        if (focused) { HandleInput(app); }

        if (app.window.EventKind() == 13) {
            bool over = app.mouseX >= area.x && app.mouseX < area.x + area.width
                        && app.mouseY >= area.y && app.mouseY < area.y + area.height;
            if (over) {
                int delta = app.window.EventKeyCode();
                int step = delta / 120;
                if (step == 0) {
                    if (delta > 0) { step = 1; }
                    else if (delta < 0) { step = 0 - 1; }
                }
                scrollLine = scrollLine - step * 3;
                app.RequestRedraw();
            }
        }

        if (curLine < scrollLine) { scrollLine = curLine; }
        if (curLine >= scrollLine + visLines) { scrollLine = curLine - visLines + 1; }
        int maxScroll = lines.Count - visLines;
        if (maxScroll < 0) { maxScroll = 0; }
        if (scrollLine > maxScroll) { scrollLine = maxScroll; }
        if (scrollLine < 0) { scrollLine = 0; }

        int textX = area.x + gutterW + t.paddingSmall;
        int i = 0;
        while (i < visLines) {
            int ln = scrollLine + i;
            if (ln < lines.Count) {
                int rowY = area.y + i * lineH;
                int textY = rowY + (lineH - Canvas.FontHeight(fontSize)) / 2;

                if (ln == execLine) {
                    c.FillRect(area.x + gutterW + 1, rowY, area.width - gutterW - 1, lineH, 0x40FFB020);
                } else if (ln == curLine && focused) {
                    c.FillRect(area.x + gutterW + 1, rowY, area.width - gutterW - 1, lineH, t.bgHover);
                }

                if (HasBreakpoint(ln)) {
                    int dotSz = app.Scale(10);
                    int dotX = area.x + app.Scale(6);
                    int dotY = rowY + (lineH - dotSz) / 2;
                    c.FillRoundRect(dotX, dotY, dotSz, dotSz, dotSz, t.error);
                }
                if (ln == execLine) {
                    int aw = app.Scale(10);
                    int ax = area.x + app.Scale(6);
                    int ay = rowY + (lineH - aw) / 2;
                    c.FillRoundRect(ax, ay, aw, aw, app.Scale(2), 0xFFFFB020);
                }

                string num = Convert.ToString(ln + 1);
                int numW = Canvas.MeasureText(num, fontSize);
                c.DrawText(area.x + gutterW - numW - app.Scale(8), textY, num, t.textTertiary, fontSize);

                string text = lines[ln];

                // Selection highlight
                if (selActive) {
                    CodeEditor.DrawSelHighlight(c, app, selAnchorLine, selAnchorCol,
                        curLine, curCol, ln, text, textX, rowY, lineH, fontSize, area);
                }

                // Error indicator (red underline)
                if (CodeEditor.HasInt(errorLines, ln)) {
                    c.FillRect(textX, rowY + lineH - app.Scale(2),
                        Canvas.MeasureText(text, fontSize), app.Scale(2), 0xAAFF4444);
                }

                List<string> segT = new List<string>();
                List<int> segC = new List<int>();
                CodeEditor.Highlight(text, t, segT, segC);
                int sx = textX;
                int si2 = 0;
                while (si2 < segT.Count) {
                    c.DrawText(sx, textY, segT[si2], segC[si2], fontSize);
                    sx = sx + Canvas.MeasureText(segT[si2], fontSize);
                    si2 = si2 + 1;
                }

                if (ln == curLine && focused) {
                    string upto = Text.Left(text, curCol);
                    int cxp = textX + Canvas.MeasureText(upto, fontSize);
                    c.FillRect(cxp, rowY + app.Scale(2), 1, lineH - app.Scale(4), t.primary);
                }

                // Show error tooltip on hovered error line
                if (CodeEditor.HasInt(errorLines, ln) && ln == curLine) {
                    string errMsg = CodeEditor.GetErrorMsg(errorLines, errorMsgs, ln);
                    if (errMsg.Length > 0) {
                        int ttW = Canvas.MeasureText(errMsg, fontSize) + app.Scale(12);
                        int ttH = lineH;
                        int ttX = textX;
                        int ttY = rowY - ttH - app.Scale(2);
                        if (ttY < area.y) { ttY = rowY + lineH; }
                        c.FillRoundRect(ttX, ttY, ttW, ttH, app.Scale(3), 0xFF5A1D1D);
                        c.DrawRect(ttX, ttY, ttW, ttH, 0xFFFF4444, 1);
                        c.DrawText(ttX + app.Scale(6), ttY + app.Scale(3), errMsg, 0xFFFF8888, fontSize);
                    }
                }
            }
            i = i + 1;
        }

        // ---- autocomplete popup (drawn below the cursor, with icons) ----
        if (acActive && focused && acItems.Count > 0
            && curLine >= scrollLine && curLine < scrollLine + visLines) {
            int prow = curLine - scrollLine;
            int pRowY = area.y + prow * lineH;
            int px = textX + Canvas.MeasureText(Text.Left(lines[curLine], acStart), fontSize);
            int maxShow = 10;
            int shown = acItems.Count;
            if (shown > maxShow) { shown = maxShow; }
            int itemH2 = lineH + app.Scale(2);
            int popH2 = shown * itemH2 + app.Scale(4);
            int iconW = app.Scale(22);
            int popW2 = app.Scale(220);
            int k = 0;
            while (k < acItems.Count) {
                int wpx = Canvas.MeasureText(acItems[k], fontSize) + iconW + app.Scale(16);
                if (wpx > popW2) { popW2 = wpx; }
                k = k + 1;
            }
            if (popW2 > app.Scale(400)) { popW2 = app.Scale(400); }
            int popY2 = pRowY + lineH;
            // Ensure popup stays within the visible area
            if (popY2 + popH2 > area.y + area.height) { popY2 = pRowY - popH2; }
            if (px + popW2 > area.x + area.width) { px = area.x + area.width - popW2 - 4; }
            int first2 = 0;
            if (acSel >= maxShow) { first2 = acSel - maxShow + 1; }
            // Save popup geometry for click detection
            popX = px; popY = popY2; popW = popW2; popH = popH2;
            popItemH = itemH2; popFirst = first2; popShown = shown;
            // Draw shadow
            c.FillRoundRect(px + 2, popY2 + 2, popW2, popH2, app.Scale(4), 0x40000000);
            // Draw popup background
            c.FillRoundRect(px, popY2, popW2, popH2, app.Scale(4), 0xFF252526);
            c.DrawRect(px, popY2, popW2, popH2, 0xFF3E3E42, 1);
            int r2 = 0;
            while (r2 < shown) {
                int idx = first2 + r2;
                if (idx < acItems.Count) {
                    int iy = popY2 + app.Scale(2) + r2 * itemH2;
                    int tcol = 0xFFD4D4D4;
                    if (idx == acSel) {
                        c.FillRect(px + 2, iy, popW2 - 4, itemH2, 0xFF094771);
                        tcol = 0xFFFFFFFF;
                    }
                    int ity = iy + (itemH2 - Canvas.FontHeight(fontSize)) / 2;
                    // Draw kind icon/indicator
                    string kind2 = "";
                    if (idx < acKinds.Count) { kind2 = acKinds[idx]; }
                    int iconColor = 0xFF569CD6;
                    string iconLetter = "?";
                    if (kind2 == "M") { iconColor = 0xFF9B6DCA; iconLetter = "M"; }
                    else if (kind2 == "P") { iconColor = 0xFF569CD6; iconLetter = "P"; }
                    else if (kind2 == "T") { iconColor = 0xFF4EC9B0; iconLetter = "T"; }
                    else if (kind2 == "K") { iconColor = 0xFF569CD6; iconLetter = "K"; }
                    else if (kind2 == "S") { iconColor = 0xFFDCDCAA; iconLetter = "S"; }
                    else if (kind2 == "F") { iconColor = 0xFF9CDCFE; iconLetter = "F"; }
                    else if (kind2 == "E") { iconColor = 0xFFB8D7A3; iconLetter = "E"; }
                    else { iconColor = 0xFFCCCCCC; iconLetter = "W"; }
                    c.FillRoundRect(px + app.Scale(3), ity, app.Scale(16), app.Scale(16), app.Scale(3), iconColor);
                    c.DrawText(px + app.Scale(6), ity + app.Scale(1), iconLetter, 0xFF1E1E1E, t.fontSizeSmall);
                    c.DrawText(px + iconW, ity, acItems[idx], tcol, fontSize);
                }
                r2 = r2 + 1;
            }
            // Scrollbar hint if there are more items
            if (acItems.Count > maxShow) {
                int sbH = popH2 * shown / acItems.Count;
                if (sbH < app.Scale(10)) { sbH = app.Scale(10); }
                int sbY = popY2 + (popH2 - sbH) * first2 / (acItems.Count - shown);
                c.FillRoundRect(px + popW2 - app.Scale(6), sbY, app.Scale(4), sbH, app.Scale(2), 0xFF555555);
            }
        }

        app.hitTester.Register(HitRegion.Create(id, area.x, area.y, area.width, area.height, 1));

        if (app.window.EventKind() == 3) {
            // Check autocomplete popup click FIRST
            if (acActive && popShown > 0
                && app.mouseX >= popX && app.mouseX < popX + popW
                && app.mouseY >= popY && app.mouseY < popY + popH) {
                int relY = app.mouseY - popY - app.Scale(2);
                int clickedRow = relY / popItemH;
                if (clickedRow >= 0 && clickedRow < popShown) {
                    int clickedIdx = popFirst + clickedRow;
                    if (clickedIdx >= 0 && clickedIdx < acItems.Count) {
                        acSel = clickedIdx;
                        AcceptCompletion();
                    }
                }
                app.RequestRedraw();
            } else {
                int hit = app.hitTester.HitTest(app.mouseX, app.mouseY);
                if (hit == id) {
                    int rel = app.mouseY - area.y;
                    int clicked = scrollLine + rel / lineH;
                    if (clicked >= lines.Count) { clicked = lines.Count - 1; }
                    if (clicked < 0) { clicked = 0; }
                    if (app.mouseX < area.x + gutterW) {
                        ToggleBreakpoint(clicked);
                    } else {
                        curLine = clicked;
                        curCol = CodeEditor.ColFromX(lines[curLine], app.mouseX - textX, fontSize);
                    }
                    acActive = false;
                    app.RequestRedraw();
                }
            }
        }

        // ---- Debug hover tooltip ----
        if (execLine >= 0 && dbgVars.Count > 0) {
            // Detect word under mouse cursor
            if (app.mouseX >= textX && app.mouseX < area.x + area.width
                && app.mouseY >= area.y && app.mouseY < area.y + area.height) {
                int hoverLine = scrollLine + (app.mouseY - area.y) / lineH;
                if (hoverLine >= 0 && hoverLine < lines.Count) {
                    int hoverCol = CodeEditor.ColFromX(lines[hoverLine], app.mouseX - textX, fontSize);
                    string hWord = CodeEditor.WordAt(lines[hoverLine], hoverCol);
                    if (hWord.Length > 0) {
                        string tip = CodeEditor.LookupVar(dbgVars, hWord);
                        if (tip.Length > 0) {
                            hoverTip = tip;
                            hoverTipX = app.mouseX;
                            hoverTipY = app.mouseY;
                        } else {
                            hoverTip = "";
                        }
                    } else {
                        hoverTip = "";
                    }
                }
            }
            // Draw tooltip
            if (hoverTip.Length > 0) {
                int ttW2 = Canvas.MeasureText(hoverTip, fontSize) + app.Scale(16);
                int ttH2 = lineH + app.Scale(4);
                int ttX2 = hoverTipX + app.Scale(8);
                int ttY2 = hoverTipY - ttH2 - app.Scale(4);
                if (ttY2 < area.y) { ttY2 = hoverTipY + app.Scale(20); }
                if (ttX2 + ttW2 > area.x + area.width) { ttX2 = area.x + area.width - ttW2 - 4; }
                c.FillRoundRect(ttX2 - 1, ttY2 - 1, ttW2 + 2, ttH2 + 2, app.Scale(4), 0x60000000);
                c.FillRoundRect(ttX2, ttY2, ttW2, ttH2, app.Scale(4), 0xFF1E1E1E);
                c.DrawRect(ttX2, ttY2, ttW2, ttH2, 0xFF569CD6, 1);
                c.DrawText(ttX2 + app.Scale(8), ttY2 + app.Scale(4), hoverTip, 0xFFCE9178, fontSize);
            }
        }

        return id;
    }

    static string WordAt(string line, int col) {
        if (col < 0 || col >= line.Length) { return ""; }
        // Find word boundaries
        int start = col;
        while (start > 0) {
            string ch = line.Substring(start - 1, 1);
            if (CodeEditor.IsIdentChar(ch)) { start = start - 1; }
            else { break; }
        }
        int end = col;
        while (end < line.Length) {
            string ch = line.Substring(end, 1);
            if (CodeEditor.IsIdentChar(ch)) { end = end + 1; }
            else { break; }
        }
        if (start == end) { return ""; }
        return line.Substring(start, end - start);
    }

    static bool IsIdentChar(string ch) {
        if (ch == "_") { return true; }
        int c = ch.Substring(0, 1).Length;
        if (c == 0) { return false; }
        string fc = ch.Substring(0, 1);
        if (fc >= "a" && fc <= "z") { return true; }
        if (fc >= "A" && fc <= "Z") { return true; }
        if (fc >= "0" && fc <= "9") { return true; }
        return false;
    }

    static string LookupVar(List<string> vars, string name) {
        int i = 0;
        while (i < vars.Count) {
            string entry = vars[i];
            // entry is "name\ttype\tvalue"
            int tab1 = -1;
            int tab2 = -1;
            int j = 0;
            while (j < entry.Length) {
                string ch = entry.Substring(j, 1);
                if (ch == "\t") {
                    if (tab1 < 0) { tab1 = j; }
                    else if (tab2 < 0) { tab2 = j; }
                }
                j = j + 1;
            }
            if (tab1 > 0) {
                string vName = entry.Substring(0, tab1);
                if (vName == name) {
                    string vType = "";
                    string vVal = "";
                    if (tab2 > tab1) {
                        vType = entry.Substring(tab1 + 1, tab2 - tab1 - 1);
                        vVal = entry.Substring(tab2 + 1, entry.Length - tab2 - 1);
                    } else {
                        vType = entry.Substring(tab1 + 1, entry.Length - tab1 - 1);
                    }
                    return vName + " : " + vType + " = " + vVal;
                }
            }
            i = i + 1;
        }
        return "";
    }
}
