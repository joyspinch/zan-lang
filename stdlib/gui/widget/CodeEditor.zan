using System;
using Gui;

namespace Gui.Widget;

/// <summary>
/// A multi-line, line-numbered plain-text code editor. Holds its own buffer
/// (a list of lines) and cursor, and edits itself in response to keyboard input
/// while it has focus — the editing surface of the IDE. Immediate-mode: create
/// one, keep it across frames, and call Render(app, area) each frame.
///
///   CodeEditor ed = CodeEditor.Create();      // once
///   ed.LoadText("using System;\n\nclass Main {}");
///   ...
///   ed.Render(app, editorRect);               // every frame
/// </summary>
class CodeEditor {
    List<string> lines;
    int curLine;
    int curCol;
    int scrollLine;
    int lastId;

    // ---- autocomplete popup state ----
    List<string> acItems;   // current candidate list (filtered by prefix + kind)
    List<string> acAllItems; // candidates before the kind filter is applied
    List<string> acAllKinds; // kind tag per acAllItems entry
    string acFilter;        // "" = show all kinds; else a single kind letter
    // Geometry of the popup's kind-filter strip (for click hit-testing).
    int filtX;
    int filtY;
    int filtW;
    int filtH;
    List<string> acFull;    // full unfiltered candidates (for dot-mode re-filter)
    // CodeLens: clickable "N references" annotations (rebuilt each render).
    List<int> clLine;
    List<string> clName;
    List<int> clX;
    List<int> clY;
    List<int> clW;
    // Expandable reference list popup (opened by clicking a CodeLens count).
    bool refPopOpen;
    string refPopName;
    List<int> refPopLines;
    int refPopX;
    int refPopY;
    int refPopSel;
    // Final clamped popup geometry from the last render, used for hit testing.
    int refPopGX;
    int refPopGY;
    int refPopGW;
    int refPopGH;
    int refPopRowH;
    int refPopHeadH;
    int refPopShown;
    // Set when a Ctrl+click asks the host to run Go to Definition.
    bool gotoRequested;
    int acSel;              // selected candidate index
    bool acActive;          // popup currently shown
    int acStart;            // column where the in-progress word begins
    bool acDot;             // true when popup was triggered by '.' (member completion)
    List<string> acKinds;   // kind tag per item: "M"=method, "P"=property, "T"=type, "K"=keyword, "S"=snippet, "F"=field

    // ---- popup geometry (set during Render, read during click) ----
    int popX;
    int popY;
    int popW;
    int popH;
    int popItemH;
    int popFirst;
    int popShown;

    // ---- selection ----
    bool selActive;
    int selAnchorLine;
    int selAnchorCol;
    // True while the left button is held and dragging out a selection.
    bool mouseSelecting;
    // Double/triple-click detection: consecutive clicks at (roughly) the same
    // spot within a short window select the word, then the whole line.
    int lastClickMs;
    int lastClickLine;
    int lastClickCol;
    int clickCount;
    // Number of fully visible text rows from the last Render (for Page Up/Down).
    int pageRows;

    // ---- multi-cursor (secondary carets, each on a distinct line) ----
    List<int> mcLines;
    List<int> mcCols;

    // ---- clipboard & undo ----
    string clipboard;
    List<string> undoStack;
    List<int> undoLines;
    List<int> undoCols;
    List<string> redoStack;
    List<int> redoLines;
    List<int> redoCols;

    // ---- error diagnostics ----
    List<int> errorLines;
    List<string> errorMsgs;
    int lastDiagLine;       // caret line at last CheckErrors run (-1 = never)
    // Real compiler diagnostics from the last Run/Build, mapped onto this file.
    // Kept separate from the heuristic ones and invalidated on the next edit
    // (tracked by cErrStamp = buffer length when the diagnostics were set).
    List<int> cErrLines;
    List<string> cErrMsgs;
    int cErrStamp;

    // ---- symbol index (accurate, using-aware completion) ----
    // Types (class/struct/enum) declared across the project's other files, and
    // for each, a space-separated list of its declared member names. Fed by the
    // host IDE via SetProjectFiles() so `Utils.` completes with Utils's real
    // members instead of guesswork. The current buffer is scanned on demand.
    List<string> projTypeNames;
    List<string> projTypeMembers;
    // Raw source of every other project file, kept so signature help can parse
    // the real parameter list of a user/project method (not just its name).
    List<string> projFileSrc;
    // Missing-`using` quick-fix map: fixLines[i] is a line whose error can be
    // resolved by inserting `using fixNs[i];`.
    List<int> fixLines;
    List<string> fixNs;

    // ---- debugging ----
    List<int> bps;
    int execLine;
    List<string> dbgVars;   // tab-separated "name\ttype\tvalue" entries for hover tooltip
    string hoverTip;        // current hover tooltip text
    int hoverTipX;
    int hoverTipY;

    // Right-click context menu state.
    bool ctxOpen;
    int ctxX;
    int ctxY;
    string ctxCmd;          // command the host IDE must handle ("find"/"gotoline")

    // ---- appearance (font + syntax colors), set by the host via ApplyTheme ----
    // edFont is the code font size; 0 means "use the UI theme's medium size".
    // The syntax colors are ARGB; 0 means "fall back to the built-in default".
    int edFont;
    int synKw;
    int synTy;
    int synStr;
    int synCom;
    int synNum;
    int synText;

    /// Sets the editor's code font size and syntax-highlight colors. A 0 for any
    /// argument keeps that aspect at its built-in default.
    void ApplyTheme(int fontPx, int kw, int ty, int str, int com, int num, int text) {
        edFont = fontPx;
        synKw = kw; synTy = ty; synStr = str; synCom = com; synNum = num; synText = text;
    }

    /// The code font size to render with, honoring the theme's default when unset.
    int FontSize(Theme t) {
        if (edFont > 0) { return edFont; }
        return t.fontSizeMedium;
    }

    static CodeEditor Create() {
        CodeEditor e = new CodeEditor();
        e.edFont = 0;
        e.synKw = 0; e.synTy = 0; e.synStr = 0; e.synCom = 0; e.synNum = 0; e.synText = 0;
        e.lines = new List<string>();
        e.lines.Add("");
        e.curLine = 0;
        e.curCol = 0;
        e.scrollLine = 0;
        e.lastId = -1;
        e.acItems = new List<string>();
        e.acAllItems = new List<string>();
        e.acAllKinds = new List<string>();
        e.acFilter = "";
        e.filtX = 0; e.filtY = 0; e.filtW = 0; e.filtH = 0;
        e.acFull = new List<string>();
        e.clLine = new List<int>();
        e.clName = new List<string>();
        e.clX = new List<int>();
        e.clY = new List<int>();
        e.clW = new List<int>();
        e.refPopOpen = false;
        e.refPopName = "";
        e.refPopLines = new List<int>();
        e.refPopX = 0; e.refPopY = 0; e.refPopSel = 0;
        e.refPopGX = 0; e.refPopGY = 0; e.refPopGW = 0; e.refPopGH = 0;
        e.refPopRowH = 0; e.refPopHeadH = 0; e.refPopShown = 0;
        e.gotoRequested = false;
        e.acSel = 0;
        e.acActive = false;
        e.acStart = 0;
        e.acDot = false;
        e.acKinds = new List<string>();
        e.popX = 0; e.popY = 0; e.popW = 0; e.popH = 0;
        e.popItemH = 0; e.popFirst = 0; e.popShown = 0;
        e.selActive = false;
        e.selAnchorLine = 0;
        e.selAnchorCol = 0;
        e.mouseSelecting = false;
        e.lastClickMs = 0 - 100000;
        e.lastClickLine = -1;
        e.lastClickCol = -1;
        e.clickCount = 0;
        e.pageRows = 20;
        e.mcLines = new List<int>();
        e.mcCols = new List<int>();
        e.clipboard = "";
        e.undoStack = new List<string>();
        e.undoLines = new List<int>();
        e.undoCols = new List<int>();
        e.redoStack = new List<string>();
        e.redoLines = new List<int>();
        e.redoCols = new List<int>();
        e.errorLines = new List<int>();
        e.errorMsgs = new List<string>();
        e.lastDiagLine = -1;
        e.cErrLines = new List<int>();
        e.cErrMsgs = new List<string>();
        e.cErrStamp = -1;
        e.projTypeNames = new List<string>();
        e.projTypeMembers = new List<string>();
        e.projFileSrc = new List<string>();
        e.fixLines = new List<int>();
        e.fixNs = new List<string>();
        e.bps = new List<int>();
        e.execLine = -1;
        e.dbgVars = new List<string>();
        e.hoverTip = "";
        e.hoverTipX = 0;
        e.hoverTipY = 0;
        e.ctxOpen = false;
        e.ctxX = 0;
        e.ctxY = 0;
        e.ctxCmd = "";
        return e;
    }

    /// Splits a string into lines on '\n' (stripping '\r').
    static List<string> SplitLines(string s) {
        List<string> outLines = new List<string>();
        string cur = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\n") {
                outLines.Add(cur);
                cur = "";
            } else if (ch == "\r") {
                cur = cur;
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        outLines.Add(cur);
        return outLines;
    }

    void SetLines(List<string> ls) {
        lines = ls;
        if (lines.Count == 0) { lines.Add(""); }
        curLine = 0;
        curCol = 0;
        scrollLine = 0;
        lastDiagLine = -1;  // force diagnostics to recompute for the new content
    }

    void LoadText(string s) {
        SetLines(CodeEditor.SplitLines(s));
    }

    string GetText() {
        string outText = "";
        int i = 0;
        while (i < lines.Count) {
            outText = outText + lines[i];
            if (i + 1 < lines.Count) { outText = outText + "\n"; }
            i = i + 1;
        }
        return outText;
    }

    int LineCount() {
        return lines.Count;
    }

    int CurLine() { return curLine; }
    int CurCol() { return curCol; }

    /// Returns the identifier under the caret (empty string when none).
    string WordAtCaret() {
        if (curLine < 0 || curLine >= lines.Count) { return ""; }
        string s = lines[curLine];
        int col = curCol;
        if (col >= s.Length) { col = s.Length - 1; }
        if (col < 0) { return ""; }
        return CodeEditor.WordAt(s, col);
    }

    /// Returns true once after a Ctrl+click requested Go to Definition,
    /// clearing the flag so the host handles it exactly once.
    bool ConsumeGotoRequest() {
        if (gotoRequested) { gotoRequested = false; return true; }
        return false;
    }

    void SetDebugVars(List<string> vars) { dbgVars = vars; }

    void GoToLine(int line) {
        if (line < 0) { line = 0; }
        if (line >= lines.Count) { line = lines.Count - 1; }
        curLine = line;
        curCol = 0;
        selActive = false;
    }

    /// Total buffer size, used only as a cheap change signal for invalidating
    /// compiler diagnostics when the user edits the file.
    int BufLen() {
        int n = 0;
        int i = 0;
        while (i < lines.Count) { n = n + lines[i].Length + 1; i = i + 1; }
        return n;
    }

    /// Replaces the compiler diagnostics shown as red underlines + tooltips with
    /// the real errors reported by the last Run/Build for this file, and jumps
    /// the caret to the first one so its reason is visible immediately.
    void SetCompilerDiagnostics(List<int> errLines, List<string> msgs) {
        cErrLines = errLines;
        cErrMsgs = msgs;
        cErrStamp = BufLen();
        if (cErrLines.Count > 0) {
            GoToLine(cErrLines[0]);
        }
    }

    /// True once the buffer has changed since the compiler diagnostics were set,
    /// so stale errors stop being drawn the moment the user starts editing.
    bool CompilerDiagStale() {
        return cErrStamp < 0 || BufLen() != cErrStamp;
    }

    /// The compiler-diagnostic message for a line, or "" when none/stale.
    string CompilerErrMsg(int ln) {
        if (CompilerDiagStale()) { return ""; }
        return CodeEditor.GetErrorMsg(cErrLines, cErrMsgs, ln);
    }

    /// True when line `ln` currently carries a live compiler diagnostic.
    bool HasCompilerErr(int ln) {
        if (CompilerDiagStale()) { return false; }
        return CodeEditor.HasInt(cErrLines, ln);
    }

    void GoToLineCol(int line, int col) {
        GoToLine(line);
        curCol = col;
        ClampCol();
    }

    // ---- edit primitives ----
    void InsertStr(string ins) {
        string ln = lines[curLine];
        lines[curLine] = Text.InsertAt(ln, curCol, ins);
        curCol = curCol + ins.Length;
    }

    void NewLine() {
        string ln = lines[curLine];
        string left = Text.Left(ln, curCol);
        string right = Text.Right(ln, curCol);
        lines[curLine] = left;
        lines.Insert(curLine + 1, right);
        curLine = curLine + 1;
        curCol = 0;
    }

    void BackspaceEdit() {
        if (curCol > 0) {
            string ln = lines[curLine];
            int start = Text.PrevCharStart(ln, curCol);
            lines[curLine] = Text.DeleteBefore(ln, curCol);
            curCol = start;
        } else if (curLine > 0) {
            string prev = lines[curLine - 1];
            string cur = lines[curLine];
            int newCol = prev.Length;
            lines[curLine - 1] = prev + cur;
            lines.RemoveAt(curLine);
            curLine = curLine - 1;
            curCol = newCol;
        }
    }

    void DeleteEdit() {
        string ln = lines[curLine];
        if (curCol < ln.Length) {
            lines[curLine] = Text.RemoveAt(ln, curCol);
        } else if (curLine + 1 < lines.Count) {
            string next = lines[curLine + 1];
            lines[curLine] = ln + next;
            lines.RemoveAt(curLine + 1);
        }
    }

    void ClampCol() {
        string ln = lines[curLine];
        if (curCol > ln.Length) { curCol = ln.Length; }
        if (curCol < 0) { curCol = 0; }
    }

    void MoveLeft() {
        if (curCol > 0) {
            curCol = Text.PrevCharStart(lines[curLine], curCol);
        } else if (curLine > 0) {
            curLine = curLine - 1;
            curCol = lines[curLine].Length;
        }
    }

    void MoveRight() {
        string ln = lines[curLine];
        if (curCol < ln.Length) {
            curCol = Text.NextCharEnd(ln, curCol);
        } else if (curLine + 1 < lines.Count) {
            curLine = curLine + 1;
            curCol = 0;
        }
    }

    void MoveUp() {
        if (curLine > 0) {
            curLine = curLine - 1;
            ClampCol();
        }
    }

    void MoveDown() {
        if (curLine + 1 < lines.Count) {
            curLine = curLine + 1;
            ClampCol();
        }
    }

    /// Moves the caret to the start of the previous word (Ctrl+Left).
    void MoveWordLeft() {
        if (curCol == 0) {
            if (curLine > 0) { curLine = curLine - 1; curCol = lines[curLine].Length; }
            return;
        }
        string s = lines[curLine];
        int c = curCol;
        while (c > 0 && s.Substring(c - 1, 1) == " ") { c = c - 1; }
        if (c > 0 && CodeEditor.IsIdentChar(s.Substring(c - 1, 1))) {
            while (c > 0 && CodeEditor.IsIdentChar(s.Substring(c - 1, 1))) { c = c - 1; }
        } else {
            while (c > 0 && !CodeEditor.IsIdentChar(s.Substring(c - 1, 1))
                   && s.Substring(c - 1, 1) != " ") { c = c - 1; }
        }
        curCol = c;
    }

    /// Moves the caret to the start of the next word (Ctrl+Right).
    void MoveWordRight() {
        string s = lines[curLine];
        int n = s.Length;
        if (curCol >= n) {
            if (curLine + 1 < lines.Count) { curLine = curLine + 1; curCol = 0; }
            return;
        }
        int c = curCol;
        if (CodeEditor.IsIdentChar(s.Substring(c, 1))) {
            while (c < n && CodeEditor.IsIdentChar(s.Substring(c, 1))) { c = c + 1; }
        } else if (s.Substring(c, 1) != " ") {
            while (c < n && !CodeEditor.IsIdentChar(s.Substring(c, 1))
                   && s.Substring(c, 1) != " ") { c = c + 1; }
        }
        while (c < n && s.Substring(c, 1) == " ") { c = c + 1; }
        curCol = c;
    }

    /// Smart Home target: first non-whitespace column, or column 0 when the
    /// caret is already there (toggles, like Visual Studio / JetBrains).
    int SmartHomeCol() {
        string s = lines[curLine];
        int i = 0;
        while (i < s.Length && s.Substring(i, 1) == " ") { i = i + 1; }
        if (curCol == i) { return 0; }
        return i;
    }

    /// Swaps the current line with the one above (Alt+Up).
    void MoveLineUp() {
        if (curLine == 0) { return; }
        SaveUndo();
        string tmp = lines[curLine - 1];
        lines[curLine - 1] = lines[curLine];
        lines[curLine] = tmp;
        curLine = curLine - 1;
        ClampCol();
        selActive = false;
    }

    /// Swaps the current line with the one below (Alt+Down).
    void MoveLineDown() {
        if (curLine + 1 >= lines.Count) { return; }
        SaveUndo();
        string tmp = lines[curLine + 1];
        lines[curLine + 1] = lines[curLine];
        lines[curLine] = tmp;
        curLine = curLine + 1;
        ClampCol();
        selActive = false;
    }

    /// Adds one indent level to every line touched by the selection (Tab).
    void IndentSelection() {
        SaveUndo();
        int a = selAnchorLine;
        int b = curLine;
        if (a > b) { int tmp = a; a = b; b = tmp; }
        int i = a;
        while (i <= b) {
            lines[i] = "    " + lines[i];
            i = i + 1;
        }
        selAnchorCol = selAnchorCol + 4;
        curCol = curCol + 4;
    }

    /// Removes up to one indent level from every selected line (Shift+Tab).
    void OutdentSelection() {
        SaveUndo();
        int a = selAnchorLine;
        int b = curLine;
        if (a > b) { int tmp = a; a = b; b = tmp; }
        int i = a;
        while (i <= b) {
            string s = lines[i];
            int rem = 0;
            while (rem < 4 && rem < s.Length && s.Substring(rem, 1) == " ") { rem = rem + 1; }
            lines[i] = s.Substring(rem, s.Length - rem);
            if (i == selAnchorLine) {
                selAnchorCol = selAnchorCol - rem;
                if (selAnchorCol < 0) { selAnchorCol = 0; }
            }
            if (i == curLine) {
                curCol = curCol - rem;
                if (curCol < 0) { curCol = 0; }
            }
            i = i + 1;
        }
    }

    /// Removes up to one indent level from the current line (Shift+Tab, no
    /// selection).
    void OutdentCurrentLine() {
        SaveUndo();
        string s = lines[curLine];
        int rem = 0;
        while (rem < 4 && rem < s.Length && s.Substring(rem, 1) == " ") { rem = rem + 1; }
        lines[curLine] = s.Substring(rem, s.Length - rem);
        curCol = curCol - rem;
        if (curCol < 0) { curCol = 0; }
    }

    // ---- undo / redo ----
    void SaveUndo() {
        string snap = GetText();
        undoStack.Add(snap);
        undoLines.Add(curLine);
        undoCols.Add(curCol);
        if (undoStack.Count > 50) {
            undoStack.RemoveAt(0);
            undoLines.RemoveAt(0);
            undoCols.RemoveAt(0);
        }
        // A fresh edit invalidates the redo history.
        redoStack = new List<string>();
        redoLines = new List<int>();
        redoCols = new List<int>();
    }

    void Undo() {
        if (undoStack.Count == 0) { return; }
        int last = undoStack.Count - 1;
        string snap = undoStack[last];
        int sl = undoLines[last];
        int sc = undoCols[last];
        undoStack.RemoveAt(last);
        undoLines.RemoveAt(last);
        undoCols.RemoveAt(last);
        // Remember the pre-undo state so Redo can restore it.
        redoStack.Add(GetText());
        redoLines.Add(curLine);
        redoCols.Add(curCol);
        LoadText(snap);
        curLine = sl;
        curCol = sc;
        ClampCol();
        selActive = false;
    }

    void Redo() {
        if (redoStack.Count == 0) { return; }
        int last = redoStack.Count - 1;
        string snap = redoStack[last];
        int sl = redoLines[last];
        int sc = redoCols[last];
        redoStack.RemoveAt(last);
        redoLines.RemoveAt(last);
        redoCols.RemoveAt(last);
        undoStack.Add(GetText());
        undoLines.Add(curLine);
        undoCols.Add(curCol);
        LoadText(snap);
        curLine = sl;
        curCol = sc;
        ClampCol();
        selActive = false;
    }

    // ---- selection ----
    void SelectAll() {
        selAnchorLine = 0;
        selAnchorCol = 0;
        curLine = lines.Count - 1;
        curCol = lines[curLine].Length;
        selActive = true;
    }

    void ClearSelection() { selActive = false; }

    /// Selects the identifier under the caret (double-click). If the caret sits
    /// at a word's right edge (on the following separator) the preceding word is
    /// selected, matching Visual Studio / JetBrains behaviour.
    void SelectWordCaret() {
        string s = lines[curLine];
        int n = s.Length;
        int probe = curCol;
        bool onIdent = probe < n && CodeEditor.IsIdentChar(s.Substring(probe, 1));
        if (!onIdent && probe > 0 && CodeEditor.IsIdentChar(s.Substring(probe - 1, 1))) {
            probe = probe - 1;
            onIdent = true;
        }
        if (!onIdent) { return; }
        int start = probe;
        int end = probe + 1;
        while (start > 0 && CodeEditor.IsIdentChar(s.Substring(start - 1, 1))) { start = start - 1; }
        while (end < n && CodeEditor.IsIdentChar(s.Substring(end, 1))) { end = end + 1; }
        selAnchorLine = curLine;
        selAnchorCol = start;
        curCol = end;
        selActive = true;
        ClearExtraCarets();
    }

    /// Selects the whole current line, including its trailing newline when there
    /// is a following line (triple-click).
    void SelectLineCaret() {
        selAnchorLine = curLine;
        selAnchorCol = 0;
        if (curLine + 1 < lines.Count) {
            curLine = curLine + 1;
            curCol = 0;
        } else {
            curCol = lines[curLine].Length;
        }
        selActive = true;
        ClearExtraCarets();
    }

    /// Prepares selection state before a caret move: when `shift` is held the
    /// anchor is planted at the current caret (if not already selecting) so the
    /// move extends the selection; otherwise the selection is dropped.
    void SelPrepare(bool shift) {
        if (shift) {
            if (!selActive) {
                selAnchorLine = curLine;
                selAnchorCol = curCol;
                selActive = true;
            }
        } else {
            selActive = false;
        }
    }

    /// Places the caret from a mouse position (pixels) inside the text area.
    void CaretFromMouse(App app, Rect area, int gutterW, int fontSize) {
        int textX = area.x + gutterW + app.theme.paddingSmall;
        int rel = app.mouseY - area.y;
        int clicked = scrollLine + rel / (Canvas.FontHeight(fontSize) + app.Scale(4));
        if (clicked >= lines.Count) { clicked = lines.Count - 1; }
        if (clicked < 0) { clicked = 0; }
        curLine = clicked;
        curCol = CodeEditor.ColFromX(lines[curLine], app.mouseX - textX, fontSize);
    }

    // ---- multi-cursor ----
    void ClearExtraCarets() { mcLines = new List<int>(); mcCols = new List<int>(); }

    /// Adds a secondary caret one line below the lowest active caret.
    void AddCaretBelow() {
        int maxL = curLine;
        int i = 0;
        while (i < mcLines.Count) { if (mcLines[i] > maxL) { maxL = mcLines[i]; } i = i + 1; }
        if (maxL + 1 < lines.Count) { mcLines.Add(maxL + 1); mcCols.Add(curCol); }
    }

    /// Adds a secondary caret one line above the highest active caret.
    void AddCaretAbove() {
        int minL = curLine;
        int i = 0;
        while (i < mcLines.Count) { if (mcLines[i] < minL) { minL = mcLines[i]; } i = i + 1; }
        if (minL - 1 >= 0) { mcLines.Add(minL - 1); mcCols.Add(curCol); }
    }

    /// Inserts `ins` at the primary caret and every secondary caret.
    /// All carets sit on distinct lines, so per-line edits stay independent.
    void McInsertStr(string ins) {
        InsertStr(ins);
        int i = 0;
        while (i < mcLines.Count) {
            int L = mcLines[i];
            if (L >= 0 && L < lines.Count) {
                int C = mcCols[i];
                if (C > lines[L].Length) { C = lines[L].Length; }
                lines[L] = Text.InsertAt(lines[L], C, ins);
                mcCols[i] = C + ins.Length;
            }
            i = i + 1;
        }
    }

    /// Backspace at every caret. Collapses to a single caret when the primary
    /// caret is at column 0 (which would merge lines and shift indices).
    void McBackspace() {
        if (curCol <= 0) { ClearExtraCarets(); SaveUndo(); BackspaceEdit(); return; }
        SaveUndo();
        string ln = lines[curLine];
        int start = Text.PrevCharStart(ln, curCol);
        lines[curLine] = Text.DeleteBefore(ln, curCol);
        curCol = start;
        int i = 0;
        while (i < mcLines.Count) {
            int L = mcLines[i];
            int C = mcCols[i];
            if (L >= 0 && L < lines.Count && C > 0) {
                int cs = Text.PrevCharStart(lines[L], C);
                lines[L] = Text.DeleteBefore(lines[L], C);
                mcCols[i] = cs;
            }
            i = i + 1;
        }
    }

    void StartSelection() {
        if (!selActive) {
            selAnchorLine = curLine;
            selAnchorCol = curCol;
            selActive = true;
        }
    }

    string GetSelectedText() {
        if (!selActive) { return ""; }
        int sL = selAnchorLine;
        int sC = selAnchorCol;
        int eL = curLine;
        int eC = curCol;
        if (sL > eL || (sL == eL && sC > eC)) {
            int tmpL = sL; sL = eL; eL = tmpL;
            int tmpC = sC; sC = eC; eC = tmpC;
        }
        if (sL == eL) {
            string ln = lines[sL];
            if (sC > ln.Length) { sC = ln.Length; }
            if (eC > ln.Length) { eC = ln.Length; }
            return ln.Substring(sC, eC - sC);
        }
        string result = "";
        string firstLn = lines[sL];
        if (sC <= firstLn.Length) {
            result = firstLn.Substring(sC, firstLn.Length - sC);
        }
        int mi = sL + 1;
        while (mi < eL) {
            result = result + "\n" + lines[mi];
            mi = mi + 1;
        }
        string lastLn = lines[eL];
        if (eC > lastLn.Length) { eC = lastLn.Length; }
        result = result + "\n" + lastLn.Substring(0, eC);
        return result;
    }

    void DeleteSelection() {
        if (!selActive) { return; }
        int sL = selAnchorLine;
        int sC = selAnchorCol;
        int eL = curLine;
        int eC = curCol;
        if (sL > eL || (sL == eL && sC > eC)) {
            int tmpL = sL; sL = eL; eL = tmpL;
            int tmpC = sC; sC = eC; eC = tmpC;
        }
        SaveUndo();
        if (sL == eL) {
            string ln = lines[sL];
            if (sC > ln.Length) { sC = ln.Length; }
            if (eC > ln.Length) { eC = ln.Length; }
            lines[sL] = ln.Substring(0, sC) + ln.Substring(eC, ln.Length - eC);
        } else {
            string firstLn = lines[sL];
            string lastLn = lines[eL];
            if (sC > firstLn.Length) { sC = firstLn.Length; }
            if (eC > lastLn.Length) { eC = lastLn.Length; }
            string keep = firstLn.Substring(0, sC) + lastLn.Substring(eC, lastLn.Length - eC);
            lines[sL] = keep;
            int ri = eL;
            while (ri > sL) {
                lines.RemoveAt(ri);
                ri = ri - 1;
            }
        }
        curLine = sL;
        curCol = sC;
        selActive = false;
    }

    void CopySelection() {
        if (!selActive) { return; }
        clipboard = GetSelectedText();
        Clipboard.SetText(clipboard);
    }

    void CutSelection() {
        if (!selActive) { return; }
        clipboard = GetSelectedText();
        Clipboard.SetText(clipboard);
        DeleteSelection();
    }

    void PasteClipboard() {
        // Prefer the OS clipboard so text copied in other apps pastes here;
        // fall back to the in-editor buffer when the OS clipboard has no text.
        string os = Clipboard.GetText();
        if (os.Length > 0) { clipboard = os; }
        if (clipboard.Length == 0) { return; }
        if (selActive) { DeleteSelection(); }
        else { SaveUndo(); }
        List<string> pLines = CodeEditor.SplitLines(clipboard);
        if (pLines.Count == 1) {
            InsertStr(pLines[0]);
        } else {
            string ln = lines[curLine];
            string left = ln.Substring(0, curCol);
            string right = "";
            if (curCol < ln.Length) {
                right = ln.Substring(curCol, ln.Length - curCol);
            }
            lines[curLine] = left + pLines[0];
            int pi = 1;
            while (pi < pLines.Count - 1) {
                lines.Insert(curLine + pi, pLines[pi]);
                pi = pi + 1;
            }
            int lastIdx = pLines.Count - 1;
            string lastP = pLines[lastIdx];
            lines.Insert(curLine + lastIdx, lastP + right);
            curLine = curLine + lastIdx;
            curCol = lastP.Length;
        }
    }

    // ---- line editing (context-menu / VS-style commands) ----

    /// Deletes the active selection, or the character at the caret otherwise.
    void DeleteAtCaret() {
        if (selActive) { DeleteSelection(); }
        else { SaveUndo(); DeleteEdit(); }
    }

    /// Toggles a leading "// " line comment on the current line, or on every
    /// line spanned by the selection.
    void ToggleComment() {
        SaveUndo();
        int a = curLine;
        int b = curLine;
        if (selActive) {
            a = selAnchorLine;
            b = curLine;
            if (a > b) { int tmp = a; a = b; b = tmp; }
        }
        // If every line in range is already commented, uncomment; else comment.
        bool allComment = true;
        int i = a;
        while (i <= b) {
            string s = lines[i];
            string trimmed = CodeEditor.LTrim(s);
            if (trimmed.Length < 2 || trimmed.Substring(0, 2) != "//") {
                if (trimmed.Length > 0) { allComment = false; }
            }
            i = i + 1;
        }
        i = a;
        while (i <= b) {
            string s = lines[i];
            if (allComment) {
                lines[i] = CodeEditor.Uncomment(s);
            } else {
                if (CodeEditor.LTrim(s).Length > 0) {
                    lines[i] = "// " + s;
                }
            }
            i = i + 1;
        }
        selActive = false;
        ClampCol();
    }

    /// Duplicates the current line directly below it.
    void DuplicateLine() {
        SaveUndo();
        string s = lines[curLine];
        lines.Insert(curLine + 1, s);
        curLine = curLine + 1;
        ClampCol();
    }

    /// Removes the current line entirely.
    void DeleteLine() {
        SaveUndo();
        if (lines.Count <= 1) {
            lines[0] = "";
            curLine = 0;
            curCol = 0;
            return;
        }
        lines.RemoveAt(curLine);
        if (curLine >= lines.Count) { curLine = lines.Count - 1; }
        ClampCol();
    }

    static string LTrim(string s) {
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == " " || ch == "\t") { i = i + 1; }
            else { break; }
        }
        return s.Substring(i, s.Length - i);
    }

    /// Removes the first "// " (or "//") after leading whitespace.
    static string Uncomment(string s) {
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == " " || ch == "\t") { i = i + 1; }
            else { break; }
        }
        string lead = s.Substring(0, i);
        string rest = s.Substring(i, s.Length - i);
        if (rest.Length >= 2 && rest.Substring(0, 2) == "//") {
            rest = rest.Substring(2, rest.Length - 2);
            if (rest.Length >= 1 && rest.Substring(0, 1) == " ") {
                rest = rest.Substring(1, rest.Length - 1);
            }
        }
        return lead + rest;
    }

    /// Returns and clears any pending host command requested from the context
    /// menu (e.g. "find", "gotoline"); empty string when none.
    string TakeCommand() {
        string cmd = ctxCmd;
        ctxCmd = "";
        return cmd;
    }

    /// Fills the parallel label / shortcut / action lists for the context menu.
    /// Action 0 marks a separator row.
    static void BuildCtxMenu(List<string> labels, List<string> keys, List<int> acts) {
        labels.Add("Cut"); keys.Add("Ctrl+X"); acts.Add(1);
        labels.Add("Copy"); keys.Add("Ctrl+C"); acts.Add(2);
        labels.Add("Paste"); keys.Add("Ctrl+V"); acts.Add(3);
        labels.Add("Delete"); keys.Add("Del"); acts.Add(4);
        labels.Add(""); keys.Add(""); acts.Add(0);
        labels.Add("Select All"); keys.Add("Ctrl+A"); acts.Add(5);
        labels.Add(""); keys.Add(""); acts.Add(0);
        labels.Add("Toggle Comment"); keys.Add("Ctrl+/"); acts.Add(6);
        labels.Add("Duplicate Line"); keys.Add("Ctrl+D"); acts.Add(7);
        labels.Add("Delete Line"); keys.Add("Ctrl+L"); acts.Add(8);
        labels.Add(""); keys.Add(""); acts.Add(0);
        labels.Add("Add Cursor Above"); keys.Add("Ctrl+Alt+Up"); acts.Add(13);
        labels.Add("Add Cursor Below"); keys.Add("Ctrl+Alt+Down"); acts.Add(14);
        labels.Add(""); keys.Add(""); acts.Add(0);
        labels.Add(""); keys.Add(""); acts.Add(0);
        labels.Add("Go to Definition"); keys.Add("F12"); acts.Add(11);
        labels.Add("Find All References"); keys.Add("Shift+F12"); acts.Add(12);
        labels.Add(""); keys.Add(""); acts.Add(0);
        labels.Add("Find..."); keys.Add("Ctrl+F"); acts.Add(9);
        labels.Add("Go to Line..."); keys.Add("Ctrl+G"); acts.Add(10);
    }

    /// Runs a context-menu action by id (see BuildCtxMenu).
    void RunCtxAction(App app, int act) {
        if (act == 1) { CutSelection(); CheckErrors(); }
        else if (act == 2) { CopySelection(); }
        else if (act == 3) { PasteClipboard(); CheckErrors(); UpdateCompletion(); }
        else if (act == 4) { DeleteAtCaret(); CheckErrors(); }
        else if (act == 5) { SelectAll(); }
        else if (act == 6) { ToggleComment(); CheckErrors(); }
        else if (act == 7) { DuplicateLine(); CheckErrors(); }
        else if (act == 8) { DeleteLine(); CheckErrors(); }
        else if (act == 9) { ctxCmd = "find"; }
        else if (act == 10) { ctxCmd = "gotoline"; }
        else if (act == 11) { ctxCmd = "gotodef"; }
        else if (act == 12) { ctxCmd = "findrefs"; }
        else if (act == 13) { AddCaretAbove(); }
        else if (act == 14) { AddCaretBelow(); }
        else if (act == 20) { ApplyQuickFix(); }
        ctxOpen = false;
        app.RequestRedraw();
    }

    bool CtxMenuOpen() { return ctxOpen; }

    /// Draws the context menu as a top-level overlay (clamped to the whole
    /// window, not the editor rect) and handles item clicks. Must be called at
    /// the very end of the frame so nothing paints over it.
    void RenderCtxMenu(App app) {
        if (!ctxOpen) { return; }
        Canvas c = app.canvas;
        Theme t = app.theme;
        int fontSize = t.fontSizeMedium;
        int lineH = Canvas.FontHeight(fontSize) + app.Scale(4);
        if (lineH < 1) { lineH = 1; }

        List<string> mLabels = new List<string>();
        List<string> mKeys = new List<string>();
        List<int> mActs = new List<int>();
        CodeEditor.BuildCtxMenu(mLabels, mKeys, mActs);
        // Quick-fix: offer to insert a missing `using` when the caret line uses
        // a stdlib type whose namespace has not been imported.
        string qfNs = QuickFixNs();
        if (qfNs.Length > 0) {
            mLabels.Insert(0, ""); mKeys.Insert(0, ""); mActs.Insert(0, 0);
            mLabels.Insert(0, "Add using " + qfNs + ";"); mKeys.Insert(0, "Ctrl+."); mActs.Insert(0, 20);
        }
        int itemH = lineH;
        int sepH = app.Scale(7);
        int mW = app.Scale(150);
        int wi = 0;
        while (wi < mLabels.Count) {
            if (mActs[wi] != 0) {
                int lw = Canvas.MeasureText(mLabels[wi], fontSize)
                         + Canvas.MeasureText(mKeys[wi], fontSize) + app.Scale(44);
                if (lw > mW) { mW = lw; }
            }
            wi = wi + 1;
        }
        int mH = app.Scale(6);
        int hi = 0;
        while (hi < mActs.Count) {
            if (mActs[hi] == 0) { mH = mH + sepH; } else { mH = mH + itemH; }
            hi = hi + 1;
        }

        int winW = c.Width();
        int winH = c.Height();
        int topB = app.titlebarH;
        int mX = ctxX;
        int mY = ctxY;
        if (mX + mW > winW) { mX = winW - mW - app.Scale(4); }
        if (mY + mH > winH) { mY = winH - mH - app.Scale(4); }
        if (mX < 0) { mX = 0; }
        if (mY < topB) { mY = topB; }

        c.FillRoundRect(mX + 2, mY + 2, mW, mH, app.Scale(4), 0x50000000);
        c.FillRoundRect(mX, mY, mW, mH, app.Scale(4), 0xFF252526);
        c.DrawRect(mX, mY, mW, mH, 0xFF3E3E42, 1);

        int ry = mY + app.Scale(3);
        int ri = 0;
        while (ri < mActs.Count) {
            if (mActs[ri] == 0) {
                c.FillRect(mX + app.Scale(6), ry + sepH / 2, mW - app.Scale(12), 1, 0xFF3E3E42);
                ry = ry + sepH;
            } else {
                bool hov = app.mouseX >= mX && app.mouseX < mX + mW
                           && app.mouseY >= ry && app.mouseY < ry + itemH;
                int tcol = 0xFFD4D4D4;
                if (hov) {
                    c.FillRect(mX + app.Scale(2), ry, mW - app.Scale(4), itemH, 0xFF094771);
                    tcol = 0xFFFFFFFF;
                }
                int ty = ry + (itemH - Canvas.FontHeight(fontSize)) / 2;
                c.DrawText(mX + app.Scale(12), ty, mLabels[ri], tcol, fontSize);
                int kw = Canvas.MeasureText(mKeys[ri], fontSize);
                c.DrawText(mX + mW - kw - app.Scale(10), ty, mKeys[ri], 0xFF808080, fontSize);
                ry = ry + itemH;
            }
            ri = ri + 1;
        }

        // Left-click selects an item or dismisses the menu.
        if (app.window.EventKind() == 3 && app.window.EventButton() == 0) {
            bool inside = app.mouseX >= mX && app.mouseX < mX + mW
                          && app.mouseY >= mY && app.mouseY < mY + mH;
            if (inside) {
                int cy2 = mY + app.Scale(3);
                int ci = 0;
                int chosen = 0 - 1;
                while (ci < mActs.Count) {
                    int rh = itemH;
                    if (mActs[ci] == 0) { rh = sepH; }
                    if (mActs[ci] != 0 && app.mouseY >= cy2 && app.mouseY < cy2 + rh) {
                        chosen = mActs[ci];
                    }
                    cy2 = cy2 + rh;
                    ci = ci + 1;
                }
                if (chosen >= 0) { RunCtxAction(app, chosen); }
            } else {
                ctxOpen = false;
                app.RequestRedraw();
            }
        }
    }

    // ---- error diagnostics ----
    void CheckErrors() {
        errorLines = new List<int>();
        errorMsgs = new List<string>();
        int braceDepth = 0;
        int parenDepth = 0;
        int li = 0;
        while (li < lines.Count) {
            string ln = lines[li];
            string tr = ln;
            // Trim leading whitespace
            int si = 0;
            while (si < tr.Length) {
                string sch = tr.Substring(si, 1);
                if (sch == " " || sch == "\t") { si = si + 1; }
                else { break; }
            }
            if (si > 0) { tr = tr.Substring(si, tr.Length - si); }
            // Skip empty/comment lines
            if (tr.Length > 0 && tr.Substring(0, 1) != "/" && tr.Substring(0, 1) != "*") {
                // Check brace/paren balance per line
                int ci = 0;
                while (ci < ln.Length) {
                    string ch = ln.Substring(ci, 1);
                    if (ch == "{") { braceDepth = braceDepth + 1; }
                    if (ch == "}") { braceDepth = braceDepth - 1; }
                    if (ch == "(") { parenDepth = parenDepth + 1; }
                    if (ch == ")") { parenDepth = parenDepth - 1; }
                    ci = ci + 1;
                }
                if (braceDepth < 0) {
                    errorLines.Add(li);
                    errorMsgs.Add("Unexpected '}'");
                    braceDepth = 0;
                }
                if (parenDepth < 0) {
                    errorLines.Add(li);
                    errorMsgs.Add("Unexpected ')'");
                    parenDepth = 0;
                }
                // Check for a missing semicolon / stray statement. A code line
                // must terminate in ';' '{' '}' etc.; a line that ends on an
                // identifier or literal (e.g. `Utils.Equals`) is flagged.
                if (tr.Length >= 1) {
                    string lastCh = tr.Substring(tr.Length - 1, 1);
                    string firstCh = tr.Substring(0, 1);
                    bool needsSemi = true;
                    // Terminators / continuation characters that make a line OK as-is
                    // (ends a block, a statement, or clearly continues onto the next).
                    string endOk = "{};,:.([+-*/=<>&|?)!%^~";
                    if (CodeEditor.InSet(endOk, lastCh)) { needsSemi = false; }
                    if (firstCh == "/" || firstCh == "*" || firstCh == "#" || firstCh == "@") { needsSemi = false; }
                    // Control / declaration headers that legitimately stand without ';'.
                    if (CodeEditor.StartsWithP(tr, "class ") || CodeEditor.StartsWithP(tr, "struct ")
                        || CodeEditor.StartsWithP(tr, "if ") || CodeEditor.StartsWithP(tr, "if(")
                        || CodeEditor.StartsWithP(tr, "else") || CodeEditor.StartsWithP(tr, "while")
                        || CodeEditor.StartsWithP(tr, "for") || CodeEditor.StartsWithP(tr, "foreach")
                        || CodeEditor.StartsWithP(tr, "switch") || CodeEditor.StartsWithP(tr, "case ")
                        || CodeEditor.StartsWithP(tr, "default") || CodeEditor.StartsWithP(tr, "do")
                        || CodeEditor.StartsWithP(tr, "try") || CodeEditor.StartsWithP(tr, "catch")
                        || CodeEditor.StartsWithP(tr, "finally") || CodeEditor.StartsWithP(tr, "namespace")
                        || CodeEditor.StartsWithP(tr, "enum") || CodeEditor.StartsWithP(tr, "interface")
                        || CodeEditor.StartsWithP(tr, "public") || CodeEditor.StartsWithP(tr, "private")
                        || CodeEditor.StartsWithP(tr, "protected") || CodeEditor.StartsWithP(tr, "internal")
                        || CodeEditor.StartsWithP(tr, "static") || CodeEditor.StartsWithP(tr, "void ")
                        || CodeEditor.StartsWithP(tr, "abstract") || CodeEditor.StartsWithP(tr, "override")
                        || CodeEditor.StartsWithP(tr, "virtual")) { needsSemi = false; }
                    // Never flag the line the caret is currently on: it is
                    // expected to be incomplete while the user is typing it.
                    if (li == curLine) { needsSemi = false; }
                    if (li != curLine && CodeEditor.StartsWithP(tr, "using ") && lastCh != ";") {
                        errorLines.Add(li);
                        errorMsgs.Add("Missing ';' after using");
                        needsSemi = false;
                    }
                    // A following line that starts with a joining character means
                    // this line is part of a multi-line expression (fluent chain,
                    // continued operator) — don't flag it.
                    if (needsSemi) {
                        string nxt = "";
                        int nj = li + 1;
                        while (nj < lines.Count) {
                            string ns = CodeEditor.LTrim(lines[nj]);
                            if (ns.Length > 0 && ns.Substring(0, 1) != "/" && ns.Substring(0, 1) != "*") {
                                nxt = ns; break;
                            }
                            nj = nj + 1;
                        }
                        if (nxt.Length > 0) {
                            string joinSet = ".)+-*/=<>&|?:,]}";
                            if (CodeEditor.InSet(joinSet, nxt.Substring(0, 1))) { needsSemi = false; }
                        }
                    }
                    // The generic "missing semicolon" guess produced too many
                    // false positives (multi-line calls, attributes, generics);
                    // real, accurate diagnostics now come from the compiler after
                    // Run/Build, so this heuristic is intentionally dropped.
                    if (false && needsSemi) {
                        errorLines.Add(li);
                        errorMsgs.Add("Missing ';' (or incomplete statement)");
                    }
                }
            }
            li = li + 1;
        }
        if (braceDepth > 0) {
            errorLines.Add(lines.Count - 1);
            errorMsgs.Add("Missing closing '}'");
        }
        if (parenDepth > 0) {
            errorLines.Add(lines.Count - 1);
            errorMsgs.Add("Missing closing ')'");
        }
        // Flag stdlib types used without the required `using` import.
        AnalyzeMissingUsings();
    }

    // ---- autocomplete ----

    /// True when list `xs` already contains `v`.
    static bool Has(List<string> xs, string v) {
        int i = 0;
        while (i < xs.Count) {
            if (xs[i] == v) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `s` begins with `pre`.
    static bool StartsWithP(string s, string pre) {
        if (pre.Length > s.Length) { return false; }
        return s.Substring(0, pre.Length) == pre;
    }

    /// Appends the language keywords to `outk`.
    static void KeywordList(List<string> outk) {
        string kws = "using namespace class struct enum interface static extern void int string bool float double char long short byte uint new return if else while for foreach do in break continue true false null this base public private protected internal override virtual abstract sealed const readonly var switch case default try catch finally throw is as typeof sizeof ref out params get set operator async await yield from where select orderby group join let into ascending descending on equals when and or not with record init required global file scoped allows value partial event delegate fixed lock checked unchecked unsafe stackalloc nameof";
        string cur = "";
        int i = 0;
        int n = kws.Length;
        while (i < n) {
            string ch = kws.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0) { outk.Add(cur); cur = ""; }
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        if (cur.Length > 0) { outk.Add(cur); }
    }

    /// Appends common standard library types and members for completion.
    static void StdlibList(List<string> outk) {
        string types = "Console List Dictionary StringBuilder String Math File Directory Path Environment Process Convert Array DateTime TimeSpan Task Thread App Canvas Theme Rect Button Label Input Panel Split Modal TreeView TabView CodeEditor Ribbon Icon SignalInt SignalBool SignalString Window TreeNode RibbonCmd TabHit HitRegion Point Size";
        string methods = "WriteLine ReadLine Write ToString Add Remove RemoveAt Insert IndexOf Contains Count Length Clear Sort Reverse Join Split Substring Replace Trim StartsWith EndsWith ToUpper ToLower Format Concat Exists ReadAllText WriteAllText CreateDirectory GetFiles GetDirectories Append AppendLine Max Min Abs Round Sqrt Floor Ceiling Pow Parse TryParse GetText LoadText Render Create SetText";
        string snippets = "Program Main InitializeComponent EventArgs Dispose Override";
        string all = types + " " + methods + " " + snippets;
        string cur = "";
        int i = 0;
        int n = all.Length;
        while (i < n) {
            string ch = all.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); cur = ""; }
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); }
    }

    /// Collects unique identifier tokens (length >= 2) appearing anywhere in the
    /// buffer, so the editor can complete symbols the user has already typed.
    static void CollectWords(List<string> ls, List<string> outw) {
        string idstart = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_";
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int li = 0;
        while (li < ls.Count) {
            string line = ls[li];
            int n = line.Length;
            int i = 0;
            while (i < n) {
                string ch = line.Substring(i, 1);
                if (CodeEditor.InSet(idstart, ch)) {
                    int j = i;
                    string w = "";
                    while (j < n) {
                        string cj = line.Substring(j, 1);
                        if (CodeEditor.InSet(idrest, cj)) { w = w + cj; j = j + 1; }
                        else { break; }
                    }
                    if (w.Length >= 2 && !CodeEditor.Has(outw, w)) { outw.Add(w); }
                    i = j;
                } else {
                    i = i + 1;
                }
            }
            li = li + 1;
        }
    }

    /// Rebuilds the visible acItems/acKinds from acAllItems/acAllKinds by
    /// applying the current kind filter, then updates popup active state.
    void ApplyKindFilter() {
        acItems = new List<string>();
        acKinds = new List<string>();
        int i = 0;
        while (i < acAllItems.Count) {
            string k = "";
            if (i < acAllKinds.Count) { k = acAllKinds[i]; }
            if (acFilter == "" || acFilter == k) {
                acItems.Add(acAllItems[i]);
                acKinds.Add(k);
            }
            i = i + 1;
        }
        if (acAllItems.Count > 0) {
            acActive = true;
            if (acSel >= acItems.Count) { acSel = acItems.Count - 1; }
            if (acSel < 0) { acSel = 0; }
        } else {
            acActive = false;
            acFilter = "";
        }
    }

    /// True when the unfiltered candidate list contains at least one item of
    /// the given kind (used to gray out unavailable filter buttons).
    bool HasKind(string kind) {
        int i = 0;
        while (i < acAllKinds.Count) {
            if (acAllKinds[i] == kind) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// Recomputes the completion popup from the word immediately left of the
    /// cursor; closes the popup when there is no prefix or no candidate.
    void UpdateCompletion() {
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string ln = lines[curLine];

        // If in dot-mode, filter the full member list by the typed prefix
        if (acDot) {
            if (acStart > curCol || acStart < 0) { acActive = false; acDot = false; return; }
            string prefix = ln.Substring(acStart, curCol - acStart);
            acAllItems = new List<string>();
            acAllKinds = new List<string>();
            int fi = 0;
            while (fi < acFull.Count) {
                if (prefix.Length == 0 || CodeEditor.StartsWithI(acFull[fi], prefix)) {
                    acAllItems.Add(acFull[fi]);
                    acAllKinds.Add(CodeEditor.MemberKind(acFull[fi]));
                }
                fi = fi + 1;
            }
            if (acAllItems.Count == 0) { acActive = false; acDot = false; return; }
            acSel = 0;
            ApplyKindFilter();
            return;
        }

        // Regular word completion
        int st = curCol;
        while (st > 0) {
            string ch = ln.Substring(st - 1, 1);
            if (CodeEditor.InSet(idrest, ch)) { st = st - 1; }
            else { break; }
        }
        acStart = st;
        string pfx = ln.Substring(st, curCol - st);
        if (pfx.Length < 1) { acActive = false; return; }

        List<string> cand = new List<string>();
        List<string> candKinds = new List<string>();
        if (InAttributeContext()) {
            // Inside `[ ... ]`: only real attributes exist here. The compiler
            // recognizes exactly DllImport and StructLayout (see parser.c).
            CodeEditor.AddKindWords(cand, candKinds, "DllImport StructLayout", "M");
        } else {
            CodeEditor.SnippetListK(cand, candKinds);
            CodeEditor.KeywordListK(cand, candKinds);
            AddStdlibCandidates(cand, candKinds);
            AddProjectCandidates(cand, candKinds);
            CodeEditor.CollectWordsK(lines, cand, candKinds);
        }
        acAllItems = new List<string>();
        acAllKinds = new List<string>();
        int i = 0;
        while (i < cand.Count) {
            string w = cand[i];
            if (w != pfx && CodeEditor.StartsWithI(w, pfx) && !CodeEditor.Has(acAllItems, w)) {
                acAllItems.Add(w);
                if (i < candKinds.Count) { acAllKinds.Add(candKinds[i]); }
                else { acAllKinds.Add("W"); }
                if (acAllItems.Count >= 40) { i = cand.Count; }
            }
            i = i + 1;
        }
        if (acAllItems.Count == 0) { acActive = false; return; }
        acSel = 0;
        ApplyKindFilter();
    }

    /// Heuristic kind tag for a member name: camelCase → field, known nouns →
    /// property, *Changed/*Click → event, otherwise method.
    static string MemberKind(string name) {
        if (name.Length == 0) { return "M"; }
        string lower = "abcdefghijklmnopqrstuvwxyz";
        if (CodeEditor.InSet(lower, name.Substring(0, 1))) { return "F"; }
        if (CodeEditor.Find(name, "Changed") >= 0 || CodeEditor.Find(name, "Click") >= 0) { return "E"; }
        string props = " Count Length Keys Values Now Today UtcNow Year Month Day Hour Minute Second DayOfWeek DayOfYear Ticks PI E Capacity Empty Chars ForegroundColor BackgroundColor ResetColor Title WindowWidth WindowHeight ExitCode HasExited Id ProcessName StandardOutput StandardError StandardInput NewLine MachineName UserName OSVersion ProcessorCount TickCount StackTrace CommandLine CurrentDirectory Is64BitOperatingSystem DirectorySeparatorChar AltDirectorySeparatorChar ";
        if (CodeEditor.Find(props, " " + name + " ") >= 0) { return "P"; }
        return "M";
    }

    /// True when `w` is a control-flow keyword that looks like a call.
    static bool IsControlWord(string w) {
        string ctrl = " if for while switch catch foreach using lock return sizeof typeof new ";
        return CodeEditor.Find(ctrl, " " + w + " ") >= 0;
    }

    /// If `line` is a method/function declaration, returns the method name;
    /// otherwise returns "". Heuristic: an identifier followed by '(' whose
    /// line ends with '{' and is not a control statement.
    static string DeclNameAt(string line) {
        string trimmed = CodeEditor.TrimStr(line);
        if (trimmed.Length == 0) { return ""; }
        // Must contain a '(' and end with '{' (opening brace on same line).
        int paren = CodeEditor.Find(trimmed, "(");
        if (paren <= 0) { return ""; }
        if (trimmed.Substring(trimmed.Length - 1, 1) != "{") { return ""; }
        // Reject obvious non-decls.
        if (CodeEditor.Find(trimmed, "=") >= 0 && CodeEditor.Find(trimmed, "==") < 0) { return ""; }
        string idset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int e = paren;
        while (e > 0) {
            string ch = trimmed.Substring(e - 1, 1);
            if (CodeEditor.InSet(idset, ch)) { e = e - 1; }
            else { break; }
        }
        string name = trimmed.Substring(e, paren - e);
        if (name.Length == 0) { return ""; }
        // A declaration has a return type / modifier before the name.
        if (e == 0) { return ""; }
        if (CodeEditor.IsControlWord(name)) { return ""; }
        return name;
    }

    /// Counts whole-word occurrences of `name` across all lines.
    int CountWord(string name) {
        string idset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int total = 0;
        int li = 0;
        while (li < lines.Count) {
            string s = lines[li];
            int from = 0;
            while (true) {
                int p = CodeEditor.FindFrom(s, name, from);
                if (p < 0) { break; }
                bool lok = true;
                bool rok = true;
                if (p > 0 && CodeEditor.InSet(idset, s.Substring(p - 1, 1))) { lok = false; }
                int rp = p + name.Length;
                if (rp < s.Length && CodeEditor.InSet(idset, s.Substring(rp, 1))) { rok = false; }
                if (lok && rok) { total = total + 1; }
                from = p + name.Length;
            }
            li = li + 1;
        }
        return total;
    }

    /// Moves the caret to the next whole-word reference of `name` after
    /// `declLine` (wrapping around), skipping the declaration line itself, and
    /// selects it. Does nothing when no other reference exists.
    void JumpToNextRef(string name, int declLine) {
        string idset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int total = lines.Count;
        int scanned = 0;
        int li = declLine + 1;
        while (scanned < total) {
            if (li >= lines.Count) { li = 0; }
            if (li != declLine) {
                string s = lines[li];
                int from = 0;
                while (true) {
                    int p = CodeEditor.FindFrom(s, name, from);
                    if (p < 0) { break; }
                    bool lok = true;
                    bool rok = true;
                    if (p > 0 && CodeEditor.InSet(idset, s.Substring(p - 1, 1))) { lok = false; }
                    int rp = p + name.Length;
                    if (rp < s.Length && CodeEditor.InSet(idset, s.Substring(rp, 1))) { rok = false; }
                    if (lok && rok) {
                        ClearExtraCarets();
                        selActive = true;
                        selAnchorLine = li; selAnchorCol = p;
                        curLine = li; curCol = p + name.Length;
                        return;
                    }
                    from = p + name.Length;
                }
            }
            li = li + 1;
            scanned = scanned + 1;
        }
    }

    /// Collects every line index (excluding `declLine`) that contains a
    /// whole-word reference of `name`, in file order, into `outLines`.
    void CollectRefs(string name, int declLine, List<int> outLines) {
        string idset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int li = 0;
        while (li < lines.Count) {
            if (li != declLine) {
                string s = lines[li];
                int from = 0;
                bool found = false;
                while (!found) {
                    int p = CodeEditor.FindFrom(s, name, from);
                    if (p < 0) { break; }
                    bool lok = true;
                    bool rok = true;
                    if (p > 0 && CodeEditor.InSet(idset, s.Substring(p - 1, 1))) { lok = false; }
                    int rp = p + name.Length;
                    if (rp < s.Length && CodeEditor.InSet(idset, s.Substring(rp, 1))) { rok = false; }
                    if (lok && rok) { outLines.Add(li); found = true; }
                    from = p + name.Length;
                }
            }
            li = li + 1;
        }
    }

    /// Moves the caret to the first whole-word reference of `name` on `targetLine`
    /// and selects it (used by the reference-list popup).
    void JumpToRefLine(string name, int targetLine) {
        if (targetLine < 0 || targetLine >= lines.Count) { return; }
        string idset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string s = lines[targetLine];
        int from = 0;
        while (true) {
            int p = CodeEditor.FindFrom(s, name, from);
            if (p < 0) { break; }
            bool lok = true;
            bool rok = true;
            if (p > 0 && CodeEditor.InSet(idset, s.Substring(p - 1, 1))) { lok = false; }
            int rp = p + name.Length;
            if (rp < s.Length && CodeEditor.InSet(idset, s.Substring(rp, 1))) { rok = false; }
            if (lok && rok) {
                ClearExtraCarets();
                selActive = true;
                selAnchorLine = targetLine; selAnchorCol = p;
                curLine = targetLine; curCol = p + name.Length;
                if (curLine < scrollLine || curLine >= scrollLine + 4) {
                    scrollLine = curLine - 4;
                    if (scrollLine < 0) { scrollLine = 0; }
                }
                return;
            }
            from = p + name.Length;
        }
    }

    /// First index of `sub` in `s` at or after `start`, or -1.
    static int FindFrom(string s, string sub, int start) {
        if (sub.Length == 0) { return start; }
        int limit = s.Length - sub.Length;
        int i = start;
        if (i < 0) { i = 0; }
        while (i <= limit) {
            if (s.Substring(i, sub.Length) == sub) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    /// Trims leading/trailing spaces and tabs from `s`.
    static string TrimStr(string s) {
        int a = 0;
        while (a < s.Length) {
            string ch = s.Substring(a, 1);
            if (ch == " " || ch == "\t") { a = a + 1; }
            else { break; }
        }
        int b = s.Length;
        while (b > a) {
            string ch = s.Substring(b - 1, 1);
            if (ch == " " || ch == "\t" || ch == "\r") { b = b - 1; }
            else { break; }
        }
        return s.Substring(a, b - a);
    }

    /// Returns the identifier under the mouse pointer, or "" if none.
    string WordAtMouse(App app, Rect area, int gutterW, int fontSize) {
        int textX = area.x + gutterW + app.theme.paddingSmall;
        if (app.mouseX < textX || app.mouseX >= area.x + area.width) { return ""; }
        if (app.mouseY < area.y || app.mouseY >= area.y + area.height) { return ""; }
        int rel = app.mouseY - area.y;
        int ln = scrollLine + rel / (Canvas.FontHeight(fontSize) + app.Scale(4));
        if (ln < 0 || ln >= lines.Count) { return ""; }
        string s = lines[ln];
        int col = CodeEditor.ColFromX(s, app.mouseX - textX, fontSize);
        if (col < 0 || col > s.Length) { return ""; }
        string idset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int a = col;
        while (a > 0 && CodeEditor.InSet(idset, s.Substring(a - 1, 1))) { a = a - 1; }
        int b = col;
        while (b < s.Length && CodeEditor.InSet(idset, s.Substring(b, 1))) { b = b + 1; }
        if (b <= a) { return ""; }
        return s.Substring(a, b - a);
    }

    static void KeywordListK(List<string> outk, List<string> kinds) {
        List<string> tmp = new List<string>();
        CodeEditor.KeywordList(tmp);
        int i = 0;
        while (i < tmp.Count) {
            outk.Add(tmp[i]);
            kinds.Add("K");
            i = i + 1;
        }
    }

    static void StdlibListK(List<string> outk, List<string> kinds) {
        string types = "Console List Dictionary StringBuilder String Math File Directory Path Environment Process Convert Array DateTime TimeSpan Task Thread App Canvas Theme Rect Button Label Input Panel Split Modal TreeView TabView CodeEditor Ribbon Icon SignalInt SignalBool SignalString Window TreeNode RibbonCmd TabHit HitRegion Point Size Color Font Graphics Bitmap Image Stream StreamReader StreamWriter HttpClient JsonSerializer Regex Match Timer Socket WebSocket";
        string methods = "WriteLine ReadLine Write ToString Add Remove RemoveAt Insert IndexOf Contains Count Length Clear Sort Reverse Join Split Substring Replace Trim StartsWith EndsWith ToUpper ToLower Format Concat Exists ReadAllText WriteAllText CreateDirectory GetFiles GetDirectories Append AppendLine Max Min Abs Round Sqrt Floor Ceiling Pow Parse TryParse GetText LoadText Render Create SetText Where Select OrderBy GroupBy First Last Any All Sum Skip Take Distinct Aggregate";
        string all = types;
        string cur = "";
        int i = 0;
        while (i < all.Length) {
            string ch = all.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("T"); }
                cur = "";
            } else { cur = cur + ch; }
            i = i + 1;
        }
        if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("T"); }
        cur = "";
        i = 0;
        while (i < methods.Length) {
            string ch = methods.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("M"); }
                cur = "";
            } else { cur = cur + ch; }
            i = i + 1;
        }
        if (cur.Length > 0 && !CodeEditor.Has(outk, cur)) { outk.Add(cur); kinds.Add("M"); }
    }

    static void CollectWordsK(List<string> ls, List<string> outw, List<string> kinds) {
        List<string> tmp = new List<string>();
        CodeEditor.CollectWords(ls, tmp);
        int i = 0;
        while (i < tmp.Count) {
            if (!CodeEditor.Has(outw, tmp[i])) {
                outw.Add(tmp[i]);
                kinds.Add("W");
            }
            i = i + 1;
        }
    }

    /// Case-insensitive StartsWith check.
    static bool StartsWithI(string s, string pre) {
        if (pre.Length > s.Length) { return false; }
        string lower = "abcdefghijklmnopqrstuvwxyz";
        string upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        int i = 0;
        while (i < pre.Length) {
            string a = s.Substring(i, 1);
            string b = pre.Substring(i, 1);
            // Normalize both to same case
            string la = a;
            string lb = b;
            int ai = 0;
            while (ai < 26) {
                if (upper.Substring(ai, 1) == a) { la = lower.Substring(ai, 1); }
                if (upper.Substring(ai, 1) == b) { lb = lower.Substring(ai, 1); }
                ai = ai + 1;
            }
            if (la != lb) { return false; }
            i = i + 1;
        }
        return true;
    }

    /// Replaces the in-progress word with the selected candidate. When `viaTab`
    /// is true and the candidate is a code snippet, its template is expanded.
    void AcceptCompletion(bool viaTab) {
        if (!acActive) { return; }
        if (acSel < 0 || acSel >= acItems.Count) { acActive = false; return; }
        string ln = lines[curLine];
        string chosen = acItems[acSel];
        string chosenKind = "";
        if (acSel < acKinds.Count) { chosenKind = acKinds[acSel]; }
        if (viaTab && chosenKind == "S") { SaveUndo(); ExpandSnippet(chosen); return; }
        string left = Text.Left(ln, acStart);
        string right = Text.Right(ln, curCol);
        lines[curLine] = left + chosen + right;
        curCol = acStart + chosen.Length;
        acActive = false;
        acDot = false;
        acFilter = "";
    }

    /// Triggered when user types '.'. Looks at the word before the dot and
    /// suggests known members for that type, or the chain return type.
    void DotCompletion() {
        string ln = lines[curLine];
        int dotPos = curCol - 1;
        if (dotPos < 0) { acActive = false; return; }

        // On a `using X.` directive, complete child namespaces, not members.
        if (CodeEditor.StartsWithP(CodeEditor.TrimStr(ln), "using ")) {
            UsingDotCompletion();
            return;
        }

        // Walk backwards through the chain: skip matched parens and identifiers
        string idchars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int pos = dotPos;
        // Skip over closing paren groups (for chained calls like .Where(...).Select)
        if (pos > 0 && ln.Substring(pos - 1, 1) == ")") {
            int depth = 1;
            pos = pos - 1;
            while (pos > 0 && depth > 0) {
                pos = pos - 1;
                string pc = ln.Substring(pos, 1);
                if (pc == ")") { depth = depth + 1; }
                else if (pc == "(") { depth = depth - 1; }
            }
        }
        // Now get the word (method or variable name) before the paren or dot
        int end = pos;
        while (pos > 0) {
            string pc = ln.Substring(pos - 1, 1);
            if (CodeEditor.InSet(idchars, pc)) { pos = pos - 1; }
            else { break; }
        }
        string lastWord = ln.Substring(pos, end - pos);

        // Walk further back to find the owner (e.g. "Console" in "Console.Xxx")
        string owner = lastWord;
        if (pos > 0 && ln.Substring(pos - 1, 1) == ".") {
            int ownerEnd = pos - 1;
            int ownerStart = ownerEnd;
            while (ownerStart > 0) {
                string pc = ln.Substring(ownerStart - 1, 1);
                if (CodeEditor.InSet(idchars, pc)) { ownerStart = ownerStart - 1; }
                else { break; }
            }
            owner = ln.Substring(ownerStart, ownerEnd - ownerStart);
        }

        // Build member list based on identified type
        acStart = curCol;
        acFull = new List<string>();
        acDot = true;

        // Resolve the receiver's type, then list ONLY that type's real members.
        // Priority: hardcoded stdlib static types -> user/project type -> the
        // declared type of a local variable -> universal object members. We
        // never dump speculative string/collection/LINQ helpers for a receiver
        // we cannot resolve (that produced bogus `Utils.OrderByDescending`).
        string recv = lastWord;
        if (recv.Length == 0) { recv = owner; }
        string norm = CodeEditor.NormalizeStdlibType(recv);
        if (CodeEditor.IsKnownStdlibType(norm)) {
            CodeEditor.AddMembers(acFull, norm);
            if (CodeEditor.IsCollectionType(norm) && UsesLinq()) { CodeEditor.AddLinqMembers(acFull); }
        } else {
            List<string> mem = new List<string>();
            bool found = FindTypeMembers(recv, mem);
            bool coll = false;
            if (!found) {
                string vt = ResolveVarType(recv);
                if (vt.Length > 0) {
                    string nvt = CodeEditor.NormalizeStdlibType(vt);
                    if (CodeEditor.IsKnownStdlibType(nvt)) {
                        CodeEditor.AddMembers(acFull, nvt);
                        found = true;
                        if (CodeEditor.IsCollectionType(nvt)) { coll = true; }
                    } else if (FindTypeMembers(vt, mem)) {
                        found = true;
                    }
                }
            }
            if (found) {
                int mi = 0;
                while (mi < mem.Count) {
                    if (!CodeEditor.Has(acFull, mem[mi])) { acFull.Add(mem[mi]); }
                    mi = mi + 1;
                }
                if (coll && UsesLinq()) { CodeEditor.AddLinqMembers(acFull); }
                // Universal members every object inherits.
                if (!CodeEditor.Has(acFull, "ToString")) { acFull.Add("ToString"); }
                if (!CodeEditor.Has(acFull, "Equals")) { acFull.Add("Equals"); }
                if (!CodeEditor.Has(acFull, "GetHashCode")) { acFull.Add("GetHashCode"); }
                if (!CodeEditor.Has(acFull, "GetType")) { acFull.Add("GetType"); }
            } else {
                acFull.Add("ToString"); acFull.Add("Equals");
                acFull.Add("GetHashCode"); acFull.Add("GetType");
            }
        }

        acFilter = "";
        acAllItems = new List<string>();
        acAllKinds = new List<string>();
        int fi = 0;
        while (fi < acFull.Count) {
            acAllItems.Add(acFull[fi]);
            acAllKinds.Add(CodeEditor.MemberKind(acFull[fi]));
            fi = fi + 1;
        }
        if (acAllItems.Count == 0) { acActive = false; acDot = false; return; }
        acSel = 0;
        ApplyKindFilter();
    }

    /// Namespace completion for a `using X.` directive: lists the child
    /// namespaces of the prefix typed so far (e.g. `using System.` -> Data,
    /// Net, IO, Text, ...). Derived from the stdlib namespace catalog so it
    /// never invents members and never falls through to the type-member path.
    void UsingDotCompletion() {
        string ln = lines[curLine];
        int dotPos = curCol - 1;
        string nsset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_.";
        int s = dotPos;
        while (s > 0 && CodeEditor.InSet(nsset, ln.Substring(s - 1, 1))) { s = s - 1; }
        string prefix = ln.Substring(s, dotPos - s);
        while (prefix.Length > 0 && prefix.Substring(prefix.Length - 1, 1) == ".") {
            prefix = prefix.Substring(0, prefix.Length - 1);
        }
        acStart = curCol;
        acDot = true;
        acFull = new List<string>();
        List<string> kids = new List<string>();
        CodeEditor.ChildNamespaces(prefix, kids);
        int ki = 0;
        while (ki < kids.Count) { acFull.Add(kids[ki]); ki = ki + 1; }
        acFilter = "";
        acAllItems = new List<string>();
        acAllKinds = new List<string>();
        int fi = 0;
        while (fi < acFull.Count) {
            acAllItems.Add(acFull[fi]);
            acAllKinds.Add("M");
            fi = fi + 1;
        }
        if (acAllItems.Count == 0) { acActive = false; acDot = false; return; }
        acSel = 0;
        ApplyKindFilter();
    }

    /// Appends to `out2` the distinct next-segment child namespaces of `prefix`
    /// found in the stdlib catalog (e.g. prefix "System.Data" -> Orm Sqlite
    /// Postgres).
    static void ChildNamespaces(string prefix, List<string> out2) {
        string data = CodeEditor.StdlibNsData();
        string pre = prefix + ".";
        int i = 0;
        string cur = "";
        while (i <= data.Length) {
            string ch = "";
            if (i < data.Length) { ch = data.Substring(i, 1); }
            if (ch == ";" || i == data.Length) {
                string key = cur;
                int eq = CodeEditor.Find(cur, "=");
                if (eq > 0) { key = cur.Substring(0, eq); }
                if (key.Length > pre.Length && CodeEditor.StartsWithP(key, pre)) {
                    string rest = key.Substring(pre.Length, key.Length - pre.Length);
                    string seg = rest;
                    int dotp = CodeEditor.Find(rest, ".");
                    if (dotp > 0) { seg = rest.Substring(0, dotp); }
                    if (seg.Length > 0 && !CodeEditor.Has(out2, seg)) { out2.Add(seg); }
                }
                cur = "";
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
    }

    /// Populates member lists for known types.
    static void AddMembers(List<string> out2, string typeName) {
        if (typeName == "Console") {
            out2.Add("WriteLine"); out2.Add("ReadLine"); out2.Add("Write");
            out2.Add("Clear"); out2.Add("ReadKey"); out2.Add("SetCursorPosition");
            out2.Add("ForegroundColor"); out2.Add("BackgroundColor"); out2.Add("ResetColor");
            out2.Add("Title"); out2.Add("WindowWidth"); out2.Add("WindowHeight");
            out2.Add("Beep"); out2.Add("Error"); out2.Add("Out"); out2.Add("In");
