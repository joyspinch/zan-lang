using System;
using Gui;

namespace Gui.Widget;

/// <summary>
/// A multi-line, line-numbered plain-text code editor. Holds its own buffer
/// (a list of lines) and cursor, and edits itself in response to keyboard input
/// while it has focus — the editing surface of the IDE. Immediate-mode: create
/// one, keep it across frames, and call Render(app, area) each frame.
///
///   CodeEditor ed = CodeEditor.Create();      // once
///   ed.LoadText("using System;\n\nclass Main {}");
///   ...
///   ed.Render(app, editorRect);               // every frame
/// </summary>
class CodeEditor {
    List<string> lines;
    int curLine;
    int curCol;
    int scrollLine;
    int lastId;

    // ---- autocomplete popup state ----
    List<string> acItems;   // current candidate list (filtered by prefix)
    int acSel;              // selected candidate index
    bool acActive;          // popup currently shown
    int acStart;            // column where the in-progress word begins

    static CodeEditor Create() {
        CodeEditor e = new CodeEditor();
        e.lines = new List<string>();
        e.lines.Add("");
        e.curLine = 0;
        e.curCol = 0;
        e.scrollLine = 0;
        e.lastId = -1;
        e.acItems = new List<string>();
        e.acSel = 0;
        e.acActive = false;
        e.acStart = 0;
        return e;
    }

    /// Splits a string into lines on '\n' (stripping '\r').
    static List<string> SplitLines(string s) {
        List<string> outLines = new List<string>();
        string cur = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\n") {
                outLines.Add(cur);
                cur = "";
            } else if (ch == "\r") {
                cur = cur;
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        outLines.Add(cur);
        return outLines;
    }

    void SetLines(List<string> ls) {
        lines = ls;
        if (lines.Count == 0) { lines.Add(""); }
        curLine = 0;
        curCol = 0;
        scrollLine = 0;
    }

    void LoadText(string s) {
        SetLines(CodeEditor.SplitLines(s));
    }

    string GetText() {
        string outText = "";
        int i = 0;
        while (i < lines.Count) {
            outText = outText + lines[i];
            if (i + 1 < lines.Count) { outText = outText + "\n"; }
            i = i + 1;
        }
        return outText;
    }

    int LineCount() {
        return lines.Count;
    }

    // ---- edit primitives ----
    void InsertStr(string ins) {
        string ln = lines[curLine];
        lines[curLine] = Text.InsertAt(ln, curCol, ins);
        curCol = curCol + ins.Length;
    }

    void NewLine() {
        string ln = lines[curLine];
        string left = Text.Left(ln, curCol);
        string right = Text.Right(ln, curCol);
        lines[curLine] = left;
        lines.Insert(curLine + 1, right);
        curLine = curLine + 1;
        curCol = 0;
    }

    void BackspaceEdit() {
        if (curCol > 0) {
            string ln = lines[curLine];
            lines[curLine] = Text.RemoveAt(ln, curCol - 1);
            curCol = curCol - 1;
        } else if (curLine > 0) {
            string prev = lines[curLine - 1];
            string cur = lines[curLine];
            int newCol = prev.Length;
            lines[curLine - 1] = prev + cur;
            lines.RemoveAt(curLine);
            curLine = curLine - 1;
            curCol = newCol;
        }
    }

    void DeleteEdit() {
        string ln = lines[curLine];
        if (curCol < ln.Length) {
            lines[curLine] = Text.RemoveAt(ln, curCol);
        } else if (curLine + 1 < lines.Count) {
            string next = lines[curLine + 1];
            lines[curLine] = ln + next;
            lines.RemoveAt(curLine + 1);
        }
    }

    void ClampCol() {
        string ln = lines[curLine];
        if (curCol > ln.Length) { curCol = ln.Length; }
        if (curCol < 0) { curCol = 0; }
    }

    void MoveLeft() {
        if (curCol > 0) {
            curCol = curCol - 1;
        } else if (curLine > 0) {
            curLine = curLine - 1;
            curCol = lines[curLine].Length;
        }
    }

    void MoveRight() {
        string ln = lines[curLine];
        if (curCol < ln.Length) {
            curCol = curCol + 1;
        } else if (curLine + 1 < lines.Count) {
            curLine = curLine + 1;
            curCol = 0;
        }
    }

    void MoveUp() {
        if (curLine > 0) {
            curLine = curLine - 1;
            ClampCol();
        }
    }

    void MoveDown() {
        if (curLine + 1 < lines.Count) {
            curLine = curLine + 1;
            ClampCol();
        }
    }

    // ---- autocomplete ----

    /// True when list `xs` already contains `v`.
    static bool Has(List<string> xs, string v) {
        int i = 0;
        while (i < xs.Count) {
            if (xs[i] == v) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `s` begins with `pre`.
    static bool StartsWithP(string s, string pre) {
        if (pre.Length > s.Length) { return false; }
        return s.Substring(0, pre.Length) == pre;
    }

    /// Appends the language keywords to `outk`.
    static void KeywordList(List<string> outk) {
        string kws = "using namespace class struct enum interface static void int string bool float double char long new return if else while for foreach in break continue true false null this base public private protected override virtual abstract const readonly var switch case default try catch finally throw";
        string cur = "";
        int i = 0;
        int n = kws.Length;
        while (i < n) {
            string ch = kws.Substring(i, 1);
            if (ch == " ") {
                if (cur.Length > 0) { outk.Add(cur); cur = ""; }
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        if (cur.Length > 0) { outk.Add(cur); }
    }

    /// Collects unique identifier tokens (length >= 2) appearing anywhere in the
    /// buffer, so the editor can complete symbols the user has already typed.
    static void CollectWords(List<string> ls, List<string> outw) {
        string idstart = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_";
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int li = 0;
        while (li < ls.Count) {
            string line = ls[li];
            int n = line.Length;
            int i = 0;
            while (i < n) {
                string ch = line.Substring(i, 1);
                if (CodeEditor.InSet(idstart, ch)) {
                    int j = i;
                    string w = "";
                    while (j < n) {
                        string cj = line.Substring(j, 1);
                        if (CodeEditor.InSet(idrest, cj)) { w = w + cj; j = j + 1; }
                        else { break; }
                    }
                    if (w.Length >= 2 && !CodeEditor.Has(outw, w)) { outw.Add(w); }
                    i = j;
                } else {
                    i = i + 1;
                }
            }
            li = li + 1;
        }
    }

    /// Recomputes the completion popup from the word immediately left of the
    /// cursor; closes the popup when there is no prefix or no candidate.
    void UpdateCompletion() {
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string ln = lines[curLine];
        int st = curCol;
        while (st > 0) {
            string ch = ln.Substring(st - 1, 1);
            if (CodeEditor.InSet(idrest, ch)) { st = st - 1; }
            else { break; }
        }
        acStart = st;
        string prefix = ln.Substring(st, curCol - st);
        acItems = new List<string>();
        if (prefix.Length < 1) { acActive = false; return; }

        List<string> cand = new List<string>();
        CodeEditor.KeywordList(cand);
        CodeEditor.CollectWords(lines, cand);
        int i = 0;
        while (i < cand.Count) {
            string w = cand[i];
            if (w != prefix && CodeEditor.StartsWithP(w, prefix) && !CodeEditor.Has(acItems, w)) {
                acItems.Add(w);
                if (acItems.Count >= 12) { i = cand.Count; }
            }
            i = i + 1;
        }
        if (acItems.Count > 0) { acActive = true; acSel = 0; }
        else { acActive = false; }
    }

    /// Replaces the in-progress word with the selected candidate.
    void AcceptCompletion() {
        string ln = lines[curLine];
        string chosen = acItems[acSel];
        string left = Text.Left(ln, acStart);
        string right = Text.Right(ln, curCol);
        lines[curLine] = left + chosen + right;
        curCol = acStart + chosen.Length;
        acActive = false;
    }

    void HandleInput(App app) {
        int kind = app.window.EventKind();
        if (kind == 6) {
            int code = app.window.EventKeyCode();
            if (code == 8) {
                BackspaceEdit();
                UpdateCompletion();
                app.RequestRedraw();
            } else if (code == 13) {
                if (acActive) { AcceptCompletion(); }
                else { NewLine(); }
                app.RequestRedraw();
            } else if (code == 9) {
                if (acActive) { AcceptCompletion(); }
                else { InsertStr("    "); }
                app.RequestRedraw();
            } else if (code == 27) {
                acActive = false;
                app.RequestRedraw();
            } else {
                string ch = Text.CharStr(code);
                if (ch.Length > 0) {
                    InsertStr(ch);
                    UpdateCompletion();
                    app.RequestRedraw();
                }
            }
        } else if (kind == 4) {
            int kc = app.window.EventKeyCode();
            if (acActive && kc == 38) {
                acSel = acSel - 1;
                if (acSel < 0) { acSel = acItems.Count - 1; }
                app.RequestRedraw();
            } else if (acActive && kc == 40) {
                acSel = acSel + 1;
                if (acSel >= acItems.Count) { acSel = 0; }
                app.RequestRedraw();
            } else if (kc == 27) { acActive = false; app.RequestRedraw(); }
            else if (kc == 37) { acActive = false; MoveLeft(); app.RequestRedraw(); }
            else if (kc == 39) { acActive = false; MoveRight(); app.RequestRedraw(); }
            else if (kc == 38) { MoveUp(); app.RequestRedraw(); }
            else if (kc == 40) { MoveDown(); app.RequestRedraw(); }
            else if (kc == 36) { curCol = 0; acActive = false; app.RequestRedraw(); }
            else if (kc == 35) { curCol = lines[curLine].Length; acActive = false; app.RequestRedraw(); }
            else if (kc == 46) { DeleteEdit(); acActive = false; app.RequestRedraw(); }
        }
    }

    /// Maps a pixel x-offset (relative to the text origin) to a column index by
    /// measuring successive prefixes.
    static int ColFromX(string s, int px, int fontSize) {
        if (px <= 0) { return 0; }
        int i = 1;
        while (i <= s.Length) {
            int w = Canvas.MeasureText(Text.Left(s, i), fontSize);
            if (w >= px) { return i; }
            i = i + 1;
        }
        return s.Length;
    }

    // ---- syntax highlighting ----

    /// True when the one-character string `ch` occurs in `set`.
    static bool InSet(string chars, string ch) {
        int i = 0;
        while (i < chars.Length) {
            if (chars.Substring(i, 1) == ch) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `hay` contains the substring `needle`.
    static bool ContainsSub(string hay, string needle) {
        int n = hay.Length;
        int m = needle.Length;
        if (m == 0) { return true; }
        int i = 0;
        while (i + m <= n) {
            if (hay.Substring(i, m) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `w` is a Zan/C#-style language keyword.
    static bool IsKeyword(string w) {
        string kws = " using namespace class struct enum interface static void int string bool float double char long short byte uint new return if else while for foreach do in break continue true false null this base public private protected internal override virtual abstract sealed const readonly var switch case default try catch finally throw is as typeof sizeof ref out params get set operator ";
        return CodeEditor.ContainsSub(kws, " " + w + " ");
    }

    /// Splits `line` into colored segments (parallel outT/outC lists): keywords,
    /// types (Capitalized identifiers), strings, line comments and numbers get
    /// distinct colors; everything else uses the default text color.
    static void Highlight(string line, Theme t, List<string> outT, List<int> outC) {
        int kwC = 0xFF569CD6;
        int tyC = 0xFF4EC9B0;
        int strC = 0xFFCE9178;
        int comC = 0xFF6A9955;
        int numC = 0xFFB5CEA8;
        int def = t.textPrimary;
        string lower = "abcdefghijklmnopqrstuvwxyz";
        string upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        string digits = "0123456789";
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int n = line.Length;
        int i = 0;
        string pending = "";
        while (i < n) {
            string ch = line.Substring(i, 1);
            if (ch == "/" && i + 1 < n && line.Substring(i + 1, 1) == "/") {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                outT.Add(line.Substring(i, n - i)); outC.Add(comC);
                i = n;
            } else if (ch == "\"") {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i + 1;
                string s = "\"";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (cj == "\\" && j + 1 < n) {
                        s = s + cj + line.Substring(j + 1, 1);
                        j = j + 2;
                    } else if (cj == "\"") {
                        s = s + cj;
                        j = j + 1;
                        break;
                    } else {
                        s = s + cj;
                        j = j + 1;
                    }
                }
                outT.Add(s); outC.Add(strC);
                i = j;
            } else if (CodeEditor.InSet(digits, ch)) {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i;
                string num = "";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (CodeEditor.InSet(digits, cj) || cj == "." || cj == "x"
                        || CodeEditor.InSet("abcdefABCDEF", cj)) {
                        num = num + cj; j = j + 1;
                    } else { break; }
                }
                outT.Add(num); outC.Add(numC);
                i = j;
            } else if (CodeEditor.InSet(lower + upper + "_", ch)) {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i;
                string w = "";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (CodeEditor.InSet(idrest, cj)) { w = w + cj; j = j + 1; }
                    else { break; }
                }
                int col = def;
                if (CodeEditor.IsKeyword(w)) { col = kwC; }
                else if (CodeEditor.InSet(upper, line.Substring(i, 1))) { col = tyC; }
                outT.Add(w); outC.Add(col);
                i = j;
            } else {
                pending = pending + ch;
                i = i + 1;
            }
        }
        if (pending.Length > 0) { outT.Add(pending); outC.Add(def); }
    }

    int Render(App app, Rect area) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        lastId = id;
        bool focused = app.focus.IsFocused(id);

        int fontSize = t.fontSizeMedium;
        int lineH = Canvas.FontHeight(fontSize) + app.Scale(4);
        if (lineH < 1) { lineH = 1; }
        int gutterW = app.Scale(48);

        c.FillRect(area.x, area.y, area.width, area.height, t.bgPrimary);
        c.FillRect(area.x, area.y, gutterW, area.height, t.bgSecondary);
        c.FillRect(area.x + gutterW, area.y, 1, area.height, t.divider);

        app.CaptureWheel(area.x, area.y, area.width, area.height);

        int visLines = area.height / lineH;
        if (visLines < 1) { visLines = 1; }

        if (focused) { HandleInput(app); }

        if (app.window.EventKind() == 13) {
            bool over = app.mouseX >= area.x && app.mouseX < area.x + area.width
                        && app.mouseY >= area.y && app.mouseY < area.y + area.height;
            if (over) {
                int delta = app.window.EventKeyCode();
                int step = delta / 120;
                if (step == 0) {
                    if (delta > 0) { step = 1; }
                    else if (delta < 0) { step = 0 - 1; }
                }
                scrollLine = scrollLine - step * 3;
                app.RequestRedraw();
            }
        }

        if (curLine < scrollLine) { scrollLine = curLine; }
        if (curLine >= scrollLine + visLines) { scrollLine = curLine - visLines + 1; }
        int maxScroll = lines.Count - visLines;
        if (maxScroll < 0) { maxScroll = 0; }
        if (scrollLine > maxScroll) { scrollLine = maxScroll; }
        if (scrollLine < 0) { scrollLine = 0; }

        int textX = area.x + gutterW + t.paddingSmall;
        int i = 0;
        while (i < visLines) {
            int ln = scrollLine + i;
            if (ln < lines.Count) {
                int rowY = area.y + i * lineH;
                int textY = rowY + (lineH - Canvas.FontHeight(fontSize)) / 2;

                if (ln == curLine && focused) {
                    c.FillRect(area.x + gutterW + 1, rowY, area.width - gutterW - 1, lineH, t.bgHover);
                }

                string num = Convert.ToString(ln + 1);
                int numW = Canvas.MeasureText(num, fontSize);
                c.DrawText(area.x + gutterW - numW - app.Scale(8), textY, num, t.textTertiary, fontSize);

                string text = lines[ln];
                List<string> segT = new List<string>();
                List<int> segC = new List<int>();
                CodeEditor.Highlight(text, t, segT, segC);
                int sx = textX;
                int si = 0;
                while (si < segT.Count) {
                    c.DrawText(sx, textY, segT[si], segC[si], fontSize);
                    sx = sx + Canvas.MeasureText(segT[si], fontSize);
                    si = si + 1;
                }

                if (ln == curLine && focused) {
                    string upto = Text.Left(text, curCol);
                    int cxp = textX + Canvas.MeasureText(upto, fontSize);
                    c.FillRect(cxp, rowY + app.Scale(2), 1, lineH - app.Scale(4), t.primary);
                }
            }
            i = i + 1;
        }

        // ---- autocomplete popup (drawn above the text, anchored at the word) ----
        if (acActive && focused && acItems.Count > 0
            && curLine >= scrollLine && curLine < scrollLine + visLines) {
            int prow = curLine - scrollLine;
            int pRowY = area.y + prow * lineH;
            int px = textX + Canvas.MeasureText(Text.Left(lines[curLine], acStart), fontSize);
            int shown = acItems.Count;
            if (shown > 8) { shown = 8; }
            int itemH = lineH;
            int popH = shown * itemH + app.Scale(4);
            int popW = app.Scale(120);
            int k = 0;
            while (k < acItems.Count) {
                int wpx = Canvas.MeasureText(acItems[k], fontSize) + app.Scale(20);
                if (wpx > popW) { popW = wpx; }
                k = k + 1;
            }
            int popY = pRowY + lineH;
            int first = 0;
            if (acSel >= 8) { first = acSel - 7; }
            c.FillRoundRect(px, popY, popW, popH, t.borderRadiusSmall, t.bgTertiary);
            c.DrawRect(px, popY, popW, popH, t.borderPrimary, 1);
            int r2 = 0;
            while (r2 < shown) {
                int idx = first + r2;
                if (idx < acItems.Count) {
                    int iy = popY + app.Scale(2) + r2 * itemH;
                    int tcol = t.textPrimary;
                    if (idx == acSel) {
                        c.FillRect(px, iy, popW, itemH, t.primary);
                        tcol = t.bgPrimary;
                    }
                    int ity = iy + (itemH - Canvas.FontHeight(fontSize)) / 2;
                    c.DrawText(px + app.Scale(8), ity, acItems[idx], tcol, fontSize);
                }
                r2 = r2 + 1;
            }
        }

        app.hitTester.Register(HitRegion.Create(id, area.x, area.y, area.width, area.height, 1));

        if (app.window.EventKind() == 3) {
            int hit = app.hitTester.HitTest(app.mouseX, app.mouseY);
            if (hit == id) {
                int rel = app.mouseY - area.y;
                int clicked = scrollLine + rel / lineH;
                if (clicked >= lines.Count) { clicked = lines.Count - 1; }
                if (clicked < 0) { clicked = 0; }
                curLine = clicked;
                curCol = CodeEditor.ColFromX(lines[curLine], app.mouseX - textX, fontSize);
                acActive = false;
                app.RequestRedraw();
            }
        }

        return id;
    }
}
