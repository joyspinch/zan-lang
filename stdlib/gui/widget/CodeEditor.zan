            out2.Add("Max"); out2.Add("Min"); out2.Add("Abs"); out2.Add("Sqrt");
            out2.Add("Round"); out2.Add("Floor"); out2.Add("Ceiling"); out2.Add("Pow");
            out2.Add("Log"); out2.Add("Log10"); out2.Add("Sin"); out2.Add("Cos");
            out2.Add("Tan"); out2.Add("Atan"); out2.Add("Atan2"); out2.Add("Exp");
            out2.Add("Sign"); out2.Add("Truncate"); out2.Add("Clamp");
            out2.Add("PI"); out2.Add("E");
        } else if (typeName == "File") {
            out2.Add("ReadAllText"); out2.Add("WriteAllText"); out2.Add("ReadAllLines");
            out2.Add("WriteAllLines"); out2.Add("AppendAllText"); out2.Add("Exists");
