        if (name == "WriteLine") { return "void WriteLine(object value)"; }
        if (name == "ReadLine") { return "string ReadLine()"; }
        if (name == "Write") { return "void Write(object value)"; }
        if (name == "Add") { return "void Add(T item)"; }
        if (name == "Remove") { return "bool Remove(T item)"; }
        if (name == "RemoveAt") { return "void RemoveAt(int index)"; }
        if (name == "Insert") { return "void Insert(int index, T item)"; }
        if (name == "Count") { return "int Count { get; }"; }
        if (name == "Length") { return "int Length { get; }"; }
        if (name == "Clear") { return "void Clear()"; }
        if (name == "Contains") { return "bool Contains(T item)"; }
        if (name == "IndexOf") { return "int IndexOf(T item)"; }
        if (name == "Substring") { return "string Substring(int start, int len)"; }
        if (name == "Replace") { return "string Replace(string old, string new)"; }
        if (name == "Split") { return "string[] Split(string separator)"; }
        if (name == "Join") { return "string Join(string sep, IEnumerable values)"; }
        if (name == "Trim") { return "string Trim()"; }
        if (name == "ToUpper") { return "string ToUpper()"; }
        if (name == "ToLower") { return "string ToLower()"; }
        if (name == "StartsWith") { return "bool StartsWith(string value)"; }
        if (name == "EndsWith") { return "bool EndsWith(string value)"; }
        if (name == "ToString") { return "string ToString()"; }
        if (name == "Parse") { return "T Parse(string s)"; }
        if (name == "TryParse") { return "bool TryParse(string s, out T result)"; }
        if (name == "Where") { return "IEnumerable<T> Where(Func<T,bool> predicate)"; }
        if (name == "Select") { return "IEnumerable<R> Select(Func<T,R> selector)"; }
        if (name == "OrderBy") { return "IEnumerable<T> OrderBy(Func<T,K> key)"; }
        if (name == "First") { return "T First()"; }
        if (name == "Last") { return "T Last()"; }
        if (name == "Any") { return "bool Any(Func<T,bool> predicate)"; }
        if (name == "All") { return "bool All(Func<T,bool> predicate)"; }
        if (name == "Sum") { return "N Sum()"; }
        if (name == "Max") { return "T Max()"; }
        if (name == "Min") { return "T Min()"; }
        if (name == "Abs") { return "double Abs(double value)"; }
        if (name == "Sqrt") { return "double Sqrt(double value)"; }
        if (name == "ReadAllText") { return "string ReadAllText(string path)"; }
        if (name == "WriteAllText") { return "void WriteAllText(string path, string text)"; }
        if (name == "Format") { return "string Format(string fmt, params object[] args)"; }
        if (name == "ContainsKey") { return "bool ContainsKey(K key)"; }
        if (name == "TryGetValue") { return "bool TryGetValue(K key, out V value)"; }
        if (name == "Append") { return "StringBuilder Append(object value)"; }
        if (name == "AppendLine") { return "StringBuilder AppendLine(object value)"; }
        return "";
    }

    /// Curated one-line documentation for well-known members, else "".
    static string DescDoc(string name) {
        if (name == "WriteLine") { return "Writes the value followed by a line terminator to standard output."; }
        if (name == "ReadLine") { return "Reads the next line of characters from standard input."; }
        if (name == "Write") { return "Writes the value to standard output (no line terminator)."; }
        if (name == "Add") { return "Adds an item to the end of the collection."; }
        if (name == "Remove") { return "Removes the first occurrence of the item; returns whether it was found."; }
        if (name == "RemoveAt") { return "Removes the item at the given zero-based index."; }
        if (name == "Insert") { return "Inserts an item at the given index, shifting later items."; }
        if (name == "Count") { return "Number of elements currently in the collection."; }
        if (name == "Length") { return "Number of characters/elements."; }
        if (name == "Clear") { return "Removes all elements."; }
        if (name == "Contains") { return "Returns whether the item is present."; }
        if (name == "IndexOf") { return "Zero-based index of the first matching item, or -1."; }
        if (name == "Substring") { return "Returns a portion of the string starting at start."; }
        if (name == "Replace") { return "Returns a copy with all occurrences of old replaced by new."; }
        if (name == "Split") { return "Splits the string into an array around the separator."; }
        if (name == "Join") { return "Concatenates values, inserting the separator between them."; }
        if (name == "Trim") { return "Removes leading and trailing whitespace."; }
        if (name == "ToUpper") { return "Returns an uppercase copy of the string."; }
        if (name == "ToLower") { return "Returns a lowercase copy of the string."; }
        if (name == "StartsWith") { return "Returns whether the string begins with the given value."; }
        if (name == "EndsWith") { return "Returns whether the string ends with the given value."; }
        if (name == "ToString") { return "Returns the text representation of this object."; }
        if (name == "Parse") { return "Converts the string to the target type; throws on failure."; }
        if (name == "TryParse") { return "Attempts to convert the string; returns success without throwing."; }
        if (name == "Where") { return "Filters a sequence by a predicate."; }
        if (name == "Select") { return "Projects each element into a new form."; }
        if (name == "OrderBy") { return "Sorts elements in ascending order by a key."; }
        if (name == "First") { return "Returns the first element (throws if empty)."; }
        if (name == "Last") { return "Returns the last element (throws if empty)."; }
        if (name == "Any") { return "Returns whether any element satisfies the predicate."; }
        if (name == "All") { return "Returns whether every element satisfies the predicate."; }
        if (name == "Sum") { return "Computes the sum of the sequence."; }
        if (name == "Max") { return "Returns the maximum value."; }
        if (name == "Min") { return "Returns the minimum value."; }
        if (name == "Abs") { return "Returns the absolute value."; }
        if (name == "Sqrt") { return "Returns the square root."; }
        if (name == "ReadAllText") { return "Opens a file, reads all text, then closes it."; }
        if (name == "WriteAllText") { return "Creates or overwrites a file with the given text."; }
        if (name == "Format") { return "Replaces format items in a string with argument values."; }
        if (name == "ContainsKey") { return "Returns whether the dictionary contains the key."; }
        if (name == "TryGetValue") { return "Gets the value for a key without throwing if absent."; }
        if (name == "Append") { return "Appends the value to this builder."; }
        if (name == "AppendLine") { return "Appends the value followed by a line terminator."; }
        return "";
    }

    /// Word-wraps `s` to fit within `maxW` pixels at `fontSize`, appending the
    /// resulting lines to `outl` (at most `maxLines`).
    static void WrapText(string s, int maxW, int fontSize, List<string> outl, int maxLines) {
        string cur = "";
        string word = "";
        int i = 0;
        while (i <= s.Length) {
            string ch = "";
            if (i < s.Length) { ch = s.Substring(i, 1); }
            if (ch == " " || i == s.Length) {
                string trial = cur;
                if (trial.Length > 0) { trial = trial + " "; }
                trial = trial + word;
                if (Canvas.MeasureText(trial, fontSize) > maxW && cur.Length > 0) {
                    outl.Add(cur);
                    cur = word;
                    if (outl.Count >= maxLines - 1) {
                        // Dump the rest onto the final line and stop.
                        int j = i;
                        while (j < s.Length) { cur = cur + s.Substring(j, 1); j = j + 1; }
                        outl.Add(cur);
                        return;
                    }
                } else {
                    cur = trial;
                }
                word = "";
            } else {
                word = word + ch;
            }
            i = i + 1;
        }
        if (cur.Length > 0) { outl.Add(cur); }
    }

    /// Appends built-in code-snippet triggers (kind "S") to a candidate list.
    static void SnippetListK(List<string> outk, List<string> kinds) {
        outk.Add("for"); kinds.Add("S");
        outk.Add("foreach"); kinds.Add("S");
        outk.Add("while"); kinds.Add("S");
        outk.Add("if"); kinds.Add("S");
        outk.Add("ifelse"); kinds.Add("S");
        outk.Add("class"); kinds.Add("S");
        outk.Add("func"); kinds.Add("S");
        outk.Add("prop"); kinds.Add("S");
        outk.Add("try"); kinds.Add("S");
    }

    /// Expands a code snippet at the current caret, replacing the trigger word
    /// [acStart, curCol). Places the caret at the "$C$" marker in the body.
    void ExpandSnippet(string name) {
        List<string> body = new List<string>();
        if (name == "for") {
            body.Add("for (int i = 0; i < $C$; i = i + 1) {");
            body.Add("    ");
            body.Add("}");
        } else if (name == "foreach") {
            body.Add("foreach (var item in $C$) {");
            body.Add("    ");
            body.Add("}");
        } else if (name == "while") {
            body.Add("while ($C$) {");
            body.Add("    ");
            body.Add("}");
        } else if (name == "if") {
            body.Add("if ($C$) {");
            body.Add("    ");
            body.Add("}");
        } else if (name == "ifelse") {
            body.Add("if ($C$) {");
            body.Add("    ");
            body.Add("} else {");
            body.Add("    ");
            body.Add("}");
        } else if (name == "class") {
            body.Add("class $C$ {");
            body.Add("    ");
            body.Add("}");
        } else if (name == "func") {
            body.Add("void $C$() {");
            body.Add("    ");
            body.Add("}");
        } else if (name == "prop") {
            body.Add("int $C$;");
        } else if (name == "try") {
            body.Add("try {");
            body.Add("    $C$");
            body.Add("} catch (Exception e) {");
            body.Add("    ");
            body.Add("}");
        } else {
            return;
        }

        string curls = lines[curLine];
        string left = Text.Left(curls, acStart);
        string right = Text.Right(curls, curCol);
        // Base indent = leading whitespace of the current line.
        string indent = "";
        int p = 0;
        while (p < left.Length) {
            string ch = left.Substring(p, 1);
            if (ch == " ") { indent = indent + " "; p = p + 1; }
            else { break; }
        }

        int caretLine = curLine;
        int caretCol = acStart;
        List<string> assembled = new List<string>();
        int n = body.Count;
        int bi = 0;
        while (bi < n) {
            string pre = indent;
            if (bi == 0) { pre = left; }
            string lineText = pre + body[bi];
            if (bi == n - 1) { lineText = lineText + right; }
            int mk = CodeEditor.Find(lineText, "$C$");
            if (mk >= 0) {
                caretLine = curLine + bi;
                caretCol = mk;
                lineText = Text.Left(lineText, mk) + Text.Right(lineText, mk + 3);
            }
            assembled.Add(lineText);
            bi = bi + 1;
        }

        lines[curLine] = assembled[0];
        int ins = 1;
        while (ins < assembled.Count) {
            lines.Insert(curLine + ins, assembled[ins]);
            ins = ins + 1;
        }
        curLine = caretLine;
        curCol = caretCol;
        acActive = false;
        acDot = false;
        acFilter = "";
        CheckErrors();
    }

    // ---- breakpoints ----

    /// True when integer list `xs` contains `v`.
    static bool HasInt(List<int> xs, int v) {
        int i = 0;
        while (i < xs.Count) {
            if (xs[i] == v) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when line `line` (0-based) has a breakpoint.
    bool HasBreakpoint(int line) {
        return CodeEditor.HasInt(bps, line);
    }

    /// Toggles a breakpoint on `line`.
    void ToggleBreakpoint(int line) {
        int idx = -1;
        int i = 0;
        while (i < bps.Count) {
            if (bps[i] == line) { idx = i; }
            i = i + 1;
        }
        if (idx >= 0) { bps.RemoveAt(idx); }
        else { bps.Add(line); }
    }

    /// The set of breakpoint line numbers (0-based).
    List<int> Breakpoints() {
        return bps;
    }

    /// Highlights `line` as the currently paused execution line (-1 clears).
    void SetExecLine(int line) {
        execLine = line;
        if (line >= 0) {
            curLine = line;
            if (curLine < scrollLine) { scrollLine = curLine; }
        }
    }

    void HandleInput(App app) {
        int kind = app.window.EventKind();
        if (kind == 6) {
            int code = app.window.EventKeyCode();
            // Ctrl+A = select all (code 1)
            if (code == 1) {
                SelectAll();
                app.RequestRedraw();
                return;
            }
            // Ctrl+C = copy (code 3)
            if (code == 3) {
                CopySelection();
                app.RequestRedraw();
                return;
            }
            // Ctrl+X = cut (code 24)
            if (code == 24) {
                CutSelection();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            // Ctrl+V = paste (code 22)
            if (code == 22) {
                PasteClipboard();
                CheckErrors();
                UpdateCompletion();
                app.RequestRedraw();
                return;
            }
            // Ctrl+Z = undo (code 26)
            if (code == 26) {
                Undo();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            // Ctrl+Y = redo (code 25)
            if (code == 25) {
                Redo();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            // Ctrl+D = duplicate line (code 4)
            if (code == 4) {
                DuplicateLine();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            // Ctrl+L = delete line (code 12)
            if (code == 12) {
                DeleteLine();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            // Ctrl+/ = toggle line comment (code 31)
            if (code == 31) {
                ToggleComment();
                CheckErrors();
                app.RequestRedraw();
                return;
            }
            if (code == 8) {
                if (selActive) { ClearExtraCarets(); DeleteSelection(); }
                else if (mcLines.Count > 0) { McBackspace(); }
                else { SaveUndo(); BackspaceEdit(); }
                CheckErrors();
                UpdateCompletion();
                app.RequestRedraw();
            } else if (code == 13) {
                if (acActive) { AcceptCompletion(false); }
                else {
                    ClearExtraCarets();
                    if (selActive) { DeleteSelection(); }
                    else { SaveUndo(); }
                    NewLine();
                    CheckErrors();
                }
                app.RequestRedraw();
            } else if (code == 9) {
                bool tabShift = Modifiers.HasShift(app.window.EventMods());
                if (acActive) { AcceptCompletion(true); }
                else if (tabShift) {
                    if (selActive && selAnchorLine != curLine) { OutdentSelection(); }
                    else { OutdentCurrentLine(); }
                    CheckErrors();
                }
                else if (selActive && selAnchorLine != curLine) {
                    IndentSelection();
                    CheckErrors();
                }
                else {
                    if (selActive) { ClearExtraCarets(); DeleteSelection(); }
                    if (mcLines.Count > 0) { McInsertStr("    "); }
                    else { InsertStr("    "); }
                }
                app.RequestRedraw();
            } else if (code == 27) {
                acActive = false;
                acFilter = "";
                selActive = false;
                refPopOpen = false;
                ClearExtraCarets();
                ctxOpen = false;
                app.RequestRedraw();
            } else if (code > 31) {
                string ch = Text.CharStr(code);
                if (ch.Length > 0) {
                    if (selActive) { ClearExtraCarets(); DeleteSelection(); }
                    else { SaveUndo(); }
                    if (mcLines.Count > 0) { McInsertStr(ch); }
                    else { InsertStr(ch); }
                    selActive = false;
                    if (ch == ".") {
                        DotCompletion();
                    } else {
                        UpdateCompletion();
                    }
                    // Only re-run diagnostics for characters that can change the
                    // structure of *other* lines (brace/paren balance, statement
                    // termination). Ordinary text on the current line is validated
                    // once the caret leaves the line, avoiding a full-document
                    // rescan on every keystroke.
                    if (ch == "{" || ch == "}" || ch == "(" || ch == ")" || ch == ";") {
                        CheckErrors();
                    }
                    app.RequestRedraw();
                }
            }
        } else if (kind == 4) {
            int kc = app.window.EventKeyCode();
            if (acActive && kc == 38) {
                acSel = acSel - 1;
                if (acSel < 0) { acSel = acItems.Count - 1; }
                app.RequestRedraw();
            } else if (acActive && kc == 40) {
                acSel = acSel + 1;
                if (acSel >= acItems.Count) { acSel = 0; }
                app.RequestRedraw();
            } else if (kc == 27) { acActive = false; acFilter = ""; selActive = false; refPopOpen = false; app.RequestRedraw(); }
            else if (kc == 37) {
                int m37 = app.window.EventMods();
                acActive = false; ClearExtraCarets(); SelPrepare(Modifiers.HasShift(m37));
                if (Modifiers.HasCtrl(m37)) { MoveWordLeft(); } else { MoveLeft(); }
                app.RequestRedraw();
            }
            else if (kc == 39) {
                int m39 = app.window.EventMods();
                acActive = false; ClearExtraCarets(); SelPrepare(Modifiers.HasShift(m39));
                if (Modifiers.HasCtrl(m39)) { MoveWordRight(); } else { MoveRight(); }
                app.RequestRedraw();
            }
            else if (kc == 38) {
                int mods38 = app.window.EventMods();
                if (Modifiers.HasCtrl(mods38) && Modifiers.HasAlt(mods38)) { AddCaretAbove(); }
                else if (Modifiers.HasAlt(mods38)) { ClearExtraCarets(); MoveLineUp(); CheckErrors(); }
                else { ClearExtraCarets(); SelPrepare(Modifiers.HasShift(mods38)); MoveUp(); }
                app.RequestRedraw();
            }
            else if (kc == 40) {
                int mods40 = app.window.EventMods();
                if (Modifiers.HasCtrl(mods40) && Modifiers.HasAlt(mods40)) { AddCaretBelow(); }
                else if (Modifiers.HasAlt(mods40)) { ClearExtraCarets(); MoveLineDown(); CheckErrors(); }
                else { ClearExtraCarets(); SelPrepare(Modifiers.HasShift(mods40)); MoveDown(); }
                app.RequestRedraw();
            }
            else if (kc == 33) {
                int vis = pageRows;
                bool sh = Modifiers.HasShift(app.window.EventMods());
                acActive = false; ClearExtraCarets(); SelPrepare(sh);
                int np = curLine - vis; if (np < 0) { np = 0; }
                curLine = np; ClampCol(); app.RequestRedraw();
            }
            else if (kc == 34) {
                int vis = pageRows;
                bool sh = Modifiers.HasShift(app.window.EventMods());
                acActive = false; ClearExtraCarets(); SelPrepare(sh);
                int np = curLine + vis; if (np > lines.Count - 1) { np = lines.Count - 1; }
                curLine = np; ClampCol(); app.RequestRedraw();
            }
            else if (kc == 36) {
                int m36 = app.window.EventMods();
                acActive = false; ClearExtraCarets(); SelPrepare(Modifiers.HasShift(m36));
                if (Modifiers.HasCtrl(m36)) { curLine = 0; curCol = 0; }
                else { curCol = SmartHomeCol(); }
                app.RequestRedraw();
            }
            else if (kc == 35) {
                int m35 = app.window.EventMods();
                acActive = false; ClearExtraCarets(); SelPrepare(Modifiers.HasShift(m35));
                if (Modifiers.HasCtrl(m35)) { curLine = lines.Count - 1; }
                curCol = lines[curLine].Length;
                app.RequestRedraw();
            }
            else if (kc == 46) {
                if (selActive) { DeleteSelection(); }
                else { SaveUndo(); DeleteEdit(); }
                acActive = false;
                CheckErrors();
                app.RequestRedraw();
            }
        }
    }

    /// Maps a pixel x-offset (relative to the text origin) to a column index by
    /// measuring successive prefixes.
    static int ColFromX(string s, int px, int fontSize) {
        if (px <= 0) { return 0; }
        int i = Text.NextCharEnd(s, 0);
        while (i <= s.Length) {
            int w = Canvas.MeasureText(Text.Left(s, i), fontSize);
            if (w >= px) { return i; }
            if (i >= s.Length) { return s.Length; }
            i = Text.NextCharEnd(s, i);
        }
        return s.Length;
    }

    // ---- syntax highlighting ----

    /// True when the one-character string `ch` occurs in `set`.
    static bool InSet(string chars, string ch) {
        int i = 0;
        while (i < chars.Length) {
            if (chars.Substring(i, 1) == ch) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `hay` contains the substring `needle`.
    static bool ContainsSub(string hay, string needle) {
        int n = hay.Length;
        int m = needle.Length;
        if (m == 0) { return true; }
        int i = 0;
        while (i + m <= n) {
            if (hay.Substring(i, m) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// True when `w` is a Zan/C#-style language keyword.
    static bool IsKeyword(string w) {
        string kws = " using namespace class struct enum interface static void int string bool float double char long short byte uint new return if else while for foreach do in break continue true false null this base public private protected internal override virtual abstract sealed const readonly var switch case default try catch finally throw is as typeof sizeof ref out params get set operator async await yield from where select orderby group join let into ascending descending on equals when and or not with record init required global file scoped allows value partial event delegate fixed lock checked unchecked unsafe stackalloc nameof ";
        return CodeEditor.ContainsSub(kws, " " + w + " ");
    }

    /// Splits `line` into colored segments (parallel outT/outC lists): keywords,
    /// types (Capitalized identifiers), strings, line comments and numbers get
    /// distinct colors; everything else uses the default text color.
    void Highlight(string line, Theme t, List<string> outT, List<int> outC) {
        int kwC = 0xFF569CD6;
        int tyC = 0xFF4EC9B0;
        int strC = 0xFFCE9178;
        int comC = 0xFF6A9955;
        int numC = 0xFFB5CEA8;
        int def = t.textPrimary;
        if (synKw != 0) { kwC = synKw; }
        if (synTy != 0) { tyC = synTy; }
        if (synStr != 0) { strC = synStr; }
        if (synCom != 0) { comC = synCom; }
        if (synNum != 0) { numC = synNum; }
        if (synText != 0) { def = synText; }
        CodeEditor.HighlightSpans(line, kwC, tyC, strC, comC, numC, def, outT, outC);
    }

    /// Static tokenizer used by both the editor and read-only code views (e.g.
    /// the component gallery). Splits `line` into colored segments (parallel
    /// outT/outC lists) using the given palette.
    static void HighlightSpans(string line, int kwC, int tyC, int strC,
            int comC, int numC, int def, List<string> outT, List<int> outC) {
        string lower = "abcdefghijklmnopqrstuvwxyz";
        string upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        string digits = "0123456789";
        string idrest = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int n = line.Length;
        int i = 0;
        string pending = "";
        while (i < n) {
            string ch = line.Substring(i, 1);
            if (ch == "/" && i + 1 < n && line.Substring(i + 1, 1) == "/") {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                outT.Add(line.Substring(i, n - i)); outC.Add(comC);
                i = n;
            } else if (ch == "\"") {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i + 1;
                string s = "\"";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (cj == "\\" && j + 1 < n) {
                        s = s + cj + line.Substring(j + 1, 1);
                        j = j + 2;
                    } else if (cj == "\"") {
                        s = s + cj;
                        j = j + 1;
                        break;
                    } else {
                        s = s + cj;
                        j = j + 1;
                    }
                }
                outT.Add(s); outC.Add(strC);
                i = j;
            } else if (CodeEditor.InSet(digits, ch)) {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i;
                string num = "";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (CodeEditor.InSet(digits, cj) || cj == "." || cj == "x"
                        || CodeEditor.InSet("abcdefABCDEF", cj)) {
                        num = num + cj; j = j + 1;
                    } else { break; }
                }
                outT.Add(num); outC.Add(numC);
                i = j;
            } else if (CodeEditor.InSet(lower + upper + "_", ch)) {
                if (pending.Length > 0) { outT.Add(pending); outC.Add(def); pending = ""; }
                int j = i;
                string w = "";
                while (j < n) {
                    string cj = line.Substring(j, 1);
                    if (CodeEditor.InSet(idrest, cj)) { w = w + cj; j = j + 1; }
                    else { break; }
                }
                int col = def;
                if (CodeEditor.IsKeyword(w)) { col = kwC; }
                else if (CodeEditor.InSet(upper, line.Substring(i, 1))) { col = tyC; }
                outT.Add(w); outC.Add(col);
                i = j;
            } else {
                pending = pending + ch;
                i = i + 1;
            }
        }
        if (pending.Length > 0) { outT.Add(pending); outC.Add(def); }
    }

    static void DrawSelHighlight(Canvas c, App app,
            int aL, int aC, int cL, int cC,
            int ln, string text, int textX, int rowY, int lineH, int fontSize, Rect area) {
        int sL = aL; int sC = aC; int eL = cL; int eC = cC;
        if (sL > eL || (sL == eL && sC > eC)) {
            int tL = sL; sL = eL; eL = tL;
            int tC = sC; sC = eC; eC = tC;
        }
        if (ln < sL || ln > eL) { return; }
        int startC = 0;
        int endC = text.Length;
        if (ln == sL) { startC = sC; }
        if (ln == eL) { endC = eC; }
        if (startC > text.Length) { startC = text.Length; }
        if (endC > text.Length) { endC = text.Length; }
        if (startC >= endC && ln != sL && ln != eL) {
            startC = 0; endC = text.Length;
        }
        if (startC >= endC) { return; }
        int xStart = textX + Canvas.MeasureText(Text.Left(text, startC), fontSize);
        int xEnd = textX + Canvas.MeasureText(Text.Left(text, endC), fontSize);
        c.FillRect(xStart, rowY, xEnd - xStart, lineH, 0x40264F78);
    }

    static string GetErrorMsg(List<int> errLines, List<string> errMsgs, int line) {
        int i = 0;
        while (i < errLines.Count) {
            if (errLines[i] == line && i < errMsgs.Count) {
                return errMsgs[i];
            }
            i = i + 1;
        }
        return "";
    }

    int Render(App app, Rect area) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        lastId = id;
        bool focused = app.focus.IsFocused(id);

        int fontSize = FontSize(t);
        int lineH = Canvas.FontHeight(fontSize) + app.Scale(4);
        if (lineH < 1) { lineH = 1; }
        int gutterW = app.Scale(48);

        c.FillRect(area.x, area.y, area.width, area.height, t.bgPrimary);
        c.FillRect(area.x, area.y, gutterW, area.height, t.bgSecondary);
        c.FillRect(area.x + gutterW, area.y, 1, area.height, t.divider);

        app.CaptureWheel(area.x, area.y, area.width, area.height);

        int visLines = area.height / lineH;
        if (visLines < 1) { visLines = 1; }
        pageRows = visLines;

        if (focused) { HandleInput(app); }
        // Re-validate diagnostics when the caret moves to a different line: the
        // line just left is now complete and checkable, while the active line is
        // deliberately skipped by CheckErrors. This also avoids a full-document
        // rescan on every keystroke within a line.
        if (curLine != lastDiagLine) {
            CheckErrors();
            lastDiagLine = curLine;
        }

        if (app.window.EventKind() == 13) {
            bool over = app.mouseX >= area.x && app.mouseX < area.x + area.width
                        && app.mouseY >= area.y && app.mouseY < area.y + area.height;
            if (over) {
                int delta = app.window.EventKeyCode();
                int step = delta / 120;
                if (step == 0) {
                    if (delta > 0) { step = 1; }
                    else if (delta < 0) { step = 0 - 1; }
                }
                scrollLine = scrollLine - step * 3;
                app.RequestRedraw();
            }
        }

        if (curLine < scrollLine) { scrollLine = curLine; }
        if (curLine >= scrollLine + visLines) { scrollLine = curLine - visLines + 1; }
        int maxScroll = lines.Count - visLines;
        if (maxScroll < 0) { maxScroll = 0; }
        if (scrollLine > maxScroll) { scrollLine = maxScroll; }
        if (scrollLine < 0) { scrollLine = 0; }

        int textX = area.x + gutterW + t.paddingSmall;
        clLine = new List<int>();
        clName = new List<string>();
        clX = new List<int>();
        clY = new List<int>();
        clW = new List<int>();
        int i = 0;
        while (i < visLines) {
            int ln = scrollLine + i;
            if (ln < lines.Count) {
                int rowY = area.y + i * lineH;
                int textY = rowY + (lineH - Canvas.FontHeight(fontSize)) / 2;

                if (ln == execLine) {
                    c.FillRect(area.x + gutterW + 1, rowY, area.width - gutterW - 1, lineH, 0x40FFB020);
                } else if (ln == curLine && focused) {
                    c.FillRect(area.x + gutterW + 1, rowY, area.width - gutterW - 1, lineH, t.bgHover);
                }

                if (HasBreakpoint(ln)) {
                    int dotSz = app.Scale(10);
                    int dotX = area.x + app.Scale(6);
                    int dotY = rowY + (lineH - dotSz) / 2;
                    c.FillRoundRect(dotX, dotY, dotSz, dotSz, dotSz, t.error);
                }
                if (ln == execLine) {
                    int aw = app.Scale(10);
                    int ax = area.x + app.Scale(6);
                    int ay = rowY + (lineH - aw) / 2;
                    c.FillRoundRect(ax, ay, aw, aw, app.Scale(2), 0xFFFFB020);
                }

                string num = Convert.ToString(ln + 1);
                int numW = Canvas.MeasureText(num, fontSize);
                c.DrawText(area.x + gutterW - numW - app.Scale(8), textY, num, t.textTertiary, fontSize);

                string text = lines[ln];

                // Selection highlight
                if (selActive) {
                    CodeEditor.DrawSelHighlight(c, app, selAnchorLine, selAnchorCol,
                        curLine, curCol, ln, text, textX, rowY, lineH, fontSize, area);
                }

                // Error indicator (red underline). Real compiler errors take
                // priority and are drawn a touch bolder than the heuristic ones.
                if (HasCompilerErr(ln)) {
                    c.FillRect(textX, rowY + lineH - app.Scale(2),
                        Canvas.MeasureText(text, fontSize), app.Scale(2), 0xFFFF4444);
                } else if (CodeEditor.HasInt(errorLines, ln)) {
                    c.FillRect(textX, rowY + lineH - app.Scale(2),
                        Canvas.MeasureText(text, fontSize), app.Scale(2), 0xAAFF4444);
                }

                List<string> segT = new List<string>();
                List<int> segC = new List<int>();
                Highlight(text, t, segT, segC);
                int sx = textX;
                int si2 = 0;
                while (si2 < segT.Count) {
                    c.DrawText(sx, textY, segT[si2], segC[si2], fontSize);
                    sx = sx + Canvas.MeasureText(segT[si2], fontSize);
                    si2 = si2 + 1;
                }

                if (ln == curLine && focused) {
                    string upto = Text.Left(text, curCol);
                    int cxp = textX + Canvas.MeasureText(upto, fontSize);
                    c.FillRect(cxp, rowY + app.Scale(2), 1, lineH - app.Scale(4), t.primary);
                }

                // CodeLens: reference count for a method declaration on this line.
                string decl = CodeEditor.DeclNameAt(text);
                if (decl.Length > 0) {
                    int refs = CountWord(decl) - 1;
                    if (refs < 0) { refs = 0; }
                    string clLabel = Convert.ToString(refs) + " references";
                    if (refs == 1) { clLabel = "1 reference"; }
                    int clx = sx + app.Scale(24);
                    int clw = Canvas.MeasureText(clLabel, t.fontSizeSmall);
                    if (clx + clw < area.x + area.width) {
                        c.DrawText(clx, textY, clLabel, 0xFF608B4E, t.fontSizeSmall);
                        clLine.Add(ln); clName.Add(decl);
                        clX.Add(clx); clY.Add(rowY); clW.Add(clw);
                    }
                }

                // Secondary carets (multi-cursor) on this line.
                if (focused && mcLines.Count > 0) {
                    int mci = 0;
                    while (mci < mcLines.Count) {
                        if (mcLines[mci] == ln) {
                            int mcc = mcCols[mci];
                            if (mcc > text.Length) { mcc = text.Length; }
                            int mcx = textX + Canvas.MeasureText(Text.Left(text, mcc), fontSize);
                            c.FillRect(mcx, rowY + app.Scale(2), 1, lineH - app.Scale(4), 0xFF00D0A0);
                        }
                        mci = mci + 1;
                    }
                }

                // Show the error reason for the caret line. Compiler diagnostics
                // win over the heuristic guess when both are present.
                if ((HasCompilerErr(ln) || CodeEditor.HasInt(errorLines, ln)) && ln == curLine) {
                    string errMsg = CompilerErrMsg(ln);
                    if (errMsg.Length == 0) { errMsg = CodeEditor.GetErrorMsg(errorLines, errorMsgs, ln); }
                    if (errMsg.Length > 0) {
                        int ttW = Canvas.MeasureText(errMsg, fontSize) + app.Scale(12);
                        int ttH = lineH;
                        int ttX = textX;
                        int ttY = rowY - ttH - app.Scale(2);
                        if (ttY < area.y) { ttY = rowY + lineH; }
                        c.FillRoundRect(ttX, ttY, ttW, ttH, app.Scale(3), 0xFF5A1D1D);
                        c.DrawRect(ttX, ttY, ttW, ttH, 0xFFFF4444, 1);
                        c.DrawText(ttX + app.Scale(6), ttY + app.Scale(3), errMsg, 0xFFFF8888, fontSize);
                    }
                }
            }
            i = i + 1;
        }

        // ---- right-edge diagnostics / scroll strip (VS-style overview ruler) ----
        // Shows a viewport thumb plus a red tick for every diagnostic line so the
        // user can jump straight to problem areas; clicking the strip scrolls there.
        {
            int stripW = app.Scale(14);
            int stripX = area.x + area.width - stripW;
            c.FillRect(stripX, area.y, stripW, area.height, 0xFF2A2A2E);
            c.FillRect(stripX, area.y, app.Scale(1), area.height, 0xFF3E3E42);
            int total = lines.Count;
            if (total < 1) { total = 1; }
            int thumbY = area.y + scrollLine * area.height / total;
            int thumbH = visLines * area.height / total;
            if (thumbH < app.Scale(24)) { thumbH = app.Scale(24); }
            if (thumbY + thumbH > area.y + area.height) { thumbY = area.y + area.height - thumbH; }
            if (thumbY < area.y) { thumbY = area.y; }
            c.FillRoundRect(stripX + app.Scale(3), thumbY, stripW - app.Scale(6), thumbH, app.Scale(3), 0x50FFFFFF);
            int mi = 0;
            while (mi < errorLines.Count) {
                int el = errorLines[mi];
                if (el >= 0 && el < lines.Count) {
                    int my = area.y + el * area.height / total;
                    c.FillRect(stripX + app.Scale(2), my, stripW - app.Scale(4), app.Scale(3), 0xFFFF4444);
                }
                mi = mi + 1;
            }
            if (!CompilerDiagStale()) {
                int ci2 = 0;
                while (ci2 < cErrLines.Count) {
                    int el2 = cErrLines[ci2];
                    if (el2 >= 0 && el2 < lines.Count) {
                        int my2 = area.y + el2 * area.height / total;
                        c.FillRect(stripX + app.Scale(2), my2, stripW - app.Scale(4), app.Scale(3), 0xFFFF4444);
                    }
                    ci2 = ci2 + 1;
                }
            }
        }

        // ---- autocomplete popup (drawn below the cursor, with icons) ----
        if (acActive && focused && acAllItems.Count > 0
            && curLine >= scrollLine && curLine < scrollLine + visLines) {
            int prow = curLine - scrollLine;
            int pRowY = area.y + prow * lineH;
            int px = textX + Canvas.MeasureText(Text.Left(lines[curLine], acStart), fontSize);
            int maxShow = 10;
            int shown = acItems.Count;
            if (shown > maxShow) { shown = maxShow; }
            int itemH2 = lineH + app.Scale(2);
            int popH2 = shown * itemH2 + app.Scale(4);
            if (shown == 0) { popH2 = itemH2 + app.Scale(4); }
            int iconW = app.Scale(22);
            int popW2 = app.Scale(220);
            int k = 0;
            while (k < acItems.Count) {
                int wpx = Canvas.MeasureText(acItems[k], fontSize) + iconW + app.Scale(16);
                if (wpx > popW2) { popW2 = wpx; }
                k = k + 1;
            }
            if (popW2 > app.Scale(400)) { popW2 = app.Scale(400); }
            int popY2 = pRowY + lineH;
            // Ensure popup stays within the visible area
            if (popY2 + popH2 > area.y + area.height) { popY2 = pRowY - popH2; }
            if (px + popW2 > area.x + area.width) { px = area.x + area.width - popW2 - 4; }
            int first2 = 0;
            if (acSel >= maxShow) { first2 = acSel - maxShow + 1; }
            // Save popup geometry for click detection
            popX = px; popY = popY2; popW = popW2; popH = popH2;
            popItemH = itemH2; popFirst = first2; popShown = shown;
            // Draw shadow
            c.FillRoundRect(px + 2, popY2 + 2, popW2, popH2, app.Scale(4), 0x40000000);
            // Draw popup background
            c.FillRoundRect(px, popY2, popW2, popH2, app.Scale(4), 0xFF252526);
            c.DrawRect(px, popY2, popW2, popH2, 0xFF3E3E42, 1);
            int r2 = 0;
            while (r2 < shown) {
                int idx = first2 + r2;
                if (idx < acItems.Count) {
                    int iy = popY2 + app.Scale(2) + r2 * itemH2;
                    int tcol = 0xFFD4D4D4;
                    if (idx == acSel) {
                        c.FillRect(px + 2, iy, popW2 - 4, itemH2, 0xFF094771);
                        tcol = 0xFFFFFFFF;
                    }
                    int ity = iy + (itemH2 - Canvas.FontHeight(fontSize)) / 2;
                    // Draw kind icon/indicator
                    string kind2 = "";
                    if (idx < acKinds.Count) { kind2 = acKinds[idx]; }
                    int iconColor = 0xFF569CD6;
                    string iconLetter = "?";
                    if (kind2 == "M") { iconColor = 0xFF9B6DCA; iconLetter = "M"; }
                    else if (kind2 == "P") { iconColor = 0xFF569CD6; iconLetter = "P"; }
                    else if (kind2 == "T") { iconColor = 0xFF4EC9B0; iconLetter = "T"; }
                    else if (kind2 == "K") { iconColor = 0xFF569CD6; iconLetter = "K"; }
                    else if (kind2 == "S") { iconColor = 0xFFDCDCAA; iconLetter = "S"; }
                    else if (kind2 == "F") { iconColor = 0xFF9CDCFE; iconLetter = "F"; }
                    else if (kind2 == "E") { iconColor = 0xFFB8D7A3; iconLetter = "E"; }
                    else { iconColor = 0xFFCCCCCC; iconLetter = "W"; }
                    c.FillRoundRect(px + app.Scale(3), ity, app.Scale(16), app.Scale(16), app.Scale(3), iconColor);
                    c.DrawText(px + app.Scale(6), ity + app.Scale(1), iconLetter, 0xFF1E1E1E, t.fontSizeSmall);
                    c.DrawText(px + iconW, ity, acItems[idx], tcol, fontSize);
                }
                r2 = r2 + 1;
            }
            // Scrollbar hint if there are more items
            if (acItems.Count > maxShow) {
                int sbH = popH2 * shown / acItems.Count;
                if (sbH < app.Scale(10)) { sbH = app.Scale(10); }
                int sbY = popY2 + (popH2 - sbH) * first2 / (acItems.Count - shown);
                c.FillRoundRect(px + popW2 - app.Scale(6), sbY, app.Scale(4), sbH, app.Scale(2), 0xFF555555);
            }

            // Placeholder text when the active filter hides every item.
            if (acItems.Count == 0) {
                int hy = popY2 + (itemH2 - Canvas.FontHeight(fontSize)) / 2 + app.Scale(2);
                c.DrawText(px + app.Scale(8), hy, "no " + CodeEditor.KindWord(acFilter) + " here", 0xFF808080, fontSize);
            }

            // ---- kind filter strip (click to show only one kind) ----
            List<string> fkinds = new List<string>();
            fkinds.Add(""); fkinds.Add("M"); fkinds.Add("P"); fkinds.Add("F");
            fkinds.Add("E"); fkinds.Add("T"); fkinds.Add("K"); fkinds.Add("S");
            int fbH = app.Scale(22);
            int fbY = popY2 + popH2;
            filtX = px; filtY = fbY; filtW = popW2; filtH = fbH;
            c.FillRect(px, fbY, popW2, fbH, 0xFF2D2D30);
            c.DrawRect(px, fbY, popW2, fbH, 0xFF3E3E42, 1);
            int isz = app.Scale(16);
            int fgap = app.Scale(4);
            int fbx = px + app.Scale(5);
            int fiy = fbY + (fbH - isz) / 2;
            int fki = 0;
            while (fki < fkinds.Count) {
                string fk = fkinds[fki];
                bool present = fk == "" || HasKind(fk);
                bool seld = acFilter == fk;
                string flet = "*";
                int fcol = 0xFFCCCCCC;
                if (fk == "M") { fcol = 0xFF9B6DCA; flet = "M"; }
                else if (fk == "P") { fcol = 0xFF569CD6; flet = "P"; }
                else if (fk == "F") { fcol = 0xFF9CDCFE; flet = "F"; }
                else if (fk == "E") { fcol = 0xFFB8D7A3; flet = "E"; }
                else if (fk == "T") { fcol = 0xFF4EC9B0; flet = "T"; }
                else if (fk == "K") { fcol = 0xFF569CD6; flet = "K"; }
                else if (fk == "S") { fcol = 0xFFDCDCAA; flet = "S"; }
                if (!present) { fcol = 0xFF4A4A4A; }
                if (seld) {
                    c.FillRoundRect(fbx - app.Scale(2), fiy - app.Scale(2), isz + app.Scale(4), isz + app.Scale(4), app.Scale(3), 0xFF094771);
                }
                c.FillRoundRect(fbx, fiy, isz, isz, app.Scale(3), fcol);
                int tc = 0xFF1E1E1E;
                if (!present) { tc = 0xFF6A6A6A; }
                c.DrawText(fbx + app.Scale(4), fiy + app.Scale(1), flet, tc, t.fontSizeSmall);
                fbx = fbx + isz + fgap;
                fki = fki + 1;
            }

            // ---- description panel for the highlighted item ----
            if (acSel >= 0 && acSel < acItems.Count) {
                string dName = acItems[acSel];
                string dKind = "";
                if (acSel < acKinds.Count) { dKind = acKinds[acSel]; }
                string dSig = RealSigFor(dName);
                if (dSig.Length == 0) { dSig = CodeEditor.DescSig(dName); }
                string dDoc = CodeEditor.DescDoc(dName);
                string sigLine = dSig;
                if (sigLine.Length == 0) { sigLine = dName; }
                string kindLine = "(" + CodeEditor.KindWord(dKind) + ")";
                if (dDoc.Length == 0 && dKind == "S") {
                    dDoc = "Press Tab to insert the '" + dName + "' code template.";
                }

                int dw = app.Scale(280);
                int dpad = app.Scale(8);
                int fh = Canvas.FontHeight(fontSize);
                List<string> wrapped = new List<string>();
                if (dDoc.Length > 0) {
                    CodeEditor.WrapText(dDoc, dw - dpad * 2, t.fontSizeSmall, wrapped, 6);
                }
                int dh = dpad * 2 + fh + app.Scale(4) + fh;
                if (wrapped.Count > 0) {
                    dh = dh + app.Scale(6) + wrapped.Count * (Canvas.FontHeight(t.fontSizeSmall) + app.Scale(2));
                }
                // Prefer right of the popup; fall back to the left.
                int dx = px + popW2 + app.Scale(6);
                if (dx + dw > area.x + area.width) { dx = px - dw - app.Scale(6); }
                if (dx < area.x) { dx = area.x + app.Scale(2); }
                int dy = popY2;
                if (dy + dh > area.y + area.height) { dy = area.y + area.height - dh; }
                if (dy < area.y) { dy = area.y; }

                c.FillRoundRect(dx + 2, dy + 2, dw, dh, app.Scale(4), 0x40000000);
                c.FillRoundRect(dx, dy, dw, dh, app.Scale(4), 0xFF2D2D30);
                c.DrawRect(dx, dy, dw, dh, 0xFF3E3E42, 1);
                int ty = dy + dpad;
                c.DrawText(dx + dpad, ty, sigLine, 0xFF9CDCFE, fontSize);
                ty = ty + fh + app.Scale(4);
                c.DrawText(dx + dpad, ty, kindLine, 0xFF808080, t.fontSizeSmall);
                ty = ty + Canvas.FontHeight(t.fontSizeSmall) + app.Scale(6);
                int wl = 0;
                while (wl < wrapped.Count) {
                    c.DrawText(dx + dpad, ty, wrapped[wl], 0xFFCCCCCC, t.fontSizeSmall);
                    ty = ty + Canvas.FontHeight(t.fontSizeSmall) + app.Scale(2);
                    wl = wl + 1;
                }
            }
        }

        // ---- right-click context menu ----
        // Open on right mouse button (button 1) pressed inside the text area.
        if (app.window.EventKind() == 2 && app.window.EventButton() == 1) {
            bool overArea = app.mouseX >= area.x + gutterW && app.mouseX < area.x + area.width
                            && app.mouseY >= area.y && app.mouseY < area.y + area.height;
            if (overArea) {
                if (!selActive) {
                    int rrel = app.mouseY - area.y;
                    int rclk = scrollLine + rrel / lineH;
                    if (rclk >= lines.Count) { rclk = lines.Count - 1; }
                    if (rclk < 0) { rclk = 0; }
                    curLine = rclk;
                    curCol = CodeEditor.ColFromX(lines[curLine], app.mouseX - textX, fontSize);
                }
                ctxOpen = true;
                ctxX = app.mouseX;
                ctxY = app.mouseY;
                acActive = false;
                app.RequestRedraw();
            }
        }

        app.hitTester.Register(HitRegion.Create(id, area.x, area.y, area.width, area.height, 1));

        // ---- left button pressed: place caret / begin drag-select ----
        // Skip when the click lands on the autocomplete popup (handled on up).
        bool overPopup = acActive && popShown > 0
            && app.mouseX >= popX && app.mouseX < popX + popW
            && app.mouseY >= popY && app.mouseY < popY + popH;
        bool overFilter = acActive && filtW > 0
            && app.mouseX >= filtX && app.mouseX < filtX + filtW
            && app.mouseY >= filtY && app.mouseY < filtY + filtH;
        bool overCodeLens = false;
        int cli = 0;
        while (cli < clLine.Count) {
            if (app.mouseX >= clX[cli] && app.mouseX < clX[cli] + clW[cli]
                && app.mouseY >= clY[cli] && app.mouseY < clY[cli] + lineH) {
                overCodeLens = true;
            }
            cli = cli + 1;
        }
        // Reference-list popup: click an entry to jump, click outside to dismiss.
        if (refPopOpen && app.window.EventKind() == 2 && app.window.EventButton() == 0) {
            bool insidePop = app.mouseX >= refPopGX && app.mouseX < refPopGX + refPopGW
                && app.mouseY >= refPopGY && app.mouseY < refPopGY + refPopGH;
            if (insidePop) {
                int relRow = (app.mouseY - refPopGY - refPopHeadH) / refPopRowH;
                if (relRow >= 0 && relRow < refPopShown && relRow < refPopLines.Count) {
                    JumpToRefLine(refPopName, refPopLines[relRow]);
                    refPopOpen = false;
                }
                app.RequestRedraw();
                return id;
            }
            refPopOpen = false;
            app.RequestRedraw();
        }

        // Click on the diagnostics/scroll strip (right edge): jump to that line.
        int diagStripW = app.Scale(14);
        int diagStripX = area.x + area.width - diagStripW;
        if (app.window.EventKind() == 2 && app.window.EventButton() == 0
            && !ctxOpen && !overPopup && !overFilter && !overCodeLens
            && app.mouseX >= diagStripX && app.mouseX < area.x + area.width
            && app.mouseY >= area.y && app.mouseY < area.y + area.height) {
            int dtotal = lines.Count;
            if (dtotal < 1) { dtotal = 1; }
            int dtgt = (app.mouseY - area.y) * dtotal / area.height;
            if (dtgt < 0) { dtgt = 0; }
            if (dtgt >= lines.Count) { dtgt = lines.Count - 1; }
            curLine = dtgt;
            if (curCol > lines[curLine].Length) { curCol = lines[curLine].Length; }
            selActive = false;
            ClearExtraCarets();
            scrollLine = dtgt - visLines / 2;
            if (scrollLine < 0) { scrollLine = 0; }
            app.RequestRedraw();
            return id;
        }
        if (app.window.EventKind() == 2 && app.window.EventButton() == 0
            && !ctxOpen && !overPopup && !overFilter && !overCodeLens) {
            bool overText = app.mouseX >= area.x + gutterW && app.mouseX < diagStripX
                            && app.mouseY >= area.y && app.mouseY < area.y + area.height;
            if (overText) {
                bool sh = Modifiers.HasShift(app.window.EventMods());
                bool ct = Modifiers.HasCtrl(app.window.EventMods());
                if (ct) {
                    // Ctrl+click: place caret and ask the host for Go to Definition.
                    CaretFromMouse(app, area, gutterW, fontSize);
                    selActive = false;
                    ClearExtraCarets();
                    gotoRequested = true;
                } else if (sh) {
                    if (!selActive) {
                        selAnchorLine = curLine; selAnchorCol = curCol; selActive = true;
                    }
                    CaretFromMouse(app, area, gutterW, fontSize);
                } else {
                    CaretFromMouse(app, area, gutterW, fontSize);
                    bool near = curLine == lastClickLine
                        && curCol >= lastClickCol - 1 && curCol <= lastClickCol + 1;
                    if (app.nowMs - lastClickMs <= 400 && near) {
                        clickCount = clickCount + 1;
                    } else {
                        clickCount = 1;
                    }
                    lastClickMs = app.nowMs;
                    lastClickLine = curLine;
                    lastClickCol = curCol;
                    if (clickCount == 2) {
                        SelectWordCaret();
                        mouseSelecting = false;
                    } else if (clickCount >= 3) {
                        SelectLineCaret();
                        mouseSelecting = false;
                        clickCount = 0;
                    } else {
                        selAnchorLine = curLine; selAnchorCol = curCol;
                        selActive = false;
                        ClearExtraCarets();
                        mouseSelecting = true;
                    }
                }
                acActive = false;
                app.RequestRedraw();
            }
        }

        // ---- dragging: extend the selection to the pointer ----
        if (app.window.EventKind() == 1 && mouseSelecting) {
            CaretFromMouse(app, area, gutterW, fontSize);
            if (curLine != selAnchorLine || curCol != selAnchorCol) { selActive = true; }
            else { selActive = false; }
            app.RequestRedraw();
        }

        // ---- hover: redraw so the symbol tooltip tracks the pointer ----
        if (app.window.EventKind() == 1 && !mouseSelecting && !acActive) {
            if (app.mouseX >= area.x && app.mouseX < area.x + area.width
                && app.mouseY >= area.y && app.mouseY < area.y + area.height) {
                app.RequestRedraw();
            }
        }

        if (app.window.EventKind() == 3 && app.window.EventButton() == 0 && !ctxOpen) {
            mouseSelecting = false;
            // CodeLens click: open an expandable list of all references.
            bool clHit = false;
            int clc = 0;
            while (clc < clLine.Count) {
                if (app.mouseX >= clX[clc] && app.mouseX < clX[clc] + clW[clc]
                    && app.mouseY >= clY[clc] && app.mouseY < clY[clc] + lineH) {
                    refPopLines = new List<int>();
                    CollectRefs(clName[clc], clLine[clc], refPopLines);
                    refPopName = clName[clc];
                    refPopSel = 0;
                    refPopX = clX[clc];
                    refPopY = clY[clc] + lineH;
                    refPopOpen = refPopLines.Count > 0;
                    if (!refPopOpen) { JumpToNextRef(clName[clc], clLine[clc]); }
                    clHit = true;
                    app.RequestRedraw();
                }
                clc = clc + 1;
            }
            if (clHit) {
                // handled
            }
            // Kind filter strip click: toggle the selected kind.
            else if (acActive && filtW > 0
                && app.mouseX >= filtX && app.mouseX < filtX + filtW
                && app.mouseY >= filtY && app.mouseY < filtY + filtH) {
                List<string> fk2 = new List<string>();
                fk2.Add(""); fk2.Add("M"); fk2.Add("P"); fk2.Add("F");
                fk2.Add("E"); fk2.Add("T"); fk2.Add("K"); fk2.Add("S");
                int step = app.Scale(16) + app.Scale(4);
                int fidx = (app.mouseX - (filtX + app.Scale(5))) / step;
                if (fidx >= 0 && fidx < fk2.Count) {
                    string chosenF = fk2[fidx];
                    if (chosenF == "" || HasKind(chosenF)) {
                        if (acFilter == chosenF) { acFilter = ""; }
                        else { acFilter = chosenF; }
                        acSel = 0;
                        ApplyKindFilter();
                    }
                }
                app.RequestRedraw();
            }
            // Check autocomplete popup click
            else if (acActive && popShown > 0
                && app.mouseX >= popX && app.mouseX < popX + popW
                && app.mouseY >= popY && app.mouseY < popY + popH) {
                int relY = app.mouseY - popY - app.Scale(2);
                int clickedRow = relY / popItemH;
                if (clickedRow >= 0 && clickedRow < popShown) {
                    int clickedIdx = popFirst + clickedRow;
                    if (clickedIdx >= 0 && clickedIdx < acItems.Count) {
                        acSel = clickedIdx;
                        AcceptCompletion(false);
                    }
                }
                app.RequestRedraw();
            } else {
                int hit = app.hitTester.HitTest(app.mouseX, app.mouseY);
                if (hit == id && app.mouseX < area.x + gutterW) {
                    int rel = app.mouseY - area.y;
                    int clicked = scrollLine + rel / lineH;
                    if (clicked >= lines.Count) { clicked = lines.Count - 1; }
                    if (clicked < 0) { clicked = 0; }
                    ToggleBreakpoint(clicked);
                    app.RequestRedraw();
                }
            }
        }

        // ---- Debug hover tooltip ----
        if (execLine >= 0 && dbgVars.Count > 0) {
            // Detect word under mouse cursor
            if (app.mouseX >= textX && app.mouseX < area.x + area.width
                && app.mouseY >= area.y && app.mouseY < area.y + area.height) {
                int hoverLine = scrollLine + (app.mouseY - area.y) / lineH;
                if (hoverLine >= 0 && hoverLine < lines.Count) {
                    int hoverCol = CodeEditor.ColFromX(lines[hoverLine], app.mouseX - textX, fontSize);
                    string hWord = CodeEditor.WordAt(lines[hoverLine], hoverCol);
                    if (hWord.Length > 0) {
                        string raw = CodeEditor.LookupVarRaw(dbgVars, hWord);
                        if (raw.Length > 0) {
                            hoverTip = raw;
                            hoverTipX = app.mouseX;
                            hoverTipY = app.mouseY;
                        } else {
                            hoverTip = "";
                        }
                    } else {
                        hoverTip = "";
                    }
                }
            }
            // Draw the (possibly multi-line, JSON-formatted) tooltip.
            if (hoverTip.Length > 0) {
                List<string> hl = new List<string>();
                CodeEditor.BuildHoverLines(hoverTip, hl);
                int rowh = Canvas.FontHeight(fontSize) + app.Scale(2);
                int maxw = 0;
                int k = 0;
                while (k < hl.Count) {
                    int mw = Canvas.MeasureText(hl[k], fontSize);
                    if (mw > maxw) { maxw = mw; }
                    k = k + 1;
                }
                int ttW2 = maxw + app.Scale(16);
                int capW = area.width - app.Scale(8);
                if (ttW2 > capW) { ttW2 = capW; }
                int ttH2 = rowh * hl.Count + app.Scale(8);
                int ttX2 = hoverTipX + app.Scale(8);
                int ttY2 = hoverTipY + app.Scale(20);
                if (ttX2 + ttW2 > area.x + area.width) { ttX2 = area.x + area.width - ttW2 - app.Scale(4); }
                if (ttX2 < area.x) { ttX2 = area.x; }
                if (ttY2 + ttH2 > area.y + area.height) { ttY2 = hoverTipY - ttH2 - app.Scale(6); }
                if (ttY2 < area.y) { ttY2 = area.y; }
                c.FillRoundRect(ttX2 - 1, ttY2 - 1, ttW2 + 2, ttH2 + 2, app.Scale(4), 0x80000000);
                c.FillRoundRect(ttX2, ttY2, ttW2, ttH2, app.Scale(4), 0xFF1E1E1E);
                c.DrawRect(ttX2, ttY2, ttW2, ttH2, 0xFF569CD6, 1);
                int ty = ttY2 + app.Scale(4);
                int kk = 0;
                while (kk < hl.Count) {
                    int col = 0xFFCE9178;
                    if (kk == 0) { col = 0xFF9CDCFE; }
                    c.DrawText(ttX2 + app.Scale(8), ty, hl[kk], col, fontSize);
                    ty = ty + rowh;
                    kk = kk + 1;
                }
            }
        }

        // ---- Ctrl+hover: underline the identifier as a clickable link ----
        if (!acActive && !ctxOpen && Modifiers.HasCtrl(app.window.EventMods())) {
            int utextX = area.x + gutterW + t.paddingSmall;
            if (app.mouseX >= utextX && app.mouseX < area.x + area.width
                && app.mouseY >= area.y && app.mouseY < area.y + area.height) {
                int urel = app.mouseY - area.y;
                int uln = scrollLine + urel / lineH;
                if (uln >= 0 && uln < lines.Count) {
                    string uls = lines[uln];
                    int ucol = CodeEditor.ColFromX(uls, app.mouseX - utextX, fontSize);
                    string uidset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
                    if (ucol >= 0 && ucol <= uls.Length) {
                        int ua = ucol;
                        while (ua > 0 && CodeEditor.InSet(uidset, uls.Substring(ua - 1, 1))) { ua = ua - 1; }
                        int ub = ucol;
                        while (ub < uls.Length && CodeEditor.InSet(uidset, uls.Substring(ub, 1))) { ub = ub + 1; }
                        if (ub > ua) {
                            int uxp = utextX + Canvas.MeasureText(uls.Substring(0, ua), fontSize);
                            int uwp = Canvas.MeasureText(uls.Substring(ua, ub - ua), fontSize);
                            int uyp = area.y + (uln - scrollLine) * lineH
                                + (lineH + Canvas.FontHeight(fontSize)) / 2 + app.Scale(1);
                            c.FillRect(uxp, uyp, uwp, app.Scale(1), 0xFF4EA1D3);
                        }
                    }
                }
            }
        }

        // ---- symbol hover tooltip (method/property signature + docs) ----
        if (!acActive && !ctxOpen && execLine < 0) {
            string hw = WordAtMouse(app, area, gutterW, fontSize);
            if (hw.Length > 0) {
                string hsig = RealSigFor(hw);
                if (hsig.Length == 0) { hsig = CodeEditor.DescSig(hw); }
                string hdoc = CodeEditor.DescDoc(hw);
                if (hsig.Length > 0) {
                    int hpad = app.Scale(8);
                    int hfh = Canvas.FontHeight(fontSize);
                    int sfh = Canvas.FontHeight(t.fontSizeSmall);
                    // Fixed inner text width; wrap BOTH signature and docs to it so no
                    // content can spill past the box, then shrink the box to the widest
                    // line actually produced (never wider than the cap).
                    int innerW = app.Scale(300);
                    List<string> siglines = new List<string>();
                    CodeEditor.WrapText(hsig, innerW, fontSize, siglines, 4);
                    List<string> hlines = new List<string>();
                    if (hdoc.Length > 0) {
                        CodeEditor.WrapText(hdoc, innerW, t.fontSizeSmall, hlines, 6);
                    }
                    int widest = 0;
                    int wi = 0;
                    while (wi < siglines.Count) {
                        int lw = Canvas.MeasureText(siglines[wi], fontSize);
                        if (lw > widest) { widest = lw; }
                        wi = wi + 1;
                    }
                    wi = 0;
                    while (wi < hlines.Count) {
                        int lw = Canvas.MeasureText(hlines[wi], t.fontSizeSmall);
                        if (lw > widest) { widest = lw; }
                        wi = wi + 1;
                    }
                    if (widest > innerW) { widest = innerW; }
                    int hw2 = widest + hpad * 2;
                    if (hw2 < app.Scale(120)) { hw2 = app.Scale(120); }
                    int hh = hpad * 2 + siglines.Count * hfh;
                    if (hlines.Count > 0) {
                        hh = hh + app.Scale(4) + hlines.Count * (sfh + app.Scale(2));
                    }
                    int hx = app.mouseX + app.Scale(12);
                    int hy = app.mouseY + app.Scale(18);
                    if (hx + hw2 > area.x + area.width) { hx = area.x + area.width - hw2 - app.Scale(4); }
                    if (hx < area.x) { hx = area.x + app.Scale(2); }
                    if (hy + hh > area.y + area.height) { hy = app.mouseY - hh - app.Scale(6); }
                    if (hy < area.y) { hy = area.y + app.Scale(2); }
                    c.FillRoundRect(hx + 2, hy + 2, hw2, hh, app.Scale(4), 0x50000000);
                    c.FillRoundRect(hx, hy, hw2, hh, app.Scale(4), 0xFF252526);
                    c.DrawRect(hx, hy, hw2, hh, 0xFF569CD6, 1);
                    int hty = hy + hpad;
                    int sl = 0;
                    while (sl < siglines.Count) {
                        c.DrawText(hx + hpad, hty, siglines[sl], 0xFF9CDCFE, fontSize);
                        hty = hty + hfh;
                        sl = sl + 1;
                    }
                    hty = hty + app.Scale(4);
                    int hl = 0;
                    while (hl < hlines.Count) {
                        c.DrawText(hx + hpad, hty, hlines[hl], 0xFFCCCCCC, t.fontSizeSmall);
                        hty = hty + sfh + app.Scale(2);
                        hl = hl + 1;
                    }
                }
            }
        }

        // ---- expandable reference list popup (from a CodeLens click) ----
        if (refPopOpen && refPopLines.Count > 0) {
            int rpMax = 10;
            int rpShown = refPopLines.Count;
            if (rpShown > rpMax) { rpShown = rpMax; }
            int rpRowH = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(6);
            int rpHeadH = rpRowH;
            int rpW = app.Scale(440);
            if (rpW > area.width - app.Scale(20)) { rpW = area.width - app.Scale(20); }
            int rpH = rpHeadH + rpShown * rpRowH + app.Scale(6);
            int rpX = refPopX;
            int rpY = refPopY;
            if (rpX + rpW > area.x + area.width) { rpX = area.x + area.width - rpW - app.Scale(6); }
            if (rpX < area.x) { rpX = area.x + app.Scale(2); }
            if (rpY + rpH > area.y + area.height) { rpY = area.y + area.height - rpH - app.Scale(4); }
            if (rpY < area.y) { rpY = area.y + app.Scale(2); }
            refPopGX = rpX; refPopGY = rpY; refPopGW = rpW; refPopGH = rpH;
            refPopRowH = rpRowH; refPopHeadH = rpHeadH; refPopShown = rpShown;
            c.FillRoundRect(rpX + 2, rpY + 2, rpW, rpH, app.Scale(4), 0x60000000);
            c.FillRoundRect(rpX, rpY, rpW, rpH, app.Scale(4), 0xFF252526);
            c.DrawRect(rpX, rpY, rpW, rpH, 0xFF569CD6, 1);
            // Header: "N references to <name>"
            string rpHead = Convert.ToString(refPopLines.Count) + " references to " + refPopName;
            c.FillRect(rpX + 1, rpY + 1, rpW - 2, rpHeadH, 0xFF2D2D30);
            c.DrawText(rpX + app.Scale(8), rpY + app.Scale(4), rpHead, 0xFF9CDCFE, t.fontSizeSmall);
            int rri = 0;
            while (rri < rpShown) {
                int rl = refPopLines[rri];
                int ry = rpY + rpHeadH + rri * rpRowH;
                bool rhover = app.mouseX >= rpX && app.mouseX < rpX + rpW
                    && app.mouseY >= ry && app.mouseY < ry + rpRowH;
                if (rhover) { c.FillRect(rpX + 1, ry, rpW - 2, rpRowH, 0xFF094771); }
                string rnum = Convert.ToString(rl + 1);
                c.DrawText(rpX + app.Scale(8), ry + app.Scale(3), rnum, 0xFF858585, t.fontSizeSmall);
                string rcode = CodeEditor.TrimStr(lines[rl]);
                if (rcode.Length > 64) { rcode = rcode.Substring(0, 64) + "..."; }
                c.DrawText(rpX + app.Scale(48), ry + app.Scale(3), rcode, 0xFFCCCCCC, t.fontSizeSmall);
                rri = rri + 1;
            }
            if (refPopLines.Count > rpShown) {
                int mory = rpY + rpHeadH + rpShown * rpRowH;
                c.DrawText(rpX + app.Scale(8), mory - rpRowH + app.Scale(3),
                    "... +" + Convert.ToString(refPopLines.Count - rpShown) + " more", 0xFF858585, t.fontSizeSmall);
            }
        }

        return id;
    }

    static string WordAt(string line, int col) {
        if (col < 0 || col >= line.Length) { return ""; }
        // Find word boundaries
        int start = col;
        while (start > 0) {
            string ch = line.Substring(start - 1, 1);
            if (CodeEditor.IsIdentChar(ch)) { start = start - 1; }
            else { break; }
        }
        int end = col;
        while (end < line.Length) {
            string ch = line.Substring(end, 1);
            if (CodeEditor.IsIdentChar(ch)) { end = end + 1; }
            else { break; }
        }
        if (start == end) { return ""; }
        return line.Substring(start, end - start);
    }

    static bool IsIdentChar(string ch) {
        if (ch == "_") { return true; }
        int c = ch.Substring(0, 1).Length;
        if (c == 0) { return false; }
        string fc = ch.Substring(0, 1);
        if (fc >= "a" && fc <= "z") { return true; }
        if (fc >= "A" && fc <= "Z") { return true; }
        if (fc >= "0" && fc <= "9") { return true; }
        return false;
    }

    static string LookupVar(List<string> vars, string name) {
        int i = 0;
        while (i < vars.Count) {
            string entry = vars[i];
            // entry is "name\ttype\tvalue"
            int tab1 = -1;
            int tab2 = -1;
            int j = 0;
            while (j < entry.Length) {
                string ch = entry.Substring(j, 1);
                if (ch == "\t") {
                    if (tab1 < 0) { tab1 = j; }
                    else if (tab2 < 0) { tab2 = j; }
                }
                j = j + 1;
            }
            if (tab1 > 0) {
                string vName = entry.Substring(0, tab1);
                if (vName == name) {
                    string vType = "";
                    string vVal = "";
                    if (tab2 > tab1) {
                        vType = entry.Substring(tab1 + 1, tab2 - tab1 - 1);
                        vVal = entry.Substring(tab2 + 1, entry.Length - tab2 - 1);
                    } else {
                        vType = entry.Substring(tab1 + 1, entry.Length - tab1 - 1);
                    }
                    return vName + " : " + vType + " = " + vVal;
                }
            }
            i = i + 1;
        }
        return "";
    }

    /// Like LookupVar, but returns the raw "name\ttype\tvalue" entry so the
    /// caller can render an expandable, formatted tooltip.
    static string LookupVarRaw(List<string> vars, string name) {
        int i = 0;
        while (i < vars.Count) {
            string entry = vars[i];
            int tab1 = -1;
            int j = 0;
            while (j < entry.Length) {
                if (entry.Substring(j, 1) == "\t") { tab1 = j; j = entry.Length; }
                j = j + 1;
            }
            if (tab1 > 0 && entry.Substring(0, tab1) == name) { return entry; }
            i = i + 1;
        }
        return "";
    }

    static string Indent(int n) {
        string s = "";
        int i = 0;
        while (i < n && i < 12) { s = s + "  "; i = i + 1; }
        return s;
    }

    /// Pretty-prints a JSON-ish value string into indented lines. Ignores
    /// structure inside quoted strings, caps at maxLines, truncates very long
    /// lines, and reads at most 8000 input chars (large-data safety).
    static void PrettyJson(string s, List<string> out2, int maxLines) {
        int indent = 0;
        string cur = "";
        bool inStr = false;
        int i = 0;
        int limit = s.Length;
        if (limit > 8000) { limit = 8000; }
        while (i < limit) {
            string ch = s.Substring(i, 1);
            if (inStr) {
                cur = cur + ch;
                if (ch == "\"") { inStr = false; }
                else if (ch == "\\" && i + 1 < limit) { cur = cur + s.Substring(i + 1, 1); i = i + 1; }
            } else if (ch == "\"") {
                cur = cur + ch; inStr = true;
            } else if (ch == "{" || ch == "[") {
                cur = cur + ch;
                out2.Add(CodeEditor.Indent(indent) + CodeEditor.Clip(cur));
                cur = "";
                indent = indent + 1;
            } else if (ch == "}" || ch == "]") {
                if (cur.Length > 0) { out2.Add(CodeEditor.Indent(indent) + CodeEditor.Clip(cur)); cur = ""; }
                indent = indent - 1;
                if (indent < 0) { indent = 0; }
                out2.Add(CodeEditor.Indent(indent) + ch);
            } else if (ch == ",") {
                cur = cur + ch;
                out2.Add(CodeEditor.Indent(indent) + CodeEditor.Clip(cur));
                cur = "";
            } else if (ch == ":") {
                cur = cur + ": ";
            } else if (ch == " " || ch == "\n" || ch == "\t" || ch == "\r") {
                // insignificant whitespace outside strings
            } else {
                cur = cur + ch;
            }
            if (out2.Count >= maxLines) { out2.Add("  ...(truncated)"); return; }
            i = i + 1;
        }
        if (cur.Length > 0) { out2.Add(CodeEditor.Indent(indent) + CodeEditor.Clip(cur)); }
    }

    /// Caps a single tooltip line so a very long value can't blow up the box.
    static string Clip(string s) {
        if (s.Length > 200) { return s.Substring(0, 200) + " ..."; }
        return s;
    }

    /// Builds the lines shown in the debug hover tooltip: a header
    /// (`name : type`) followed by the value, pretty-printed if it looks like
    /// JSON / an array / an object.
    static void BuildHoverLines(string entry, List<string> out2) {
        int tab1 = -1;
        int tab2 = -1;
        int j = 0;
        while (j < entry.Length) {
            string ch = entry.Substring(j, 1);
            if (ch == "\t") {
                if (tab1 < 0) { tab1 = j; }
                else if (tab2 < 0) { tab2 = j; }
            }
            j = j + 1;
        }
        string vName = entry;
        string vType = "";
        string vVal = "";
        if (tab1 > 0) {
            vName = entry.Substring(0, tab1);
            if (tab2 > tab1) {
                vType = entry.Substring(tab1 + 1, tab2 - tab1 - 1);
                vVal = entry.Substring(tab2 + 1, entry.Length - tab2 - 1);
            } else {
                vType = entry.Substring(tab1 + 1, entry.Length - tab1 - 1);
            }
        }
        out2.Add(vName + " : " + vType);
        int a = 0;
        while (a < vVal.Length && vVal.Substring(a, 1) == " ") { a = a + 1; }
        string vt = vVal.Substring(a, vVal.Length - a);
        if (vt.Length > 0 && (vt.Substring(0, 1) == "{" || vt.Substring(0, 1) == "[")) {
            CodeEditor.PrettyJson(vt, out2, 60);
        } else {
            out2.Add("= " + CodeEditor.Clip(vVal));
        }
    }
}
