using System;
using Gui;

namespace Gui.Widget;

/// Skeleton loading placeholder.
class Skeleton : Control {
    int prefWpx;
    int prefHpx;

    void InitSkeleton(int w, int h) {
        this.InitControl("skeleton", 1);
        prefWpx = w;
        prefHpx = h;
    }

    /// Retained-mode constructor: `Skeleton s = new Skeleton(200, 16);`
    Skeleton(int w, int h) {
        InitSkeleton(w, h);
    }

    override void OnMeasure(App app) {
        prefW = prefWpx;
        prefH = prefHpx;
    }

    override void OnPaint(App app) {
        Skeleton.Rect(app, bx, by, bw, bh);
    }

    static void Rect(App app, int x, int y, int w, int h) {
        app.canvas.FillRoundRect(x, y, w, h, app.theme.borderRadiusMedium, app.theme.bgTertiary);
    }

    static void Circle(App app, int x, int y, int radius) {
        app.canvas.FillCircle(x, y, radius, app.theme.bgTertiary);
    }

    static void Text(App app, int x, int y, int width) {
        int h = Canvas.FontHeight(app.theme.fontSizeMedium);
        app.canvas.FillRoundRect(x, y, width, h, app.theme.borderRadiusSmall, app.theme.bgTertiary);
    }
}
