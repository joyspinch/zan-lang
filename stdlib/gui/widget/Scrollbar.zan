using System;
using Gui;

namespace Gui.Widget;

/// Scrollbar track and thumb.
class Scrollbar {
    static void RenderVertical(App app, int x, int y, int height, int contentHeight, int scrollOffset) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        c.FillRoundRect(x, y, 8, height, 4, t.bgTertiary);

        if (contentHeight > height && contentHeight > 0) {
            int thumbH = height * height / contentHeight;
            if (thumbH < 20) { thumbH = 20; }
            int thumbY = y + scrollOffset * (height - thumbH) / (contentHeight - height);
            c.FillRoundRect(x, thumbY, 8, thumbH, 4, t.scrollbar);
        }
    }
}
