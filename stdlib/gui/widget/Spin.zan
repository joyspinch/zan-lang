using System;
using Gui;

namespace Gui.Widget;

/// An animated loading spinner. Draws a ring of dots with a rotating bright
/// head + fading trail. Requests a redraw each frame so it keeps spinning.
class Spin {
    // 8 unit-circle offsets (x1000) at 45-degree steps, starting at top.
    static int OffX(int i) {
        if (i == 0) { return 0; }
        if (i == 1) { return 707; }
        if (i == 2) { return 1000; }
        if (i == 3) { return 707; }
        if (i == 4) { return 0; }
        if (i == 5) { return -707; }
        if (i == 6) { return -1000; }
        return -707;
    }
    static int OffY(int i) {
        if (i == 0) { return -1000; }
        if (i == 1) { return -707; }
        if (i == 2) { return 0; }
        if (i == 3) { return 707; }
        if (i == 4) { return 1000; }
        if (i == 5) { return 707; }
        if (i == 6) { return 0; }
        return -707;
    }

    static void Render(App app, int cx, int cy, int radius, int color) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int dotR = radius / 4;
        if (dotR < app.Scale(2)) { dotR = app.Scale(2); }
        int active = (app.frameCount / 3) % 8;
        int i = 0;
        while (i < 8) {
            int px = cx + PivotSafeMul(Spin.OffX(i), radius);
            int py = cy + PivotSafeMul(Spin.OffY(i), radius);
            int d = (active - i + 8) % 8;
            int dc = t.bgTertiary;
            int dr = dotR;
            if (d == 0) { dc = color; dr = dotR + app.Scale(1); }
            else if (d == 1) { dc = color; }
            else if (d == 2) { dc = t.textTertiary; }
            else if (d == 3) { dc = t.borderPrimary; }
            c.FillCircle(px, py, dr, dc);
            i = i + 1;
        }
        app.RequestRedraw();
    }

    // (offset_x1000 * radius) / 1000 without overflow surprises.
    static int PivotSafeMul(int per1000, int radius) {
        return (per1000 * radius) / 1000;
    }

    /// Spinner with a caption below it, centered in a box.
    static void WithTip(App app, int x, int y, int w, int h, string tip) {
        Theme t = app.theme;
        int cx = x + w / 2;
        int cy = y + h / 2 - app.Scale(10);
        Spin.Render(app, cx, cy, app.Scale(18), t.primary);
        if (tip != "") {
            int ty = cy + app.Scale(30);
            app.canvas.DrawTextCentered(x, ty, w, Canvas.FontHeight(t.fontSizeSmall),
                                        tip, t.textSecondary, t.fontSizeSmall);
        }
    }
}
