using System;
using Gui;

namespace Gui.Widget;

/// Dropdown: a trigger button that opens a menu of action items.
/// The caller owns the open/closed state and calls RenderMenu when open.
class Dropdown {
    /// Draws the trigger button. Returns its hit id.
    static int RenderTrigger(App app, int x, int y, int w, int h, string label, bool open) {
        int id = app.focus.AllocId();
        Canvas c = app.canvas;
        Theme t = app.theme;

        bool hovered = app.focus.IsHovered(id);
        int border = t.borderPrimary;
        if (hovered || open) { border = t.borderHover; }

        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(x, y, w, h, border, 1);
        int textY = y + (h - Canvas.FontHeight(t.fontSizeMedium)) / 2;
        c.DrawText(x + t.paddingMedium, textY, label, t.textPrimary, t.fontSizeMedium);
        Icon.DrawCenteredIn(c, "arrow-down", x + w - t.paddingLarge - t.iconSizeSmall, y, t.iconSizeSmall, h, t.iconSizeSmall, t.textSecondary);

        app.hitTester.Register(HitRegion.Create(id, x, y, w, h, 4));
        return id;
    }

    /// Draws the open menu of items and returns the first item's hit id.
    static int RenderMenu(App app, int x, int y, int w, List<string> items) {
        int firstId = app.focus.AllocId();
        int count = items.Count;
        int i = 1;
        while (i < count) {
            app.focus.AllocId();
            i = i + 1;
        }

        Canvas c = app.canvas;
        Theme t = app.theme;
        int optH = t.heightMedium;
        int totalH = count * optH + t.paddingTiny * 2;

        c.FillRoundRect(x + 1, y + 2, w, totalH, t.borderRadiusMedium, t.shadowColor);
        c.FillRoundRect(x, y, w, totalH, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(x, y, w, totalH, t.borderPrimary, 1);

        i = 0;
        while (i < count) {
            int optId = firstId + i;
            int optY = y + t.paddingTiny + i * optH;
            bool hovered = app.focus.IsHovered(optId);
            if (hovered) { c.FillRect(x + 1, optY, w - 2, optH, t.bgHover); }
            c.DrawText(x + t.paddingMedium, optY + (optH - Canvas.FontHeight(t.fontSizeMedium)) / 2,
                       items[i], t.textPrimary, t.fontSizeMedium);
            app.hitTester.Register(HitRegion.Create(optId, x, optY, w, optH, 0));
            i = i + 1;
        }
        return firstId;
    }
}
