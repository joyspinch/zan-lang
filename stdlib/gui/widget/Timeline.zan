using System;
using Gui;

namespace Gui.Widget;

/// Vertical timeline (NaiveUI n-timeline). Each entry has a colored dot,
/// a connecting line, a title and a description.
class Timeline : Control {
    List<string> titles;
    List<string> descs;

    void InitTimeline() {
        this.InitControl("timeline", 1);
        titles = new List<string>();
        descs = new List<string>();
    }

    /// Retained-mode constructor: `Timeline tl = new Timeline(); tl.AddEntry("Created", "...");`
    Timeline() {
        InitTimeline();
    }

    void AddEntry(string title, string desc) {
        titles.Add(title);
        descs.Add(desc);
    }

    override void OnMeasure(App app) {
        prefH = Timeline.RowHeight(app) * titles.Count;
        prefW = app.Scale(240);
    }

    override void OnPaint(App app) {
        Timeline.Render(app, bx, by, titles, descs);
    }

    static int RowHeight(App app) {
        Theme t = app.theme;
        return t.heightLarge + t.paddingSmall;
    }

    static void Render(App app, int x, int y, List<string> titles, List<string> descs) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int n = titles.Count;
        int rowH = Timeline.RowHeight(app);
        int dotR = app.Scale(5);
        int lw = app.Scale(2);
        int lineX = x + dotR;

        int i = 0;
        while (i < n) {
            int top = y + i * rowH;
            int cy = top + dotR + app.Scale(2);
            if (i < n - 1) {
                c.FillRect(lineX - lw / 2, cy, lw, rowH, t.divider);
            }
            int dotColor = t.primary;
            if (i == 0) { dotColor = t.success; }
            c.FillCircle(lineX, cy, dotR, dotColor);

            int tx = x + dotR * 2 + t.gapLarge;
            c.DrawText(tx, top, titles[i], t.textPrimary, t.fontSizeMedium);
            if (i < descs.Count) {
                c.DrawText(tx, top + Canvas.FontHeight(t.fontSizeMedium) + t.gapSmall,
                           descs[i], t.textTertiary, t.fontSizeSmall);
            }
            i = i + 1;
        }
    }
}
