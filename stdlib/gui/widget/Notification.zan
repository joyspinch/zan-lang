using System;
using Gui;

namespace Gui.Widget;

/// Notification bar with icon and type indicator.
class Notification {
    static void Render(App app, int x, int y, int w, string message, int ntype) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int h = t.heightLarge + t.paddingSmall;

        // Shadow + body
        c.FillRoundRect(x + 1, y + 2, w, h, t.borderRadiusMedium, t.shadowColor);
        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(x, y, w, h, t.borderSecondary, 1);

        int barColor = t.primary;
        string iconName = "info";
        if (ntype == 2) { barColor = t.info; iconName = "info"; }
        if (ntype == 3) { barColor = t.success; iconName = "success"; }
        if (ntype == 4) { barColor = t.warning; iconName = "warning"; }
        if (ntype == 5) { barColor = t.error; iconName = "error"; }
        c.FillRect(x, y, 3, h, barColor);

        Icon.DrawCenteredIn(c, iconName, x + t.paddingMedium, y, t.iconSizeMedium, h, t.iconSizeMedium, barColor);
        c.DrawText(x + t.paddingMedium + t.iconSizeMedium + t.gapSmall, y + (h - Canvas.FontHeight(t.fontSizeMedium)) / 2,
                   message, t.textPrimary, t.fontSizeMedium);
    }
}
