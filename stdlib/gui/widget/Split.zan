using System;
using Gui;

namespace Gui.Widget;

/// <summary>
/// A draggable divider that splits a region into two resizable panes — the
/// building block for IDE-style layouts (project tree | editor, editor |
/// output). The size of the first pane is held in a reactive SignalInt so it
/// persists across frames and can be bound elsewhere.
///
/// Immediate-mode usage: call the factory each frame with the area to split.
/// It draws the handle, processes any in-progress drag (updating the signal),
/// and returns a Split whose `first`/`second` rects the caller lays out into:
///
///   Split sp = Split.Vertical(app, area, sidebarW, 160, 320);
///   RenderSidebar(app, sp.first);
///   RenderEditor(app, sp.second);
/// </summary>
class Split {
    /// Content rectangle of the first (left/top) pane.
    Rect first;
    /// Content rectangle of the second (right/bottom) pane.
    Rect second;
    /// Focus id of the drag handle (for custom hit queries if needed).
    int handleId;

    /// Splits `area` into left|right panes with a vertical drag handle.
    /// `firstW` holds the left pane width (px). `minFirst`/`minSecond` clamp the
    /// drag so neither pane collapses below a usable width.
    static Split Vertical(App app, Rect area, SignalInt firstW, int minFirst, int minSecond) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        int handleW = 5;

        int maxFirst = area.width - minSecond - handleW;
        if (maxFirst < minFirst) { maxFirst = minFirst; }

        if (app.focus.IsPressed(id)) {
            int nv = app.mouseX - area.x;
            if (nv < minFirst) { nv = minFirst; }
            if (nv > maxFirst) { nv = maxFirst; }
            firstW.Set(nv);
            app.RequestRedraw();
        }

        int fw = firstW.Get();
        if (fw < minFirst) { fw = minFirst; }
        if (fw > maxFirst) { fw = maxFirst; }

        int handleX = area.x + fw;
        int hc = t.divider;
        if (app.focus.IsHovered(id) || app.focus.IsPressed(id)) { hc = t.primary; }
        c.FillRect(handleX, area.y, handleW, area.height, hc);
        app.hitTester.Register(HitRegion.Create(id, handleX, area.y, handleW, area.height, 4));

        Split s = new Split();
        s.first = Rect.Create(area.x, area.y, fw, area.height);
        s.second = Rect.Create(handleX + handleW, area.y, area.width - fw - handleW, area.height);
        s.handleId = id;
        return s;
    }

    /// Splits `area` into top|bottom panes with a horizontal drag handle.
    /// `firstH` holds the top pane height (px).
    static Split Horizontal(App app, Rect area, SignalInt firstH, int minFirst, int minSecond) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        int handleH = 5;

        int maxFirst = area.height - minSecond - handleH;
        if (maxFirst < minFirst) { maxFirst = minFirst; }

        if (app.focus.IsPressed(id)) {
            int nv = app.mouseY - area.y;
            if (nv < minFirst) { nv = minFirst; }
            if (nv > maxFirst) { nv = maxFirst; }
            firstH.Set(nv);
            app.RequestRedraw();
        }

        int fh = firstH.Get();
        if (fh < minFirst) { fh = minFirst; }
        if (fh > maxFirst) { fh = maxFirst; }

        int handleY = area.y + fh;
        int hc = t.divider;
        if (app.focus.IsHovered(id) || app.focus.IsPressed(id)) { hc = t.primary; }
        c.FillRect(area.x, handleY, area.width, handleH, hc);
        app.hitTester.Register(HitRegion.Create(id, area.x, handleY, area.width, handleH, 5));

        Split s = new Split();
        s.first = Rect.Create(area.x, area.y, area.width, fh);
        s.second = Rect.Create(area.x, handleY + handleH, area.width, area.height - fh - handleH);
        s.handleId = id;
        return s;
    }
}
