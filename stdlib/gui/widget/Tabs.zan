using System;
using Gui;

namespace Gui.Widget;

/// Tab bar with reactive int binding for active index.
class Tabs {
    static int Render(App app, int x, int y, int totalWidth, List<string> labels, SignalInt model) {
        int firstId = app.focus.AllocId();
        Canvas c = app.canvas;
        Theme t = app.theme;

        int tabH = t.heightMedium;
        int count = labels.Count;
        int activeIndex = model.Get();

        int i = 1;
        while (i < count) {
            app.focus.AllocId();
            i = i + 1;
        }

        c.FillRect(x, y + tabH - 1, totalWidth, 1, t.divider);

        int tabX = x;
        int activeX = x;
        int activeW = 0;
        i = 0;
        while (i < count) {
            string label = labels[i];
            int tabW = Canvas.MeasureText(label, t.fontSizeMedium) + t.paddingLarge * 2;
            int tabId = firstId + i;

            bool hovered = app.focus.IsHovered(tabId);
            bool active = i == activeIndex;

            // Fade the hover background in/out (non-active tabs only). Painting
            // the page background at e=0 is a visual no-op.
            int hTarget = 0;
            if (hovered && !active) { hTarget = 1000; }
            int he = app.AnimTo(1000000 + tabId, hTarget, 120);
            if (he > 0) {
                c.FillRect(tabX, y, tabW, tabH, App.LerpColor(t.bgPrimary, t.bgHover, he));
            }

            int textColor = t.primary;
            if (!active) { textColor = App.LerpColor(t.textSecondary, t.textPrimary, he); }
            c.DrawTextCentered(tabX, y, tabW, tabH, label, textColor, t.fontSizeMedium);

            if (active) { activeX = tabX; activeW = tabW; }

            app.hitTester.Register(HitRegion.Create(tabId, tabX, y, tabW, tabH, 0));
            tabX = tabX + tabW;
            i = i + 1;
        }

        // Single underline indicator that slides/stretches to the active tab.
        // A fixed-duration smoothstep glide (ease-in-out) reads smoother than an
        // exponential decay, whose long low-velocity tail can look steppy.
        int indX = app.AnimTo(600000 + firstId, activeX, 200);
        int indW = app.AnimTo(800000 + firstId, activeW, 200);
        c.FillRect(indX, y + tabH - 2, indW, 2, t.primary);

        return firstId;
    }

    static void HandleClick(App app, int firstId, int count, SignalInt model) {
        if (app.window.EventKind() == 3) {
            int hitId = app.hitTester.HitTest(app.mouseX, app.mouseY);
            if (hitId >= firstId && hitId < firstId + count) {
                model.Set(hitId - firstId);
                app.RequestRedraw();
            }
        }
    }
}

/// <summary>
/// High-level, self-contained tab bar.
///
/// A retained component (create once, keep across frames) that owns its tab
/// list, active index, closable state, horizontal overflow scrolling, and a
/// right-click context menu. A single Render() call draws the bar AND handles
/// all interaction — no separate HandleClick, hit-id bookkeeping, or scrollbar
/// wiring at the call site:
///
///   // once:
///   TabBar tabs = TabBar.Create(TabBar.Card());
///   tabs.Add("Overview", false);   // (label, closable)
///   tabs.Add("Details", true);
///
///   // each frame:
///   tabs.Render(app, x, y, width);
///   int now = tabs.Active();           // current index
///   int closed = tabs.TakeClosed();    // index removed this frame, or -1
///
/// Styles: Line (underline), Card (raised tab), Segment (pill group).
/// </summary>
class TabBar {
    List<string> labels;
    List<bool> closable;
    int active;
    int style;
    int scrollX;

    int changedIndex;
    int closedIndex;

    bool menuOpen;
    int menuTab;
    int menuX;
    int menuY;

    static int Line() { return 0; }
    static int Card() { return 1; }
    static int Segment() { return 2; }

    static TabBar Create(int style) {
        TabBar b = new TabBar();
        b.labels = new List<string>();
        b.closable = new List<bool>();
        b.active = 0;
        b.style = style;
        b.scrollX = 0;
        b.changedIndex = 0 - 1;
        b.closedIndex = 0 - 1;
        b.menuOpen = false;
        b.menuTab = 0;
        b.menuX = 0;
        b.menuY = 0;
        return b;
    }

    void Add(string label, bool canClose) {
        labels.Add(label);
        closable.Add(canClose);
    }

    int Count() {
        return labels.Count;
    }

    int Active() {
        return active;
    }

    string ActiveLabel() {
        if (active < 0 || active >= labels.Count) { return ""; }
        return labels[active];
    }

    void Select(int i) {
        if (i < 0 || i >= labels.Count) { return; }
        if (i != active) {
            active = i;
            changedIndex = i;
        }
    }

    /// Returns the index selected this frame (or -1), then clears it.
    int TakeChanged() {
        int r = changedIndex;
        changedIndex = 0 - 1;
        return r;
    }

    /// Returns the index closed this frame (or -1), then clears it. The tab is
    /// already removed from this bar; use it to drop any parallel per-tab state.
    int TakeClosed() {
        int r = closedIndex;
        closedIndex = 0 - 1;
        return r;
    }

    void CloseAt(int i) {
        if (i < 0 || i >= labels.Count) { return; }
        labels.RemoveAt(i);
        closable.RemoveAt(i);
        closedIndex = i;
        if (active > i) { active = active - 1; }
        if (active >= labels.Count) { active = labels.Count - 1; }
        if (active < 0) { active = 0; }
    }

    int TabWidth(App app, int i) {
        Theme t = app.theme;
        int w = Canvas.MeasureText(labels[i], t.fontSizeMedium) + t.paddingLarge * 2;
        if (closable[i]) { w = w + app.Scale(18); }
        return w;
    }

    int ContentWidth(App app) {
        int total = 0;
        int i = 0;
        while (i < labels.Count) {
            total = total + this.TabWidth(app, i);
            i = i + 1;
        }
        return total;
    }

    void Render(App app, int x, int y, int totalWidth) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int tabH = t.heightMedium;
        int count = labels.Count;

        int ek = app.window.EventKind();
        int eb = app.window.EventButton();
        bool leftUp = ek == 3 && eb == 0;
        bool rightDown = ek == 2 && eb == 1;

        int contentW = this.ContentWidth(app);
        bool overflow = contentW > totalWidth;

        // Reserve room on the right for scroll chevrons when overflowing.
        int chevW = tabH;
        int viewW = totalWidth;
        if (overflow) { viewW = totalWidth - chevW * 2; }
        if (viewW < 0) { viewW = 0; }

        int maxScroll = contentW - viewW;
        if (maxScroll < 0) { maxScroll = 0; }

        bool overBar = app.mouseX >= x && app.mouseX < x + totalWidth
            && app.mouseY >= y && app.mouseY < y + tabH;

        // Mouse wheel scrolls the strip horizontally while hovered.
        if (overflow && overBar && ek == 13) {
            app.CaptureWheel(x, y, totalWidth, tabH);
            int d = app.window.EventKeyCode();
            scrollX = scrollX - d * app.scrollSpeed / 120;
            app.RequestRedraw();
        }
        if (scrollX > maxScroll) { scrollX = maxScroll; }
        if (scrollX < 0) { scrollX = 0; }

        // Style background.
        if (style == 2) {
            c.FillRoundRect(x, y, totalWidth, tabH, t.borderRadiusMedium, t.bgTertiary);
        } else {
            c.FillRect(x, y + tabH - 1, viewW, 1, t.divider);
        }

        c.PushClip(x, y, viewW, tabH);

        int tabX = x - scrollX;
        int i = 0;
        while (i < count) {
            int tw = this.TabWidth(app, i);
            bool isActive = i == active;

            bool overTab = app.mouseX >= tabX && app.mouseX < tabX + tw
                && app.mouseX >= x && app.mouseX < x + viewW
                && app.mouseY >= y && app.mouseY < y + tabH;

            // Close button geometry (right side of the tab).
            int closeW = app.Scale(18);
            int closeX = tabX + tw - closeW;
            bool overClose = closable[i] && overTab
                && app.mouseX >= closeX && app.mouseX < closeX + closeW;

            // ---- paint by style ----
            if (style == 1) {
                // Card: raised rounded tab; active uses the page bg + border.
                int cardBg = t.bgSecondary;
                if (isActive) { cardBg = t.bgPrimary; }
                else if (overTab) { cardBg = t.bgHover; }
                c.FillRoundRect(tabX + 2, y + 2, tw - 4, tabH - 2,
                    t.borderRadiusMedium, cardBg);
                if (isActive) {
                    c.DrawRect(tabX + 2, y + 2, tw - 4, tabH - 2, t.borderPrimary, 1);
                }
            } else if (style == 2) {
                // Segment: pill highlight behind the active item.
                if (isActive) {
                    c.FillRoundRect(tabX + 3, y + 3, tw - 6, tabH - 6,
                        t.borderRadiusSmall, t.bgPrimary);
                } else if (overTab) {
                    c.FillRoundRect(tabX + 3, y + 3, tw - 6, tabH - 6,
                        t.borderRadiusSmall, t.bgHover);
                }
            } else {
                // Line: hover tint only.
                if (overTab && !isActive) {
                    c.FillRect(tabX, y, tw, tabH, t.bgHover);
                }
            }

            // Label.
            int tc = States.TextMuted(t, overTab, isActive, false);
            if (style == 2 && isActive) { tc = t.textPrimary; }
            int labelW = tw;
            if (closable[i]) { labelW = tw - closeW; }
            c.DrawTextCentered(tabX, y, labelW, tabH, labels[i], tc, t.fontSizeMedium);

            // Close affordance.
            if (closable[i]) {
                int icoColor = t.textTertiary;
                if (overClose) {
                    c.FillRoundRect(closeX, y + (tabH - closeW) / 2, closeW, closeW,
                        t.borderRadiusSmall, t.bgActive);
                    icoColor = t.error;
                }
                Icon.DrawCenteredIn(c, "close", closeX, y, closeW, tabH,
                    t.iconSizeSmall, icoColor);
            }

            // Active underline for the Line style.
            if (style == 0 && isActive) {
                c.FillRect(tabX, y + tabH - 2, tw, 2, t.primary);
            }

            // ---- input (suppressed while the context menu is open) ----
            if (!menuOpen) {
                if (leftUp && overClose) {
                    this.CloseAt(i);
                    app.RequestRedraw();
                } else if (leftUp && overTab) {
                    this.Select(i);
                    app.RequestRedraw();
                } else if (rightDown && overTab) {
                    menuOpen = true;
                    menuTab = i;
                    menuX = app.mouseX;
                    menuY = app.mouseY;
                    app.RequestRedraw();
                }
            }

            tabX = tabX + tw;
            i = i + 1;
        }

        c.PopClip();

        // Overflow chevrons.
        if (overflow) {
            int lx = x + viewW;
            int rx = x + viewW + chevW;
            bool overL = app.mouseX >= lx && app.mouseX < lx + chevW
                && app.mouseY >= y && app.mouseY < y + tabH;
            bool overR = app.mouseX >= rx && app.mouseX < rx + chevW
                && app.mouseY >= y && app.mouseY < y + tabH;
            if (overL) { c.FillRect(lx, y, chevW, tabH, t.bgHover); }
            if (overR) { c.FillRect(rx, y, chevW, tabH, t.bgHover); }
            Icon.DrawCenteredIn(c, "arrow-left", lx, y, chevW, tabH,
                t.iconSizeSmall, t.textSecondary);
            Icon.DrawCenteredIn(c, "arrow-right", rx, y, chevW, tabH,
                t.iconSizeSmall, t.textSecondary);
            if (leftUp && !menuOpen) {
                if (overL) {
                    scrollX = scrollX - app.Scale(80);
                    if (scrollX < 0) { scrollX = 0; }
                    app.RequestRedraw();
                } else if (overR) {
                    scrollX = scrollX + app.Scale(80);
                    if (scrollX > maxScroll) { scrollX = maxScroll; }
                    app.RequestRedraw();
                }
            }
        }

        // Context menu overlay.
        if (menuOpen) {
            this.RenderMenu(app, leftUp);
        }
    }

    void RenderMenu(App app, bool leftUp) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int itemH = app.Scale(30);
        int mw = app.Scale(150);
        int pad = app.Scale(4);

        List<string> items = new List<string>();
        items.Add("Close");
        items.Add("Close others");
        items.Add("Close all");

        int mh = items.Count * itemH + pad * 2;
        int mx = menuX;
        int my = menuY;

        c.FillRoundRect(mx, my, mw, mh, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(mx, my, mw, mh, t.borderPrimary, 1);

        bool inside = app.mouseX >= mx && app.mouseX < mx + mw
            && app.mouseY >= my && app.mouseY < my + mh;
        int picked = 0 - 1;

        int i = 0;
        while (i < items.Count) {
            int iy = my + pad + i * itemH;
            bool over = app.mouseX >= mx && app.mouseX < mx + mw
                && app.mouseY >= iy && app.mouseY < iy + itemH;
            if (over) {
                c.FillRoundRect(mx + pad, iy, mw - pad * 2, itemH,
                    t.borderRadiusSmall, t.bgHover);
            }
            int ty = iy + (itemH - Canvas.FontHeight(t.fontSizeMedium)) / 2;
            c.DrawText(mx + pad * 3, ty, items[i], t.textPrimary, t.fontSizeMedium);
            if (leftUp && over) { picked = i; }
            i = i + 1;
        }

        if (leftUp) {
            if (picked == 0) {
                this.CloseAt(menuTab);
            } else if (picked == 1) {
                // Keep only the menu tab.
                string keep = "";
                bool keepClose = false;
                if (menuTab >= 0 && menuTab < labels.Count) {
                    keep = labels[menuTab];
                    keepClose = closable[menuTab];
                }
                labels = new List<string>();
                closable = new List<bool>();
                if (keep != "") {
                    labels.Add(keep);
                    closable.Add(keepClose);
                }
                active = 0;
                closedIndex = menuTab;
            } else if (picked == 2) {
                labels = new List<string>();
                closable = new List<bool>();
                active = 0;
                closedIndex = 0;
            }
            // Any click (on an item or outside) dismisses the menu.
            menuOpen = false;
            app.RequestRedraw();
        }
    }
}
