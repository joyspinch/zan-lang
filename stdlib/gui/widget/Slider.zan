using System;
using Gui;

namespace Gui.Widget;

/// Slider with reactive int binding and live drag / click-to-seek.
/// While the handle (or track) is pressed the value tracks the pointer,
/// mirroring NaiveUI's n-slider behaviour. All sizes are DPI-scaled.
///
/// C#-style retained instance:
///     Slider vol = Slider.Bind(0, 100, model);
///     vol.Change += () => { ... };   // fires while dragging as value changes
///     vol.Render(app, x, y, width);
/// Legacy immediate-mode static is kept for existing callers.
class Slider : Control {
    int minVal;
    int maxVal;
    SignalInt model;
    int wid;
    /// Fires whenever the value changes (C#-style: `s.Change += h;`).
    UiEvent Change;
    /// Fires when a drag/seek gesture ends (pointer released on the slider).
    UiEvent DragEnd;

    void InitSlider(int lo, int hi, SignalInt m) {
        this.InitControl("slider", 1);
        minVal = lo;
        maxVal = hi;
        model = m;
        wid = WidgetId.Next();
        Change = UiEvent.Create();
        DragEnd = UiEvent.Create();
    }

    /// Retained-mode constructor: `Slider vol = new Slider(0, 100, model);`
    Slider(int lo, int hi, SignalInt m) {
        InitSlider(lo, hi, m);
    }

    static Slider Bind(int minVal, int maxVal, SignalInt model) {
        Slider s = new Slider(minVal, maxVal, model);
        return s;
    }

    int Value() { return model.Get(); }

    int Render(App app, int x, int y, int width) {
        int id = wid;
        app.focus.RegisterFocusable(id);
        bool changed = Slider.Paint(app, id, x, y, width, minVal, maxVal, model);
        // Keyboard: arrows nudge the focused slider.
        if (Ui.Focused(app, id) && app.window.EventKind() == 4) {
            int kc = app.window.EventKeyCode();
            int v = model.Get();
            if (kc == 37 || kc == 40) { v = v - 1; }
            if (kc == 39 || kc == 38) { v = v + 1; }
            if (v < minVal) { v = minVal; }
            if (v > maxVal) { v = maxVal; }
            if (v != model.Get()) { model.Set(v); changed = true; app.RequestRedraw(); }
        }
        if (changed) { Change.Raise(); }
        DragEnd.RaiseIf(Ui.MouseUpOn(app, id));
        On.Fire(app, id);
        return id;
    }

    override List<string> Events() {
        List<string> e = Control.CommonEvents();
        e.Add("Change");
        e.Add("DragEnd");
        return e;
    }

    override string Kind() { return "Slider"; }

    override List<PropSpec> Props() {
        List<PropSpec> ps = new List<PropSpec>();
        ps.Add(PropSpec.Int("min", "Minimum"));
        ps.Add(PropSpec.Int("max", "Maximum"));
        ps.Add(PropSpec.Int("value", "Value"));
        return ps;
    }

    override string GetProp(string key) {
        if (key == "value") { return Convert.ToString(model.Get()); }
        if (key == "min") { return Convert.ToString(minVal); }
        if (key == "max") { return Convert.ToString(maxVal); }
        return "";
    }

    override void SetProp(string key, string val) {
        if (key == "value") { int v = Convert.ToInt32(val); model.Set(v); }
        else if (key == "min") { minVal = Convert.ToInt32(val); }
        else if (key == "max") { maxVal = Convert.ToInt32(val); }
    }

    override void BindEvent(string evt, Action a) {
        if (evt == "Change") { Change.Add(a); return; }
        if (evt == "DragEnd") { DragEnd.Add(a); return; }
        On.AddByName(evt, a);
    }

    /// Draws the rail/fill/handle and applies live drag. Returns true if the
    /// value changed this frame. Shared by retained + legacy paths.
    static bool Paint(App app, int id, int x, int y, int width, int minVal, int maxVal, SignalInt model) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        bool hovered = app.focus.IsHovered(id);
        bool active = app.focus.IsPressed(id);
        bool changed = false;

        int totalH = t.heightMedium;
        int range = maxVal - minVal;
        if (range < 1) { range = 1; }

        // Live drag / click-to-seek: while pressed, map the cursor X onto the value.
        if (active) {
            int rel = app.mouseX - x;
            if (rel < 0) { rel = 0; }
            if (rel > width) { rel = width; }
            int newVal = minVal + (rel * range + width / 2) / width;
            if (newVal < minVal) { newVal = minVal; }
            if (newVal > maxVal) { newVal = maxVal; }
            if (newVal != model.Get()) {
                model.Set(newVal);
                changed = true;
                app.RequestRedraw();
            }
        }

        int currentVal = model.Get();
        int trackH = app.Scale(4);
        int trackY = y + (totalH - trackH) / 2;

        // Rail + active fill
        c.FillRoundRect(x, trackY, width, trackH, trackH / 2, t.bgTertiary);
        int fillW = (currentVal - minVal) * width / range;
        if (fillW < 0) { fillW = 0; }
        if (fillW > width) { fillW = width; }
        c.FillRoundRect(x, trackY, fillW, trackH, trackH / 2, t.primary);

        // Handle: white knob with ring; focus halo on hover/drag.
        int knobR = app.Scale(9);
        int knobX = x + fillW;
        if (knobX < x + knobR) { knobX = x + knobR; }
        if (knobX > x + width - knobR) { knobX = x + width - knobR; }
        int knobY = trackY + trackH / 2;
        if (hovered || active) {
            c.FillCircle(knobX, knobY, knobR + app.Scale(4), t.bgHover);
        }
        int ringColor = t.borderPrimary;
        if (hovered || active) { ringColor = t.primary; }
        c.FillCircle(knobX, knobY, knobR, ringColor);
        c.FillCircle(knobX, knobY, knobR - app.Scale(2), t.bgPrimary);

        app.hitTester.Register(HitRegion.Create(id, x, y, width, totalH, 3));
        return changed;
    }

    static int Render(App app, int x, int y, int width, int minVal, int maxVal, SignalInt model) {
        int id = app.focus.AllocId();
        Slider.Paint(app, id, x, y, width, minVal, maxVal, model);
        return id;
    }

    override void OnMeasure(App app) {
        prefH = app.theme.heightMedium;
        prefW = app.Scale(160);
    }

    override void OnPaint(App app) {
        this.Render(app, bx, by, bw);
    }
}
