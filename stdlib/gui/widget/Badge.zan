using System;
using Gui;

namespace Gui.Widget;

/// Badge indicator (dot or count).
class Badge {
    static void Dot(App app, int x, int y) {
        app.canvas.FillCircle(x, y, 4, app.theme.error);
    }

    static void Count(App app, int x, int y, int count) {
        if (count <= 0) { return; }
        Canvas c = app.canvas;
        Theme t = app.theme;
        c.FillCircle(x, y, 8, t.error);
    }
}
