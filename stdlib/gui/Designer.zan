using System;
using Gui.Widget;

namespace Gui;

/// A FormCreate / form-builder style visual designer, self-contained and reusable.
///
/// Instead of free-form pixel dragging it edits an ordered list of form FIELDS
/// (FormField controls held as children of a `form` root panel) and renders them
/// as a vertical, labelled form — the layout everyone builds by hand in VB /
/// WinForms / element-plus form designers, but without touching coordinates.
///
/// Surface:
///   * a toolbar (Save / Load / Export / Preview / Clear, plus move-up /
///     move-down / delete acting on the selected field),
///   * a categorised field palette on the left (click a type to append a row),
///   * the vertical form preview in the centre (label + required star + a preview
///     of each field control; click a row to select it),
///   * a right-hand inspector with a Field / Form tab pair: Field edits the
///     selected row (label, model name, placeholder, required, options, change
///     handler); Form edits form-level config (name, label position, size, label
///     width, required-star visibility, submit/reset buttons, submit handler),
///   * a status bar.
///
/// Everything round-trips through Serialize: the form config is a header line and
/// the fields are the serialized Control subtree, so relationships, order,
/// properties and event bindings all persist.
///
/// Usage:
///   Designer d = Designer.Create();   // once
///   d.Seed(app);                      // optional sample fields
///   d.Render(app, x, y, w, h);        // each frame
class Designer {
    List<FormField> fields;
    FormField sel;
    FormField selPrev;
    string doc;
    string msg;
    int inspTab;      // 0 = field, 1 = form
    bool preview;
    int seq;          // running counter for generated field names

    // Container into which the palette adds new components: the selected
    // container, or the parent container of the selected child, or null for
    // the top-level form. Lets you click a Card / Tabs then drop components in.
    FormField activeContainer;
    bool rowClicked;  // set while a row consumes a mousedown, so background
                      // clicks can deselect
    int paletteScroll; // vertical scroll offset for the component palette
    int palClipTop;    // visible top/bottom of the palette body (for culling)
    int palClipBot;
    int formScroll;    // vertical scroll offset for the form preview
    int formClipTop;   // visible top/bottom of the form body (for culling)
    int formClipBot;

    // Form-level configuration.
    int labelPos;     // 0 left, 1 right, 2 top
    int formSize;     // 0 large, 1 default, 2 small
    int labelWidth;   // logical px reserved for the label column
    bool hideStar;    // hide the required-field red star
    bool showSubmit;
    bool showReset;

    // Drag state (palette -> form to add; within form to reorder).
    bool dragging;
    bool dragFromPalette;
    bool dragMoved;
    int dragKind;     // field type being dragged out of the palette
    int dragIndex;    // source row index when reordering
    int dropIndex;    // computed insertion index
    int dropY;        // y of the insertion indicator
    int dragMouseX;
    int dragMouseY;

    // Palette hover (for the tooltip drawn on top after the panels).
    int hoverFt;
    int hoverX;
    int hoverY;

    // Inline editors (persist across frames; reseeded when the selection changes).
    SignalString labelSig;
    Input labelInput;
    SignalString nameSig;
    Input nameInput;
    SignalString phSig;
    Input phInput;
    SignalString optSig;
    Input optInput;
    SignalString evtSig;
    Input evtInput;
    SignalString formNameSig;
    Input formNameInput;
    SignalString submitSig;
    Input submitInput;

    static Designer Create() {
        Designer d = new Designer();
        d.fields = new List<FormField>();
        d.sel = null;
        d.selPrev = null;
        d.doc = "";
        d.msg = "click a field type on the left to add a row";
        d.inspTab = 1;
        d.preview = false;
        d.seq = 0;
        d.activeContainer = null;
        d.rowClicked = false;
        d.paletteScroll = 0;
        d.formScroll = 0;
        d.labelPos = 0;
        d.formSize = 1;
        d.labelWidth = 92;
        d.hideStar = false;
        d.showSubmit = true;
        d.showReset = true;
        d.dragging = false;
        d.dragFromPalette = false;
        d.dragMoved = false;
        d.dragKind = 0;
        d.dragIndex = -1;
        d.dropIndex = -1;
        d.dropY = 0;
        d.dragMouseX = 0;
        d.dragMouseY = 0;
        d.hoverFt = -1;
        d.hoverX = 0;
        d.hoverY = 0;
        d.labelSig = SignalString.Create("");
        d.labelInput = Input.Bind(d.labelSig, "label");
        d.nameSig = SignalString.Create("");
        d.nameInput = Input.Bind(d.nameSig, "field name");
        d.phSig = SignalString.Create("");
        d.phInput = Input.Bind(d.phSig, "placeholder");
        d.optSig = SignalString.Create("");
        d.optInput = Input.Bind(d.optSig, "new option");
        d.evtSig = SignalString.Create("");
        d.evtInput = Input.Bind(d.evtSig, "handler");
        d.formNameSig = SignalString.Create("My form");
        d.formNameInput = Input.Bind(d.formNameSig, "form name");
        d.submitSig = SignalString.Create("");
        d.submitInput = Input.Bind(d.submitSig, "handler");
        return d;
    }

    /// Optional sample content so a fresh designer isn't an empty form —
    /// including a Card and a Tabs container with nested components so the
    /// composition / tab-switching behaviour is visible out of the box.
    void Seed(App app) {
        activeContainer = null;
        // A 24-column grid: two halves, then thirds, showing 等分 layout.
        AddField(0); fields[fields.Count - 1].span = 12;
        AddField(2); fields[fields.Count - 1].span = 12;
        AddField(3); fields[fields.Count - 1].span = 8;
        AddField(6); fields[fields.Count - 1].span = 8;
        AddField(7); fields[fields.Count - 1].span = 8;

        // A Card container with nested children.
        activeContainer = null;
        AddField(18);
        AddField(15);
        AddField(0);

        // A Tabs container: table + statistic on tab 1, alert on tab 2.
        activeContainer = null;
        AddField(36);
        AddField(23);
        AddField(22);
        if (activeContainer != null) { activeContainer.uiState.Set(1); }
        AddField(28);
        if (activeContainer != null) { activeContainer.uiState.Set(0); }

        // A full-width chart.
        activeContainer = null;
        AddField(43);

        activeContainer = null;
        sel = null;
        selPrev = null;
        inspTab = 1;
    }

    // --- Field mutation ------------------------------------------------------

    /// Adds a new component. When a container is active the component is nested
    /// inside it (into the active tab for Tabs); otherwise it is appended to
    /// the top-level form. Adding a container makes it the active container so
    /// you can immediately drop components inside.
    void AddField(int ftype) {
        FormField f = FormField.New(ftype, seq);
        seq = seq + 1;
        if (activeContainer != null) {
            f.childTab = 0;
            if (activeContainer.ftype == 36) { f.childTab = activeContainer.uiState.Get(); }
            activeContainer.kids.Add(f);
        } else {
            fields.Add(f);
        }
        sel = f;
        inspTab = 0;
        if (f.IsContainer()) { activeContainer = f; }
        msg = "added " + FormField.TypeName(ftype);
    }

    bool ContainsRef(List<FormField> lst, FormField target) {
        int i = 0;
        while (i < lst.Count) {
            if (lst[i] == target) { return true; }
            i = i + 1;
        }
        return false;
    }

    int IndexIn(List<FormField> lst, FormField f) {
        int i = 0;
        while (i < lst.Count) {
            if (lst[i] == f) { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// The container that holds `target` in its kids, or null when target is a
    /// top-level field (or not found). Searched recursively.
    FormField ParentContainerOf(FormField target) {
        if (ContainsRef(fields, target)) { return null; }
        return FindOwner(fields, target);
    }

    FormField FindOwner(List<FormField> lst, FormField target) {
        int i = 0;
        while (i < lst.Count) {
            FormField f = lst[i];
            if (f.IsContainer()) {
                if (ContainsRef(f.kids, target)) { return f; }
                FormField r = FindOwner(f.kids, target);
                if (r != null) { return r; }
            }
            i = i + 1;
        }
        return null;
    }

    /// Rebuilds `lst` without `target` (mid-list RemoveAt is used elsewhere but
    /// rebuilding keeps parity with the Insert workaround below).
    List<FormField> ListRemove(List<FormField> lst, FormField target) {
        List<FormField> nl = new List<FormField>();
        int i = 0;
        while (i < lst.Count) {
            if (lst[i] != target) { nl.Add(lst[i]); }
            i = i + 1;
        }
        return nl;
    }

    /// Moves the element at `from` to land at `to`, rebuilt via Add (the
    /// runtime's mid-list Insert overruns its buffer and corrupts the heap).
    List<FormField> ListMove(List<FormField> lst, int from, int to) {
        if (from < 0 || from >= lst.Count) { return lst; }
        FormField mv = lst[from];
        List<FormField> rest = new List<FormField>();
        int i = 0;
        while (i < lst.Count) {
            if (i != from) { rest.Add(lst[i]); }
            i = i + 1;
        }
        if (to < 0) { to = 0; }
        if (to > rest.Count) { to = rest.Count; }
        List<FormField> nl = new List<FormField>();
        i = 0;
        while (i < rest.Count) {
            if (i == to) { nl.Add(mv); }
            nl.Add(rest[i]);
            i = i + 1;
        }
        if (to >= rest.Count) { nl.Add(mv); }
        return nl;
    }

    void MoveSel(int delta) {
        if (sel == null) { return; }
        FormField pc = ParentContainerOf(sel);
        if (pc == null) {
            int idx = IndexIn(fields, sel);
            if (idx < 0) { return; }
            int to = idx + delta;
            if (to < 0) { to = 0; }
            if (to >= fields.Count) { to = fields.Count - 1; }
            if (to != idx) { fields = ListMove(fields, idx, to); }
        } else {
            int idx = IndexIn(pc.kids, sel);
            if (idx < 0) { return; }
            int to = idx + delta;
            if (to < 0) { to = 0; }
            if (to >= pc.kids.Count) { to = pc.kids.Count - 1; }
            if (to != idx) { pc.kids = ListMove(pc.kids, idx, to); }
        }
    }

    /// Inserts `nf` so it ends up at index `at` in the top-level list.
    void InsertFieldAt(int at, FormField nf) {
        if (at < 0) { at = 0; }
        if (at > fields.Count) { at = fields.Count; }
        List<FormField> nl = new List<FormField>();
        int i = 0;
        while (i < fields.Count) {
            if (i == at) { nl.Add(nf); }
            nl.Add(fields[i]);
            i = i + 1;
        }
        if (at >= fields.Count) { nl.Add(nf); }
        fields = nl;
    }

    void DeleteSel() {
        if (sel == null) { return; }
        FormField pc = ParentContainerOf(sel);
        if (pc == null) {
            fields = ListRemove(fields, sel);
        } else {
            pc.kids = ListRemove(pc.kids, sel);
        }
        sel = null;
        selPrev = null;
        activeContainer = null;
        msg = "deleted field";
    }

    // --- Top-level layout ----------------------------------------------------

    void Render(App app, int x, int y, int w, int h) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int barH = app.Scale(30);
        int statusH = app.Scale(20);
        int top = y + app.Scale(6);
        int bodyY = top + barH + app.Scale(8);
        int bot = y + h - statusH - app.Scale(6);

        int palX = x + app.Scale(12);
        int palW = app.Scale(176);
        int inspW = app.Scale(288);
        int canX = palX + palW + app.Scale(12);
        int canW = w - palW - inspW - app.Scale(60);
        // Fill the middle (通栏) but keep a ceiling so the inspector always
        // stays on-screen on very wide windows.
        if (canW > app.Scale(860)) { canW = app.Scale(860); }
        if (canW < app.Scale(240)) { canW = app.Scale(240); }
        int inspX = canX + canW + app.Scale(12);
        int bodyH = bot - bodyY;

        int ek = app.window.EventKind();
        // Track pointer while a drag is in flight; the actual drop is resolved
        // by RenderForm (it owns the row geometry).
        if (dragging && ek == 1) {
            if (app.mouseX != dragMouseX || app.mouseY != dragMouseY) { dragMoved = true; }
            dragMouseX = app.mouseX;
            dragMouseY = app.mouseY;
            app.RequestRedraw();
        }

        hoverFt = -1;
        RenderToolbar(app, c, t, canX, top, canW, barH);
        RenderForm(app, c, t, canX, bodyY, canW, bodyH);
        RenderPalette(app, c, t, palX, bodyY, palW, bodyH);
        RenderInspector(app, c, t, inspX, bodyY, inspW, bodyH);
        RenderStatus(app, c, t, palX, bot + app.Scale(4), inspX + inspW - palX);

        // A drag that ends anywhere outside the form is simply cancelled.
        if (dragging && ek == 3) {
            dragging = false;
            dragFromPalette = false;
            dragMoved = false;
            dragIndex = -1;
        }

        // Palette tooltip (name + description), drawn on top of every panel.
        if (hoverFt >= 0 && !dragging) {
            Tooltip.RenderRich(app, hoverX, hoverY,
                FormField.TypeName(hoverFt), FieldDesc(hoverFt));
        }
        // Ghost chip that follows the cursor while dragging — for both a new
        // field from the palette and an existing row being reordered — so it's
        // always clear which component is in flight.
        if (dragging && dragMoved) {
            int gkind = dragKind;
            if (!dragFromPalette && dragIndex >= 0 && dragIndex < fields.Count) {
                gkind = fields[dragIndex].ftype;
            }
            string gl = FormField.TypeName(gkind);
            int gh = app.Scale(26);
            int icoW = app.Scale(22);
            int gw = icoW + Canvas.MeasureText(gl, t.fontSizeSmall) + app.Scale(16);
            int gx = dragMouseX + app.Scale(8);
            int gy = dragMouseY - gh / 2;
            c.FillRoundRect(gx + 1, gy + 2, gw, gh, t.borderRadiusSmall, t.shadowColor);
            c.FillRoundRect(gx, gy, gw, gh, t.borderRadiusSmall, t.primary);
            Icon.DrawCenteredIn(c, FieldIcon(gkind), gx + app.Scale(4), gy, icoW, gh,
                t.fontSizeSmall, t.textInverse);
            c.DrawText(gx + icoW + app.Scale(4), gy + app.Scale(6), gl, t.textInverse, t.fontSizeSmall);
        }
    }

    // --- Toolbar -------------------------------------------------------------

    void RenderToolbar(App app, Canvas c, Theme t, int tx, int ty, int tw, int th) {
        int bw = app.Scale(50);
        int g = app.Scale(6);
        int bx = tx;
        int sId = Button.Primary("Save").Render(app, bx, ty, bw);
        if (Button.WasClicked(app, sId)) {
            doc = SaveJson();
            msg = "saved JSON (" + Convert.ToString(doc.Length) + " chars)";
        }
        bx = bx + bw + g;
        int lId = Button.Create("Load").Render(app, bx, ty, bw);
        if (Button.WasClicked(app, lId) && doc != "") {
            LoadJson(doc);
            msg = "loaded " + Convert.ToString(fields.Count) + " fields from JSON";
        }
        bx = bx + bw + g;
        int eId = Button.Create("Export").Render(app, bx, ty, bw + app.Scale(8));
        if (Button.WasClicked(app, eId)) {
            doc = SaveJson();
            msg = "exported " + Convert.ToString(fields.Count) + " fields to JSON";
        }
        bx = bx + bw + app.Scale(8) + g;
        int pType = 0;
        if (preview) { pType = 3; }
        int pId = Button.Typed("Preview", pType).Render(app, bx, ty, bw + app.Scale(12));
        if (Button.WasClicked(app, pId)) {
            preview = !preview;
            if (preview) { sel = null; }
        }
        bx = bx + bw + app.Scale(12) + g;
        int clId = Button.Create("Clear").Render(app, bx, ty, bw);
        if (Button.WasClicked(app, clId)) {
            fields = new List<FormField>();
            sel = null; selPrev = null; activeContainer = null;
            msg = "cleared form";
        }
        bx = bx + bw + g + app.Scale(10);
        int uId = Button.Create("Up").Render(app, bx, ty, app.Scale(36));
        if (Button.WasClicked(app, uId)) { MoveSel(-1); }
        bx = bx + app.Scale(36) + g;
        int dnId = Button.Create("Down").Render(app, bx, ty, app.Scale(46));
        if (Button.WasClicked(app, dnId)) { MoveSel(1); }
        bx = bx + app.Scale(46) + g;
        int delId = Button.Typed("Del", 5).Render(app, bx, ty, app.Scale(40));
        if (Button.WasClicked(app, delId)) { DeleteSel(); }
    }

    // --- Field palette -------------------------------------------------------

    void RenderPalette(App app, Canvas c, Theme t, int px, int py, int pw, int ph) {
        int fs = t.fontSizeSmall;
        c.FillRoundRect(px, py, pw, ph, app.Scale(6), t.bgSecondary);
        c.DrawRect(px, py, pw, ph, t.borderPrimary, 1);

        // The palette holds more components than fit at once, so it scrolls
        // internally. Claim the wheel while the pointer is over it (otherwise
        // the whole page scrolls) and clamp the offset to the content height.
        int contentH = PaletteContentH(app);
        int maxScroll = contentH - ph;
        if (maxScroll < 0) { maxScroll = 0; }
        if (InRect(app.mouseX, app.mouseY, px, py, pw, ph)) {
            app.CaptureWheel(px, py, pw, ph);
            if (app.window.EventKind() == 13) {
                int delta = app.window.EventKeyCode();
                paletteScroll = paletteScroll - delta * app.Scale(40) / 120;
                app.RequestRedraw();
            }
        }
        if (paletteScroll < 0) { paletteScroll = 0; }
        if (paletteScroll > maxScroll) { paletteScroll = maxScroll; }

        c.PushClip(px + 1, py + 1, pw - 2, ph - 2);
        palClipTop = py + 1;
        palClipBot = py + ph - 1;
        int ix = px + app.Scale(8);
        int iw = pw - app.Scale(16);
        if (maxScroll > 0) { iw = iw - app.Scale(6); }
        int iy = py + app.Scale(8) - paletteScroll;
        if (PalVisible(app, iy, app.Scale(14))) {
            c.DrawText(ix, iy, "COMPONENTS", t.textTertiary, fs);
        }
        iy = iy + app.Scale(20);

        iy = PaletteGroup(app, c, t, "Basic", 0, 8, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "Advanced", 8, 15, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "Layout", 15, 18, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "Display", 18, 28, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "Feedback", 28, 34, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "Navigation", 34, 40, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "Display+", 40, 47, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "Feedback+", 47, 53, ix, iy, iw);
        iy = PaletteGroup(app, c, t, "More", 53, 55, ix, iy, iw);
        c.PopClip();

        if (maxScroll > 0) {
            Scrollbar.RenderVertical(app, px + pw - app.Scale(7), py + 1,
                ph - 2, contentH, paletteScroll);
        }
    }

    /// Total pixel height of all palette groups, mirroring the layout in
    /// RenderPalette / PaletteGroup so scrolling can be clamped correctly.
    int PaletteContentH(App app) {
        int h = app.Scale(8) + app.Scale(20);
        h = h + PaletteGroupH(app, 8);   // Basic
        h = h + PaletteGroupH(app, 7);   // Advanced
        h = h + PaletteGroupH(app, 3);   // Layout
        h = h + PaletteGroupH(app, 10);  // Display
        h = h + PaletteGroupH(app, 6);   // Feedback
        h = h + PaletteGroupH(app, 6);   // Navigation
        h = h + PaletteGroupH(app, 7);   // Display+
        h = h + PaletteGroupH(app, 6);   // Feedback+
        h = h + PaletteGroupH(app, 2);   // More
        return h + app.Scale(8);
    }

    int PaletteGroupH(App app, int count) {
        int cols = 4;
        int rows = (count + cols - 1) / cols;
        int rowStep = app.Scale(34) + app.Scale(6);
        return app.Scale(18) + rows * rowStep + app.Scale(10);
    }

    /// Renders a 4-across grid of icon-only palette tiles for field types
    /// [lo, hi) and returns the next y. Hovering a tile arms a tooltip; pressing
    /// one begins a drag that can be dropped onto the form to add the field.
    int PaletteGroup(App app, Canvas c, Theme t, string title, int lo, int hi,
            int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        if (PalVisible(app, iy, app.Scale(14))) {
            c.DrawText(ix, iy, title, t.textSecondary, fs);
        }
        iy = iy + app.Scale(18);
        int cols = 4;
        int gapx = app.Scale(4);
        int tileW = (iw - (cols - 1) * gapx) / cols;
        int tileH = app.Scale(34);
        int rowStep = tileH + app.Scale(6);
        int ek = app.window.EventKind();
        int ft = lo;
        int col = 0;
        while (ft < hi) {
            int bx = ix + col * (tileW + gapx);
            // Only draw / hit-test tiles that fit fully inside the palette body;
            // the clip doesn't contain child widgets, so partial tiles are culled.
            if (PalVisible(app, iy, tileH)) {
                if (!preview && ek == 2 && !dragging
                    && InRect(app.mouseX, app.mouseY, bx, iy, tileW, tileH)) {
                    dragging = true;
                    dragFromPalette = true;
                    dragMoved = false;
                    dragKind = ft;
                    dragMouseX = app.mouseX;
                    dragMouseY = app.mouseY;
                }
                Button b = Button.WithIcon("", FieldIcon(ft));
                b.SetSize(2);
                int id = b.Render(app, bx, iy, tileW);
                if (Button.WasClicked(app, id) && !dragMoved) { AddField(ft); }
                if (!dragging && InRect(app.mouseX, app.mouseY, bx, iy, tileW, tileH)) {
                    hoverFt = ft;
                    hoverX = ix + iw + app.Scale(10);
                    hoverY = iy;
                    app.RequestRedraw();
                }
            }
            col = col + 1;
            if (col == cols) { col = 0; iy = iy + rowStep; }
            ft = ft + 1;
        }
        if (col != 0) { iy = iy + rowStep; }
        return iy + app.Scale(10);
    }

    bool InRect(int mx, int my, int x, int y, int w, int h) {
        return mx >= x && mx <= x + w && my >= y && my <= y + h;
    }

    /// True when a palette element of the given height fits fully inside the
    /// palette body. The canvas clip alone doesn't contain child widgets here,
    /// so tiles that would straddle the edge are culled instead of drawn.
    bool PalVisible(App app, int yy, int h) {
        return yy >= palClipTop && yy + h <= palClipBot;
    }

    /// True when a form element of the given height fits fully inside the form
    /// body. Like the palette, rows that would straddle the edge are culled.
    bool FormVisible(int yy, int h) {
        return yy >= formClipTop && yy + h <= formClipBot;
    }

    /// Total pixel height of the form preview (header + all rows + submit bar),
    /// mirroring RenderForm's layout so the scroll offset can be clamped.
    int FormContentH(App app) {
        int pad = app.Scale(14);
        int h = pad + app.Scale(24) + app.Scale(10);
        int n = fields.Count;
        int i = 0;
        while (i < n) {
            int cols = 0;
            int rowEnd = i;
            while (rowEnd < n) {
                int sp = ClampSpan(fields[rowEnd].span);
                if (rowEnd > i && cols + sp > 24) { break; }
                cols = cols + sp;
                rowEnd = rowEnd + 1;
                if (cols >= 24) { break; }
            }
            int rowH = 0;
            int k = i;
            while (k < rowEnd) {
                int hk = FieldHeight(app, fields[k]);
                if (labelPos == 2 && !fields[k].IsDisplay()) { hk = hk + app.Scale(18); }
                if (hk > rowH) { rowH = hk; }
                k = k + 1;
            }
            h = h + rowH + app.Scale(6);
            i = rowEnd;
        }
        if (showSubmit || showReset) { h = h + app.Scale(4) + app.Scale(36); }
        return h + pad;
    }

    /// Clamp a field's column span into the valid 1..24 grid range.
    int ClampSpan(int sp) {
        if (sp < 1) { return 24; }
        if (sp > 24) { return 24; }
        return sp;
    }

