using System;

namespace Platform;

/// <summary>
/// POSIX API bindings via DllImport.
/// Usage: Posix.write(1, "Hello\n", 6);
/// </summary>
class Posix {
    // libc
    [DllImport("c")]
    static extern int open(string path, int flags);

    [DllImport("c")]
    static extern int close(int fd);

    [DllImport("c")]
    static extern int read(int fd, string buf, int count);

    [DllImport("c")]
    static extern int write(int fd, string buf, int count);

    [DllImport("c")]
    static extern int unlink(string path);

    [DllImport("c")]
    static extern int mkdir(string path, int mode);

    [DllImport("c")]
    static extern int rmdir(string path);

    [DllImport("c")]
    static extern int getpid();

    [DllImport("c")]
    static extern int getuid();

    [DllImport("c")]
    static extern int sleep(int seconds);

    [DllImport("c")]
    static extern int puts(string str);

    [DllImport("c")]
    static extern int system(string command);
}
