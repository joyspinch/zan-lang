using System;

namespace Gui;

class App {
    Window window;
    Canvas canvas;
    Theme theme;
    FocusManager focus;
    HitTester hitTester;
    bool isRunning;
    bool needsRedraw;
    int frameCount;
    int mouseX;
    int mouseY;
    int scrollY;
    int contentHeight;
    int scrollSpeed;
    int dpiScale;
    int titlebarH;
    int captionBtnW;
    int splitX;
    int sidebarScrollY;
    int sidebarContentHeight;
    bool isDark;
    bool isTopmost;
    bool showThemeButton;
    bool showPinButton;
    bool showMinimizeButton;
    bool showMaximizeButton;
    // Title-bar theme picker. When themeNames is non-empty the theme caption
    // button opens a dropdown menu listing these presets (a "color" glyph)
    // instead of toggling dark/light; themeMenuChange fires on a new pick and
    // themeMenuModel carries the chosen index. The option ids live in a stable
    // high WidgetId block so they never collide with the caption button ids.
    List<string> themeNames;
    SignalInt themeMenuModel;
    SignalBool themeMenuOpen;
    SignalInt themeMenuScroll;
    int themeMenuBaseId;
    UiEvent themeMenuChange;
    // Built-in skin switching: when autoSkins is on the title-bar theme button
    // is a menu of Theme.PresetNames and App applies the picked preset itself
    // (no per-app handler). appliedSkin is the index last applied so RenderChrome
    // detects a new pick each frame. Every window gets this by default.
    bool autoSkins;
    int appliedSkin;
    // True while the OS is compositing a real translucent backdrop (Win11
    // acrylic / macOS vibrancy / Linux compositor blur) behind this window.
    // Set by ApplyTheme when a glass skin is active. When on, the frame is
    // cleared transparent and the in-app wallpaper is skipped so the blurred
    // desktop shows through the gaps.
    bool glassNative;
    // Rect (in canvas coords) that wants to consume mouse-wheel events this
    // frame â€?e.g. a DataTable body with its own internal row scroll. When the
    // pointer is inside it, ProcessEvent suppresses page scrolling so the wheel
    // drives the widget instead. Reset every frame in BeginFrame.
    int wheelCapX;
    int wheelCapY;
    int wheelCapW;
    int wheelCapH;
    int wheelClaimSeq;
    int wheelCapOrder;
    int wheelOwnerOrder;
    bool blocksInputBelow;
    bool inputBlockPrevious;

    // --- Event delegation ---
    // Target of the current mouse event, resolved once per event in
    // ProcessEvent against the PREVIOUS frame's complete hit regions (which
    // already include popups/overlays on top). Widgets ask Ui.Clicked/Pressed
    // whether they are this target, so a click is delivered to exactly one
    // widget â€?the top-most one under the pointer â€?instead of every widget
    // that happens to re-read the raw event during its own render.
    int clickTargetId;
    int pressTargetId;
    // Secondary (right) mouse-button targets, resolved the same way as the
    // primary click/press targets but kept separate so a right-click never
    // trips Ui.Clicked or steals keyboard focus. Read via RightClickTarget()
    // / RightPressTarget() (see Ui.RightClicked).
    int rightClickTargetId;
    int rightPressTargetId;
    // Double-click / double-tap detection. lastClickId + lastClickMs record the
    // most recent completed click; doubleClickNow is a one-frame flag set when a
    // second click lands on the same id within the double-click window. Read via
    // DoubleClickNow() / Ui.DoubleClicked.
    int lastClickId;
    int lastClickMs;
    bool doubleClickNow;
    // Touch/pointer gesture state. On a press we snapshot the target id, the
    // pointer position and the wall-clock time; on release we derive a swipe
    // direction from the travel, and while held PollLongPress() reports a
    // long-press once the hold passes the threshold without much movement.
    // Single-finger touch arrives as a synthesized mouse sequence, so these
    // work on touchscreens without any runtime change (multi-touch/pinch would
    // need real WM_TOUCH / XInput2 support in the C runtime).
    int pressStartX;
    int pressStartY;
    int pressStartMs;
    int pressStartId;
    bool longPressFired;
    int swipeDir;
    // Deferred overlay popups (Select/SelectBox/Dropdown/Menu option lists).
    // They run AFTER the main content pass so they both paint above it and
    // register their hit regions last (making them the top-most target). Data,
    // not callbacks, because Zan delegates can't capture locals / bind `this`.
    // Collected during a frame, drained by RunOverlays, cleared in BeginFrame.
    List<OverlayPopup> overlays;

    // --- Animation clock ---
    // Per-key tween state. Widgets call AnimTo()/AnimPx() each frame with a
    // target; the value eases toward it and keeps requesting redraws until it
    // settles, giving smooth transitions on an otherwise event-driven loop.
    // AnimTo is *time-based*: progress = (now - start) / duration, so it is
    // immune to per-frame dt jitter (which used to make the motion stutter).
    // Columns are index-aligned: key / current value / target / tween-start
    // value / tween-start time (ms) / duration (ms).
    List<int> animKeys;
    List<int> animVals;
    List<int> animTarget;
    List<int> animFrom;
    List<int> animStart;
    List<int> animDur;
    int nowMs;
    int lastFrameMs;
    int lastPresentMs;
    // Wall-clock deadline (ms) at which a *throttled* animation wants its next
    // repaint, or -1 when none is pending. Looping animations (e.g. a loading
    // spinner) register here via RequestAnimationFrame instead of
    // RequestRedraw, so the event loop sleeps between frames and repaints them
    // at a low cadence rather than busy-rendering the whole page at 60fps.
    int animNextMs;

    // True when the current frame processed a real OS event (input, resize,
    // etc). A pure animation repaint (spinner tick, easing step) wakes with no
    // event, leaving the backdrop behind glass unchanged so its blur/wallpaper
    // can be served from cache. See BackdropDirty().
    bool backdropDirty;

    // Per-frame counter handing each glass surface a stable blur-cache slot in
    // draw order. Reset in BeginFrame; incremented by NextBlurSlot().
    int blurSlotSeq;

    // Wallpaper-backdrop cache invalidation. The gradient + soft colour blobs
    // are static: they depend only on the window size and the active skin, not
    // on content/scroll/typing. bgThemeGen bumps on every theme change; the
    // backdrop snapshot records the gen it was painted with (bgSnapGen) so it
    // is restored with a cheap pixel copy on EVERY frame (not just non-dirty
    // ones) until the size or skin actually changes. Repainting the ~80 large
    // feathered blobs each dirty frame is what made glass/gradient skins janky
    // while scrolling or typing.
    int bgThemeGen;
    int bgSnapGen;

    static App Create(string title, int width, int height) {
        App app = new App();
        app.window = Window.Create(title, width, height);
        app.theme = Theme.Light();
        app.focus = FocusManager.Create();
        app.hitTester = HitTester.Create();
        app.isRunning = true;
        app.needsRedraw = true;
        app.frameCount = 0;
        app.mouseX = 0;
        app.mouseY = 0;
        app.scrollY = 0;
        app.contentHeight = 0;
        app.scrollSpeed = 40;
        app.dpiScale = 100;
        app.titlebarH = 32;
        app.captionBtnW = 46;
        app.splitX = 0;
        app.sidebarScrollY = 0;
        app.sidebarContentHeight = 0;
        app.wheelCapX = 0;
        app.wheelCapY = 0;
        app.wheelCapW = 0;
        app.wheelCapH = 0;
        app.wheelClaimSeq = 0;
        app.wheelCapOrder = 0;
        app.wheelOwnerOrder = 0;
        app.blocksInputBelow = false;
        app.inputBlockPrevious = false;
        app.clickTargetId = -1;
        app.pressTargetId = -1;
        app.rightClickTargetId = -1;
        app.rightPressTargetId = -1;
        app.lastClickId = -1;
        app.lastClickMs = 0;
        app.doubleClickNow = false;
        app.pressStartX = 0;
        app.pressStartY = 0;
        app.pressStartMs = 0;
        app.pressStartId = -1;
        app.longPressFired = false;
        app.swipeDir = 0;
        app.overlays = new List<OverlayPopup>();
        app.isDark = false;
        app.isTopmost = false;
        app.showThemeButton = true;
        app.showPinButton = true;
        app.showMinimizeButton = true;
        app.showMaximizeButton = true;
        app.themeNames = new List<string>();
        app.themeMenuModel = SignalInt.Create(0);
        app.themeMenuOpen = SignalBool.Create(false);
        app.themeMenuScroll = SignalInt.Create(0);
        app.themeMenuBaseId = 0;
        app.themeMenuChange = UiEvent.Create();
        app.autoSkins = false;
        app.appliedSkin = -1;
        app.animKeys = new List<int>();
        app.animVals = new List<int>();
        app.animTarget = new List<int>();
        app.animFrom = new List<int>();
        app.animStart = new List<int>();
        app.animDur = new List<int>();
        app.nowMs = Window.GetTickMs();
        app.lastFrameMs = app.nowMs;
        app.lastPresentMs = 0;
        app.animNextMs = -1;
        app.backdropDirty = true;
        app.blurSlotSeq = 0;
        // gen != snapGen so the wallpaper is painted (and snapshotted) once up
        // front, then restored from cache until the skin/size changes.
        app.bgThemeGen = 1;
        app.bgSnapGen = 0;
        app.canvas = Canvas.Create(width, height);
        // Reset the UI-thread dispatch queue up front (on the UI thread) so
        // App.Post is safe the moment any background worker is spawned.
        Dispatcher.Init();
        // Every window gets the built-in skin picker in its title bar by
        // default (light window -> "Light" preselected). The id block is
        // allocated now, before any app WidgetId.Mark, so option ids stay
        // stable. Apps that persisted a skin just call EnableSkins(index).
        app.EnableSkins(1);
        return app;
    }

    static App CreateDark(string title, int width, int height) {
        App app = App.Create(title, width, height);
        app.theme = Theme.Dark();
        app.isDark = true;
        app.EnableSkins(0);
        return app;
    }

    /// Swaps the active theme (light/dark) and re-applies DPI scaling.
    void SetDark(bool dark) {
        isDark = dark;
        if (dark) { theme = Theme.Dark(); } else { theme = Theme.Light(); }
        theme.ScaleByDpi(dpiScale);
        needsRedraw = true;
    }

    /// Installs an arbitrary theme preset (re-applying DPI scaling). `dark`
    /// controls dark-appropriate chrome details (caption hover wash, etc.).
    void ApplyTheme(Theme t, bool dark) {
        isDark = dark;
        theme = t;
        theme.ScaleByDpi(dpiScale);
        // Frosted glass is rendered in-app: a software blur over the themed
        // wallpaper on an opaque window. A native OS-acrylic (layered) window
        // was tried but it altered the look and made the window resize itself
        // (UpdateLayeredWindow drove the window size), so glass skins stay
        // software-rendered here. Always drop any layered style if it was set.
        if (glassNative) { window.DisableGlass(); }
        glassNative = false;
        bgThemeGen = bgThemeGen + 1;
        needsRedraw = true;
    }

    /// Packed ARGB tint handed to the OS glass compositor: the active skin's
    /// primary background colour at ~59% alpha so the blurred desktop keeps
    /// colour and body presence while text stays readable.
    int GlassTint() {
        int rgb = theme.bgPrimary % 16777216;
        if (rgb < 0) { rgb = rgb + 16777216; }
        return 150 * 16777216 + rgb;
    }

    /// Turns the title-bar theme button into the built-in skin picker
    /// (Theme.PresetNames) and has App apply the chosen preset itself â€?no
    /// per-app change handler or switch statement. Every window enables this by
    /// default (see Create); call again to preselect a persisted skin. `index`
    /// must be the skin whose theme is already active so the first frame does
    /// not re-apply it. Idempotent: the stable id block is allocated once.
    void EnableSkins(int index) {
        autoSkins = true;
        themeNames = Theme.PresetNames();
        if (themeMenuBaseId == 0) {
            themeMenuBaseId = WidgetId.Block(themeNames.Count);
        }
        themeMenuModel.Set(index);
        appliedSkin = index;
        showThemeButton = true;
        window.SetCaptionButtons(ChromeButtonCount());
        needsRedraw = true;
    }

    void EnableSkins() { this.EnableSkins(0); }

    /// Applies built-in skin `i` (Theme.PresetAt) with its dark-chrome flag and
    /// records it as the active skin so the picker stays in sync.
    void ApplySkin(int i) {
        this.ApplyTheme(Theme.PresetAt(i), Theme.PresetDark(i));
        themeMenuModel.Set(i);
        appliedSkin = i;
    }

    /// When the built-in skin picker's selection changed (user pick), applies
    /// it. Called each frame start so content and chrome repaint together.
    void SyncSkin() {
        if (autoSkins && themeMenuModel.Get() != appliedSkin) {
            this.ApplySkin(themeMenuModel.Get());
        }
    }

    // ---- themed window backdrop (built-in, shared by every window) ---------
    // The wallpaper that makes gradient/glass/neon skins read as real: a
    // vertical gradient plus soft colour blobs the frosted panels blur. Lives
    // in the framework so the IDE, the gallery and any window render identical
    // skins â€?apps just call RenderBackground behind their content.

    /// One soft wallpaper glow: nested translucent disks feathering to a bright
    /// centre (no hard rim), giving the backdrop blur real colour to soften.
    void BackdropBlob(int cx, int cy, int r, int cr, int cg, int cb) {
        Canvas c = canvas;
        // Smooth radial feather instead of a few hard rings: many faint,
        // equal-alpha concentric steps from the rim inward. Coverage rises
        // gently toward the centre, so overlaps blend into one soft light
        // bloom (no visible "target" rings) and stays light/airy.
        int steps = 20;
        int i = steps;
        while (i > 0) {
            int rr = r * i / steps;
            c.FillCircle(cx, cy, rr, Theme.Rgba(cr, cg, cb, 9));
            i = i - 1;
        }
    }

    /// A soft glow coloured from a packed ARGB theme accent.
    void BackdropDrift(int cx, int cy, int r, int color) {
        int cr = (color / 65536) % 256;
        int cg = (color / 256) % 256;
        int cb = color % 256;
        this.BackdropBlob(cx, cy, r, cr, cg, cb);
    }

    /// Colour blobs from the theme's own accents over the vertical gradient
    /// (non-glass gradient presets) so the ramp reads as a wallpaper.
    void BackdropGradientWallpaper(int ax, int ay, int aw, int ah) {
        Theme t = theme;
        int r = this.Scale(340);
        this.BackdropDrift(ax + aw * 20 / 100, ay + ah * 24 / 100, r, t.primary);
        this.BackdropDrift(ax + aw * 74 / 100, ay + ah * 18 / 100, r, t.info);
        this.BackdropDrift(ax + aw * 82 / 100, ay + ah * 72 / 100, r, t.success);
        this.BackdropDrift(ax + aw * 30 / 100, ay + ah * 84 / 100, r, t.error);
    }

    /// iOS-style multi-colour wallpaper for the frosted-glass presets.
    void BackdropGlassWallpaper(int ax, int ay, int aw, int ah) {
        this.BackdropBlob(ax + aw * 14 / 100, ay + ah * 20 / 100,
            this.Scale(320), 128, 96, 245);
        this.BackdropBlob(ax + aw * 40 / 100, ay + ah * 34 / 100,
            this.Scale(300), 236, 120, 175);
        this.BackdropBlob(ax + aw * 78 / 100, ay + ah * 16 / 100,
            this.Scale(320), 96, 156, 255);
        this.BackdropBlob(ax + aw * 62 / 100, ay + ah * 72 / 100,
            this.Scale(340), 240, 112, 196);
        this.BackdropBlob(ax + aw * 30 / 100, ay + ah * 86 / 100,
            this.Scale(300), 96, 222, 208);
        this.BackdropBlob(ax + aw * 90 / 100, ay + ah * 58 / 100,
            this.Scale(280), 156, 120, 250);
    }

    /// Paints the active skin's window backdrop into [x,y,w,h]: a gradient +
    /// soft colour blobs for gradient/glass presets (so frosted panels blur
    /// real colour), otherwise a flat bgPrimary fill. Cached per redraw â€?
    /// animation-only frames restore the pixels with one copy instead of
    /// repainting the (expensive) blobs. `slot` is a snapshot cache slot the
    /// caller reserves for its backdrop.
    void RenderBackground(int x, int y, int w, int h, int slot) {
        Canvas c = canvas;
        Theme t = theme;
        // Native glass: the window is a flat semi-transparent sheet (cleared in
        // BeginFrame) over the OS-blurred desktop. Add a soft top-down light
        // sheen so the glass reads with depth (brighter near the top) like real
        // acrylic instead of a flat slab.
        if (glassNative) {
            int hi = t.textPrimary % 16777216;
            if (hi < 0) { hi = hi + 16777216; }
            int bands = 18;
            int bh = h / 3 / bands;
            if (bh < 1) { bh = 1; }
            int i = 0;
            while (i < bands) {
                int a = 15 - (15 * i / bands);
                c.FillRect(x, y + i * bh, w, bh, a * 16777216 + hi);
                i = i + 1;
            }
            return;
        }
        if (t.gradient != 0) {
            // The wallpaper (gradient + soft blobs) is static per skin+size, so
            // restore it from the snapshot on every frame -- including dirty
            // ones -- as long as the skin generation matches. Only a skin change
            // (bgThemeGen bumped) or a resize (RestoreRect geometry mismatch)
            // forces the expensive repaint. This keeps glass/gradient skins
            // smooth while scrolling or typing instead of re-blobbing per frame.
            bool restored = false;
            if (bgSnapGen == bgThemeGen) {
                restored = c.RestoreRect(x, y, w, h, slot);
            }
            if (!restored) {
                c.FillVGrad(x, y, w, h, t.bgGradTop, t.bgGradBottom);
                if (t.glass != 0) {
                    this.BackdropGlassWallpaper(x, y, w, h);
                } else {
                    this.BackdropGradientWallpaper(x, y, w, h);
                }
                c.SnapshotRect(x, y, w, h, slot);
                bgSnapGen = bgThemeGen;
            }
        } else {
            c.FillRect(x, y, w, h, t.bgPrimary);
        }
    }

    int ChromeButtonCount() {
        int count = 1;
        if (showThemeButton) { count = count + 1; }
        if (showPinButton) { count = count + 1; }
        if (showMinimizeButton) { count = count + 1; }
        if (showMaximizeButton) { count = count + 1; }
        return count;
    }

    void SetChromeButtons(
        bool themeButton,
        bool pinButton,
        bool minimizeButton,
        bool maximizeButton
    ) {
        showThemeButton = themeButton;
        showPinButton = pinButton;
        showMinimizeButton = minimizeButton;
        showMaximizeButton = maximizeButton;
        window.SetCaptionButtons(ChromeButtonCount());
        needsRedraw = true;
    }

    /// Turns the title-bar theme caption button into a dropdown menu that lists
    /// `names` (e.g. skin presets) instead of a plain dark/light toggle, and
    /// keeps it in the ORIGINAL caption-button slot so it stays non-draggable.
    /// Add a handler to the returned event to react to a pick, then read
    /// ThemeMenuIndex(). Call once, before WidgetId.Mark(), so the option-id
    /// block is stable for the app's lifetime.
    UiEvent SetThemeMenu(List<string> names, int index) {
        themeNames = names;
        themeMenuModel.Set(index);
        themeMenuBaseId = WidgetId.Block(names.Count);
        showThemeButton = true;
        window.SetCaptionButtons(ChromeButtonCount());
        needsRedraw = true;
        return themeMenuChange;
    }

    /// True when the title-bar theme button acts as a preset menu.
    bool ThemeMenuMode() { return themeNames.Count > 0; }

    /// Index currently selected in the title-bar theme menu.
    int ThemeMenuIndex() { return themeMenuModel.Get(); }

    /// Sync the menu selection without firing the change event (deep links).
    void SetThemeMenuIndex(int i) {
        themeMenuModel.Set(i);
        needsRedraw = true;
    }

    void Show() {
        window.Show();
        int realW = window.GetWidth();
        int realH = window.GetHeight();
        if (realW != canvas.Width() || realH != canvas.Height()) {
            canvas.Destroy();
            canvas = Canvas.Create(realW, realH);
        }
        dpiScale = Canvas.GetDpiScale();
        theme.ScaleByDpi(dpiScale);
        scrollSpeed = 40 * dpiScale / 100;
        titlebarH = Window.TitlebarHeight();
        captionBtnW = Window.CaptionButtonWidth();
        if (titlebarH < 24) { titlebarH = Scale(32); }
        if (captionBtnW < 24) { captionBtnW = Scale(46); }
        window.SetCaptionButtons(ChromeButtonCount());
    }

    /// Shows the window and runs the standard event loop until it closes,
    /// painting just the title-bar chrome each frame. A one-call convenience
    /// for simple windows; to draw your own content, drive the
    /// BeginFrame / RenderChrome / PresentFrame loop directly instead.
    void Run(string title) {
        Show();
        while (isRunning) {
            if (!ProcessEvent()) { break; }
            if (!needsRedraw) { continue; }
            BeginFrame();
            RenderChrome(title);
            PresentFrame();
        }
    }

    /// Height reserved by the custom title bar; content should start below it.
    int ContentTop() {
        return titlebarH;
    }

    /// Draws the borderless-window title bar (brand + drag area + min/max/close
    /// caption buttons) and processes clicks on the caption buttons. Should be
    /// drawn last each frame so it overlays content.
    void RenderChrome(string title) {
        Canvas c = canvas;
        Theme t = theme;
        int W = c.Width();
        int hbar = titlebarH;

        // Under the frosted-glass skin the title bar frosts the content behind
        // it too (blur + translucent themed tint + faint white sheen), so the
        // chrome matches the glass body instead of sitting on a flat opaque bar.
        if (t.glass != 0) {
            c.BlurRectCached(0, 0, W, hbar, Scale(22),
                NextBlurSlot(), BackdropDirty());
            c.FillRect(0, 0, W, hbar, 200 * 16777216 + (t.bgSecondary % 16777216));
            c.FillRect(0, 0, W, hbar, 26 * 16777216 + (t.textPrimary % 16777216));
        } else {
            c.FillRect(0, 0, W, hbar, t.bgSecondary);
        }
        c.FillRect(0, hbar - 1, W, 1, t.divider);

        int pad = t.paddingLarge;
        int brand = t.iconSizeSmall;
        Icon.Draw(c, "home", pad, (hbar - brand) / 2, brand, t.primary);
        int txtY = (hbar - Canvas.FontHeight(t.fontSizeMedium)) / 2;
        c.DrawText(pad + brand + t.gapSmall, txtY, title, t.textPrimary, t.fontSizeMedium);

        int bw = captionBtnW;
        int closeX = W - bw;
        int nextX = closeX;
        int maxX = -bw;
        int minX = -bw;
        int pinX = -bw;
        int themeX = -bw;
        if (showMaximizeButton) { nextX = nextX - bw; maxX = nextX; }
        if (showMinimizeButton) { nextX = nextX - bw; minX = nextX; }
        if (showPinButton) { nextX = nextX - bw; pinX = nextX; }
        if (showThemeButton) { nextX = nextX - bw; themeX = nextX; }

        int themeId = focus.AllocId();
        int pinId = focus.AllocId();
        int minId = focus.AllocId();
        int maxId = focus.AllocId();
        int closeId = focus.AllocId();

        bool themeH = focus.IsHovered(themeId);
        bool pinH = focus.IsHovered(pinId);
        bool minH = focus.IsHovered(minId);
        bool maxH = focus.IsHovered(maxId);
        bool closeH = focus.IsHovered(closeId);

        // Caption hover wash follows the active theme's own hover token so the
        // window controls stay coordinated with every skin (a translucent wash
        // over glass/gradient, the themed grey on light/dark) instead of a
        // fixed grey. Close keeps the signature Windows red.
        int capHover = t.bgHover;
        int closeRed = 0xFFE81123;
        if (showThemeButton && themeH) {
            c.FillRect(themeX, 0, bw, hbar, capHover);
        }
        if (showPinButton && pinH) {
            c.FillRect(pinX, 0, bw, hbar, capHover);
        }
        if (showMinimizeButton && minH) {
            c.FillRect(minX, 0, bw, hbar, capHover);
        }
        if (showMaximizeButton && maxH) {
            c.FillRect(maxX, 0, bw, hbar, capHover);
        }
        if (closeH) { c.FillRect(closeX, 0, bw, hbar, closeRed); }

        // Caption glyphs render at the small "caption" size (~11px) that Windows
        // and WeChat use â€?thin and crisp rather than chunky â€?and are centered
        // in each 46-wide button for a refined, balanced title bar.
        int gl = (t.iconSizeCaption * 33) / 25;
        int gcolor = t.textSecondary;

        // Theme control: a "color" palette glyph when it opens a preset menu,
        // otherwise the classic sun/moon dark-light toggle.
        int themeColor = gcolor;
        if (themeH || (this.ThemeMenuMode() && themeMenuOpen.Get())) {
            themeColor = t.textPrimary;
        }
        string themeIcon = "moon";
        if (isDark) { themeIcon = "sun"; }
        if (this.ThemeMenuMode()) { themeIcon = "color"; }
        if (showThemeButton) {
            Icon.DrawCenteredIn(
                c, themeIcon, themeX, 0, bw, hbar, gl, themeColor);
        }

        // Pin (always-on-top): accent color + filled glyph when active.
        int pinColor = gcolor;
        if (pinH) { pinColor = t.textPrimary; }
        string pinIcon = "pin";
        if (isTopmost) { pinIcon = "unpin"; pinColor = t.primary; }
        if (showPinButton) {
            Icon.DrawCenteredIn(
                c, pinIcon, pinX, 0, bw, hbar, gl, pinColor);
        }

        int minColor = gcolor;
        if (minH) { minColor = t.textPrimary; }
        if (showMinimizeButton) {
            Icon.DrawCenteredIn(
                c, "minimize", minX, 0, bw, hbar, gl, minColor);
        }

        string maxName = "maximize";
        if (window.IsMaximized()) { maxName = "restore"; }
        int maxColor = gcolor;
        if (maxH) { maxColor = t.textPrimary; }
        if (showMaximizeButton) {
            Icon.DrawCenteredIn(
                c, maxName, maxX, 0, bw, hbar, gl, maxColor);
        }

        int xcolor = gcolor;
        if (closeH) { xcolor = 0xFFFFFFFF; }
        Icon.DrawCenteredIn(c, "close", closeX, 0, bw, hbar, gl, xcolor);

        if (showThemeButton) {
            hitTester.Register(
                HitRegion.Create(themeId, themeX, 0, bw, hbar, 3));
        }
        if (showPinButton) {
            hitTester.Register(
                HitRegion.Create(pinId, pinX, 0, bw, hbar, 3));
        }
        if (showMinimizeButton) {
            hitTester.Register(
                HitRegion.Create(minId, minX, 0, bw, hbar, 3));
        }
        if (showMaximizeButton) {
            hitTester.Register(
                HitRegion.Create(maxId, maxX, 0, bw, hbar, 3));
        }
        hitTester.Register(HitRegion.Create(closeId, closeX, 0, bw, hbar, 3));

        if (window.EventKind() == 3) {
            int hit = hitTester.HitTest(mouseX, mouseY);
            if (showThemeButton && hit == themeId) {
                if (this.ThemeMenuMode()) {
                    if (!themeMenuOpen.Get()) { themeMenuScroll.Set(0); }
                    themeMenuOpen.Set(!themeMenuOpen.Get());
                    needsRedraw = true;
                } else {
                    SetDark(!isDark);
                }
            } else if (showPinButton && hit == pinId) {
                isTopmost = !isTopmost;
                window.SetTopmost(isTopmost);
                needsRedraw = true;
            } else if (showMinimizeButton && hit == minId) {
                window.Minimize();
            } else if (showMaximizeButton && hit == maxId) {
                window.ToggleMaximize();
            } else if (hit == closeId) {
                window.Close();
            }
        }

        // A native-glass (layered) window has no OS drop-shadow, so its edge can
        // vanish into a similar wallpaper. Stroke a subtle rim around the whole
        // window plus a brighter top highlight so the bounds stay clear.
        if (glassNative) {
            int H = c.Height();
            c.DrawRect(0, 0, W, H, 130 * 16777216 + (t.textPrimary % 16777216), 1);
            c.FillRect(0, 0, W, 1, 70 * 16777216 + (t.textPrimary % 16777216));
        }

        // Defer the preset menu to the overlay layer so it drops above all
        // content and its option hit regions win the z-order. Right-align the
        // menu under the caption button; nudge it in if it would clip the edge.
        if (this.ThemeMenuMode() && themeMenuOpen.Get()) {
            int menuW = Scale(168);
            int mx = themeX + bw - menuW;
            if (mx < Scale(4)) { mx = Scale(4); }
            int my = hbar + Scale(2);
            AddOverlay(OverlayPopup.OptionList(mx, my, menuW, themeNames,
                themeMenuBaseId, themeMenuModel, themeId, themeMenuOpen,
                themeMenuScroll, themeMenuChange));
        }
    }

    void RequestRedraw() {
        needsRedraw = true;
    }

    /// Requests a *throttled* repaint for a looping animation: the next frame
    /// is scheduled at most `minIntervalMs` from now, and the event loop sleeps
    /// (idle, no CPU) until then instead of busy-rendering at 60fps. Unlike
    /// RequestRedraw this does not force an immediate frame, so a permanently
    /// animating widget (a spinner, a skeleton shimmer) repaints the page at a
    /// low cadence. An earlier deadline always wins if several animations are
    /// live in the same frame. Input still wakes the loop promptly.
    void RequestAnimationFrame(int minIntervalMs) {
        int due = Window.GetTickMs() + minIntervalMs;
        if (animNextMs < 0 || due < animNextMs) { animNextMs = due; }
    }

    /// True when the content behind glass surfaces may have changed this frame
    /// (any OS input / resize / theme), false when the frame is a pure
    /// animation tick over an unchanged backdrop. Glass surfaces pass this to
    /// Canvas.BlurRectCached so spinners/toasts reuse the cached blur.
    bool BackdropDirty() {
        return backdropDirty;
    }

    void ReuseBackdrop() {
        backdropDirty = false;
    }

    bool PointerPressed() {
        return focus.pressedId >= 0;
    }

    /// Hands out the next stable per-frame blur-cache slot (draw order). Slots
    /// beyond the cache capacity fall back to an uncached blur.
    int NextBlurSlot() {
        int s = blurSlotSeq;
        blurSlotSeq = blurSlotSeq + 1;
        if (s > 63) { return -1; }
        return s;
    }

    /// Report the focused text widget's caret (client-area px) so the IME
    /// composition/candidate window follows the cursor instead of pinning to
    /// the window origin. Called each frame by Input/TextArea while focused.
    void SetImeCaret(int x, int y) {
        Ime.SetCaret(x, y);
    }

    /// <summary>
    /// Marshals a delegate onto this window's UI thread â€?the equivalent of
    /// C#'s <c>Control.Invoke</c>/<c>BeginInvoke</c>. Safe to call from any
    /// thread: the delegate is queued (under an OS mutex in the runtime) and
    /// runs on the UI thread at the start of the next frame, after which a
    /// repaint is requested. A background worker uses this to hand results back
    /// without touching UI state off-thread.
    /// </summary>
    void Post(Action handler) {
        Dispatcher.Post(handler);
        // Wake the loop if it is blocked in WaitEvent so the queued work runs
        // promptly instead of waiting for the next input event.
        window.Wake();
    }

    /// <summary>
    /// Runs every delegate queued via <see cref="Post"/> on the UI thread and
    /// requests a repaint if any ran. Called automatically each event-loop
    /// iteration by ProcessEvent; a hand-rolled loop can also call it directly.
    /// </summary>
    void DrainPosts() {
        Action handler = Dispatcher.Take();
        while (handler != null) {
            handler();
            needsRedraw = true;
            handler = Dispatcher.Take();
        }
    }

    /// Finds the row index for an animation key, or -1. Rows are appended by
    /// AnimTo/AnimPx and kept index-aligned across all six columns.
    int AnimIndex(int key) {
        int i = 0;
        while (i < animKeys.Count) {
            if (animKeys[i] == key) { return i; }
            i = i + 1;
        }
        return -1;
    }

    void AnimAdd(int key, int val, int target, int durMs) {
        animKeys.Add(key);
        animVals.Add(val);
        animTarget.Add(target);
        animFrom.Add(val);
        animStart.Add(nowMs);
        animDur.Add(durMs);
    }

    /// Time-based eased tween of a per-key value (permille, 0..1000) toward
    /// `target` over `durMs`, returning the *already eased* current value (do
    /// NOT wrap in Ease again). Progress is (now - start)/duration so motion is
    /// smooth regardless of frame-rate or timer granularity. Retargeting mid-
    /// flight restarts the tween from the current value. First sighting snaps.
    int AnimTo(int key, int target, int durMs) {
        int idx = AnimIndex(key);
        if (idx < 0) {
            AnimAdd(key, target, target, durMs);
            return target;
        }
        if (animTarget[idx] != target) {
            animFrom[idx] = animVals[idx];
            animTarget[idx] = target;
            animStart[idx] = nowMs;
            animDur[idx] = durMs;
        }
        int from = animFrom[idx];
        int tgt = animTarget[idx];
        if (from == tgt) { animVals[idx] = tgt; return tgt; }
        int dur = animDur[idx];
        if (dur < 1) { dur = 1; }
        int elapsed = nowMs - animStart[idx];
        if (elapsed < 0) { elapsed = 0; }
        int p = elapsed * 1000 / dur;
        if (p > 1000) { p = 1000; }
        int e = App.Ease(p);
        int val = from + (tgt - from) * e / 1000;
        animVals[idx] = val;
        if (p < 1000) { needsRedraw = true; } else { animVals[idx] = tgt; }
        return animVals[idx];
    }

    /// One-shot intro tween: eases a per-key value from 0 up to 1000 over
    /// `durMs` on first sighting, then holds at 1000. Unlike AnimTo (which snaps
    /// to its target on the first frame) this always plays the grow-in, so a
    /// chart, bar or card can animate up from its baseline the first time it is
    /// drawn. Keeps requesting repaints until it settles. Returns the eased
    /// 0..1000 progress.
    int AnimIntro(int key, int durMs) {
        int idx = AnimIndex(key);
        if (idx < 0) {
            animKeys.Add(key);
            animVals.Add(0);
            animTarget.Add(1000);
            animFrom.Add(0);
            animStart.Add(nowMs);
            animDur.Add(durMs);
            needsRedraw = true;
            return 0;
        }
        int from = animFrom[idx];
        int tgt = animTarget[idx];
        if (from == tgt) { animVals[idx] = tgt; return tgt; }
        int dur = animDur[idx];
        if (dur < 1) { dur = 1; }
        int elapsed = nowMs - animStart[idx];
        if (elapsed < 0) { elapsed = 0; }
        int p = elapsed * 1000 / dur;
        if (p > 1000) { p = 1000; }
        int e = App.Ease(p);
        int val = from + (tgt - from) * e / 1000;
        animVals[idx] = val;
        if (p < 1000) { needsRedraw = true; } else { animVals[idx] = tgt; }
        return animVals[idx];
    }

    /// Eases a per-key value toward `target` in arbitrary (pixel) space using
    /// exponential smoothing, so it works for any range (unlike AnimTo which is
    /// 0..1000). `tauMs` is the smoothing time constant (larger = slower). Used
    /// for e.g. a tab underline sliding between tabs of differing widths.
    int AnimPx(int key, int target, int tauMs) {
        int idx = AnimIndex(key);
        if (idx < 0) {
            AnimAdd(key, target, target, tauMs);
            return target;
        }
        int cur = animVals[idx];
        if (cur == target) { return cur; }
        int dt = nowMs - lastFrameMs;
        if (dt < 1) { dt = 1; }
        if (dt > 64) { dt = 64; }
        if (tauMs < 1) { tauMs = 1; }
        int f = dt * 1000 / (dt + tauMs);
        int delta = (target - cur) * f / 1000;
        if (delta == 0) {
            if (target > cur) { delta = 1; } else { delta = -1; }
        }
        int next = cur + delta;
        if (delta > 0 && next > target) { next = target; }
        if (delta < 0 && next < target) { next = target; }
        animVals[idx] = next;
        if (next != target) { needsRedraw = true; }
        return next;
    }

    /// Smoothstep (3t^2 - 2t^3) easing of a permille value for accel/decel.
    static int Ease(int p) {
        if (p <= 0) { return 0; }
        if (p >= 1000) { return 1000; }
        int t2 = p * p / 1000;
        int t3 = t2 * p / 1000;
        return 3 * t2 - 2 * t3;
    }

    /// Linear interpolation between a and b by permille p (0..1000).
    static int Lerp(int a, int b, int p) {
        return a + (b - a) * p / 1000;
    }

    /// Blend two packed RGB colors by permille p (0..1000), returning an opaque
    /// (0xFF alpha) color. Robust to colors stored as negative signed ints.
    static int LerpColor(int c0, int c1, int p) {
        // Packed 0xAARRGGBB colors are stored as signed ints, so any color with
        // a 0xFF alpha is negative. Extract the low 24 RGB bits with a floored
        // modulo first (truncating `c / 65536` would mis-decode negatives, e.g.
        // white -1 would read as pure blue), then split the positive value.
        int rgb0 = c0 % 16777216; if (rgb0 < 0) { rgb0 = rgb0 + 16777216; }
        int rgb1 = c1 % 16777216; if (rgb1 < 0) { rgb1 = rgb1 + 16777216; }
        int r0 = rgb0 / 65536;
        int g0 = (rgb0 / 256) % 256;
        int b0 = rgb0 % 256;
        int r1 = rgb1 / 65536;
        int g1 = (rgb1 / 256) % 256;
        int b1 = rgb1 % 256;
        int r = r0 + (r1 - r0) * p / 1000;
        int g = g0 + (g1 - g0) * p / 1000;
        int b = b0 + (b1 - b0) * p / 1000;
        return 4278190080 + r * 65536 + g * 256 + b;
    }

    /// Scales a packed color's existing alpha channel by permille p (0..1000),
    /// keeping its RGB. p=1000 returns the color unchanged; p=0 makes it fully
    /// transparent. Works for both opaque colors and ones that already carry an
    /// alpha (e.g. glass tokens), so a fill/overlay can fade in and out. Robust
    /// to the signed-int color packing (see LerpColor).
    static int ScaleAlpha(int color, int p) {
        if (p >= 1000) { return color; }
        if (p < 0) { p = 0; }
        int rgb = color % 16777216; if (rgb < 0) { rgb = rgb + 16777216; }
        int a = (color - rgb) / 16777216; if (a < 0) { a = a + 256; }
        a = a * p / 1000;
        return rgb + a * 16777216;
    }

    /// A scrollable widget calls this during render to claim the wheel while
    /// hovered. The last hovered claim is the owner on the next input frame, so
    /// a nested view consumes the wheel without also scrolling its parent.
    bool CaptureWheel(int x, int y, int w, int h) {
        bool inside = mouseX >= x && mouseX < x + w
            && mouseY >= y && mouseY < y + h;
        if (!inside) { return false; }
        wheelClaimSeq = wheelClaimSeq + 1;
        wheelCapX = x;
        wheelCapY = y;
        wheelCapW = w;
        wheelCapH = h;
        wheelCapOrder = wheelClaimSeq;
        return window.EventKind() == 13
            && wheelOwnerOrder == wheelClaimSeq;
    }

    void SetContentHeight(int h) {
        contentHeight = h;
    }

    int ViewportHeight() {
        return canvas.Height();
    }

    int Scale(int v) {
        return v * dpiScale / 100;
    }

    void SetTheme(Theme t) {
        theme = t;
        theme.ScaleByDpi(dpiScale);
        bgThemeGen = bgThemeGen + 1;
        needsRedraw = true;
    }

    bool ProcessEvent() {
        // If a repaint is already pending (e.g. a click handler changed state
        // mid-frame), don't block waiting for the next OS event â€?poll so the
        // new state paints immediately. Otherwise block until an event arrives.
        int result;
        if (needsRedraw) {
            // A repaint is pending (state change or an in-flight animation).
            // Cap the busy-poll to ~60fps so a running animation doesn't spin
            // the CPU at hundreds of fps; sleeping the remainder of the frame
            // budget also yields smoother, wall-clock-paced motion.
            int since = Window.GetTickMs() - lastPresentMs;
            if (lastPresentMs > 0 && since < 16) { Window.SleepMs(16 - since); }
            result = window.PollEvent();
        } else if (animNextMs >= 0) {
            // A throttled animation (e.g. a loading spinner) wants its next
            // frame at animNextMs. Sleep (idle) until then instead of busy-
            // rendering the whole page at 60fps, but poll in short slices so
            // OS input still wakes the loop promptly. When the deadline is
            // reached, flag a repaint and fall through with no pending event.
            result = 1;
            bool waiting = true;
            while (waiting) {
                int now = Window.GetTickMs();
                if (now >= animNextMs) {
                    needsRedraw = true;
                    waiting = false;
                } else {
                    int remain = animNextMs - now;
                    if (remain > 15) { remain = 15; }
                    Window.SleepMs(remain);
                    result = window.PollEvent();
                    if (result != 1) { waiting = false; }
                }
            }
        } else {
            result = window.WaitEvent();
        }
        if (result < 0) {
            isRunning = false;
            return false;
        }

        // Run any work marshalled from background threads on the UI thread.
        // A Wake() delivers an empty (kind 0) event solely to trigger this.
        DrainPosts();

        int kind = window.EventKind();

        // A pure animation repaint wakes with no OS event (kind 0): the content
        // behind glass is unchanged, so its blur + the static wallpaper can be
        // restored from cache. Any real event (input/resize/etc) marks the
        // backdrop dirty so it is recomputed this frame -- EXCEPT a pure hover
        // move (kind 1 with no button held). Moving the pointer never changes
        // the pixels behind glass: the wallpaper is static and hover highlights
        // paint on foreground widgets over the glass, not behind it. Re-blurring
        // the whole chrome every time the cursor crosses a widget is what made
        // the frosted theme feel sluggish, so hover reuses the cached blur +
        // wallpaper snapshot. A held drag (pressedId >= 0) may scroll/select
        // content behind glass, so it still dirties the backdrop.
        bool hoverOnly = (kind == 1) && (focus.pressedId < 0);
        backdropDirty = (kind != 0) && !hoverOnly;

        if (kind == 8) {
            isRunning = false;
            return false;
        }

        // Keep the render surface locked to the real window size. Maximize/restore
        // sends WM_SIZE synchronously (inside ShowWindow), and the one-shot resize
        // event can be cleared before we read it â€?so drive the surface from the
        // persistent window dimensions, not the transient kind==7 event. This
        // guarantees Present() blits 1:1 (never stretched/blurry) and that layout
        // + hit-testing use the same coordinate space as the mouse.
        int curW = window.GetWidth();
        int curH = window.GetHeight();
        if (curW > 0 && curH > 0) {
            if (curW != canvas.Width() || curH != canvas.Height()) {
                canvas.Destroy();
                canvas = Canvas.Create(curW, curH);
                // Clamp scroll to the new viewport instead of snapping to the
                // top â€?resizing shouldn't jump the user's scroll position.
                int viewH = curH - titlebarH;
                int maxScroll = contentHeight - viewH;
                if (maxScroll < 0) { maxScroll = 0; }
                if (scrollY > maxScroll) { scrollY = maxScroll; }
                if (scrollY < 0) { scrollY = 0; }
                needsRedraw = true;
            }
        }

        if (kind == 1) {
            mouseX = window.EventX();
            mouseY = window.EventY();
            int hitId = hitTester.HitTest(mouseX, mouseY);
            int oldHover = focus.hoveredId;
            focus.SetHovered(hitId);
            if (hitId != oldHover) {
                needsRedraw = true;
            }
            // While a widget is held (e.g. slider/scrollbar drag) keep repainting
            // as the pointer moves so the value tracks the cursor live.
            if (focus.pressedId >= 0) {
                needsRedraw = true;
            }
            int cursorId = hitId;
            if (focus.pressedId >= 0) { cursorId = focus.pressedId; }
            int wtype = hitTester.GetWidgetType(cursorId);
            if (wtype == 0) {
                Window.SetCursor(1);
            } else if (wtype == 1) {
                Window.SetCursor(2);
            } else if (wtype == 4) {
                Window.SetCursor(3);
            } else if (wtype == 5) {
                Window.SetCursor(4);
            } else {
                Window.SetCursor(0);
            }
        }

        if (kind == 2) {
            mouseX = window.EventX();
            mouseY = window.EventY();
            int hitId = hitTester.HitTest(mouseX, mouseY);
            if (window.EventButton() == 1) {
                // Secondary button: record the target for Ui.RightClicked but
                // leave the primary focus/press state untouched, so a right
                // click never steals keyboard focus or arms a primary click.
                rightPressTargetId = hitId;
            } else {
                focus.SetPressed(hitId);
                focus.SetFocused(hitId);
                pressTargetId = hitId;
                NotePressStart(hitId, mouseX, mouseY);
            }
            needsRedraw = true;
        }

        if (kind == 3) {
            mouseX = window.EventX();
            mouseY = window.EventY();
            int hitId = hitTester.HitTest(mouseX, mouseY);
            if (window.EventButton() == 1) {
                // Secondary button release: resolve the right-click target only;
                // the primary click target stays untouched so Ui.Clicked stays
                // quiet on a right click.
                rightClickTargetId = hitId;
            } else {
                // Resolve the click target against the still-intact previous-frame
                // hit regions (popups included, top-most wins) before BeginFrame
                // clears them, so exactly one widget sees Ui.Clicked this frame.
                clickTargetId = hitId;
                NoteRelease(mouseX, mouseY);
                NoteClickTarget(clickTargetId);
                focus.ClearPress();
            }
            needsRedraw = true;
        }

        // Tab / Shift+Tab move keyboard focus through the focusable ring built
        // last frame (see FocusManager.RegisterFocusable).
        if (kind == 4 && window.EventKeyCode() == 9) {
            if (!this.HasOverlays() && !blocksInputBelow) {
                int dir = 1;
                if (Modifiers.HasShift(window.EventMods())) { dir = -1; }
                focus.FocusStep(dir);
            }
            needsRedraw = true;
        }

        if (kind == 13) {
            int delta = window.EventKeyCode();
            int viewH = canvas.Height() - titlebarH;
            mouseX = window.EventX();
            mouseY = window.EventY();
            if (this.HasOverlays() || blocksInputBelow) {
                // Popups and modal scrims own this input frame. Let their
                // render path consume the wheel instead of moving content
                // underneath the floating surface.
                needsRedraw = true;
            } else if (splitX > 0 && mouseX < splitX) {
                // Scroll the sidebar when the pointer is over it.
                int oldS = sidebarScrollY;
                sidebarScrollY = sidebarScrollY - delta * scrollSpeed / 120;
                if (sidebarScrollY < 0) { sidebarScrollY = 0; }
                int maxS = sidebarContentHeight - viewH;
                if (maxS < 0) { maxS = 0; }
                if (sidebarScrollY > maxS) { sidebarScrollY = maxS; }
                if (sidebarScrollY != oldS) { needsRedraw = true; }
            } else if (mouseX >= wheelCapX && mouseX < wheelCapX + wheelCapW
                       && mouseY >= wheelCapY && mouseY < wheelCapY + wheelCapH) {
                // Pointer is over a widget that scrolls internally (e.g. the
                // DataTable body); let it handle the wheel during render instead
                // of scrolling the whole page.
                needsRedraw = true;
            } else {
                int oldScroll = scrollY;
                scrollY = scrollY - delta * scrollSpeed / 120;
                if (scrollY < 0) { scrollY = 0; }
                int maxScroll = contentHeight - viewH;
                if (maxScroll < 0) { maxScroll = 0; }
                if (scrollY > maxScroll) { scrollY = maxScroll; }
                if (scrollY != oldScroll) {
                    needsRedraw = true;
                }
            }
        }

        // Typed character (WM_CHAR) / key down: repaint so focused text fields
        // (e.g. the DataTable filter search box) can consume the keystroke this
        // frame. The event slot still holds the char for widgets to read.
        if (kind == 6 || kind == 4 || kind == 5) {
            needsRedraw = true;
        }

        return true;
    }

    /// Native handle of this app's window (for multi-window event routing).
    int WindowHandle() { return window.GetHandle(); }

    /// Applies the current, already-pumped native event to this window when the
    /// event originated from it (evHwnd == this window). This lets a single
    /// process drive several top-level windows (e.g. the IDE plus a floating
    /// dialog) from one shared event pump: the loop pumps once, reads the event
    /// hwnd, and offers the event to each App via ApplyEvent. Returns false if
    /// THIS window received a close event.
    bool ApplyEvent(int evHwnd) {
        bool mine = evHwnd == window.GetHandle();
        int kind = window.EventKind();
        backdropDirty = mine && kind != 0;

        if (mine && kind == 8) {
            isRunning = false;
            return false;
        }
        if (!mine) { return true; }

        int curW = window.ClientWidth();
        int curH = window.ClientHeight();
        if (curW > 0 && curH > 0) {
            if (curW != canvas.Width() || curH != canvas.Height()) {
                canvas.Destroy();
                canvas = Canvas.Create(curW, curH);
                int viewH = curH - titlebarH;
                int maxScroll = contentHeight - viewH;
                if (maxScroll < 0) { maxScroll = 0; }
                if (scrollY > maxScroll) { scrollY = maxScroll; }
                if (scrollY < 0) { scrollY = 0; }
                needsRedraw = true;
            }
        }

        if (kind == 1) {
            mouseX = window.EventX();
            mouseY = window.EventY();
            int hitId = hitTester.HitTest(mouseX, mouseY);
            int oldHover = focus.hoveredId;
            focus.SetHovered(hitId);
            if (hitId != oldHover) { needsRedraw = true; }
            if (focus.pressedId >= 0) { needsRedraw = true; }
            int cursorId = hitId;
            if (focus.pressedId >= 0) { cursorId = focus.pressedId; }
            int wtype = hitTester.GetWidgetType(cursorId);
            if (wtype == 0) { Window.SetCursor(1); }
            else if (wtype == 1) { Window.SetCursor(2); }
            else if (wtype == 4) { Window.SetCursor(3); }
            else if (wtype == 5) { Window.SetCursor(4); }
            else { Window.SetCursor(0); }
        }

        if (kind == 2) {
            mouseX = window.EventX();
            mouseY = window.EventY();
            int hitId = hitTester.HitTest(mouseX, mouseY);
            if (window.EventButton() == 1) {
                rightPressTargetId = hitId;
            } else {
                focus.SetPressed(hitId);
                focus.SetFocused(hitId);
                pressTargetId = hitId;
                NotePressStart(hitId, mouseX, mouseY);
            }
            needsRedraw = true;
        }

        if (kind == 3) {
            mouseX = window.EventX();
            mouseY = window.EventY();
            int hitId = hitTester.HitTest(mouseX, mouseY);
            if (window.EventButton() == 1) {
                rightClickTargetId = hitId;
            } else {
                clickTargetId = hitId;
                NoteRelease(mouseX, mouseY);
                NoteClickTarget(clickTargetId);
                focus.ClearPress();
            }
            needsRedraw = true;
        }

        if (kind == 4 && window.EventKeyCode() == 9) {
            if (!this.HasOverlays() && !blocksInputBelow) {
                int dir = 1;
                if (Modifiers.HasShift(window.EventMods())) { dir = -1; }
                focus.FocusStep(dir);
            }
            needsRedraw = true;
        }

        if (kind == 13) {
            mouseX = window.EventX();
            mouseY = window.EventY();
            int delta = window.EventKeyCode();
            int viewH = canvas.Height() - titlebarH;
            if (this.HasOverlays() || blocksInputBelow) {
                needsRedraw = true;
            } else if (mouseX >= wheelCapX && mouseX < wheelCapX + wheelCapW
                && mouseY >= wheelCapY && mouseY < wheelCapY + wheelCapH) {
                needsRedraw = true;
            } else {
                int oldScroll = scrollY;
                scrollY = scrollY - delta * scrollSpeed / 120;
                if (scrollY < 0) { scrollY = 0; }
                int maxScroll = contentHeight - viewH;
                if (maxScroll < 0) { maxScroll = 0; }
                if (scrollY > maxScroll) { scrollY = maxScroll; }
                if (scrollY != oldScroll) { needsRedraw = true; }
            }
        }

        if (kind == 6 || kind == 4 || kind == 5) { needsRedraw = true; }
        return true;
    }

    void PresentFrame() {
        // Draw + dispatch popups last so they sit above all content and own the
        // top-most hit regions (framework-owned overlay/z-order layer).
        RunOverlays();
        window.Present(canvas);
        frameCount = frameCount + 1;
        lastPresentMs = Window.GetTickMs();
        // Snapshot hover/focus/press as this frame's "previous" baseline so the
        // next rendered frame can detect enter/leave and focus/blur transitions
        // (Ui.Entered/Left/FocusGained/FocusLost).
        focus.RollFrame();
    }

    void BeginFrame() {
        // Apply a freshly-picked built-in skin before anything paints, so the
        // whole window (content + chrome) redraws in the new theme this frame.
        this.SyncSkin();
        // Advance the animation clock. AnimTo() uses (nowMs - lastFrameMs) as
        // the elapsed step so eases run at a wall-clock rate regardless of fps.
        lastFrameMs = nowMs;
        nowMs = Window.GetTickMs();
        // Clear the redraw flag at frame start; handlers invoked during this
        // frame may set it again to request an immediate follow-up repaint.
        needsRedraw = false;
        // Clear any throttled-animation deadline too; still-live animations
        // (spinners etc.) re-arm it via RequestAnimationFrame during render.
        animNextMs = -1;
        // Hand glass surfaces stable blur-cache slots again from the top.
        blurSlotSeq = 0;
        wheelOwnerOrder = wheelCapOrder;
        wheelClaimSeq = 0;
        wheelCapOrder = 0;
        wheelCapW = 0;
        wheelCapH = 0;
        inputBlockPrevious = blocksInputBelow;
        blocksInputBelow = false;
        hitTester.Clear();
        focus.ResetIds();
        overlays = new List<OverlayPopup>();
        if (glassNative) {
            // Frosted sheet: clear the whole window to a *semi-transparent* tint
            // (not fully transparent) so the OS backdrop shows through evenly
            // blurred while the window stays a solid, bordered glass panel. A
            // fully transparent clear left the window looking see-through/washed
            // (and borderless) over light backgrounds.
            int rgb = theme.bgPrimary % 16777216;
            if (rgb < 0) { rgb = rgb + 16777216; }
            canvas.Clear(198 * 16777216 + rgb);
        } else {
            canvas.Clear(theme.bgPrimary);
        }
    }

    /// Queues a popup to be painted and dispatched after the main content pass,
    /// so it sits above everything and owns the top-most hit regions. See
    /// <see cref="RunOverlays"/>.
    void AddOverlay(OverlayPopup p) {
        overlays.Add(p);
    }

    /// Draws + dispatches every overlay registered this frame, in registration
    /// order. Call once, right after the main render and before PresentFrame.
    void RunOverlays() {
        int i = 0;
        while (i < overlays.Count) {
            OverlayPopup p = overlays[i];
            p.Render(this);
            i = i + 1;
        }
    }

    /// True while a popup layer is active this frame.
    bool HasOverlays() { return overlays.Count > 0; }

    /// True while a modal overlay / popup scrim owns the pointer -- either this
    /// frame (a BlockHitsRect/BlockHitsBelow ran) or the previous one (the popup
    /// was already up). Immediate-mode widgets that read mouseX/mouseY directly
    /// must gate their hover/press/click on `!PointerCaptured()` so the pointer
    /// does not fall through the popup to the layer beneath it.
    bool PointerCaptured() { return blocksInputBelow || inputBlockPrevious; }

    /// Registers a hit region that swallows clicks over [x,y,w,h] so a modal /
    /// popup surface blocks the widgets beneath it. The HitTester is
    /// last-registered-wins and overlays paint after the page content, so
    /// calling this while drawing the backdrop -- and BEFORE the overlay's own
    /// buttons register -- makes the blocker win everywhere except on those
    /// buttons. Returns the blocker id.
    int BlockHitsRect(int x, int y, int w, int h) {
        int id = focus.AllocId();
        hitTester.Register(HitRegion.Create(id, x, y, w, h, -1));
        return id;
    }

    /// Full-window BlockHitsRect: the standard scrim for a modal overlay whose
    /// dimmed backdrop covers the whole window.
    int BlockHitsBelow() {
        bool firstBlock = !blocksInputBelow;
        blocksInputBelow = true;
        int id = BlockHitsRect(0, 0, canvas.Width(), canvas.Height());
        if (firstBlock && !inputBlockPrevious) { focus.SetFocused(id); }
        return id;
    }

    /// Id of the widget the current click (mouse-up) landed on, or -1.
    int ClickTarget() { return clickTargetId; }

    /// Id of the widget the current press (mouse-down) landed on, or -1.
    int PressTarget() { return pressTargetId; }

    /// Id of the widget the current secondary (right) click landed on, or -1.
    int RightClickTarget() { return rightClickTargetId; }

    /// Id of the widget the current secondary (right) press landed on, or -1.
    int RightPressTarget() { return rightPressTargetId; }

    /// True on the frame a completed click is the second of a double click on
    /// the same widget within the double-click window (see Ui.DoubleClicked).
    bool DoubleClickNow() { return doubleClickNow; }

    /// Records a completed click on `id` and flags a double click when it
    /// repeats on the same id within 400 ms. Called from the mouse-up paths.
    void NoteClickTarget(int id) {
        int t = Window.GetTickMs();
        if (id >= 0 && id == lastClickId && (t - lastClickMs) <= 400) {
            doubleClickNow = true;
        } else {
            doubleClickNow = false;
        }
        lastClickId = id;
        lastClickMs = t;
    }

    /// Snapshots the press target/position/time so gestures (swipe, long-press)
    /// can be derived from the press onward. Called from the mouse-down paths.
    void NotePressStart(int id, int x, int y) {
        pressStartId = id;
        pressStartX = x;
        pressStartY = y;
        pressStartMs = Window.GetTickMs();
        longPressFired = false;
        swipeDir = 0;
    }

    /// Derives a swipe direction from the press-to-release travel: 0 none,
    /// 1 left, 2 right, 3 up, 4 down. Called from the mouse-up paths, so it is
    /// valid to read (via SwipeDir) on a release frame.
    void NoteRelease(int x, int y) {
        int dx = x - pressStartX;
        int dy = y - pressStartY;
        int adx = dx; if (adx < 0) { adx = -adx; }
        int ady = dy; if (ady < 0) { ady = -ady; }
        swipeDir = 0;
        if (adx >= 48 || ady >= 48) {
            if (adx >= ady) {
                if (dx < 0) { swipeDir = 1; } else { swipeDir = 2; }
            } else {
                if (dy < 0) { swipeDir = 3; } else { swipeDir = 4; }
            }
        }
    }

    /// Swipe direction resolved on the current release frame (see NoteRelease).
    int SwipeDir() { return swipeDir; }
    /// The widget the in-flight gesture started on (press target).
    int SwipeTarget() { return pressStartId; }

    /// Reports a long press on `id` once the pointer has been held on it past
    /// the threshold without moving far. Arms a low-cadence follow-up frame
    /// while holding so the timer advances even with no further input; returns
    /// true exactly once per press. Movement beyond a small slop cancels it
    /// (the gesture is then a drag/swipe, not a long press).
    bool PollLongPress(int id) {
        if (longPressFired) { return false; }
        if (focus.pressedId != id) { return false; }
        if (pressStartId != id) { return false; }
        int mdx = mouseX - pressStartX; if (mdx < 0) { mdx = -mdx; }
        int mdy = mouseY - pressStartY; if (mdy < 0) { mdy = -mdy; }
        if (mdx > 12 || mdy > 12) { longPressFired = true; return false; }
        int t = Window.GetTickMs();
        if ((t - pressStartMs) >= 500) {
            longPressFired = true;
            RequestRedraw();
            return true;
        }
        RequestAnimationFrame(80);
        return false;
    }
}
