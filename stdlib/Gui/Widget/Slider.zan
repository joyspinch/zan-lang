using System;
using Gui;

namespace Gui.Widget;

/// Slider with reactive int binding and live drag / click-to-seek.
/// While the handle (or track) is pressed the value tracks the pointer,
/// mirroring NaiveUI's n-slider behaviour. All sizes are DPI-scaled.
class Slider {
    static int Render(App app, int x, int y, int width, int minVal, int maxVal, SignalInt model) {
        int id = app.focus.AllocId();
        Canvas c = app.canvas;
        Theme t = app.theme;

        bool hovered = app.focus.IsHovered(id);
        bool active = app.focus.IsPressed(id);

        int totalH = t.heightMedium;
        int range = maxVal - minVal;
        if (range < 1) { range = 1; }

        // Live drag / click-to-seek: while pressed, map the cursor X onto the value.
        if (active) {
            int rel = app.mouseX - x;
            if (rel < 0) { rel = 0; }
            if (rel > width) { rel = width; }
            int newVal = minVal + (rel * range + width / 2) / width;
            if (newVal < minVal) { newVal = minVal; }
            if (newVal > maxVal) { newVal = maxVal; }
            if (newVal != model.Get()) {
                model.Set(newVal);
                app.RequestRedraw();
            }
        }

        int currentVal = model.Get();
        int trackH = app.Scale(4);
        int trackY = y + (totalH - trackH) / 2;

        // Rail + active fill
        c.FillRoundRect(x, trackY, width, trackH, trackH / 2, t.bgTertiary);
        int fillW = (currentVal - minVal) * width / range;
        if (fillW < 0) { fillW = 0; }
        if (fillW > width) { fillW = width; }
        c.FillRoundRect(x, trackY, fillW, trackH, trackH / 2, t.primary);

        // Handle: white knob with ring; focus halo on hover/drag.
        int knobX = x + fillW;
        int knobY = trackY + trackH / 2;
        int knobR = app.Scale(9);
        if (hovered || active) {
            c.FillCircle(knobX, knobY, knobR + app.Scale(4), t.bgHover);
        }
        int ringColor = t.borderPrimary;
        if (hovered || active) { ringColor = t.primary; }
        c.FillCircle(knobX, knobY, knobR, ringColor);
        c.FillCircle(knobX, knobY, knobR - app.Scale(2), t.bgPrimary);

        app.hitTester.Register(HitRegion.Create(id, x, y, width, totalH, 3));
        return id;
    }
}
