using System;
using Gui;

namespace Gui.Widget;

/// A column descriptor for DataTable.
/// cellType: 0 text, 1 link, 2 tag, 3 progress, 4 badge
/// align:    0 left, 1 center, 2 right
class DataColumn {
    string title;
    int width;
    int cellType;
    int align;
    bool sortable;
    bool filterable;
    bool resizable;
    int tagType;
    bool numeric;
    int summary;   // total-row aggregate: 0 none,1 sum,2 avg,3 min,4 max,5 count,6 derived

    // ---- derived summary (summary==6): computed from OTHER columns' aggregate
    // values, so it costs O(1) and never scans the rows.
    // deriveOp: 0 percent (A*100/B), 1 ratio (A/B), 2 diff (A-B), 3 sum (A+B), 4 product (A*B)
    // deriveA / deriveB: source column indices whose aggregate values feed the op
    int deriveOp;
    int deriveA;
    int deriveB;

    // ---- conditional formatting ----
    int cfMode;    // 0 none,1 data bar,2 color scale,3 highlight >,4 highlight <
    int cfColor;   // data-bar / low-end / highlight accent color
    int cfColor2;  // color-scale high-end color
    int cfThreshold; // highlight comparison value

    // ---- display formatting (affects the rendered string only; sort/filter
    // still see the raw cell value) ----
    int fmt;       // 0 raw, 1 formatted (prefix + optionally grouped digits + suffix)
    bool grouped;  // insert thousands separators into the integer part
    string prefix; // leading text, e.g. a currency symbol
    string suffix; // trailing text, e.g. "%"

    // ---- editing ----
    bool editable; // cell values can be edited inline (opt-in)

    // ---- pinning / freeze ----
    bool pinned;   // freeze this column to the left: hoisted ahead of the rest
                   // and kept at its natural width when others compress to fit

    static DataColumn Create(string title, int width) {
        DataColumn col = new DataColumn();
        col.title = title;
        col.width = width;
        col.cellType = 0;
        col.align = 0;
        col.sortable = true;
        col.filterable = true;
        col.resizable = true;
        col.tagType = 1;
        col.numeric = false;
        col.summary = 0;
        col.deriveOp = 0;
        col.deriveA = 0;
        col.deriveB = -1;
        col.cfMode = 0;
        col.cfColor = 0;
        col.cfColor2 = 0;
        col.cfThreshold = 0;
        col.fmt = 0;
        col.grouped = false;
        col.prefix = "";
        col.suffix = "";
        col.editable = false;
        col.pinned = false;
        return col;
    }

    /// Opt a column in to inline editing (double/second-click a cell or press
    /// F2/Enter). Numeric columns validate input on commit.
    static DataColumn Editable(DataColumn c) {
        c.editable = true; return c;
    }

    /// Freeze a column to the left edge: it is hoisted ahead of the unpinned
    /// columns and keeps its natural width while the rest shrink to fit.
    static DataColumn Pin(DataColumn c) {
        c.pinned = true; return c;
    }

    // ---- display-format configurators (compose onto any column) ----
    /// Currency: thousands-grouped digits with a leading symbol, right-aligned.
    static DataColumn Money(DataColumn c, string symbol) {
        c.fmt = 1; c.grouped = true; c.prefix = symbol; c.numeric = true; c.align = 2; return c;
    }
    /// Percent: appends "%", right-aligned.
    static DataColumn Percent(DataColumn c) {
        c.fmt = 1; c.suffix = "%"; c.numeric = true; c.align = 2; return c;
    }
    /// Thousands separators only (e.g. 1234567 -> 1,234,567).
    static DataColumn Grouped(DataColumn c) {
        c.fmt = 1; c.grouped = true; c.numeric = true; c.align = 2; return c;
    }
    /// Arbitrary prefix/suffix (either may be empty), e.g. units like " kg".
    static DataColumn Affix(DataColumn c, string prefix, string suffix) {
        c.fmt = 1; c.prefix = prefix; c.suffix = suffix; return c;
    }

    // ---- conditional-format configurators (static so they compose without
    // relying on instance-method chaining) ----
    static DataColumn DataBar(DataColumn c, int color) {
        c.cfMode = 1; c.cfColor = color; return c;
    }
    static DataColumn ColorScale(DataColumn c, int lowColor, int highColor) {
        c.cfMode = 2; c.cfColor = lowColor; c.cfColor2 = highColor; return c;
    }
    static DataColumn HighlightGreater(DataColumn c, int threshold, int color) {
        c.cfMode = 3; c.cfThreshold = threshold; c.cfColor = color; return c;
    }
    static DataColumn HighlightLess(DataColumn c, int threshold, int color) {
        c.cfMode = 4; c.cfThreshold = threshold; c.cfColor = color; return c;
    }

    /// Marks a column as fixed-width: users can't drag its right border and the
    /// pointer shows a not-allowed cursor over the (would-be) resize grip.
    static DataColumn NotResizable(DataColumn c) {
        c.resizable = false; return c;
    }

    static DataColumn Text(string title, int width) {
        return DataColumn.Create(title, width);
    }

    static DataColumn Numeric(string title, int width) {
        DataColumn c = DataColumn.Create(title, width);
        c.numeric = true;
        c.align = 2;
        return c;
    }

    static DataColumn Link(string title, int width) {
        DataColumn c = DataColumn.Create(title, width);
        c.cellType = 1;
        return c;
    }

    static DataColumn TagCol(string title, int width, int tagType) {
        DataColumn c = DataColumn.Create(title, width);
        c.cellType = 2;
        c.tagType = tagType;
        c.align = 1;
        return c;
    }

    static DataColumn ProgressCol(string title, int width) {
        DataColumn c = DataColumn.Create(title, width);
        c.cellType = 3;
        c.numeric = true;
        return c;
    }

    static DataColumn BadgeCol(string title, int width) {
        DataColumn c = DataColumn.Create(title, width);
        c.cellType = 4;
        c.align = 1;
        return c;
    }

    /// A numeric column whose summary is derived from other columns' aggregates
    /// (no per-row scan). `op` is 0 percent / 1 ratio / 2 diff / 3 sum / 4 product;
    /// `a` and `b` are the source column indices.
    static DataColumn Derived(string title, int width, int op, int a, int b) {
        DataColumn c = DataColumn.Create(title, width);
        c.numeric = true;
        c.align = 2;
        c.summary = 6;
        c.deriveOp = op;
        c.deriveA = a;
        c.deriveB = b;
        return c;
    }

    // ---- footer-aggregate configurators (show a total row for this column) ----
    static DataColumn Sum(DataColumn c) { c.summary = 1; return c; }
    static DataColumn Avg(DataColumn c) { c.summary = 2; return c; }
    static DataColumn Min(DataColumn c) { c.summary = 3; return c; }
    static DataColumn Max(DataColumn c) { c.summary = 4; return c; }
    static DataColumn Count(DataColumn c) { c.summary = 5; return c; }
}

/// One row of string cells. Build with Create() then Push() per column.
class DataRow {
    List<string> cells;

    static DataRow Create() {
        DataRow r = new DataRow();
        r.cells = new List<string>();
        return r;
    }

    void Push(string v) {
        cells.Add(v);
    }

    string At(int i) {
        if (i < 0) { return ""; }
        if (i >= cells.Count) { return ""; }
        return cells[i];
    }

    void Set(int i, string v) {
        if (i < 0) { return; }
        while (cells.Count <= i) { cells.Add(""); }
        cells[i] = v;
    }
}

/// Per-column filter with three cooperating stages (all optional):
///  1. set filter   \u2014 values present in `hidden` are removed (Values tab);
///  2. text filter  \u2014 `textMode` (1 contains / 2 equals / 3 starts / 4 ends)
///     tested against `textQuery` (Text Filters tab);
///  3. batch filter \u2014 each entry in `batchTerms` is matched (exact or
///     substring per `batchExact`); `batchKeep` keeps matches, else excludes.
class ColFilter {
    List<string> hidden;
    int textMode;
    string textQuery;
    List<string> batchTerms;
    bool batchExact;
    bool batchKeep;

    static ColFilter Create() {
        ColFilter f = new ColFilter();
        f.hidden = new List<string>();
        f.textMode = 1;
        f.textQuery = "";
        f.batchTerms = new List<string>();
        f.batchExact = false;
        f.batchKeep = true;
        return f;
    }

    bool IsHidden(string v) {
        return hidden.Contains(v);
    }

    void Toggle(string v) {
        int idx = hidden.IndexOf(v);
        if (idx >= 0) {
            hidden.RemoveAt(idx);
        } else {
            hidden.Add(v);
        }
    }

    bool Active() {
        if (hidden.Count > 0) { return true; }
        if (textQuery.Length > 0) { return true; }
        if (batchTerms.Count > 0) { return true; }
        return false;
    }
}

/// Persisted DataTable state — create once (outside the frame loop) and pass in
/// every frame so selection / sort / filter / scroll survive across repaints.
class DataTableState {
    bool inited;
    int sortCol;
    int sortDir;
    // Multi-column sort keys (outer→inner priority). sortCol/sortDir mirror the
    // primary (index 0) key for back-compat; an empty list means "unsorted".
    List<int> sortCols;
    List<int> sortDirs;
    List<bool> selected;
    List<int> colWidths;
    List<int> dispW;
    List<int> order;
    List<ColFilter> filters;
    int openMenu;
    int scrollRow;
    int scrollX;               // horizontal pixel offset into the data columns
    int resizeCol;
    int resizeStartX;
    int resizeStartW;
    bool dirty;

    int filterTab;
    string searchText;
    int valScroll;
    int editFocus;
    List<string> batchLines;
    int batchExactFlag;
    List<string> menuVals;
    List<string> menuMatched;
    string menuSearchCache;

    bool showRowNum;
    bool showSelect;
    bool striped;

    // ---- summary (total) row ----
    bool showSummary;
    List<int> aggMode;         // per column: 0 none,1 sum,2 avg,3 min,4 max,5 count,6 derived
    List<int> aggValue;        // cached raw aggregate value per column (feeds derived columns)
    List<string> summaryText;  // cached formatted aggregate per column

    // ---- conditional formatting: per-column min/max over the filtered set,
    // cached so data-bar / color-scale cells normalise without a per-frame scan ----
    List<int> cfMin;
    List<int> cfMax;

    // ---- pagination ----
    bool paged;
    SignalInt pageModel;       // 1-based current page, bound to the Pagination widget
    int pageRows;              // rows per page (auto-fit), recomputed each frame

    // ---- selection & interaction ----
    int selAnchor;             // order-index anchor for shift range row-select (-1 none)
    int rangeR0;               // cell-range start row (order-index, -1 = no range)
    int rangeC0;               // cell-range start column
    int rangeR1;               // cell-range end row (order-index)
    int rangeC1;               // cell-range end column
    bool rangeDrag;            // currently drag-selecting a cell range
    int dragRow;               // order-index position of row being drag-reordered (-1 none)
    int dragStartY;            // pointer Y where a row press began
    bool dragMoved;            // pointer moved enough to become a reorder drag
    bool ctxOpen;              // right-click context menu open
    int ctxX;                  // context-menu anchor X
    int ctxY;                  // context-menu anchor Y
    List<bool> colHidden;      // per-column visibility (true = hidden from view)
    List<bool> colPinned;      // per-column freeze-left flag (true = frozen)
    List<int> colOrder;        // user column order (master sequence of column indices)
    int dragCol;               // column index being header-drag-reordered (-1 none)
    int dragColStartX;         // pointer X where the header press began
    bool dragColMoved;         // pointer moved enough to become a reorder drag
    int dropVis;               // visual insertion slot during a column drag (-1 none)
    bool hdrCtxOpen;           // header right-click context menu open
    int hdrCtxCol;             // column the header context menu targets
    int hdrCtxX;               // header context-menu anchor X
    int hdrCtxY;               // header context-menu anchor Y
    string toast;              // transient status message (copy/export feedback)
    int toastFrames;           // frames remaining to show the toast

    // ---- chart-from-selection overlay ----
    bool chartOpen;            // bar-chart overlay drawn on top of the grid
    string chartTitle;         // chart caption (value column name)
    List<string> chartLabels;  // per-bar category label (raw first-column value)
    List<int> chartVals;       // per-bar value (integer part of the numeric cell)
    int chartMax;              // largest bar value (>=1), for scaling

    // ---- row grouping (ag-Grid / DevExpress style) ----
    List<int> groupCols;       // grouped columns, outer→inner (empty = flat table)
    List<string> collapsedKeys;// group path keys whose rows are collapsed away
    List<int> dispKind;        // per display row: 0 = data row, 1 = group header
    List<int> dispRow;         // data-row index (kind 0) or group-table index (kind 1)
    List<int> dispNo;          // 1-based data ordinal for kind-0 rows, else 0
    List<string> grpLabel;     // group header caption ("Region: North")
    List<int> grpLevel;        // group nesting depth (0 = outermost)
    List<int> grpCount;        // number of data rows contained in the group
    List<string> grpKey;       // full group path key (collapse lookup)
    List<bool> grpCollapsed;   // per-group collapsed snapshot for rendering

    // ---- semantic event surface (sender = this state; handlers pull context
    // via HitRow()/HitCol()/SortColIndex()/... per the parameterless model) ----
    UiEvent HeaderClick;       // a sortable/filterable header title was clicked
    UiEvent Sort;              // sort column/direction changed (read SortColIndex/SortDirection)
    UiEvent RowClick;          // a row was clicked (read HitRow/HitOrderIndex)
    UiEvent RowDoubleClick;    // a row was double-clicked
    UiEvent CellClick;         // a data cell was clicked (read HitRow/HitCol)
    UiEvent CellEdit;          // an in-cell edit committed (read EditRow/EditCol/EditValue)
    UiEvent SelectionChanged;  // the selected-row set changed
    UiEvent ColumnResize;      // a column width changed by dragging (read HitCol)
    UiEvent ScrollChanged;     // the virtual row window scrolled (read ScrollTop)
    UiEvent GroupChanged;      // grouping columns changed (read GroupCount)
    UiEvent ColumnReorder;     // a column was drag-reordered (read HitCol)
    int hitRow;                // data-row index of the last row/cell interaction
    int hitOrder;              // order-position (post sort/filter) of that row
    int hitCol;                // column index of the last header/cell interaction
    int editRow;               // data-row index being edited (CellEdit)
    int editCol;               // column index being edited (CellEdit)
    string editVal;            // committed value (CellEdit)
    bool editing;              // an inline editor is currently open
    string editBuf;            // working text inside the open editor
    int editCur;               // caret position (chars) in editBuf

    static DataTableState Create() {
        DataTableState s = new DataTableState();
        s.inited = false;
        s.sortCol = -1;
        s.sortDir = 1;
        s.sortCols = new List<int>();
        s.sortDirs = new List<int>();
        s.selected = new List<bool>();
        s.colWidths = new List<int>();
        s.dispW = new List<int>();
        s.order = new List<int>();
        s.filters = new List<ColFilter>();
        s.openMenu = -1;
        s.scrollRow = 0;
        s.scrollX = 0;
        s.resizeCol = -1;
        s.resizeStartX = 0;
        s.resizeStartW = 0;
        s.dirty = true;
        s.filterTab = 0;
        s.searchText = "";
        s.valScroll = 0;
        s.editFocus = 0;
        s.batchLines = new List<string>();
        s.batchLines.Add("");
        s.batchExactFlag = 0;
        s.menuVals = new List<string>();
        s.menuMatched = new List<string>();
        s.menuSearchCache = "";
        s.showRowNum = true;
        s.showSelect = true;
        s.striped = true;
        s.showSummary = false;
        s.aggMode = new List<int>();
        s.aggValue = new List<int>();
        s.summaryText = new List<string>();
        s.cfMin = new List<int>();
        s.cfMax = new List<int>();
        s.paged = false;
        s.pageModel = SignalInt.Create(1);
        s.pageRows = 0;
        s.selAnchor = -1;
        s.rangeR0 = -1;
        s.rangeC0 = -1;
        s.rangeR1 = -1;
        s.rangeC1 = -1;
        s.rangeDrag = false;
        s.dragRow = -1;
        s.dragStartY = 0;
        s.dragMoved = false;
        s.ctxOpen = false;
        s.ctxX = 0;
        s.ctxY = 0;
        s.colHidden = new List<bool>();
        s.colPinned = new List<bool>();
        s.colOrder = new List<int>();
        s.dragCol = -1;
        s.dragColStartX = 0;
        s.dragColMoved = false;
        s.dropVis = -1;
        s.hdrCtxOpen = false;
        s.hdrCtxCol = -1;
        s.hdrCtxX = 0;
        s.hdrCtxY = 0;
        s.toast = "";
        s.toastFrames = 0;
        s.chartOpen = false;
        s.chartTitle = "";
        s.chartLabels = new List<string>();
        s.chartVals = new List<int>();
        s.chartMax = 1;
        s.HeaderClick = UiEvent.Create();
        s.Sort = UiEvent.Create();
        s.RowClick = UiEvent.Create();
        s.RowDoubleClick = UiEvent.Create();
        s.CellClick = UiEvent.Create();
        s.CellEdit = UiEvent.Create();
        s.SelectionChanged = UiEvent.Create();
        s.ColumnResize = UiEvent.Create();
        s.ScrollChanged = UiEvent.Create();
        s.GroupChanged = UiEvent.Create();
        s.ColumnReorder = UiEvent.Create();
        s.groupCols = new List<int>();
        s.collapsedKeys = new List<string>();
        s.dispKind = new List<int>();
        s.dispRow = new List<int>();
        s.dispNo = new List<int>();
        s.grpLabel = new List<string>();
        s.grpLevel = new List<int>();
        s.grpCount = new List<int>();
        s.grpKey = new List<string>();
        s.grpCollapsed = new List<bool>();
        s.hitRow = -1;
        s.hitOrder = -1;
        s.hitCol = -1;
        s.editRow = -1;
        s.editCol = -1;
        s.editVal = "";
        s.editing = false;
        s.editBuf = "";
        s.editCur = 0;
        return s;
    }

    // ---- event context accessors (option A: handlers read the sender) ----
    int HitRow() { return hitRow; }
    int HitOrderIndex() { return hitOrder; }
    int HitCol() { return hitCol; }
    int SortColIndex() { return sortCol; }
    int SortDirection() { return sortDir; }
    int ScrollTop() { return scrollRow; }
    int EditRow() { return editRow; }
    int EditCol() { return editCol; }
    string EditValue() { return editVal; }
}

/// Virtual data source for DataTable (DevExpress-style ValueNeeded).
///
/// The grid never stores rows itself — it pulls cells on demand for the visible
/// window, and reads a typed key (`CellNum`) for sorting / aggregation without
/// re-parsing strings. Subclass this and back it with columnar storage (one
/// array per column) to hold millions of rows in a fraction of the memory a
/// `List<DataRow>` of string cells would cost, and to sort / total without
/// per-cell string parsing.
class DataSource {
    /// Number of source rows.
    virtual int RowCount() { return 0; }
    /// Display text for a cell (row = source index, col = column index).
    virtual string CellText(int row, int col) { return ""; }
    /// Numeric key for a cell, used for sorting/aggregating numeric columns.
    /// Return 0 for non-numeric columns.
    virtual int CellNum(int row, int col) { return 0; }

    /// Write a cell value back into the underlying data (inline editing).
    /// Read-only sources ignore the write.
    virtual void SetCell(int row, int col, string v) { }
}

/// Backward-compatible adapter: serves an in-memory `List<DataRow>` of string
/// cells through the DataSource interface, so existing `DataTable.Render(...,
/// rows, ...)` calls keep working unchanged.
class RowListSource : DataSource {
    List<DataRow> rows;

    static RowListSource Create(List<DataRow> rows) {
        RowListSource s = new RowListSource();
        s.rows = rows;
        return s;
    }

    override int RowCount() { return this.rows.Count; }
    override string CellText(int row, int col) { return this.rows[row].At(col); }
    override int CellNum(int row, int col) { return DataTable.ParseInt(this.rows[row].At(col)); }
    override void SetCell(int row, int col, string v) { this.rows[row].Set(col, v); }
}

/// Enterprise-style data grid: fixed row-number & selection columns, sortable
/// headers, Excel-style set-filter header menus, resizable columns, custom cell
/// renderers (text/link/tag/progress/badge) and virtualised rows (only the
/// visible window is drawn, so tens of thousands of rows stay smooth).
///
/// Data is supplied through a `DataSource` (see `Render` for the List<DataRow>
/// convenience overload, or `RenderSource` to pass a custom virtual source).
class DataTable {
    // ---------- small helpers ----------

    static int CompareStr(string a, string b) {
        int la = a.Length;
        int lb = b.Length;
        int n = la;
        if (lb < n) { n = lb; }
        int i = 0;
        while (i < n) {
            char cha = a[i];
            char chb = b[i];
            int ca = (int)cha;
            int cb = (int)chb;
            if (ca < cb) { return -1; }
            if (ca > cb) { return 1; }
            i = i + 1;
        }
        if (la < lb) { return -1; }
        if (la > lb) { return 1; }
        return 0;
    }

    static bool IsIntStr(string s) {
        int n = s.Length;
        if (n == 0) { return false; }
        int i = 0;
        while (i < n) {
            char ch = s[i];
            int c = (int)ch;
            bool neg = (i == 0 && c == 45);
            if (!neg) {
                if (c < 48 || c > 57) { return false; }
            }
            i = i + 1;
        }
        return true;
    }

    static int ParseInt(string s) {
        int n = s.Length;
        if (n == 0) { return 0; }
        int i = 0;
        bool neg = false;
        char c0 = s[0];
        if ((int)c0 == 45) { neg = true; i = 1; }
        int v = 0;
        while (i < n) {
            char ch = s[i];
            int c = (int)ch;
            if (c < 48 || c > 57) { i = n; } else {
                v = v * 10 + (c - 48);
                i = i + 1;
            }
        }
        if (neg) { return 0 - v; }
        return v;
    }

    // Insert thousands separators into a run of digits. Left untouched if the
    // string contains any non-digit (so it never mangles a non-numeric cell).
    static string GroupDigits(string ipart) {
        int n = ipart.Length;
        int k = 0;
        while (k < n) {
            int cc = (int)ipart[k];
            if (cc < 48 || cc > 57) { return ipart; }
            k = k + 1;
        }
        if (n <= 3) { return ipart; }
        string outp = "";
        int cnt = 0;
        int i = n - 1;
        while (i >= 0) {
            outp = ipart.Substring(i, 1) + outp;
            cnt = cnt + 1;
            if (cnt % 3 == 0 && i > 0) { outp = "," + outp; }
            i = i - 1;
        }
        return outp;
    }

    // Apply a column's display format to a raw cell value: optional thousands
    // grouping of the integer part plus prefix/suffix. Sign and any fractional
    // part are preserved. Returns the raw value unchanged when fmt is off.
    static string FormatCell(DataColumn col, string raw) {
        if (col.fmt == 0) { return raw; }
        if (raw.Length == 0) { return raw; }
        string sign = "";
        string body = raw;
        if ((int)raw[0] == 45) { sign = "-"; body = raw.Substring(1); }
        int dot = -1;
        int i = 0;
        while (i < body.Length) {
            if ((int)body[i] == 46) { dot = i; i = body.Length; } else { i = i + 1; }
        }
        string ipart = body;
        string fpart = "";
        if (dot >= 0) { ipart = body.Substring(0, dot); fpart = body.Substring(dot); }
        if (col.grouped) { ipart = DataTable.GroupDigits(ipart); }
        return sign + col.prefix + ipart + fpart + col.suffix;
    }

    // ---- inline cell editing ----

    // Accepts an optional leading '-', decimal digits and at most one '.'.
    static bool IsNumericStr(string s) {
        if (s.Length == 0) { return false; }
        int i = 0;
        if ((int)s[0] == 45) { i = 1; }
        if (i >= s.Length) { return false; }
        int dots = 0;
        while (i < s.Length) {
            int cc = (int)s[i];
            if (cc == 46) { dots = dots + 1; if (dots > 1) { return false; } }
            else if (cc < 48 || cc > 57) { return false; }
            i = i + 1;
        }
        return true;
    }

    static void BeginEdit(DataTableState st, List<DataColumn> cols,
                          DataSource src, int rowIdx, int col) {
        if (col < 0 || col >= cols.Count) { return; }
        if (!cols[col].editable) { return; }
        if (rowIdx < 0 || rowIdx >= src.RowCount()) { return; }
        st.editing = true;
        st.editRow = rowIdx;
        st.editCol = col;
        st.editBuf = src.CellText(rowIdx, col);
        st.editCur = st.editBuf.Length;
    }

    static void CancelEdit(DataTableState st) {
        st.editing = false;
        st.editRow = -1;
        st.editCol = -1;
    }

    /// Validate (numeric columns only) and write the buffer back into the row.
    /// A rejected numeric value keeps the editor open so the user can correct it.
    static void CommitEdit(DataTableState st, List<DataColumn> cols, DataSource src) {
        if (!st.editing) { return; }
        int rr = st.editRow;
        int cc = st.editCol;
        if (cc >= 0 && cc < cols.Count && cols[cc].numeric) {
            if (!DataTable.IsNumericStr(st.editBuf)) { return; }
        }
        if (rr >= 0 && rr < src.RowCount() && cc >= 0) {
            src.SetCell(rr, cc, st.editBuf);
            st.editVal = st.editBuf;
            st.hitRow = rr;
            st.hitCol = cc;
            st.CellEdit.Raise();
            st.dirty = true;
        }
        st.editing = false;
        st.editRow = -1;
        st.editCol = -1;
    }

    // ---- case-insensitive string matching for the text/batch filters ----

    static int FoldC(int cc) {
        if (cc >= 65 && cc <= 90) { return cc + 32; }
        return cc;
    }

    static bool MatchAt(string hay, string needle, int off) {
        int j = 0;
        while (j < needle.Length) {
            char ch = hay[off + j];
            char cn = needle[j];
            if (DataTable.FoldC((int)ch) != DataTable.FoldC((int)cn)) { return false; }
            j = j + 1;
        }
        return true;
    }

    static bool EqCI(string a, string b) {
        if (a.Length != b.Length) { return false; }
        return DataTable.MatchAt(a, b, 0);
    }

    static bool ContainsCI(string hay, string needle) {
        int nl = needle.Length;
        int hl = hay.Length;
        if (nl == 0) { return true; }
        if (nl > hl) { return false; }
        int i = 0;
        while (i <= hl - nl) {
            if (DataTable.MatchAt(hay, needle, i)) { return true; }
            i = i + 1;
        }
        return false;
    }

    static bool StartsCI(string hay, string needle) {
        if (needle.Length > hay.Length) { return false; }
        return DataTable.MatchAt(hay, needle, 0);
    }

    static bool EndsCI(string hay, string needle) {
        int nl = needle.Length;
        int hl = hay.Length;
        if (nl > hl) { return false; }
        return DataTable.MatchAt(hay, needle, hl - nl);
    }

    static bool TextMatch(string v, string q, int mode) {
        if (q.Length == 0) { return true; }
        if (mode == 2) { return DataTable.EqCI(v, q); }
        if (mode == 3) { return DataTable.StartsCI(v, q); }
        if (mode == 4) { return DataTable.EndsCI(v, q); }
        return DataTable.ContainsCI(v, q);
    }

    // Build a one-character string from an ASCII code (printable range only).
    static string CharStr(int code) {
        if (code < 32 || code > 126) { return ""; }
        string tbl = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~";
        return tbl.Substring(code - 32, 1);
    }

    static string Backspace(string s) {
        if (s.Length <= 1) { return ""; }
        return s.Substring(0, s.Length - 1);
    }

    // Whether a single cell value survives every stage of the column filter.
    static bool CellPasses(ColFilter f, string v) {
        if (f.hidden.Contains(v)) { return false; }
        if (f.textQuery.Length > 0) {
            if (!DataTable.TextMatch(v, f.textQuery, f.textMode)) { return false; }
        }
        if (f.batchTerms.Count > 0) {
            bool matched = false;
            int i = 0;
            while (i < f.batchTerms.Count) {
                bool hit = false;
                if (f.batchExact) { hit = DataTable.EqCI(v, f.batchTerms[i]); }
                else { hit = DataTable.ContainsCI(v, f.batchTerms[i]); }
                if (hit) { matched = true; i = f.batchTerms.Count; }
                else { i = i + 1; }
            }
            if (f.batchKeep) {
                if (!matched) { return false; }
            } else {
                if (matched) { return false; }
            }
        }
        return true;
    }

    static int CompareCell(string a, string b, bool numeric) {
        if (numeric) {
            int va = ParseInt(a);
            int vb = ParseInt(b);
            if (va < vb) { return -1; }
            if (va > vb) { return 1; }
            return 0;
        }
        return DataTable.CompareStr(a, b);
    }

    static string Truncate(string text, int fontSize, int maxW) {
        if (maxW <= 0) { return ""; }
        if (Canvas.MeasureText(text, fontSize) <= maxW) { return text; }
        int n = text.Length;
        int k = n;
        while (k > 0) {
            string cand = text.Substring(0, k);
            string withDots = cand + "…";
            if (Canvas.MeasureText(withDots, fontSize) <= maxW) {
                return withDots;
            }
            k = k - 1;
        }
        return "…";
    }

    static int TypeColor(Theme t, int type) {
        if (type == 1) { return t.primary; }
        if (type == 2) { return t.info; }
        if (type == 3) { return t.success; }
        if (type == 4) { return t.warning; }
        if (type == 5) { return t.error; }
        return t.textSecondary;
    }

    // ---------- state maintenance ----------

    static void EnsureInit(DataTableState st, List<DataColumn> cols, DataSource src) {
        if (!st.inited) {
            int i = 0;
            while (i < cols.Count) {
                st.colWidths.Add(cols[i].width);
                st.filters.Add(ColFilter.Create());
                st.aggMode.Add(cols[i].summary);
                st.summaryText.Add("");
                st.colHidden.Add(false);
                st.colPinned.Add(cols[i].pinned);
                st.colOrder.Add(i);
                if (cols[i].summary > 0) { st.showSummary = true; }
                i = i + 1;
            }
            i = 0;
            int nrows = src.RowCount();
            while (i < nrows) {
                st.selected.Add(false);
                i = i + 1;
            }
            st.inited = true;
            st.dirty = true;
        }
        while (st.selected.Count < src.RowCount()) { st.selected.Add(false); }
        while (st.colHidden.Count < cols.Count) { st.colHidden.Add(false); }
        while (st.colPinned.Count < cols.Count) { st.colPinned.Add(false); }
        // colOrder tracks every column exactly once; append any not yet listed.
        int co = 0;
        while (co < cols.Count) {
            if (st.colOrder.IndexOf(co) < 0) { st.colOrder.Add(co); }
            co = co + 1;
        }
    }

    // ---------- column visibility / auto-fit helpers ----------

    static int HiddenCount(DataTableState st) {
        int n = 0;
        int i = 0;
        while (i < st.colHidden.Count) {
            if (st.colHidden[i]) { n = n + 1; }
            i = i + 1;
        }
        return n;
    }

    static void ShowAllColumns(DataTableState st) {
        int i = 0;
        while (i < st.colHidden.Count) { st.colHidden[i] = false; i = i + 1; }
    }

    // ---------- footer aggregation ----------
    // Set a column's total-row aggregate (0 none,1 sum,2 avg,3 min,4 max,5 count)
    // and auto-toggle the footer to match whether any column still aggregates.
    static void SetAggregate(DataTableState st, int col, int mode) {
        while (st.aggMode.Count <= col) { st.aggMode.Add(0); }
        if (col < 0 || col >= st.aggMode.Count) { return; }
        st.aggMode[col] = mode;
        bool any = false;
        int i = 0;
        while (i < st.aggMode.Count) { if (st.aggMode[i] > 0) { any = true; } i = i + 1; }
        st.showSummary = any;
        st.dirty = true;
    }

    // ---------- column pinning / freeze ----------

    static void PinColumn(DataTableState st, int col) {
        if (col >= 0 && col < st.colPinned.Count) { st.colPinned[col] = true; }
    }

    static void UnpinColumn(DataTableState st, int col) {
        if (col >= 0 && col < st.colPinned.Count) { st.colPinned[col] = false; }
    }

    static void TogglePin(DataTableState st, int col) {
        if (col >= 0 && col < st.colPinned.Count) { st.colPinned[col] = !st.colPinned[col]; }
    }

    // Column indices in on-screen order: active group columns are hoisted to the
    // front (right after the #/select gutter), then the remaining columns in
    // their natural order. Hidden columns are excluded. Every layout pass
    // (header / cells / hit-test / summary) iterates this so the grouped columns
    // read as the row's leading key, DevExpress/ag-Grid style.
    static bool IsPinned(DataTableState st, int col) {
        return col >= 0 && col < st.colPinned.Count && st.colPinned[col];
    }

    static List<int> VisibleOrder(DataTableState st, List<DataColumn> cols) {
        // Master sequence is the user column order (drag-reorderable); pinned and
        // grouped columns are still hoisted to the front, preserving their
        // relative position within that order.
        List<int> seq = new List<int>();
        int s = 0;
        while (s < st.colOrder.Count) {
            int ci = st.colOrder[s];
            if (ci >= 0 && ci < cols.Count && seq.IndexOf(ci) < 0) { seq.Add(ci); }
            s = s + 1;
        }
        int a = 0;
        while (a < cols.Count) {
            if (seq.IndexOf(a) < 0) { seq.Add(a); }
            a = a + 1;
        }

        List<int> ord = new List<int>();
        // 1) frozen (pinned-left) columns first, in user order.
        int p = 0;
        while (p < seq.Count) {
            int pc = seq[p];
            if (!st.colHidden[pc] && DataTable.IsPinned(st, pc) && ord.IndexOf(pc) < 0) { ord.Add(pc); }
            p = p + 1;
        }
        // 2) active group columns (unless already pinned) hoisted next.
        int g = 0;
        while (g < st.groupCols.Count) {
            int gc = st.groupCols[g];
            if (gc >= 0 && gc < cols.Count && !st.colHidden[gc] && ord.IndexOf(gc) < 0) {
                ord.Add(gc);
            }
            g = g + 1;
        }
        // 3) the remaining visible columns in user order.
        int i = 0;
        while (i < seq.Count) {
            int rc = seq[i];
            if (!st.colHidden[rc] && ord.IndexOf(rc) < 0) { ord.Add(rc); }
            i = i + 1;
        }
        return ord;
    }

    // Reorder a column in the user column order: move `from` so it sits just
    // before `beforeCol` (or to the end when beforeCol < 0). No-op when the
    // move would not change anything.
    static void MoveColumn(DataTableState st, int from, int beforeCol) {
        int fi = st.colOrder.IndexOf(from);
        if (fi < 0) { return; }
        if (from == beforeCol) { return; }
        st.colOrder.RemoveAt(fi);
        if (beforeCol < 0) {
            st.colOrder.Add(from);
        } else {
            int bi = st.colOrder.IndexOf(beforeCol);
            if (bi < 0) { st.colOrder.Add(from); }
            else { st.colOrder.Insert(bi, from); }
        }
        st.dirty = true;
    }

    // Combined width of the frozen (pinned-left) columns at their natural size.
    static int PinnedWidth(DataTableState st) {
        int w = 0;
        int i = 0;
        while (i < st.colWidths.Count) {
            if (!st.colHidden[i] && DataTable.IsPinned(st, i)) { w = w + st.colWidths[i]; }
            i = i + 1;
        }
        return w;
    }

    // Widest rendered cell (title + data) for a column, used by auto-fit. Scans
    // the filtered view so the width matches what's actually on screen.
    static int MeasureColWidth(App app, List<DataColumn> cols, DataSource src,
                               DataTableState st, int col) {
        int fs = app.theme.fontSizeMedium;
        int w = Canvas.MeasureText(cols[col].title, fs);
        int i = 0;
        while (i < st.order.Count) {
            int cw = Canvas.MeasureText(DataTable.FormatCell(cols[col], src.CellText(st.order[i], col)), fs);
            if (cw > w) { w = cw; }
            i = i + 1;
        }
        // padding on both sides + room for the sort arrow / header menu icon.
        int fit = w + app.theme.paddingSmall * 2 + app.Scale(26);
        if (fit < app.Scale(48)) { fit = app.Scale(48); }
        return fit;
    }

    static void AutoFitColumn(App app, List<DataColumn> cols, DataSource src,
                              DataTableState st, int col) {
        if (col < 0 || col >= st.colWidths.Count) { return; }
        st.colWidths[col] = DataTable.MeasureColWidth(app, cols, src, st, col);
    }

    static void AutoFitAll(App app, List<DataColumn> cols, DataSource src,
                           DataTableState st) {
        int i = 0;
        while (i < cols.Count && i < st.colWidths.Count) {
            if (!st.colHidden[i]) {
                st.colWidths[i] = DataTable.MeasureColWidth(app, cols, src, st, i);
            }
            i = i + 1;
        }
    }

    static bool RowPasses(DataTableState st, List<DataColumn> cols, DataSource src, int row) {
        int i = 0;
        while (i < cols.Count) {
            ColFilter f = st.filters[i];
            if (f.Active()) {
                if (!DataTable.CellPasses(f, src.CellText(row, i))) { return false; }
            }
            i = i + 1;
        }
        return true;
    }

    // Filter predicate over only the columns known to have an active filter.
    static bool RowPassesActive(DataTableState st, DataSource src, List<int> af, int row) {
        int a = 0;
        while (a < af.Count) {
            int c = af[a];
            if (!DataTable.CellPasses(st.filters[c], src.CellText(row, c))) { return false; }
            a = a + 1;
        }
        return true;
    }

    static void Recompute(DataTableState st, List<DataColumn> cols, DataSource src) {
        if (!st.dirty) { return; }
        st.order.Clear();
        int nrows = src.RowCount();

        // Collect the columns that actually have an active filter (usually none).
        // The common no-filter case then skips the O(rows * cols) predicate scan
        // entirely — a big win when re-sorting a million unfiltered rows.
        List<int> af = new List<int>();
        int fc = 0;
        while (fc < cols.Count) {
            if (st.filters[fc].Active()) { af.Add(fc); }
            fc = fc + 1;
        }

        int i = 0;
        if (af.Count == 0) {
            while (i < nrows) { st.order.Add(i); i = i + 1; }
        } else {
            while (i < nrows) {
                if (DataTable.RowPassesActive(st, src, af, i)) { st.order.Add(i); }
                i = i + 1;
            }
        }
        if (st.groupCols.Count > 0) {
            DataTable.SortOrderGrouped(st, cols, src);
        } else if (st.sortCols.Count == 1) {
            // fast path: decorate-sort a single key (sortCol mirrors sortCols[0])
            DataTable.SortOrder(st, cols, src);
        } else if (st.sortCols.Count > 1) {
            DataTable.SortOrderMulti(st, cols, src);
        }
        if (st.showSummary) { DataTable.ComputeSummary(st, cols, src); }
        DataTable.ComputeColStats(st, cols, src);
        DataTable.BuildDisplay(st, cols, src);
        int maxScroll = st.dispKind.Count - 1;
        if (st.scrollRow > maxScroll) { st.scrollRow = maxScroll; }
        if (st.scrollRow < 0) { st.scrollRow = 0; }
        st.dirty = false;
    }

    // Derived aggregate for a summary==6 column, computed from OTHER columns'
    // already-aggregated values — O(1), no row scan.
    static int DeriveValue(DataColumn col, List<int> agg) {
        int a = 0;
        int b = 0;
        if (col.deriveA >= 0 && col.deriveA < agg.Count) { a = agg[col.deriveA]; }
        if (col.deriveB >= 0 && col.deriveB < agg.Count) { b = agg[col.deriveB]; }
        int op = col.deriveOp;
        if (op == 0) { if (b != 0) { return a * 100 / b; } return 0; }
        if (op == 1) { if (b != 0) { return a / b; } return 0; }
        if (op == 2) { return a - b; }
        if (op == 3) { return a + b; }
        if (op == 4) { return a * b; }
        return a;
    }

    // ---------- row grouping ----------
    static bool IsGrouped(DataTableState st) { return st.groupCols.Count > 0; }
    static int GroupCount(DataTableState st) { return st.groupCols.Count; }

    static void CollapseAll(DataTableState st) {
        int i = 0;
        while (i < st.grpKey.Count) {
            if (st.collapsedKeys.IndexOf(st.grpKey[i]) < 0) { st.collapsedKeys.Add(st.grpKey[i]); }
            i = i + 1;
        }
        st.dirty = true;
    }

    static void ExpandAll(DataTableState st) {
        st.collapsedKeys.Clear();
        st.dirty = true;
    }

    static void GroupBy(DataTableState st, int col) {
        if (col < 0) { return; }
        if (st.groupCols.IndexOf(col) >= 0) { return; }
        st.groupCols.Add(col);
        st.dirty = true;
    }

    static void Ungroup(DataTableState st) {
        st.groupCols.Clear();
        st.collapsedKeys.Clear();
        st.dirty = true;
    }

    static bool IsCollapsed(DataTableState st, string key) {
        return st.collapsedKeys.IndexOf(key) >= 0;
    }

    static void ToggleCollapse(DataTableState st, string key) {
        int idx = st.collapsedKeys.IndexOf(key);
        if (idx >= 0) { st.collapsedKeys.RemoveAt(idx); }
        else { st.collapsedKeys.Add(key); }
        st.dirty = true;
    }

    // Path key for the group that data row `rowIdx` belongs to at nesting
    // `level` — the concatenation of its group-column values down to that level,
    // joined by a control separator so distinct paths never collide.
    static string PathKey(DataTableState st, DataSource src, int rowIdx, int level) {
        string sep = DataTable.CharStr(31);
        string k = "";
        int g = 0;
        while (g <= level && g < st.groupCols.Count) {
            k = k + src.CellText(rowIdx, st.groupCols[g]) + sep;
            g = g + 1;
        }
        return k;
    }

    // Compare two data rows by the grouping columns (outer→inner), then by the
    // active sort column as a tiebreak, so rows of the same group stay adjacent.
    static int CmpGroupRow(DataTableState st, List<DataColumn> cols, DataSource src, int ra, int rb) {
        int g = 0;
        while (g < st.groupCols.Count) {
            int gc = st.groupCols[g];
            bool num = false;
            if (gc >= 0 && gc < cols.Count) { num = cols[gc].numeric; }
            int cmp = DataTable.CompareCell(src.CellText(ra, gc), src.CellText(rb, gc), num);
            if (cmp != 0) { return cmp; }
            g = g + 1;
        }
        return DataTable.CmpMultiKey(st, cols, src, ra, rb);
    }

    static void MergeGrp(DataTableState st, List<DataColumn> cols, DataSource src,
                         int lo, int mid, int hi, List<int> tmp) {
        int i = lo;
        int j = mid;
        int k = lo;
        while (i < mid && j < hi) {
            if (DataTable.CmpGroupRow(st, cols, src, st.order[i], st.order[j]) <= 0) {
                tmp[k] = st.order[i]; i = i + 1;
            } else {
                tmp[k] = st.order[j]; j = j + 1;
            }
            k = k + 1;
        }
        while (i < mid) { tmp[k] = st.order[i]; i = i + 1; k = k + 1; }
        while (j < hi) { tmp[k] = st.order[j]; j = j + 1; k = k + 1; }
        int p = lo;
        while (p < hi) { st.order[p] = tmp[p]; p = p + 1; }
    }

    static void SortOrderGrouped(DataTableState st, List<DataColumn> cols, DataSource src) {
        int n = st.order.Count;
        if (n < 2) { return; }
        List<int> tmp = new List<int>();
        int z = 0;
        while (z < n) { tmp.Add(0); z = z + 1; }
        int width = 1;
        while (width < n) {
            int lo = 0;
            while (lo < n) {
                int mid = lo + width;
                if (mid > n) { mid = n; }
                int hi = lo + width * 2;
                if (hi > n) { hi = n; }
                if (mid < hi) { DataTable.MergeGrp(st, cols, src, lo, mid, hi, tmp); }
                lo = lo + width * 2;
            }
            width = width * 2;
        }
    }

    // Build the flat display model (group headers interleaved with data rows)
    // from the already filtered+sorted st.order. When no grouping is active the
    // model mirrors st.order one-to-one, so every downstream render/hit path
    // behaves exactly as before.
    static void BuildDisplay(DataTableState st, List<DataColumn> cols, DataSource src) {
        st.dispKind.Clear();
        st.dispRow.Clear();
        st.dispNo.Clear();
        st.grpLabel.Clear();
        st.grpLevel.Clear();
        st.grpCount.Clear();
        st.grpKey.Clear();
        st.grpCollapsed.Clear();
        int G = st.groupCols.Count;
        if (G == 0) {
            int i = 0;
            while (i < st.order.Count) {
                st.dispKind.Add(0);
                st.dispRow.Add(st.order[i]);
                st.dispNo.Add(i + 1);
                i = i + 1;
            }
            return;
        }
        int N = st.order.Count;
        int dataNo = 0;
        int p = 0;
        while (p < N) {
            int rowIdx = st.order[p];
            int L = 0;
            while (L < G) {
                bool isNew = false;
                if (p == 0) { isNew = true; }
                else if (DataTable.PathKey(st, src, st.order[p], L)
                      != DataTable.PathKey(st, src, st.order[p - 1], L)) { isNew = true; }
                if (isNew) {
                    string key = DataTable.PathKey(st, src, rowIdx, L);
                    bool ancColl = false;
                    int a = 0;
                    while (a < L) {
                        if (DataTable.IsCollapsed(st, DataTable.PathKey(st, src, rowIdx, a))) {
                            ancColl = true;
                        }
                        a = a + 1;
                    }
                    int cnt = 0;
                    int q = p;
                    while (q < N && DataTable.PathKey(st, src, st.order[q], L) == key) {
                        cnt = cnt + 1; q = q + 1;
                    }
                    int gi = st.grpLabel.Count;
                    st.grpLabel.Add(cols[st.groupCols[L]].title + ": "
                        + src.CellText(rowIdx, st.groupCols[L]));
                    st.grpLevel.Add(L);
                    st.grpCount.Add(cnt);
                    st.grpKey.Add(key);
                    st.grpCollapsed.Add(DataTable.IsCollapsed(st, key));
                    if (!ancColl) {
                        st.dispKind.Add(1);
                        st.dispRow.Add(gi);
                        st.dispNo.Add(0);
                    }
                }
                L = L + 1;
            }
            bool anyColl = false;
            int a2 = 0;
            while (a2 < G) {
                if (DataTable.IsCollapsed(st, DataTable.PathKey(st, src, rowIdx, a2))) {
                    anyColl = true;
                }
                a2 = a2 + 1;
            }
            dataNo = dataNo + 1;
            if (!anyColl) {
                st.dispKind.Add(0);
                st.dispRow.Add(rowIdx);
                st.dispNo.Add(dataNo);
            }
            p = p + 1;
        }
    }

    // Per-column aggregate over the current filtered set (st.order), cached as
    // formatted strings so the summary row costs nothing to redraw per frame.
    //
    // Base aggregates (sum/avg/min/max) are gathered in a SINGLE pass over the
    // visible rows — all such columns accumulate together, so N aggregated
    // columns cost one traversal, not one traversal each. Derived columns
    // (summary==6) are then computed from those cached aggregates in O(1) each,
    // never touching the rows again.
    static void ComputeSummary(DataTableState st, List<DataColumn> cols, DataSource src) {
        int nc = cols.Count;
        while (st.aggMode.Count < nc) { st.aggMode.Add(0); }
        int n = st.order.Count;

        // per-column accumulators + the compact set of columns that need a scan
        List<int> sumV = new List<int>();
        List<int> minV = new List<int>();
        List<int> maxV = new List<int>();
        List<int> baseCols = new List<int>();
        int col = 0;
        while (col < nc) {
            sumV.Add(0);
            minV.Add(0);
            maxV.Add(0);
            int m = st.aggMode[col];
            if (m >= 1 && m <= 4) { baseCols.Add(col); }
            col = col + 1;
        }

        // ---- accumulate every base column over the visible rows ----
        // Accumulation is kept in scalars and written back to the per-column
        // lists ONCE (outside the row loop): index-writing a list inside a hot
        // million-iteration loop hits a -O0 codegen bug that leaks stack. This
        // still costs one CellNum read per (base column, row) — the same total
        // work as a single interleaved pass — and only the aggregated columns
        // are ever scanned.
        int bi = 0;
        while (bi < baseCols.Count) {
            int bc = baseCols[bi];
            int s = 0;
            int mn = 0;
            int mx = 0;
            int k = 0;
            while (k < n) {
                int v = src.CellNum(st.order[k], bc);
                s = s + v;
                if (k == 0) { mn = v; mx = v; }
                else {
                    if (v < mn) { mn = v; }
                    if (v > mx) { mx = v; }
                }
                k = k + 1;
            }
            sumV[bc] = s;
            minV[bc] = mn;
            maxV[bc] = mx;
            bi = bi + 1;
        }

        // resolve each column's raw aggregate value (base first, then derived so
        // derived columns read finished aggregates)
        st.aggValue.Clear();
        col = 0;
        while (col < nc) { st.aggValue.Add(0); col = col + 1; }
        col = 0;
        while (col < nc) {
            int m = st.aggMode[col];
            if (m == 1) { st.aggValue[col] = sumV[col]; }
            else if (m == 2) { if (n > 0) { st.aggValue[col] = sumV[col] / n; } }
            else if (m == 3) { st.aggValue[col] = minV[col]; }
            else if (m == 4) { st.aggValue[col] = maxV[col]; }
            else if (m == 5) { st.aggValue[col] = n; }
            col = col + 1;
        }
        col = 0;
        while (col < nc) {
            if (st.aggMode[col] == 6) { st.aggValue[col] = DataTable.DeriveValue(cols[col], st.aggValue); }
            col = col + 1;
        }

        // format (no row scan)
        st.summaryText.Clear();
        col = 0;
        while (col < nc) {
            int m = st.aggMode[col];
            string txt = "";
            if (m == 1) { txt = "Σ " + DataTable.FormatCell(cols[col], Convert.ToString(st.aggValue[col])); }
            else if (m == 2) { txt = "avg " + DataTable.FormatCell(cols[col], Convert.ToString(st.aggValue[col])); }
            else if (m == 3) { txt = "min " + DataTable.FormatCell(cols[col], Convert.ToString(st.aggValue[col])); }
            else if (m == 4) { txt = "max " + DataTable.FormatCell(cols[col], Convert.ToString(st.aggValue[col])); }
            else if (m == 5) { txt = "n " + Convert.ToString(n); }
            else if (m == 6) {
                if (cols[col].deriveOp == 0) { txt = Convert.ToString(st.aggValue[col]) + "%"; }
                else { txt = Convert.ToString(st.aggValue[col]); }
            }
            st.summaryText.Add(txt);
            col = col + 1;
        }
    }

    // Per-column min/max over the filtered set, for data-bar & color-scale
    // normalisation. Only columns with cfMode 1 or 2 are scanned.
    static void ComputeColStats(DataTableState st, List<DataColumn> cols, DataSource src) {
        st.cfMin.Clear();
        st.cfMax.Clear();
        int n = st.order.Count;
        int col = 0;
        while (col < cols.Count) {
            int mn = 0;
            int mx = 0;
            if (cols[col].cfMode == 1 || cols[col].cfMode == 2) {
                int k = 0;
                while (k < n) {
                    int v = src.CellNum(st.order[k], col);
                    if (k == 0) { mn = v; mx = v; }
                    else { if (v < mn) { mn = v; } if (v > mx) { mx = v; } }
                    k = k + 1;
                }
            }
            st.cfMin.Add(mn);
            st.cfMax.Add(mx);
            col = col + 1;
        }
    }

    // ---- color helpers for conditional formatting ----
    // Opaque 0xFFRRGGBB packed as a positive int.
    static int Rgb(int r, int g, int b) {
        return 4278190080 + r * 65536 + g * 256 + b;
    }
    // Same RGB with a custom alpha (for translucent cell tints / data bars).
    static int ColorAlpha(int packed, int a) {
        int rgb = packed % 16777216;
        if (rgb < 0) { rgb = rgb + 16777216; }
        return rgb + a * 16777216;
    }
    // Linear blend of two opaque packed colors: (1-num/den)*c0 + (num/den)*c1.
    static int LerpColor(int c0, int c1, int num, int den) {
        if (den <= 0) { return c0; }
        if (num < 0) { num = 0; }
        if (num > den) { num = den; }
        int r0 = (c0 / 65536) % 256;
        int g0 = (c0 / 256) % 256;
        int b0 = c0 % 256;
        int r1 = (c1 / 65536) % 256;
        int g1 = (c1 / 256) % 256;
        int b1 = c1 % 256;
        int r = r0 + (r1 - r0) * num / den;
        int g = g0 + (g1 - g0) * num / den;
        int b = b0 + (b1 - b0) * num / den;
        return DataTable.Rgb(r, g, b);
    }

    // ---- O(n log n) merge sort of row indices by the active sort column ----
    // The previous selection sort was O(n^2) and locked up on large datasets;
    // this bottom-up merge sort keeps sorting 100k+ rows responsive.
    //
    // Sort keys are extracted ONCE up front (decorate-sort-undecorate) into
    // parallel arrays and moved in lockstep with the row indices during merges,
    // so a comparison is a plain int/string compare instead of re-fetching the
    // cell and re-parsing it on every one of the ~n*log2(n) comparisons.

    static void MergeKeyed(bool numeric, int dir,
                           List<int> order, List<int> nkey, List<string> skey,
                           int lo, int mid, int hi,
                           List<int> otmp, List<int> ntmp, List<string> stmp) {
        int i = lo;
        int j = mid;
        int k = lo;
        while (i < mid && j < hi) {
            int cmp = 0;
            if (numeric) {
                if (nkey[i] < nkey[j]) { cmp = -1; }
                else if (nkey[i] > nkey[j]) { cmp = 1; }
            } else {
                cmp = DataTable.CompareStr(skey[i], skey[j]);
            }
            if (dir == 2) { cmp = 0 - cmp; }
            if (cmp <= 0) {
                otmp[k] = order[i];
                if (numeric) { ntmp[k] = nkey[i]; } else { stmp[k] = skey[i]; }
                i = i + 1;
            } else {
                otmp[k] = order[j];
                if (numeric) { ntmp[k] = nkey[j]; } else { stmp[k] = skey[j]; }
                j = j + 1;
            }
            k = k + 1;
        }
        while (i < mid) {
            otmp[k] = order[i];
            if (numeric) { ntmp[k] = nkey[i]; } else { stmp[k] = skey[i]; }
            i = i + 1; k = k + 1;
        }
        while (j < hi) {
            otmp[k] = order[j];
            if (numeric) { ntmp[k] = nkey[j]; } else { stmp[k] = skey[j]; }
            j = j + 1; k = k + 1;
        }
        k = lo;
        while (k < hi) {
            order[k] = otmp[k];
            if (numeric) { nkey[k] = ntmp[k]; } else { skey[k] = stmp[k]; }
            k = k + 1;
        }
    }

    // ---------- multi-column sort ----------
    // sortCols/sortDirs hold the active keys (outer→inner). sortCol/sortDir are
    // kept in sync with the primary key so existing readers keep working.
    static void SyncPrimary(DataTableState st) {
        if (st.sortCols.Count > 0) { st.sortCol = st.sortCols[0]; st.sortDir = st.sortDirs[0]; }
        else { st.sortCol = -1; st.sortDir = 1; }
    }

    /// Replace the sort with a single key (dir: 1 asc, 2 desc). col<0 clears it.
    static void SortBy(DataTableState st, int col, int dir) {
        st.sortCols.Clear(); st.sortDirs.Clear();
        if (col >= 0) { st.sortCols.Add(col); st.sortDirs.Add(dir); }
        DataTable.SyncPrimary(st); st.dirty = true;
    }

    /// Append (or re-point) a secondary sort key without disturbing the others.
    static void AddSort(DataTableState st, int col, int dir) {
        if (col < 0) { return; }
        int idx = st.sortCols.IndexOf(col);
        if (idx < 0) { st.sortCols.Add(col); st.sortDirs.Add(dir); }
        else { st.sortDirs[idx] = dir; }
        DataTable.SyncPrimary(st); st.dirty = true;
    }

    static void ClearSort(DataTableState st) {
        st.sortCols.Clear(); st.sortDirs.Clear();
        DataTable.SyncPrimary(st); st.dirty = true;
    }

    // Header-click state machine. `additive` (Shift) toggles this column as an
    // extra key (asc → desc → removed); otherwise it becomes the sole key,
    // cycling asc → desc → cleared when clicked repeatedly.
    static void CycleSort(DataTableState st, int col, bool additive) {
        int idx = st.sortCols.IndexOf(col);
        if (additive) {
            if (idx < 0) { st.sortCols.Add(col); st.sortDirs.Add(1); }
            else if (st.sortDirs[idx] == 1) { st.sortDirs[idx] = 2; }
            else { st.sortCols.RemoveAt(idx); st.sortDirs.RemoveAt(idx); }
        } else {
            bool only = st.sortCols.Count == 1 && idx == 0;
            if (only) {
                if (st.sortDirs[0] == 1) { st.sortDirs[0] = 2; }
                else { st.sortCols.Clear(); st.sortDirs.Clear(); }
            } else {
                st.sortCols.Clear(); st.sortDirs.Clear();
                st.sortCols.Add(col); st.sortDirs.Add(1);
            }
        }
        DataTable.SyncPrimary(st);
    }

    // Compare two data rows across every active sort key (stable tiebreak order).
    static int CmpMultiKey(DataTableState st, List<DataColumn> cols, DataSource src, int ra, int rb) {
        int g = 0;
        while (g < st.sortCols.Count) {
            int sc = st.sortCols[g];
            if (sc >= 0 && sc < cols.Count) {
                int cmp = DataTable.CompareCell(src.CellText(ra, sc), src.CellText(rb, sc), cols[sc].numeric);
                if (st.sortDirs[g] == 2) { cmp = 0 - cmp; }
                if (cmp != 0) { return cmp; }
            }
            g = g + 1;
        }
        return 0;
    }

    static void MergeMulti(DataTableState st, List<DataColumn> cols, DataSource src,
                           int lo, int mid, int hi, List<int> tmp) {
        int i = lo;
        int j = mid;
        int k = lo;
        while (i < mid && j < hi) {
            if (DataTable.CmpMultiKey(st, cols, src, st.order[i], st.order[j]) <= 0) {
                tmp[k] = st.order[i]; i = i + 1;
            } else {
                tmp[k] = st.order[j]; j = j + 1;
            }
            k = k + 1;
        }
        while (i < mid) { tmp[k] = st.order[i]; i = i + 1; k = k + 1; }
        while (j < hi) { tmp[k] = st.order[j]; j = j + 1; k = k + 1; }
        int p = lo;
        while (p < hi) { st.order[p] = tmp[p]; p = p + 1; }
    }

    static void SortOrderMulti(DataTableState st, List<DataColumn> cols, DataSource src) {
        int n = st.order.Count;
        if (n < 2) { return; }
        List<int> tmp = new List<int>();
        int z = 0;
        while (z < n) { tmp.Add(0); z = z + 1; }
        int width = 1;
        while (width < n) {
            int lo = 0;
            while (lo < n) {
                int mid = lo + width;
                if (mid > n) { mid = n; }
                int hi = lo + width * 2;
                if (hi > n) { hi = n; }
                if (mid < hi) { DataTable.MergeMulti(st, cols, src, lo, mid, hi, tmp); }
                lo = lo + width * 2;
            }
            width = width * 2;
        }
    }

    static void SortOrder(DataTableState st, List<DataColumn> cols, DataSource src) {
        int n = st.order.Count;
        if (n < 2) { return; }
        bool numeric = cols[st.sortCol].numeric;
        int dir = st.sortDir;
        int sc = st.sortCol;

        // decorate: pull the sort key for each visible row once (O(n)), so a
        // comparison is a plain int/string compare rather than a per-compare
        // CellNum/CellText call.
        List<int> nkey = new List<int>();
        List<string> skey = new List<string>();
        int q = 0;
        while (q < n) {
            if (numeric) { nkey.Add(src.CellNum(st.order[q], sc)); }
            else { skey.Add(src.CellText(st.order[q], sc)); }
            q = q + 1;
        }

        List<int> otmp = new List<int>();
        List<int> ntmp = new List<int>();
        List<string> stmp = new List<string>();
        int p = 0;
        while (p < n) {
            otmp.Add(0);
            if (numeric) { ntmp.Add(0); } else { stmp.Add(""); }
            p = p + 1;
        }

        int width = 1;
        while (width < n) {
            int lo = 0;
            while (lo < n) {
                int mid = lo + width;
                if (mid > n) { mid = n; }
                int hi = lo + width * 2;
                if (hi > n) { hi = n; }
                if (mid < hi) { DataTable.MergeKeyed(numeric, dir, st.order, nkey, skey, lo, mid, hi, otmp, ntmp, stmp); }
                lo = lo + width * 2;
            }
            width = width * 2;
        }
    }

    // ---- O(n log n) merge sort of a string list (used for Distinct) ----

    static void MergeStr(List<string> src, int lo, int mid, int hi, List<string> tmp) {
        int i = lo;
        int j = mid;
        int k = lo;
        while (i < mid && j < hi) {
            if (DataTable.CompareStr(src[i], src[j]) <= 0) { tmp[k] = src[i]; i = i + 1; }
            else { tmp[k] = src[j]; j = j + 1; }
            k = k + 1;
        }
        while (i < mid) { tmp[k] = src[i]; i = i + 1; k = k + 1; }
        while (j < hi) { tmp[k] = src[j]; j = j + 1; k = k + 1; }
        k = lo;
        while (k < hi) { src[k] = tmp[k]; k = k + 1; }
    }

    static void SortStr(List<string> a) {
        int n = a.Count;
        if (n < 2) { return; }
        List<string> tmp = new List<string>();
        int p = 0;
        while (p < n) { tmp.Add(""); p = p + 1; }
        int width = 1;
        while (width < n) {
            int lo = 0;
            while (lo < n) {
                int mid = lo + width;
                if (mid > n) { mid = n; }
                int hi = lo + width * 2;
                if (hi > n) { hi = n; }
                if (mid < hi) { DataTable.MergeStr(a, lo, mid, hi, tmp); }
                lo = lo + width * 2;
            }
            width = width * 2;
        }
    }

    // Sorted distinct values of a column, computed by sorting all cell values
    // (O(n log n)) and collapsing adjacent duplicates (O(n)). The previous
    // implementation rescanned the result list per row — O(n^2) — which hung
    // on high-cardinality columns once the dataset grew large.
    static List<string> Distinct(DataSource src, int col) {
        List<string> vals = new List<string>();
        int i = 0;
        int nrows = src.RowCount();
        while (i < nrows) { vals.Add(src.CellText(i, col)); i = i + 1; }
        DataTable.SortStr(vals);
        List<string> res = new List<string>();
        int j = 0;
        while (j < vals.Count) {
            if (j == 0 || DataTable.CompareStr(vals[j], vals[j - 1]) != 0) { res.Add(vals[j]); }
            j = j + 1;
        }
        return res;
    }

    // ---------- selection / clipboard / export helpers ----------

    static int MinI(int a, int b) { if (a < b) { return a; } return b; }
    static int MaxI(int a, int b) { if (a > b) { return a; } return b; }

    static bool HasRange(DataTableState st) {
        return st.rangeR0 >= 0 && st.rangeC0 >= 0;
    }

    // Escape one CSV field (quote when it holds a comma, quote or newline).
    static string CsvField(string v) {
        bool needsQuote = false;
        int i = 0;
        while (i < v.Length) {
            char ch = v[i];
            int cc = (int)ch;
            if (cc == 44 || cc == 34 || cc == 10 || cc == 13) { needsQuote = true; i = v.Length; }
            else { i = i + 1; }
        }
        if (!needsQuote) { return v; }
        // Double any embedded quotes, copying runs with Substring so non-ASCII
        // characters survive intact (no char-by-char reconstruction).
        string body = "";
        int start = 0;
        int k = 0;
        while (k < v.Length) {
            if ((int)v[k] == 34) {
                body = body + v.Substring(start, k - start + 1) + "\"";
                start = k + 1;
            }
            k = k + 1;
        }
        body = body + v.Substring(start, v.Length - start);
        return "\"" + body + "\"";
    }

    // Build a tab-separated (clipboard) or comma-separated (CSV) block for the
    // active cell range if any, otherwise for the checkbox-selected rows, else
    // the whole (filtered/sorted) view. `csv` picks the delimiter + escaping;
    // `withHeader` prepends the column titles.
    static string BuildText(DataTableState st, List<DataColumn> cols, DataSource src, bool csv, bool withHeader) {
        string sep = "\t";
        if (csv) { sep = ","; }
        string nl = "\r\n";
        string outp = "";

        int c0 = 0;
        int c1 = cols.Count - 1;
        bool rangeMode = DataTable.HasRange(st);
        if (rangeMode) {
            c0 = DataTable.MinI(st.rangeC0, st.rangeC1);
            c1 = DataTable.MaxI(st.rangeC0, st.rangeC1);
        }

        if (withHeader) {
            string line = "";
            int cc = c0;
            while (cc <= c1) {
                string h = cols[cc].title;
                if (csv) { h = DataTable.CsvField(h); }
                if (cc > c0) { line = line + sep; }
                line = line + h;
                cc = cc + 1;
            }
            outp = line + nl;
        }

        if (rangeMode) {
            int r0 = DataTable.MinI(st.rangeR0, st.rangeR1);
            int r1 = DataTable.MaxI(st.rangeR0, st.rangeR1);
            int rr = r0;
            while (rr <= r1) {
                if (rr >= 0 && rr < st.order.Count) {
                    int srcRow = st.order[rr];
                    string line = "";
                    int cc = c0;
                    while (cc <= c1) {
                        string v = src.CellText(srcRow, cc);
                        if (csv) { v = DataTable.CsvField(v); }
                        if (cc > c0) { line = line + sep; }
                        line = line + v;
                        cc = cc + 1;
                    }
                    outp = outp + line + nl;
                }
                rr = rr + 1;
            }
            return outp;
        }

        // else: selected rows, or the whole view when nothing is checked
        bool anySel = false;
        int s = 0;
        while (s < st.order.Count) { if (st.selected[st.order[s]]) { anySel = true; s = st.order.Count; } else { s = s + 1; } }
        int oi = 0;
        while (oi < st.order.Count) {
            int ri = st.order[oi];
            if (!anySel || st.selected[ri]) {
                string line = "";
                int cc = c0;
                while (cc <= c1) {
                    string v = src.CellText(ri, cc);
                    if (csv) { v = DataTable.CsvField(v); }
                    if (cc > c0) { line = line + sep; }
                    line = line + v;
                    cc = cc + 1;
                }
                outp = outp + line + nl;
            }
            oi = oi + 1;
        }
        return outp;
    }

    static void SelectAllRows(DataTableState st, bool val) {
        int k = 0;
        while (k < st.order.Count) { st.selected[st.order[k]] = val; k = k + 1; }
    }

    // Integer part of a loosely-formatted numeric cell (ignores separators and a
    // fractional tail): "1,234.56" -> 1234, "-98%" -> -98, "" -> 0.
    static int ParseIntLoose(string s) {
        int i = 0;
        bool neg = false;
        if (i < s.Length && (int)s[i] == 45) { neg = true; i = i + 1; }
        int v = 0;
        bool any = false;
        while (i < s.Length) {
            int cc = (int)s[i];
            if (cc == 46) { i = s.Length; }            // stop at the decimal point
            else if (cc >= 48 && cc <= 57) { v = v * 10 + (cc - 48); any = true; i = i + 1; }
            else { i = i + 1; }                        // skip separators / units
        }
        if (!any) { return 0; }
        if (neg) { return 0 - v; }
        return v;
    }

    // Build a bar chart from the active cell range: bars = range rows, values =
    // the rightmost numeric column in the range, labels = the range's first
    // column (or the row ordinal when that IS the value column). Returns false
    // when there is no range or the range holds no numeric column.
    static bool BuildChartFromRange(DataTableState st, List<DataColumn> cols, DataSource src) {
        if (!DataTable.HasRange(st)) { return false; }
        int c0 = DataTable.MinI(st.rangeC0, st.rangeC1);
        int c1 = DataTable.MaxI(st.rangeC0, st.rangeC1);
        int r0 = DataTable.MinI(st.rangeR0, st.rangeR1);
        int r1 = DataTable.MaxI(st.rangeR0, st.rangeR1);

        int valCol = -1;
        int cc = c1;
        while (cc >= c0) {
            if (cc >= 0 && cc < cols.Count && cols[cc].numeric) { valCol = cc; cc = c0 - 1; }
            else { cc = cc - 1; }
        }
        if (valCol < 0) { return false; }
        int labCol = c0;
        if (labCol == valCol) { labCol = -1; }

        st.chartLabels = new List<string>();
        st.chartVals = new List<int>();
        st.chartMax = 1;
        st.chartTitle = cols[valCol].title;

        int rr = r0;
        int n = 0;
        while (rr <= r1) {
            if (rr >= 0 && rr < st.order.Count) {
                int ri = st.order[rr];
                int v = DataTable.ParseIntLoose(src.CellText(ri, valCol));
                string lab = Convert.ToString(n + 1);
                if (labCol >= 0) { lab = src.CellText(ri, labCol); }
                st.chartLabels.Add(lab);
                st.chartVals.Add(v);
                int av = v;
                if (av < 0) { av = 0 - av; }
                if (av > st.chartMax) { st.chartMax = av; }
                n = n + 1;
            }
            rr = rr + 1;
        }
        return n > 0;
    }

    static void ClearRange(DataTableState st) {
        st.rangeR0 = -1;
        st.rangeC0 = -1;
        st.rangeR1 = -1;
        st.rangeC1 = -1;
    }

    // Move the row occupying order-position `from` so it lands at order-position
    // `to`, shifting the rest — the manual drag-reorder of the visible order.
    static void MoveOrder(DataTableState st, int from, int to) {
        if (from < 0 || from >= st.order.Count) { return; }
        if (to < 0) { to = 0; }
        if (to >= st.order.Count) { to = st.order.Count - 1; }
        if (from == to) { return; }
        int v = st.order[from];
        st.order.RemoveAt(from);
        st.order.Insert(to, v);
    }

    // ---------- cell rendering ----------

    static void DrawCell(App app, DataColumn col, string val, int cx, int cy, int cw, int rowH, int cfLo, int cfHi) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int fs = t.fontSizeMedium;
        int pad = t.paddingSmall;
        int innerW = cw - pad * 2;

        // ---- conditional formatting (plain text/numeric cells only) ----
        int cfText = t.textPrimary;
        if (col.cfMode != 0 && col.cellType == 0) {
            int v = DataTable.ParseInt(val);
            if (col.cfMode == 1) {
                // data bar proportional to value across the column's min..max
                int span = cfHi - cfLo;
                if (span <= 0) { span = 1; }
                int frac = (v - cfLo) * 100 / span;
                if (frac < 0) { frac = 0; }
                if (frac > 100) { frac = 100; }
                int barH = rowH - app.Scale(8);
                int barY = cy + app.Scale(4);
                int barW = frac * innerW / 100;
                int tint = DataTable.ColorAlpha(col.cfColor, 95);
                int rad = app.Scale(2);
                if (barW > 0) {
                    // Clean flat data bar with a slight corner radius; fall back to
                    // a plain rect when the bar is too short to round without the
                    // straight-segment math underflowing.
                    if (barW < rad * 2) { c.FillRect(cx + pad, barY, barW, barH, tint); }
                    else { c.FillRoundRect(cx + pad, barY, barW, barH, rad, tint); }
                }
                string sb = DataTable.Truncate(DataTable.FormatCell(col, val), fs, innerW);
                int twb = Canvas.MeasureText(sb, fs);
                int tyb = cy + (rowH - Canvas.FontHeight(fs)) / 2;
                c.DrawText(cx + cw - pad - twb, tyb, sb, t.textPrimary, fs);
                return;
            } else if (col.cfMode == 2) {
                c.FillRect(cx, cy, cw, rowH, DataTable.LerpColor(col.cfColor, col.cfColor2, v - cfLo, cfHi - cfLo));
            } else if (col.cfMode == 3 && v > col.cfThreshold) {
                c.FillRect(cx, cy, cw, rowH, DataTable.ColorAlpha(col.cfColor, 38));
                cfText = col.cfColor;
            } else if (col.cfMode == 4 && v < col.cfThreshold) {
                c.FillRect(cx, cy, cw, rowH, DataTable.ColorAlpha(col.cfColor, 38));
                cfText = col.cfColor;
            }
        }

        if (col.cellType == 3) {
            int pct = DataTable.ParseInt(val);
            if (pct < 0) { pct = 0; }
            if (pct > 100) { pct = 100; }
            int barH = app.Scale(6);
            int barY = cy + (rowH - barH) / 2;
            int barW = innerW - app.Scale(40);
            if (barW < app.Scale(20)) { barW = app.Scale(20); }
            c.FillRoundRect(cx + pad, barY, barW, barH, barH / 2, t.bgTertiary);
            int fillW = pct * barW / 100;
            int barColor = t.primary;
            if (pct >= 100) { barColor = t.success; }
            c.FillRoundRect(cx + pad, barY, fillW, barH, barH / 2, barColor);
            int txtY = cy + (rowH - Canvas.FontHeight(t.fontSizeSmall)) / 2;
            c.DrawText(cx + pad + barW + app.Scale(6), txtY, Convert.ToString(pct) + "%", t.textSecondary, t.fontSizeSmall);
            return;
        }

        if (col.cellType == 2) {
            int tc = DataTable.TypeColor(t, col.tagType);
            int tagH = t.heightSmall;
            int tagY = cy + (rowH - tagH) / 2;
            string label = DataTable.Truncate(val, t.fontSizeSmall, innerW - pad * 2);
            int tagW = Canvas.MeasureText(label, t.fontSizeSmall) + pad * 2;
            int tagX = cx + pad;
            if (col.align == 1) { tagX = cx + (cw - tagW) / 2; }
            c.FillRoundRect(tagX, tagY, tagW, tagH, t.borderRadiusSmall, t.bgSecondary);
            c.DrawRect(tagX, tagY, tagW, tagH, tc, 1);
            int txtY = tagY + (tagH - Canvas.FontHeight(t.fontSizeSmall)) / 2;
            c.DrawText(tagX + pad, txtY, label, tc, t.fontSizeSmall);
            return;
        }

        if (col.cellType == 4) {
            int dotR = app.Scale(4);
            int dotColor = t.success;
            if (val == "0" || val == "" || val == "Offline" || val == "Idle" || val == "Inactive" || val == "Closed") { dotColor = t.textTertiary; }
            int cxc = cx + pad + dotR;
            if (col.align == 1) { cxc = cx + cw / 2 - Canvas.MeasureText(val, fs) / 2 - dotR - app.Scale(4); }
            c.FillCircle(cxc, cy + rowH / 2, dotR, dotColor);
            int txtY = cy + (rowH - Canvas.FontHeight(fs)) / 2;
            c.DrawText(cxc + dotR + app.Scale(4), txtY, val, t.textPrimary, fs);
            return;
        }

        int color = cfText;
        if (col.cellType == 1) { color = t.primary; }
        string shown = DataTable.Truncate(DataTable.FormatCell(col, val), fs, innerW);
        int tw = Canvas.MeasureText(shown, fs);
        int tx = cx + pad;
        if (col.align == 1) { tx = cx + (cw - tw) / 2; }
        if (col.align == 2) { tx = cx + cw - pad - tw; }
        int ty = cy + (rowH - Canvas.FontHeight(fs)) / 2;
        c.DrawText(tx, ty, shown, color, fs);
    }

    // ---------- main render ----------

    /// Convenience overload: render an in-memory List<DataRow> (wraps it in a
    /// RowListSource). For large / virtual data, use RenderSource with a custom
    /// DataSource subclass instead.
    static void Render(App app, int x, int y, int viewW, int viewH,
                       List<DataColumn> cols, List<DataRow> rows, DataTableState st) {
        DataTable.RenderSource(app, x, y, viewW, viewH, cols, RowListSource.Create(rows), st);
    }

    static void RenderSource(App app, int x, int y, int viewW, int viewH,
                       List<DataColumn> cols, DataSource src, DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        DataTable.EnsureInit(st, cols, src);
        DataTable.Recompute(st, cols, src);

        int headerH = t.heightMedium;
        int rowH = t.heightMedium;
        int fs = t.fontSizeMedium;

        int numW = 0;
        if (st.showRowNum) {
            // Wide enough for the largest row number so 7-digit counts never
            // spill into the neighbouring column.
            numW = app.Scale(46);
            int needW = Canvas.MeasureText(Convert.ToString(src.RowCount()), t.fontSizeSmall)
                        + app.Scale(16);
            if (needW > numW) { numW = needW; }
        }
        int selW = 0;
        if (st.showSelect) { selW = app.Scale(40); }

        int gridColor = t.divider;
        int menuIconW = app.Scale(22);

        // Right edge that content may not spill past (leaves room for the
        // vertical scrollbar). Columns whose right side would exceed this are
        // clamped, and any column starting beyond it is skipped — so cells and
        // headers never draw outside the table's own border.
        int sbGutter = app.Scale(12);
        int clipRight = x + viewW - sbGutter;

        // total data width (hidden columns contribute nothing)
        int dataW = 0;
        int ci = 0;
        while (ci < st.colWidths.Count) {
            if (!st.colHidden[ci]) { dataW = dataW + st.colWidths[ci]; }
            ci = ci + 1;
        }
        int totalW = numW + selW + dataW;

        // Columns keep their natural widths; when the total exceeds the
        // available band the data region pans horizontally (st.scrollX) and
        // only the visible column window is drawn — so wide tables scroll
        // instead of squeezing every column into the viewport. Hidden columns
        // collapse to zero width; frozen (pinned) and grouped columns are
        // hoisted to the front of the visible order.
        int availData = clipRight - (x + numW + selW);
        if (availData < app.Scale(80)) { availData = app.Scale(80); }
        int pinnedW = DataTable.PinnedWidth(st);
        int flexNatW = dataW - pinnedW;                 // unpinned natural total
        int flexAvail = availData - pinnedW;            // space left for unpinned
        int minFlex = app.Scale(40);
        if (flexAvail < minFlex) { flexAvail = minFlex; }
        st.dispW.Clear();
        int di = 0;
        while (di < st.colWidths.Count) {
            if (st.colHidden[di]) { st.dispW.Add(0); }
            else { st.dispW.Add(st.colWidths[di]); }
            di = di + 1;
        }
        int maxScrollX = dataW - availData;
        if (maxScrollX < 0) { maxScrollX = 0; }
        if (st.scrollX > maxScrollX) { st.scrollX = maxScrollX; }
        if (st.scrollX < 0) { st.scrollX = 0; }
        int firstDataX = x + numW + selW;
        int dataViewW = clipRight - firstDataX;

        // Column display order (group columns hoisted to the front). Computed
        // once and shared by every layout pass so header / cells / hit-test /
        // summary stay perfectly aligned.
        List<int> vorder = DataTable.VisibleOrder(st, cols);

        // outer border
        c.FillRoundRect(x, y, viewW, viewH, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(x, y, viewW, viewH, t.borderPrimary, 1);

        // ---------------- header ----------------
        c.FillRect(x, y, viewW, headerH, t.bgSecondary);
        int hx = x;

        if (st.showRowNum) {
            c.DrawTextCentered(hx, y, numW, headerH, "#", t.textTertiary, t.fontSizeSmall);
            hx = hx + numW;
            c.FillRect(hx, y, 1, headerH, gridColor);
        }
        if (st.showSelect) {
            // select-all checkbox
            int allId = app.focus.AllocId();
            bool allChecked = st.order.Count > 0;
            int oi = 0;
            while (oi < st.order.Count) {
                if (!st.selected[st.order[oi]]) { allChecked = false; oi = st.order.Count; } else { oi = oi + 1; }
            }
            int box = app.Scale(16);
            int bx = hx + (selW - box) / 2;
            int by = y + (headerH - box) / 2;
            if (allChecked) {
                c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.primary);
                int ins = app.Scale(3);
                Icon.Draw(c, "check", bx + ins, by + ins, box - ins * 2, t.textInverse);
            } else {
                c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.bgPrimary);
                c.DrawRect(bx, by, box, box, t.borderPrimary, 1);
            }
            app.hitTester.Register(HitRegion.Create(allId, hx, y, selW, headerH, 0));
            if (app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == allId) {
                bool target = !allChecked;
                int k = 0;
                while (k < st.order.Count) { st.selected[st.order[k]] = target; k = k + 1; }
                st.SelectionChanged.Raise();
                app.RequestRedraw();
            }
            hx = hx + selW;
            c.FillRect(hx, y, 1, headerH, gridColor);
        }

        // Column drag-reorder in progress this frame (a header title is held and
        // the pointer has moved past the start threshold). dropVisLocal is the
        // visual slot the dragged column would land before; dropX is its screen x.
        bool colDragging = st.dragCol >= 0 && st.dragColMoved;
        int dropVisLocal = -1;
        int dropX = -1;

        c.PushClip(firstDataX, y, dataViewW, headerH);
        int hoi = 0;
        int hcl = firstDataX - st.scrollX;
        while (hoi < vorder.Count) {
            int i = vorder[hoi];
            DataColumn col = cols[i];
            int cw = st.dispW[i];
            // Ids are allocated for every column — visible or not — so the id
            // sequence stays identical across frames while panning; otherwise
            // widgets registered after the header (scrollbars) would change id
            // mid-drag whenever a column entered/left the viewport.
            int titleId = app.focus.AllocId();
            int menuId = -1;
            if (col.filterable || col.sortable) { menuId = app.focus.AllocId(); }
            int rzId = app.focus.AllocId();
            if (hcl + cw <= firstDataX || hcl >= clipRight) {
                hcl = hcl + cw;
                hoi = hoi + 1;
            } else {
            hx = hcl;
            // visible slice of this column (for hit regions / hover fill)
            int visX = hx;
            if (visX < firstDataX) { visX = firstDataX; }
            int visR = hx + cw;
            if (visR > clipRight) { visR = clipRight; }
            int visW = visR - visX;
            // drag-reorder drop slot: first column whose left half contains the
            // pointer becomes the insertion target.
            if (colDragging && dropVisLocal < 0 && app.mouseX < hx + cw / 2) {
                dropVisLocal = hoi;
                dropX = visX;
            }
            bool hHover = app.focus.IsHovered(titleId);
            if (hHover) { c.FillRect(visX, y, visW, headerH, t.bgHover); }

            int pad = t.paddingSmall;
            int availTitle = cw - pad * 2 - menuIconW;
            string ht = DataTable.Truncate(col.title, fs, availTitle);
            int ty = y + (headerH - Canvas.FontHeight(fs)) / 2;
            c.DrawText(hx + pad, ty, ht, t.textSecondary, fs);

            // sort indicator — arrow per key, plus a 1-based priority badge when
            // more than one column feeds a multi-column sort.
            int spos = st.sortCols.IndexOf(i);
            if (spos >= 0) {
                string arrow = "arrow-up";
                if (st.sortDirs[spos] == 2) { arrow = "arrow-down"; }
                int aw = app.Scale(12);
                int ax = hx + pad + Canvas.MeasureText(ht, fs) + app.Scale(4);
                Icon.Draw(c, arrow, ax, y + (headerH - aw) / 2, aw, t.primary);
                if (st.sortCols.Count > 1) {
                    c.DrawText(ax + aw + app.Scale(1), ty,
                               Convert.ToString(spos + 1), t.primary, t.fontSizeSmall);
                }
            }

            // header menu icon — DevExpress-style: only revealed when the mouse
            // is over the header cell, when this column has an active filter, or
            // while its menu is open. `menuId` is always allocated so widget ids
            // stay stable across frames regardless of the icon's visibility.
            if (menuId >= 0) {
                int mIx = hx + cw - menuIconW - app.Scale(2);
                bool active = st.filters[i].Active();
                bool cellHover = app.mouseX >= visX && app.mouseX < visR
                                 && app.mouseY >= y && app.mouseY < y + headerH;
                bool showIcon = active || cellHover || st.openMenu == i;
                if (showIcon) {
                    int mColor = t.textTertiary;
                    if (active) { mColor = t.primary; }
                    if (app.focus.IsHovered(menuId)) { mColor = t.textPrimary; }
                    Icon.DrawCenteredIn(c, "filter", mIx, y, menuIconW, headerH, app.Scale(13), mColor);
                    app.hitTester.Register(HitRegion.Create(menuId, mIx, y, menuIconW, headerH, 0));
                    if (!st.dragColMoved && app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == menuId) {
                        if (st.openMenu == i) { st.openMenu = -1; } else {
                            st.openMenu = i;
                            st.filterTab = 0;
                            st.searchText = "";
                            st.valScroll = 0;
                            st.editFocus = 0;
                            st.batchLines = new List<string>();
                            st.batchLines.Add("");
                            st.batchExactFlag = 0;
                            st.menuVals = DataTable.Distinct(src, i);
                            st.menuMatched = st.menuVals;
                            st.menuSearchCache = "";
                        }
                        app.RequestRedraw();
                    }
                }
            }

            // header title: press starts a potential drag-reorder; a click (no
            // drag) cycles the sort. The dragged column is dimmed while moving.
            int titleW = visW - menuIconW;
            if (titleW < 0) { titleW = 0; }
            app.hitTester.Register(HitRegion.Create(titleId, visX, y, titleW, headerH, 0));
            if (app.window.EventKind() == 2 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == titleId) {
                st.dragCol = i;
                st.dragColStartX = app.mouseX;
                st.dragColMoved = false;
            }
            if (st.dragCol == i && app.focus.pressedId == titleId) {
                int dd = app.mouseX - st.dragColStartX;
                if (dd < 0) { dd = 0 - dd; }
                if (!st.dragColMoved && dd > app.Scale(5)) {
                    st.dragColMoved = true;
                }
                if (st.dragColMoved) { app.RequestRedraw(); }
            }
            if (colDragging && st.dragCol == i) {
                c.FillRect(visX, y, visW, headerH, t.bgHover);
            }
            if (col.sortable && !st.dragColMoved && app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.ClickTarget() == titleId) {
                st.hitCol = i;
                st.HeaderClick.Raise();
                bool addSort = Modifiers.HasShift(app.window.EventMods());
                DataTable.CycleSort(st, i, addSort);
                st.dirty = true;
                st.Sort.Raise();
                app.RequestRedraw();
            }

            // right-click a header cell => column context menu (sort / auto-fit /
            // hide). Geometry-based so it wins regardless of the overlapping
            // title / menu-icon / resize ids registered for this cell.
            if (app.window.EventKind() == 2 && app.window.EventButton() == 1
                && st.openMenu < 0
                && app.mouseX >= hx && app.mouseX < hx + cw
                && app.mouseY >= y && app.mouseY < y + headerH) {
                st.hdrCtxOpen = true;
                st.hdrCtxCol = i;
                st.hdrCtxX = app.mouseX;
                st.hdrCtxY = app.mouseY;
                st.hitCol = i;
                app.RequestRedraw();
            }

            // resize handle (right border). Draggable columns get a horizontal
            // resize cursor (widget type 4); fixed columns show the not-allowed
            // cursor (widget type 6) so the grip clearly reads as disabled.
            int rzW = app.Scale(6);
            int rzX = hx + cw - rzW / 2;
            int rzCursor = 4;
            if (!col.resizable) { rzCursor = 6; }
            app.hitTester.Register(HitRegion.Create(rzId, rzX, y, rzW, headerH, rzCursor));
            if (col.resizable && app.window.EventKind() == 2 && app.window.EventButton() == 0 && app.PressTarget() == rzId) {
                st.resizeCol = i;
                st.resizeStartX = app.mouseX;
                st.resizeStartW = st.colWidths[i];
            }
            if (col.resizable && st.resizeCol == i && app.focus.pressedId == rzId) {
                int nw = st.resizeStartW + (app.mouseX - st.resizeStartX);
                if (nw < app.Scale(48)) { nw = app.Scale(48); }
                if (nw != st.colWidths[i]) {
                    st.colWidths[i] = nw;
                    st.hitCol = i;
                    st.ColumnResize.Raise();
                    app.RequestRedraw();
                }
            }

            if (st.resizeCol == i && app.window.EventKind() == 3 && app.window.EventButton() == 0) {
                st.hitCol = i;
                st.resizeCol = -1;
                st.ColumnResizeEnd.Raise();
            }

            c.FillRect(hx + cw, y, 1, headerH, gridColor);
            hcl = hcl + cw;
            hoi = hoi + 1;
            }
        }
        c.PopClip();
        c.FillRect(x, y + headerH - 1, viewW, 1, gridColor);

        // Column drag feedback + drop: a 2px accent line marks the insertion
        // boundary and a floating chip follows the pointer. On release the
        // column is moved before the target slot (or to the end).
        if (colDragging) {
            if (dropVisLocal < 0) { dropX = hx; }
            c.FillRect(dropX - 1, y, app.Scale(2), headerH, t.primary);
            string dl = cols[st.dragCol].title;
            int chW = Canvas.MeasureText(dl, fs) + app.Scale(16);
            int chX = app.mouseX - chW / 2;
            if (chX < x) { chX = x; }
            if (chX + chW > x + viewW) { chX = x + viewW - chW; }
            c.FillRoundRect(chX, y + app.Scale(3), chW, headerH - app.Scale(6),
                            t.borderRadiusSmall, t.primary);
            c.DrawText(chX + app.Scale(8),
                       y + (headerH - Canvas.FontHeight(fs)) / 2, dl, t.textInverse, fs);
        }
        // Remember the drop slot while the button is held, so the finalize below
        // uses the last live drag position rather than wherever the pointer sits
        // on the frame that happens to flush the release.
        if (colDragging && app.focus.pressedId >= 0) { st.dropVis = dropVisLocal; }
        // Finalize when the button is no longer held. The App clears the press on
        // mouse-up before this render runs, so `pressedId < 0` reliably marks the
        // release frame even when the synthetic event's kind is coalesced away.
        if (st.dragCol >= 0 && app.focus.pressedId < 0) {
            if (st.dragColMoved) {
                int beforeCol = -1;
                if (st.dropVis >= 0 && st.dropVis < vorder.Count) {
                    beforeCol = vorder[st.dropVis];
                }
                if (beforeCol != st.dragCol) {
                    DataTable.MoveColumn(st, st.dragCol, beforeCol);
                    st.hitCol = st.dragCol;
                    st.ColumnReorder.Raise();
                }
            }
            st.dragCol = -1;
            st.dragColMoved = false;
            st.dropVis = -1;
            app.RequestRedraw();
        }

        // ---------------- body (virtualised) ----------------
        int total = st.dispKind.Count;
        int summaryH = 0;
        if (st.showSummary) { summaryH = rowH; }
        int pagerH = 0;
        if (st.paged) { pagerH = app.Scale(38); }

        int bodyTop = y + headerH;
        int bodyH = viewH - headerH - summaryH - pagerH;
        if (bodyH < rowH) { bodyH = rowH; }
        int visRows = bodyH / rowH;
        if (visRows < 1) { visRows = 1; }

        // In paged mode the visible window is a whole page; otherwise it is the
        // virtual-scroll offset.
        int start = 0;
        if (st.paged) {
            st.pageRows = visRows;
            int totalPages = 1;
            if (total > 0) { totalPages = (total + visRows - 1) / visRows; }
            int cur = st.pageModel.Get();
            if (cur > totalPages) { cur = totalPages; st.pageModel.Set(cur); }
            if (cur < 1) { cur = 1; st.pageModel.Set(cur); }
            start = (cur - 1) * visRows;
        } else {
            start = st.scrollRow;
            if (start > total - visRows) { start = total - visRows; }
            if (start < 0) { start = 0; }
            st.scrollRow = start;
        }

        // Normalised cell-range bounds (order-index rows + column indices) for
        // highlighting the drag-selected rectangle behind the cells.
        bool hasRange = DataTable.HasRange(st);
        int rgR0 = 0;
        int rgR1 = -1;
        int rgC0 = 0;
        int rgC1 = -1;
        if (hasRange) {
            rgR0 = DataTable.MinI(st.rangeR0, st.rangeR1);
            rgR1 = DataTable.MaxI(st.rangeR0, st.rangeR1);
            rgC0 = DataTable.MinI(st.rangeC0, st.rangeC1);
            rgC1 = DataTable.MaxI(st.rangeC0, st.rangeC1);
        }

        // screen rect of the cell currently being edited (captured in the loop
        // so the inline editor can be drawn over it after the rows are painted)
        int edX = 0;
        int edY = 0;
        int edW = 0;
        int edH = 0;
        bool edVis = false;

        int r = 0;
        while (r < visRows && (start + r) < total) {
            int oiRow = start + r;
            int ry = bodyTop + r * rowH;

            // Group header row: indented chevron + caption + row count. It
            // occupies a display slot but carries no data-row payload.
            if (st.dispKind[oiRow] == 1) {
                int gi = st.dispRow[oiRow];
                int lvl = st.grpLevel[gi];
                c.FillRect(x + 1, ry, viewW - 2, rowH, t.bgTertiary);
                int gcx = x + numW + selW + lvl * app.Scale(16) + app.Scale(6);
                bool gcoll = st.grpCollapsed[gi];
                string chev = "chevron-down";
                if (gcoll) { chev = "chevron-right"; }
                int chSz = app.Scale(14);
                Icon.Draw(c, chev, gcx, ry + (rowH - chSz) / 2, chSz, t.textSecondary);
                string glbl = st.grpLabel[gi] + "  (" + Convert.ToString(st.grpCount[gi]) + ")";
                c.DrawText(gcx + chSz + app.Scale(4),
                    ry + (rowH - t.fontSizeMedium) / 2, glbl, t.textPrimary, t.fontSizeMedium);
                c.FillRect(x + 1, ry + rowH - 1, viewW - 2, 1, gridColor);
                r = r + 1;
                continue;
            }

            int rowIdx = st.dispRow[oiRow];
            bool rowInRange = hasRange && oiRow >= rgR0 && oiRow <= rgR1;

            int rowId = app.focus.AllocId();
            app.hitTester.Register(HitRegion.Create(rowId, x, ry, viewW, rowH, 0));
            bool rHover = app.focus.IsHovered(rowId);
            bool rSel = st.selected[rowIdx];

            int rowBg = t.bgPrimary;
            if (st.striped && (st.dispNo[oiRow] % 2 == 0)) { rowBg = t.bgSecondary; }
            if (rSel) { rowBg = t.bgActive; }
            if (rHover) { rowBg = t.bgHover; }
            c.FillRect(x + 1, ry, viewW - 2, rowH, rowBg);

            int cx2 = x;
            if (st.showRowNum) {
                // Sequential display position (1,2,3…) in the current sorted/
                // filtered view — NOT the original data index, so the row-number
                // column stays ordered instead of jumping around when the user
                // sorts or filters.
                c.DrawTextCentered(cx2, ry, numW, rowH, Convert.ToString(st.dispNo[oiRow]), t.textTertiary, t.fontSizeSmall);
                cx2 = cx2 + numW;
            }
            if (st.showSelect) {
                int box = app.Scale(16);
                int bx = cx2 + (selW - box) / 2;
                int by = ry + (rowH - box) / 2;
                if (rSel) {
                    c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.primary);
                    int ins = app.Scale(3);
                    Icon.Draw(c, "check", bx + ins, by + ins, box - ins * 2, t.textInverse);
                } else {
                    c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.bgPrimary);
                    c.DrawRect(bx, by, box, box, t.borderPrimary, 1);
                }
                int selId = app.focus.AllocId();
                app.hitTester.Register(HitRegion.Create(selId, cx2, ry, selW, rowH, 0));
                if (app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == selId) {
                    st.selected[rowIdx] = !rSel;
                    st.hitRow = rowIdx;
                    st.SelectionChanged.Raise();
                    app.RequestRedraw();
                }
                cx2 = cx2 + selW;
            }

            c.PushClip(firstDataX, ry, dataViewW, rowH);
            int coi = 0;
            int ccl = firstDataX - st.scrollX;
            while (coi < vorder.Count && ccl < clipRight) {
                int cc = vorder[coi];
                int cw = st.dispW[cc];
                if (ccl + cw > firstDataX) {
                    if (rowInRange && cc >= rgC0 && cc <= rgC1) {
                        c.FillRect(ccl, ry, cw, rowH, t.bgActive);
                    }
                    if (st.editing && rowIdx == st.editRow && cc == st.editCol) {
                        edX = ccl; edY = ry; edW = cw; edH = rowH; edVis = true;
                    }
                    int cfLo = 0;
                    int cfHi = 0;
                    if (cc < st.cfMin.Count) { cfLo = st.cfMin[cc]; cfHi = st.cfMax[cc]; }
                    DataTable.DrawCell(app, cols[cc], src.CellText(rowIdx, cc), ccl, ry, cw, rowH, cfLo, cfHi);
                }
                ccl = ccl + cw;
                coi = coi + 1;
            }
            c.PopClip();

            c.FillRect(x + 1, ry + rowH - 1, viewW - 2, 1, gridColor);
            r = r + 1;
        }

        // ---------------- freeze boundary ----------------
        // A subtle accent divider marks where the frozen (pinned) columns end.
        if (pinnedW > 0) {
            int freezeX = x + numW + selW + pinnedW;
            if (freezeX < clipRight) {
                c.FillRect(freezeX, y, app.Scale(2), bodyTop + bodyH - y, t.borderPrimary);
            }
        }

        // ---------------- row-drag drop indicator ----------------
        if (st.dragRow >= 0 && st.dragMoved) {
            int dropRow = (app.mouseY - bodyTop) / rowH;
            if (dropRow < 0) { dropRow = 0; }
            if (dropRow > visRows) { dropRow = visRows; }
            int dy = bodyTop + dropRow * rowH;
            if (dy < bodyTop) { dy = bodyTop; }
            if (dy > bodyTop + bodyH) { dy = bodyTop + bodyH; }
            c.FillRect(x + 1, dy - 1, viewW - 2, app.Scale(2), t.primary);
        }

        // ---------------- inline cell editor overlay ----------------
        if (st.editing && edVis && edW > app.Scale(8)) {
            int epad = t.paddingSmall;
            int efs = t.fontSizeMedium;
            int etY = edY + (edH - Canvas.FontHeight(efs)) / 2;
            c.FillRect(edX, edY, edW, edH, t.bgPrimary);
            c.DrawRect(edX, edY, edW, edH, t.borderFocus, 2);
            c.PushClip(edX + epad, edY, edW - epad * 2, edH);
            c.DrawText(edX + epad, etY, st.editBuf, t.textPrimary, efs);
            int ecaretX = edX + epad + Canvas.MeasureText(Text.Left(st.editBuf, st.editCur), efs);
            c.FillRect(ecaretX, etY, 1, Canvas.FontHeight(efs), t.primary);
            c.PopClip();
            app.SetImeCaret(ecaretX, etY + Canvas.FontHeight(efs));
        }

        // ---------------- body pointer interaction ----------------
        // Map the pointer to an order-position row and a data column purely from
        // geometry (works for range-extend / reorder even outside hit regions).
        int ptrOi = -1;
        if (app.mouseY >= bodyTop && app.mouseY < bodyTop + bodyH && app.mouseX >= x && app.mouseX < clipRight) {
            int rr2 = (app.mouseY - bodyTop) / rowH;
            if (rr2 >= 0 && rr2 < visRows && (start + rr2) < total) { ptrOi = start + rr2; }
        }
        int ptrCol = -1;
        if (ptrOi >= 0 && app.mouseX >= firstDataX) {
            int colL = firstDataX - st.scrollX;
            int pci = 0;
            while (pci < vorder.Count) {
                int cci = vorder[pci];
                int cwv = st.dispW[cci];
                if (app.mouseX >= colL && app.mouseX < colL + cwv) { ptrCol = cci; pci = vorder.Count; }
                else { colL = colL + cwv; pci = pci + 1; }
            }
        }
        int ek = app.window.EventKind();
        int eb = app.window.EventButton();
        int emods = app.window.EventMods();
        // While the context menu is open it is modal: swallow body events so a
        // click on a menu item can't also start a range/selection behind it.
        // (RenderContextMenu reads the raw event to drive item hits / dismiss.)
        if (st.ctxOpen) { ek = 0; }
        if (st.hdrCtxOpen) { ek = 0; }

        // ---------------- inline editor key handling ----------------
        // While an editor is open it owns the keyboard: printable input, caret
        // movement and commit/cancel. Events are swallowed so they don't also
        // drive selection/scroll behind the editor.
        // Only keyboard events are swallowed here; mouse presses fall through to
        // the press handler, which commits the edit before re-selecting.
        if (st.editing) {
            if (ek == 6) {
                int code = app.window.EventKeyCode();
                if (code == 13) { DataTable.CommitEdit(st, cols, src); }
                else if (code == 27) { DataTable.CancelEdit(st); }
                else if (code == 9) { DataTable.CommitEdit(st, cols, src); }
                else if (code == 8) {
                    if (st.editCur > 0) {
                        int startp = Text.PrevCharStart(st.editBuf, st.editCur);
                        st.editBuf = Text.DeleteBefore(st.editBuf, st.editCur);
                        st.editCur = startp;
                    }
                } else {
                    string ch = Text.CharStr(code);
                    if (ch.Length > 0) {
                        st.editBuf = Text.InsertAt(st.editBuf, st.editCur, ch);
                        st.editCur = st.editCur + ch.Length;
                    }
                }
                app.RequestRedraw();
                ek = 0;
            } else if (ek == 4) {
                int kc = app.window.EventKeyCode();
                if (kc == 27) { DataTable.CancelEdit(st); }
                else if (kc == 13) { DataTable.CommitEdit(st, cols, src); }
                else if (kc == 37) { if (st.editCur > 0) { st.editCur = Text.PrevCharStart(st.editBuf, st.editCur); } }
                else if (kc == 39) { if (st.editCur < st.editBuf.Length) { st.editCur = Text.NextCharEnd(st.editBuf, st.editCur); } }
                else if (kc == 36) { st.editCur = 0; }
                else if (kc == 35) { st.editCur = st.editBuf.Length; }
                else if (kc == 46) { if (st.editCur < st.editBuf.Length) { st.editBuf = Text.RemoveAt(st.editBuf, st.editCur); } }
                app.RequestRedraw();
                ek = 0;
            }
        }

        // F2 / Enter opens an editor on the active editable cell (Excel-style).
        if (!st.editing && ek == 4) {
            int kc2 = app.window.EventKeyCode();
            if ((kc2 == 113 || kc2 == 13) && st.hitRow >= 0 && st.hitCol >= 0
                && st.hitCol < cols.Count && cols[st.hitCol].editable) {
                DataTable.BeginEdit(st, cols, src, st.hitRow, st.hitCol);
                ek = 0;
                app.RequestRedraw();
            }
        }

        // left press
        if (ek == 2 && eb == 0 && ptrOi >= 0) {
            if (st.dispKind[ptrOi] == 1) {
                // group header press: toggle collapse of that group
                int gi = st.dispRow[ptrOi];
                DataTable.ToggleCollapse(st, st.grpKey[gi]);
                app.RequestRedraw();
            } else if (app.mouseX >= x && app.mouseX < x + numW) {
                // row-number press: could become a row click or a reorder drag
                st.dragRow = ptrOi;
                st.dragStartY = app.mouseY;
                st.dragMoved = false;
            } else if (app.mouseX >= firstDataX && ptrCol >= 0) {
                // A press on the cell that's already the sole active selection
                // (a slow second click) opens the inline editor; otherwise begin
                // a rectangular range selection. A press while editing commits
                // first, then re-selects.
                bool sameCell = (!st.editing) && st.hitOrder == ptrOi && st.hitCol == ptrCol
                    && st.rangeR0 == st.rangeR1 && st.rangeC0 == st.rangeC1;
                if (st.editing) { DataTable.CommitEdit(st, cols, src); }
                if (sameCell && cols[ptrCol].editable) {
                    DataTable.BeginEdit(st, cols, src, st.dispRow[ptrOi], ptrCol);
                    app.RequestRedraw();
                } else {
                    st.rangeR0 = ptrOi;
                    st.rangeR1 = ptrOi;
                    st.rangeC0 = ptrCol;
                    st.rangeC1 = ptrCol;
                    st.rangeDrag = true;
                    st.selAnchor = ptrOi;
                    st.hitOrder = ptrOi;
                    st.hitRow = st.dispRow[ptrOi];
                    st.hitCol = ptrCol;
                    st.CellClick.Raise();
                    app.RequestRedraw();
                }
            }
        }

        // drag move
        if (ek == 1) {
            if (st.rangeDrag && ptrOi >= 0) {
                st.rangeR1 = ptrOi;
                if (ptrCol >= 0) { st.rangeC1 = ptrCol; }
                app.RequestRedraw();
            }
            if (st.dragRow >= 0) {
                int dd = app.mouseY - st.dragStartY;
                if (dd < 0) { dd = 0 - dd; }
                if (dd > rowH / 2) { st.dragMoved = true; app.RequestRedraw(); }
            }
        }

        // left release
        if (ek == 3 && eb == 0) {
            if (st.rangeDrag) { st.rangeDrag = false; app.RequestRedraw(); }
            if (st.dragRow >= 0) {
                if (st.groupCols.Count == 0 && st.dragMoved && ptrOi >= 0 && ptrOi != st.dragRow
                    && st.dispKind[ptrOi] == 0) {
                    DataTable.MoveOrder(st, st.dragRow, ptrOi);
                    // manual order — drop any active sort without re-running
                    // Recompute (which would rebuild st.order and lose the move).
                    st.sortCols.Clear(); st.sortDirs.Clear();
                    DataTable.SyncPrimary(st);
                    app.RequestRedraw();
                } else if (!st.dragMoved && st.dispKind[st.dragRow] == 0) {
                    // treat as a row-selection click (按行选择)
                    int ri = st.dispRow[st.dragRow];
                    st.hitOrder = st.dragRow;
                    st.hitRow = ri;
                    st.hitCol = -1;
                    st.RowClick.Raise();
                    st.SelectionChanged.Raise();
                    bool shift = (emods & 2) != 0;
                    bool ctrl = (emods & 1) != 0;
                    if (shift && st.selAnchor >= 0) {
                        DataTable.SelectAllRows(st, false);
                        int a = DataTable.MinI(st.selAnchor, st.dragRow);
                        int b = DataTable.MaxI(st.selAnchor, st.dragRow);
                        int kk = a;
                        while (kk <= b) { if (kk >= 0 && kk < st.dispKind.Count && st.dispKind[kk] == 0) { st.selected[st.dispRow[kk]] = true; } kk = kk + 1; }
                    } else if (ctrl) {
                        st.selected[ri] = !st.selected[ri];
                        st.selAnchor = st.dragRow;
                    } else {
                        DataTable.SelectAllRows(st, false);
                        st.selected[ri] = true;
                        st.selAnchor = st.dragRow;
                        DataTable.ClearRange(st);
                    }
                    app.RequestRedraw();
                }
                st.dragRow = -1;
                st.dragMoved = false;
            }
        }

        // double-click on a body row
        if (ek == 3 && eb == 0 && ptrOi >= 0 && st.dispKind[ptrOi] == 0 && app.DoubleClickNow()) {
            st.hitOrder = ptrOi;
            st.hitRow = st.dispRow[ptrOi];
            st.RowDoubleClick.Raise();
        }

        // right press => context menu
        if (ek == 2 && eb == 1 && st.openMenu < 0
            && app.mouseX >= x && app.mouseX < x + viewW
            && app.mouseY >= bodyTop && app.mouseY < bodyTop + bodyH) {
            // if right-clicking a row outside any current range/selection, make
            // that row the selection so the menu's copy/export act on something.
            if (ptrOi >= 0 && st.dispKind[ptrOi] == 0 && !DataTable.HasRange(st)) {
                int ri = st.dispRow[ptrOi];
                if (!st.selected[ri]) {
                    DataTable.SelectAllRows(st, false);
                    st.selected[ri] = true;
                    st.selAnchor = ptrOi;
                }
            }
            st.ctxOpen = true;
            st.ctxX = app.mouseX;
            st.ctxY = app.mouseY;
            app.RequestRedraw();
        }

        // empty state
        if (total == 0) {
            c.DrawTextCentered(x, bodyTop, viewW, bodyH, "No matching rows", t.textTertiary, t.fontSizeMedium);
        }

        // ---------------- summary (total) row ----------------
        if (st.showSummary) {
            int sumY = bodyTop + bodyH;
            c.FillRect(x + 1, sumY, viewW - 2, summaryH, t.bgSecondary);
            c.FillRect(x + 1, sumY, viewW - 2, 1, gridColor);
            int sx = x + numW + selW;
            if (st.showRowNum || st.showSelect) {
                c.DrawTextCentered(x, sumY, numW + selW, summaryH, "Σ", t.textTertiary, t.fontSizeSmall);
            }
            c.PushClip(firstDataX, sumY, dataViewW, summaryH);
            int soi = 0;
            sx = firstDataX - st.scrollX;
            while (soi < vorder.Count && sx < clipRight) {
                int sc = vorder[soi];
                int cw = st.dispW[sc];
                if (sx + cw > firstDataX) {
                    string stxt = "";
                    if (sc < st.summaryText.Count) { stxt = st.summaryText[sc]; }
                    if (stxt.Length > 0) {
                        int pad = t.paddingSmall;
                        string shown = DataTable.Truncate(stxt, fs, cw - pad * 2);
                        int tw = Canvas.MeasureText(shown, fs);
                        int tx = sx + pad;
                        if (cols[sc].align == 2) { tx = sx + cw - pad - tw; }
                        else if (cols[sc].align == 1) { tx = sx + (cw - tw) / 2; }
                        int ty = sumY + (summaryH - Canvas.FontHeight(fs)) / 2;
                        c.DrawText(tx, ty, shown, t.textPrimary, fs);
                    }
                }
                sx = sx + cw;
                soi = soi + 1;
            }
            c.PopClip();
        }

        // ---------------- pager footer (reuses the Pagination widget) ----------------
        if (st.paged) {
            int fY = bodyTop + bodyH + summaryH;
            c.FillRect(x + 1, fY, viewW - 2, pagerH, t.bgSecondary);
            c.FillRect(x + 1, fY, viewW - 2, 1, gridColor);
            int totalPages = 1;
            if (total > 0) { totalPages = (total + visRows - 1) / visRows; }
            int cur = st.pageModel.Get();
            int pgW = Pagination.MeasureWidth(app, totalPages, cur);
            int pgX = x + (viewW - pgW) / 2;
            if (pgX < x + t.paddingMedium) { pgX = x + t.paddingMedium; }
            int pgY = fY + (pagerH - t.heightMedium) / 2;
            int pgFirst = Pagination.Render(app, pgX, pgY, totalPages, st.pageModel);
            Pagination.HandleClick(app, pgFirst, totalPages, st.pageModel);
            // range info on the left
            int from = (cur - 1) * visRows + 1;
            int to = cur * visRows;
            if (to > total) { to = total; }
            if (total == 0) { from = 0; }
            string info = Convert.ToString(from) + "-" + Convert.ToString(to) + " / " + Convert.ToString(total);
            c.DrawText(x + t.paddingMedium, pgY + (t.heightMedium - Canvas.FontHeight(t.fontSizeSmall)) / 2, info, t.textTertiary, t.fontSizeSmall);
        }

        // ---------------- vertical scrollbar ----------------
        if (!st.paged && total > visRows && visRows > 0) {
            int sbW = app.Scale(8);
            int sbX = x + viewW - sbW - app.Scale(2);
            int trackY = bodyTop + app.Scale(2);
            int trackH = bodyH - app.Scale(4);
            int thumbH = trackH * visRows / total;
            if (thumbH < app.Scale(24)) { thumbH = app.Scale(24); }
            int maxStart = total - visRows;
            int thumbY = trackY;
            if (maxStart > 0) { thumbY = trackY + (trackH - thumbH) * start / maxStart; }

            int sbId = app.focus.AllocId();
            bool sbHover = app.focus.IsHovered(sbId);
            int thumbColor = t.scrollbar;
            if (sbHover || app.focus.pressedId == sbId) { thumbColor = t.scrollbarHover; }
            c.FillRoundRect(sbX, thumbY, sbW, thumbH, sbW / 2, thumbColor);
            app.hitTester.Register(HitRegion.Create(sbId, sbX, trackY, sbW, trackH, 0));
            if (app.focus.pressedId == sbId && maxStart > 0) {
                int rel = app.mouseY - trackY - thumbH / 2;
                int denom = trackH - thumbH;
                if (denom < 1) { denom = 1; }
                int ns = rel * maxStart / denom;
                if (ns < 0) { ns = 0; }
                if (ns > maxStart) { ns = maxStart; }
                if (ns != st.scrollRow) { st.scrollRow = ns; st.ScrollChanged.Raise(); app.RequestRedraw(); }
            }
        }

        // ---------------- horizontal scrollbar ----------------
        if (maxScrollX > 0) {
            int hbH = app.Scale(8);
            int hbY = bodyTop + bodyH - hbH - app.Scale(2);
            int htrackX = firstDataX + app.Scale(2);
            int htrackW = dataViewW - app.Scale(4);
            int thumbW = htrackW * availData / dataW;
            if (thumbW < app.Scale(24)) { thumbW = app.Scale(24); }
            int thumbX = htrackX + (htrackW - thumbW) * st.scrollX / maxScrollX;
            int hbId = app.focus.AllocId();
            bool hbHover = app.focus.IsHovered(hbId);
            int hbColor = t.scrollbar;
            if (hbHover || app.focus.pressedId == hbId) { hbColor = t.scrollbarHover; }
            c.FillRoundRect(thumbX, hbY, thumbW, hbH, hbH / 2, hbColor);
            app.hitTester.Register(HitRegion.Create(hbId, htrackX, hbY, htrackW, hbH, 0));
            if (app.focus.pressedId == hbId) {
                int rel = app.mouseX - htrackX - thumbW / 2;
                int denom = htrackW - thumbW;
                if (denom < 1) { denom = 1; }
                int ns = rel * maxScrollX / denom;
                if (ns < 0) { ns = 0; }
                if (ns > maxScrollX) { ns = maxScrollX; }
                if (ns != st.scrollX) { st.scrollX = ns; app.RequestRedraw(); }
            }
        }

        // ---------------- mouse-wheel scrolls the table body ----------------
        // Claim the wheel while the pointer is over the body so the surrounding
        // page doesn't scroll instead, then advance the virtual row window.
        if (visRows > 0) {
            app.CaptureWheel(x, bodyTop, viewW, bodyH);
        }
        if (st.openMenu < 0 && ownsBodyWheel
            && maxScrollX > 0 && (app.window.EventMods() & 2) != 0) {
            // Shift+wheel pans the columns horizontally.
            int hDelta = app.window.EventKeyCode();
            int hStep = hDelta / 120;
            if (hStep == 0) { if (hDelta > 0) { hStep = 1; } else if (hDelta < 0) { hStep = 0 - 1; } }
            int nsx = st.scrollX - hStep * app.Scale(48);
            if (nsx < 0) { nsx = 0; }
            if (nsx > maxScrollX) { nsx = maxScrollX; }
            if (nsx != st.scrollX) { st.scrollX = nsx; app.RequestRedraw(); }
        } else if (st.openMenu < 0 && ownsBodyWheel) {
            if (total > visRows) {
                int delta = app.window.EventKeyCode();
                int step = delta / 120;
                if (step == 0) { if (delta > 0) { step = 1; } else if (delta < 0) { step = 0 - 1; } }
                if (st.paged) {
                    // wheel flips whole pages
                    int totalPages = (total + visRows - 1) / visRows;
                    int cp = st.pageModel.Get();
                    int np = cp - step;
                    if (np < 1) { np = 1; }
                    if (np > totalPages) { np = totalPages; }
                    if (np != cp) { st.pageModel.Set(np); app.RequestRedraw(); }
                } else {
                    int ns = st.scrollRow - step * 3;
                    int maxStart = total - visRows;
                    if (ns < 0) { ns = 0; }
                    if (ns > maxStart) { ns = maxStart; }
                    if (ns != st.scrollRow) { st.scrollRow = ns; st.ScrollChanged.Raise(); app.RequestRedraw(); }
                }
            }
        }

        // ---------------- header set-filter menu (overlay, drawn last) ----------------
        if (st.openMenu >= 0 && st.openMenu < cols.Count) {
            DataTable.RenderMenu(app, x, y, viewW, headerH, numW, selW, cols, src, st);
        }

        // ---------------- right-click context menu (overlay) ----------------
        if (st.ctxOpen) {
            DataTable.RenderContextMenu(app, x, y, viewW, viewH, cols, src, st);
        }

        // ---------------- header column context menu (overlay) ----------------
        if (st.hdrCtxOpen) {
            DataTable.RenderHeaderMenu(app, x, y, viewW, viewH, cols, src, st);
        }

        // ---------------- chart-from-selection overlay ----------------
        if (st.chartOpen) {
            DataTable.RenderChart(app, x, y, viewW, viewH, st);
        }

        // ---------------- transient toast (copy/export feedback) ----------------
        if (st.toastFrames > 0 && st.toast.Length > 0) {
            int tfs = t.fontSizeSmall;
            int tw = Canvas.MeasureText(st.toast, tfs) + app.Scale(24);
            int th = t.heightMedium;
            int tx = x + (viewW - tw) / 2;
            int tyy = y + viewH - th - app.Scale(12);
            c.FillRoundRect(tx, tyy, tw, th, t.borderRadiusMedium, t.textPrimary);
            c.DrawTextCentered(tx, tyy, tw, th, st.toast, t.bgPrimary, tfs);
            st.toastFrames = st.toastFrames - 1;
            if (st.toastFrames > 0) { app.RequestRedraw(); }
        }
    }

    // ---------- right-click context menu ----------

    static void CtxItem(App app, int mx, int my, int mw, int ih, string label, string accel) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        if (hov) { c.FillRect(mx, my, mw, ih, t.bgHover); }
        c.DrawText(mx + app.Scale(12), my + (ih - Canvas.FontHeight(t.fontSizeSmall)) / 2, label, t.textPrimary, t.fontSizeSmall);
        if (accel.Length > 0) {
            int aw = Canvas.MeasureText(accel, t.fontSizeSmall);
            c.DrawText(mx + mw - aw - app.Scale(12), my + (ih - Canvas.FontHeight(t.fontSizeSmall)) / 2, accel, t.textTertiary, t.fontSizeSmall);
        }
        app.hitTester.Register(HitRegion.Create(id, mx, my, mw, ih, 0));
    }

    // A header-menu aggregate row: shows a check on the active mode, and on
    // click applies it and closes the menu. Returns the next item's y.
    static int AggItem(App app, int mx, int iy, int mw, int ih,
                       DataTableState st, int col, int mode, string label, int curAgg) {
        string mark = "";
        if (mode == curAgg) { mark = "✓"; }
        DataTable.CtxItem(app, mx, iy, mw, ih, label, mark);
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SetAggregate(st, col, mode);
            st.hitCol = col; st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        return iy + ih;
    }

    static bool CtxHit(App app, int mx, int my, int mw, int ih) {
        // Was the row spanning (mx,my,mw,ih) just clicked? Uses geometry so the
        // ids stay simple; the menu is modal-ish (drawn last, wins hit-testing).
        return app.window.EventKind() == 3 && app.window.EventButton() == 0
               && app.mouseX >= mx && app.mouseX < mx + mw
               && app.mouseY >= my && app.mouseY < my + ih;
    }

    static void Flash(DataTableState st, string msg) {
        st.toast = msg;
        st.toastFrames = 90;
    }

    static void RenderContextMenu(App app, int x, int y, int viewW, int viewH,
                                  List<DataColumn> cols, DataSource src, DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int mw = app.Scale(230);
        int ih = t.heightMedium;
        int sepH = app.Scale(9);

        // menu items: label, accelerator, kind (0 item, 1 separator)
        // 0 copy, 1 copy-with-headers, 2 export csv, 3 chart-from-selection,
        // sep, 4 select all, sep, 5 clear
        int nItems = 6;
        int mh = ih * nItems + sepH * 2 + app.Scale(8);

        int mx = st.ctxX;
        int my = st.ctxY;
        if (mx + mw > x + viewW) { mx = x + viewW - mw - app.Scale(2); }
        if (my + mh > y + viewH) { my = y + viewH - mh - app.Scale(2); }
        if (mx < x) { mx = x; }
        if (my < y) { my = y; }

        // claim wheel + swallow clicks over the whole menu so gaps and the page
        // beneath it don't get scrolled or fall through (items register later)
        app.CaptureWheel(mx, my, mw, mh);
        app.BlockHitsRect(mx, my, mw, mh);
        c.FillRoundRect(mx, my, mw, mh, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(mx, my, mw, mh, t.borderPrimary, 1);

        int iy = my + app.Scale(4);
        DataTable.CtxItem(app, mx, iy, mw, ih, "复制  Copy", "Ctrl+C");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            Clipboard.SetText(DataTable.BuildText(st, cols, src, false, false));
            DataTable.Flash(st, "已复制到剪贴板");
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "复制（含表头）", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            Clipboard.SetText(DataTable.BuildText(st, cols, src, false, true));
            DataTable.Flash(st, "已复制（含表头）");
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "导出 CSV", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            bool ok = SysFile.Write("datatable_export.csv", DataTable.BuildText(st, cols, src, true, true));
            if (ok) { DataTable.Flash(st, "已导出 datatable_export.csv"); }
            else { DataTable.Flash(st, "导出失败"); }
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "从选区生成图表  Chart", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            if (DataTable.BuildChartFromRange(st, cols, src)) {
                st.chartOpen = true;
            } else {
                DataTable.Flash(st, "请先框选含数值列的区域");
            }
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "全选", "Ctrl+A");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SelectAllRows(st, true);
            DataTable.ClearRange(st);
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "清除选择", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SelectAllRows(st, false);
            DataTable.ClearRange(st);
            st.ctxOpen = false;
            app.RequestRedraw();
        }

        // click outside closes the menu
        if (app.window.EventKind() == 3
            && !(app.mouseX >= mx && app.mouseX < mx + mw && app.mouseY >= my && app.mouseY < my + mh)) {
            st.ctxOpen = false;
            app.RequestRedraw();
        }
    }

    // ---------- chart-from-selection overlay ----------
    // A modal bar chart built from the selected range (see BuildChartFromRange).
    // Closes on the [x] button, a click outside the panel, or Escape.
    static void RenderChart(App app, int x, int y, int viewW, int viewH,
                            DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int m = app.Scale(20);
        int px = x + m;
        int py = y + m;
        int pw = viewW - m * 2;
        int ph = viewH - m * 2;
        if (pw < app.Scale(120) || ph < app.Scale(100)) { st.chartOpen = false; return; }

        // scrim + panel
        c.FillRect(x, y, viewW, viewH, t.overlay);
        // modal: claim wheel + block all hits beneath the chart overlay
        app.CaptureWheel(x, y, viewW, viewH);
        app.BlockHitsRect(x, y, viewW, viewH);
        c.FillRoundRect(px, py, pw, ph, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(px, py, pw, ph, t.borderPrimary, 1);

        // title bar
        int th = t.heightLarge;
        c.FillRect(px + 1, py + 1, pw - 2, th, t.bgSecondary);
        c.FillRect(px + 1, py + th, pw - 2, 1, t.divider);
        c.DrawText(px + app.Scale(14), py + (th - Canvas.FontHeight(t.fontSizeMedium)) / 2,
                   "图表 Chart · " + st.chartTitle, t.textPrimary, t.fontSizeMedium);

        // close button
        int cbs = app.Scale(22);
        int cbx = px + pw - cbs - app.Scale(8);
        int cby = py + (th - cbs) / 2;
        bool cbHot = app.mouseX >= cbx && app.mouseX < cbx + cbs
                     && app.mouseY >= cby && app.mouseY < cby + cbs;
        if (cbHot) { c.FillRoundRect(cbx, cby, cbs, cbs, app.Scale(4), t.bgHover); }
        c.DrawTextCentered(cbx, cby, cbs, cbs, "×", t.textPrimary, t.fontSizeLarge);

        // plot area
        int axisW = app.Scale(44);
        int plotX = px + axisW;
        int plotTop = py + th + app.Scale(14);
        int plotBottom = py + ph - app.Scale(30);
        int plotRight = px + pw - app.Scale(16);
        int plotW = plotRight - plotX;
        int plotH = plotBottom - plotTop;
        int n = st.chartVals.Count;
        if (plotH < app.Scale(20) || plotW < app.Scale(20) || n <= 0) {
            // still allow closing even if too small to plot
        } else {
            int mx = st.chartMax;
            if (mx < 1) { mx = 1; }

            // baseline + max/zero axis labels + a faint midline
            c.FillRect(plotX, plotBottom, plotW, 1, t.borderPrimary);
            c.DrawText(px + app.Scale(8), plotTop - Canvas.FontHeight(t.fontSizeSmall) / 2,
                       Convert.ToString(mx), t.textTertiary, t.fontSizeSmall);
            c.DrawText(px + app.Scale(8), plotBottom - Canvas.FontHeight(t.fontSizeSmall) / 2,
                       "0", t.textTertiary, t.fontSizeSmall);
            int midY = plotTop + plotH / 2;
            c.FillRect(plotX, midY, plotW, 1, t.divider);

            int slotW = plotW / n;
            int barW = slotW * 3 / 5;
            if (barW < app.Scale(4)) { barW = app.Scale(4); }
            int i = 0;
            while (i < n) {
                int av = st.chartVals[i];
                if (av < 0) { av = 0 - av; }
                int bh = av * plotH / mx;
                if (bh < 1 && av > 0) { bh = 1; }
                int slotL = plotX + slotW * i;
                int bx = slotL + (slotW - barW) / 2;
                int byy = plotBottom - bh;
                c.FillRect(bx, byy, barW, bh, t.primary);

                // value label above the bar
                string vlab = Convert.ToString(st.chartVals[i]);
                int vlw = Canvas.MeasureText(vlab, t.fontSizeSmall);
                int vlx = slotL + (slotW - vlw) / 2;
                int vly = byy - Canvas.FontHeight(t.fontSizeSmall) - app.Scale(2);
                if (vly < plotTop) { vly = plotTop; }
                c.DrawText(vlx, vly, vlab, t.textSecondary, t.fontSizeSmall);

                // category label below the baseline (clipped to the slot)
                c.PushClip(slotL, plotBottom + app.Scale(4), slotW, app.Scale(20));
                c.DrawTextCentered(slotL, plotBottom + app.Scale(4), slotW,
                                   Canvas.FontHeight(t.fontSizeSmall),
                                   st.chartLabels[i], t.textTertiary, t.fontSizeSmall);
                c.PopClip();
                i = i + 1;
            }
        }

        // close interactions: [x], click outside the panel, or Escape
        bool clicked = app.window.EventKind() == 3 && app.window.EventButton() == 0;
        bool inside = app.mouseX >= px && app.mouseX < px + pw
                      && app.mouseY >= py && app.mouseY < py + ph;
        if ((clicked && (cbHot || !inside))
            || (app.window.EventKind() == 4 && app.window.EventKeyCode() == 27)) {
            st.chartOpen = false;
            app.RequestRedraw();
        }
    }

    // ---------- header (column) context menu ----------
    // Right-clicking a column header opens this DevExpress/ag-Grid-style menu:
    // sort, auto-fit width, hide the column, restore all columns, and jump to
    // the set-filter popup. Layout mirrors RenderContextMenu (running iy).
    static void RenderHeaderMenu(App app, int x, int y, int viewW, int viewH,
                                 List<DataColumn> cols, DataSource src, DataTableState st) {
        int col = st.hdrCtxCol;
        if (col < 0 || col >= cols.Count) { st.hdrCtxOpen = false; return; }
        Canvas c = app.canvas;
        Theme t = app.theme;
        int mw = app.Scale(230);
        int ih = t.heightMedium;
        int sepH = app.Scale(9);

        bool canClear = st.sortCols.IndexOf(col) >= 0;
        bool anyHidden = DataTable.HiddenCount(st) > 0;
        bool canFilter = cols[col].filterable;
        bool canAgg = cols[col].numeric;

        int nItems = 4;                       // asc, desc, auto-fit, auto-fit-all
        if (canClear) { nItems = nItems + 1; }
        nItems = nItems + 1;                  // group by this column
        if (st.groupCols.Count > 0) { nItems = nItems + 1; }  // ungroup all
        nItems = nItems + 1;                  // pin / unpin column
        nItems = nItems + 1;                  // hide column
        if (anyHidden) { nItems = nItems + 1; }
        if (canAgg) { nItems = nItems + 6; }  // sum/avg/min/max/count/none total
        if (canFilter) { nItems = nItems + 1; }
        int nSep = 3;                         // after sort, after auto-fit, after group
        if (canAgg) { nSep = nSep + 1; }      // before aggregate items
        if (canFilter) { nSep = nSep + 1; }   // before filter item
        int mh = ih * nItems + sepH * nSep + app.Scale(8);

        int mx = st.hdrCtxX;
        int my = st.hdrCtxY;
        if (mx + mw > x + viewW) { mx = x + viewW - mw - app.Scale(2); }
        if (my + mh > y + viewH) { my = y + viewH - mh - app.Scale(2); }
        if (mx < x) { mx = x; }
        if (my < y) { my = y; }

        // claim wheel + swallow clicks over the whole menu so gaps and the page
        // beneath it don't get scrolled or fall through (items register later)
        app.CaptureWheel(mx, my, mw, mh);
        app.BlockHitsRect(mx, my, mw, mh);
        c.FillRoundRect(mx, my, mw, mh, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(mx, my, mw, mh, t.borderPrimary, 1);

        int iy = my + app.Scale(4);
        DataTable.CtxItem(app, mx, iy, mw, ih, "升序排序  Sort Ascending", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SortBy(st, col, 1);
            st.hitCol = col; st.Sort.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "降序排序  Sort Descending", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SortBy(st, col, 2);
            st.hitCol = col; st.Sort.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        if (canClear) {
            DataTable.CtxItem(app, mx, iy, mw, ih, "清除排序  Clear Sort", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                DataTable.ClearSort(st);
                st.Sort.Raise();
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "自动列宽  Auto-fit Column", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.AutoFitColumn(app, cols, src, st, col);
            st.hitCol = col; st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "自动全部列宽  Auto-fit All", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.AutoFitAll(app, cols, src, st);
            st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;

        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "按此列分组  Group by This", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.GroupBy(st, col);
            st.hitCol = col; st.GroupChanged.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        if (st.groupCols.Count > 0) {
            DataTable.CtxItem(app, mx, iy, mw, ih, "取消分组  Ungroup All", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                DataTable.Ungroup(st);
                st.GroupChanged.Raise();
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        string pinLbl = "冻结此列  Freeze Column";
        if (DataTable.IsPinned(st, col)) { pinLbl = "取消冻结  Unfreeze Column"; }
        DataTable.CtxItem(app, mx, iy, mw, ih, pinLbl, "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.TogglePin(st, col);
            st.hitCol = col; st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "隐藏此列  Hide Column", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            st.colHidden[col] = true;
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        if (anyHidden) {
            DataTable.CtxItem(app, mx, iy, mw, ih, "显示所有列  Show All Columns", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                DataTable.ShowAllColumns(st);
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        if (canAgg) {
            c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
            iy = iy + sepH;
            int curAgg = 0;
            if (col < st.aggMode.Count) { curAgg = st.aggMode[col]; }
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 1, "合计  Sum", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 2, "平均  Average", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 3, "最小  Min", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 4, "最大  Max", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 5, "计数  Count", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 0, "无汇总  No Total", curAgg);
        }

        if (canFilter) {
            c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
            iy = iy + sepH;
            DataTable.CtxItem(app, mx, iy, mw, ih, "筛选…  Filter", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                st.openMenu = col;
                st.filterTab = 0;
                st.searchText = "";
                st.valScroll = 0;
                st.editFocus = 0;
                st.batchLines = new List<string>();
                st.batchLines.Add("");
                st.batchExactFlag = 0;
                st.menuVals = DataTable.Distinct(src, col);
                st.menuMatched = st.menuVals;
                st.menuSearchCache = "";
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        // click outside closes the menu
        if (app.window.EventKind() == 3
            && !(app.mouseX >= mx && app.mouseX < mx + mw && app.mouseY >= my && app.mouseY < my + mh)) {
            st.hdrCtxOpen = false;
            app.RequestRedraw();
        }
    }

    // ---------- tabbed filter popup (DevExpress-style) ----------

    static bool TabBtn(App app, int bx, int by, int bw, int bh, string label, bool active) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        if (active) { c.FillRect(bx, by, bw, bh, t.bgActive); }
        else if (hov) { c.FillRect(bx, by, bw, bh, t.bgHover); }
        int fg = t.textSecondary;
        if (active) { fg = t.primary; }
        c.DrawTextCentered(bx, by, bw, bh, label, fg, t.fontSizeSmall);
        if (active) { c.FillRect(bx, by + bh - app.Scale(2), bw, app.Scale(2), t.primary); }
        app.hitTester.Register(HitRegion.Create(id, bx, by, bw, bh, 0));
        return app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == id;
    }

    static bool IconBtn(App app, int bx, int by, int bw, int bh, string icon, bool active) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        int col = t.textSecondary;
        if (active) { c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, t.bgActive); col = t.primary; }
        else if (hov) { c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, t.bgHover); }
        Icon.DrawCenteredIn(c, icon, bx, by, bw, bh, app.Scale(13), col);
        app.hitTester.Register(HitRegion.Create(id, bx, by, bw, bh, 0));
        return app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == id;
    }

    static bool TextBtn(App app, int bx, int by, int bw, int bh, string label, bool primary) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        int bg = t.bgSecondary;
        int fg = t.textPrimary;
        if (primary) { bg = t.primary; fg = t.textInverse; }
        else if (hov) { bg = t.bgHover; }
        c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, bg);
        if (!primary) { c.DrawRect(bx, by, bw, bh, t.borderPrimary, 1); }
        c.DrawTextCentered(bx, by, bw, bh, label, fg, t.fontSizeSmall);
        app.hitTester.Register(HitRegion.Create(id, bx, by, bw, bh, 0));
        return app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == id;
    }

    static void EditBox(App app, int bx, int by, int bw, int bh, string text, string ph, bool focused) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int fs = t.fontSizeSmall;
        int bc = t.borderPrimary;
        if (focused) { bc = t.borderFocus; }
        c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, t.bgPrimary);
        c.DrawRect(bx, by, bw, bh, bc, 1);
        int tpad = app.Scale(6);
        int ty = by + (bh - Canvas.FontHeight(fs)) / 2;
        string shown = DataTable.Truncate(text, fs, bw - tpad * 2);
        if (text.Length == 0) {
            c.DrawText(bx + tpad, ty, ph, t.textTertiary, fs);
        } else {
            c.DrawText(bx + tpad, ty, shown, t.textPrimary, fs);
        }
        if (focused) {
            int cxp = bx + tpad + Canvas.MeasureText(shown, fs);
            if (cxp > bx + bw - tpad) { cxp = bx + bw - tpad; }
            c.FillRect(cxp, ty, app.Scale(1), Canvas.FontHeight(fs), t.primary);
        }
    }

    static void RenderMenu(App app, int x, int y, int viewW, int headerH, int numW, int selW,
                           List<DataColumn> cols, DataSource src, DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int mi = st.openMenu;
        ColFilter f = st.filters[mi];

        int pad = app.Scale(10);
        int fs = t.fontSizeSmall;
        int fsM = t.fontSizeMedium;
        int rowH = app.Scale(28);
        int menuW = app.Scale(256);
        int menuH = app.Scale(348);

        // anchor under the column, clamp fully inside the window
        int mx = x + numW + selW - st.scrollX;
        int k = 0;
        while (k < mi) { mx = mx + st.dispW[k]; k = k + 1; }
        if (mx + menuW > x + viewW) { mx = x + viewW - menuW; }
        if (mx < x) { mx = x; }
        int my = y + headerH;
        int canH = c.Height();
        if (my + menuH > canH) { my = canH - menuH - app.Scale(6); }
        if (my < app.titlebarH) { my = app.titlebarH; }

        // claim the wheel over the popup so the page underneath doesn't scroll
        app.CaptureWheel(mx, my, menuW, menuH);
        // swallow clicks over the whole panel so empty areas don't fall through
        app.BlockHitsRect(mx, my, menuW, menuH);

        // route typed keys to the focused edit field
        if (app.window.EventKind() == 6 && st.editFocus != 0) {
            int chv = app.window.EventKeyCode();
            if (st.editFocus == 1) {
                if (chv == 8) { st.searchText = DataTable.Backspace(st.searchText); }
                else { string ad = DataTable.CharStr(chv); if (ad.Length > 0) { st.searchText = st.searchText + ad; } }
            } else if (st.editFocus == 2) {
                if (chv == 8) { f.textQuery = DataTable.Backspace(f.textQuery); }
                else { string ad = DataTable.CharStr(chv); if (ad.Length > 0) { f.textQuery = f.textQuery + ad; } }
                st.dirty = true;
            } else if (st.editFocus == 3) {
                int last = st.batchLines.Count - 1;
                if (last < 0) { st.batchLines.Add(""); last = 0; }
                if (chv == 13) { st.batchLines.Add(""); }
                else if (chv == 8) {
                    string cur = st.batchLines[last];
                    if (cur.Length > 0) { st.batchLines[last] = DataTable.Backspace(cur); }
                    else if (last > 0) { st.batchLines.RemoveAt(last); }
                } else {
                    string ad = DataTable.CharStr(chv);
                    if (ad.Length > 0) { st.batchLines[last] = st.batchLines[last] + ad; }
                }
            }
            app.RequestRedraw();
        }

        // panel
        c.FillRoundRect(mx + app.Scale(2), my + app.Scale(3), menuW, menuH, t.borderRadiusMedium, t.overlay);
        c.FillRoundRect(mx, my, menuW, menuH, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(mx, my, menuW, menuH, t.borderPrimary, 1);

        // header: title + sort asc/desc
        int hy = my + app.Scale(8);
        c.DrawText(mx + pad, hy + (rowH - Canvas.FontHeight(fsM)) / 2, cols[mi].title, t.textPrimary, fsM);
        int sbw = app.Scale(26);
        int sUpX = mx + menuW - pad - sbw * 2 - app.Scale(4);
        int sDnX = mx + menuW - pad - sbw;
        if (DataTable.IconBtn(app, sUpX, hy, sbw, rowH, "arrow-up", st.sortCol == mi && st.sortDir == 1)) {
            DataTable.SortBy(st, mi, 1); app.RequestRedraw();
        }
        if (DataTable.IconBtn(app, sDnX, hy, sbw, rowH, "arrow-down", st.sortCol == mi && st.sortDir == 2)) {
            DataTable.SortBy(st, mi, 2); app.RequestRedraw();
        }
        int cy = hy + rowH + app.Scale(6);

        // tabs
        int tabW = (menuW - pad * 2) / 3;
        if (DataTable.TabBtn(app, mx + pad, cy, tabW, rowH, "Values", st.filterTab == 0)) { st.filterTab = 0; st.editFocus = 0; app.RequestRedraw(); }
        if (DataTable.TabBtn(app, mx + pad + tabW, cy, tabW, rowH, "Text", st.filterTab == 1)) { st.filterTab = 1; st.editFocus = 0; app.RequestRedraw(); }
        if (DataTable.TabBtn(app, mx + pad + tabW * 2, cy, tabW, rowH, "Batch", st.filterTab == 2)) { st.filterTab = 2; st.editFocus = 0; app.RequestRedraw(); }
        c.FillRect(mx + pad, cy + rowH, menuW - pad * 2, 1, t.divider);
        cy = cy + rowH + app.Scale(8);

        int footerH = app.Scale(40);
        int contentBottom = my + menuH - footerH;

        if (st.filterTab == 0) {
            int boxH = app.Scale(26);
            DataTable.EditBox(app, mx + pad, cy, menuW - pad * 2, boxH, st.searchText, "Search values...", st.editFocus == 1);
            int sId = app.focus.AllocId();
            app.hitTester.Register(HitRegion.Create(sId, mx + pad, cy, menuW - pad * 2, boxH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == sId) { st.editFocus = 1; app.RequestRedraw(); }
            cy = cy + boxH + app.Scale(6);

            int itemH = app.Scale(24);
            int allId = app.focus.AllocId();
            bool anyHidden = f.hidden.Count > 0;
            if (app.focus.IsHovered(allId)) { c.FillRect(mx + pad, cy, menuW - pad * 2, itemH, t.bgHover); }
            DataTable.DrawMiniCheck(app, mx + pad, cy, itemH, !anyHidden);
            c.DrawText(mx + pad + app.Scale(22), cy + (itemH - Canvas.FontHeight(fs)) / 2, "(Select All)", t.textPrimary, fs);
            app.hitTester.Register(HitRegion.Create(allId, mx + pad, cy, menuW - pad * 2, itemH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == allId) {
                f.hidden.Clear();
                st.dirty = true; app.RequestRedraw();
            }
            cy = cy + itemH;

            // Rebuild the filtered value list only when the search text changes
            // (not every frame): a column can have thousands of distinct values,
            // so re-scanning + reallocating each frame would stutter. The list
            // is virtualised — only the visible window is drawn — so it stays
            // smooth no matter how many distinct values there are.
            if (!(st.searchText == st.menuSearchCache)) {
                st.menuMatched = new List<string>();
                int vi0 = 0;
                while (vi0 < st.menuVals.Count) {
                    if (DataTable.ContainsCI(st.menuVals[vi0], st.searchText)) { st.menuMatched.Add(st.menuVals[vi0]); }
                    vi0 = vi0 + 1;
                }
                st.menuSearchCache = st.searchText;
                st.valScroll = 0;
            }
            List<string> matched = st.menuMatched;

            int sbGW = app.Scale(10);
            int listX = mx + pad;
            int itemW = menuW - pad * 2 - sbGW;
            int listH = contentBottom - cy;
            int visN = listH / itemH;
            if (visN < 1) { visN = 1; }
            int maxScroll = matched.Count - visN;
            if (maxScroll < 0) { maxScroll = 0; }
            if (st.valScroll > maxScroll) { st.valScroll = maxScroll; }
            if (st.valScroll < 0) { st.valScroll = 0; }

            int listTop = cy;
            int r2 = 0;
            while (r2 < visN && (st.valScroll + r2) < matched.Count) {
                string v = matched[st.valScroll + r2];
                int vId = app.focus.AllocId();
                if (app.focus.IsHovered(vId)) { c.FillRect(listX, cy, itemW, itemH, t.bgHover); }
                bool visible = !f.IsHidden(v);
                DataTable.DrawMiniCheck(app, listX, cy, itemH, visible);
                string label = DataTable.Truncate(v, fs, itemW - app.Scale(26));
                c.DrawText(listX + app.Scale(22), cy + (itemH - Canvas.FontHeight(fs)) / 2, label, t.textPrimary, fs);
                app.hitTester.Register(HitRegion.Create(vId, listX, cy, itemW, itemH, 0));
                if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == vId) {
                    f.Toggle(v); st.dirty = true; app.RequestRedraw();
                }
                cy = cy + itemH;
                r2 = r2 + 1;
            }

            // draggable scrollbar for the virtualised value list
            if (matched.Count > visN) {
                int trackX = listX + itemW + app.Scale(3);
                int trackY = listTop;
                int trackH = visN * itemH;
                int sbW = app.Scale(6);
                int thumbH = trackH * visN / matched.Count;
                if (thumbH < app.Scale(20)) { thumbH = app.Scale(20); }
                int thumbY = trackY;
                if (maxScroll > 0) { thumbY = trackY + (trackH - thumbH) * st.valScroll / maxScroll; }
                int vsbId = app.focus.AllocId();
                int thumbColor = t.scrollbar;
                if (app.focus.IsHovered(vsbId) || app.focus.pressedId == vsbId) { thumbColor = t.scrollbarHover; }
                c.FillRoundRect(trackX, thumbY, sbW, thumbH, sbW / 2, thumbColor);
                app.hitTester.Register(HitRegion.Create(vsbId, trackX, trackY, sbW, trackH, 0));
                if (app.focus.pressedId == vsbId && maxScroll > 0) {
                    int rel = app.mouseY - trackY - thumbH / 2;
                    int denom = trackH - thumbH;
                    if (denom < 1) { denom = 1; }
                    int ns = rel * maxScroll / denom;
                    if (ns < 0) { ns = 0; }
                    if (ns > maxScroll) { ns = maxScroll; }
                    if (ns != st.valScroll) { st.valScroll = ns; app.RequestRedraw(); }
                }
            }
            if (app.window.EventKind() == 13) {
                bool inside = app.mouseX >= mx && app.mouseX < mx + menuW && app.mouseY >= my && app.mouseY < my + menuH;
                if (inside) {
                    int delta = app.window.EventKeyCode();
                    st.valScroll = st.valScroll - delta / 120;
                    if (st.valScroll > maxScroll) { st.valScroll = maxScroll; }
                    if (st.valScroll < 0) { st.valScroll = 0; }
                    app.RequestRedraw();
                }
            }
        } else if (st.filterTab == 1) {
            int chipW = (menuW - pad * 2 - app.Scale(9)) / 4;
            int chipH = app.Scale(24);
            int gap = app.Scale(3);
            if (DataTable.TabBtn(app, mx + pad, cy, chipW, chipH, "Contains", f.textMode == 1)) { f.textMode = 1; st.dirty = true; app.RequestRedraw(); }
            if (DataTable.TabBtn(app, mx + pad + (chipW + gap), cy, chipW, chipH, "Equals", f.textMode == 2)) { f.textMode = 2; st.dirty = true; app.RequestRedraw(); }
            if (DataTable.TabBtn(app, mx + pad + (chipW + gap) * 2, cy, chipW, chipH, "Starts", f.textMode == 3)) { f.textMode = 3; st.dirty = true; app.RequestRedraw(); }
            if (DataTable.TabBtn(app, mx + pad + (chipW + gap) * 3, cy, chipW, chipH, "Ends", f.textMode == 4)) { f.textMode = 4; st.dirty = true; app.RequestRedraw(); }
            cy = cy + chipH + app.Scale(8);

            int boxH = app.Scale(26);
            DataTable.EditBox(app, mx + pad, cy, menuW - pad * 2, boxH, f.textQuery, "Enter filter text...", st.editFocus == 2);
            int qId = app.focus.AllocId();
            app.hitTester.Register(HitRegion.Create(qId, mx + pad, cy, menuW - pad * 2, boxH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == qId) { st.editFocus = 2; app.RequestRedraw(); }
            cy = cy + boxH + app.Scale(10);

            c.DrawText(mx + pad, cy, "Live-filters as you type", t.textTertiary, fs);
            cy = cy + Canvas.FontHeight(fs) + app.Scale(2);
            c.DrawText(mx + pad, cy, "(case-insensitive).", t.textTertiary, fs);
        } else {
            c.DrawText(mx + pad, cy, "One condition per line:", t.textSecondary, fs);
            cy = cy + Canvas.FontHeight(fs) + app.Scale(4);
            int areaH = contentBottom - cy - app.Scale(66);
            if (areaH < app.Scale(48)) { areaH = app.Scale(48); }
            int aId = app.focus.AllocId();
            int abc = t.borderPrimary;
            if (st.editFocus == 3) { abc = t.borderFocus; }
            c.FillRoundRect(mx + pad, cy, menuW - pad * 2, areaH, t.borderRadiusSmall, t.bgPrimary);
            c.DrawRect(mx + pad, cy, menuW - pad * 2, areaH, abc, 1);
            app.hitTester.Register(HitRegion.Create(aId, mx + pad, cy, menuW - pad * 2, areaH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == aId) { st.editFocus = 3; app.RequestRedraw(); }
            int lh = Canvas.FontHeight(fs) + app.Scale(3);
            int li = 0;
            int ly = cy + app.Scale(4);
            while (li < st.batchLines.Count && ly + lh < cy + areaH) {
                string ln = DataTable.Truncate(st.batchLines[li], fs, menuW - pad * 2 - app.Scale(10));
                c.DrawText(mx + pad + app.Scale(5), ly, ln, t.textPrimary, fs);
                if (st.editFocus == 3 && li == st.batchLines.Count - 1) {
                    int cxp = mx + pad + app.Scale(5) + Canvas.MeasureText(ln, fs);
                    c.FillRect(cxp, ly, app.Scale(1), Canvas.FontHeight(fs), t.primary);
                }
                ly = ly + lh;
                li = li + 1;
            }
            cy = cy + areaH + app.Scale(6);

            int exId = app.focus.AllocId();
            bool exact = st.batchExactFlag == 1;
            DataTable.DrawMiniCheck(app, mx + pad, cy, app.Scale(22), exact);
            c.DrawText(mx + pad + app.Scale(22), cy + (app.Scale(22) - Canvas.FontHeight(fs)) / 2, "Exact match", t.textPrimary, fs);
            app.hitTester.Register(HitRegion.Create(exId, mx + pad, cy, app.Scale(130), app.Scale(22), 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == exId) {
                if (st.batchExactFlag == 1) { st.batchExactFlag = 0; } else { st.batchExactFlag = 1; }
                app.RequestRedraw();
            }
            cy = cy + app.Scale(28);

            int bw = (menuW - pad * 2 - app.Scale(6)) / 2;
            int bh = app.Scale(26);
            bool keepClick = DataTable.TextBtn(app, mx + pad, cy, bw, bh, "Keep matching", true);
            bool exclClick = DataTable.TextBtn(app, mx + pad + bw + app.Scale(6), cy, bw, bh, "Exclude", false);
            if (keepClick || exclClick) {
                f.batchTerms.Clear();
                int bl = 0;
                while (bl < st.batchLines.Count) {
                    if (st.batchLines[bl].Length > 0) { f.batchTerms.Add(st.batchLines[bl]); }
                    bl = bl + 1;
                }
                f.batchExact = st.batchExactFlag == 1;
                f.batchKeep = keepClick;
                st.dirty = true;
                app.RequestRedraw();
            }
        }

        // footer: Clear / Close
        int fy = my + menuH - footerH + app.Scale(6);
        int fbw = (menuW - pad * 2 - app.Scale(6)) / 2;
        int fbh = app.Scale(28);
        c.FillRect(mx + pad, my + menuH - footerH, menuW - pad * 2, 1, t.divider);
        bool clearClick = DataTable.TextBtn(app, mx + pad, fy, fbw, fbh, "Clear Filter", false);
        bool closeClick = DataTable.TextBtn(app, mx + pad + fbw + app.Scale(6), fy, fbw, fbh, "Close", false);
        if (clearClick) {
            st.filters[mi] = ColFilter.Create();
            st.searchText = "";
            st.batchLines = new List<string>();
            st.batchLines.Add("");
            st.batchExactFlag = 0;
            st.editFocus = 0;
            st.dirty = true;
            app.RequestRedraw();
        }
        if (closeClick) { st.openMenu = -1; app.RequestRedraw(); }

        // click outside closes the menu (and blurs the edit field)
        if (app.window.EventKind() == 3) {
            bool inside = app.mouseX >= mx && app.mouseX < mx + menuW && app.mouseY >= my && app.mouseY < my + menuH;
            bool onIcon = app.mouseY >= y && app.mouseY < y + headerH;
            if (!inside && !onIcon) { st.openMenu = -1; app.RequestRedraw(); }
        }
    }

    static void DrawMiniCheck(App app, int bx, int cy, int itemH, bool checked) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int box = app.Scale(15);
        int by = cy + (itemH - box) / 2;
        if (checked) {
            c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.primary);
            int ins = app.Scale(3);
            Icon.Draw(c, "check", bx + ins, by + ins, box - ins * 2, t.textInverse);
        } else {
            c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.bgPrimary);
            c.DrawRect(bx, by, box, box, t.borderPrimary, 1);
        }
    }
}
