using System;
using Gui;

namespace Gui.Widget;

/// Toggle switch with reactive bool binding.
///
/// C#-style retained instance:
///     Switch dark = Switch.Bind(model);
///     dark.Change += () => { ... };
///     dark.Render(app, x, y);
/// Legacy immediate-mode static is kept for existing callers.
class Switch : Control {
    SignalBool model;
    int wid;
    /// Fires whenever the switch toggles (C#-style: `sw.Change += h;`).
    UiEvent Change;

    void InitSwitch(SignalBool m) {
        this.InitControl("switch", 1);
        model = m;
        wid = WidgetId.Next();
        Change = UiEvent.Create();
    }

    /// Retained-mode constructor: `Switch dark = new Switch();`
    Switch() {
        InitSwitch(SignalBool.Create(false));
    }

    static Switch Bind(SignalBool model) {
        Switch s = new Switch();
        s.model = model;
        return s;
    }

    static Switch Create() {
        return new Switch();
    }

    bool IsOn() { return model.Get(); }
    void SetOn(bool v) { model.Set(v); }

    int Render(App app, int x, int y) {
        int id = wid;
        Switch.Paint(app, id, x, y, model.Get());
        app.focus.RegisterFocusable(id);

        bool fire = Ui.Clicked(app, id);
        if (Ui.Focused(app, id) && app.window.EventKind() == 4) {
            int kc = app.window.EventKeyCode();
            if (kc == 32 || kc == 13) { fire = true; }
        }
        if (fire) {
            model.Toggle();
            Change.Raise();
            app.RequestRedraw();
        }
        On.Fire(app, id);
        return id;
    }

    override List<string> Events() {
        List<string> e = Control.CommonEvents();
        e.Add("Change");
        e.Add("Toggle");
        return e;
    }

    override string Kind() { return "Switch"; }

    override List<PropSpec> Props() {
        List<PropSpec> ps = new List<PropSpec>();
        ps.Add(PropSpec.Bool("value", "On"));
        return ps;
    }

    override string GetProp(string key) {
        if (key == "value" || key == "checked" || key == "on") {
            if (model.Get()) { return "true"; }
            return "false";
        }
        return "";
    }

    override void SetProp(string key, string val) {
        if (key == "value" || key == "checked" || key == "on") {
            model.Set(val == "true");
        }
    }

    override void BindEvent(string evt, Action a) {
        if (evt == "Change" || evt == "Toggle") { Change.Add(a); return; }
        On.AddByName(evt, a);
    }

    static int Paint(App app, int id, int x, int y, bool isOn) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int hv = Ui.HoverLevel(app, id);
        int trackW = app.Scale(40);
        int trackH = app.Scale(22);
        int margin = app.Scale(2);
        int knobR = (trackH - margin * 2) / 2;
        int totalH = t.heightMedium;
        int trackY = y + (totalH - trackH) / 2;

        // Ease 0->1000 as the switch toggles so the knob slides and the track
        // colour crossfades between off/on instead of snapping.
        int target = 0;
        if (isOn) { target = 1000; }
        int e = app.AnimTo(id, target, 140);

        int offColor = App.LerpColor(t.borderPrimary, t.borderHover, hv);
        int onColor = App.LerpColor(t.primary, t.primaryHover, hv);
        int trackColor = App.LerpColor(offColor, onColor, e);
        c.FillRoundRect(x, trackY, trackW, trackH, trackH / 2, trackColor);

        int offX = x + knobR + margin;
        int onX = x + trackW - knobR - margin;
        int knobX = App.Lerp(offX, onX, e);
        int knobY = trackY + trackH / 2;
        c.FillCircle(knobX, knobY + 1, knobR, t.shadowColor);
        c.FillCircle(knobX, knobY, knobR, t.textInverse);

        app.hitTester.Register(HitRegion.Create(id, x, y, trackW, totalH, 3));
        return id;
    }

    static int Render(App app, int x, int y, SignalBool model) {
        int id = app.focus.AllocId();
        return Switch.Paint(app, id, x, y, model.Get());
    }

    static void HandleClick(App app, int id, SignalBool model) {
        if (app.window.EventKind() == 3) {
            if (app.hitTester.HitTest(app.mouseX, app.mouseY) == id) {
                model.Toggle();
                app.RequestRedraw();
            }
        }
    }

    override void OnMeasure(App app) {
        prefH = app.theme.heightMedium;
        prefW = app.Scale(40);
    }

    override void OnPaint(App app) {
        this.Render(app, bx, by);
    }
}
