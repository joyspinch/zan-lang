            // [StructLayout(LayoutKind.Sequential)] — the only real member used
            // by the FFI/marshalling attribute.
            out2.Add("Sequential"); out2.Add("Explicit"); out2.Add("Auto");
        } else {
            // Unknown / unresolved receiver: only the universally-available
            // object members. We deliberately do NOT guess string / collection /
