using System;
using Gui;

namespace Gui.Widget;

/// Typography helpers: headings, paragraphs and inline text styles.
class Typography {
    /// Heading. level 1..6 maps to decreasing font sizes.
    static int Heading(App app, int x, int y, string text, int level) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int fs = t.fontSizeHuge;
        if (level == 1) { fs = t.fontSizeHuge + t.fontSizeMedium; }
        if (level == 2) { fs = t.fontSizeHuge; }
        if (level == 3) { fs = t.fontSizeLarge + 2; }
        if (level == 4) { fs = t.fontSizeLarge; }
        if (level == 5) { fs = t.fontSizeMedium + 1; }
        if (level >= 6) { fs = t.fontSizeMedium; }
        c.DrawText(x, y, text, t.textPrimary, fs);
        return Canvas.FontHeight(fs);
    }

    /// Body paragraph text.
    static int Paragraph(App app, int x, int y, string text) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        c.DrawText(x, y, text, t.textSecondary, t.fontSizeMedium);
        return Canvas.FontHeight(t.fontSizeMedium);
    }

    /// Colored inline text. kind: 0=primary,1=success,2=warning,3=error,4=muted.
    static int Text(App app, int x, int y, string text, int kind) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int color = t.textPrimary;
        if (kind == 1) { color = t.success; }
        if (kind == 2) { color = t.warning; }
        if (kind == 3) { color = t.error; }
        if (kind == 4) { color = t.textTertiary; }
        c.DrawText(x, y, text, color, t.fontSizeMedium);
        return Canvas.MeasureText(text, t.fontSizeMedium);
    }
}
