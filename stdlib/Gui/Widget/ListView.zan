using System;
using Gui;

namespace Gui.Widget;

/// Bordered list container (NaiveUI n-list) with divided rows.
class ListView {
    static int RowHeight(App app) {
        return app.theme.heightLarge;
    }

    static int Height(App app, int count) {
        return count * ListView.RowHeight(app);
    }

    static void Render(App app, int x, int y, int w, List<string> items) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int n = items.Count;
        int rowH = ListView.RowHeight(app);
        int h = n * rowH;

        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRoundRect(x, y, w, h, t.borderRadiusMedium, t.borderSecondary, 1);

        // Clip rows to the list box so long item text can never spill past the
        // right edge into a neighbouring component.
        c.PushClip(x, y, w, h);
        int i = 0;
        while (i < n) {
            int ry = y + i * rowH;
            if (i > 0) { c.FillRect(x, ry, w, 1, t.divider); }
            int ty = ry + (rowH - Canvas.FontHeight(t.fontSizeMedium)) / 2;
            int textMaxW = w - t.paddingLarge * 2;
            c.DrawText(x + t.paddingLarge, ty,
                Ellipsis.Fit(items[i], textMaxW, t.fontSizeMedium),
                t.textPrimary, t.fontSizeMedium);
            i = i + 1;
        }
        c.PopClip();
    }
}
