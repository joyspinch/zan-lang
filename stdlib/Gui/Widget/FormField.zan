    static string DefaultPlaceholder(int ft) {
        if (ft == 6) { return "Please select"; }
        if (ft == 10) { return "Pick a date"; }
        if (ft == 11) { return "Pick a time"; }
        if (ft == 12) { return "Click to upload"; }
        if (ft == 2) { return "Please enter a password"; }
        return "Please enter";
    }

    /// Whether a field type carries a user-editable option list. Beyond the
    /// choice fields, several display / navigation components reuse the option
    /// list for their items: table columns (23), timeline events (24), tree
    /// nodes (25), collapse sections (26), steps (34), breadcrumb trail (35),
    /// tab titles (36) and menu items (38).
    static bool UsesOptionsOf(int ft) {
        return ft == 4 || ft == 5 || ft == 6
            || ft == 23 || ft == 24 || ft == 25 || ft == 26
            || ft == 34 || ft == 35 || ft == 36 || ft == 38
            || ft == 40 || ft == 41 || ft == 42 || ft == 55;
    }

    /// Non-visual (behaviour) components, WinForms component-tray style: they
    /// never occupy space in the designed window itself -- the designer shows
    /// them in the tray strip below the canvas instead. Tooltip (33),
    /// Loading (47), Dropdown (48), Float Button (49), Popover (50),
    /// Popconfirm (51), Notification (52), Context Menu (55), Layer (56),
    /// Timer (57).
    static bool IsNonVisualOf(int ft) {
        return ft == 33 || ft == 47 || ft == 48 || ft == 49 || ft == 50
            || ft == 51 || ft == 52 || ft == 55 || ft == 56 || ft == 57;
    }

    bool IsNonVisual() {
        return FormField.IsNonVisualOf(ftype);
    }

    bool UsesOptions() {
        return FormField.UsesOptionsOf(ftype);
    }

    /// Display / layout / feedback / navigation components (ftype >= 15) render
    /// static content: they span the full row and skip the label column.
    static bool IsDisplayOf(int ft) {
        return ft >= 15;
    }

    bool IsDisplay() {
        return FormField.IsDisplayOf(ftype);
    }

    /// Row height (unscaled) so taller inputs (textarea/upload/richtext) and
    /// multi-option fields get the room they need on the canvas.
    int RowUnits() {
        if (ftype == 1) { return 62; }
        if (ftype == 12) { return 78; }
        if (ftype == 14) { return 84; }
        if (ftype == 4 || ftype == 5) { return 34; }
        if (ftype == 15) { return 30; }
        if (ftype == 16) { return 26; }
        if (ftype == 17) { return 24; }
        if (ftype == 18) { return 96; }
        if (ftype == 19) { return 30; }
        if (ftype == 20) { return 34; }
        if (ftype == 21) { return 44; }
        if (ftype == 22) { return 60; }
        if (ftype == 23) { return 104; }
        if (ftype == 24) { return 92; }
        if (ftype == 25) { return 92; }
        if (ftype == 26) { return 72; }
        if (ftype == 27) { return 84; }
        if (ftype == 28) { return 40; }
        if (ftype == 29) { return 40; }
        if (ftype == 30) { return 96; }
        if (ftype == 31) { return 70; }
        if (ftype == 32) { return 44; }
        if (ftype == 33) { return 34; }
        if (ftype == 34) { return 56; }
        if (ftype == 35) { return 30; }
        if (ftype == 36) { return 70; }
        if (ftype == 37) { return 34; }
        if (ftype == 38) { return 92; }
        if (ftype == 39) { return 56; }
        if (ftype == 40) { return 96; }
        if (ftype == 41) { return 104; }
        if (ftype == 42) { return 104; }
        if (ftype == 43) { return 140; }
        if (ftype == 44) { return 26; }
        if (ftype == 45) { return 96; }
        if (ftype == 46) { return 96; }
        if (ftype == 47) { return 44; }
        if (ftype == 48) { return 40; }
        if (ftype == 49) { return 56; }
        if (ftype == 50) { return 88; }
        if (ftype == 51) { return 104; }
        if (ftype == 52) { return 52; }
        if (ftype == 53) { return 88; }
        if (ftype == 54) { return 40; }
        return 34;
    }

    // ---- option list ---------------------------------------------------------

    int OptionCount() { return options.Count; }
    string OptionAt(int i) { return options[i]; }
    void AddOption(string s) { options.Add(s); }
    /// Removes one option by rebuilding the list (the runtime's mid-list
    /// RemoveAt can corrupt the heap, like mid-list Insert).
    void RemoveOptionAt(int i) {
        if (i < 0 || i >= options.Count) { return; }
        List<string> nl = new List<string>();
        int k = 0;
        while (k < options.Count) {
            if (k != i) { nl.Add(options[k]); }
            k = k + 1;
        }
        options = nl;
    }

    string JoinOptions() {
        string r = "";
        int i = 0;
        while (i < options.Count) {
            if (i > 0) { r = r + "|"; }
            r = r + options[i];
            i = i + 1;
        }
        return r;
    }

    void SetOptionsFrom(string joined) {
        options = new List<string>();
        string cur = "";
        int i = 0;
        while (i < joined.Length) {
            string ch = joined.Substring(i, 1);
            if (ch == "|") { options.Add(cur); cur = ""; }
            else { cur = cur + ch; }
            i = i + 1;
        }
        if (cur.Length > 0) { options.Add(cur); }
    }

    // ---- designer / serialization model --------------------------------------

    override string Kind() { return "Field"; }

    override List<PropSpec> Props() {
        List<PropSpec> ps = new List<PropSpec>();
        ps.Add(PropSpec.Int("ftype", "Type"));
        ps.Add(PropSpec.Text("label", "Label"));
        ps.Add(PropSpec.Text("fname", "Name"));
        ps.Add(PropSpec.Text("placeholder", "Placeholder"));
        ps.Add(PropSpec.Bool("required", "Required"));
        ps.Add(PropSpec.Bool("defOn", "Default on"));
        ps.Add(PropSpec.Int("span", "Span"));
        if (ftype == 100) { ps.Add(PropSpec.Text("customKind", "Component")); }
        ps.Add(PropSpec.Text("options", "Options"));
        return ps;
    }

    override string GetProp(string key) {
        if (key == "ftype") { return Convert.ToString(ftype); }
        if (key == "label") { return label; }
        if (key == "fname") { return fname; }
        if (key == "placeholder") { return placeholder; }
        if (key == "required") { if (required) { return "true"; } return "false"; }
        if (key == "defOn") { if (defOn) { return "true"; } return "false"; }
        if (key == "span") { return Convert.ToString(span); }
        if (key == "customKind") { return customKind; }
        if (key == "options") { return JoinOptions(); }
        return "";
    }

    override void SetProp(string key, string val) {
        if (key == "ftype") { ftype = Convert.ToInt32(val); }
        else if (key == "label") { label = val; }
        else if (key == "fname") { fname = val; name = val; }
        else if (key == "placeholder") { placeholder = val; }
        else if (key == "required") { required = (val == "true"); }
        else if (key == "defOn") { defOn = (val == "true"); }
        else if (key == "span") { span = Convert.ToInt32(val); }
        else if (key == "customKind") { customKind = val; }
        else if (key == "options") { SetOptionsFrom(val); }
    }
}
