    }

    /// Type-specific semantic events for a field type (beyond the common
    /// pointer/focus/keyboard/lifecycle set every Control inherits). Drives the
    /// Designer's event inspector and the JSON `on*` handler contract.
    static List<string> SemanticEventsOf(int ft) {
        List<string> e = new List<string>();
        // --- form inputs ---
        if (ft == 0 || ft == 1 || ft == 2 || ft == 3) {
            e.Add("Change"); e.Add("Submit");            // Input/Textarea/Password/Number
        } else if (ft == 14) {
            e.Add("Change");                              // Rich Text
        } else if (ft == 4) {
            e.Add("Change");                              // Radio
        } else if (ft == 5) {
            e.Add("Change"); e.Add("Toggle");             // Checkbox
        } else if (ft == 6) {
            e.Add("Change"); e.Add("SelectionChanged");   // Select
        } else if (ft == 7) {
            e.Add("Change"); e.Add("Toggle");             // Switch
        } else if (ft == 8) {
            e.Add("Change");                              // Rate
        } else if (ft == 9) {
            e.Add("Change"); e.Add("DragEnd");            // Slider
        } else if (ft == 10 || ft == 11) {
            e.Add("Change"); e.Add("Open"); e.Add("Close"); // Date / Time picker
        } else if (ft == 12) {
            e.Add("Change"); e.Add("Upload"); e.Add("Remove"); // Upload
        } else if (ft == 13) {
            e.Add("Change");                              // Color
        // --- display ---
        } else if (ft == 19) {
            e.Add("Click"); e.Add("Close");               // Tag (closable)
        } else if (ft == 21) {
            e.Add("Click");                               // Avatar
        } else if (ft == 22) {
            e.Add("Click");                               // Statistic
        } else if (ft == 23 || ft == 41) {
            e.Add("HeaderClick"); e.Add("Sort"); e.Add("RowClick");
            e.Add("RowDoubleClick"); e.Add("CellClick"); e.Add("CellEdit");
            e.Add("SelectionChanged"); e.Add("ColumnResize"); e.Add("ScrollChanged");
        } else if (ft == 24) {
            e.Add("ItemClick");                           // Timeline
        } else if (ft == 25) {
            e.Add("Expand"); e.Add("Collapse"); e.Add("Select"); // Tree
        } else if (ft == 26) {
            e.Add("Toggle"); e.Add("Change");             // Collapse
        // --- feedback ---
        } else if (ft == 28) {
            e.Add("Close");                               // Alert
        } else if (ft == 30) {
            e.Add("Action");                              // Result
        } else if (ft == 33) {
            e.Add("Show"); e.Add("Hide");                 // Tooltip
        } else if (ft == 34) {
            e.Add("Change");                              // Steps
        // --- navigation ---
        } else if (ft == 35) {
            e.Add("ItemClick");                           // Breadcrumb
        } else if (ft == 36) {
            e.Add("TabChanged"); e.Add("TabClosed");      // Tabs
        } else if (ft == 37) {
            e.Add("Change");                              // Pagination
        } else if (ft == 38 || ft == 40 || ft == 48) {
            e.Add("ItemClick"); e.Add("SelectionChanged"); // Menu / List / Dropdown
        } else if (ft == 55) {
            e.Add("ItemClick"); e.Add("Opening");         // Context Menu
        } else if (ft == 56) {
            e.Add("Open"); e.Add("Close");                // Layer
        } else if (ft == 57) {
            e.Add("Tick");                                // Timer
        } else if (ft == 39) {
            e.Add("Back");                                // Page Header
        // --- display+/feedback+ ---
        } else if (ft == 42) {
            e.Add("Change");                              // Carousel
        } else if (ft == 43) {
            e.Add("PointClick"); e.Add("LegendClick");    // Chart
        } else if (ft == 49) {
            e.Add("Click");                               // Float Button
        } else if (ft == 50) {
            e.Add("Show"); e.Add("Hide");                 // Popover
        } else if (ft == 51) {
            e.Add("Confirm"); e.Add("Cancel");            // Popconfirm
        } else if (ft == 52) {
            e.Add("Click"); e.Add("Close");               // Notification
        } else if (ft == 54) {
            e.Add("Click");                               // Icon
        }
        return e;
    }

    override List<string> Events() {
        List<string> e = Control.CommonEvents();
        List<string> sem = FormField.SemanticEventsOf(ftype);
        int i = 0;
        while (i < sem.Count) {
            if (!e.Contains(sem[i])) { e.Add(sem[i]); }
            i = i + 1;
        }
        return e;
    }

