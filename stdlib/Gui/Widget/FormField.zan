using System;
using Gui;

namespace Gui.Widget;

/// A single row of a data-entry form (FormCreate / form-builder style).
///
/// A FormField is a designable Control that captures WHAT to collect, not how to
/// paint an interactive widget: its field type (`ftype`), the label shown beside
/// it, the model key (`fname`), a placeholder, a required flag and — for choice
/// fields — a list of options. The visual designer renders a preview of the row
/// and edits these through the standard Kind()/Props()/GetProp/SetProp model, so
/// the whole form round-trips through Serialize with no special-casing.
///
/// Field types (ftype):
///   0 input      1 textarea  2 password 3 number  4 radio
///   5 checkbox   6 select    7 switch   8 rate    9 slider
///   10 date      11 time     12 upload  13 color   14 richtext
///
/// Display / layout components (ftype >= 15) render static content rather than
/// capturing input; they span the full row width and carry no label column.
/// Grouped in the designer palette by category:
///   Layout:     15 title     16 text        17 divider
///   Display:    18 card       19 tag         20 badge     21 avatar
///               22 statistic  23 table       24 timeline  25 tree
///               26 collapse   27 empty
///   Feedback:   28 alert      29 progress     30 result    31 skeleton
///               32 spin       33 tooltip
///   Navigation: 34 steps      35 breadcrumb   36 tabs      37 pagination
///               38 menu       39 pageheader
class FormField : Control {
    int ftype;
    string label;
    string fname;
    string placeholder;
    // For project custom components (ftype == 100): the discovered component's
    // type tag (CustomComponents kind), serialised so JSON round-trips it.
    string customKind;
    bool required;
    bool defOn;      // default on-state for switch fields
    int span;        // column span out of 24 (24 = full row, 12 = half, ...)
    List<string> options;

    // Container support. A container (Card / Tabs) holds nested child
    // components in `kids`; each child records which tab it lives under in
    // `childTab` (always 0 for single-body containers like Card). `uiState`
    // is the reactive index the composed widget binds to — active tab for
    // Tabs, current step for Steps, open panel for Collapse, page for
    // Pagination, selected item for Menu / Tree — so previews are live.
    List<FormField> kids;
    int childTab;
    SignalInt uiState;

    void InitField(int ft) {
        this.InitControl("field", 0);
        ftype = ft;
        label = FormField.DefaultLabel(ft);
        fname = "field";
        placeholder = FormField.DefaultPlaceholder(ft);
        required = false;
        defOn = false;
        span = 24;
        customKind = "";
        options = new List<string>();
        kids = new List<FormField>();
        childTab = 0;
        uiState = SignalInt.Create(0);
        SeedOptions(ft);
    }

    /// Container types own nested child components: Card (18) has a single
    /// body; Tabs (36) partitions its children across tab panels.
    static bool IsContainerOf(int ft) {
        return ft == 18 || ft == 36;
    }

    bool IsContainer() {
        return FormField.IsContainerOf(ftype);
    }

    int KidCount() { return kids.Count; }
    FormField KidAt(int i) { return kids[i]; }

    /// Seeds a component's default option list — choice values, table columns,
    /// tab titles, step / menu / tree items — so a freshly added component is
    /// not blank in the preview.
    void SeedOptions(int ft) {
        if (ft == 23) { options.Add("Name:name"); options.Add("Email:email"); options.Add("Status:status"); return; }
        if (ft == 24) { options.Add("Created"); options.Add("Approved"); options.Add("Shipped"); return; }
        if (ft == 25) { options.Add("Root"); options.Add("Child A"); options.Add("Child B"); return; }
        if (ft == 26) { options.Add("Section 1"); options.Add("Section 2"); return; }
        if (ft == 34) { options.Add("Step 1"); options.Add("Step 2"); options.Add("Step 3"); return; }
        if (ft == 35) { options.Add("Home"); options.Add("Library"); options.Add("Data"); return; }
        if (ft == 36) { options.Add("Tab 1"); options.Add("Tab 2"); options.Add("Tab 3"); return; }
        if (ft == 38) { options.Add("Dashboard"); options.Add("Settings"); options.Add("Profile"); return; }
        if (ft == 40) { options.Add("List item one"); options.Add("List item two"); options.Add("List item three"); return; }
        if (ft == 41) { options.Add("Name:name"); options.Add("Email:email"); options.Add("Status:status"); return; }
        if (ft == 42) { options.Add("Slide 1"); options.Add("Slide 2"); options.Add("Slide 3"); return; }
        if (FormField.UsesOptionsOf(ft)) {
            options.Add("Option 1");
            options.Add("Option 2");
            options.Add("Option 3");
        }
    }

    FormField(int ft) {
        InitField(ft);
    }

    /// Builds a field of `ftype` with a unique default model key.
    static FormField New(int ft, int seq) {
        FormField f = new FormField(ft);
        f.fname = FormField.TypeKey(ft) + Convert.ToString(seq);
        f.name = f.fname;
        return f;
    }

    /// ftype sentinel for a project custom component (discovered at build time).
    static int Custom() { return 100; }

    bool IsCustom() { return ftype == 100; }

    /// Builds a custom-component field carrying its discovered `kind` tag.
    static FormField NewCustom(string kind, int seq) {
        FormField f = new FormField(100);
        f.customKind = kind;
        f.label = kind;
        f.fname = kind + Convert.ToString(seq);
        f.name = f.fname;
        return f;
    }

    // ---- type metadata -------------------------------------------------------

    /// Short type key used for default model names, e.g. "input", "select".
    static string TypeKey(int ft) {
        if (ft == 1) { return "textarea"; }
        if (ft == 2) { return "password"; }
        if (ft == 3) { return "number"; }
        if (ft == 4) { return "radio"; }
        if (ft == 5) { return "checkbox"; }
        if (ft == 6) { return "select"; }
        if (ft == 7) { return "switch"; }
        if (ft == 8) { return "rate"; }
        if (ft == 9) { return "slider"; }
        if (ft == 10) { return "date"; }
        if (ft == 11) { return "time"; }
        if (ft == 12) { return "upload"; }
        if (ft == 13) { return "color"; }
        if (ft == 14) { return "richtext"; }
        if (ft == 15) { return "title"; }
        if (ft == 16) { return "text"; }
        if (ft == 17) { return "divider"; }
        if (ft == 18) { return "card"; }
        if (ft == 19) { return "tag"; }
        if (ft == 20) { return "badge"; }
        if (ft == 21) { return "avatar"; }
        if (ft == 22) { return "statistic"; }
        if (ft == 23) { return "table"; }
        if (ft == 24) { return "timeline"; }
        if (ft == 25) { return "tree"; }
        if (ft == 26) { return "collapse"; }
        if (ft == 27) { return "empty"; }
        if (ft == 28) { return "alert"; }
        if (ft == 29) { return "progress"; }
        if (ft == 30) { return "result"; }
        if (ft == 31) { return "skeleton"; }
        if (ft == 32) { return "spin"; }
        if (ft == 33) { return "tooltip"; }
        if (ft == 34) { return "steps"; }
        if (ft == 35) { return "breadcrumb"; }
        if (ft == 36) { return "tabs"; }
        if (ft == 37) { return "pagination"; }
        if (ft == 38) { return "menu"; }
        if (ft == 39) { return "pageheader"; }
        if (ft == 40) { return "listview"; }
        if (ft == 41) { return "datatable"; }
        if (ft == 42) { return "carousel"; }
        if (ft == 43) { return "chart"; }
        if (ft == 44) { return "ellipsis"; }
        if (ft == 45) { return "panel"; }
        if (ft == 46) { return "scrollbar"; }
        if (ft == 47) { return "loading"; }
        if (ft == 48) { return "dropdown"; }
        if (ft == 49) { return "floatbutton"; }
        if (ft == 50) { return "popover"; }
