using System;
using Gui;

namespace Gui.Widget;

/// Vertical navigation menu (NaiveUI n-menu style) with reactive selection.
/// Items are a flat list; the selected item gets an accent bar + tint.
/// `scrollOffset` scrolls the list; rows fully outside [y, bottomY) are culled.
class Menu {
    static int RenderVertical(App app, int x, int y, int w, int bottomY, int itemH,
                              List<string> items, SignalInt selected, int scrollOffset) {
        int firstId = app.focus.AllocId();
        int count = items.Count;
        int i = 1;
        while (i < count) {
            app.focus.AllocId();
            i = i + 1;
        }

        Canvas c = app.canvas;
        Theme t = app.theme;
        int sel = selected.Get();
        int accent = app.Scale(3);

        // Clip the whole list to its viewport so partially-scrolled rows and
        // long item labels stay inside [y, bottomY) and never bleed out.
        int viewH = bottomY - y;
        if (viewH < 0) { viewH = 0; }
        c.PushClip(x, y, w, viewH);

        i = 0;
        while (i < count) {
            int id = firstId + i;
            int iy = y + i * itemH - scrollOffset;
            if (iy + itemH > y && iy < bottomY) {
                bool active = i == sel;
                int hv = Ui.HoverLevel(app, id);

                if (active) {
                    c.FillRect(x, iy, w, itemH, t.bgActive);
                    c.FillRect(x, iy, accent, itemH, t.primary);
                } else if (hv > 0) {
                    c.FillRect(x, iy, w, itemH, App.ScaleAlpha(t.bgHover, hv));
                }

                int tc = t.textSecondary;
                if (active) { tc = t.primary; }
                else { tc = App.LerpColor(t.textSecondary, t.textPrimary, hv); }

                int ty = iy + (itemH - Canvas.FontHeight(t.fontSizeMedium)) / 2;
                int textMaxW = w - t.paddingLarge * 2;
                c.DrawText(x + t.paddingLarge, ty,
                    Ellipsis.Fit(items[i], textMaxW, t.fontSizeMedium),
                    tc, t.fontSizeMedium);

                app.hitTester.Register(HitRegion.Create(id, x, iy, w, itemH, 0));
            }
            i = i + 1;
        }
        c.PopClip();
        return firstId;
    }

    /// Icon + label variant on a rounded surface (template pickers, wizards).
    /// Rows write the clicked index straight back to `selected`.
    static void RenderVerticalIcons(App app, int x, int y, int w, int h, int itemH,
                                    List<string> items, List<string> icons, SignalInt selected) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium, t.bgSecondary);

        int n = items.Count;
        int firstId = app.focus.AllocId();
        int i = 1;
        while (i < n) { app.focus.AllocId(); i = i + 1; }

        int sel = selected.Get();
        int glyph = t.fontSizeLarge;
        int accent = app.Scale(3);
        int k = 0;
        while (k < n) {
            int id = firstId + k;
            int rowY = y + k * itemH;
            bool hovered = app.focus.IsHovered(id);
            bool active = k == sel;
            if (active) {
                c.FillRect(x, rowY, w, itemH, t.bgActive);
                c.FillRect(x, rowY, accent, itemH, t.primary);
            } else if (hovered) {
                c.FillRect(x, rowY, w, itemH, t.bgHover);
            }
            int iconColor = t.textSecondary;
            int textColor = t.textPrimary;
            if (active) { iconColor = t.primary; textColor = t.primary; }
            Icon.DrawCenteredIn(c, icons[k], x + t.paddingMedium, rowY, glyph, itemH, glyph, iconColor);
            int textX = x + t.paddingMedium + glyph + t.gapMedium;
            int textY = rowY + (itemH - Canvas.FontHeight(t.fontSizeMedium)) / 2;
            c.DrawText(textX, textY, items[k], textColor, t.fontSizeMedium);
            app.hitTester.Register(HitRegion.Create(id, x, rowY, w, itemH, 0));
            k = k + 1;
        }

        if (app.ClickAvailable()) {
            int hitv = app.hitTester.HitTest(app.mouseX, app.mouseY);
            int idx = hitv - firstId;
            if (idx >= 0 && idx < n) {
                selected.Set(idx);
                app.RequestRedraw();
            }
        }
    }

    static void HandleClick(App app, int firstId, int count, SignalInt selected) {
        if (app.window.EventKind() != 3) { return; }
        int hit = app.ClickTarget();
        if (hit >= firstId && hit < firstId + count) {
            int idx = hit - firstId;
            if (selected.Get() != idx) {
                selected.Set(idx);
                app.scrollY = 0;
                app.RequestRedraw();
            }
        }
    }
}
