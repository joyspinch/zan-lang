using System;
using Gui;

namespace Gui.Widget;

/// Tooltip popup anchored to a point, with a small pointer notch. Prefers to
/// sit above the anchor; flips below when there is not enough room on top.
class Tooltip {
    // Filled triangle pointing down (wide base on top at `topY`, apex below).
    static void TriDown(Canvas c, int cx, int topY, int half, int h, int color) {
        int r = 0;
        while (r < h) {
            int hw = half - half * r / h;
            if (hw < 1) { hw = 1; }
            c.FillRect(cx - hw, topY + r, hw * 2, 1, color);
            r = r + 1;
        }
    }

    // Filled triangle pointing up (apex at `topY`, wide base below).
    static void TriUp(Canvas c, int cx, int topY, int half, int h, int color) {
        int r = 0;
        while (r < h) {
            int hw = half * r / h;
            if (hw < 1) { hw = 1; }
            c.FillRect(cx - hw, topY + r, hw * 2, 1, color);
            r = r + 1;
        }
    }

    /// Opaque two-line tooltip: a bold title over a muted description. Used by
    /// component palettes where the tip sits over other widgets and must stay
    /// fully readable (the translucent `Render` variant bleeds text through).
    static void RenderRich(App app, int x, int y, string title, string desc) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int fs = t.fontSizeSmall;
        int pad = app.Scale(8);
        int lh = Canvas.FontHeight(fs);
        int tw = Canvas.MeasureText(desc, fs);
        int titleW = Canvas.MeasureText(title, fs);
        if (titleW > tw) { tw = titleW; }
        int boxW = tw + pad * 2;
        int boxH = lh * 2 + app.Scale(4) + pad * 2;
        int margin = app.Scale(4);
        if (x + boxW > c.Width() - margin) { x = c.Width() - margin - boxW; }
        if (x < margin) { x = margin; }
        if (y + boxH > c.Height() - margin) { y = c.Height() - margin - boxH; }
        if (y < app.titlebarH) { y = app.titlebarH; }

        int bg = 0xFF1F2430;        // opaque dark slate
        int border = 0xFF3A4150;
        int titleColor = 0xFFFFFFFF;
        int descColor = 0xFFBFC7D5;

        c.FillRoundRect(x + 1, y + 3, boxW, boxH, t.borderRadiusSmall, t.shadowColor);
        c.FillRoundRect(x, y, boxW, boxH, t.borderRadiusSmall, bg);
        c.DrawRect(x, y, boxW, boxH, border, 1);
        c.DrawText(x + pad, y + pad, title, titleColor, fs);
        c.DrawText(x + pad, y + pad + lh + app.Scale(4), desc, descColor, fs);
    }

    static void Render(App app, int anchorX, int anchorY, string text) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int tw = Canvas.MeasureText(text, t.fontSizeSmall) + app.Scale(16);
        int th = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(10);
        int notch = app.Scale(5);
        int gap = app.Scale(6);

        int tx = anchorX - tw / 2;
        if (tx < app.Scale(4)) { tx = app.Scale(4); }
        if (tx + tw > c.Width() - app.Scale(4)) {
            tx = c.Width() - app.Scale(4) - tw;
        }
        int bgColor = -939524096; // rgba(0,0,0,0.75)

        bool below = false;
        int ty = anchorY - th - gap - notch;
        if (ty < app.titlebarH) { below = true; ty = anchorY + gap + notch; }
        if (ty + th > c.Height() - app.Scale(4)) {
            below = false;
            ty = c.Height() - app.Scale(4) - th;
        }

        c.FillRoundRect(tx + 1, ty + 2, tw, th, t.borderRadiusSmall, t.shadowColor);
        c.FillRoundRect(tx, ty, tw, th, t.borderRadiusSmall, bgColor);
        c.DrawTextCentered(tx, ty, tw, th, text, t.textInverse, t.fontSizeSmall);

        if (below) {
            Tooltip.TriUp(c, anchorX, ty - notch, notch, notch, bgColor);
        } else {
            Tooltip.TriDown(c, anchorX, ty + th, notch, notch, bgColor);
        }
    }
}
