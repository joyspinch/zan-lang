using System;
using Gui;

namespace Gui.Widget;

/// Scrollbar track and thumb.
class Scrollbar {
    static void RenderVertical(App app, int x, int y, int height, int contentHeight, int scrollOffset) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        if (height <= 0) { return; }
        int barW = app.Scale(8);
        int radius = app.Scale(4);
        c.PushClip(x, y, barW, height);
        c.FillRoundRect(x, y, barW, height, radius, t.bgTertiary);

        if (contentHeight > height && contentHeight > 0) {
            int minThumb = app.Scale(20);
            if (minThumb > height) { minThumb = height; }
            int thumbH = height * height / contentHeight;
            if (thumbH < minThumb) { thumbH = minThumb; }
            if (thumbH > height) { thumbH = height; }
            int travel = height - thumbH;
            int mo = contentHeight - height;
            int thumbY = y;
            if (mo > 0 && travel > 0) { thumbY = y + scrollOffset * travel / mo; }
            if (thumbY < y) { thumbY = y; }
            if (thumbY + thumbH > y + height) { thumbY = y + height - thumbH; }
            c.FillRoundRect(x, thumbY, barW, thumbH, radius, t.scrollbar);
        }
        c.PopClip();
    }

    /// Interactive vertical scrollbar bound to a scroll-offset signal. Supports
    /// thumb dragging and click-to-jump: while pressed the thumb centres on the
    /// pointer, so a track click scrolls there too. `viewH` is the visible
    /// height of the scrolled surface; `height` is the bar length (usually the
    /// same). Updates `offset` in [0, contentHeight - viewH].
    static void RenderVerticalScroll(App app, int x, int y, int height,
                                     int viewH, int contentHeight, SignalInt offset) {
        int id = app.focus.AllocId();
        Canvas c = app.canvas;
        Theme t = app.theme;
        if (height <= 0) { return; }
        int barW = app.Scale(10);
        int radius = barW / 2;

        int mo = contentHeight - viewH;
        if (mo < 0) { mo = 0; }

        int minThumb = app.Scale(24);
        int thumbH = height;
        if (contentHeight > viewH && contentHeight > 0) {
            thumbH = height * viewH / contentHeight;
        }
        if (thumbH < minThumb) { thumbH = minThumb; }
        if (thumbH > height) { thumbH = height; }
        int travel = height - thumbH;

        bool active = app.focus.IsPressed(id);
        if (active && travel > 0 && mo > 0) {
            int rel = app.mouseY - y - thumbH / 2;
            if (rel < 0) { rel = 0; }
            if (rel > travel) { rel = travel; }
            int newOff = rel * mo / travel;
            if (newOff != offset.Get()) { offset.Set(newOff); app.RequestRedraw(); }
        }

        int cur = offset.Get();
        if (cur < 0) { cur = 0; }
        if (cur > mo) { cur = mo; }

        bool hovered = app.focus.IsHovered(id);
        c.PushClip(x, y, barW, height);
        c.FillRoundRect(x, y, barW, height, radius, t.bgTertiary);
        if (mo > 0) {
            int thumbY = y;
            if (travel > 0) { thumbY = y + cur * travel / mo; }
            int thumbColor = t.scrollbar;
            if (hovered || active) { thumbColor = t.textTertiary; }
            c.FillRoundRect(x, thumbY, barW, thumbH, radius, thumbColor);
        }
        c.PopClip();

        app.hitTester.Register(HitRegion.Create(id, x, y, barW, height, 0));
    }

    /// Mouse-wheel scrolling for a scrollable surface. Pass the full content
    /// viewport rect (not just the bar) so the wheel scrolls when the pointer
    /// is anywhere over the content. Updates `offset` in [0, contentHeight-vh].
    /// Call once per frame alongside RenderVerticalScroll.
    static void HandleWheel(App app, int vx, int vy, int vw, int vh,
                            int contentHeight, SignalInt offset) {
        int mo = contentHeight - vh;
        if (mo <= 0) { return; }
        bool over = app.mouseX >= vx && app.mouseX < vx + vw
            && app.mouseY >= vy && app.mouseY < vy + vh;
        if (!over) { return; }
        bool owns = app.CaptureWheel(vx, vy, vw, vh);
        if (!owns || app.window.EventKind() != 13) { return; }
        int delta = app.window.EventKeyCode();
        int cur = offset.Get() - delta * app.scrollSpeed / 120;
        if (cur < 0) { cur = 0; }
        if (cur > mo) { cur = mo; }
        if (cur != offset.Get()) { offset.Set(cur); app.RequestRedraw(); }
    }
}
