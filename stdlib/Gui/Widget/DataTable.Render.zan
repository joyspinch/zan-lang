using System;
using Gui;

namespace Gui.Widget;

/// DataTable part: cell rendering (conditional formatting, cell types)
/// and the virtualised main render path (header / body / footer /
/// interaction).
partial class DataTable {
    // ---------- cell rendering ----------

    static void DrawCell(App app, DataColumn col, string val, int cx, int cy, int cw, int rowH, int cfLo, int cfHi) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int fs = t.fontSizeMedium;
        int pad = t.paddingSmall;
        int innerW = cw - pad * 2;

        // ---- conditional formatting (plain text/numeric cells only) ----
        int cfText = t.textPrimary;
        if (col.cfMode != 0 && col.cellType == 0) {
            int v = DataTable.ParseInt(val);
            if (col.cfMode == 1) {
                // data bar proportional to value across the column's min..max
                int span = cfHi - cfLo;
                if (span <= 0) { span = 1; }
                int frac = (v - cfLo) * 100 / span;
                if (frac < 0) { frac = 0; }
                if (frac > 100) { frac = 100; }
                int barH = rowH - app.Scale(8);
                int barY = cy + app.Scale(4);
                int barW = frac * innerW / 100;
                int tint = DataTable.ColorAlpha(col.cfColor, 95);
                int rad = app.Scale(2);
                if (barW > 0) {
                    // Clean flat data bar with a slight corner radius; fall back to
                    // a plain rect when the bar is too short to round without the
                    // straight-segment math underflowing.
                    if (barW < rad * 2) { c.FillRect(cx + pad, barY, barW, barH, tint); }
                    else { c.FillRoundRect(cx + pad, barY, barW, barH, rad, tint); }
                }
                string sb = DataTable.Truncate(DataTable.FormatCell(col, val), fs, innerW);
                int twb = Canvas.MeasureText(sb, fs);
                int tyb = cy + (rowH - Canvas.FontHeight(fs)) / 2;
                c.DrawText(cx + cw - pad - twb, tyb, sb, t.textPrimary, fs);
                return;
            } else if (col.cfMode == 2) {
                c.FillRect(cx, cy, cw, rowH, DataTable.LerpColor(col.cfColor, col.cfColor2, v - cfLo, cfHi - cfLo));
            } else if (col.cfMode == 3 && v > col.cfThreshold) {
                c.FillRect(cx, cy, cw, rowH, DataTable.ColorAlpha(col.cfColor, 38));
                cfText = col.cfColor;
            } else if (col.cfMode == 4 && v < col.cfThreshold) {
                c.FillRect(cx, cy, cw, rowH, DataTable.ColorAlpha(col.cfColor, 38));
                cfText = col.cfColor;
            }
        }

        if (col.cellType == 3) {
            int pct = DataTable.ParseInt(val);
            if (pct < 0) { pct = 0; }
            if (pct > 100) { pct = 100; }
            int barH = app.Scale(6);
            int barY = cy + (rowH - barH) / 2;
            int barW = innerW - app.Scale(40);
            if (barW < app.Scale(20)) { barW = app.Scale(20); }
            c.FillRoundRect(cx + pad, barY, barW, barH, barH / 2, t.bgTertiary);
            int fillW = pct * barW / 100;
            int barColor = t.primary;
            if (pct >= 100) { barColor = t.success; }
            c.FillRoundRect(cx + pad, barY, fillW, barH, barH / 2, barColor);
            int txtY = cy + (rowH - Canvas.FontHeight(t.fontSizeSmall)) / 2;
            c.DrawText(cx + pad + barW + app.Scale(6), txtY, Convert.ToString(pct) + "%", t.textSecondary, t.fontSizeSmall);
            return;
        }

        if (col.cellType == 2) {
            int tc = DataTable.TypeColor(t, col.tagType);
            int tagH = t.heightSmall;
            int tagY = cy + (rowH - tagH) / 2;
            string label = DataTable.Truncate(val, t.fontSizeSmall, innerW - pad * 2);
            int tagW = Canvas.MeasureText(label, t.fontSizeSmall) + pad * 2;
            int tagX = cx + pad;
            if (col.align == 1) { tagX = cx + (cw - tagW) / 2; }
            c.FillRoundRect(tagX, tagY, tagW, tagH, t.borderRadiusSmall, t.bgSecondary);
            c.DrawRect(tagX, tagY, tagW, tagH, tc, 1);
            int txtY = tagY + (tagH - Canvas.FontHeight(t.fontSizeSmall)) / 2;
            c.DrawText(tagX + pad, txtY, label, tc, t.fontSizeSmall);
            return;
        }

        if (col.cellType == 4) {
            int dotR = app.Scale(4);
            int dotColor = t.success;
            if (val == "0" || val == "" || val == "Offline" || val == "Idle" || val == "Inactive" || val == "Closed") { dotColor = t.textTertiary; }
            int cxc = cx + pad + dotR;
            if (col.align == 1) { cxc = cx + cw / 2 - Canvas.MeasureText(val, fs) / 2 - dotR - app.Scale(4); }
            c.FillCircle(cxc, cy + rowH / 2, dotR, dotColor);
            int txtY = cy + (rowH - Canvas.FontHeight(fs)) / 2;
            c.DrawText(cxc + dotR + app.Scale(4), txtY, val, t.textPrimary, fs);
            return;
        }

        int color = cfText;
        if (col.cellType == 1) { color = t.primary; }
        string shown = DataTable.Truncate(DataTable.FormatCell(col, val), fs, innerW);
        int tw = Canvas.MeasureText(shown, fs);
        int tx = cx + pad;
        if (col.align == 1) { tx = cx + (cw - tw) / 2; }
        if (col.align == 2) { tx = cx + cw - pad - tw; }
        int ty = cy + (rowH - Canvas.FontHeight(fs)) / 2;
        c.DrawText(tx, ty, shown, color, fs);
    }

    // ---------- main render ----------

    /// Convenience overload: render an in-memory List<DataRow> (wraps it in a
    /// RowListSource). For large / virtual data, use RenderSource with a custom
    /// DataSource subclass instead.
    static void Render(App app, int x, int y, int viewW, int viewH,
                       List<DataColumn> cols, List<DataRow> rows, DataTableState st) {
        DataTable.RenderSource(app, x, y, viewW, viewH, cols, RowListSource.Create(rows), st);
    }

    static void RenderSource(App app, int x, int y, int viewW, int viewH,
                       List<DataColumn> cols, DataSource src, DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        DataTable.EnsureInit(st, cols, src);
        DataTable.Recompute(st, cols, src);

        int headerH = t.heightMedium;
        int rowH = t.heightMedium;
        int fs = t.fontSizeMedium;

        int numW = 0;
        if (st.showRowNum) {
            // Wide enough for the largest row number so 7-digit counts never
            // spill into the neighbouring column.
            numW = app.Scale(46);
            int needW = Canvas.MeasureText(Convert.ToString(src.RowCount()), t.fontSizeSmall)
                        + app.Scale(16);
            if (needW > numW) { numW = needW; }
        }
        int selW = 0;
        if (st.showSelect) { selW = app.Scale(40); }

        int gridColor = t.divider;
        int menuIconW = app.Scale(22);

        // Right edge that content may not spill past (leaves room for the
        // vertical scrollbar). Columns whose right side would exceed this are
        // clamped, and any column starting beyond it is skipped — so cells and
        // headers never draw outside the table's own border.
        int sbGutter = app.Scale(12);
        int clipRight = x + viewW - sbGutter;

        // total data width (hidden columns contribute nothing)
        int dataW = 0;
        int ci = 0;
        while (ci < st.colWidths.Count) {
            if (!st.colHidden[ci]) { dataW = dataW + st.colWidths[ci]; }
            ci = ci + 1;
        }
        int totalW = numW + selW + dataW;

        // Columns keep their natural widths; when the total exceeds the
        // available band the data region pans horizontally (st.scrollX) and
        // only the visible column window is drawn — so wide tables scroll
        // instead of squeezing every column into the viewport. Hidden columns
        // collapse to zero width; frozen (pinned) and grouped columns are
        // hoisted to the front of the visible order.
        int availData = clipRight - (x + numW + selW);
        if (availData < app.Scale(80)) { availData = app.Scale(80); }
        int pinnedW = DataTable.PinnedWidth(st);
        int flexNatW = dataW - pinnedW;                 // unpinned natural total
        int flexAvail = availData - pinnedW;            // space left for unpinned
        int minFlex = app.Scale(40);
        if (flexAvail < minFlex) { flexAvail = minFlex; }
        st.dispW.Clear();
        int di = 0;
        while (di < st.colWidths.Count) {
            if (st.colHidden[di]) { st.dispW.Add(0); }
            else { st.dispW.Add(st.colWidths[di]); }
            di = di + 1;
        }
        int maxScrollX = dataW - availData;
        if (maxScrollX < 0) { maxScrollX = 0; }
        if (st.scrollX > maxScrollX) { st.scrollX = maxScrollX; }
        if (st.scrollX < 0) { st.scrollX = 0; }
        int firstDataX = x + numW + selW;
        int dataViewW = clipRight - firstDataX;

        // Column display order (group columns hoisted to the front). Computed
        // once and shared by every layout pass so header / cells / hit-test /
        // summary stay perfectly aligned.
        List<int> vorder = DataTable.VisibleOrder(st, cols);

        // outer border
        c.FillRoundRect(x, y, viewW, viewH, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(x, y, viewW, viewH, t.borderPrimary, 1);

        // ---------------- header ----------------
        c.FillRect(x, y, viewW, headerH, t.bgSecondary);
        int hx = x;

        if (st.showRowNum) {
            c.DrawTextCentered(hx, y, numW, headerH, "#", t.textTertiary, t.fontSizeSmall);
            hx = hx + numW;
            c.FillRect(hx, y, 1, headerH, gridColor);
        }
        if (st.showSelect) {
            // select-all checkbox
            int allId = app.focus.AllocId();
            bool allChecked = st.order.Count > 0;
            int oi = 0;
            while (oi < st.order.Count) {
                if (!st.selected[st.order[oi]]) { allChecked = false; oi = st.order.Count; } else { oi = oi + 1; }
            }
            int box = app.Scale(16);
            int bx = hx + (selW - box) / 2;
            int by = y + (headerH - box) / 2;
            if (allChecked) {
                c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.primary);
                int ins = app.Scale(3);
                Icon.Draw(c, "check", bx + ins, by + ins, box - ins * 2, t.textInverse);
            } else {
                c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.bgPrimary);
                c.DrawRect(bx, by, box, box, t.borderPrimary, 1);
            }
            app.hitTester.Register(HitRegion.Create(allId, hx, y, selW, headerH, 0));
            if (app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == allId) {
                bool target = !allChecked;
                int k = 0;
                while (k < st.order.Count) { st.selected[st.order[k]] = target; k = k + 1; }
                st.SelectionChanged.Raise();
                app.RequestRedraw();
            }
            hx = hx + selW;
            c.FillRect(hx, y, 1, headerH, gridColor);
        }

        // Column drag-reorder in progress this frame (a header title is held and
        // the pointer has moved past the start threshold). dropVisLocal is the
        // visual slot the dragged column would land before; dropX is its screen x.
        bool colDragging = st.dragCol >= 0 && st.dragColMoved;
        int dropVisLocal = -1;
        int dropX = -1;

        c.PushClip(firstDataX, y, dataViewW, headerH);
        int hoi = 0;
        int hcl = firstDataX - st.scrollX;
        while (hoi < vorder.Count) {
            int i = vorder[hoi];
            DataColumn col = cols[i];
            int cw = st.dispW[i];
            // Ids are allocated for every column — visible or not — so the id
            // sequence stays identical across frames while panning; otherwise
            // widgets registered after the header (scrollbars) would change id
            // mid-drag whenever a column entered/left the viewport.
            int titleId = app.focus.AllocId();
            int menuId = -1;
            if (col.filterable || col.sortable) { menuId = app.focus.AllocId(); }
            int rzId = app.focus.AllocId();
            if (hcl + cw <= firstDataX || hcl >= clipRight) {
                hcl = hcl + cw;
                hoi = hoi + 1;
            } else {
            hx = hcl;
            // visible slice of this column (for hit regions / hover fill)
            int visX = hx;
            if (visX < firstDataX) { visX = firstDataX; }
            int visR = hx + cw;
            if (visR > clipRight) { visR = clipRight; }
            int visW = visR - visX;
            // drag-reorder drop slot: first column whose left half contains the
            // pointer becomes the insertion target.
            if (colDragging && dropVisLocal < 0 && app.mouseX < hx + cw / 2) {
                dropVisLocal = hoi;
                dropX = visX;
            }
            bool hHover = app.focus.IsHovered(titleId);
            if (hHover) { c.FillRect(visX, y, visW, headerH, t.bgHover); }

            int pad = t.paddingSmall;
            int availTitle = cw - pad * 2 - menuIconW;
            string ht = DataTable.Truncate(col.title, fs, availTitle);
            int ty = y + (headerH - Canvas.FontHeight(fs)) / 2;
            c.DrawText(hx + pad, ty, ht, t.textSecondary, fs);

            // sort indicator — arrow per key, plus a 1-based priority badge when
            // more than one column feeds a multi-column sort.
            int spos = DataTable.SortIndexOf(st, i);
            if (spos >= 0) {
                string arrow = "arrow-up";
                if (st.sortKeys[spos].dir == 2) { arrow = "arrow-down"; }
                int aw = app.Scale(12);
                int ax = hx + pad + Canvas.MeasureText(ht, fs) + app.Scale(4);
                Icon.Draw(c, arrow, ax, y + (headerH - aw) / 2, aw, t.primary);
                if (st.sortKeys.Count > 1) {
                    c.DrawText(ax + aw + app.Scale(1), ty,
                               Convert.ToString(spos + 1), t.primary, t.fontSizeSmall);
                }
            }

            // header menu icon — DevExpress-style: only revealed when the mouse
            // is over the header cell, when this column has an active filter, or
            // while its menu is open. `menuId` is always allocated so widget ids
            // stay stable across frames regardless of the icon's visibility.
            if (menuId >= 0) {
                int mIx = hx + cw - menuIconW - app.Scale(2);
                bool active = st.filters[i].Active();
                bool cellHover = app.mouseX >= visX && app.mouseX < visR
                                 && app.mouseY >= y && app.mouseY < y + headerH;
                bool showIcon = active || cellHover || st.openMenu == i;
                if (showIcon) {
                    int mColor = t.textTertiary;
                    if (active) { mColor = t.primary; }
                    if (app.focus.IsHovered(menuId)) { mColor = t.textPrimary; }
                    Icon.DrawCenteredIn(c, "filter", mIx, y, menuIconW, headerH, app.Scale(13), mColor);
                    app.hitTester.Register(HitRegion.Create(menuId, mIx, y, menuIconW, headerH, 0));
                    if (!st.dragColMoved && app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == menuId) {
                        if (st.openMenu == i) { st.openMenu = -1; } else {
                            st.openMenu = i;
                            st.filterTab = 0;
                            st.searchText = "";
                            st.valScroll = 0;
                            st.editFocus = 0;
                            st.batchLines = new List<string>();
                            st.batchLines.Add("");
                            st.batchExactFlag = 0;
                            st.menuVals = DataTable.Distinct(src, i);
                            st.menuMatched = st.menuVals;
                            st.menuSearchCache = "";
                        }
                        app.RequestRedraw();
                    }
                }
            }

            // header title: press starts a potential drag-reorder; a click (no
            // drag) cycles the sort. The dragged column is dimmed while moving.
            int titleW = visW - menuIconW;
            if (titleW < 0) { titleW = 0; }
            app.hitTester.Register(HitRegion.Create(titleId, visX, y, titleW, headerH, 0));
            if (app.window.EventKind() == 2 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == titleId) {
                st.dragCol = i;
                st.dragColStartX = app.mouseX;
                st.dragColMoved = false;
            }
            if (st.dragCol == i && app.focus.pressedId == titleId) {
                int dd = app.mouseX - st.dragColStartX;
                if (dd < 0) { dd = 0 - dd; }
                if (!st.dragColMoved && dd > app.Scale(5)) {
                    st.dragColMoved = true;
                }
                if (st.dragColMoved) { app.RequestRedraw(); }
            }
            if (colDragging && st.dragCol == i) {
                c.FillRect(visX, y, visW, headerH, t.bgHover);
            }
            if (col.sortable && !st.dragColMoved && app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.ClickTarget() == titleId) {
                st.hitCol = i;
                st.HeaderClick.Raise();
                bool addSort = Modifiers.HasShift(app.window.EventMods());
                DataTable.CycleSort(st, i, addSort);
                st.dirty = true;
                st.Sort.Raise();
                app.RequestRedraw();
            }

            // right-click a header cell => column context menu (sort / auto-fit /
            // hide). Geometry-based so it wins regardless of the overlapping
            // title / menu-icon / resize ids registered for this cell.
            if (app.window.EventKind() == 2 && app.window.EventButton() == 1
                && st.openMenu < 0
                && app.mouseX >= hx && app.mouseX < hx + cw
                && app.mouseY >= y && app.mouseY < y + headerH) {
                st.hdrCtxOpen = true;
                st.hdrCtxCol = i;
                st.hdrCtxX = app.mouseX;
                st.hdrCtxY = app.mouseY;
                st.hitCol = i;
                app.RequestRedraw();
            }

            // resize handle (right border). Draggable columns get a horizontal
            // resize cursor (widget type 4); fixed columns show the not-allowed
            // cursor (widget type 6) so the grip clearly reads as disabled.
            int rzW = app.Scale(6);
            int rzX = hx + cw - rzW / 2;
            int rzCursor = 4;
            if (!col.resizable) { rzCursor = 6; }
            app.hitTester.Register(HitRegion.Create(rzId, rzX, y, rzW, headerH, rzCursor));
            if (col.resizable && app.window.EventKind() == 2 && app.window.EventButton() == 0 && app.PressTarget() == rzId) {
                st.resizeCol = i;
                st.resizeStartX = app.mouseX;
                st.resizeStartW = st.colWidths[i];
            }
            if (col.resizable && st.resizeCol == i && app.focus.pressedId == rzId) {
                int nw = st.resizeStartW + (app.mouseX - st.resizeStartX);
                if (nw < app.Scale(48)) { nw = app.Scale(48); }
                if (nw != st.colWidths[i]) {
                    st.colWidths[i] = nw;
                    st.hitCol = i;
                    st.ColumnResize.Raise();
                    app.RequestRedraw();
                }
            }

            if (st.resizeCol == i && app.window.EventKind() == 3 && app.window.EventButton() == 0) {
                st.hitCol = i;
                st.resizeCol = -1;
                st.ColumnResizeEnd.Raise();
            }

            c.FillRect(hx + cw, y, 1, headerH, gridColor);
            hcl = hcl + cw;
            hoi = hoi + 1;
            }
        }
        c.PopClip();
        c.FillRect(x, y + headerH - 1, viewW, 1, gridColor);

        // Column drag feedback + drop: a 2px accent line marks the insertion
        // boundary and a floating chip follows the pointer. On release the
        // column is moved before the target slot (or to the end).
        if (colDragging) {
            if (dropVisLocal < 0) { dropX = hx; }
            c.FillRect(dropX - 1, y, app.Scale(2), headerH, t.primary);
            string dl = cols[st.dragCol].title;
            int chW = Canvas.MeasureText(dl, fs) + app.Scale(16);
            int chX = app.mouseX - chW / 2;
            if (chX < x) { chX = x; }
            if (chX + chW > x + viewW) { chX = x + viewW - chW; }
            c.FillRoundRect(chX, y + app.Scale(3), chW, headerH - app.Scale(6),
                            t.borderRadiusSmall, t.primary);
            c.DrawText(chX + app.Scale(8),
                       y + (headerH - Canvas.FontHeight(fs)) / 2, dl, t.textInverse, fs);
        }
        // Remember the drop slot while the button is held, so the finalize below
        // uses the last live drag position rather than wherever the pointer sits
        // on the frame that happens to flush the release.
        if (colDragging && app.focus.pressedId >= 0) { st.dropVis = dropVisLocal; }
        // Finalize when the button is no longer held. The App clears the press on
        // mouse-up before this render runs, so `pressedId < 0` reliably marks the
        // release frame even when the synthetic event's kind is coalesced away.
        if (st.dragCol >= 0 && app.focus.pressedId < 0) {
            if (st.dragColMoved) {
                int beforeCol = -1;
                if (st.dropVis >= 0 && st.dropVis < vorder.Count) {
                    beforeCol = vorder[st.dropVis];
                }
                if (beforeCol != st.dragCol) {
                    DataTable.MoveColumn(st, st.dragCol, beforeCol);
                    st.hitCol = st.dragCol;
                    st.ColumnReorder.Raise();
                }
            }
            st.dragCol = -1;
            st.dragColMoved = false;
            st.dropVis = -1;
            app.RequestRedraw();
        }

        // ---------------- body (virtualised) ----------------
        int total = st.dispRows.Count;
        int summaryH = 0;
        if (st.showSummary) { summaryH = rowH; }
        int pagerH = 0;
        if (st.paged) { pagerH = app.Scale(38); }

        int bodyTop = y + headerH;
        int bodyH = viewH - headerH - summaryH - pagerH;
        if (bodyH < rowH) { bodyH = rowH; }
        int visRows = bodyH / rowH;
        if (visRows < 1) { visRows = 1; }

        // In paged mode the visible window is a whole page; otherwise it is the
        // virtual-scroll offset.
        int start = 0;
        if (st.paged) {
            st.pageRows = visRows;
            int totalPages = 1;
            if (total > 0) { totalPages = (total + visRows - 1) / visRows; }
            int cur = st.pageModel.Get();
            if (cur > totalPages) { cur = totalPages; st.pageModel.Set(cur); }
            if (cur < 1) { cur = 1; st.pageModel.Set(cur); }
            start = (cur - 1) * visRows;
        } else {
            start = st.scrollRow;
            if (start > total - visRows) { start = total - visRows; }
            if (start < 0) { start = 0; }
            st.scrollRow = start;
        }

        // Normalised cell-range bounds (order-index rows + column indices) for
        // highlighting the drag-selected rectangle behind the cells.
        bool hasRange = DataTable.HasRange(st);
        int rgR0 = 0;
        int rgR1 = -1;
        int rgC0 = 0;
        int rgC1 = -1;
        if (hasRange) {
            rgR0 = DataTable.MinI(st.rangeR0, st.rangeR1);
            rgR1 = DataTable.MaxI(st.rangeR0, st.rangeR1);
            rgC0 = DataTable.MinI(st.rangeC0, st.rangeC1);
            rgC1 = DataTable.MaxI(st.rangeC0, st.rangeC1);
        }

        // screen rect of the cell currently being edited (captured in the loop
        // so the inline editor can be drawn over it after the rows are painted)
        int edX = 0;
        int edY = 0;
        int edW = 0;
        int edH = 0;
        bool edVis = false;

        int r = 0;
        while (r < visRows && (start + r) < total) {
            int oiRow = start + r;
            int ry = bodyTop + r * rowH;

            // Group header row: indented chevron + caption + row count. It
            // occupies a display slot but carries no data-row payload.
            if (st.dispRows[oiRow].kind == 1) {
                int gi = st.dispRows[oiRow].row;
                GroupRow grp = st.groups[gi];
                int lvl = grp.level;
                c.FillRect(x + 1, ry, viewW - 2, rowH, t.bgTertiary);
                int gcx = x + numW + selW + lvl * app.Scale(16) + app.Scale(6);
                bool gcoll = grp.collapsed;
                string chev = "chevron-down";
                if (gcoll) { chev = "chevron-right"; }
                int chSz = app.Scale(14);
                Icon.Draw(c, chev, gcx, ry + (rowH - chSz) / 2, chSz, t.textSecondary);
                string glbl = grp.label + "  (" + Convert.ToString(grp.count) + ")";
                c.DrawText(gcx + chSz + app.Scale(4),
                    ry + (rowH - t.fontSizeMedium) / 2, glbl, t.textPrimary, t.fontSizeMedium);
                c.FillRect(x + 1, ry + rowH - 1, viewW - 2, 1, gridColor);
                r = r + 1;
                continue;
            }

            int rowIdx = st.dispRows[oiRow].row;
            bool rowInRange = hasRange && oiRow >= rgR0 && oiRow <= rgR1;

            int rowId = app.focus.AllocId();
            app.hitTester.Register(HitRegion.Create(rowId, x, ry, viewW, rowH, 0));
            bool rHover = app.focus.IsHovered(rowId);
            bool rSel = st.selected[rowIdx];

            int rowBg = t.bgPrimary;
            if (st.striped && (st.dispRows[oiRow].no % 2 == 0)) { rowBg = t.bgSecondary; }
            if (rSel) { rowBg = t.bgActive; }
            if (rHover) { rowBg = t.bgHover; }
            c.FillRect(x + 1, ry, viewW - 2, rowH, rowBg);

            int cx2 = x;
            if (st.showRowNum) {
                // Sequential display position (1,2,3…) in the current sorted/
                // filtered view — NOT the original data index, so the row-number
                // column stays ordered instead of jumping around when the user
                // sorts or filters.
                c.DrawTextCentered(cx2, ry, numW, rowH, Convert.ToString(st.dispRows[oiRow].no), t.textTertiary, t.fontSizeSmall);
                cx2 = cx2 + numW;
            }
            if (st.showSelect) {
                int box = app.Scale(16);
                int bx = cx2 + (selW - box) / 2;
                int by = ry + (rowH - box) / 2;
                if (rSel) {
                    c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.primary);
                    int ins = app.Scale(3);
                    Icon.Draw(c, "check", bx + ins, by + ins, box - ins * 2, t.textInverse);
                } else {
                    c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.bgPrimary);
                    c.DrawRect(bx, by, box, box, t.borderPrimary, 1);
                }
                int selId = app.focus.AllocId();
                app.hitTester.Register(HitRegion.Create(selId, cx2, ry, selW, rowH, 0));
                if (app.window.EventKind() == 3 && app.window.EventButton() == 0 && app.hitTester.HitTest(app.mouseX, app.mouseY) == selId) {
                    st.selected[rowIdx] = !rSel;
                    st.hitRow = rowIdx;
                    st.SelectionChanged.Raise();
                    app.RequestRedraw();
                }
                cx2 = cx2 + selW;
            }

            c.PushClip(firstDataX, ry, dataViewW, rowH);
            int coi = 0;
            int ccl = firstDataX - st.scrollX;
            while (coi < vorder.Count && ccl < clipRight) {
                int cc = vorder[coi];
                int cw = st.dispW[cc];
                if (ccl + cw > firstDataX) {
                    if (rowInRange && cc >= rgC0 && cc <= rgC1) {
                        c.FillRect(ccl, ry, cw, rowH, t.bgActive);
                    }
                    if (st.editing && rowIdx == st.editRow && cc == st.editCol) {
                        edX = ccl; edY = ry; edW = cw; edH = rowH; edVis = true;
                    }
                    int cfLo = 0;
                    int cfHi = 0;
                    if (cc < st.cfMin.Count) { cfLo = st.cfMin[cc]; cfHi = st.cfMax[cc]; }
                    DataTable.DrawCell(app, cols[cc], src.CellText(rowIdx, cc), ccl, ry, cw, rowH, cfLo, cfHi);
                }
                ccl = ccl + cw;
                coi = coi + 1;
            }
            c.PopClip();

            c.FillRect(x + 1, ry + rowH - 1, viewW - 2, 1, gridColor);
            r = r + 1;
        }

        // ---------------- freeze boundary ----------------
        // A subtle accent divider marks where the frozen (pinned) columns end.
        if (pinnedW > 0) {
            int freezeX = x + numW + selW + pinnedW;
            if (freezeX < clipRight) {
                c.FillRect(freezeX, y, app.Scale(2), bodyTop + bodyH - y, t.borderPrimary);
            }
        }

        // ---------------- row-drag drop indicator ----------------
        if (st.dragRow >= 0 && st.dragMoved) {
            int dropRow = (app.mouseY - bodyTop) / rowH;
            if (dropRow < 0) { dropRow = 0; }
            if (dropRow > visRows) { dropRow = visRows; }
            int dy = bodyTop + dropRow * rowH;
            if (dy < bodyTop) { dy = bodyTop; }
            if (dy > bodyTop + bodyH) { dy = bodyTop + bodyH; }
            c.FillRect(x + 1, dy - 1, viewW - 2, app.Scale(2), t.primary);
        }

        // ---------------- inline cell editor overlay ----------------
        if (st.editing && edVis && edW > app.Scale(8)) {
            int epad = t.paddingSmall;
            int efs = t.fontSizeMedium;
            int etY = edY + (edH - Canvas.FontHeight(efs)) / 2;
            c.FillRect(edX, edY, edW, edH, t.bgPrimary);
            c.DrawRect(edX, edY, edW, edH, t.borderFocus, 2);
            c.PushClip(edX + epad, edY, edW - epad * 2, edH);
            c.DrawText(edX + epad, etY, st.editBuf, t.textPrimary, efs);
            int ecaretX = edX + epad + Canvas.MeasureText(Text.Left(st.editBuf, st.editCur), efs);
            c.FillRect(ecaretX, etY, 1, Canvas.FontHeight(efs), t.primary);
            c.PopClip();
            app.SetImeCaret(ecaretX, etY + Canvas.FontHeight(efs));
        }

        // ---------------- body pointer interaction ----------------
        // Map the pointer to an order-position row and a data column purely from
        // geometry (works for range-extend / reorder even outside hit regions).
        int ptrOi = -1;
        if (app.mouseY >= bodyTop && app.mouseY < bodyTop + bodyH && app.mouseX >= x && app.mouseX < clipRight) {
            int rr2 = (app.mouseY - bodyTop) / rowH;
            if (rr2 >= 0 && rr2 < visRows && (start + rr2) < total) { ptrOi = start + rr2; }
        }
        int ptrCol = -1;
        if (ptrOi >= 0 && app.mouseX >= firstDataX) {
            int colL = firstDataX - st.scrollX;
            int pci = 0;
            while (pci < vorder.Count) {
                int cci = vorder[pci];
                int cwv = st.dispW[cci];
                if (app.mouseX >= colL && app.mouseX < colL + cwv) { ptrCol = cci; pci = vorder.Count; }
                else { colL = colL + cwv; pci = pci + 1; }
            }
        }
        int ek = app.window.EventKind();
        int eb = app.window.EventButton();
        int emods = app.window.EventMods();
        // While the context menu is open it is modal: swallow body events so a
        // click on a menu item can't also start a range/selection behind it.
        // (RenderContextMenu reads the raw event to drive item hits / dismiss.)
        if (st.ctxOpen) { ek = 0; }
        if (st.hdrCtxOpen) { ek = 0; }

        // ---------------- inline editor key handling ----------------
        // While an editor is open it owns the keyboard: printable input, caret
        // movement and commit/cancel. Events are swallowed so they don't also
        // drive selection/scroll behind the editor.
        // Only keyboard events are swallowed here; mouse presses fall through to
        // the press handler, which commits the edit before re-selecting.
        if (st.editing) {
            if (ek == 6) {
                int code = app.window.EventKeyCode();
                if (code == 13) { DataTable.CommitEdit(st, cols, src); }
                else if (code == 27) { DataTable.CancelEdit(st); }
                else if (code == 9) { DataTable.CommitEdit(st, cols, src); }
                else if (code == 8) {
                    if (st.editCur > 0) {
                        int startp = Text.PrevCharStart(st.editBuf, st.editCur);
                        st.editBuf = Text.DeleteBefore(st.editBuf, st.editCur);
                        st.editCur = startp;
                    }
                } else {
                    string ch = Text.CharStr(code);
                    if (ch.Length > 0) {
                        st.editBuf = Text.InsertAt(st.editBuf, st.editCur, ch);
                        st.editCur = st.editCur + ch.Length;
                    }
                }
                app.RequestRedraw();
                ek = 0;
            } else if (ek == 4) {
                int kc = app.window.EventKeyCode();
                if (kc == 27) { DataTable.CancelEdit(st); }
                else if (kc == 13) { DataTable.CommitEdit(st, cols, src); }
                else if (kc == 37) { if (st.editCur > 0) { st.editCur = Text.PrevCharStart(st.editBuf, st.editCur); } }
                else if (kc == 39) { if (st.editCur < st.editBuf.Length) { st.editCur = Text.NextCharEnd(st.editBuf, st.editCur); } }
                else if (kc == 36) { st.editCur = 0; }
                else if (kc == 35) { st.editCur = st.editBuf.Length; }
                else if (kc == 46) { if (st.editCur < st.editBuf.Length) { st.editBuf = Text.RemoveAt(st.editBuf, st.editCur); } }
                app.RequestRedraw();
                ek = 0;
            }
        }

        // F2 / Enter opens an editor on the active editable cell (Excel-style).
        if (!st.editing && ek == 4) {
            int kc2 = app.window.EventKeyCode();
            if ((kc2 == 113 || kc2 == 13) && st.hitRow >= 0 && st.hitCol >= 0
                && st.hitCol < cols.Count && cols[st.hitCol].editable) {
                DataTable.BeginEdit(st, cols, src, st.hitRow, st.hitCol);
                ek = 0;
                app.RequestRedraw();
            }
        }

        // left press
        if (ek == 2 && eb == 0 && ptrOi >= 0) {
            if (st.dispRows[ptrOi].kind == 1) {
                // group header press: toggle collapse of that group
                int gi = st.dispRows[ptrOi].row;
                DataTable.ToggleCollapse(st, st.groups[gi].key);
                app.RequestRedraw();
            } else if (app.mouseX >= x && app.mouseX < x + numW) {
                // row-number press: could become a row click or a reorder drag
                st.dragRow = ptrOi;
                st.dragStartY = app.mouseY;
                st.dragMoved = false;
            } else if (app.mouseX >= firstDataX && ptrCol >= 0) {
                // A press on the cell that's already the sole active selection
                // (a slow second click) opens the inline editor; otherwise begin
                // a rectangular range selection. A press while editing commits
                // first, then re-selects.
                bool sameCell = (!st.editing) && st.hitOrder == ptrOi && st.hitCol == ptrCol
                    && st.rangeR0 == st.rangeR1 && st.rangeC0 == st.rangeC1;
                if (st.editing) { DataTable.CommitEdit(st, cols, src); }
                if (sameCell && cols[ptrCol].editable) {
                    DataTable.BeginEdit(st, cols, src, st.dispRows[ptrOi].row, ptrCol);
                    app.RequestRedraw();
                } else {
                    st.rangeR0 = ptrOi;
                    st.rangeR1 = ptrOi;
                    st.rangeC0 = ptrCol;
                    st.rangeC1 = ptrCol;
                    st.rangeDrag = true;
                    st.selAnchor = ptrOi;
                    st.hitOrder = ptrOi;
                    st.hitRow = st.dispRows[ptrOi].row;
                    st.hitCol = ptrCol;
                    st.CellClick.Raise();
                    app.RequestRedraw();
                }
            }
        }

        // drag move
        if (ek == 1) {
            if (st.rangeDrag && ptrOi >= 0) {
                st.rangeR1 = ptrOi;
                if (ptrCol >= 0) { st.rangeC1 = ptrCol; }
                app.RequestRedraw();
            }
            if (st.dragRow >= 0) {
                int dd = app.mouseY - st.dragStartY;
                if (dd < 0) { dd = 0 - dd; }
                if (dd > rowH / 2) { st.dragMoved = true; app.RequestRedraw(); }
            }
        }

        // left release
        if (ek == 3 && eb == 0) {
            if (st.rangeDrag) { st.rangeDrag = false; app.RequestRedraw(); }
            if (st.dragRow >= 0) {
                if (st.groupCols.Count == 0 && st.dragMoved && ptrOi >= 0 && ptrOi != st.dragRow
                    && st.dispRows[ptrOi].kind == 0) {
                    DataTable.MoveOrder(st, st.dragRow, ptrOi);
                    // manual order — drop any active sort without re-running
                    // Recompute (which would rebuild st.order and lose the move).
                    st.sortKeys.Clear();
                    DataTable.SyncPrimary(st);
                    app.RequestRedraw();
                } else if (!st.dragMoved && st.dispRows[st.dragRow].kind == 0) {
                    // treat as a row-selection click (按行选择)
                    int ri = st.dispRows[st.dragRow].row;
                    st.hitOrder = st.dragRow;
                    st.hitRow = ri;
                    st.hitCol = -1;
                    st.RowClick.Raise();
                    st.SelectionChanged.Raise();
                    bool shift = (emods & 2) != 0;
                    bool ctrl = (emods & 1) != 0;
                    if (shift && st.selAnchor >= 0) {
                        DataTable.SelectAllRows(st, false);
                        int a = DataTable.MinI(st.selAnchor, st.dragRow);
                        int b = DataTable.MaxI(st.selAnchor, st.dragRow);
                        int kk = a;
                        while (kk <= b) { if (kk >= 0 && kk < st.dispRows.Count && st.dispRows[kk].kind == 0) { st.selected[st.dispRows[kk].row] = true; } kk = kk + 1; }
                    } else if (ctrl) {
                        st.selected[ri] = !st.selected[ri];
                        st.selAnchor = st.dragRow;
                    } else {
                        DataTable.SelectAllRows(st, false);
                        st.selected[ri] = true;
                        st.selAnchor = st.dragRow;
                        DataTable.ClearRange(st);
                    }
                    app.RequestRedraw();
                }
                st.dragRow = -1;
                st.dragMoved = false;
            }
        }

        // double-click on a body row
        if (ek == 3 && eb == 0 && ptrOi >= 0 && st.dispRows[ptrOi].kind == 0 && app.DoubleClickNow()) {
            st.hitOrder = ptrOi;
            st.hitRow = st.dispRows[ptrOi].row;
            st.RowDoubleClick.Raise();
        }

        // right press => context menu
        if (ek == 2 && eb == 1 && st.openMenu < 0
            && app.mouseX >= x && app.mouseX < x + viewW
            && app.mouseY >= bodyTop && app.mouseY < bodyTop + bodyH) {
            // if right-clicking a row outside any current range/selection, make
            // that row the selection so the menu's copy/export act on something.
            if (ptrOi >= 0 && st.dispRows[ptrOi].kind == 0 && !DataTable.HasRange(st)) {
                int ri = st.dispRows[ptrOi].row;
                if (!st.selected[ri]) {
                    DataTable.SelectAllRows(st, false);
                    st.selected[ri] = true;
                    st.selAnchor = ptrOi;
                }
            }
            st.ctxOpen = true;
            st.ctxX = app.mouseX;
            st.ctxY = app.mouseY;
            app.RequestRedraw();
        }

        // empty state
        if (total == 0) {
            c.DrawTextCentered(x, bodyTop, viewW, bodyH, "No matching rows", t.textTertiary, t.fontSizeMedium);
        }

        // ---------------- summary (total) row ----------------
        if (st.showSummary) {
            int sumY = bodyTop + bodyH;
            c.FillRect(x + 1, sumY, viewW - 2, summaryH, t.bgSecondary);
            c.FillRect(x + 1, sumY, viewW - 2, 1, gridColor);
            int sx = x + numW + selW;
            if (st.showRowNum || st.showSelect) {
                c.DrawTextCentered(x, sumY, numW + selW, summaryH, "Σ", t.textTertiary, t.fontSizeSmall);
            }
            c.PushClip(firstDataX, sumY, dataViewW, summaryH);
            int soi = 0;
            sx = firstDataX - st.scrollX;
            while (soi < vorder.Count && sx < clipRight) {
                int sc = vorder[soi];
                int cw = st.dispW[sc];
                if (sx + cw > firstDataX) {
                    string stxt = "";
                    if (sc < st.summaryText.Count) { stxt = st.summaryText[sc]; }
                    if (stxt.Length > 0) {
                        int pad = t.paddingSmall;
                        string shown = DataTable.Truncate(stxt, fs, cw - pad * 2);
                        int tw = Canvas.MeasureText(shown, fs);
                        int tx = sx + pad;
                        if (cols[sc].align == 2) { tx = sx + cw - pad - tw; }
                        else if (cols[sc].align == 1) { tx = sx + (cw - tw) / 2; }
                        int ty = sumY + (summaryH - Canvas.FontHeight(fs)) / 2;
                        c.DrawText(tx, ty, shown, t.textPrimary, fs);
                    }
                }
                sx = sx + cw;
                soi = soi + 1;
            }
            c.PopClip();
        }

        // ---------------- pager footer (reuses the Pagination widget) ----------------
        if (st.paged) {
            int fY = bodyTop + bodyH + summaryH;
            c.FillRect(x + 1, fY, viewW - 2, pagerH, t.bgSecondary);
            c.FillRect(x + 1, fY, viewW - 2, 1, gridColor);
            int totalPages = 1;
            if (total > 0) { totalPages = (total + visRows - 1) / visRows; }
            int cur = st.pageModel.Get();
            int pgW = Pagination.MeasureWidth(app, totalPages, cur);
            int pgX = x + (viewW - pgW) / 2;
            if (pgX < x + t.paddingMedium) { pgX = x + t.paddingMedium; }
            int pgY = fY + (pagerH - t.heightMedium) / 2;
            int pgFirst = Pagination.Render(app, pgX, pgY, totalPages, st.pageModel);
            Pagination.HandleClick(app, pgFirst, totalPages, st.pageModel);
            // range info on the left
            int from = (cur - 1) * visRows + 1;
            int to = cur * visRows;
            if (to > total) { to = total; }
            if (total == 0) { from = 0; }
            string info = Convert.ToString(from) + "-" + Convert.ToString(to) + " / " + Convert.ToString(total);
            c.DrawText(x + t.paddingMedium, pgY + (t.heightMedium - Canvas.FontHeight(t.fontSizeSmall)) / 2, info, t.textTertiary, t.fontSizeSmall);
        }

        // ---------------- vertical scrollbar ----------------
        if (!st.paged && total > visRows && visRows > 0) {
            int sbW = app.Scale(8);
            int sbX = x + viewW - sbW - app.Scale(2);
            int trackY = bodyTop + app.Scale(2);
            int trackH = bodyH - app.Scale(4);
            int thumbH = trackH * visRows / total;
            if (thumbH < app.Scale(24)) { thumbH = app.Scale(24); }
            int maxStart = total - visRows;
            int thumbY = trackY;
            if (maxStart > 0) { thumbY = trackY + (trackH - thumbH) * start / maxStart; }

            int sbId = app.focus.AllocId();
            bool sbHover = app.focus.IsHovered(sbId);
            int thumbColor = t.scrollbar;
            if (sbHover || app.focus.pressedId == sbId) { thumbColor = t.scrollbarHover; }
            c.FillRoundRect(sbX, thumbY, sbW, thumbH, sbW / 2, thumbColor);
            app.hitTester.Register(HitRegion.Create(sbId, sbX, trackY, sbW, trackH, 0));
            if (app.focus.pressedId == sbId && maxStart > 0) {
                int rel = app.mouseY - trackY - thumbH / 2;
                int denom = trackH - thumbH;
                if (denom < 1) { denom = 1; }
                int ns = rel * maxStart / denom;
                if (ns < 0) { ns = 0; }
                if (ns > maxStart) { ns = maxStart; }
                if (ns != st.scrollRow) { st.scrollRow = ns; st.ScrollChanged.Raise(); app.RequestRedraw(); }
            }
        }

        // ---------------- horizontal scrollbar ----------------
        if (maxScrollX > 0) {
            int hbH = app.Scale(8);
            int hbY = bodyTop + bodyH - hbH - app.Scale(2);
            int htrackX = firstDataX + app.Scale(2);
            int htrackW = dataViewW - app.Scale(4);
            int thumbW = htrackW * availData / dataW;
            if (thumbW < app.Scale(24)) { thumbW = app.Scale(24); }
            int thumbX = htrackX + (htrackW - thumbW) * st.scrollX / maxScrollX;
            int hbId = app.focus.AllocId();
            bool hbHover = app.focus.IsHovered(hbId);
            int hbColor = t.scrollbar;
            if (hbHover || app.focus.pressedId == hbId) { hbColor = t.scrollbarHover; }
            c.FillRoundRect(thumbX, hbY, thumbW, hbH, hbH / 2, hbColor);
            app.hitTester.Register(HitRegion.Create(hbId, htrackX, hbY, htrackW, hbH, 0));
            if (app.focus.pressedId == hbId) {
                int rel = app.mouseX - htrackX - thumbW / 2;
                int denom = htrackW - thumbW;
                if (denom < 1) { denom = 1; }
                int ns = rel * maxScrollX / denom;
                if (ns < 0) { ns = 0; }
                if (ns > maxScrollX) { ns = maxScrollX; }
                if (ns != st.scrollX) { st.scrollX = ns; app.RequestRedraw(); }
            }
        }

        // ---------------- mouse-wheel scrolls the table body ----------------
        // Claim the wheel while the pointer is over the body so the surrounding
        // page doesn't scroll instead, then advance the virtual row window.
        bool ownsBodyWheel = false;
        if (visRows > 0) {
            ownsBodyWheel = app.CaptureWheel(x, bodyTop, viewW, bodyH);
        }
        if (st.openMenu < 0 && ownsBodyWheel
            && maxScrollX > 0 && (app.window.EventMods() & 2) != 0) {
            // Shift+wheel pans the columns horizontally.
            int hDelta = app.window.EventKeyCode();
            int hStep = hDelta / 120;
            if (hStep == 0) { if (hDelta > 0) { hStep = 1; } else if (hDelta < 0) { hStep = 0 - 1; } }
            int nsx = st.scrollX - hStep * app.Scale(48);
            if (nsx < 0) { nsx = 0; }
            if (nsx > maxScrollX) { nsx = maxScrollX; }
            if (nsx != st.scrollX) { st.scrollX = nsx; app.RequestRedraw(); }
        } else if (st.openMenu < 0 && ownsBodyWheel) {
            if (total > visRows) {
                int delta = app.window.EventKeyCode();
                int step = delta / 120;
                if (step == 0) { if (delta > 0) { step = 1; } else if (delta < 0) { step = 0 - 1; } }
                if (st.paged) {
                    // wheel flips whole pages
                    int totalPages = (total + visRows - 1) / visRows;
                    int cp = st.pageModel.Get();
                    int np = cp - step;
                    if (np < 1) { np = 1; }
                    if (np > totalPages) { np = totalPages; }
                    if (np != cp) { st.pageModel.Set(np); app.RequestRedraw(); }
                } else {
                    int ns = st.scrollRow - step * 3;
                    int maxStart = total - visRows;
                    if (ns < 0) { ns = 0; }
                    if (ns > maxStart) { ns = maxStart; }
                    if (ns != st.scrollRow) { st.scrollRow = ns; st.ScrollChanged.Raise(); app.RequestRedraw(); }
                }
            }
        }

        // ---------------- header set-filter menu (overlay, drawn last) ----------------
        if (st.openMenu >= 0 && st.openMenu < cols.Count) {
            DataTable.RenderMenu(app, x, y, viewW, headerH, numW, selW, cols, src, st);
        }

        // ---------------- right-click context menu (overlay) ----------------
        if (st.ctxOpen) {
            DataTable.RenderContextMenu(app, x, y, viewW, viewH, cols, src, st);
        }

        // ---------------- header column context menu (overlay) ----------------
        if (st.hdrCtxOpen) {
            DataTable.RenderHeaderMenu(app, x, y, viewW, viewH, cols, src, st);
        }

        // ---------------- chart-from-selection overlay ----------------
        if (st.chartOpen) {
            DataTable.RenderChart(app, x, y, viewW, viewH, st);
        }

        // ---------------- transient toast (copy/export feedback) ----------------
        if (st.toastFrames > 0 && st.toast.Length > 0) {
            int tfs = t.fontSizeSmall;
            int tw = Canvas.MeasureText(st.toast, tfs) + app.Scale(24);
            int th = t.heightMedium;
            int tx = x + (viewW - tw) / 2;
            int tyy = y + viewH - th - app.Scale(12);
            c.FillRoundRect(tx, tyy, tw, th, t.borderRadiusMedium, t.textPrimary);
            c.DrawTextCentered(tx, tyy, tw, th, st.toast, t.bgPrimary, tfs);
            st.toastFrames = st.toastFrames - 1;
            if (st.toastFrames > 0) { app.RequestRedraw(); }
        }
    }

    // ---------- right-click context menu ----------

    static void CtxItem(App app, int mx, int my, int mw, int ih, string label, string accel) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        if (hov) { c.FillRect(mx, my, mw, ih, t.bgHover); }
        c.DrawText(mx + app.Scale(12), my + (ih - Canvas.FontHeight(t.fontSizeSmall)) / 2, label, t.textPrimary, t.fontSizeSmall);
        if (accel.Length > 0) {
            int aw = Canvas.MeasureText(accel, t.fontSizeSmall);
            c.DrawText(mx + mw - aw - app.Scale(12), my + (ih - Canvas.FontHeight(t.fontSizeSmall)) / 2, accel, t.textTertiary, t.fontSizeSmall);
        }
        app.hitTester.Register(HitRegion.Create(id, mx, my, mw, ih, 0));
    }

    // A header-menu aggregate row: shows a check on the active mode, and on
    // click applies it and closes the menu. Returns the next item's y.
    static int AggItem(App app, int mx, int iy, int mw, int ih,
                       DataTableState st, int col, int mode, string label, int curAgg) {
        string mark = "";
        if (mode == curAgg) { mark = "✓"; }
        DataTable.CtxItem(app, mx, iy, mw, ih, label, mark);
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SetAggregate(st, col, mode);
            st.hitCol = col; st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        return iy + ih;
    }

    static bool CtxHit(App app, int mx, int my, int mw, int ih) {
        // Was the row spanning (mx,my,mw,ih) just clicked? Uses geometry so the
        // ids stay simple; the menu is modal-ish (drawn last, wins hit-testing).
        return app.window.EventKind() == 3 && app.window.EventButton() == 0
               && app.mouseX >= mx && app.mouseX < mx + mw
               && app.mouseY >= my && app.mouseY < my + ih;
    }

    static void Flash(DataTableState st, string msg) {
        st.toast = msg;
        st.toastFrames = 90;
    }

    static void RenderContextMenu(App app, int x, int y, int viewW, int viewH,
                                  List<DataColumn> cols, DataSource src, DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int mw = app.Scale(230);
        int ih = t.heightMedium;
        int sepH = app.Scale(9);

        // menu items: label, accelerator, kind (0 item, 1 separator)
        // 0 copy, 1 copy-with-headers, 2 export csv, 3 chart-from-selection,
        // sep, 4 select all, sep, 5 clear
        int nItems = 6;
        int mh = ih * nItems + sepH * 2 + app.Scale(8);

        int mx = st.ctxX;
        int my = st.ctxY;
        if (mx + mw > x + viewW) { mx = x + viewW - mw - app.Scale(2); }
        if (my + mh > y + viewH) { my = y + viewH - mh - app.Scale(2); }
        if (mx < x) { mx = x; }
        if (my < y) { my = y; }

        // claim wheel + swallow clicks over the whole menu so gaps and the page
        // beneath it don't get scrolled or fall through (items register later)
        app.CaptureWheel(mx, my, mw, mh);
        app.BlockHitsRect(mx, my, mw, mh);
        c.FillRoundRect(mx, my, mw, mh, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(mx, my, mw, mh, t.borderPrimary, 1);

        int iy = my + app.Scale(4);
        DataTable.CtxItem(app, mx, iy, mw, ih, "复制  Copy", "Ctrl+C");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            Clipboard.SetText(DataTable.BuildText(st, cols, src, false, false));
            DataTable.Flash(st, "已复制到剪贴板");
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "复制（含表头）", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            Clipboard.SetText(DataTable.BuildText(st, cols, src, false, true));
            DataTable.Flash(st, "已复制（含表头）");
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "导出 CSV", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            bool ok = SysFile.Write("datatable_export.csv", DataTable.BuildText(st, cols, src, true, true));
            if (ok) { DataTable.Flash(st, "已导出 datatable_export.csv"); }
            else { DataTable.Flash(st, "导出失败"); }
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "从选区生成图表  Chart", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            if (DataTable.BuildChartFromRange(st, cols, src)) {
                st.chartOpen = true;
            } else {
                DataTable.Flash(st, "请先框选含数值列的区域");
            }
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "全选", "Ctrl+A");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SelectAllRows(st, true);
            DataTable.ClearRange(st);
            st.ctxOpen = false;
            app.RequestRedraw();
        }
        iy = iy + ih;
        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "清除选择", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SelectAllRows(st, false);
            DataTable.ClearRange(st);
            st.ctxOpen = false;
            app.RequestRedraw();
        }

        // click outside closes the menu
        if (app.window.EventKind() == 3
            && !(app.mouseX >= mx && app.mouseX < mx + mw && app.mouseY >= my && app.mouseY < my + mh)) {
            st.ctxOpen = false;
            app.RequestRedraw();
        }
    }

    // ---------- chart-from-selection overlay ----------
    // A modal bar chart built from the selected range (see BuildChartFromRange).
    // Closes on the [x] button, a click outside the panel, or Escape.
    static void RenderChart(App app, int x, int y, int viewW, int viewH,
                            DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;

        int m = app.Scale(20);
        int px = x + m;
        int py = y + m;
        int pw = viewW - m * 2;
        int ph = viewH - m * 2;
        if (pw < app.Scale(120) || ph < app.Scale(100)) { st.chartOpen = false; return; }

        // scrim + panel
        c.FillRect(x, y, viewW, viewH, t.overlay);
        // modal: claim wheel + block all hits beneath the chart overlay
        app.CaptureWheel(x, y, viewW, viewH);
        app.BlockHitsRect(x, y, viewW, viewH);
        c.FillRoundRect(px, py, pw, ph, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(px, py, pw, ph, t.borderPrimary, 1);

        // title bar
        int th = t.heightLarge;
        c.FillRect(px + 1, py + 1, pw - 2, th, t.bgSecondary);
        c.FillRect(px + 1, py + th, pw - 2, 1, t.divider);
        c.DrawText(px + app.Scale(14), py + (th - Canvas.FontHeight(t.fontSizeMedium)) / 2,
                   "图表 Chart · " + st.chartTitle, t.textPrimary, t.fontSizeMedium);

        // close button
        int cbs = app.Scale(22);
        int cbx = px + pw - cbs - app.Scale(8);
        int cby = py + (th - cbs) / 2;
        bool cbHot = app.mouseX >= cbx && app.mouseX < cbx + cbs
                     && app.mouseY >= cby && app.mouseY < cby + cbs;
        if (cbHot) { c.FillRoundRect(cbx, cby, cbs, cbs, app.Scale(4), t.bgHover); }
        c.DrawTextCentered(cbx, cby, cbs, cbs, "×", t.textPrimary, t.fontSizeLarge);

        // plot area
        int axisW = app.Scale(44);
        int plotX = px + axisW;
        int plotTop = py + th + app.Scale(14);
        int plotBottom = py + ph - app.Scale(30);
        int plotRight = px + pw - app.Scale(16);
        int plotW = plotRight - plotX;
        int plotH = plotBottom - plotTop;
        int n = st.chartBars.Count;
        if (plotH < app.Scale(20) || plotW < app.Scale(20) || n <= 0) {
            // still allow closing even if too small to plot
        } else {
            int mx = st.chartMax;
            if (mx < 1) { mx = 1; }

            // baseline + max/zero axis labels + a faint midline
            c.FillRect(plotX, plotBottom, plotW, 1, t.borderPrimary);
            c.DrawText(px + app.Scale(8), plotTop - Canvas.FontHeight(t.fontSizeSmall) / 2,
                       Convert.ToString(mx), t.textTertiary, t.fontSizeSmall);
            c.DrawText(px + app.Scale(8), plotBottom - Canvas.FontHeight(t.fontSizeSmall) / 2,
                       "0", t.textTertiary, t.fontSizeSmall);
            int midY = plotTop + plotH / 2;
            c.FillRect(plotX, midY, plotW, 1, t.divider);

            int slotW = plotW / n;
            int barW = slotW * 3 / 5;
            if (barW < app.Scale(4)) { barW = app.Scale(4); }
            int i = 0;
            while (i < n) {
                ChartBar bar = st.chartBars[i];
                int av = bar.val;
                if (av < 0) { av = 0 - av; }
                int bh = av * plotH / mx;
                if (bh < 1 && av > 0) { bh = 1; }
                int slotL = plotX + slotW * i;
                int bx = slotL + (slotW - barW) / 2;
                int byy = plotBottom - bh;
                c.FillRect(bx, byy, barW, bh, t.primary);

                // value label above the bar
                string vlab = Convert.ToString(bar.val);
                int vlw = Canvas.MeasureText(vlab, t.fontSizeSmall);
                int vlx = slotL + (slotW - vlw) / 2;
                int vly = byy - Canvas.FontHeight(t.fontSizeSmall) - app.Scale(2);
                if (vly < plotTop) { vly = plotTop; }
                c.DrawText(vlx, vly, vlab, t.textSecondary, t.fontSizeSmall);

                // category label below the baseline (clipped to the slot)
                c.PushClip(slotL, plotBottom + app.Scale(4), slotW, app.Scale(20));
                c.DrawTextCentered(slotL, plotBottom + app.Scale(4), slotW,
                                   Canvas.FontHeight(t.fontSizeSmall),
                                   bar.label, t.textTertiary, t.fontSizeSmall);
                c.PopClip();
                i = i + 1;
            }
        }

        // close interactions: [x], click outside the panel, or Escape
        bool clicked = app.window.EventKind() == 3 && app.window.EventButton() == 0;
        bool inside = app.mouseX >= px && app.mouseX < px + pw
                      && app.mouseY >= py && app.mouseY < py + ph;
        if ((clicked && (cbHot || !inside))
            || (app.window.EventKind() == 4 && app.window.EventKeyCode() == 27)) {
            st.chartOpen = false;
            app.RequestRedraw();
        }
    }

    // ---------- header (column) context menu ----------
    // Right-clicking a column header opens this DevExpress/ag-Grid-style menu:
    // sort, auto-fit width, hide the column, restore all columns, and jump to
    // the set-filter popup. Layout mirrors RenderContextMenu (running iy).
    static void RenderHeaderMenu(App app, int x, int y, int viewW, int viewH,
                                 List<DataColumn> cols, DataSource src, DataTableState st) {
        int col = st.hdrCtxCol;
        if (col < 0 || col >= cols.Count) { st.hdrCtxOpen = false; return; }
        Canvas c = app.canvas;
        Theme t = app.theme;
        int mw = app.Scale(230);
        int ih = t.heightMedium;
        int sepH = app.Scale(9);

        bool canClear = DataTable.SortIndexOf(st, col) >= 0;
        bool anyHidden = DataTable.HiddenCount(st) > 0;
        bool canFilter = cols[col].filterable;
        bool canAgg = cols[col].numeric;

        int nItems = 4;                       // asc, desc, auto-fit, auto-fit-all
        if (canClear) { nItems = nItems + 1; }
        nItems = nItems + 1;                  // group by this column
        if (st.groupCols.Count > 0) { nItems = nItems + 1; }  // ungroup all
        nItems = nItems + 1;                  // pin / unpin column
        nItems = nItems + 1;                  // hide column
        if (anyHidden) { nItems = nItems + 1; }
        if (canAgg) { nItems = nItems + 6; }  // sum/avg/min/max/count/none total
        if (canFilter) { nItems = nItems + 1; }
        int nSep = 3;                         // after sort, after auto-fit, after group
        if (canAgg) { nSep = nSep + 1; }      // before aggregate items
        if (canFilter) { nSep = nSep + 1; }   // before filter item
        int mh = ih * nItems + sepH * nSep + app.Scale(8);

        int mx = st.hdrCtxX;
        int my = st.hdrCtxY;
        if (mx + mw > x + viewW) { mx = x + viewW - mw - app.Scale(2); }
        if (my + mh > y + viewH) { my = y + viewH - mh - app.Scale(2); }
        if (mx < x) { mx = x; }
        if (my < y) { my = y; }

        // claim wheel + swallow clicks over the whole menu so gaps and the page
        // beneath it don't get scrolled or fall through (items register later)
        app.CaptureWheel(mx, my, mw, mh);
        app.BlockHitsRect(mx, my, mw, mh);
        c.FillRoundRect(mx, my, mw, mh, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(mx, my, mw, mh, t.borderPrimary, 1);

        int iy = my + app.Scale(4);
        DataTable.CtxItem(app, mx, iy, mw, ih, "升序排序  Sort Ascending", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SortBy(st, col, 1);
            st.hitCol = col; st.Sort.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "降序排序  Sort Descending", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.SortBy(st, col, 2);
            st.hitCol = col; st.Sort.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        if (canClear) {
            DataTable.CtxItem(app, mx, iy, mw, ih, "清除排序  Clear Sort", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                DataTable.ClearSort(st);
                st.Sort.Raise();
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "自动列宽  Auto-fit Column", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.AutoFitColumn(app, cols, src, st, col);
            st.hitCol = col; st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "自动全部列宽  Auto-fit All", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.AutoFitAll(app, cols, src, st);
            st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;

        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        DataTable.CtxItem(app, mx, iy, mw, ih, "按此列分组  Group by This", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.GroupBy(st, col);
            st.hitCol = col; st.GroupChanged.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        if (st.groupCols.Count > 0) {
            DataTable.CtxItem(app, mx, iy, mw, ih, "取消分组  Ungroup All", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                DataTable.Ungroup(st);
                st.GroupChanged.Raise();
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
        iy = iy + sepH;
        string pinLbl = "冻结此列  Freeze Column";
        if (DataTable.IsPinned(st, col)) { pinLbl = "取消冻结  Unfreeze Column"; }
        DataTable.CtxItem(app, mx, iy, mw, ih, pinLbl, "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            DataTable.TogglePin(st, col);
            st.hitCol = col; st.ColumnResize.Raise();
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        DataTable.CtxItem(app, mx, iy, mw, ih, "隐藏此列  Hide Column", "");
        if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
            st.colHidden[col] = true;
            st.hdrCtxOpen = false; app.RequestRedraw();
        }
        iy = iy + ih;
        if (anyHidden) {
            DataTable.CtxItem(app, mx, iy, mw, ih, "显示所有列  Show All Columns", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                DataTable.ShowAllColumns(st);
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        if (canAgg) {
            c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
            iy = iy + sepH;
            int curAgg = 0;
            if (col < st.aggMode.Count) { curAgg = st.aggMode[col]; }
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 1, "合计  Sum", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 2, "平均  Average", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 3, "最小  Min", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 4, "最大  Max", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 5, "计数  Count", curAgg);
            iy = DataTable.AggItem(app, mx, iy, mw, ih, st, col, 0, "无汇总  No Total", curAgg);
        }

        if (canFilter) {
            c.FillRect(mx + app.Scale(8), iy + sepH / 2, mw - app.Scale(16), 1, t.divider);
            iy = iy + sepH;
            DataTable.CtxItem(app, mx, iy, mw, ih, "筛选…  Filter", "");
            if (DataTable.CtxHit(app, mx, iy, mw, ih)) {
                st.openMenu = col;
                st.filterTab = 0;
                st.searchText = "";
                st.valScroll = 0;
                st.editFocus = 0;
                st.batchLines = new List<string>();
                st.batchLines.Add("");
                st.batchExactFlag = 0;
                st.menuVals = DataTable.Distinct(src, col);
                st.menuMatched = st.menuVals;
                st.menuSearchCache = "";
                st.hdrCtxOpen = false; app.RequestRedraw();
            }
            iy = iy + ih;
        }

        // click outside closes the menu
        if (app.window.EventKind() == 3
            && !(app.mouseX >= mx && app.mouseX < mx + mw && app.mouseY >= my && app.mouseY < my + mh)) {
            st.hdrCtxOpen = false;
            app.RequestRedraw();
        }
    }

    // ---------- tabbed filter popup (DevExpress-style) ----------

    static bool TabBtn(App app, int bx, int by, int bw, int bh, string label, bool active) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        if (active) { c.FillRect(bx, by, bw, bh, t.bgActive); }
        else if (hov) { c.FillRect(bx, by, bw, bh, t.bgHover); }
        int fg = t.textSecondary;
        if (active) { fg = t.primary; }
        c.DrawTextCentered(bx, by, bw, bh, label, fg, t.fontSizeSmall);
        if (active) { c.FillRect(bx, by + bh - app.Scale(2), bw, app.Scale(2), t.primary); }
        app.hitTester.Register(HitRegion.Create(id, bx, by, bw, bh, 0));
        return app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == id;
    }

    static bool IconBtn(App app, int bx, int by, int bw, int bh, string icon, bool active) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        int col = t.textSecondary;
        if (active) { c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, t.bgActive); col = t.primary; }
        else if (hov) { c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, t.bgHover); }
        Icon.DrawCenteredIn(c, icon, bx, by, bw, bh, app.Scale(13), col);
        app.hitTester.Register(HitRegion.Create(id, bx, by, bw, bh, 0));
        return app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == id;
    }

    static bool TextBtn(App app, int bx, int by, int bw, int bh, string label, bool primary) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int id = app.focus.AllocId();
        bool hov = app.focus.IsHovered(id);
        int bg = t.bgSecondary;
        int fg = t.textPrimary;
        if (primary) { bg = t.primary; fg = t.textInverse; }
        else if (hov) { bg = t.bgHover; }
        c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, bg);
        if (!primary) { c.DrawRect(bx, by, bw, bh, t.borderPrimary, 1); }
        c.DrawTextCentered(bx, by, bw, bh, label, fg, t.fontSizeSmall);
        app.hitTester.Register(HitRegion.Create(id, bx, by, bw, bh, 0));
        return app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == id;
    }

    static void EditBox(App app, int bx, int by, int bw, int bh, string text, string ph, bool focused) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int fs = t.fontSizeSmall;
        int bc = t.borderPrimary;
        if (focused) { bc = t.borderFocus; }
        c.FillRoundRect(bx, by, bw, bh, t.borderRadiusSmall, t.bgPrimary);
        c.DrawRect(bx, by, bw, bh, bc, 1);
        int tpad = app.Scale(6);
        int ty = by + (bh - Canvas.FontHeight(fs)) / 2;
        string shown = DataTable.Truncate(text, fs, bw - tpad * 2);
        if (text.Length == 0) {
            c.DrawText(bx + tpad, ty, ph, t.textTertiary, fs);
        } else {
            c.DrawText(bx + tpad, ty, shown, t.textPrimary, fs);
        }
        if (focused) {
            int cxp = bx + tpad + Canvas.MeasureText(shown, fs);
            if (cxp > bx + bw - tpad) { cxp = bx + bw - tpad; }
            c.FillRect(cxp, ty, app.Scale(1), Canvas.FontHeight(fs), t.primary);
        }
    }

    static void RenderMenu(App app, int x, int y, int viewW, int headerH, int numW, int selW,
                           List<DataColumn> cols, DataSource src, DataTableState st) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int mi = st.openMenu;
        ColFilter f = st.filters[mi];

        int pad = app.Scale(10);
        int fs = t.fontSizeSmall;
        int fsM = t.fontSizeMedium;
        int rowH = app.Scale(28);
        int menuW = app.Scale(256);
        int menuH = app.Scale(348);

        // anchor under the column, clamp fully inside the window
        int mx = x + numW + selW - st.scrollX;
        int k = 0;
        while (k < mi) { mx = mx + st.dispW[k]; k = k + 1; }
        if (mx + menuW > x + viewW) { mx = x + viewW - menuW; }
        if (mx < x) { mx = x; }
        int my = y + headerH;
        int canH = c.Height();
        if (my + menuH > canH) { my = canH - menuH - app.Scale(6); }
        if (my < app.titlebarH) { my = app.titlebarH; }

        // claim the wheel over the popup so the page underneath doesn't scroll
        app.CaptureWheel(mx, my, menuW, menuH);
        // swallow clicks over the whole panel so empty areas don't fall through
        app.BlockHitsRect(mx, my, menuW, menuH);

        // route typed keys to the focused edit field
        if (app.window.EventKind() == 6 && st.editFocus != 0) {
            int chv = app.window.EventKeyCode();
            if (st.editFocus == 1) {
                if (chv == 8) { st.searchText = DataTable.Backspace(st.searchText); }
                else { string ad = DataTable.CharStr(chv); if (ad.Length > 0) { st.searchText = st.searchText + ad; } }
            } else if (st.editFocus == 2) {
                if (chv == 8) { f.textQuery = DataTable.Backspace(f.textQuery); }
                else { string ad = DataTable.CharStr(chv); if (ad.Length > 0) { f.textQuery = f.textQuery + ad; } }
                st.dirty = true;
            } else if (st.editFocus == 3) {
                int last = st.batchLines.Count - 1;
                if (last < 0) { st.batchLines.Add(""); last = 0; }
                if (chv == 13) { st.batchLines.Add(""); }
                else if (chv == 8) {
                    string cur = st.batchLines[last];
                    if (cur.Length > 0) { st.batchLines[last] = DataTable.Backspace(cur); }
                    else if (last > 0) { st.batchLines.RemoveAt(last); }
                } else {
                    string ad = DataTable.CharStr(chv);
                    if (ad.Length > 0) { st.batchLines[last] = st.batchLines[last] + ad; }
                }
            }
            app.RequestRedraw();
        }

        // panel
        c.FillRoundRect(mx + app.Scale(2), my + app.Scale(3), menuW, menuH, t.borderRadiusMedium, t.overlay);
        c.FillRoundRect(mx, my, menuW, menuH, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(mx, my, menuW, menuH, t.borderPrimary, 1);

        // header: title + sort asc/desc
        int hy = my + app.Scale(8);
        c.DrawText(mx + pad, hy + (rowH - Canvas.FontHeight(fsM)) / 2, cols[mi].title, t.textPrimary, fsM);
        int sbw = app.Scale(26);
        int sUpX = mx + menuW - pad - sbw * 2 - app.Scale(4);
        int sDnX = mx + menuW - pad - sbw;
        if (DataTable.IconBtn(app, sUpX, hy, sbw, rowH, "arrow-up", st.sortCol == mi && st.sortDir == 1)) {
            DataTable.SortBy(st, mi, 1); app.RequestRedraw();
        }
        if (DataTable.IconBtn(app, sDnX, hy, sbw, rowH, "arrow-down", st.sortCol == mi && st.sortDir == 2)) {
            DataTable.SortBy(st, mi, 2); app.RequestRedraw();
        }
        int cy = hy + rowH + app.Scale(6);

        // tabs
        int tabW = (menuW - pad * 2) / 3;
        if (DataTable.TabBtn(app, mx + pad, cy, tabW, rowH, "Values", st.filterTab == 0)) { st.filterTab = 0; st.editFocus = 0; app.RequestRedraw(); }
        if (DataTable.TabBtn(app, mx + pad + tabW, cy, tabW, rowH, "Text", st.filterTab == 1)) { st.filterTab = 1; st.editFocus = 0; app.RequestRedraw(); }
        if (DataTable.TabBtn(app, mx + pad + tabW * 2, cy, tabW, rowH, "Batch", st.filterTab == 2)) { st.filterTab = 2; st.editFocus = 0; app.RequestRedraw(); }
        c.FillRect(mx + pad, cy + rowH, menuW - pad * 2, 1, t.divider);
        cy = cy + rowH + app.Scale(8);

        int footerH = app.Scale(40);
        int contentBottom = my + menuH - footerH;

        if (st.filterTab == 0) {
            int boxH = app.Scale(26);
            DataTable.EditBox(app, mx + pad, cy, menuW - pad * 2, boxH, st.searchText, "Search values...", st.editFocus == 1);
            int sId = app.focus.AllocId();
            app.hitTester.Register(HitRegion.Create(sId, mx + pad, cy, menuW - pad * 2, boxH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == sId) { st.editFocus = 1; app.RequestRedraw(); }
            cy = cy + boxH + app.Scale(6);

            int itemH = app.Scale(24);
            int allId = app.focus.AllocId();
            bool anyHidden = f.hidden.Count > 0;
            if (app.focus.IsHovered(allId)) { c.FillRect(mx + pad, cy, menuW - pad * 2, itemH, t.bgHover); }
            DataTable.DrawMiniCheck(app, mx + pad, cy, itemH, !anyHidden);
            c.DrawText(mx + pad + app.Scale(22), cy + (itemH - Canvas.FontHeight(fs)) / 2, "(Select All)", t.textPrimary, fs);
            app.hitTester.Register(HitRegion.Create(allId, mx + pad, cy, menuW - pad * 2, itemH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == allId) {
                f.hidden.Clear();
                st.dirty = true; app.RequestRedraw();
            }
            cy = cy + itemH;

            // Rebuild the filtered value list only when the search text changes
            // (not every frame): a column can have thousands of distinct values,
            // so re-scanning + reallocating each frame would stutter. The list
            // is virtualised — only the visible window is drawn — so it stays
            // smooth no matter how many distinct values there are.
            if (!(st.searchText == st.menuSearchCache)) {
                st.menuMatched = new List<string>();
                int vi0 = 0;
                while (vi0 < st.menuVals.Count) {
                    if (DataTable.ContainsCI(st.menuVals[vi0], st.searchText)) { st.menuMatched.Add(st.menuVals[vi0]); }
                    vi0 = vi0 + 1;
                }
                st.menuSearchCache = st.searchText;
                st.valScroll = 0;
            }
            List<string> matched = st.menuMatched;

            int sbGW = app.Scale(10);
            int listX = mx + pad;
            int itemW = menuW - pad * 2 - sbGW;
            int listH = contentBottom - cy;
            int visN = listH / itemH;
            if (visN < 1) { visN = 1; }
            int maxScroll = matched.Count - visN;
            if (maxScroll < 0) { maxScroll = 0; }
            if (st.valScroll > maxScroll) { st.valScroll = maxScroll; }
            if (st.valScroll < 0) { st.valScroll = 0; }

            int listTop = cy;
            int r2 = 0;
            while (r2 < visN && (st.valScroll + r2) < matched.Count) {
                string v = matched[st.valScroll + r2];
                int vId = app.focus.AllocId();
                if (app.focus.IsHovered(vId)) { c.FillRect(listX, cy, itemW, itemH, t.bgHover); }
                bool visible = !f.IsHidden(v);
                DataTable.DrawMiniCheck(app, listX, cy, itemH, visible);
                string label = DataTable.Truncate(v, fs, itemW - app.Scale(26));
                c.DrawText(listX + app.Scale(22), cy + (itemH - Canvas.FontHeight(fs)) / 2, label, t.textPrimary, fs);
                app.hitTester.Register(HitRegion.Create(vId, listX, cy, itemW, itemH, 0));
                if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == vId) {
                    f.Toggle(v); st.dirty = true; app.RequestRedraw();
                }
                cy = cy + itemH;
                r2 = r2 + 1;
            }

            // draggable scrollbar for the virtualised value list
            if (matched.Count > visN) {
                int trackX = listX + itemW + app.Scale(3);
                int trackY = listTop;
                int trackH = visN * itemH;
                int sbW = app.Scale(6);
                int thumbH = trackH * visN / matched.Count;
                if (thumbH < app.Scale(20)) { thumbH = app.Scale(20); }
                int thumbY = trackY;
                if (maxScroll > 0) { thumbY = trackY + (trackH - thumbH) * st.valScroll / maxScroll; }
                int vsbId = app.focus.AllocId();
                int thumbColor = t.scrollbar;
                if (app.focus.IsHovered(vsbId) || app.focus.pressedId == vsbId) { thumbColor = t.scrollbarHover; }
                c.FillRoundRect(trackX, thumbY, sbW, thumbH, sbW / 2, thumbColor);
                app.hitTester.Register(HitRegion.Create(vsbId, trackX, trackY, sbW, trackH, 0));
                if (app.focus.pressedId == vsbId && maxScroll > 0) {
                    int rel = app.mouseY - trackY - thumbH / 2;
                    int denom = trackH - thumbH;
                    if (denom < 1) { denom = 1; }
                    int ns = rel * maxScroll / denom;
                    if (ns < 0) { ns = 0; }
                    if (ns > maxScroll) { ns = maxScroll; }
                    if (ns != st.valScroll) { st.valScroll = ns; app.RequestRedraw(); }
                }
            }
            if (app.window.EventKind() == 13) {
                bool inside = app.mouseX >= mx && app.mouseX < mx + menuW && app.mouseY >= my && app.mouseY < my + menuH;
                if (inside) {
                    int delta = app.window.EventKeyCode();
                    st.valScroll = st.valScroll - delta / 120;
                    if (st.valScroll > maxScroll) { st.valScroll = maxScroll; }
                    if (st.valScroll < 0) { st.valScroll = 0; }
                    app.RequestRedraw();
                }
            }
        } else if (st.filterTab == 1) {
            int chipW = (menuW - pad * 2 - app.Scale(9)) / 4;
            int chipH = app.Scale(24);
            int gap = app.Scale(3);
            if (DataTable.TabBtn(app, mx + pad, cy, chipW, chipH, "Contains", f.textMode == 1)) { f.textMode = 1; st.dirty = true; app.RequestRedraw(); }
            if (DataTable.TabBtn(app, mx + pad + (chipW + gap), cy, chipW, chipH, "Equals", f.textMode == 2)) { f.textMode = 2; st.dirty = true; app.RequestRedraw(); }
            if (DataTable.TabBtn(app, mx + pad + (chipW + gap) * 2, cy, chipW, chipH, "Starts", f.textMode == 3)) { f.textMode = 3; st.dirty = true; app.RequestRedraw(); }
            if (DataTable.TabBtn(app, mx + pad + (chipW + gap) * 3, cy, chipW, chipH, "Ends", f.textMode == 4)) { f.textMode = 4; st.dirty = true; app.RequestRedraw(); }
            cy = cy + chipH + app.Scale(8);

            int boxH = app.Scale(26);
            DataTable.EditBox(app, mx + pad, cy, menuW - pad * 2, boxH, f.textQuery, "Enter filter text...", st.editFocus == 2);
            int qId = app.focus.AllocId();
            app.hitTester.Register(HitRegion.Create(qId, mx + pad, cy, menuW - pad * 2, boxH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == qId) { st.editFocus = 2; app.RequestRedraw(); }
            cy = cy + boxH + app.Scale(10);

            c.DrawText(mx + pad, cy, "Live-filters as you type", t.textTertiary, fs);
            cy = cy + Canvas.FontHeight(fs) + app.Scale(2);
            c.DrawText(mx + pad, cy, "(case-insensitive).", t.textTertiary, fs);
        } else {
            c.DrawText(mx + pad, cy, "One condition per line:", t.textSecondary, fs);
            cy = cy + Canvas.FontHeight(fs) + app.Scale(4);
            int areaH = contentBottom - cy - app.Scale(66);
            if (areaH < app.Scale(48)) { areaH = app.Scale(48); }
            int aId = app.focus.AllocId();
            int abc = t.borderPrimary;
            if (st.editFocus == 3) { abc = t.borderFocus; }
            c.FillRoundRect(mx + pad, cy, menuW - pad * 2, areaH, t.borderRadiusSmall, t.bgPrimary);
            c.DrawRect(mx + pad, cy, menuW - pad * 2, areaH, abc, 1);
            app.hitTester.Register(HitRegion.Create(aId, mx + pad, cy, menuW - pad * 2, areaH, 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == aId) { st.editFocus = 3; app.RequestRedraw(); }
            int lh = Canvas.FontHeight(fs) + app.Scale(3);
            int li = 0;
            int ly = cy + app.Scale(4);
            while (li < st.batchLines.Count && ly + lh < cy + areaH) {
                string ln = DataTable.Truncate(st.batchLines[li], fs, menuW - pad * 2 - app.Scale(10));
                c.DrawText(mx + pad + app.Scale(5), ly, ln, t.textPrimary, fs);
                if (st.editFocus == 3 && li == st.batchLines.Count - 1) {
                    int cxp = mx + pad + app.Scale(5) + Canvas.MeasureText(ln, fs);
                    c.FillRect(cxp, ly, app.Scale(1), Canvas.FontHeight(fs), t.primary);
                }
                ly = ly + lh;
                li = li + 1;
            }
            cy = cy + areaH + app.Scale(6);

            int exId = app.focus.AllocId();
            bool exact = st.batchExactFlag == 1;
            DataTable.DrawMiniCheck(app, mx + pad, cy, app.Scale(22), exact);
            c.DrawText(mx + pad + app.Scale(22), cy + (app.Scale(22) - Canvas.FontHeight(fs)) / 2, "Exact match", t.textPrimary, fs);
            app.hitTester.Register(HitRegion.Create(exId, mx + pad, cy, app.Scale(130), app.Scale(22), 0));
            if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == exId) {
                if (st.batchExactFlag == 1) { st.batchExactFlag = 0; } else { st.batchExactFlag = 1; }
                app.RequestRedraw();
            }
            cy = cy + app.Scale(28);

            int bw = (menuW - pad * 2 - app.Scale(6)) / 2;
            int bh = app.Scale(26);
            bool keepClick = DataTable.TextBtn(app, mx + pad, cy, bw, bh, "Keep matching", true);
            bool exclClick = DataTable.TextBtn(app, mx + pad + bw + app.Scale(6), cy, bw, bh, "Exclude", false);
            if (keepClick || exclClick) {
                f.batchTerms.Clear();
                int bl = 0;
                while (bl < st.batchLines.Count) {
                    if (st.batchLines[bl].Length > 0) { f.batchTerms.Add(st.batchLines[bl]); }
                    bl = bl + 1;
                }
                f.batchExact = st.batchExactFlag == 1;
                f.batchKeep = keepClick;
                st.dirty = true;
                app.RequestRedraw();
            }
        }

        // footer: Clear / Close
        int fy = my + menuH - footerH + app.Scale(6);
        int fbw = (menuW - pad * 2 - app.Scale(6)) / 2;
        int fbh = app.Scale(28);
        c.FillRect(mx + pad, my + menuH - footerH, menuW - pad * 2, 1, t.divider);
        bool clearClick = DataTable.TextBtn(app, mx + pad, fy, fbw, fbh, "Clear Filter", false);
        bool closeClick = DataTable.TextBtn(app, mx + pad + fbw + app.Scale(6), fy, fbw, fbh, "Close", false);
        if (clearClick) {
            st.filters[mi] = ColFilter.Create();
            st.searchText = "";
            st.batchLines = new List<string>();
            st.batchLines.Add("");
            st.batchExactFlag = 0;
            st.editFocus = 0;
            st.dirty = true;
            app.RequestRedraw();
        }
        if (closeClick) { st.openMenu = -1; app.RequestRedraw(); }

        // click outside closes the menu (and blurs the edit field)
        if (app.window.EventKind() == 3) {
            bool inside = app.mouseX >= mx && app.mouseX < mx + menuW && app.mouseY >= my && app.mouseY < my + menuH;
            bool onIcon = app.mouseY >= y && app.mouseY < y + headerH;
            if (!inside && !onIcon) { st.openMenu = -1; app.RequestRedraw(); }
        }
    }

    static void DrawMiniCheck(App app, int bx, int cy, int itemH, bool checked) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int box = app.Scale(15);
        int by = cy + (itemH - box) / 2;
        if (checked) {
            c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.primary);
            int ins = app.Scale(3);
            Icon.Draw(c, "check", bx + ins, by + ins, box - ins * 2, t.textInverse);
        } else {
            c.FillRoundRect(bx, by, box, box, t.borderRadiusSmall, t.bgPrimary);
            c.DrawRect(bx, by, box, box, t.borderPrimary, 1);
        }
    }
}
