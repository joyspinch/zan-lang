using System;

namespace Gui;

/// Vue-style reactive data binding.
/// Signal: mutable reactive value. Set triggers version bump.
/// Two-way binding: widget reads signal.Get(), writes signal.Set(v).
class SignalInt {
    int val;
    int version;

    static SignalInt Create(int initial) {
        SignalInt s = new SignalInt();
        s.val = initial;
        s.version = 0;
        return s;
    }

    int Get() { return val; }

    void Set(int v) {
        val = v;
        version = version + 1;
    }

    int Version() { return version; }
}

class SignalBool {
    bool val;
    int version;

    static SignalBool Create(bool initial) {
        SignalBool s = new SignalBool();
        s.val = initial;
        s.version = 0;
        return s;
    }

    bool Get() { return val; }

    void Set(bool v) {
        val = v;
        version = version + 1;
    }

    void Toggle() {
        val = !val;
        version = version + 1;
    }

    int Version() { return version; }
}

class SignalString {
    string val;
    int version;

    static SignalString Create(string initial) {
        SignalString s = new SignalString();
        s.val = initial;
        s.version = 0;
        return s;
    }

    string Get() { return val; }

    void Set(string v) {
        val = v;
        version = version + 1;
    }

    int Version() { return version; }
}

/// Tracks version numbers of multiple signals to detect changes.
class ChangeTracker {
    int lastVersion;

    static ChangeTracker Create() {
        ChangeTracker ct = new ChangeTracker();
        ct.lastVersion = -1;
        return ct;
    }

    bool Changed(int currentVersion) {
        if (currentVersion != lastVersion) {
            lastVersion = currentVersion;
            return true;
        }
        return false;
    }
}
