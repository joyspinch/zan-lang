using System;
using Gui.Widget;

namespace Gui;

/// Designer part: the property inspector (per-field editors, two-way
/// sync) and design JSON serialization.
partial class Designer {
    void RenderInspector(App app, Canvas c, Theme t, int x, int y, int w, int h) {
        int fs = t.fontSizeSmall;
        c.FillRoundRect(x, y, w, h, app.Scale(6), t.bgSecondary);
        c.DrawRect(x, y, w, h, t.borderPrimary, 1);
        int ix = x + app.Scale(12);
        int iw = w - app.Scale(24);

        // Fixed header: which object is being edited + the Properties / Events
        // tab pair. The target is the selected component, or the root Window
        // when nothing is selected.
        bool root = (sel == null);
        int hy = y + app.Scale(10);
        string target = Designer.T("WINDOW", "窗口") + "  ·  " + winTitleSig.Get();
        if (!root) {
            string tn = FormField.TypeName(sel.ftype);
            if (sel.ftype == 100) { tn = sel.customKind; }
            target = Designer.T("COMPONENT", "组件") + "  ·  " + tn;
        }
        c.DrawText(ix, hy, Ellipsis.Fit(target, iw, fs), t.textTertiary, fs);
        hy = hy + app.Scale(18);

        int tabW = (iw - app.Scale(6)) / 2;
        int pType = 0; if (inspTab == 0) { pType = 1; }
        int eType = 0; if (inspTab == 1) { eType = 1; }
        int pId = Button.Typed(Designer.T("Properties", "属性"), pType).Render(app, ix, hy, tabW);
        int eId = Button.Typed(Designer.T("Events", "事件"), eType).Render(app, ix + tabW + app.Scale(6), hy, tabW);
        if (Button.WasClicked(app, pId) && inspTab != 0) { inspTab = 0; inspScroll = 0; }
        if (Button.WasClicked(app, eId) && inspTab != 1) { inspTab = 1; inspScroll = 0; }
        hy = hy + app.Scale(38);

        // Scrollable body. Content height is measured from the previous frame
        // (inspContentH) so tall property / grouped-event lists can scroll.
        int bodyY = hy;
        int bodyH = y + h - bodyY - app.Scale(8);
        int maxScroll = inspContentH - bodyH;
        if (maxScroll < 0) { maxScroll = 0; }
        if (InRect(app.mouseX, app.mouseY, x, bodyY, w, bodyH)) {
            if (app.CaptureWheel(x, bodyY, w, bodyH)) {
                int delta = app.window.EventKeyCode();
                inspScroll = inspScroll - delta * app.Scale(40) / 120;
                app.RequestRedraw();
            }
        }
        if (inspScroll < 0) { inspScroll = 0; }
        if (inspScroll > maxScroll) { inspScroll = maxScroll; }

        c.PushClip(x + 1, bodyY, w - 2, bodyH);
        int iy = bodyY - inspScroll;
        int startY = iy;
        if (inspTab == 1) {
            iy = RenderEventsTab(app, c, t, ix, iy, iw);
        } else if (root) {
            iy = RenderWindowProps(app, c, t, ix, iy, iw);
        } else {
            SyncEditors(sel);
            iy = RenderFieldProps(app, c, t, sel, ix, iy, iw);
        }
        inspContentH = iy - startY;
        c.PopClip();

        if (maxScroll > 0) {
            Scrollbar.RenderVertical(app, x + w - app.Scale(7), bodyY,
                bodyH, inspContentH, inspScroll);
        }
    }

    void SyncEditors(FormField f) {
        if (f == selPrev) { return; }
        selPrev = f;
        labelSig.Set(f.label);
        nameSig.Set(f.fname);
        phSig.Set(f.placeholder);
        bindSig.Set(f.bindPath);
        bindPropSig.Set(f.bindProp);
        customSig.Set(f.customKind);
        optSig.Set("");
        List<string> evs = f.Events();
        if (evs.Count > 0) { evtEditing = evs[0]; } else { evtEditing = ""; }
        evtSig.Set(f.GetHandler(evtEditing));
    }

    /// Suggests a delegate method name for an event, e.g. field "amount" +
    /// "Change" -> "OnAmountChange". Spaces in the type name are stripped so
    /// display components (e.g. "Data Table") still yield a valid identifier.
    static string SuggestHandler(FormField f, string ev) {
        string src = f.fname;
        if (src == "") { src = FormField.TypeName(f.ftype); }
        string id = "";
        int i = 0;
        while (i < src.Length) {
            string chs = src.Substring(i, 1);
            if (chs != " ") { id = id + chs; }
            i = i + 1;
        }
        return "On" + id + ev;
    }

    /// Properties tab for the selected component (no events — those live on the
    /// Events tab). Returns the y after the last row so the body can scroll.
    int RenderFieldProps(App app, Canvas c, Theme t, FormField f, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        iy = LabeledInput(app, c, t, Designer.T("Label", "标签"), labelInput, ix, iy, iw);
        f.label = labelSig.Get();
        iy = LabeledInput(app, c, t, Designer.T("Name", "名称"), nameInput, ix, iy, iw);
        f.fname = nameSig.Get();
        f.name = f.fname;
        iy = LabeledInput(app, c, t, Designer.T("Placeholder", "占位文本"), phInput, ix, iy, iw);
        f.placeholder = phSig.Get();
        string bindLbl = Designer.T("Bind path", "绑定路径");
        if (f.ftype == 23 || f.ftype == 41) { bindLbl = Designer.T("Data source", "数据源"); }
        iy = LabeledInput(app, c, t, bindLbl, bindInput, ix, iy, iw);
        f.bindPath = bindSig.Get();
        // Two-way binding picker: variables scanned from the paired code file.
        if (bindVars.Count > 0) {
            string pickLbl = Designer.T("Pick from code ▾", "从代码选择 ▾");
            if (bindPickOpen) { pickLbl = Designer.T("Pick from code ▴", "从代码选择 ▴"); }
            int pkId = SmallBtn(app, pickLbl, 0, ix + app.Scale(84), iy, iw - app.Scale(84));
            if (Button.WasClicked(app, pkId)) {
                bindPickOpen = !bindPickOpen;
                app.RequestRedraw();
            }
            iy = iy + app.Scale(34);
            if (bindPickOpen) {
                int bvi = 0;
                while (bvi < bindVars.Count) {
                    int bvType = 0;
                    if (bindVars[bvi] == f.bindPath) { bvType = 1; }
                    int bvId = SmallBtn(app, bindVars[bvi], bvType,
                        ix + app.Scale(84), iy, iw - app.Scale(84));
                    if (Button.WasClicked(app, bvId)) {
                        f.bindPath = bindVars[bvi];
                        bindSig.Set(f.bindPath);
                        bindInput.SetText(f.bindPath);
                        bindPickOpen = false;
                        msg = Designer.T("bound to ", "已绑定 ") + f.bindPath;
                        app.RequestRedraw();
                    }
                    iy = iy + app.Scale(32);
                    bvi = bvi + 1;
                }
            }
        }
        iy = LabeledInput(app, c, t, Designer.T("Bind prop", "绑定属性"), bindPropInput, ix, iy, iw);
        f.bindProp = bindPropSig.Get();
        if (f.ftype == 100) {
            iy = LabeledInput(app, c, t, Designer.T("Component", "组件"), customInput, ix, iy, iw);
            f.customKind = customSig.Get();
        }

        f.required = ToggleRow(app, c, t, Designer.T("Required", "必填"), f.required, ix, iy, iw);
        iy = iy + app.Scale(34);

        // Field width on the 24-column grid: quick presets plus an exact span.
        List<string> spanOpts = new List<string>();
        spanOpts.Add("1/1"); spanOpts.Add("1/2"); spanOpts.Add("1/3"); spanOpts.Add("1/4");
        int spanSel = 0;
        if (f.span == 12) { spanSel = 1; }
        else if (f.span == 8) { spanSel = 2; }
        else if (f.span == 6) { spanSel = 3; }
        int newSel = SegRow(app, c, t, Designer.T("Field width", "字段宽度"), spanOpts, spanSel, ix, iy, iw);
        if (newSel != spanSel) {
            if (newSel == 1) { f.span = 12; }
            else if (newSel == 2) { f.span = 8; }
            else if (newSel == 3) { f.span = 6; }
            else { f.span = 24; }
        }
        iy = iy + app.Scale(54);
        f.span = IntRow(app, c, t, Designer.T("Span / 24", "跨度 / 24"), f.span, 1, ix, iy, iw);
        if (f.span < 1) { f.span = 1; }
        if (f.span > 24) { f.span = 24; }
        iy = iy + app.Scale(36);

        if (f.ftype == 7) {
            f.defOn = ToggleRow(app, c, t, Designer.T("Default on", "默认开启"), f.defOn, ix, iy, iw);
            iy = iy + app.Scale(34);
        }

        if (f.UsesOptions()) {
            bool table = (f.ftype == 23 || f.ftype == 41);
            iy = iy + app.Scale(6);
            if (table) {
                c.DrawText(ix, iy, Designer.T("COLUMNS (title · field)", "列（标题 · 字段）"), t.textTertiary, fs);
            } else {
                c.DrawText(ix, iy, Designer.T("OPTIONS", "选项"), t.textTertiary, fs);
            }
            iy = iy + app.Scale(20);
            int oi = 0;
            while (oi < f.OptionCount()) {
                string disp = f.OptionAt(oi);
                if (table) {
                    disp = Designer.ColTitle(disp);
                    string cfd = Designer.ColField(f.OptionAt(oi));
                    if (cfd != "") { disp = disp + "  ·  " + cfd; }
                }
                c.DrawText(ix, iy + app.Scale(7),
                    Convert.ToString(oi + 1) + ".  " + disp, t.textSecondary, fs);
                int rmId = SmallIconBtn(app, "close", 5, ix + iw - app.Scale(28), iy, app.Scale(28));
                if (Button.WasClicked(app, rmId)) {
                    RemoveOptionFixup(f, oi);
                }
                iy = iy + app.Scale(32);
                oi = oi + 1;
            }
            if (table) {
                // Two-part column editor: display title + data field key.
                int half = (iw - app.Scale(54) - app.Scale(6)) / 2;
                optInput.Render(app, ix, iy, half, app.Scale(28));
                optFieldInput.Render(app, ix + half + app.Scale(6), iy, half, app.Scale(28));
                int addId = SmallBtn(app, Designer.T("Add", "添加"), 1, ix + iw - app.Scale(48), iy, app.Scale(48));
                if (Button.WasClicked(app, addId) && optSig.Get() != "") {
                    string col = optSig.Get();
                    if (optFieldSig.Get() != "") { col = col + ":" + optFieldSig.Get(); }
                    f.AddOption(col);
                    optSig.Set("");
                    optFieldSig.Set("");
                }
            } else {
                optInput.Render(app, ix, iy, iw - app.Scale(54), app.Scale(28));
                int addId = SmallBtn(app, Designer.T("Add", "添加"), 1, ix + iw - app.Scale(48), iy, app.Scale(48));
                if (Button.WasClicked(app, addId) && optSig.Get() != "") {
                    f.AddOption(optSig.Get());
                    optSig.Set("");
                }
            }
            iy = iy + app.Scale(38);
        }
        return iy + app.Scale(4);
    }

    /// Removes option `oi` from `f` and repairs dependent state so the UI never
    /// indexes past the shrunken list (the old direct RemoveOptionAt could
    /// leave a Tabs container's active tab / child tab out of range).
    void RemoveOptionFixup(FormField f, int oi) {
        f.RemoveOptionAt(oi);
        if (f.ftype == 36) {
            int ki = 0;
            while (ki < f.kids.Count) {
                if (f.kids[ki].childTab == oi) { f.kids[ki].childTab = 0; }
                else if (f.kids[ki].childTab > oi) { f.kids[ki].childTab = f.kids[ki].childTab - 1; }
                ki = ki + 1;
            }
        }
        if (f.uiState.Get() >= f.OptionCount() || f.uiState.Get() < 0) { f.uiState.Set(0); }
    }

    /// Display title of a table column option ("Title:field" convention).
    static string ColTitle(string opt) {
        int p = Designer.IndexOfColon(opt);
        if (p < 0) { return opt; }
        return opt.Substring(0, p);
    }

    /// Data field key of a table column option ("" when none was declared).
    static string ColField(string opt) {
        int p = Designer.IndexOfColon(opt);
        if (p < 0) { return ""; }
        return opt.Substring(p + 1, opt.Length - p - 1);
    }

    static int IndexOfColon(string s) {
        int i = 0;
        while (i < s.Length) {
            if (s.Substring(i, 1) == ":") { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// Properties tab for the root Window: window chrome (title/size/flags) plus
    /// the shared layout defaults applied to labelled input rows placed inside.
    int RenderWindowProps(App app, Canvas c, Theme t, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy, Designer.T("WINDOW", "窗口"), t.textTertiary, fs);
        iy = iy + app.Scale(20);

        iy = LabeledInput(app, c, t, Designer.T("Title", "标题"), winTitleInput, ix, iy, iw);

        // Save the whole designed window as a reusable project component; the
        // host IDE persists it and it then shows up under "My Components".
        int scId = SmallBtn(app, Designer.T("Save as component", "保存为组件"), 1, ix, iy, iw);
        if (Button.WasClicked(app, scId)) {
            saveCompRequested = true;
            msg = Designer.T("saving as component…", "正在保存为组件…");
        }
        iy = iy + app.Scale(36);

        winW = IntRow(app, c, t, Designer.T("Width", "宽度"), winW, 20, ix, iy, iw);
        iy = iy + app.Scale(36);
        winH = IntRow(app, c, t, Designer.T("Height", "高度"), winH, 20, ix, iy, iw);
        iy = iy + app.Scale(36);

        winResizable = ToggleRow(app, c, t, Designer.T("Resizable", "可调整大小"), winResizable, ix, iy, iw);
        iy = iy + app.Scale(34);
        winTool = ToggleRow(app, c, t, Designer.T("Tool window", "工具窗口"), winTool, ix, iy, iw);
        iy = iy + app.Scale(34);
        winCenter = ToggleRow(app, c, t, Designer.T("Center on show", "显示时居中"), winCenter, ix, iy, iw);
        iy = iy + app.Scale(34);
        winGlass = ToggleRow(app, c, t, Designer.T("Frosted glass", "毛玻璃效果"), winGlass, ix, iy, iw);
        iy = iy + app.Scale(40);

        c.DrawText(ix, iy, Designer.T("LAYOUT", "布局"), t.textTertiary, fs);
        iy = iy + app.Scale(20);
        List<string> posOpts = new List<string>();
        posOpts.Add(Designer.T("Left", "左")); posOpts.Add(Designer.T("Right", "右")); posOpts.Add(Designer.T("Top", "上"));
        labelPos = SegRow(app, c, t, Designer.T("Label position", "标签位置"), posOpts, labelPos, ix, iy, iw);
        iy = iy + app.Scale(54);
        List<string> szOpts = new List<string>();
        szOpts.Add(Designer.T("Large", "大")); szOpts.Add(Designer.T("Default", "默认")); szOpts.Add(Designer.T("Small", "小"));
        formSize = SegRow(app, c, t, Designer.T("Control size", "控件大小"), szOpts, formSize, ix, iy, iw);
        iy = iy + app.Scale(54);
        labelWidth = IntRow(app, c, t, Designer.T("Label width", "标签宽度"), labelWidth, 8, ix, iy, iw);
        iy = iy + app.Scale(36);
        bool showStar = !hideStar;
        showStar = ToggleRow(app, c, t, Designer.T("Required star", "必填星号"), showStar, ix, iy, iw);
        hideStar = !showStar;
        iy = iy + app.Scale(40);
        return iy;
    }

    /// Events tab: every event of the current target (window root or selected
    /// component), grouped by category (Pointer / Keyboard / Focus / Drag /
    /// Lifecycle / Value) and scrollable, with an inline handler editor.
    int RenderEventsTab(App app, Canvas c, Theme t, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        bool root = (sel == null);
        List<string> evs = Designer.WindowEventNames();
        if (!root) { evs = sel.Events(); }

        // Re-seed the shared handler editor whenever the target changes.
        bool tgtChanged = (root != evtRootPrev) || (!root && sel != evtSelPrev);
        evtRootPrev = root;
        evtSelPrev = sel;
        if (root) {
            if (tgtChanged || !evs.Contains(winEvtEditing)) {
                if (evs.Count > 0) { winEvtEditing = evs[0]; } else { winEvtEditing = ""; }
                evtSig.Set(WinGetHandler(winEvtEditing));
            }
        } else {
            if (tgtChanged || !evs.Contains(evtEditing)) {
                if (evs.Count > 0) { evtEditing = evs[0]; } else { evtEditing = ""; }
                evtSig.Set(sel.GetHandler(evtEditing));
            }
        }

        int rowH = app.Scale(26);
        List<string> groups = Designer.EventGroups();
        int gi = 0;
        while (gi < groups.Count) {
            string grp = groups[gi];
            int cnt = 0;
            int ck = 0;
            while (ck < evs.Count) {
                if (Designer.EventCategory(evs[ck]) == grp) { cnt = cnt + 1; }
                ck = ck + 1;
            }
            if (cnt > 0) {
                c.DrawText(ix, iy, Designer.GroupLabel(grp) + "  (" + Convert.ToString(cnt) + ")", t.textSecondary, fs);
                iy = iy + app.Scale(20);
                int ei = 0;
                while (ei < evs.Count) {
                    string ev = evs[ei];
                    if (Designer.EventCategory(ev) == grp) {
                        string cur;
                        if (root) { cur = winEvtEditing; } else { cur = evtEditing; }
                        if (ev == cur) {
                            c.FillRoundRect(ix - app.Scale(4), iy - app.Scale(2),
                                iw + app.Scale(8), rowH, app.Scale(4), t.bgActive);
                        }
                        c.DrawText(ix, iy + app.Scale(5), ev, t.textPrimary, fs);
                        string h;
                        if (root) { h = WinGetHandler(ev); } else { h = sel.GetHandler(ev); }
                        string hv = h;
                        int hColor = t.textTertiary;
                        if (hv == "") { hv = "—"; } else { hColor = t.success; }
                        c.DrawText(ix + app.Scale(92), iy + app.Scale(5),
                            Ellipsis.Fit(hv, iw - app.Scale(180), fs), hColor, fs);
                        int edId = SmallBtn(app, Designer.T("edit", "编辑"), 0, ix + iw - app.Scale(84), iy, app.Scale(40));
                        if (Button.WasClicked(app, edId)) {
                            if (root) { winEvtEditing = ev; evtSig.Set(WinGetHandler(ev)); }
                            else { evtEditing = ev; evtSig.Set(sel.GetHandler(ev)); }
                        }
                        int crId = SmallBtn(app, Designer.T("new", "新建"), 1, ix + iw - app.Scale(40), iy, app.Scale(40));
                        if (Button.WasClicked(app, crId)) {
                            if (root) {
                                winEvtEditing = ev;
                                string sug = "OnWindow" + ev;
                                WinSetHandler(ev, sug);
                                evtSig.Set(sug);
                            } else {
                                evtEditing = ev;
                                string sug = Designer.SuggestHandler(sel, ev);
                                sel.SetHandler(ev, sug);
                                evtSig.Set(sug);
                            }
                        }
                        iy = iy + rowH + app.Scale(4);
                    }
                    ei = ei + 1;
                }
                iy = iy + app.Scale(8);
            }
            gi = gi + 1;
        }

        string editEv;
        if (root) { editEv = winEvtEditing; } else { editEv = evtEditing; }
        iy = iy + app.Scale(2);
        c.DrawText(ix, iy, "on " + editEv + " +=", t.textTertiary, fs);
        iy = iy + app.Scale(18);
        evtInput.Render(app, ix, iy, iw, app.Scale(28));
        if (editEv != "") {
            if (root) { WinSetHandler(editEv, evtSig.Get()); }
            else { sel.SetHandler(editEv, evtSig.Get()); }
        }
        return iy + app.Scale(38);
    }

    /// The root Window's designable events (lifecycle / size / focus / keyboard).
    static List<string> WindowEventNames() {
        List<string> e = new List<string>();
        e.Add("Load"); e.Add("Show"); e.Add("Hide"); e.Add("Closing"); e.Add("Close");
        e.Add("Resize"); e.Add("Move"); e.Add("Minimize"); e.Add("Maximize"); e.Add("Restore");
        e.Add("Activate"); e.Add("Deactivate");
        e.Add("KeyDown"); e.Add("KeyUp");
        return e;
    }

    string WinGetHandler(string ev) {
        int i = 0;
        while (i < winEvents.Count) {
            if (winEvents[i].key == ev) { return winEvents[i].val; }
            i = i + 1;
        }
        return "";
    }

    void WinSetHandler(string ev, string h) {
        int i = 0;
        while (i < winEvents.Count) {
            if (winEvents[i].key == ev) { winEvents[i].val = h; return; }
            i = i + 1;
        }
        winEvents.Add(new EventBinding(ev, h));
    }

    /// Logical category for an event name, so the Events tab can group a long
    /// event list under readable headings instead of overflowing.
    static string EventCategory(string ev) {
        if (ev == "Click" || ev == "DoubleClick" || ev == "RightClick"
            || ev == "MouseDown" || ev == "MouseUp" || ev == "Enter"
            || ev == "Leave" || ev == "Move" || ev == "Wheel" || ev == "Tap"
            || ev == "LongPress" || ev == "Swipe" || ev == "Hover") { return "Pointer"; }
        if (ev == "KeyDown" || ev == "KeyUp" || ev == "KeyPress") { return "Keyboard"; }
        if (ev == "Focus" || ev == "Blur" || ev == "Activate"
            || ev == "Deactivate") { return "Focus"; }
        if (ev == "DragStart" || ev == "Drag" || ev == "DragEnd" || ev == "Drop"
            || ev == "DragEnter" || ev == "DragLeave") { return "Drag & Drop"; }
        if (ev == "Resize" || ev == "Show" || ev == "Hide" || ev == "Open"
            || ev == "Close" || ev == "Closing" || ev == "Load"
            || ev == "Minimize" || ev == "Maximize" || ev == "Restore") { return "Lifecycle"; }
        return "Value & Data";
    }

    /// Display label for an event category heading. Category KEYS stay
    /// English (they are matched by string equality); only the heading text
    /// shown in the Events tab is translated.
    static string GroupLabel(string grp) {
        if (grp == "Pointer") { return Designer.T("Pointer", "指针"); }
        if (grp == "Keyboard") { return Designer.T("Keyboard", "键盘"); }
        if (grp == "Focus") { return Designer.T("Focus", "焦点"); }
        if (grp == "Drag & Drop") { return Designer.T("Drag & Drop", "拖放"); }
        if (grp == "Lifecycle") { return Designer.T("Lifecycle", "生命周期"); }
        if (grp == "Value & Data") { return Designer.T("Value & Data", "值与数据"); }
        return grp;
    }

    /// Category display order for the Events tab.
    static List<string> EventGroups() {
        List<string> g = new List<string>();
        g.Add("Pointer"); g.Add("Keyboard"); g.Add("Focus");
        g.Add("Drag & Drop"); g.Add("Lifecycle"); g.Add("Value & Data");
        return g;
    }

    /// Case-sensitive substring test used by the palette filter (which matches
    /// against the lowercase type key, so a lowercase query is enough).
    static bool Contains(string hay, string needle) {
        if (needle.Length == 0) { return true; }
        if (hay.Length < needle.Length) { return false; }
        int i = 0;
        while (i + needle.Length <= hay.Length) {
            if (hay.Substring(i, needle.Length) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    // --- Inspector row helpers ----------------------------------------------

    int LabeledInput(App app, Canvas c, Theme t, string label, Input inp, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy + app.Scale(7), label, t.textSecondary, fs);
        int lw = app.Scale(84);
        inp.Render(app, ix + lw, iy, iw - lw, app.Scale(28));
        return iy + app.Scale(36);
    }

    bool ToggleRow(App app, Canvas c, Theme t, string label, bool val, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy + app.Scale(7), label, t.textSecondary, fs);
        string disp = Designer.T("Off", "关");
        int ty = 0;
        if (val) { disp = Designer.T("On", "开"); ty = 3; }
        int id = SmallBtn(app, disp, ty, ix + iw - app.Scale(54), iy, app.Scale(54));
        bool nv = val;
        if (Button.WasClicked(app, id)) { nv = !val; }
        return nv;
    }

    int IntRow(App app, Canvas c, Theme t, string label, int val, int step, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        int bw = app.Scale(28);
        int valW = app.Scale(40);
        c.DrawText(ix, iy + app.Scale(7), label, t.textSecondary, fs);
        int pX = ix + iw - bw;
        int vX = pX - valW;
        int mX = vX - bw;
        int mId = SmallBtn(app, "-", 0, mX, iy, bw);
        c.DrawTextCentered(vX, iy, valW, app.Scale(28), Convert.ToString(val), t.textPrimary, fs);
        int pId = SmallIconBtn(app, "plus", 0, pX, iy, bw);
        int nv = val;
        if (Button.WasClicked(app, mId)) { nv = val - step; }
        if (Button.WasClicked(app, pId)) { nv = val + step; }
        if (nv < 0) { nv = 0; }
        return nv;
    }

    int SegRow(App app, Canvas c, Theme t, string title, List<string> opts, int cur, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy, title, t.textSecondary, fs);
        int segY = iy + app.Scale(18);
        int n = opts.Count;
        int gapx = app.Scale(4);
        int segW = (iw - (n - 1) * gapx) / n;
        int gx = ix;
        int res = cur;
        int i = 0;
        while (i < n) {
            int ty = 0;
            if (i == cur) { ty = 1; }
            int id = SmallBtn(app, opts[i], ty, gx, segY, segW);
            if (Button.WasClicked(app, id)) { res = i; }
            gx = gx + segW + gapx;
            i = i + 1;
        }
        return res;
    }

    // --- Status bar ----------------------------------------------------------

    void RenderStatus(App app, Canvas c, Theme t, int x, int y, int w) {
        int fs = t.fontSizeSmall;
        string s = Convert.ToString(fields.Count) + Designer.T(" fields", " 个组件");
        if (sel != null) {
            s = s + Designer.T("   ·   selected: ", "   ·   已选中：") + FormField.TypeName(sel.ftype) + " '" + sel.fname + "'";
        }
        if (activeContainer != null) {
            s = s + Designer.T("   ·   adding into: ", "   ·   添加到：") + FormField.TypeName(activeContainer.ftype);
            if (activeContainer.ftype == 36) {
                s = s + Designer.T(" tab ", " 标签页 ") + Convert.ToString(activeContainer.uiState.Get() + 1);
            }
        }
        c.DrawText(x, y, s + "     ·     " + msg, t.textTertiary, fs);
    }

    // --- Persistence (JSON) --------------------------------------------------

    /// Serialises the whole form as a human-editable JSON document: the form
    /// config plus an ordered "fields" array. This is the interchange format —
    /// hand-editing the JSON and loading it back reconfigures the form, so the
    /// designer is fully data-driven. Round-trips with LoadJson.
    ///   { name, labelPos, formSize, labelWidth, hideStar, showSubmit,
    ///     showReset, submit, fields:[ { type,label,name,placeholder,
    ///     required,change,options:[...] } ] }
    string SaveJson() {
        string o = "{\n";
        o = o + "  \"name\": \"" + JEsc(formNameSig.Get()) + "\",\n";
        o = o + "  \"labelPos\": " + Convert.ToString(labelPos) + ",\n";
        o = o + "  \"formSize\": " + Convert.ToString(formSize) + ",\n";
        o = o + "  \"labelWidth\": " + Convert.ToString(labelWidth) + ",\n";
        o = o + "  \"hideStar\": " + JB(hideStar) + ",\n";
        o = o + "  \"showSubmit\": " + JB(showSubmit) + ",\n";
        o = o + "  \"showReset\": " + JB(showReset) + ",\n";
        o = o + "  \"submit\": \"" + JEsc(submitSig.Get()) + "\",\n";
        o = o + "  \"fields\": [\n";
        o = o + EmitFields(fields, 2);
        o = o + "  ]\n}";
        return o;
    }

    string Indent(int depth) {
        string s = "";
        int i = 0;
        while (i < depth) { s = s + "  "; i = i + 1; }
        return s;
    }

    /// Serialises a list of fields (recursing into container `kids`).
    string EmitFields(List<FormField> lst, int depth) {
        string pad = Indent(depth);
        string o = "";
        int i = 0;
        while (i < lst.Count) {
            FormField f = lst[i];
            o = o + pad + "{\n";
            o = o + EmitFieldBody(f, depth + 1);
            o = o + pad + "}";
            if (i < lst.Count - 1) { o = o + ","; }
            o = o + "\n";
            i = i + 1;
        }
        return o;
    }

    /// Emits every bound event handler as an `"on<Event>": "name"` line, so
    /// the JSON round-trips all designer event bindings (not just Change).
    string EmitHandlers(FormField f, string p) {
        string o = "";
        List<string> evs = f.Events();
        int i = 0;
        while (i < evs.Count) {
            string h = f.GetHandler(evs[i]);
            if (h != "") {
                o = o + p + "\"on" + evs[i] + "\": \"" + JEsc(h) + "\",\n";
            }
            i = i + 1;
        }
        return o;
    }

    /// Parses an `"on<Event>": "name"` line into the field's handler table.
    /// `type` is emitted before handlers, so cur.Events() already reflects the
    /// correct field type by the time these lines are read.
    void ParseHandlerLine(FormField cur, string ln) {
        List<string> evs = cur.Events();
        int i = 0;
        while (i < evs.Count) {
            if (LineKey(ln, "on" + evs[i])) {
                cur.SetHandler(evs[i], JStr(JAfter(ln)));
                i = evs.Count;
            } else {
                i = i + 1;
            }
        }
    }

    string EmitFieldBody(FormField f, int depth) {
        string p = Indent(depth);
        string o = "";
        o = o + p + "\"type\": " + Convert.ToString(f.ftype) + ",\n";
        if (f.ftype == 100) {
            o = o + p + "\"custom\": \"" + JEsc(f.customKind) + "\",\n";
        }
        o = o + p + "\"label\": \"" + JEsc(f.label) + "\",\n";
        o = o + p + "\"name\": \"" + JEsc(f.fname) + "\",\n";
        o = o + p + "\"placeholder\": \"" + JEsc(f.placeholder) + "\",\n";
        o = o + p + "\"bind\": \"" + JEsc(f.bindPath) + "\",\n";
        o = o + p + "\"bindProp\": \"" + JEsc(f.bindProp) + "\",\n";
        o = o + p + "\"required\": " + JB(f.required) + ",\n";
        o = o + p + "\"span\": " + Convert.ToString(f.span) + ",\n";
        o = o + p + "\"defOn\": " + JB(f.defOn) + ",\n";
        o = o + p + "\"childTab\": " + Convert.ToString(f.childTab) + ",\n";
        o = o + p + "\"activeTab\": " + Convert.ToString(f.uiState.Get()) + ",\n";
        o = o + EmitHandlers(f, p);
        o = o + p + "\"options\": [" + JOpts(f) + "]";
        if (f.IsContainer()) {
            o = o + ",\n" + p + "\"kids\": [\n";
            o = o + EmitFields(f.kids, depth + 1);
            o = o + p + "]\n";
        } else {
            o = o + "\n";
        }
        return o;
    }

    /// Rebuilds the form from a JSON document produced by SaveJson (or hand
    /// written). Tolerant of pretty-printed whitespace: it scans line by line,
    /// keys before "fields" set the form config, then each { ... } block in the
    /// array becomes a field.
    void LoadJson(string s) {
        List<string> lines = Serialize.SplitLines(s);
        fields = new List<FormField>();
        // Stack of open field objects; a new `{` becomes a child of the field
        // on top of the stack (its container), or a top-level field when empty.
        List<FormField> stack = new List<FormField>();
        bool inFields = false;
        int total = 0;
        int i = 0;
        while (i < lines.Count) {
            string ln = Trim(lines[i]);
            if (!inFields) {
                if (LineKey(ln, "fields")) {
                    inFields = true;
                } else if (LineKey(ln, "name")) {
                    formNameSig.Set(JStr(JAfter(ln)));
                } else if (LineKey(ln, "labelPos")) {
                    labelPos = JInt(JAfter(ln));
                } else if (LineKey(ln, "formSize")) {
                    formSize = JInt(JAfter(ln));
                } else if (LineKey(ln, "labelWidth")) {
                    labelWidth = JInt(JAfter(ln));
                } else if (LineKey(ln, "hideStar")) {
                    hideStar = JBool(JAfter(ln));
                } else if (LineKey(ln, "showSubmit")) {
                    showSubmit = JBool(JAfter(ln));
                } else if (LineKey(ln, "showReset")) {
                    showReset = JBool(JAfter(ln));
                } else if (LineKey(ln, "submit")) {
                    submitSig.Set(JStr(JAfter(ln)));
                }
            } else {
                if (StartsWith(ln, "{")) { total = total + 1; }
                i = ParseFieldLine(lines, i, ln, fields, stack);
            }
            i = i + 1;
        }
        seq = total;
        sel = null;
        selPrev = null;
        activeContainer = null;
    }

    /// Handles one line inside the "fields" array (shared by LoadJson and
    /// ParseComponentFields); returns the possibly-advanced line index (the
    /// "options" array can span several lines).
    int ParseFieldLine(List<string> lines, int i, string ln,
            List<FormField> topList, List<FormField> stack) {
        if (StartsWith(ln, "{")) {
            FormField nf = new FormField(0);
            nf.SetOptionsFrom("");
            if (stack.Count > 0) {
                stack[stack.Count - 1].kids.Add(nf);
            } else {
                topList.Add(nf);
            }
            stack.Add(nf);
        } else if (StartsWith(ln, "}")) {
            if (stack.Count > 0) { stack.RemoveAt(stack.Count - 1); }
        } else if (stack.Count > 0) {
            FormField cur = stack[stack.Count - 1];
            if (LineKey(ln, "type")) {
                cur.ftype = JInt(JAfter(ln));
            } else if (LineKey(ln, "custom")) {
                cur.customKind = JStr(JAfter(ln));
            } else if (LineKey(ln, "label")) {
                cur.label = JStr(JAfter(ln));
            } else if (LineKey(ln, "name")) {
                cur.fname = JStr(JAfter(ln));
                cur.name = cur.fname;
            } else if (LineKey(ln, "placeholder")) {
                cur.placeholder = JStr(JAfter(ln));
            } else if (LineKey(ln, "bind")) {
                cur.bindPath = JStr(JAfter(ln));
            } else if (LineKey(ln, "bindProp")) {
                cur.bindProp = JStr(JAfter(ln));
            } else if (LineKey(ln, "required")) {
                cur.required = JBool(JAfter(ln));
            } else if (LineKey(ln, "span")) {
                cur.span = JInt(JAfter(ln));
            } else if (LineKey(ln, "defOn")) {
                cur.defOn = JBool(JAfter(ln));
            } else if (LineKey(ln, "childTab")) {
                cur.childTab = JInt(JAfter(ln));
            } else if (LineKey(ln, "activeTab")) {
                cur.uiState.Set(JInt(JAfter(ln)));
            } else if (LineKey(ln, "change")) {
                cur.SetHandler("Change", JStr(JAfter(ln)));
            } else if (LineKey(ln, "options")) {
                string rawOptions = JAfter(ln);
                while (!JsonArrayClosed(rawOptions) && i + 1 < lines.Count) {
                    i = i + 1;
                    rawOptions = rawOptions + "\n" + Trim(lines[i]);
                }
                ParseOptions(cur, rawOptions);
            } else {
                ParseHandlerLine(cur, ln);
            }
        }
        return i;
    }

    /// Parses just the "fields" array of a design JSON into a fresh list,
    /// used to instantiate saved user components without touching the form.
    List<FormField> ParseComponentFields(string s) {
        List<string> lines = Serialize.SplitLines(s);
        List<FormField> outp = new List<FormField>();
        List<FormField> stack = new List<FormField>();
        bool inFields = false;
        int i = 0;
        while (i < lines.Count) {
            string ln = Trim(lines[i]);
            if (!inFields) {
                if (LineKey(ln, "fields")) { inFields = true; }
            } else {
                i = ParseFieldLine(lines, i, ln, outp, stack);
            }
            i = i + 1;
        }
        return outp;
    }

    // --- JSON helpers --------------------------------------------------------

    string JB(bool b) {
        if (b) { return "true"; }
        return "false";
    }

    string JEsc(string s) {
        string r = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\\") { r = r + "\\\\"; }
            else if (ch == "\"") { r = r + "\\\""; }
            else if (ch == "\n") { r = r + "\\n"; }
            else if (ch == "\t") { r = r + "\\t"; }
            else { r = r + ch; }
            i = i + 1;
        }
        return r;
    }

    string JUn(string ch) {
        if (ch == "n") { return "\n"; }
        if (ch == "t") { return "\t"; }
        return ch;
    }

    string JOpts(FormField f) {
        string r = "";
        int o = 0;
        while (o < f.OptionCount()) {
            if (o > 0) { r = r + ", "; }
            r = r + "\"" + JEsc(f.OptionAt(o)) + "\"";
            o = o + 1;
        }
        return r;
    }

    /// Reads quoted strings out of a JSON array literal like ["a", "b"].
    bool JsonArrayClosed(string raw) {
        bool quoted = false;
        bool escaped = false;
        int i = 0;
        while (i < raw.Length) {
            string ch = raw.Substring(i, 1);
            if (escaped) {
                escaped = false;
            } else if (ch == "\\") {
                escaped = true;
            } else if (ch == "\"") {
                quoted = !quoted;
            } else if (ch == "]" && !quoted) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    void ParseOptions(FormField f, string raw) {
        f.SetOptionsFrom("");
        int i = 0;
        while (i < raw.Length) {
            if (raw.Substring(i, 1) == "\"") {
                string acc = "";
                int j = i + 1;
                bool done = false;
                while (j < raw.Length && !done) {
                    string ch = raw.Substring(j, 1);
                    if (ch == "\\" && j + 1 < raw.Length) {
                        acc = acc + JUn(raw.Substring(j + 1, 1));
                        j = j + 2;
                    } else if (ch == "\"") {
                        done = true;
                    } else {
                        acc = acc + ch;
                        j = j + 1;
                    }
                }
                f.AddOption(acc);
                i = j + 1;
            } else {
                i = i + 1;
            }
        }
    }

    // True when the trimmed line's key (the token in the leading "...") equals k.
    bool LineKey(string line, string k) {
        return StartsWith(line, "\"" + k + "\"");
    }

    bool StartsWith(string s, string p) {
        if (s.Length < p.Length) { return false; }
        return s.Substring(0, p.Length) == p;
    }

    // Everything after the first ':' on a line (the raw value, still with any
    // trailing comma and surrounding spaces).
    string JAfter(string line) {
        int i = 0;
        while (i < line.Length) {
            if (line.Substring(i, 1) == ":") {
                return Trim(line.Substring(i + 1, line.Length - i - 1));
            }
            i = i + 1;
        }
        return "";
    }

    string Trim(string s) {
        int a = 0;
        int b = s.Length;
        while (a < b) {
            string ch = s.Substring(a, 1);
            if (ch == " " || ch == "\t" || ch == "\r") { a = a + 1; }
            else { break; }
        }
        while (b > a) {
            string ch = s.Substring(b - 1, 1);
            if (ch == " " || ch == "\t" || ch == "\r") { b = b - 1; }
            else { break; }
        }
        return s.Substring(a, b - a);
    }

    string StripComma(string s) {
        string t = Trim(s);
        if (t.Length > 0 && t.Substring(t.Length - 1, 1) == ",") {
            return Trim(t.Substring(0, t.Length - 1));
        }
        return t;
    }

    // Decodes a JSON scalar value: a quoted string (unescaped) or a bare token.
    string JStr(string raw) {
        string t = Trim(raw);
        if (t.Length == 0) { return ""; }
        if (t.Substring(0, 1) == "\"") {
            string acc = "";
            int j = 1;
            bool done = false;
            while (j < t.Length && !done) {
                string ch = t.Substring(j, 1);
                if (ch == "\\" && j + 1 < t.Length) {
                    acc = acc + JUn(t.Substring(j + 1, 1));
                    j = j + 2;
                } else if (ch == "\"") {
                    done = true;
                } else {
                    acc = acc + ch;
                    j = j + 1;
                }
            }
            return acc;
        }
        return StripComma(t);
    }

    int JInt(string raw) {
        string t = StripComma(raw);
        if (t.Length == 0) { return 0; }
        return Convert.ToInt32(t);
    }

    bool JBool(string raw) {
        return StripComma(raw) == "true";
    }
}
