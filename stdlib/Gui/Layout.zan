using System;

namespace Gui;

/// CSS Flexbox layout engine (pure Zan).
/// Supports: direction, justify, align, gap, wrap, grow/shrink, padding/margin.

class FlexStyle {
    int direction;
    int justify;
    int alignItems;
    int flexGrow;
    int flexShrink;
    int width;
    int height;
    int minWidth;
    int minHeight;
    int maxWidth;
    int maxHeight;
    int padTop;
    int padRight;
    int padBottom;
    int padLeft;
    int marginTop;
    int marginRight;
    int marginBottom;
    int marginLeft;
    int gap;

    static FlexStyle Default() {
        FlexStyle s = new FlexStyle();
        s.direction = 0;
        s.justify = 0;
        s.alignItems = 3;
        s.flexGrow = 0;
        s.flexShrink = 1000;
        s.width = -1;
        s.height = -1;
        s.minWidth = 0;
        s.minHeight = 0;
        s.maxWidth = -1;
        s.maxHeight = -1;
        s.padTop = 0;
        s.padRight = 0;
        s.padBottom = 0;
        s.padLeft = 0;
        s.marginTop = 0;
        s.marginRight = 0;
        s.marginBottom = 0;
        s.marginLeft = 0;
        s.gap = 0;
        return s;
    }

    static FlexStyle Row() {
        FlexStyle s = FlexStyle.Default();
        s.direction = 0;
        return s;
    }

    static FlexStyle Column() {
        FlexStyle s = FlexStyle.Default();
        s.direction = 1;
        return s;
    }

    FlexStyle SetPadding(int top, int right, int bottom, int left) {
        padTop = top;
        padRight = right;
        padBottom = bottom;
        padLeft = left;
        return this;
    }

    FlexStyle SetPaddingAll(int p) {
        padTop = p;
        padRight = p;
        padBottom = p;
        padLeft = p;
        return this;
    }

    FlexStyle SetGap(int g) {
        gap = g;
        return this;
    }

    FlexStyle SetSize(int w, int h) {
        width = w;
        height = h;
        return this;
    }

    FlexStyle SetGrow(int g) {
        flexGrow = g;
        return this;
    }

    FlexStyle SetJustify(int j) {
        justify = j;
        return this;
    }

    FlexStyle SetAlign(int a) {
        alignItems = a;
        return this;
    }
}

class FlexNode {
    FlexStyle style;
    List<FlexNode> children;
    int resultX;
    int resultY;
    int resultW;
    int resultH;
    int contentW;
    int contentH;

    static FlexNode Create(FlexStyle s) {
        FlexNode n = new FlexNode();
        n.style = s;
        n.children = new List<FlexNode>();
        n.resultX = 0;
        n.resultY = 0;
        n.resultW = 0;
        n.resultH = 0;
        n.contentW = 0;
        n.contentH = 0;
        return n;
    }

    FlexNode AddChild(FlexNode child) {
        children.Add(child);
        return this;
    }

    void Compute(int containerW, int containerH) {
        int w = style.width;
        int h = style.height;
        if (w < 0) { w = containerW; }
        if (h < 0) { h = containerH; }
        if (style.maxWidth >= 0 && w > style.maxWidth) { w = style.maxWidth; }
        if (style.maxHeight >= 0 && h > style.maxHeight) { h = style.maxHeight; }
        if (w < style.minWidth) { w = style.minWidth; }
        if (h < style.minHeight) { h = style.minHeight; }

        resultW = w;
        resultH = h;

        int innerW = w - style.padLeft - style.padRight;
        int innerH = h - style.padTop - style.padBottom;
        if (innerW < 0) { innerW = 0; }
        if (innerH < 0) { innerH = 0; }

        int count = children.Count;
        if (count == 0) { return; }

        bool isRow = style.direction == 0;
        int totalFixed = 0;
        int totalGrow = 0;
        int gaps = 0;
        if (count > 1) { gaps = (count - 1) * style.gap; }

        int i = 0;
        while (i < count) {
            FlexNode child = children[i];
            int cw = child.style.width;
            int ch = child.style.height;
            if (cw < 0 && !isRow) { cw = innerW; }
            if (ch < 0 && isRow) { ch = innerH; }
            if (cw < 0) { cw = 0; }
            if (ch < 0) { ch = 0; }

            child.Compute(cw, ch);

            if (isRow) {
                totalFixed = totalFixed + child.resultW + child.style.marginLeft + child.style.marginRight;
                totalGrow = totalGrow + child.style.flexGrow;
            } else {
                totalFixed = totalFixed + child.resultH + child.style.marginTop + child.style.marginBottom;
                totalGrow = totalGrow + child.style.flexGrow;
            }
            i = i + 1;
        }

        int mainSize = innerW;
        if (!isRow) { mainSize = innerH; }
        int freeSpace = mainSize - totalFixed - gaps;
        if (freeSpace < 0) { freeSpace = 0; }

        if (totalGrow > 0) {
            i = 0;
            while (i < count) {
                FlexNode child = children[i];
                if (child.style.flexGrow > 0) {
                    int extra = freeSpace * child.style.flexGrow / totalGrow;
                    if (isRow) {
                        child.resultW = child.resultW + extra;
                    } else {
                        child.resultH = child.resultH + extra;
                    }
                }
                i = i + 1;
            }
            freeSpace = 0;
        }

        int offset = 0;
        int spaceBefore = 0;
        int spaceBetween = style.gap;

        if (style.justify == 1) {
            offset = freeSpace / 2;
        } else if (style.justify == 2) {
            offset = freeSpace;
        } else if (style.justify == 3 && count > 1) {
            spaceBetween = freeSpace / (count - 1) + style.gap;
        } else if (style.justify == 4) {
            int totalSpaces = count * 2;
            if (totalSpaces > 0) {
                spaceBefore = freeSpace / totalSpaces;
                spaceBetween = spaceBefore * 2 + style.gap;
                offset = spaceBefore;
            }
        } else if (style.justify == 5 && count > 0) {
            int totalSpaces = count + 1;
            spaceBefore = freeSpace / totalSpaces;
            spaceBetween = spaceBefore + style.gap;
            offset = spaceBefore;
        }

        int pos = offset;
        i = 0;
        while (i < count) {
            FlexNode child = children[i];
            int mx = style.padLeft;
            int my = style.padTop;

            if (isRow) {
                pos = pos + child.style.marginLeft;
                child.resultX = mx + pos;

                int crossSize = innerH - child.style.marginTop - child.style.marginBottom;
                if (style.alignItems == 0) {
                    child.resultY = my + child.style.marginTop;
                } else if (style.alignItems == 1) {
                    child.resultY = my + child.style.marginTop + (crossSize - child.resultH) / 2;
                } else if (style.alignItems == 2) {
                    child.resultY = my + child.style.marginTop + crossSize - child.resultH;
                } else {
                    child.resultY = my + child.style.marginTop;
                    child.resultH = crossSize;
                }

                pos = pos + child.resultW + child.style.marginRight;
            } else {
                pos = pos + child.style.marginTop;
                child.resultY = my + pos;

                int crossSize = innerW - child.style.marginLeft - child.style.marginRight;
                if (style.alignItems == 0) {
                    child.resultX = mx + child.style.marginLeft;
                } else if (style.alignItems == 1) {
                    child.resultX = mx + child.style.marginLeft + (crossSize - child.resultW) / 2;
                } else if (style.alignItems == 2) {
                    child.resultX = mx + child.style.marginLeft + crossSize - child.resultW;
                } else {
                    child.resultX = mx + child.style.marginLeft;
                    child.resultW = crossSize;
                }

                pos = pos + child.resultH + child.style.marginBottom;
            }

            if (i < count - 1) { pos = pos + spaceBetween; }
            i = i + 1;
        }
    }
}
