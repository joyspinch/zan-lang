        if (ft == 44) { return Designer.T("Truncated text with ellipsis", "带省略号的截断文本"); }
        if (ft == 45) { return Designer.T("Titled content panel", "带标题内容面板"); }
        if (ft == 46) { return Designer.T("Vertical scrollbar", "垂直滚动条"); }
        if (ft == 47) { return Designer.T("Loading indicator", "加载指示器"); }
        if (ft == 48) { return Designer.T("Dropdown trigger", "下拉触发器"); }
        if (ft == 49) { return Designer.T("Floating action button", "悬浮操作按钮"); }
        if (ft == 50) { return Designer.T("Anchored popover", "锚定气泡卡片"); }
        if (ft == 51) { return Designer.T("Inline confirm popover", "内联确认气泡"); }
        if (ft == 52) { return Designer.T("Notification toast", "通知提示"); }
        if (ft == 53) { return Designer.T("Command ribbon", "命令功能区"); }
        if (ft == 54) { return Designer.T("Standalone icon", "独立图标"); }
        if (ft == 55) { return Designer.T("Right-click context menu (component tray)", "右键上下文菜单（组件托盘）"); }
        if (ft == 56) { return Designer.T("Popup layer / overlay (component tray)", "弹出层 / 遮罩（组件托盘）"); }
        if (ft == 57) { return Designer.T("Interval timer (component tray)", "定时器（组件托盘）"); }
        return Designer.T("Form field", "表单字段");
    }

    /// Maps a field type to a Segoe MDL2 icon name for the palette.
    string FieldIcon(int ft) {
        if (ft == 0) { return "edit"; }
        if (ft == 1) { return "menu"; }
        if (ft == 2) { return "lock"; }
        if (ft == 3) { return "sort"; }
        if (ft == 4) { return "like"; }
        if (ft == 5) { return "check"; }
        if (ft == 6) { return "chevron-down"; }
        if (ft == 7) { return "settings"; }
        if (ft == 8) { return "star"; }
        if (ft == 9) { return "more"; }
        if (ft == 10) { return "calendar"; }
        if (ft == 11) { return "clock"; }
        if (ft == 12) { return "upload"; }
        if (ft == 13) { return "color"; }
        if (ft == 14) { return "font"; }
        if (ft == 15) { return "font"; }
        if (ft == 16) { return "align-left"; }
        if (ft == 17) { return "minus"; }
        if (ft == 18) { return "grid"; }
        if (ft == 19) { return "pin"; }
        if (ft == 20) { return "bell"; }
        if (ft == 21) { return "user"; }
        if (ft == 22) { return "sort"; }
        if (ft == 23) { return "table"; }
        if (ft == 24) { return "more"; }
        if (ft == 25) { return "folder"; }
        if (ft == 26) { return "chevron-down"; }
        if (ft == 27) { return "file"; }
        if (ft == 28) { return "warning"; }
        if (ft == 29) { return "refresh"; }
        if (ft == 30) { return "success"; }
        if (ft == 31) { return "copy"; }
        if (ft == 32) { return "refresh"; }
        if (ft == 33) { return "info"; }
        if (ft == 34) { return "check"; }
        if (ft == 35) { return "chevron-right"; }
        if (ft == 36) { return "layout"; }
        if (ft == 37) { return "more"; }
        if (ft == 38) { return "menu"; }
        if (ft == 39) { return "arrow-left"; }
        if (ft == 40) { return "menu"; }
        if (ft == 41) { return "grid"; }
        if (ft == 42) { return "image"; }
        if (ft == 43) { return "sort"; }
        if (ft == 44) { return "more"; }
        if (ft == 45) { return "layout"; }
        if (ft == 46) { return "more"; }
        if (ft == 47) { return "refresh"; }
        if (ft == 48) { return "chevron-down"; }
        if (ft == 49) { return "plus"; }
        if (ft == 50) { return "info"; }
        if (ft == 51) { return "warning"; }
        if (ft == 52) { return "bell"; }
        if (ft == 53) { return "grid"; }
        if (ft == 54) { return "star"; }
        if (ft == 55) { return "menu"; }
        if (ft == 56) { return "copy"; }
        if (ft == 57) { return "clock"; }
        return "file";
    }

    /// Renders a small (height 28) button and returns its id. Used throughout
    /// the inspector so controls fit inside compact rows.
    int SmallBtn(App app, string text, int type, int x, int y, int w) {
        Button b = Button.Typed(text, type);
        b.SetSize(1);
        return b.Render(app, x, y, w);
    }

    /// Small (height 28) icon-only button — same footprint as SmallBtn but the
    /// label is a vector Icon glyph instead of a text character.
    int SmallIconBtn(App app, string iconName, int type, int x, int y, int w) {
        Button b = Button.IconTyped(iconName, type);
        b.SetSize(1);
        return b.Render(app, x, y, w);
    }

    // --- Form preview --------------------------------------------------------
}
