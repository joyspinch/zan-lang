        if (ft == 46) { return Designer.T("Vertical scrollbar", "垂直滚动条"); }
        if (ft == 47) { return Designer.T("Loading indicator", "加载指示器"); }
        if (ft == 48) { return Designer.T("Dropdown trigger", "下拉触发器"); }
        if (ft == 49) { return Designer.T("Floating action button", "悬浮操作按钮"); }
        if (ft == 50) { return Designer.T("Anchored popover", "锚定气泡卡片"); }
        if (ft == 51) { return Designer.T("Inline confirm popover", "内联确认气泡"); }
        if (ft == 52) { return Designer.T("Notification toast", "通知提示"); }
        if (ft == 53) { return Designer.T("Command ribbon", "命令功能区"); }
        if (ft == 54) { return Designer.T("Standalone icon", "独立图标"); }
        if (ft == 55) { return Designer.T("Right-click context menu (component tray)", "右键上下文菜单（组件托盘）"); }
        if (ft == 56) { return Designer.T("Popup layer / overlay (component tray)", "弹出层 / 遮罩（组件托盘）"); }
        if (ft == 57) { return Designer.T("Interval timer (component tray)", "定时器（组件托盘）"); }
        return Designer.T("Form field", "表单字段");
    }

    /// Maps a field type to a Segoe MDL2 icon name for the palette.
    string FieldIcon(int ft) {
        if (ft == 0) { return "edit"; }
        if (ft == 1) { return "menu"; }
        if (ft == 2) { return "lock"; }
        if (ft == 3) { return "sort"; }
        if (ft == 4) { return "like"; }
        if (ft == 5) { return "check"; }
        if (ft == 6) { return "chevron-down"; }
        if (ft == 7) { return "settings"; }
        if (ft == 8) { return "star"; }
        if (ft == 9) { return "more"; }
        if (ft == 10) { return "calendar"; }
        if (ft == 11) { return "clock"; }
        if (ft == 12) { return "upload"; }
        if (ft == 13) { return "color"; }
        if (ft == 14) { return "font"; }
        if (ft == 15) { return "font"; }
        if (ft == 16) { return "align-left"; }
        if (ft == 17) { return "minus"; }
        if (ft == 18) { return "grid"; }
        if (ft == 19) { return "pin"; }
        if (ft == 20) { return "bell"; }
        if (ft == 21) { return "user"; }
        if (ft == 22) { return "sort"; }
        if (ft == 23) { return "table"; }
        if (ft == 24) { return "more"; }
        if (ft == 25) { return "folder"; }
        if (ft == 26) { return "chevron-down"; }
        if (ft == 27) { return "file"; }
        if (ft == 28) { return "warning"; }
        if (ft == 29) { return "refresh"; }
        if (ft == 30) { return "success"; }
        if (ft == 31) { return "copy"; }
        if (ft == 32) { return "refresh"; }
        if (ft == 33) { return "info"; }
        if (ft == 34) { return "check"; }
        if (ft == 35) { return "chevron-right"; }
        if (ft == 36) { return "layout"; }
        if (ft == 37) { return "more"; }
        if (ft == 38) { return "menu"; }
        if (ft == 39) { return "arrow-left"; }
        if (ft == 40) { return "menu"; }
        if (ft == 41) { return "grid"; }
        if (ft == 42) { return "image"; }
        if (ft == 43) { return "sort"; }
        if (ft == 44) { return "more"; }
        if (ft == 45) { return "layout"; }
        if (ft == 46) { return "more"; }
        if (ft == 47) { return "refresh"; }
        if (ft == 48) { return "chevron-down"; }
        if (ft == 49) { return "plus"; }
        if (ft == 50) { return "info"; }
        if (ft == 51) { return "warning"; }
        if (ft == 52) { return "bell"; }
        if (ft == 53) { return "grid"; }
        if (ft == 54) { return "star"; }
        if (ft == 55) { return "menu"; }
        if (ft == 56) { return "copy"; }
        if (ft == 57) { return "clock"; }
        return "file";
    }

    /// Renders a small (height 28) button and returns its id. Used throughout
    /// the inspector so controls fit inside compact rows.
    int SmallBtn(App app, string text, int type, int x, int y, int w) {
        Button b = Button.Typed(text, type);
        b.SetSize(1);
        return b.Render(app, x, y, w);
    }

    /// Small (height 28) icon-only button — same footprint as SmallBtn but the
    /// label is a vector Icon glyph instead of a text character.
    int SmallIconBtn(App app, string iconName, int type, int x, int y, int w) {
        Button b = Button.IconTyped(iconName, type);
        b.SetSize(1);
        return b.Render(app, x, y, w);
    }

    // --- Form preview --------------------------------------------------------

    void RenderForm(App app, Canvas c, Theme t, int cx, int cy, int cw, int ch) {
        int fs = t.fontSizeSmall;
        c.FillRoundRect(cx, cy, cw, ch, app.Scale(6), t.bgPrimary);
        c.DrawRect(cx, cy, cw, ch, t.borderPrimary, 1);
        c.PushClip(cx + 1, cy + 1, cw - 2, ch - 2);
        formClipTop = cy + 1;
        formClipBot = cy + ch - 1;

        // The form can grow past its panel, so it scrolls internally. Claim the
        // wheel while the pointer is over it and clamp the offset (skip while a
        // drag is in progress so dropping isn't fighting the scroll).
        int contentH = FormContentH(app);
        int maxScroll = contentH - ch;
        if (maxScroll < 0) { maxScroll = 0; }
        if (!dragging && InRect(app.mouseX, app.mouseY, cx, cy, cw, ch)) {
            bool ownsWheel = app.CaptureWheel(cx, cy, cw, ch);
            if (ownsWheel) {
                int fdelta = app.window.EventKeyCode();
                formScroll = formScroll - fdelta * app.Scale(40) / 120;
                app.RequestRedraw();
            }
        }
        if (formScroll < 0) { formScroll = 0; }
        if (formScroll > maxScroll) { formScroll = maxScroll; }

        int pad = app.Scale(14);
        int fx = cx + pad;
        int fw = cw - pad * 2;
        if (maxScroll > 0) { fw = fw - app.Scale(8); }
        int fy = cy + pad - formScroll;

        string head = formNameSig.Get();
        if (preview) { head = head + Designer.T("   (preview)", "  （预览）"); }
        if (FormVisible(fy, app.Scale(18))) {
            c.DrawText(fx, fy, head, t.textPrimary, t.fontSizeMedium);
        }
        fy = fy + app.Scale(24);
        if (FormVisible(fy, 1)) { c.FillRect(fx, fy, fw, 1, t.divider); }
        fy = fy + app.Scale(10);

        // Non-visual components never take part in the canvas layout: they
        // live in the tray strip below (see RenderTray). Lay out only the
        // visual fields; visIdx maps a layout position back to the real index
        // in `fields` so drag/drop indices stay correct.
        List<int> visIdx = new List<int>();
        int vf = 0;
        while (vf < fields.Count) {
            if (!fields[vf].IsNonVisual()) { visIdx.Add(vf); }
            vf = vf + 1;
        }
        int n = visIdx.Count;
        if (n == 0) {
            c.DrawText(fx, fy + app.Scale(6),
                Designer.T("Empty form — pick a component on the left, or drag one in.", "空表单 —— 在左侧选择一个组件，或拖入一个组件。"),
                t.textTertiary, fs);
        }
        bool active = dragging && InRect(dragMouseX, dragMouseY, cx, cy, cw, ch);
        bool dropSet = false;
        dropIndex = fields.Count;
        dropY = fy - app.Scale(4);
        int colGap = app.Scale(12);
        rowClicked = false;
        dropContainer = null;
        int i = 0;
        while (i < n) {
            // Pack consecutive fields into one visual row until their column
            // spans (out of 24) would overflow, FormCreate-style. Containers
            // and display components normally span the full 24.
            int rowStart = i;
            int cols = 0;
            int rowEnd = i;
            while (rowEnd < n) {
                int sp = ClampSpan(fields[visIdx[rowEnd]].span);
                if (rowEnd > rowStart && cols + sp > 24) { break; }
                cols = cols + sp;
                rowEnd = rowEnd + 1;
                if (cols >= 24) { break; }
            }
            // Row height is the tallest field in the row (+ top-label room).
            int rowH = 0;
            int k = rowStart;
            while (k < rowEnd) {
                int hk = FieldHeight(app, fields[visIdx[k]]);
                if (labelPos == 2 && !fields[visIdx[k]].IsDisplay()) { hk = hk + app.Scale(18); }
                if (hk > rowH) { rowH = hk; }
                k = k + 1;
            }
            if (active && !dropSet && dragMouseY < fy + rowH / 2) {
                dropIndex = visIdx[rowStart];
                dropY = fy - app.Scale(4);
                dropSet = true;
            }
            // Cull rows that don't fit fully inside the body: the canvas clip
            // doesn't contain child widgets, so a straddling row would bleed.
            bool vis = FormVisible(fy, rowH);
            int accSpan = 0;
            int rc = rowStart;
            while (rc < rowEnd) {
                int sp = ClampSpan(fields[visIdx[rc]].span);
                int x0 = fx + fw * accSpan / 24;
                accSpan = accSpan + sp;
                int x1 = fx + fw * accSpan / 24;
                int wf = x1 - x0;
                if (rc < rowEnd - 1) { wf = wf - colGap; }
                if (vis) { RenderRow(app, c, t, fields[visIdx[rc]], x0, fy, wf, rowH, visIdx[rc], true); }
                rc = rc + 1;
            }
            fy = fy + rowH + app.Scale(6);
            i = rowEnd;
        }
        if (active && !dropSet) { dropIndex = fields.Count; dropY = fy - app.Scale(4); }
        if (active && (dragFromPalette || dragMoved) && dropContainer == null) {
            c.FillRect(fx, dropY, fw, app.Scale(2), t.primary);
        }

        int dek = app.window.EventKind();
        if (dragging && dek == 3 && active) { DropField(); app.RequestRedraw(); }

        // Click on empty form background clears the selection / add target.
        if (!preview && dek == 2 && !rowClicked && !dragging
            && InRect(app.mouseX, app.mouseY, cx, cy, cw, ch)) {
            sel = null;
            activeContainer = null;
            app.RequestRedraw();
        }

        c.PopClip();

        if (maxScroll > 0) {
            Scrollbar.RenderVertical(app, cx + cw - app.Scale(7), cy + 1,
                ch - 2, contentH, formScroll);
        }
    }

    /// Resolves the pending drag onto the form: palette drags insert a new
    /// field at dropIndex; in-form drags relocate the dragged row there.
    void DropField() {
        if (dragFromPalette) {
            if (dragKind != 100 && dragKind != 200 && FormField.IsNonVisualOf(dragKind)) {
                // Non-visual components go to the tray regardless of where
                // they were dropped.
                AddField(dragKind);
            } else if (dropContainer != null) {
                // Drop into the container under the pointer (its active tab
                // for Tabs).
                activeContainer = dropContainer;
                if (dragKind == 200) { AddUserComponent(dragUserComp); }
                else if (dragKind == 100) { AddCustomField(dragCustomKind); }
                else { AddField(dragKind); }
            } else if (dragKind == 200) {
                activeContainer = null;
                AddUserComponent(dragUserComp);
            } else if (dragKind == 100) {
                FormField nf = FormField.NewCustom(dragCustomKind, seq);
                seq = seq + 1;
                InsertFieldAt(dropIndex, nf);
                sel = nf;
                inspTab = 0;
                msg = Designer.T("added ", "已添加 ") + dragCustomKind;
            } else {
                FormField nf = FormField.New(dragKind, seq);
                seq = seq + 1;
                InsertFieldAt(dropIndex, nf);
                sel = nf;
                inspTab = 0;
                if (nf.IsContainer()) { activeContainer = nf; }
                msg = Designer.T("added ", "已添加 ") + FormField.TypeName(dragKind);
            }
        } else if (dragIndex >= 0 && dragMoved) {
            FormField mv = fields[dragIndex];
            if (dropContainer != null && dropContainer != mv && !InSubtree(mv, dropContainer)) {
                // Re-parent the dragged top-level row into the container
                // under the pointer (its active tab for Tabs).
                fields = ListRemove(fields, mv);
                mv.childTab = 0;
                if (dropContainer.ftype == 36) { mv.childTab = dropContainer.uiState.Get(); }
                dropContainer.kids.Add(mv);
                sel = mv;
                activeContainer = dropContainer;
                msg = Designer.T("moved into ", "已移入 ") + FormField.TypeName(dropContainer.ftype);
            } else {
                int at = dropIndex;
                if (at > dragIndex) { at = at - 1; }
                fields = ListMove(fields, dragIndex, at);
                sel = mv;
                msg = Designer.T("moved field", "已移动组件");
            }
        }
        dropContainer = null;
    }

    void RenderRow(App app, Canvas c, Theme t, FormField f, int rx, int ry, int rw, int rowH, int idx, bool topLevel) {
        int fs = t.fontSizeSmall;
        bool selected = !preview && (f == sel);
        if (topLevel && dragging && !dragFromPalette && dragIndex == idx && dragMoved) {
            c.FillRoundRect(rx - app.Scale(6), ry - app.Scale(3),
                rw + app.Scale(12), rowH + app.Scale(6), app.Scale(4), t.bgActive);
        }
        if (selected) {
            c.FillRoundRect(rx - app.Scale(6), ry - app.Scale(3),
                rw + app.Scale(12), rowH + app.Scale(6), app.Scale(4), t.bgHover);
            c.DrawRect(rx - app.Scale(6), ry - app.Scale(3),
                rw + app.Scale(12), rowH + app.Scale(6), t.primary, 2);
        }

        if (f.IsContainer()) {
            // Container frame + nested children (children handle their own
            // selection first, so a click inside prefers the child).
            RenderContainer(app, c, t, f, rx, ry, rw, rowH);
            // While a drag hovers this container it becomes the drop target
            // (nested containers win: they render after their parent).
            if (dragging && InRect(dragMouseX, dragMouseY, rx, ry, rw, rowH)) {
                bool ok = true;
                if (!dragFromPalette) {
                    if (dragIndex < 0 || dragIndex >= fields.Count) { ok = false; }
                    else if (fields[dragIndex] == f || InSubtree(fields[dragIndex], f)) { ok = false; }
                }
                if (ok) {
                    dropContainer = f;
                    c.DrawRect(rx - app.Scale(4), ry - app.Scale(2),
                        rw + app.Scale(8), rowH + app.Scale(4), t.primary, 2);
                }
            }
        } else {
            int lw = app.Scale(labelWidth);
            int gap = app.Scale(10);
            int ctlX = rx;
            int ctlY = ry;
            int ctlW = rw;
            int labelY = ry + app.Scale(6);

            if (f.IsDisplay()) {
                ctlX = rx; ctlY = ry; ctlW = rw;
            } else if (labelPos == 2) {
                DrawLabel(app, c, t, f, rx, labelY, rw, 0);
                ctlY = ry + app.Scale(26); ctlX = rx; ctlW = rw;
            } else {
                int align = labelPos;
                DrawLabel(app, c, t, f, rx, labelY, lw, align);
                ctlX = rx + lw + gap;
                ctlW = rw - lw - gap;
            }
            PreviewControl(app, c, t, f, ctlX, ctlY, ctlW, rowH - (ctlY - ry));
        }

        int ek = app.window.EventKind();
        bool inRow = InRect(app.mouseX, app.mouseY,
            rx - app.Scale(6), ry - app.Scale(3), rw + app.Scale(12), rowH + app.Scale(6));
        // A nested child already handled the click (rowClicked) — don't let the
        // enclosing container steal the selection.
        if (!preview && ek == 2 && inRow && !dragging && !rowClicked) {
            sel = f;
            inspTab = 0;
            rowClicked = true;
            if (f.IsContainer()) { activeContainer = f; }
            else { activeContainer = ParentContainerOf(f); }
            if (topLevel) {
                dragging = true;
                dragFromPalette = false;
                dragMoved = false;
                dragIndex = idx;
                dragMouseX = app.mouseX;
                dragMouseY = app.mouseY;
            }
            app.RequestRedraw();
        }
    }

    // --- Container geometry + rendering --------------------------------------

    /// Height of a container's chrome above its body: Card title bar, or the
    /// Tabs header strip.
    int ContainerHeaderH(App app, FormField f) {
        Theme t = app.theme;
        if (f.ftype == 18) { return Card.ContentY(0, t); }
        return t.heightMedium + app.Scale(8);
    }

    /// Height of the visible child stack for the active tab (or the card body),
    /// with a minimum so an empty container is still a usable drop target.
    int ContainerBodyH(App app, FormField f) {
        int gap = app.Scale(6);
        int pad = app.Scale(8);
        int total = 0;
        int shown = 0;
        int activeTab = f.uiState.Get();
        if (activeTab >= f.OptionCount() || activeTab < 0) { activeTab = 0; }
        int i = 0;
        while (i < f.KidCount()) {
            FormField ch = f.KidAt(i);
            bool vis = true;
            if (f.ftype == 36 && ch.childTab != activeTab) { vis = false; }
            if (vis) {
                total = total + FieldHeight(app, ch) + gap;
                shown = shown + 1;
            }
            i = i + 1;
        }
        if (shown == 0) { return app.Scale(40); }
        return total - gap + pad * 2;
    }

    int FieldHeight(App app, FormField f) {
        if (f.IsContainer()) {
            return ContainerHeaderH(app, f) + ContainerBodyH(app, f) + app.Scale(10);
        }
        return app.Scale(f.RowUnits());
    }

    void RenderContainer(App app, Canvas c, Theme t, FormField f, int rx, int ry, int rw, int rowH) {
        int headerH = ContainerHeaderH(app, f);
        if (f.ftype == 18) {
            Card.Render(app, rx, ry, rw, rowH, f.label);
            int innerX = rx + t.paddingLarge;
            int innerW = rw - t.paddingLarge * 2;
            RenderKids(app, c, t, f, innerX, ry + headerH, innerW, 0);
        } else {
            List<string> labels = new List<string>();
            int oi = 0;
            while (oi < f.OptionCount()) { labels.Add(f.OptionAt(oi)); oi = oi + 1; }
            if (labels.Count == 0) { labels.Add("Tab 1"); }
            // Keep the active tab inside range (tab options may get deleted).
            if (f.uiState.Get() >= labels.Count || f.uiState.Get() < 0) { f.uiState.Set(0); }
            int firstId = TabStrip.Render(app, rx, ry, rw, labels, f.uiState);
            if (!preview) { TabStrip.HandleClick(app, firstId, labels.Count, f.uiState); }
            int innerX = rx + app.Scale(4);
            int innerW = rw - app.Scale(8);
            RenderKids(app, c, t, f, innerX, ry + headerH, innerW, f.uiState.Get());
        }
    }

    /// Lays the container's visible children vertically. `tabFilter` limits the
    /// children to one Tabs panel (ignored for single-body Card).
    void RenderKids(App app, Canvas c, Theme t, FormField f, int x, int y, int w, int tabFilter) {
        int gap = app.Scale(6);
        int pad = app.Scale(8);
        int cyk = y + pad;
        int shown = 0;
        int i = 0;
        while (i < f.KidCount()) {
            FormField ch = f.KidAt(i);
            bool vis = true;
            if (f.ftype == 36 && ch.childTab != tabFilter) { vis = false; }
            if (vis) {
                int kh = FieldHeight(app, ch);
                RenderRow(app, c, t, ch, x + app.Scale(4), cyk, w - app.Scale(8), kh, -1, false);
                cyk = cyk + kh + gap;
                shown = shown + 1;
            }
            i = i + 1;
        }
        if (shown == 0) {
            c.DrawText(x + app.Scale(6), y + app.Scale(12),
                Designer.T("Empty — select this container, then add components", "空 —— 选中此容器，然后添加组件"),
                t.textTertiary, t.fontSizeSmall);
        }
    }

    void DrawLabel(App app, Canvas c, Theme t, FormField f, int lx, int ly, int lw, int align) {
        int fs = t.fontSizeSmall;
        string star = "";
        if (f.required && !hideStar) { star = "* "; }
        int starW = 0;
        if (star != "") { starW = Canvas.MeasureText("* ", fs); }
        int textW = Canvas.MeasureText(f.label, fs);
        int total = starW + textW;
        int tx = lx;
        if (align == 1) { tx = lx + lw - total; }
        if (star != "") {
            c.DrawText(tx, ly, "*", t.error, fs);
            tx = tx + starW;
        }
        c.DrawText(tx, ly, f.label, t.textSecondary, fs);
    }

    /// Draws a non-interactive preview of the field's input control.
    void PreviewControl(App app, Canvas c, Theme t, FormField f, int x, int y, int w, int avail) {
        int fs = t.fontSizeSmall;
        int line = app.Scale(28);
        if (w < app.Scale(40)) { w = app.Scale(40); }
        int ft = f.ftype;

        // Display / layout / feedback / navigation components (ftype >= 15).
        if (ft >= 15) {
            // Options may have been deleted since the ui state was set; keep
            // the index in range so option-driven previews never overrun.
            if (f.UsesOptions() && f.uiState.Get() >= f.OptionCount()) { f.uiState.Set(0); }
            PreviewDisplay(app, c, t, f, x, y, w, avail, line);
            return;
        }

        if (ft == 1) {                       // textarea
            int bh = avail - app.Scale(6);
            if (bh < line) { bh = line; }
            Box(c, t, x, y, w, bh);
            c.DrawText(x + app.Scale(8), y + app.Scale(6), f.placeholder, t.textTertiary, fs);
            return;
        }
        if (ft == 12) {                      // upload
            int bh = avail - app.Scale(6);
            if (bh < line) { bh = line; }
            c.FillRoundRect(x, y, w, bh, t.borderRadiusMedium, t.bgSecondary);
            c.DrawRect(x, y, w, bh, t.borderSecondary, 1);
            c.DrawTextCentered(x, y, w, bh, "+  " + f.placeholder, t.textTertiary, fs);
            return;
        }
        if (ft == 14) {                      // rich text
            int bh = avail - app.Scale(6);
            if (bh < line * 2) { bh = line * 2; }
            Box(c, t, x, y, w, bh);
            c.FillRect(x, y + app.Scale(24), w, 1, t.divider);
            c.DrawText(x + app.Scale(8), y + app.Scale(5), "B  I  U  •", t.textTertiary, fs);
            c.DrawText(x + app.Scale(8), y + app.Scale(30), f.placeholder, t.textTertiary, fs);
            return;
        }

        if (ft == 4 || ft == 5) {            // radio / checkbox
            PreviewChoice(app, c, t, f, x, y, w, line);
            return;
        }
        if (ft == 7) {                       // switch
            int sw = app.Scale(40);
            int sh = app.Scale(20);
            int syy = y + (line - sh) / 2;
            int track = t.bgTertiary;
            int knobX = x + sh / 2;
            if (f.defOn) {
                track = t.primary;
                knobX = x + sw - sh / 2;
            }
            c.FillRoundRect(x, syy, sw, sh, sh / 2, track);
            c.FillCircle(knobX, syy + sh / 2, sh / 2 - app.Scale(2), t.bgPrimary);
            return;
        }
        if (ft == 8) {                       // rate
            int r = app.Scale(6);
            int syy = y + line / 2;
            int sx = x + r;
            int k = 0;
            while (k < 5) {
                int col = t.borderSecondary;
                if (k < 3) { col = t.warning; }
                c.FillCircle(sx, syy, r, col);
                sx = sx + r * 2 + app.Scale(6);
                k = k + 1;
            }
            return;
        }
        if (ft == 9) {                       // slider
            int syy = y + line / 2;
            c.FillRect(x, syy, w, app.Scale(3), t.bgTertiary);
            c.FillRect(x, syy, w * 2 / 5, app.Scale(3), t.primary);
            c.FillCircle(x + w * 2 / 5, syy + app.Scale(1), app.Scale(7), t.primary);
            return;
        }
        if (ft == 13) {                      // color
            Box(c, t, x, y, w, line);
            c.FillRoundRect(x + app.Scale(6), y + app.Scale(6), app.Scale(16), line - app.Scale(12),
                t.borderRadiusSmall, t.primary);
            c.DrawText(x + app.Scale(30), y + app.Scale(6), "#3366FF", t.textSecondary, fs);
            return;
        }

        // Default single-line box (input / password / number / select / date / time).
        Box(c, t, x, y, w, line);
        string txt = f.placeholder;
        int txtCol = t.textTertiary;
        if (ft == 2) { txt = "••••••••"; }
        if (ft == 6 && f.OptionCount() > 0) { txt = f.OptionAt(0); txtCol = t.textSecondary; }
        c.DrawText(x + app.Scale(8), y + app.Scale(6), txt, txtCol, fs);
        if (ft == 6 || ft == 10 || ft == 11) {
            Icon.DrawCenteredIn(c, "chevron-down", x + w - app.Scale(20), y, app.Scale(16), line,
                app.Scale(11), t.textTertiary);
        }
        if (ft == 3) {
            Icon.DrawCenteredIn(c, "chevron-up", x + w - app.Scale(18), y,
                app.Scale(14), line / 2, app.Scale(9), t.textTertiary);
            Icon.DrawCenteredIn(c, "chevron-down", x + w - app.Scale(18), y + line / 2,
                app.Scale(14), line / 2, app.Scale(9), t.textTertiary);
        }
    }

    /// Draws the non-interactive preview for a display / layout / feedback /
    /// navigation component (ftype >= 15). Each case paints a recognisable
    /// miniature of the corresponding stdlib widget.
    void PreviewDisplay(App app, Canvas c, Theme t, FormField f, int x, int y, int w, int avail, int line) {
        int fs = t.fontSizeSmall;
        int ft = f.ftype;

        if (ft == 100) {                     // project custom component
            int bh = line + app.Scale(8);
            c.FillRoundRect(x, y, w, bh, t.borderRadiusMedium, t.bgSecondary);
            c.DrawRect(x, y, w, bh, t.primary, 1);
            string icon = CustomComponents.IconOf(f.customKind);
            if (icon == "") { icon = "puzzle"; }
            Icon.DrawCenteredIn(c, icon, x + app.Scale(6), y, app.Scale(20), bh,
                app.Scale(13), t.primary);
            c.DrawText(x + app.Scale(30), y + (bh - fs) / 2, f.customKind, t.textSecondary, fs);
            return;
        }
        if (ft == 15) {                      // title / heading
            Typography.Heading(app, x, y, f.label, 4);
            return;
        }
        if (ft == 16) {                      // static paragraph text
            Typography.Paragraph(app, x, y, f.label);
            return;
        }
        if (ft == 17) {                      // divider
            if (f.label == "") { Divider.Render(app, x, y + line / 2, w); }
            else { Divider.RenderText(app, x, y + app.Scale(2), w, f.label, 0); }
            return;
        }
        if (ft == 18) {                      // card
            int bh = avail - app.Scale(6);
            if (bh < app.Scale(56)) { bh = app.Scale(56); }
            c.FillRoundRect(x, y, w, bh, t.borderRadiusMedium, t.bgPrimary);
            c.DrawRect(x, y, w, bh, t.borderPrimary, 1);
            c.DrawText(x + app.Scale(10), y + app.Scale(8), f.label, t.textPrimary, t.fontSizeMedium);
            c.FillRect(x, y + app.Scale(30), w, 1, t.divider);
            c.DrawText(x + app.Scale(10), y + app.Scale(38), Designer.T("Card body content", "卡片内容"), t.textTertiary, fs);
            return;
        }
        if (ft == 19) {                      // tag
            Tag.Render(app, x, y + app.Scale(3), f.label, 1);
            return;
        }
        if (ft == 20) {                      // badge
            c.DrawText(x, y + app.Scale(6), f.label, t.textPrimary, fs);
            int bw = Canvas.MeasureText(f.label, fs);
            Badge.Count(app, x + bw + app.Scale(10), y + app.Scale(2), 5);
            return;
        }
        if (ft == 21) {                      // avatar
            Avatar.Render(app, x, y + app.Scale(2), app.Scale(34), f.label);
            return;
        }
        if (ft == 22) {                      // statistic
            Statistic.Render(app, x, y, f.label, "12,480");
            return;
        }
        if (ft == 23) {                      // table
            PreviewTable(app, c, t, f, x, y, w, avail);
            return;
        }
        if (ft == 24) {                      // timeline
            List<string> titles = new List<string>();
            List<string> descs = new List<string>();
            int i = 0;
            while (i < f.OptionCount()) { titles.Add(f.OptionAt(i)); descs.Add(""); i = i + 1; }
            Timeline.Render(app, x, y + app.Scale(2), titles, descs);
            return;
        }
        if (ft == 25) {                      // tree
            List<TreeNode> nodes = new List<TreeNode>();
            int i = 0;
            while (i < f.OptionCount()) {
                if (i == 0) { nodes.Add(TreeNode.Dir(f.OptionAt(i), 0, true)); }
                else { nodes.Add(TreeNode.File(f.OptionAt(i), 1)); }
                i = i + 1;
            }
            Rect area = Rect.Create(x, y + app.Scale(2), w, avail - app.Scale(6));
            TreeView.Render(app, area, nodes, f.uiState, 0);
            return;
        }
        if (ft == 26) {                      // collapse
            List<string> titles = new List<string>();
            List<string> bodies = new List<string>();
            int i = 0;
            while (i < f.OptionCount()) { titles.Add(f.OptionAt(i)); bodies.Add(Designer.T("Panel content", "面板内容")); i = i + 1; }
            int fid = Collapse.Render(app, x, y + app.Scale(2), w, titles, bodies, f.uiState);
            if (!preview) { Collapse.HandleClick(app, fid, titles.Count, f.uiState); }
            return;
        }
        if (ft == 27) {                      // empty
            int eh = avail - app.Scale(6);
            if (eh < app.Scale(56)) { eh = app.Scale(56); }
            Empty.Render(app, x, y, w, eh, f.label);
            return;
        }
        if (ft == 28) {                      // alert
            Alert.Render(app, x, y, w, f.label, "", 2);
            return;
        }
        if (ft == 29) {                      // progress
            Progress.RenderText(app, x, y + app.Scale(8), w, 60, 1);
            return;
        }
        if (ft == 30) {                      // result
            Result.Render(app, x, y, w, 1, f.label, Designer.T("Operation completed", "操作已完成"));
            return;
        }
        if (ft == 31) {                      // skeleton
            Skeleton.Text(app, x, y + app.Scale(4), w);
            Skeleton.Text(app, x, y + app.Scale(24), w);
            Skeleton.Text(app, x, y + app.Scale(44), w * 3 / 5);
            return;
        }
        if (ft == 32) {                      // spin
            Spin.Render(app, x + app.Scale(12), y + app.Scale(16), app.Scale(10), t.primary);
            c.DrawText(x + app.Scale(30), y + app.Scale(10), Designer.T("Loading...", "加载中..."), t.textTertiary, fs);
            return;
        }
        if (ft == 33) {                      // tooltip trigger
            int bw = Canvas.MeasureText(f.label, fs) + app.Scale(20);
            c.FillRoundRect(x, y + app.Scale(2), bw, app.Scale(24), t.borderRadiusMedium, t.bgSecondary);
            c.DrawRect(x, y + app.Scale(2), bw, app.Scale(24), t.borderSecondary, 1);
            c.DrawText(x + app.Scale(10), y + app.Scale(7), f.label, t.textSecondary, fs);
            return;
        }
        if (ft == 34) {                      // steps
            List<string> labels = new List<string>();
            int i = 0;
            while (i < f.OptionCount()) { labels.Add(f.OptionAt(i)); i = i + 1; }
            Steps.Render(app, x, y + app.Scale(2), w, labels, f.uiState);
            return;
        }
        if (ft == 35) {                      // breadcrumb
            List<string> items = new List<string>();
            int i = 0;
            while (i < f.OptionCount()) { items.Add(f.OptionAt(i)); i = i + 1; }
            Breadcrumb.Render(app, x, y + app.Scale(4), items);
            return;
        }
        if (ft == 36) {                      // tabs
            int nn = f.OptionCount(); if (nn < 1) { nn = 3; }
            int gx = x;
            int i = 0;
            while (i < nn) {
                string it = "Tab"; if (i < f.OptionCount()) { it = f.OptionAt(i); }
                int tw = Canvas.MeasureText(it, fs) + app.Scale(16);
                int col = t.textTertiary;
                if (i == 0) { col = t.primary; }
                c.DrawText(gx + app.Scale(8), y + app.Scale(4), it, col, fs);
                if (i == 0) { c.FillRect(gx, y + app.Scale(24), tw, app.Scale(2), t.primary); }
                gx = gx + tw;
                i = i + 1;
            }
            c.FillRect(x, y + app.Scale(25), w, 1, t.divider);
            c.DrawText(x + app.Scale(4), y + app.Scale(38), Designer.T("Tab panel content", "标签页内容"), t.textTertiary, fs);
            return;
        }
        if (ft == 37) {                      // pagination
            int fid = Pagination.Render(app, x, y + app.Scale(2), 10, f.uiState);
            if (!preview) { Pagination.HandleClick(app, fid, 10, f.uiState); }
            return;
        }
        if (ft == 38) {                      // menu
            List<string> items = new List<string>();
            int i = 0;
            while (i < f.OptionCount()) { items.Add(f.OptionAt(i)); i = i + 1; }
            int mh = avail - app.Scale(4);
            Menu.RenderVertical(app, x, y + app.Scale(2), w, y + app.Scale(2) + mh,
                t.heightMedium, items, f.uiState, 0);
            return;
        }
        if (ft == 39) {                      // page header
            PageHeader.Render(app, x, y, w, f.label, Designer.T("Subtitle / description", "副标题 / 描述"));
            return;
        }
        if (ft == 40) {                      // list view
            List<string> items = new List<string>();
            int i = 0;
            while (i < f.OptionCount()) { items.Add(f.OptionAt(i)); i = i + 1; }
            ListView.Render(app, x, y + app.Scale(2), w, items);
            return;
        }
        if (ft == 41) {                      // data table
            PreviewTable(app, c, t, f, x, y, w, avail);
            return;
        }
        if (ft == 42) {                      // carousel
            List<string> slides = new List<string>();
            int i = 0;
            while (i < f.OptionCount()) { slides.Add(f.OptionAt(i)); i = i + 1; }
            if (slides.Count == 0) { slides.Add("Slide 1"); }
            int chh = avail - app.Scale(6);
            if (chh < app.Scale(70)) { chh = app.Scale(70); }
            int cid = Carousel.Render(app, x, y, w, chh, slides, f.uiState);
            if (!preview) { Carousel.HandleClick(app, cid, slides.Count, f.uiState); }
            return;
        }
        if (ft == 43) {                      // chart
            PreviewChart(app, c, t, f, x, y, w, avail);
            return;
        }
        if (ft == 44) {                      // ellipsis
            Ellipsis.Render(app, x, y + app.Scale(4), w, f.label);
            return;
        }
        if (ft == 45) {                      // panel
            int ph = avail - app.Scale(6);
            if (ph < app.Scale(70)) { ph = app.Scale(70); }
            Rect r = Panel.Section(app, x, y, w, ph, f.label);
            c.DrawText(r.x, r.y, Designer.T("Panel content", "面板内容"), t.textTertiary, fs);
            return;
        }
        if (ft == 46) {                      // scrollbar
            int sh = avail - app.Scale(6);
            if (sh < app.Scale(70)) { sh = app.Scale(70); }
            c.DrawRect(x, y, w, sh, t.borderPrimary, 1);
            c.DrawText(x + app.Scale(8), y + app.Scale(8),
                Designer.T("Scrollable content", "可滚动内容"), t.textTertiary, fs);
            Scrollbar.RenderVertical(app, x + w - app.Scale(10), y, sh,
                sh * 3, app.Scale(20));
            return;
        }
        if (ft == 47) {                      // loading
            int r = app.Scale(12);
            Loading.Render(app, x + r + app.Scale(4), y + r + app.Scale(8), r);
            c.DrawText(x + r * 2 + app.Scale(16), y + r,
                Designer.T("Loading...", "加载中..."), t.textTertiary, fs);
            return;
        }
        if (ft == 48) {                      // dropdown trigger
            Dropdown.RenderTrigger(app, x, y + app.Scale(2),
                app.Scale(180), t.heightMedium, f.label, false);
            return;
        }
        if (ft == 49) {                      // float button
            FloatButton.Render(app, x, y + app.Scale(2), t.heightLarge, "plus", 1);
            return;
        }
        if (ft == 50) {                      // popover
            Popover.Render(app, x + app.Scale(90), y,
                app.Scale(180), app.Scale(60), f.label, Designer.T("Popover body text", "气泡内容"));
            return;
        }
        if (ft == 51) {                      // popconfirm
            Layer.DrawPopconfirm(app, x + app.Scale(110), y, f.label, Designer.T("OK", "确定"), Designer.T("Cancel", "取消"));
            return;
        }
        if (ft == 52) {                      // notification
            Layer.DrawNotify(app, x, y + app.Scale(2), w, f.label, 3);
            return;
        }
        if (ft == 53) {                      // ribbon
            List<RibbonCmd> cmds = new List<RibbonCmd>();
            cmds.Add(RibbonCmd.Group("save", Designer.T("Save", "保存")));
            cmds.Add(RibbonCmd.Create("copy", Designer.T("Copy", "复制")));
            cmds.Add(RibbonCmd.Create("paste", Designer.T("Paste", "粘贴")));
            cmds.Add(RibbonCmd.Create("cut", Designer.T("Cut", "剪切")));
            Ribbon.Render(app, x, y, w, Ribbon.Height(app), cmds);
            return;
        }
        if (ft == 54) {                      // icon
            int sz = app.Scale(24);
            Icon.DrawCenteredIn(c, "star", x, y, sz, sz, t.iconSizeLarge, t.primary);
            c.DrawText(x + sz + app.Scale(8), y + app.Scale(4),
                f.label, t.textSecondary, fs);
            return;
        }
    }

    /// Human name of a chart kind (Chart field stores the kind in uiState).
    static string ChartKindName(int k) {
        if (k == 1) { return "Line"; }
        if (k == 2) { return "Area"; }
        if (k == 3) { return "Stacked"; }
        if (k == 4) { return "H-Bar"; }
        if (k == 5) { return "Pie"; }
        if (k == 6) { return "Donut"; }
        if (k == 7) { return "Scatter"; }
        return "Bar";
    }

    /// Preview for the Chart component. The chart kind is held in the field's
    /// uiState (0 Bar .. 7 Scatter) so a single palette entry composes every
    /// chart type the stdlib Chart widget provides.
    void PreviewChart(App app, Canvas c, Theme t, FormField f, int x, int y, int w, int avail) {
        int kind = f.uiState.Get();
        int hh = avail - app.Scale(6);
        if (hh < app.Scale(120)) { hh = app.Scale(120); }

        List<string> labels = new List<string>();
        labels.Add("Mon"); labels.Add("Tue"); labels.Add("Wed");
        labels.Add("Thu"); labels.Add("Fri");
        List<int> a = new List<int>();
        a.Add(24); a.Add(52); a.Add(38); a.Add(66); a.Add(45);
        List<int> b = new List<int>();
        b.Add(30); b.Add(20); b.Add(50); b.Add(40); b.Add(60);

        if (kind == 5 || kind == 6) {
            if (kind == 6) { Chart.Donut(app, x, y, w, hh, f.label, labels, a); }
            else { Chart.Pie(app, x, y, w, hh, f.label, labels, a); }
            return;
        }
        if (kind == 7) {
            List<int> xs = new List<int>();
            xs.Add(12); xs.Add(28); xs.Add(40); xs.Add(55); xs.Add(70);
            Chart.Scatter(app, x, y, w, hh, f.label, xs, a, Chart.Palette(t, 0));
            return;
        }

        List<ChartSeries> series = new List<ChartSeries>();
        series.Add(ChartSeries.Create("Series A", a, Chart.Palette(t, 0)));
        series.Add(ChartSeries.Create("Series B", b, Chart.Palette(t, 1)));
        if (kind == 1) { Chart.Line(app, x, y, w, hh, f.label, labels, series); return; }
        if (kind == 2) { Chart.Area(app, x, y, w, hh, f.label, labels, series); return; }
        if (kind == 3) { Chart.StackedBar(app, x, y, w, hh, f.label, labels, series); return; }
        if (kind == 4) { Chart.HBar(app, x, y, w, hh, f.label, labels, series); return; }
        Chart.Bar(app, x, y, w, hh, f.label, labels, series);
    }

    /// Renders a compact non-interactive preview of a table field: a header row
    /// built from the field's options (its columns) plus a few placeholder rows.
    void PreviewTable(App app, Canvas c, Theme t, FormField f, int x, int y, int w, int avail) {
        int nc = f.OptionCount();
        if (nc < 1) { nc = 3; }
        List<string> cols = new List<string>();
        List<int> widths = new List<int>();
        List<string> cells = new List<string>();
        int colW = w / nc;
        int i = 0;
        while (i < nc) {
            string h = "Col " + Convert.ToString(i + 1);
            if (i < f.OptionCount()) { h = Designer.ColTitle(f.OptionAt(i)); }
            cols.Add(h);
            widths.Add(colW);
            cells.Add("—");
            i = i + 1;
        }
        int totalW = colW * nc;
        int rowH = t.heightMedium;
        int bh = avail - app.Scale(6);
        if (bh < rowH * 3) { bh = rowH * 3; }
        c.PushClip(x, y, totalW, bh);
        Table.RenderHeader(app, x, y, cols, widths);
        int ry = y + rowH;
        bool striped = true;
        while (ry + rowH <= y + bh) {
            Table.RenderRow(app, x, ry, cells, widths, striped);
            striped = !striped;
            ry = ry + rowH;
        }
        c.PopClip();
        c.DrawRect(x, y, totalW, bh, t.borderPrimary, 1);
    }

    /// Renders a horizontal preview of a radio/checkbox field's options.
    void PreviewChoice(App app, Canvas c, Theme t, FormField f, int x, int y, int w, int line) {
        int fs = t.fontSizeSmall;
        bool radio = (f.ftype == 4);
        int cy = y + line / 2;
        int gx = x;
        int mark = app.Scale(14);
        int i = 0;
        while (i < f.OptionCount()) {
            string opt = f.OptionAt(i);
            if (radio) {
                c.FillCircle(gx + mark / 2, cy, mark / 2, t.bgPrimary);
                c.DrawRect(gx, cy - mark / 2, mark, mark, t.borderPrimary, 1);
                if (i == 0) { c.FillCircle(gx + mark / 2, cy, mark / 4, t.primary); }
            } else {
                c.FillRoundRect(gx, cy - mark / 2, mark, mark, t.borderRadiusSmall, t.bgPrimary);
                c.DrawRect(gx, cy - mark / 2, mark, mark, t.borderPrimary, 1);
            }
            int tx = gx + mark + app.Scale(4);
            c.DrawText(tx, y + app.Scale(6), opt, t.textSecondary, fs);
            int ow = mark + app.Scale(8) + Canvas.MeasureText(opt, fs) + app.Scale(12);
            gx = gx + ow;
            if (gx > x + w - app.Scale(30)) { i = f.OptionCount(); }
            i = i + 1;
        }
    }

    void Box(Canvas c, Theme t, int x, int y, int w, int h) {
        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium, t.bgPrimary);
        c.DrawRect(x, y, w, h, t.borderPrimary, 1);
    }

    // --- Inspector -----------------------------------------------------------

    void RenderInspector(App app, Canvas c, Theme t, int x, int y, int w, int h) {
        int fs = t.fontSizeSmall;
        c.FillRoundRect(x, y, w, h, app.Scale(6), t.bgSecondary);
        c.DrawRect(x, y, w, h, t.borderPrimary, 1);
        int ix = x + app.Scale(12);
        int iw = w - app.Scale(24);

        // Fixed header: which object is being edited + the Properties / Events
        // tab pair. The target is the selected component, or the root Window
        // when nothing is selected.
        bool root = (sel == null);
        int hy = y + app.Scale(10);
        string target = Designer.T("WINDOW", "窗口") + "  ·  " + winTitleSig.Get();
        if (!root) {
            string tn = FormField.TypeName(sel.ftype);
            if (sel.ftype == 100) { tn = sel.customKind; }
            target = Designer.T("COMPONENT", "组件") + "  ·  " + tn;
        }
        c.DrawText(ix, hy, Ellipsis.Fit(target, iw, fs), t.textTertiary, fs);
        hy = hy + app.Scale(18);

        int tabW = (iw - app.Scale(6)) / 2;
        int pType = 0; if (inspTab == 0) { pType = 1; }
        int eType = 0; if (inspTab == 1) { eType = 1; }
        int pId = Button.Typed(Designer.T("Properties", "属性"), pType).Render(app, ix, hy, tabW);
        int eId = Button.Typed(Designer.T("Events", "事件"), eType).Render(app, ix + tabW + app.Scale(6), hy, tabW);
        if (Button.WasClicked(app, pId) && inspTab != 0) { inspTab = 0; inspScroll = 0; }
        if (Button.WasClicked(app, eId) && inspTab != 1) { inspTab = 1; inspScroll = 0; }
        hy = hy + app.Scale(38);

        // Scrollable body. Content height is measured from the previous frame
        // (inspContentH) so tall property / grouped-event lists can scroll.
        int bodyY = hy;
        int bodyH = y + h - bodyY - app.Scale(8);
        int maxScroll = inspContentH - bodyH;
        if (maxScroll < 0) { maxScroll = 0; }
        if (InRect(app.mouseX, app.mouseY, x, bodyY, w, bodyH)) {
            if (app.CaptureWheel(x, bodyY, w, bodyH)) {
                int delta = app.window.EventKeyCode();
                inspScroll = inspScroll - delta * app.Scale(40) / 120;
                app.RequestRedraw();
            }
        }
        if (inspScroll < 0) { inspScroll = 0; }
        if (inspScroll > maxScroll) { inspScroll = maxScroll; }

        c.PushClip(x + 1, bodyY, w - 2, bodyH);
        int iy = bodyY - inspScroll;
        int startY = iy;
        if (inspTab == 1) {
            iy = RenderEventsTab(app, c, t, ix, iy, iw);
        } else if (root) {
            iy = RenderWindowProps(app, c, t, ix, iy, iw);
        } else {
            SyncEditors(sel);
            iy = RenderFieldProps(app, c, t, sel, ix, iy, iw);
        }
        inspContentH = iy - startY;
        c.PopClip();

        if (maxScroll > 0) {
            Scrollbar.RenderVertical(app, x + w - app.Scale(7), bodyY,
                bodyH, inspContentH, inspScroll);
        }
    }

    void SyncEditors(FormField f) {
        if (f == selPrev) { return; }
        selPrev = f;
        labelSig.Set(f.label);
        nameSig.Set(f.fname);
        phSig.Set(f.placeholder);
        bindSig.Set(f.bindPath);
        bindPropSig.Set(f.bindProp);
        customSig.Set(f.customKind);
        optSig.Set("");
        List<string> evs = f.Events();
        if (evs.Count > 0) { evtEditing = evs[0]; } else { evtEditing = ""; }
        evtSig.Set(f.GetHandler(evtEditing));
    }

    /// Suggests a delegate method name for an event, e.g. field "amount" +
    /// "Change" -> "OnAmountChange". Spaces in the type name are stripped so
    /// display components (e.g. "Data Table") still yield a valid identifier.
    static string SuggestHandler(FormField f, string ev) {
        string src = f.fname;
        if (src == "") { src = FormField.TypeName(f.ftype); }
        string id = "";
        int i = 0;
        while (i < src.Length) {
            string chs = src.Substring(i, 1);
            if (chs != " ") { id = id + chs; }
            i = i + 1;
        }
        return "On" + id + ev;
    }

    /// Properties tab for the selected component (no events — those live on the
    /// Events tab). Returns the y after the last row so the body can scroll.
    int RenderFieldProps(App app, Canvas c, Theme t, FormField f, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        iy = LabeledInput(app, c, t, Designer.T("Label", "标签"), labelInput, ix, iy, iw);
        f.label = labelSig.Get();
        iy = LabeledInput(app, c, t, Designer.T("Name", "名称"), nameInput, ix, iy, iw);
        f.fname = nameSig.Get();
        f.name = f.fname;
        iy = LabeledInput(app, c, t, Designer.T("Placeholder", "占位文本"), phInput, ix, iy, iw);
        f.placeholder = phSig.Get();
        string bindLbl = Designer.T("Bind path", "绑定路径");
        if (f.ftype == 23 || f.ftype == 41) { bindLbl = Designer.T("Data source", "数据源"); }
        iy = LabeledInput(app, c, t, bindLbl, bindInput, ix, iy, iw);
        f.bindPath = bindSig.Get();
        // Two-way binding picker: variables scanned from the paired code file.
        if (bindVars.Count > 0) {
            string pickLbl = Designer.T("Pick from code ▾", "从代码选择 ▾");
            if (bindPickOpen) { pickLbl = Designer.T("Pick from code ▴", "从代码选择 ▴"); }
            int pkId = SmallBtn(app, pickLbl, 0, ix + app.Scale(84), iy, iw - app.Scale(84));
            if (Button.WasClicked(app, pkId)) {
                bindPickOpen = !bindPickOpen;
                app.RequestRedraw();
            }
            iy = iy + app.Scale(34);
            if (bindPickOpen) {
                int bvi = 0;
                while (bvi < bindVars.Count) {
                    int bvType = 0;
                    if (bindVars[bvi] == f.bindPath) { bvType = 1; }
                    int bvId = SmallBtn(app, bindVars[bvi], bvType,
                        ix + app.Scale(84), iy, iw - app.Scale(84));
                    if (Button.WasClicked(app, bvId)) {
                        f.bindPath = bindVars[bvi];
                        bindSig.Set(f.bindPath);
                        bindInput.SetText(f.bindPath);
                        bindPickOpen = false;
                        msg = Designer.T("bound to ", "已绑定 ") + f.bindPath;
                        app.RequestRedraw();
                    }
                    iy = iy + app.Scale(32);
                    bvi = bvi + 1;
                }
            }
        }
        iy = LabeledInput(app, c, t, Designer.T("Bind prop", "绑定属性"), bindPropInput, ix, iy, iw);
        f.bindProp = bindPropSig.Get();
        if (f.ftype == 100) {
            iy = LabeledInput(app, c, t, Designer.T("Component", "组件"), customInput, ix, iy, iw);
            f.customKind = customSig.Get();
        }

        f.required = ToggleRow(app, c, t, Designer.T("Required", "必填"), f.required, ix, iy, iw);
        iy = iy + app.Scale(34);

        // Field width on the 24-column grid: quick presets plus an exact span.
        List<string> spanOpts = new List<string>();
        spanOpts.Add("1/1"); spanOpts.Add("1/2"); spanOpts.Add("1/3"); spanOpts.Add("1/4");
        int spanSel = 0;
        if (f.span == 12) { spanSel = 1; }
        else if (f.span == 8) { spanSel = 2; }
        else if (f.span == 6) { spanSel = 3; }
        int newSel = SegRow(app, c, t, Designer.T("Field width", "字段宽度"), spanOpts, spanSel, ix, iy, iw);
        if (newSel != spanSel) {
            if (newSel == 1) { f.span = 12; }
            else if (newSel == 2) { f.span = 8; }
            else if (newSel == 3) { f.span = 6; }
            else { f.span = 24; }
        }
        iy = iy + app.Scale(54);
        f.span = IntRow(app, c, t, Designer.T("Span / 24", "跨度 / 24"), f.span, 1, ix, iy, iw);
        if (f.span < 1) { f.span = 1; }
        if (f.span > 24) { f.span = 24; }
        iy = iy + app.Scale(36);

        if (f.ftype == 7) {
            f.defOn = ToggleRow(app, c, t, Designer.T("Default on", "默认开启"), f.defOn, ix, iy, iw);
            iy = iy + app.Scale(34);
        }

        if (f.UsesOptions()) {
            bool table = (f.ftype == 23 || f.ftype == 41);
            iy = iy + app.Scale(6);
            if (table) {
                c.DrawText(ix, iy, Designer.T("COLUMNS (title · field)", "列（标题 · 字段）"), t.textTertiary, fs);
            } else {
                c.DrawText(ix, iy, Designer.T("OPTIONS", "选项"), t.textTertiary, fs);
            }
            iy = iy + app.Scale(20);
            int oi = 0;
            while (oi < f.OptionCount()) {
                string disp = f.OptionAt(oi);
                if (table) {
                    disp = Designer.ColTitle(disp);
                    string cfd = Designer.ColField(f.OptionAt(oi));
                    if (cfd != "") { disp = disp + "  ·  " + cfd; }
                }
                c.DrawText(ix, iy + app.Scale(7),
                    Convert.ToString(oi + 1) + ".  " + disp, t.textSecondary, fs);
                int rmId = SmallIconBtn(app, "close", 5, ix + iw - app.Scale(28), iy, app.Scale(28));
                if (Button.WasClicked(app, rmId)) {
                    RemoveOptionFixup(f, oi);
                }
                iy = iy + app.Scale(32);
                oi = oi + 1;
            }
            if (table) {
                // Two-part column editor: display title + data field key.
                int half = (iw - app.Scale(54) - app.Scale(6)) / 2;
                optInput.Render(app, ix, iy, half, app.Scale(28));
                optFieldInput.Render(app, ix + half + app.Scale(6), iy, half, app.Scale(28));
                int addId = SmallBtn(app, Designer.T("Add", "添加"), 1, ix + iw - app.Scale(48), iy, app.Scale(48));
                if (Button.WasClicked(app, addId) && optSig.Get() != "") {
                    string col = optSig.Get();
                    if (optFieldSig.Get() != "") { col = col + ":" + optFieldSig.Get(); }
                    f.AddOption(col);
                    optSig.Set("");
                    optFieldSig.Set("");
                }
            } else {
                optInput.Render(app, ix, iy, iw - app.Scale(54), app.Scale(28));
                int addId = SmallBtn(app, Designer.T("Add", "添加"), 1, ix + iw - app.Scale(48), iy, app.Scale(48));
                if (Button.WasClicked(app, addId) && optSig.Get() != "") {
                    f.AddOption(optSig.Get());
                    optSig.Set("");
                }
            }
            iy = iy + app.Scale(38);
        }
        return iy + app.Scale(4);
    }

    /// Removes option `oi` from `f` and repairs dependent state so the UI never
    /// indexes past the shrunken list (the old direct RemoveOptionAt could
    /// leave a Tabs container's active tab / child tab out of range).
    void RemoveOptionFixup(FormField f, int oi) {
        f.RemoveOptionAt(oi);
        if (f.ftype == 36) {
            int ki = 0;
            while (ki < f.kids.Count) {
                if (f.kids[ki].childTab == oi) { f.kids[ki].childTab = 0; }
                else if (f.kids[ki].childTab > oi) { f.kids[ki].childTab = f.kids[ki].childTab - 1; }
                ki = ki + 1;
            }
        }
        if (f.uiState.Get() >= f.OptionCount() || f.uiState.Get() < 0) { f.uiState.Set(0); }
    }

    /// Display title of a table column option ("Title:field" convention).
    static string ColTitle(string opt) {
        int p = Designer.IndexOfColon(opt);
        if (p < 0) { return opt; }
        return opt.Substring(0, p);
    }

    /// Data field key of a table column option ("" when none was declared).
    static string ColField(string opt) {
        int p = Designer.IndexOfColon(opt);
        if (p < 0) { return ""; }
        return opt.Substring(p + 1, opt.Length - p - 1);
    }

    static int IndexOfColon(string s) {
        int i = 0;
        while (i < s.Length) {
            if (s.Substring(i, 1) == ":") { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// Properties tab for the root Window: window chrome (title/size/flags) plus
    /// the shared layout defaults applied to labelled input rows placed inside.
    int RenderWindowProps(App app, Canvas c, Theme t, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy, Designer.T("WINDOW", "窗口"), t.textTertiary, fs);
        iy = iy + app.Scale(20);

        iy = LabeledInput(app, c, t, Designer.T("Title", "标题"), winTitleInput, ix, iy, iw);

        // Save the whole designed window as a reusable project component; the
        // host IDE persists it and it then shows up under "My Components".
        int scId = SmallBtn(app, Designer.T("Save as component", "保存为组件"), 1, ix, iy, iw);
        if (Button.WasClicked(app, scId)) {
            saveCompRequested = true;
            msg = Designer.T("saving as component…", "正在保存为组件…");
        }
        iy = iy + app.Scale(36);

        winW = IntRow(app, c, t, Designer.T("Width", "宽度"), winW, 20, ix, iy, iw);
        iy = iy + app.Scale(36);
        winH = IntRow(app, c, t, Designer.T("Height", "高度"), winH, 20, ix, iy, iw);
        iy = iy + app.Scale(36);

        winResizable = ToggleRow(app, c, t, Designer.T("Resizable", "可调整大小"), winResizable, ix, iy, iw);
        iy = iy + app.Scale(34);
        winTool = ToggleRow(app, c, t, Designer.T("Tool window", "工具窗口"), winTool, ix, iy, iw);
        iy = iy + app.Scale(34);
        winCenter = ToggleRow(app, c, t, Designer.T("Center on show", "显示时居中"), winCenter, ix, iy, iw);
        iy = iy + app.Scale(34);
        winGlass = ToggleRow(app, c, t, Designer.T("Frosted glass", "毛玻璃效果"), winGlass, ix, iy, iw);
        iy = iy + app.Scale(40);

        c.DrawText(ix, iy, Designer.T("LAYOUT", "布局"), t.textTertiary, fs);
        iy = iy + app.Scale(20);
        List<string> posOpts = new List<string>();
        posOpts.Add(Designer.T("Left", "左")); posOpts.Add(Designer.T("Right", "右")); posOpts.Add(Designer.T("Top", "上"));
        labelPos = SegRow(app, c, t, Designer.T("Label position", "标签位置"), posOpts, labelPos, ix, iy, iw);
        iy = iy + app.Scale(54);
        List<string> szOpts = new List<string>();
        szOpts.Add(Designer.T("Large", "大")); szOpts.Add(Designer.T("Default", "默认")); szOpts.Add(Designer.T("Small", "小"));
        formSize = SegRow(app, c, t, Designer.T("Control size", "控件大小"), szOpts, formSize, ix, iy, iw);
        iy = iy + app.Scale(54);
        labelWidth = IntRow(app, c, t, Designer.T("Label width", "标签宽度"), labelWidth, 8, ix, iy, iw);
        iy = iy + app.Scale(36);
        bool showStar = !hideStar;
        showStar = ToggleRow(app, c, t, Designer.T("Required star", "必填星号"), showStar, ix, iy, iw);
        hideStar = !showStar;
        iy = iy + app.Scale(40);
        return iy;
    }

    /// Events tab: every event of the current target (window root or selected
    /// component), grouped by category (Pointer / Keyboard / Focus / Drag /
    /// Lifecycle / Value) and scrollable, with an inline handler editor.
    int RenderEventsTab(App app, Canvas c, Theme t, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        bool root = (sel == null);
        List<string> evs = Designer.WindowEventNames();
        if (!root) { evs = sel.Events(); }

        // Re-seed the shared handler editor whenever the target changes.
        bool tgtChanged = (root != evtRootPrev) || (!root && sel != evtSelPrev);
        evtRootPrev = root;
        evtSelPrev = sel;
        if (root) {
            if (tgtChanged || !evs.Contains(winEvtEditing)) {
                if (evs.Count > 0) { winEvtEditing = evs[0]; } else { winEvtEditing = ""; }
                evtSig.Set(WinGetHandler(winEvtEditing));
            }
        } else {
            if (tgtChanged || !evs.Contains(evtEditing)) {
                if (evs.Count > 0) { evtEditing = evs[0]; } else { evtEditing = ""; }
                evtSig.Set(sel.GetHandler(evtEditing));
            }
        }

        int rowH = app.Scale(26);
        List<string> groups = Designer.EventGroups();
        int gi = 0;
        while (gi < groups.Count) {
            string grp = groups[gi];
            int cnt = 0;
            int ck = 0;
            while (ck < evs.Count) {
                if (Designer.EventCategory(evs[ck]) == grp) { cnt = cnt + 1; }
                ck = ck + 1;
            }
            if (cnt > 0) {
                c.DrawText(ix, iy, Designer.GroupLabel(grp) + "  (" + Convert.ToString(cnt) + ")", t.textSecondary, fs);
                iy = iy + app.Scale(20);
                int ei = 0;
                while (ei < evs.Count) {
                    string ev = evs[ei];
                    if (Designer.EventCategory(ev) == grp) {
                        string cur;
                        if (root) { cur = winEvtEditing; } else { cur = evtEditing; }
                        if (ev == cur) {
                            c.FillRoundRect(ix - app.Scale(4), iy - app.Scale(2),
                                iw + app.Scale(8), rowH, app.Scale(4), t.bgActive);
                        }
                        c.DrawText(ix, iy + app.Scale(5), ev, t.textPrimary, fs);
                        string h;
                        if (root) { h = WinGetHandler(ev); } else { h = sel.GetHandler(ev); }
                        string hv = h;
                        int hColor = t.textTertiary;
                        if (hv == "") { hv = "—"; } else { hColor = t.success; }
                        c.DrawText(ix + app.Scale(92), iy + app.Scale(5),
                            Ellipsis.Fit(hv, iw - app.Scale(180), fs), hColor, fs);
                        int edId = SmallBtn(app, Designer.T("edit", "编辑"), 0, ix + iw - app.Scale(84), iy, app.Scale(40));
                        if (Button.WasClicked(app, edId)) {
                            if (root) { winEvtEditing = ev; evtSig.Set(WinGetHandler(ev)); }
                            else { evtEditing = ev; evtSig.Set(sel.GetHandler(ev)); }
                        }
                        int crId = SmallBtn(app, Designer.T("new", "新建"), 1, ix + iw - app.Scale(40), iy, app.Scale(40));
                        if (Button.WasClicked(app, crId)) {
                            if (root) {
                                winEvtEditing = ev;
                                string sug = "OnWindow" + ev;
                                WinSetHandler(ev, sug);
                                evtSig.Set(sug);
                            } else {
                                evtEditing = ev;
                                string sug = Designer.SuggestHandler(sel, ev);
                                sel.SetHandler(ev, sug);
                                evtSig.Set(sug);
                            }
                        }
                        iy = iy + rowH + app.Scale(4);
                    }
                    ei = ei + 1;
                }
                iy = iy + app.Scale(8);
            }
            gi = gi + 1;
        }

        string editEv;
        if (root) { editEv = winEvtEditing; } else { editEv = evtEditing; }
        iy = iy + app.Scale(2);
        c.DrawText(ix, iy, "on " + editEv + " +=", t.textTertiary, fs);
        iy = iy + app.Scale(18);
        evtInput.Render(app, ix, iy, iw, app.Scale(28));
        if (editEv != "") {
            if (root) { WinSetHandler(editEv, evtSig.Get()); }
            else { sel.SetHandler(editEv, evtSig.Get()); }
        }
        return iy + app.Scale(38);
    }

    /// The root Window's designable events (lifecycle / size / focus / keyboard).
    static List<string> WindowEventNames() {
        List<string> e = new List<string>();
        e.Add("Load"); e.Add("Show"); e.Add("Hide"); e.Add("Closing"); e.Add("Close");
        e.Add("Resize"); e.Add("Move"); e.Add("Minimize"); e.Add("Maximize"); e.Add("Restore");
        e.Add("Activate"); e.Add("Deactivate");
        e.Add("KeyDown"); e.Add("KeyUp");
        return e;
    }

    string WinGetHandler(string ev) {
        int i = 0;
        while (i < winEvtNames.Count) {
            if (winEvtNames[i] == ev) { return winEvtHandlers[i]; }
            i = i + 1;
        }
        return "";
    }

    void WinSetHandler(string ev, string h) {
        int i = 0;
        while (i < winEvtNames.Count) {
            if (winEvtNames[i] == ev) { winEvtHandlers[i] = h; return; }
            i = i + 1;
        }
        winEvtNames.Add(ev);
        winEvtHandlers.Add(h);
    }

    /// Logical category for an event name, so the Events tab can group a long
    /// event list under readable headings instead of overflowing.
    static string EventCategory(string ev) {
        if (ev == "Click" || ev == "DoubleClick" || ev == "RightClick"
            || ev == "MouseDown" || ev == "MouseUp" || ev == "Enter"
            || ev == "Leave" || ev == "Move" || ev == "Wheel" || ev == "Tap"
            || ev == "LongPress" || ev == "Swipe" || ev == "Hover") { return "Pointer"; }
        if (ev == "KeyDown" || ev == "KeyUp" || ev == "KeyPress") { return "Keyboard"; }
        if (ev == "Focus" || ev == "Blur" || ev == "Activate"
            || ev == "Deactivate") { return "Focus"; }
        if (ev == "DragStart" || ev == "Drag" || ev == "DragEnd" || ev == "Drop"
            || ev == "DragEnter" || ev == "DragLeave") { return "Drag & Drop"; }
        if (ev == "Resize" || ev == "Show" || ev == "Hide" || ev == "Open"
            || ev == "Close" || ev == "Closing" || ev == "Load"
            || ev == "Minimize" || ev == "Maximize" || ev == "Restore") { return "Lifecycle"; }
        return "Value & Data";
    }

    /// Display label for an event category heading. Category KEYS stay
    /// English (they are matched by string equality); only the heading text
    /// shown in the Events tab is translated.
    static string GroupLabel(string grp) {
        if (grp == "Pointer") { return Designer.T("Pointer", "指针"); }
        if (grp == "Keyboard") { return Designer.T("Keyboard", "键盘"); }
        if (grp == "Focus") { return Designer.T("Focus", "焦点"); }
        if (grp == "Drag & Drop") { return Designer.T("Drag & Drop", "拖放"); }
        if (grp == "Lifecycle") { return Designer.T("Lifecycle", "生命周期"); }
        if (grp == "Value & Data") { return Designer.T("Value & Data", "值与数据"); }
        return grp;
    }

    /// Category display order for the Events tab.
    static List<string> EventGroups() {
        List<string> g = new List<string>();
        g.Add("Pointer"); g.Add("Keyboard"); g.Add("Focus");
        g.Add("Drag & Drop"); g.Add("Lifecycle"); g.Add("Value & Data");
        return g;
    }

    /// Case-sensitive substring test used by the palette filter (which matches
    /// against the lowercase type key, so a lowercase query is enough).
    static bool Contains(string hay, string needle) {
        if (needle.Length == 0) { return true; }
        if (hay.Length < needle.Length) { return false; }
        int i = 0;
        while (i + needle.Length <= hay.Length) {
            if (hay.Substring(i, needle.Length) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    // --- Inspector row helpers ----------------------------------------------

    int LabeledInput(App app, Canvas c, Theme t, string label, Input inp, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy + app.Scale(7), label, t.textSecondary, fs);
        int lw = app.Scale(84);
        inp.Render(app, ix + lw, iy, iw - lw, app.Scale(28));
        return iy + app.Scale(36);
    }

    bool ToggleRow(App app, Canvas c, Theme t, string label, bool val, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy + app.Scale(7), label, t.textSecondary, fs);
        string disp = Designer.T("Off", "关");
        int ty = 0;
        if (val) { disp = Designer.T("On", "开"); ty = 3; }
        int id = SmallBtn(app, disp, ty, ix + iw - app.Scale(54), iy, app.Scale(54));
        bool nv = val;
        if (Button.WasClicked(app, id)) { nv = !val; }
        return nv;
    }

    int IntRow(App app, Canvas c, Theme t, string label, int val, int step, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        int bw = app.Scale(28);
        int valW = app.Scale(40);
        c.DrawText(ix, iy + app.Scale(7), label, t.textSecondary, fs);
        int pX = ix + iw - bw;
        int vX = pX - valW;
        int mX = vX - bw;
        int mId = SmallBtn(app, "-", 0, mX, iy, bw);
        c.DrawTextCentered(vX, iy, valW, app.Scale(28), Convert.ToString(val), t.textPrimary, fs);
        int pId = SmallIconBtn(app, "plus", 0, pX, iy, bw);
        int nv = val;
        if (Button.WasClicked(app, mId)) { nv = val - step; }
        if (Button.WasClicked(app, pId)) { nv = val + step; }
        if (nv < 0) { nv = 0; }
        return nv;
    }

    int SegRow(App app, Canvas c, Theme t, string title, List<string> opts, int cur, int ix, int iy, int iw) {
        int fs = t.fontSizeSmall;
        c.DrawText(ix, iy, title, t.textSecondary, fs);
        int segY = iy + app.Scale(18);
        int n = opts.Count;
        int gapx = app.Scale(4);
        int segW = (iw - (n - 1) * gapx) / n;
        int gx = ix;
        int res = cur;
        int i = 0;
        while (i < n) {
            int ty = 0;
            if (i == cur) { ty = 1; }
            int id = SmallBtn(app, opts[i], ty, gx, segY, segW);
            if (Button.WasClicked(app, id)) { res = i; }
            gx = gx + segW + gapx;
            i = i + 1;
        }
        return res;
    }

    // --- Status bar ----------------------------------------------------------

    void RenderStatus(App app, Canvas c, Theme t, int x, int y, int w) {
        int fs = t.fontSizeSmall;
        string s = Convert.ToString(fields.Count) + Designer.T(" fields", " 个组件");
        if (sel != null) {
            s = s + Designer.T("   ·   selected: ", "   ·   已选中：") + FormField.TypeName(sel.ftype) + " '" + sel.fname + "'";
        }
        if (activeContainer != null) {
            s = s + Designer.T("   ·   adding into: ", "   ·   添加到：") + FormField.TypeName(activeContainer.ftype);
            if (activeContainer.ftype == 36) {
                s = s + Designer.T(" tab ", " 标签页 ") + Convert.ToString(activeContainer.uiState.Get() + 1);
            }
        }
        c.DrawText(x, y, s + "     ·     " + msg, t.textTertiary, fs);
    }

    // --- Persistence (JSON) --------------------------------------------------

    /// Serialises the whole form as a human-editable JSON document: the form
    /// config plus an ordered "fields" array. This is the interchange format —
    /// hand-editing the JSON and loading it back reconfigures the form, so the
    /// designer is fully data-driven. Round-trips with LoadJson.
    ///   { name, labelPos, formSize, labelWidth, hideStar, showSubmit,
    ///     showReset, submit, fields:[ { type,label,name,placeholder,
    ///     required,change,options:[...] } ] }
    string SaveJson() {
        string o = "{\n";
        o = o + "  \"name\": \"" + JEsc(formNameSig.Get()) + "\",\n";
        o = o + "  \"labelPos\": " + Convert.ToString(labelPos) + ",\n";
        o = o + "  \"formSize\": " + Convert.ToString(formSize) + ",\n";
        o = o + "  \"labelWidth\": " + Convert.ToString(labelWidth) + ",\n";
        o = o + "  \"hideStar\": " + JB(hideStar) + ",\n";
        o = o + "  \"showSubmit\": " + JB(showSubmit) + ",\n";
        o = o + "  \"showReset\": " + JB(showReset) + ",\n";
        o = o + "  \"submit\": \"" + JEsc(submitSig.Get()) + "\",\n";
        o = o + "  \"fields\": [\n";
        o = o + EmitFields(fields, 2);
        o = o + "  ]\n}";
        return o;
    }

    string Indent(int depth) {
        string s = "";
        int i = 0;
        while (i < depth) { s = s + "  "; i = i + 1; }
        return s;
    }

    /// Serialises a list of fields (recursing into container `kids`).
    string EmitFields(List<FormField> lst, int depth) {
        string pad = Indent(depth);
        string o = "";
        int i = 0;
        while (i < lst.Count) {
            FormField f = lst[i];
            o = o + pad + "{\n";
            o = o + EmitFieldBody(f, depth + 1);
            o = o + pad + "}";
            if (i < lst.Count - 1) { o = o + ","; }
            o = o + "\n";
            i = i + 1;
        }
        return o;
    }

    /// Emits every bound event handler as an `"on<Event>": "name"` line, so
    /// the JSON round-trips all designer event bindings (not just Change).
    string EmitHandlers(FormField f, string p) {
        string o = "";
        List<string> evs = f.Events();
        int i = 0;
        while (i < evs.Count) {
            string h = f.GetHandler(evs[i]);
            if (h != "") {
                o = o + p + "\"on" + evs[i] + "\": \"" + JEsc(h) + "\",\n";
            }
            i = i + 1;
        }
        return o;
    }

    /// Parses an `"on<Event>": "name"` line into the field's handler table.
    /// `type` is emitted before handlers, so cur.Events() already reflects the
    /// correct field type by the time these lines are read.
    void ParseHandlerLine(FormField cur, string ln) {
        List<string> evs = cur.Events();
        int i = 0;
        while (i < evs.Count) {
            if (LineKey(ln, "on" + evs[i])) {
                cur.SetHandler(evs[i], JStr(JAfter(ln)));
                i = evs.Count;
            } else {
                i = i + 1;
            }
        }
    }

    string EmitFieldBody(FormField f, int depth) {
        string p = Indent(depth);
        string o = "";
        o = o + p + "\"type\": " + Convert.ToString(f.ftype) + ",\n";
        if (f.ftype == 100) {
            o = o + p + "\"custom\": \"" + JEsc(f.customKind) + "\",\n";
        }
        o = o + p + "\"label\": \"" + JEsc(f.label) + "\",\n";
        o = o + p + "\"name\": \"" + JEsc(f.fname) + "\",\n";
        o = o + p + "\"placeholder\": \"" + JEsc(f.placeholder) + "\",\n";
        o = o + p + "\"bind\": \"" + JEsc(f.bindPath) + "\",\n";
        o = o + p + "\"bindProp\": \"" + JEsc(f.bindProp) + "\",\n";
        o = o + p + "\"required\": " + JB(f.required) + ",\n";
        o = o + p + "\"span\": " + Convert.ToString(f.span) + ",\n";
        o = o + p + "\"defOn\": " + JB(f.defOn) + ",\n";
        o = o + p + "\"childTab\": " + Convert.ToString(f.childTab) + ",\n";
        o = o + p + "\"activeTab\": " + Convert.ToString(f.uiState.Get()) + ",\n";
        o = o + EmitHandlers(f, p);
        o = o + p + "\"options\": [" + JOpts(f) + "]";
        if (f.IsContainer()) {
            o = o + ",\n" + p + "\"kids\": [\n";
            o = o + EmitFields(f.kids, depth + 1);
            o = o + p + "]\n";
        } else {
            o = o + "\n";
        }
        return o;
    }

    /// Rebuilds the form from a JSON document produced by SaveJson (or hand
    /// written). Tolerant of pretty-printed whitespace: it scans line by line,
    /// keys before "fields" set the form config, then each { ... } block in the
    /// array becomes a field.
    void LoadJson(string s) {
        List<string> lines = Serialize.SplitLines(s);
        fields = new List<FormField>();
        // Stack of open field objects; a new `{` becomes a child of the field
        // on top of the stack (its container), or a top-level field when empty.
        List<FormField> stack = new List<FormField>();
        bool inFields = false;
        int total = 0;
        int i = 0;
        while (i < lines.Count) {
            string ln = Trim(lines[i]);
            if (!inFields) {
                if (LineKey(ln, "fields")) {
                    inFields = true;
                } else if (LineKey(ln, "name")) {
                    formNameSig.Set(JStr(JAfter(ln)));
                } else if (LineKey(ln, "labelPos")) {
                    labelPos = JInt(JAfter(ln));
                } else if (LineKey(ln, "formSize")) {
                    formSize = JInt(JAfter(ln));
                } else if (LineKey(ln, "labelWidth")) {
                    labelWidth = JInt(JAfter(ln));
                } else if (LineKey(ln, "hideStar")) {
                    hideStar = JBool(JAfter(ln));
                } else if (LineKey(ln, "showSubmit")) {
                    showSubmit = JBool(JAfter(ln));
                } else if (LineKey(ln, "showReset")) {
                    showReset = JBool(JAfter(ln));
                } else if (LineKey(ln, "submit")) {
                    submitSig.Set(JStr(JAfter(ln)));
                }
            } else {
                if (StartsWith(ln, "{")) { total = total + 1; }
                i = ParseFieldLine(lines, i, ln, fields, stack);
            }
            i = i + 1;
        }
        seq = total;
        sel = null;
        selPrev = null;
        activeContainer = null;
    }

    /// Handles one line inside the "fields" array (shared by LoadJson and
    /// ParseComponentFields); returns the possibly-advanced line index (the
    /// "options" array can span several lines).
    int ParseFieldLine(List<string> lines, int i, string ln,
            List<FormField> topList, List<FormField> stack) {
        if (StartsWith(ln, "{")) {
            FormField nf = new FormField(0);
            nf.SetOptionsFrom("");
            if (stack.Count > 0) {
                stack[stack.Count - 1].kids.Add(nf);
            } else {
                topList.Add(nf);
            }
            stack.Add(nf);
        } else if (StartsWith(ln, "}")) {
            if (stack.Count > 0) { stack.RemoveAt(stack.Count - 1); }
        } else if (stack.Count > 0) {
            FormField cur = stack[stack.Count - 1];
            if (LineKey(ln, "type")) {
                cur.ftype = JInt(JAfter(ln));
            } else if (LineKey(ln, "custom")) {
                cur.customKind = JStr(JAfter(ln));
            } else if (LineKey(ln, "label")) {
                cur.label = JStr(JAfter(ln));
            } else if (LineKey(ln, "name")) {
                cur.fname = JStr(JAfter(ln));
                cur.name = cur.fname;
            } else if (LineKey(ln, "placeholder")) {
                cur.placeholder = JStr(JAfter(ln));
            } else if (LineKey(ln, "bind")) {
                cur.bindPath = JStr(JAfter(ln));
            } else if (LineKey(ln, "bindProp")) {
                cur.bindProp = JStr(JAfter(ln));
            } else if (LineKey(ln, "required")) {
                cur.required = JBool(JAfter(ln));
            } else if (LineKey(ln, "span")) {
                cur.span = JInt(JAfter(ln));
            } else if (LineKey(ln, "defOn")) {
                cur.defOn = JBool(JAfter(ln));
            } else if (LineKey(ln, "childTab")) {
                cur.childTab = JInt(JAfter(ln));
            } else if (LineKey(ln, "activeTab")) {
                cur.uiState.Set(JInt(JAfter(ln)));
            } else if (LineKey(ln, "change")) {
                cur.SetHandler("Change", JStr(JAfter(ln)));
            } else if (LineKey(ln, "options")) {
                string rawOptions = JAfter(ln);
                while (!JsonArrayClosed(rawOptions) && i + 1 < lines.Count) {
                    i = i + 1;
                    rawOptions = rawOptions + "\n" + Trim(lines[i]);
                }
                ParseOptions(cur, rawOptions);
            } else {
                ParseHandlerLine(cur, ln);
            }
        }
        return i;
    }

    /// Parses just the "fields" array of a design JSON into a fresh list,
    /// used to instantiate saved user components without touching the form.
    List<FormField> ParseComponentFields(string s) {
        List<string> lines = Serialize.SplitLines(s);
        List<FormField> outp = new List<FormField>();
        List<FormField> stack = new List<FormField>();
        bool inFields = false;
        int i = 0;
        while (i < lines.Count) {
            string ln = Trim(lines[i]);
            if (!inFields) {
                if (LineKey(ln, "fields")) { inFields = true; }
            } else {
                i = ParseFieldLine(lines, i, ln, outp, stack);
            }
            i = i + 1;
        }
        return outp;
    }

    // --- JSON helpers --------------------------------------------------------

    string JB(bool b) {
        if (b) { return "true"; }
        return "false";
    }

    string JEsc(string s) {
        string r = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\\") { r = r + "\\\\"; }
            else if (ch == "\"") { r = r + "\\\""; }
            else if (ch == "\n") { r = r + "\\n"; }
            else if (ch == "\t") { r = r + "\\t"; }
            else { r = r + ch; }
            i = i + 1;
        }
        return r;
    }

    string JUn(string ch) {
        if (ch == "n") { return "\n"; }
        if (ch == "t") { return "\t"; }
        return ch;
    }

    string JOpts(FormField f) {
        string r = "";
        int o = 0;
        while (o < f.OptionCount()) {
            if (o > 0) { r = r + ", "; }
            r = r + "\"" + JEsc(f.OptionAt(o)) + "\"";
            o = o + 1;
        }
        return r;
    }

    /// Reads quoted strings out of a JSON array literal like ["a", "b"].
    bool JsonArrayClosed(string raw) {
        bool quoted = false;
        bool escaped = false;
        int i = 0;
        while (i < raw.Length) {
            string ch = raw.Substring(i, 1);
            if (escaped) {
                escaped = false;
            } else if (ch == "\\") {
                escaped = true;
            } else if (ch == "\"") {
                quoted = !quoted;
            } else if (ch == "]" && !quoted) {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    void ParseOptions(FormField f, string raw) {
        f.SetOptionsFrom("");
        int i = 0;
        while (i < raw.Length) {
            if (raw.Substring(i, 1) == "\"") {
                string acc = "";
                int j = i + 1;
                bool done = false;
                while (j < raw.Length && !done) {
                    string ch = raw.Substring(j, 1);
                    if (ch == "\\" && j + 1 < raw.Length) {
                        acc = acc + JUn(raw.Substring(j + 1, 1));
                        j = j + 2;
                    } else if (ch == "\"") {
                        done = true;
                    } else {
                        acc = acc + ch;
                        j = j + 1;
                    }
                }
                f.AddOption(acc);
                i = j + 1;
            } else {
                i = i + 1;
            }
        }
    }

    // True when the trimmed line's key (the token in the leading "...") equals k.
    bool LineKey(string line, string k) {
        return StartsWith(line, "\"" + k + "\"");
    }

    bool StartsWith(string s, string p) {
        if (s.Length < p.Length) { return false; }
        return s.Substring(0, p.Length) == p;
    }

    // Everything after the first ':' on a line (the raw value, still with any
    // trailing comma and surrounding spaces).
    string JAfter(string line) {
        int i = 0;
        while (i < line.Length) {
            if (line.Substring(i, 1) == ":") {
                return Trim(line.Substring(i + 1, line.Length - i - 1));
            }
            i = i + 1;
        }
        return "";
    }

    string Trim(string s) {
        int a = 0;
        int b = s.Length;
        while (a < b) {
            string ch = s.Substring(a, 1);
            if (ch == " " || ch == "\t" || ch == "\r") { a = a + 1; }
            else { break; }
        }
        while (b > a) {
            string ch = s.Substring(b - 1, 1);
            if (ch == " " || ch == "\t" || ch == "\r") { b = b - 1; }
            else { break; }
        }
        return s.Substring(a, b - a);
    }

    string StripComma(string s) {
        string t = Trim(s);
        if (t.Length > 0 && t.Substring(t.Length - 1, 1) == ",") {
            return Trim(t.Substring(0, t.Length - 1));
        }
        return t;
    }

    // Decodes a JSON scalar value: a quoted string (unescaped) or a bare token.
    string JStr(string raw) {
        string t = Trim(raw);
        if (t.Length == 0) { return ""; }
        if (t.Substring(0, 1) == "\"") {
            string acc = "";
            int j = 1;
            bool done = false;
            while (j < t.Length && !done) {
                string ch = t.Substring(j, 1);
                if (ch == "\\" && j + 1 < t.Length) {
                    acc = acc + JUn(t.Substring(j + 1, 1));
                    j = j + 2;
                } else if (ch == "\"") {
                    done = true;
                } else {
                    acc = acc + ch;
                    j = j + 1;
                }
            }
            return acc;
        }
        return StripComma(t);
    }

    int JInt(string raw) {
        string t = StripComma(raw);
        if (t.Length == 0) { return 0; }
        return Convert.ToInt32(t);
    }

    bool JBool(string raw) {
        return StripComma(raw) == "true";
    }
}
