using System;

namespace Gui;

/// Name -> Action table backing the JSON UI contract. A view document stores
/// only handler *names* (e.g. `"onClick": "save"`); the business code registers
/// the matching Action once with Handle("save", MyPage.Save). The loader then
/// resolves each `on<Event>` name to its Action and subscribes it to the
/// control's event (see UiDoc.Wire). Keeps designer/JSON and code decoupled:
/// neither side references the other directly, only shared string names.
class HandlerRegistry {
    List<string> names;
    List<Action> actions;

    static HandlerRegistry Create() {
        HandlerRegistry r = new HandlerRegistry();
        r.names = new List<string>();
        r.actions = new List<Action>();
        return r;
    }

    /// Registers (or replaces) the Action bound to `name`.
    void Set(string name, Action a) {
        int i = 0;
        while (i < names.Count) {
            if (names[i] == name) { actions[i] = a; return; }
            i = i + 1;
        }
        names.Add(name);
        actions.Add(a);
    }

    bool Has(string name) {
        int i = 0;
        while (i < names.Count) {
            if (names[i] == name) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// The Action bound to `name`, or null when unregistered.
    Action Get(string name) {
        int i = 0;
        while (i < names.Count) {
            if (names[i] == name) { return actions[i]; }
            i = i + 1;
        }
        return null;
    }
}
