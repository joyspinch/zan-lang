        t.warningPressed = -3572720;
        t.error          = -3133360;
        t.errorHover     = -2205843;
        t.errorPressed   = -5562561;

        t.textPrimary    = -14736859;
        t.textSecondary  = -13420999;
        t.textTertiary   = -9012094;
        t.textDisabled   = -4013374;
        t.textInverse    = -1;

        t.bgPrimary      = -1;
        t.bgSecondary    = -328964;
        t.bgTertiary     = -789515;
        t.bgHover        = -789515;
