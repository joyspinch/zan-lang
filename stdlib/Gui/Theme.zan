using System;

namespace Gui;

/// NaiveUI theme tokens. All colors as 0xAARRGGBB packed into int.
class Theme {
    int primary;
    int primaryHover;
    int primaryPressed;
    int info;
    int infoHover;
    int infoPressed;
    int success;
    int successHover;
    int successPressed;
    int warning;
    int warningHover;
    int warningPressed;
    int error;
    int errorHover;
    int errorPressed;

    int textPrimary;
    int textSecondary;
    int textTertiary;
    int textDisabled;
    int textInverse;

    int bgPrimary;
    int bgSecondary;
    int bgTertiary;
    int bgHover;
    int bgActive;
    int bgDisabled;

    int borderPrimary;
    int borderSecondary;
    int borderHover;
    int borderFocus;
    int divider;
    int overlay;

    // 1 when this is a frosted-glass theme: panels blur the backdrop behind
    // them (via Canvas.BlurRect) and fill with a translucent tint.
    int glass;

    // 1 when the content backdrop is a vertical gradient (bgGradTop ->
    // bgGradBottom) instead of a flat bgPrimary -- modern AI / Aurora / Glass
    // wallpapers. Panels then use translucent surfaces so it shows through.
    int gradient;
    int bgGradTop;
    int bgGradBottom;

    // 1 for the neumorphism skin: controls share the page colour and are
    // raised/inset by a light top-left + dark bottom-right soft shadow pair
    // (see Emboss helpers in the shared widgets), rather than borders/fills.
    int neu;
    // 1 for the neo-brutalism skin: a solid, offset (un-blurred) drop shadow,
    // thick hard borders and sharp corners (paired with radius 0 / thick
    // borderWidth tokens and an opaque shadowColor).
    int brutal;

    // Animated backdrop effect for this skin (BackdropFx.Kind* constant, 0 =
    // none). App.RenderBackground layers the effect over the static wallpaper
    // snapshot on throttled animation frames so skins carry signature motion.
    int fx;

    int scrollbar;
    int scrollbarHover;

    int borderRadiusSmall;
    int borderRadiusMedium;
    int borderRadiusLarge;
    int borderWidth;

    int fontSizeTiny;
    int fontSizeSmall;
    int fontSizeMedium;
    int fontSizeLarge;
    int fontSizeHuge;

    int heightTiny;
    int heightSmall;
    int heightMedium;
    int heightLarge;

    int paddingTiny;
    int paddingSmall;
    int paddingMedium;
    int paddingLarge;

    int gapSmall;
    int gapMedium;
    int gapLarge;

    int iconSizeSmall;
    int iconSizeMedium;
    int iconSizeLarge;
    int iconSizeCaption;

    int shadowColor;

    int animFastMs;
    int animMediumMs;
    int animSlowMs;

