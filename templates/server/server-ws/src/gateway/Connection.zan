using System;
using System.Net.Sockets;

namespace WsGateway;

/// <summary>One connected WebSocket client tracked by the gateway. Holds the
/// socket and a TcpClient so the gateway can push/broadcast frames to it from
/// any coroutine, independently of the coroutine reading this client.</summary>
class Connection {
    int id;
    int sock;
    TcpClient client;
    bool alive;

    Connection(int id, int sock) {
        this.id = id;
        this.sock = sock;
        this.client = TcpClient.FromSocket(sock);
        this.alive = true;
    }

    static Connection Create(int id, int sock) {
        return new Connection(id, sock);
    }
}
