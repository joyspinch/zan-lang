using System;
using WsGateway;

// {{NAME}} -- gateway-worker WebSocket service.
//
// main.zan only reads config and starts the gateway; connection handling is in
// src/gateway and the business logic in src/worker (ChatWorker). config/app.json
// is loaded at runtime and is NOT compiled into the binary.
class Program {
    static async void Main() {
        Config.Load("config/app.json");
        Gateway gw = Gateway.Create(
            Config.Str("server", "host", "127.0.0.1"),
            Config.Int("server", "port", 8090));
        await gw.Start();
    }
}
