using System;
using System.IO;
using System.Json;

namespace ZanWeb;

/// <summary>
/// Runtime configuration, loaded from an external JSON file (config/app.json)
/// that is NOT compiled into the binary: edit it and restart to change host,
/// port, limits, database or cache without recompiling. A missing file or key
/// falls back to the default passed at each call site, so the app always runs.
/// </summary>
class Config {
    static bool loaded = false;
    static JsonValue root = JsonValue.NewObject();

    /// <summary>Loads the first config file found among a few conventional
    /// locations (relative to the working directory / next to the exe).</summary>
    static void Load(string relPath) {
        loaded = true;
        List<string> cands = new List<string>();
        if (relPath.Length > 0) { cands.Add(relPath); }
        cands.Add("config/app.json");
        cands.Add("app.json");
        cands.Add("../config/app.json");
        int i = 0;
        while (i < cands.Count) {
            if (File.Exists(cands[i])) {
                string txt = File.ReadAllText(cands[i]);
                if (txt.Length > 0) {
                    root = JsonValue.ParseLenient(txt);
                    Console.WriteLine("[config] loaded " + cands[i]);
                    return;
                }
            }
            i = i + 1;
        }
        Console.WriteLine("[config] no config file found; using built-in defaults");
    }

    static void Ensure() {
        if (!loaded) { Config.Load("config/app.json"); }
    }

    /// <summary>Returns a config section object (empty object when absent).</summary>
    static JsonValue Section(string name) {
        Config.Ensure();
        JsonValue v = root.Get(name);
        if (v == null) { return JsonValue.NewObject(); }
        if (!v.IsObject()) { return JsonValue.NewObject(); }
        return v;
    }

    static string Str(string section, string key, string dflt) {
        return Config.Section(section).Str(key, dflt);
    }

    static int Int(string section, string key, int dflt) {
        return Config.Section(section).Int(key, dflt);
    }

    static bool Bool(string section, string key, bool dflt) {
        return Config.Section(section).Bool(key, dflt);
    }
}
