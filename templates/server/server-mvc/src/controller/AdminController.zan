using System;

namespace ZanWeb;

/// <summary>Admin-only endpoints. The menu action returns the navigation tree
/// derived from every [Menu] route -- see MenuBuilder.</summary>
class AdminController {
    [Api(get, route="/admin/menu", title="管理菜单", auth, rank=9, menu)]
    static void Menu(HttpContext ctx) {
        Controller.Ok(ctx, MenuBuilder.Json(App.Web()));
    }
}
