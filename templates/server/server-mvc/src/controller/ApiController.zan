using System;

namespace ZanWeb;

/// <summary>JSON API actions: status, echo, auth (login / me) and the streamed
/// upload endpoint.</summary>
class ApiController {
    static void Status(HttpContext ctx) {
        ctx.Json(App.Web().StatusJson());
    }

    static void Echo(HttpContext ctx) {
        string msg = ctx.Form("msg");
        if (msg.Length == 0) { msg = ctx.Body(); }
        Controller.Ok(ctx, "{\"echo\":\"" + JsonStr.Escape(msg) + "\"}");
    }

    static void Login(HttpContext ctx) {
        Validator v = Validator.Create();
        v.Require(ctx.Form("user"), "user");
        v.MaxLen(ctx.Form("user"), 32, "user");
        v.Require(ctx.Form("pass"), "pass");
        v.MaxLen(ctx.Form("pass"), 64, "pass");
        if (!v.Ok()) {
            ctx.Status(422, "Unprocessable Entity");
            ctx.Api("1003", "validation failed", v.ErrorsJson());
            return;
        }
        string user = ctx.Form("user");
        string pass = ctx.Form("pass");
        // Demo credential check -- replace with your user store.
        if (user == "admin" && pass == "admin") {
            string token = App.Web().sessions.Issue("1", WebApp.NowSeconds());
            ctx.SetCookie("zsession", token, 86400);
            Controller.Ok(ctx, "{\"token\":\"" + token + "\"}");
        } else {
            Controller.Fail(ctx, 401, "1001", "bad credentials");
        }
    }

    static void Me(HttpContext ctx) {
        string uid = ctx.state.Get("uid");
        Controller.Ok(ctx, "{\"uid\":\"" + uid + "\"}");
    }

    static void Upload(HttpContext ctx) {
        // Large bodies are streamed to disk in 64KB chunks (binary-safe);
        // memory stays flat even for multi-hundred-MB uploads.
        string path = ctx.state.Get("upload_path");
        string size = ctx.state.Get("upload_size");
        if (path.Length == 0) {
            Controller.Fail(ctx, 400, "1002", "no upload body");
            return;
        }
        Controller.Ok(ctx, "{\"path\":\"" + JsonStr.Escape(path)
            + "\",\"bytes\":" + size + "}");
    }
}
