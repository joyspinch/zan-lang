using System;

namespace ZanWeb;

/// <summary>Serves the broker management dashboard (single page that polls the
/// /iot/* JSON APIs).</summary>
class HomeController {
    [Get]
    [Route("/")]
    [Title("控制台")]
    static void Index(HttpContext ctx) {
        ViewData d = ViewData.Create();
        d.Set("title", "{{NAME}} IoT Console");
        ctx.Html(App.Web().RenderPage("index", d));
    }
}
