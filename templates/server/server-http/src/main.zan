using System;
using System.Net.Sockets;
using System.Net.Http;

// {{NAME}} -- minimal HTTP server on the Zan coroutine runtime.
// Each connection is served on its own coroutine (see HttpServer in the
// stdlib); for a full framework (routing/{param}, rate limiting, auth,
// hooks, in-memory views) use the "Web MVC Framework" template instead.
class Program {
    static async int Run() {
        HttpRouter router = HttpRouter.Create();
        router.Get("/", "<h1>{{NAME}}</h1><p>Hello from Zan!</p>");
        router.Get("/ping", "pong");

        Socket.Initialize();
        TcpListener listener = TcpListener.Create("127.0.0.1", 8080);
        listener.Start();
        Console.WriteLine("{{NAME}} listening on http://127.0.0.1:8080");
        while (true) {
            int client = await listener.AcceptAsync();
            if (client >= 0) {
                Task.Spawn(Serve(client, router));
            }
        }
        return 0;
    }

    static async void Serve(int sock, HttpRouter router) {
        TcpClient client = TcpClient.FromSocket(sock);
        bool keepAlive = true;
        while (keepAlive) {
            string raw = await client.RecvReuseAsync();
            if (raw.Length == 0) { break; }
            HttpRequest req = HttpRequest.Parse(raw);
            keepAlive = req.keepAlive;
            HttpResponse resp = router.Match(req);
            resp = resp.SetKeepAlive(keepAlive);
            int _sent = await client.SendAsync(resp.Build());
            if (!keepAlive) { break; }
        }
        client.Close();
    }

    static void Main() {
        int r = await Run();
    }
}
