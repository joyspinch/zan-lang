// Stage-3 async lowering: await points split the $resume body into a state
// machine. An async method awaiting another registers itself as the sub-task's
// awaiter, enqueues the sub via zan_co_ready, and suspends (ret void); the
// resume-k case reloads live values and reads the sub-frame result. A non-async
// Main drives the scheduler (init/ready/run) for a root await.
// See docs/ASYNC_CPS_DESIGN.md.
class Program {
    static async int InnerAsync(int x) {
        int r = x + 100;
        return r;
    }

    static async int OuterAsync(int y) {
        int inner = await InnerAsync(y);
        return inner + 21;
    }

    static void Main() {
        int v = await OuterAsync(21);
        Console.WriteLine(v);
    }
}
