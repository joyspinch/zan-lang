class Math {
    static int Add(int a, int b) {
        return a + b;
    }

    static int Fib(int n) {
        if (n < 2) {
            return n;
        }
        return Fib(n - 1) + Fib(n - 2);
    }

    static int Main() {
        int s = Add(2, 3);
        int f = Fib(10);
        return s + f;
    }
}
