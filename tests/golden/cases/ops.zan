class Ops {
    static int Main() {
        int a = 6;
        int b = 3;
        int r = 0;
        if (a > b && b > 0) { r = r + 1; }
        if (a == 6 || b == 0) { r = r + 2; }
        r = r + (a & b);
        r = r + (a | b);
        r = r + (a ^ b);
        r = r + (a << 1);
        r = r + (a >> 1);
        if (!(a < b)) { r = r + 100; }
        return r;
    }
}
