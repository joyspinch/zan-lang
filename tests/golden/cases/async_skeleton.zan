// Stage-2 async lowering: each async method becomes a heap frame + ramp +
// resume state machine (no await splitting yet). See docs/ASYNC_CPS_DESIGN.md.
class Program {
    static async int ComputeAsync(int x) {
        int result = x * 2;
        return result;
    }

    static async int ChainAsync(int a, int b) {
        return a + b;
    }

    static int Main() {
        return 0;
    }
}

class Counter {
    int n;
    async int NextAsync() {
        return n + 1;
    }
}
