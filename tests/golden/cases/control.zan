class Loops {
    static int Sum(int n) {
        int total = 0;
        int i = 0;
        while (i < n) {
            total = total + i;
            i = i + 1;
        }
        return total;
    }

    static int Factorial(int n) {
        int result = 1;
        for (int k = 1; k <= n; k = k + 1) {
            result = result * k;
        }
        return result;
    }

    static int Main() {
        int a = Sum(5);
        int b = Factorial(4);
        if (a > b) {
            return a;
        } else {
            return b;
        }
    }
}
