// await Socket.ReadReady(fd) / Socket.WriteReady(fd): readiness-based suspension
// driven by the IO reactor (S4b-2, path A). Each await lowers to a one-shot
// watcher registration zan_io_wait_co(fd, interest, frame, step) followed by a
// suspend; the resume-k block continues once the fd is ready. interest is 1 for
// ReadReady, 2 for WriteReady. The scheduler's idle path pumps the reactor via
// zan_io_pump. A value computed before the await (`a`) survives the suspension.
class Program {
    static async int Serve(int fd) {
        int a = fd + 1;
        await Socket.ReadReady(fd);
        await Socket.WriteReady(fd);
        return a;
    }
    static void Main() {
        int v = await Serve(3);
        Console.WriteLine(v);
    }
}
