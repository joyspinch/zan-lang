enum Color { Red, Green, Blue }

class Palette {
    static int Weight(Color c) {
        switch (c) {
            case Color.Red: return 1;
            case Color.Green: return 2;
            case Color.Blue: return 3;
            default: return 0;
        }
    }
    static int Main() {
        return Weight(Color.Green) + Weight(Color.Blue);
    }
}
