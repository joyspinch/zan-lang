// await Task.Delay(ms): a time-based suspension driven by the scheduler's timer
// reactor. A value (`a`) computed before the delay survives across it, and the
// scheduler sleeps to each deadline before resuming. Work(10) -> a=11, b=12 -> 23.
class Program {
    static async int Work(int x) {
        int a = x + 1;
        await Task.Delay(20);
        int b = a + 1;
        await Task.Delay(20);
        return a + b;
    }
    static void Main() {
        int v = await Work(10);
        Console.WriteLine(v);
    }
}
