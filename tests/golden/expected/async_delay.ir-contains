%zan.co.timer = type { ptr, i64, ptr, ptr }
@__zan_co_timers = internal global ptr null
define void @zan_co_delay(i64 %0, ptr %1, ptr %2) {
store ptr %tn, ptr @__zan_co_timers
define void @"Program_Work$resume"(ptr %0)
switch i32 %state, label %co.start
i32 1, label %co.resume
i32 2, label %co.resume
call void @zan_co_delay(i64 20, ptr %0, ptr @"Program_Work$resume")
define void @zan_co_sched_run()
%t.head = load ptr, ptr @__zan_co_timers
