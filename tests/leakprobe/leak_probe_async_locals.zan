using System;

namespace LeakProbeAsyncLocals;

class Node {
    public int v;
    public Node(int x) { v = x; }
}

class Program {
    static async int Work(int i) {
        Node n = new Node(i);
        string s = "n=" + i;
        await Task.Delay(1);
        Console.WriteLine(n.v);
        Console.WriteLine(s);
        return i;
    }

    static void Main() {
        int i = 0;
        while (i < 5) {
            int r = await Work(i);
            Console.WriteLine(r);
            i = i + 1;
        }
        Console.WriteLine(i);
    }
}
