using System;
using System.Collections;
namespace Zc;

enum TokKind { Num, Plus, Minus, Star, End }

class Token {
    public TokKind kind;
    public int num;
    public Token(TokKind k, int v) { kind = k; num = v; }
}

class Lexer {
    public List<Token> Lex(string src) {
        List<Token> toks = new List<Token>();
        int i = 0;
        int n = src.Length;
        while (i < n) {
            char c = src[i];
            if (c == ' ') {
                i = i + 1;
            } else if (c >= '0' && c <= '9') {
                int v = 0;
                char d = src[i];
                while (i < n && d >= '0' && d <= '9') {
                    v = v * 10 + ((int)d - (int)'0');
                    i = i + 1;
                    if (i < n) { d = src[i]; } else { d = ' '; }
                }
                toks.Add(new Token(TokKind.Num, v));
            } else {
                if (c == '+') { toks.Add(new Token(TokKind.Plus, 0)); }
                else if (c == '-') { toks.Add(new Token(TokKind.Minus, 0)); }
                else if (c == '*') { toks.Add(new Token(TokKind.Star, 0)); }
                i = i + 1;
            }
        }
        toks.Add(new Token(TokKind.End, 0));
        return toks;
    }
}
