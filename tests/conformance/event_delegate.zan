using System;

delegate void Action();

class Event {
    List<Action> hs;

    static Event Create() {
        Event e = new Event();
        e.hs = new List<Action>();
        return e;
    }

    static Event op_add(Event self, Action h) {
        self.hs.Add(h);
        return self;
    }

    static Event op_sub(Event self, Action h) {
        int i = self.hs.Count - 1;
        while (i >= 0) {
            if (self.hs[i] == h) {
                self.hs.RemoveAt(i);
                return self;
            }
            i = i - 1;
        }
        return self;
    }

    void Raise() {
        int i = 0;
        while (i < hs.Count) {
            Action a = hs[i];
            a();
            i = i + 1;
        }
    }

    int Count() { return hs.Count; }
}

class Program {
    static void Hi() { Console.WriteLine("hi"); }
    static void Bye() { Console.WriteLine("bye"); }

    static void Main() {
        Event click = Event.Create();
        click += Program.Hi;
        click += Program.Bye;
        click += () => { Console.WriteLine("lambda"); };
        click.Raise();
        Console.WriteLine(Convert.ToString(click.Count()));

        click -= Program.Bye;
        click.Raise();
        Console.WriteLine(Convert.ToString(click.Count()));
    }
}
