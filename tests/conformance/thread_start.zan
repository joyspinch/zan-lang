using System;
using System.Threading;

namespace Conf;

// Verifies Thread.Start spawns real OS threads that run a delegate: both a
// static method group (Work) and a lambda. AtomicInt makes the shared counter
// race-free and lets the main thread spin-wait for a deterministic result
// regardless of scheduling.
class Prog {
    static AtomicInt counter;

    static void Work() {
        Prog.counter.Add(3);
    }

    static void Main() {
        Prog.counter = new AtomicInt(0);

        int i = 0;
        while (i < 4) {
            Thread.Start(Prog.Work);
            i = i + 1;
        }
        Thread.Start(() => { Prog.counter.Add(100); });

        // 4 * 3 + 100 = 112. Wait until every worker has applied its delta.
        while (Prog.counter.Load() < 112) {
            Thread.Sleep(1);
        }
        Console.WriteLine(Convert.ToString(Prog.counter.Load()));
    }
}
