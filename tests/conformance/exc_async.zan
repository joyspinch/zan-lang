// Exceptions: an exception thrown by an awaited async coroutine crosses the
// await/suspend boundary and is caught by the awaiting coroutine's try/catch.
class Program {
    static async int inner(int x) {
        if (x < 0) { throw new Exception("neg"); }
        return x + 100;
    }
    static async int outer(int y) {
        try {
            int v = await inner(y);
            return v + 21;
        } catch (Exception e) {
            Console.WriteLine("outer caught:" + e.Message);
            return -1;
        }
    }
    static void Main() {
        Console.WriteLine(await outer(-5));
        Console.WriteLine(await outer(21));
    }
}
