// Conformance: method overload resolution by arity. Same-named methods that
// differ in parameter count (and static vs instance) must each dispatch to the
// correct definition instead of always binding to the first-declared one.
using System;

class Box {
    int seed;

    Box() { this.seed = 0; }

    static Box Make(int seed) {
        Box b = new Box();
        b.seed = seed;
        return b;
    }

    // instance overloads, arity 0 / 1 / 2
    int Combine() { return this.seed; }
    int Combine(int a) { return this.seed + a; }
    int Combine(int a, int b) { return this.seed + a * 10 + b * 100; }

    // static overloads, arity 1 / 3 (also collides with instance name)
    static int Sum(int a) { return a; }
    static int Sum(int a, int b, int c) { return a + b + c; }
}

class Program {
    static void Main() {
        Box box = Box.Make(1);
        Console.WriteLine(box.Combine());          // 1
        Console.WriteLine(box.Combine(2));         // 3
        Console.WriteLine(box.Combine(2, 3));      // 1 + 20 + 300 = 321
        Console.WriteLine(Box.Sum(7));             // 7
        Console.WriteLine(Box.Sum(7, 8, 9));       // 24
    }
}
