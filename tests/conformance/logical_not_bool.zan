using System;
using System.IO;
namespace Conf;

// Regression: `!` on a bool returned inline from a function that makes native
// calls (File.Exists -> fopen) must be a logical not, not a bitwise not. A
// bitwise not of a bool materialized wider than i1 stays truthy and flips the
// branch, so both `if (!File.Exists(x))` arms are exercised here.
class T {
    static void Main() {
        string p = "lnot_probe.tmp";
        File.WriteAllText(p, "x");

        if (!File.Exists(p)) {
            Console.WriteLine("BUG-missing");
        } else {
            Console.WriteLine("found");
        }

        File.Delete(p);

        if (!File.Exists(p)) {
            Console.WriteLine("gone");
        } else {
            Console.WriteLine("BUG-present");
        }
    }
}
