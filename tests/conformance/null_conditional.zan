class Box {
    public int val;
    public string name;
    public Box inner;
    public Box(int v, string n) { val = v; name = n; inner = null; }
    public int GetVal() { return val; }
    public Box Self() { return this; }
}

class Program {
    static void Main() {
        Box b = new Box(7, "seven");
        Box nb = null;
        Console.WriteLine(b?.val);
        Console.WriteLine(nb?.val);
        Console.WriteLine(b?.GetVal());
        Console.WriteLine(nb?.GetVal());
        string s = nb?.name;
        if (s == null) { Console.WriteLine("null-name"); }
        Console.WriteLine(b?.Self()?.name);
        if (nb?.Self()?.name == null) { Console.WriteLine("chain-null"); }
        if (b?.inner?.name == null) { Console.WriteLine("inner-null"); }
        string fallback = nb?.name ?? "dflt";
        Console.WriteLine(fallback);
    }
}
