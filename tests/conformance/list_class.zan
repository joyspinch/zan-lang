using System;
using System.Collections;
namespace P;
class Node {
    public int v;
    public Node next;
    public Node(int x) { v = x; }
}
class Bag {
    public List<Node> items;
    public Bag() { items = new List<Node>(); }
    public void Put(int x) { items.Add(new Node(x)); }
    public int Total() {
        int s = 0;
        int i = 0;
        while (i < items.Count) { s = s + items[i].v; i = i + 1; }
        return s;
    }
}
class Program {
    static void Main() {
        Bag b = new Bag();
        b.Put(10);
        b.Put(20);
        b.Put(12);
        Console.WriteLine(b.items.Count);
        Console.WriteLine(b.Total());
        b.items[0].v = 100;
        Console.WriteLine(b.Total());
    }
}
