// Regression: a user-defined instance method named Add on a non-List class must
// call the user method, not the built-in List.Add intrinsic. Also verifies the
// real List.Add still works.
using System;

namespace Conf;

class Counter {
    public int total;
    public void Add(int x) { total = total + x; }
}

class Program {
    static void Main() {
        var c = new Counter();
        c.total = 0;
        c.Add(10);
        c.Add(32);
        Console.WriteLine(c.total);

        var xs = new List<int>();
        xs.Add(5);
        xs.Add(7);
        Console.WriteLine(xs.Count);
        Console.WriteLine(xs[0] + xs[1]);
    }
}
