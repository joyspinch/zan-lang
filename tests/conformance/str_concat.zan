using System;
namespace P;
class Program {
    static void Main() {
        string a = "foo";
        string b = "bar";
        string c = a + b;
        Console.WriteLine(c);
        Console.WriteLine(a + "/" + b);
        if (c == "foobar") { Console.WriteLine("eq"); } else { Console.WriteLine("ne"); }
        if (a == b) { Console.WriteLine("same"); } else { Console.WriteLine("diff"); }
    }
}
