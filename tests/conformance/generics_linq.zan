using System;
using System.Linq;

delegate bool Pred<T>(T item);
delegate R Conv<T, R>(T item);

class Box {
    static T Id<T>(T v) { return v; }

    static bool Check<T>(Pred<T> p, T v) { return p(v); }
}

class Program {
    static void Main() {
        // explicit generic method type argument
        Console.WriteLine("id=" + Convert.ToString(Box.Id<int>(42)));

        // typed lambda bound to a generic delegate, invoked through a generic method
        Pred<int> even = (int x) => x % 2 == 0;
        Console.WriteLine("check4=" + Convert.ToString(Box.Check(even, 4)));
        Console.WriteLine("check7=" + Convert.ToString(Box.Check(even, 7)));

        List<int> nums = new List<int>();
        nums.Add(1);
        nums.Add(2);
        nums.Add(3);
        nums.Add(4);
        nums.Add(5);
        nums.Add(6);

        List<int> evens = Enumerable.Where(nums, even);
        Console.WriteLine("evens=" + Convert.ToString(evens.Count));

        Conv<int, int> triple = (int x) => x * 3;
        List<int> tripled = Enumerable.Select(nums, triple);
        Console.WriteLine("tripled=" + Convert.ToString(tripled[0]) + "," +
            Convert.ToString(tripled[tripled.Count - 1]));

        Console.WriteLine("any6=" + Convert.ToString(Enumerable.Any(nums, (int x) => x > 5)));
        Console.WriteLine("all0=" + Convert.ToString(Enumerable.All(nums, (int x) => x > 0)));
        Console.WriteLine("count=" + Convert.ToString(
            Enumerable.Count(nums, (int x) => x % 2 == 0)));
        Console.WriteLine("sum=" + Convert.ToString(Enumerable.Sum(nums)));
        Console.WriteLine("contains4=" + Convert.ToString(Enumerable.Contains(nums, 4)));

        List<int> desc = Enumerable.OrderByDescending(evens, (int x) => x);
        Console.WriteLine("desc=" + Convert.ToString(desc[0]) + "," +
            Convert.ToString(desc[desc.Count - 1]));
    }
}
