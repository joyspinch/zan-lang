using System;
using System.Collections.Generic;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        Tween tw = Tween.Create()
            .Add(TweenStep.To("地图按钮", 300, Easing.BackOut).Set("y", -100.0).Set("x", 100.0))
            .Add(TweenStep.Wait(200))
            .Add(TweenStep.By("地图按钮", 300, Easing.QuadInOut).Set("y", 100.0))
            .Add(TweenStep.Call("完成回调"));

        Console.WriteLine("steps=" + Convert.ToString(tw.StepCount()));
        Console.WriteLine("total=" + Convert.ToString(tw.TotalDuration()));

        TweenStep s0 = tw.StepAt(0);
        Console.WriteLine("s0op=" + s0.Op());
        Console.WriteLine("s0dur=" + Convert.ToString(s0.Duration()));
        Console.WriteLine("s0props=" + Convert.ToString(s0.PropCount()));

        TweenStep s1 = tw.StepAt(1);
        Console.WriteLine("s1op=" + s1.Op());

        TweenStep s2 = tw.StepAt(2);
        Console.WriteLine("s2op=" + s2.Op());

        TweenStep s3 = tw.StepAt(3);
        Console.WriteLine("s3op=" + s3.Op());

        int easeCount = 0;
        Easing e = Easing.BounceInOut;
        if (e == Easing.BounceInOut) { easeCount = 31; }
        Console.WriteLine("easeLast=" + Convert.ToString(easeCount));
    }
}
