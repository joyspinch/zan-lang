// Conformance: extended LINQ operators - typed sort keys (OrderByStr/
// OrderByNum), two-key OrderBy, GroupBy/GroupByStr, SelectMany, Single/
// LastOrDefault, selector aggregates, TakeWhile/SkipWhile, string-value
// Distinct/Contains/In, and C#-style InvalidOperationException on empty
// sequences.
using System;
using System.Linq;

class User {
    string name;
    string city;
    int age;
    double score;
}

class Program {
    static User Mk(string n, string c, int a, double s) {
        User u = new User();
        u.name = n;
        u.city = c;
        u.age = a;
        u.score = s;
        return u;
    }

    static void Main() {
        List<User> users = new List<User>();
        users.Add(Program.Mk("carol", "wuhan", 41, 88.5));
        users.Add(Program.Mk("alice", "beijing", 17, 92.25));
        users.Add(Program.Mk("bob", "wuhan", 25, 75.0));
        users.Add(Program.Mk("dave", "beijing", 25, 91.0));

        // string sort keys
        List<User> byName = users.OrderByStr(u => u.name);
        Console.WriteLine("byName=" + byName[0].name + "," + byName[3].name);
        List<User> byNameDesc = users.OrderByStrDescending(u => u.name);
        Console.WriteLine("byNameDesc=" + byNameDesc[0].name);

        // double sort keys
        List<User> byScore = users.OrderByNum(u => u.score);
        Console.WriteLine("byScore=" + byScore[0].name + "," + byScore[3].name);
        List<User> byScoreDesc = users.OrderByNumDescending(u => u.score);
        Console.WriteLine("byScoreDesc=" + byScoreDesc[0].name);

        // two-key sort: age asc, then score as int tiebreak
        List<User> two = users.OrderBy(u => u.age, u => (int)u.score);
        Console.WriteLine("two=" + two[0].name + "," + two[1].name + "," + two[2].name);

        // GroupByStr
        List<Grouping<User>> byCity = users.GroupByStr(u => u.city);
        Console.WriteLine("groups=" + Convert.ToString(byCity.Count));
        Console.WriteLine("g0=" + byCity[0].Key + ":" + Convert.ToString(byCity[0].Items.Count));
        Console.WriteLine("g1=" + byCity[1].Key + ":" + Convert.ToString(byCity[1].Items.Count));

        // GroupBy (int key)
        List<Grouping<User>> byAge = users.GroupBy(u => u.age);
        Console.WriteLine("ageGroups=" + Convert.ToString(byAge.Count) +
            " k1=" + Convert.ToString(byAge[2].IntKey) +
            ":" + Convert.ToString(byAge[2].Items.Count));

        // SelectMany
        List<List<int>> nested = new List<List<int>>();
        List<int> n1 = new List<int> { 1, 2 };
        List<int> n2 = new List<int> { 3 };
        nested.Add(n1);
        nested.Add(n2);
        List<int> flat = nested.SelectMany(x => x);
        Console.WriteLine("flat=" + Convert.ToString(flat.Count) +
            " last=" + Convert.ToString(flat[2]));

        // Single / SingleOrDefault / LastOrDefault
        User onlyCarol = users.Single(u => u.age > 40);
        Console.WriteLine("single=" + onlyCarol.name);
        User none = users.SingleOrDefault(u => u.age > 90);
        Console.WriteLine("noneNull=" + Convert.ToString(none == null));
        User lastWuhan = users.LastOrDefault(u => u.city == "wuhan");
        Console.WriteLine("lastWuhan=" + lastWuhan.name);

        // selector aggregates
        Console.WriteLine("sumAge=" + Convert.ToString(users.Sum(u => u.age)));
        Console.WriteLine("sumScore=" + Convert.ToString(users.SumNum(u => u.score)));
        Console.WriteLine("minAge=" + Convert.ToString(users.Min(u => u.age)));
        Console.WriteLine("maxAge=" + Convert.ToString(users.Max(u => u.age)));
        Console.WriteLine("avgAge=" + Convert.ToString(users.Average(u => u.age)));

        // double list aggregates
        List<double> ds = new List<double>();
        ds.Add(1.5);
        ds.Add(2.5);
        Console.WriteLine("sumD=" + Convert.ToString(ds.SumNum()));
        Console.WriteLine("minD=" + Convert.ToString(ds.MinNum()));
        Console.WriteLine("maxD=" + Convert.ToString(ds.MaxNum()));
        Console.WriteLine("avgD=" + Convert.ToString(ds.AverageNum()));

        // TakeWhile / SkipWhile
        List<int> nums = new List<int> { 1, 2, 3, 4, 1 };
        List<int> tw = nums.TakeWhile(x => x < 3);
        Console.WriteLine("tw=" + Convert.ToString(tw.Count));
        List<int> sw = nums.SkipWhile(x => x < 3);
        Console.WriteLine("sw=" + Convert.ToString(sw.Count) + " first=" + Convert.ToString(sw[0]));

        // string-value Distinct / Contains / In
        List<string> cities = users.Select((User u) => u.city);
        List<string> uniq = cities.DistinctStr();
        Console.WriteLine("uniq=" + Convert.ToString(uniq.Count));
        string wu = "wu" + "han";
        Console.WriteLine("hasWuhan=" + Convert.ToString(cities.ContainsStr(wu)));
        List<string> wanted = new List<string>();
        wanted.Add(wu);
        List<string> got = cities.InStr(wanted);
        Console.WriteLine("inStr=" + Convert.ToString(got.Count));

        // empty-sequence exceptions
        List<int> empty = new List<int>();
        try {
            int f = empty.First();
            Console.WriteLine("noThrow=" + Convert.ToString(f));
        } catch (InvalidOperationException e) {
            Console.WriteLine("firstThrows=" + e.Message);
        }
        try {
            int s = nums.Single();
            Console.WriteLine("noThrow=" + Convert.ToString(s));
        } catch (InvalidOperationException e) {
            Console.WriteLine("singleThrows=" + e.Message);
        }
        Console.WriteLine("firstOrDefault=" + Convert.ToString(empty.FirstOrDefault()));

        // Aggregate with a differently-typed accumulator
        int weight = users.Aggregate(100, (int acc, User u) => acc + u.age);
        Console.WriteLine("weight=" + Convert.ToString(weight));
    }
}
