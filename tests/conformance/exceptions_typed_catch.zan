using System;

class AppIoException : Exception {
    public AppIoException(string m) : base(m) {}
}
class NetException : Exception {
    public NetException(string m) : base(m) {}
}

class Program {
    static void ThrowIt(int kind) {
        if (kind == 0) { throw new Exception("plain"); }
        if (kind == 1) { throw new AppIoException("io"); }
        throw new NetException("net");
    }
    static void Main() {
        // multi-clause dispatch: each throw lands in its matching clause
        int k = 0;
        while (k < 3) {
            try {
                ThrowIt(k);
            } catch (AppIoException io) {
                Console.WriteLine("io: " + io.Message);
            } catch (NetException ne) {
                Console.WriteLine("net: " + ne.Message);
            } catch (Exception e) {
                Console.WriteLine("base: " + e.Message);
            }
            k = k + 1;
        }
        // a derived exception is caught by a base-typed clause
        try { throw new AppIoException("d2b"); }
        catch (Exception e) { Console.WriteLine("d2b: " + e.Message); }
        // no matching clause: the exception propagates to the outer try
        try {
            try { throw new Exception("outer-bound"); }
            catch (AppIoException io) { Console.WriteLine("WRONG"); }
        } catch (Exception e) {
            Console.WriteLine("rethrown: " + e.Message);
        }
        // cross-module inheritance: base(...) initialised the inherited field
        AppIoException direct = new AppIoException("field-ok");
        Console.WriteLine("direct: " + direct.Message);
        Console.WriteLine("end");
    }
}
