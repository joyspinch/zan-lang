using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Skill Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default");

        SkillConfig burst = SkillConfig.Create("burst", "Burst")
            .SetRange(5, 0)
            .SetTarget(SkillTarget.MouseCell)
            .SetArea(1)
            .SetCost(0, 0, 10)
            .SetDamageDelay(100)
            .SetFormula("a.攻击 - b.防御")
            .SetAbsolute(true, false);

        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetVitals(100, 100, 0, 0)
            .SetCombat(100, 0, 0)
            .AddAttr("攻击", 30)
            .AddAttr("怒气", 25)
            .AddAttr("最大怒气", 30);
        NpcConfig enemyConfig = NpcConfig.Create("enemy")
            .SetVitals(100, 100, 0, 0)
            .SetCombat(100, 0, 0)
            .AddAttr("防御", 0);

        MapConfig field = MapConfig.Create("field")
            .SetGrid(64, 32, 10, 10)
            .SetDefault(true)
            .SetStart(1, 1)
            .AddSpawn(MapSpawn.Of(
                "enemy", Faction.Enemy, 3, 1, 0, 1));

        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddSkill(burst)
            .AddNpc(heroConfig)
            .AddNpc(enemyConfig)
            .AddMap(field);

        ZgmEngine engine = ZgmEngine.FromProject(project);
        Console.WriteLine(
            "valid=" + Convert.ToString(!engine.Diagnostics().HasErrors()));
        Console.WriteLine("start=" + Convert.ToString(engine.Start("")));

        ZgmWorld world = engine.World();
        ZgmActor hero = world.Hero();
        hero.AddSkill("burst");
        ZgmActor second = world.CreateActor(
            "enemy", Faction.Enemy, 4, 1);
        ZgmActor first = world.ActorAt(1);
        Console.WriteLine(
            "positions=" + Convert.ToString(first.X()) + ","
                + Convert.ToString(second.X()));

        ZgmSkillResult cast = world.CastSkillAt(
            hero, "burst", 3, 1);
        Console.WriteLine(
            "cast=" + Convert.ToString((int)cast.Status())
                + "|pending=" + Convert.ToString(cast.Pending())
                + "|rage=" + Convert.ToString(hero.Rage()));
        Console.WriteLine(
            "before=" + Convert.ToString(first.Hp()) + ","
                + Convert.ToString(second.Hp()) + "|damage="
                + Convert.ToString(cast.Damage()));

        engine.Update(99);
        Console.WriteLine(
            "after99=" + Convert.ToString(first.Hp()) + ","
                + Convert.ToString(second.Hp()) + "|pending="
                + Convert.ToString(cast.Pending()));

        engine.Update(1);
        Console.WriteLine(
            "after100=" + Convert.ToString(first.Hp()) + ","
                + Convert.ToString(second.Hp()) + "|damage="
                + Convert.ToString(cast.TotalDamage())
                + "|targets=" + Convert.ToString(cast.TargetCount())
                + "|pending=" + Convert.ToString(cast.Pending()));

        ZgmSkillResult secondCast = world.CastSkillAt(
            hero, "burst", 3, 1);
        ZgmSkillResult blocked = world.CastSkillAt(
            hero, "burst", 3, 1);
        Console.WriteLine(
            "second=" + Convert.ToString((int)secondCast.Status())
                + "|blocked=" + Convert.ToString((int)blocked.Status())
                + "|rage=" + Convert.ToString(hero.Rage()));
    }
}
