using System;
using System.Net.Sockets;

class Program {
    static void Main() {
        Socket.Initialize();
        int sock = Socket.CreateUdp();
        int checks = 0;
        if (sock >= 0) { checks = checks + 1; }
        if (!Socket.IsReadable(sock)) { checks = checks + 1; }
        if (Socket.IsWritable(sock)) { checks = checks + 1; }
        Socket.Close(sock);
        Socket.Cleanup();
        Console.WriteLine(checks);
    }
}
