using System;
using Game.Zgm;

namespace T;

class Program {
    static int promptCount;
    static int customCount;
    static int focusOffCount;

    static bool OnSystemPrompt(int code, string message) {
        Program.promptCount = Program.promptCount + 1;
        return code == 1001 && message == "full";
    }
    static void OnCustomEvent(
        string source,
        string name,
        string payload
    ) {
        if (source == "任务" && name == "完成"
            && payload == "chapter-1") {
            Program.customCount = Program.customCount + 1;
        }
    }
    static void OnFocusChanged(bool focused) {
        if (!focused) {
            Program.focusOffCount = Program.focusOffCount + 1;
        }
    }

    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM UI State")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        Label message = new Label("message")
            .SetTitle("old");
        message.At(0, 0).Size(160, 24);
        WindowConfig hud = WindowConfig.Create("hud")
            .SetSize(200, 60)
            .SetDefaultVisible(true)
            .AddWidget(message);
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddWindow(hud);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Events().OnSystemPrompt(Program.OnSystemPrompt);
        engine.Events().OnCustomEvent(Program.OnCustomEvent);
        engine.Events().OnFocusChanged(Program.OnFocusChanged);
        Console.WriteLine("start=" + Convert.ToString(engine.Start("")));
        ZgmUiRuntime ui = engine.Ui();
        ZgmWidgetState state = ui.FindWidget("hud", "message");
        Console.WriteLine(
            "prompt=" + Convert.ToString(
                ui.ShowSystemPrompt(1001, "full"))
                + "|" + Convert.ToString(
                ui.ShowSystemPrompt(2, "other"))
                + "|" + Convert.ToString(Program.promptCount));
        ui.DispatchCustomEvent("任务", "完成", "chapter-1");
        Console.WriteLine(
            "custom=" + Convert.ToString(Program.customCount));
        Console.WriteLine(
            "text=" + Convert.ToString(
                ui.SetWidgetText("hud", "message", "new"))
                + "|" + state.Text());
        Console.WriteLine(
            "focus=" + Convert.ToString(
                ui.SetFocus("hud", "message"))
                + "|" + Convert.ToString(state.Focused()));
        Console.WriteLine(
            "hide=" + Convert.ToString(
                ui.SetWidgetVisible("hud", "message", false))
                + "|" + Convert.ToString(state.Visible())
                + "|" + Convert.ToString(state.Focused())
                + "|" + Convert.ToString(Program.focusOffCount));
        Console.WriteLine(
            "hiddenFocus=" + Convert.ToString(
                ui.SetFocus("hud", "message")));
        Console.WriteLine(
            "enable=" + Convert.ToString(
                ui.SetWidgetEnabled("hud", "message", false))
                + "|" + Convert.ToString(state.Enabled())
                + "|" + Convert.ToString(
                ui.SetWidgetEnabled("hud", "message", true)));
        ui.SetWidgetVisible("hud", "message", true);
        ui.SetFocus("hud", "message");
        ZgmWindowState window = ui.FindWindow("hud");
        Console.WriteLine(
            "window=" + Convert.ToString(
                ui.SetWindowPosition("hud", 20, 30))
                + "|" + Convert.ToString(window.X())
                + "," + Convert.ToString(window.Y())
                + "|" + Convert.ToString(ui.CloseWindow("hud"))
                + "|" + Convert.ToString(state.Focused())
                + "|" + Convert.ToString(Program.focusOffCount));
        engine.Stop();
        engine.Dispose();
        project.Dispose();
    }
}
