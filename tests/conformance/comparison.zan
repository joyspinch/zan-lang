using System;
namespace Conf;
class Program {
    static void Main() {
        int a = 5;
        int b = 8;
        if (a < b) { Console.WriteLine(1); } else { Console.WriteLine(0); }
        if (a == 5) { Console.WriteLine(1); } else { Console.WriteLine(0); }
        if (a != b) { Console.WriteLine(1); } else { Console.WriteLine(0); }
        if (b >= 8) { Console.WriteLine(1); } else { Console.WriteLine(0); }
    }
}
