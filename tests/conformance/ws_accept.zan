// Conformance: RFC 6455 Sec-WebSocket-Accept derivation.
// Exercises System.Text.Encoding.Sha1 + Base64EncodeBytes via WebSocketAccept.
// The key/accept pair is the canonical example from RFC 6455 section 1.3:
//   key    = "dGhlIHNhbXBsZSBub25jZQ=="
//   accept = "s3pPLMBiTxaQ9kYGzzhZRbK+xOo="
// Also checks two known SHA-1 base64 digests to pin the hash itself.
using System;
using System.Text;

class Program {
    static void Main() {
        Console.WriteLine(Encoding.WebSocketAccept("dGhlIHNhbXBsZSBub25jZQ=="));

        // SHA1("") and SHA1("abc") as base64, to validate empty and short inputs.
        string d0 = calloc(21, 1);
        Encoding.Sha1("", 0, d0);
        Console.WriteLine(Encoding.Base64EncodeBytes(d0, 20));

        string d1 = calloc(21, 1);
        Encoding.Sha1("abc", 3, d1);
        Console.WriteLine(Encoding.Base64EncodeBytes(d1, 20));
    }

    [DllImport("crt")]
    static extern string calloc(int count, int size);
}
