using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM AI Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default");

        SkillConfig poke = SkillConfig.Create("poke", "Poke")
            .SetRange(1, 0)
            .SetPriority(5)
            .SetFormula("a.攻击 - b.防御")
            .SetAbsolute(true, false);
        SkillConfig bite = SkillConfig.Create("bite", "Bite")
            .SetRange(1, 0)
            .SetPriority(10)
            .SetInterval(1000)
            .SetFormula("a.攻击 - b.防御")
            .SetAbsolute(true, false);

        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetVitals(100, 100, 0, 0)
            .SetCombat(100, 0, 0)
            .AddAttr("防御", 0);
        NpcConfig enemyConfig = NpcConfig.Create("enemy")
            .SetVitals(100, 100, 0, 0)
            .SetCombat(100, 0, 0)
            .SetBehavior(1, -1)
            .AddAttr("攻击", 20)
            .AddSkill("poke")
            .AddSkill("bite");
        MapConfig field = MapConfig.Create("field")
            .SetGrid(10, 10, 8, 4)
            .SetDefault(true)
            .SetStart(1, 1)
            .AddSpawn(MapSpawn.Of(
                "enemy", Faction.Enemy, 4, 1, 0, 1));

        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddSkill(poke)
            .AddSkill(bite)
            .AddNpc(heroConfig)
            .AddNpc(enemyConfig)
            .AddMap(field);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Start("");
        ZgmWorld world = engine.World();
        ZgmActor enemy = world.ActorAt(1);
        ZgmActor hero = world.Hero();

        engine.Update(100);
        Console.WriteLine(
            "step1=" + Convert.ToString(enemy.X()) + ","
                + Convert.ToString(enemy.Y()) + "|"
                + Convert.ToString(hero.Hp()));
        engine.Update(100);
        Console.WriteLine(
            "step2=" + Convert.ToString(enemy.X()) + ","
                + Convert.ToString(enemy.Y()) + "|"
                + Convert.ToString(hero.Hp()));
        engine.Update(100);
        Console.WriteLine(
            "step3=" + Convert.ToString(enemy.X()) + ","
                + Convert.ToString(enemy.Y()) + "|"
                + Convert.ToString(hero.Hp()));
        engine.Update(100);
        Console.WriteLine(
            "cooldown=" + Convert.ToString(enemy.X()) + ","
                + Convert.ToString(enemy.Y()) + "|"
                + Convert.ToString(hero.Hp()));
    }
}
