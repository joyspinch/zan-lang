using System;
using System.Collections.Generic;
using Game.Dm;

namespace T;

class Program {
    static void Main() {
        TextNode txt = new TextNode("说明文本");
        txt.SetTitle("欢迎").SetFont("宋体14").SetAlign(1, 1);
        txt.At(4, 4).Anchor(0.5, 0.5);
        Console.WriteLine("txtKind=" + txt.Kind());
        Console.WriteLine("txtName=" + txt.Name());
        Console.WriteLine("txtTitle=" + txt.Title());
        Console.WriteLine("txtX=" + Convert.ToString(txt.X()));

        BmpTextNode bt = new BmpTextNode("数字");
        bt.SetTitle("12345").SetFont("10004_");
        Console.WriteLine("btKind=" + bt.Kind());
        Console.WriteLine("btTitle=" + bt.Title());

        SpriteNode sp = new SpriteNode("图标");
        sp.SetImage("图集|00009").SetColor(DmColor.Rgba(255, 200, 0, 255)).SetScale(2.0, 2.0);
        Console.WriteLine("spKind=" + sp.Kind());
        Console.WriteLine("spImage=" + sp.Image());

        RectangleNode rc = new RectangleNode("底板");
        rc.SetSize(100, 40).SetBackground(DmColor.Rgba(0, 0, 0, 128)).SetBorder(2, DmColor.Rgb(255, 255, 255));
        Console.WriteLine("rcKind=" + rc.Kind());
        Console.WriteLine("rcW=" + Convert.ToString(rc.Width()));

        CircleNode ci = new CircleNode("光点");
        ci.SetRadius(24).SetColor(DmColor.Rgb(0, 255, 0));
        Console.WriteLine("ciKind=" + ci.Kind());
        Console.WriteLine("ciR=" + Convert.ToString(ci.Radius()));

        AnimationNode an = new AnimationNode("火焰");
        an.SetAnim("火焰动画", "燃烧").SetFrameRate(1.5);
        an.At(0, -10);
        Console.WriteLine("anKind=" + an.Kind());
        Console.WriteLine("anAnim=" + an.Anim());
    }
}
