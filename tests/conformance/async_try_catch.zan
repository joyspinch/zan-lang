// try/catch inside async methods: exception state must survive the CPS
// block splits introduced by await (regression test for the LLVM dominance
// failure when eh.old/tmpmark/exc values were reused across resume blocks).
using System;

class Boom : Exception {
    public Boom(string m) { Message = m; }
}

class Program {
    static async int SlowVal(int x) {
        await Task.Delay(10);
        return x + 1;
    }

    // throw BEFORE any await in the try
    static async void EarlyThrow() {
        try {
            throw new Boom("early");
        } catch (Boom e) {
            Console.WriteLine("early=" + e.Message);
        }
    }

    // throw AFTER an await suspension inside the try
    static async void LateThrow() {
        try {
            int v = await SlowVal(1);
            Console.WriteLine("v=" + Convert.ToString(v));
            throw new Boom("late");
        } catch (Boom e) {
            Console.WriteLine("late=" + e.Message);
        }
    }

    static void Main() {
        await EarlyThrow();
        await LateThrow();
        Console.WriteLine("done");
    }
}
