using System.Threading;

class Program {
    static void PrintBool(bool flag) {
        if (flag) {
            Console.WriteLine(1);
        } else {
            Console.WriteLine(0);
        }
    }

    static void Main() {
        AtomicInt counter = new AtomicInt(2);
        Console.WriteLine(counter.Increment());
        Console.WriteLine(counter.Add(4));
        Console.WriteLine(counter.CompareExchange(7, 9));
        Console.WriteLine(counter.Load());
        Console.WriteLine(counter.CompareExchange(7, 11));
        Console.WriteLine(counter.Exchange(5));
        Console.WriteLine(counter.Load());

        string name = "zan_conformance_atomic_shared_table";
        SharedTable stale = SharedTable.Open(name);
        if (stale.IsOpen()) {
            stale.Destroy();
        }

        SharedTable table = new SharedTable(name, 16);
        table.ColumnInt("count");
        table.ColumnFloat("load");
        table.ColumnString("label", 32);
        PrintBool(table.Create());
        PrintBool(table.SetInt("workers", "count", 10));
        PrintBool(table.SetFloat("workers", "load", 12.5));
        PrintBool(table.SetString("workers", "label", "ready"));
        Console.WriteLine(table.GetInt("workers", "count"));
        Console.WriteLine((int)table.GetFloat("workers", "load"));
        string firstLabel = table.GetString("workers", "label");
        PrintBool(table.SetString("workers", "label", "updated"));
        Console.WriteLine(firstLabel);
        Console.WriteLine(table.GetString("workers", "label"));
        Console.WriteLine(table.Increment("workers", "count", 5));

        SharedTable second = SharedTable.Open(name);
        PrintBool(second.IsOpen());
        Console.WriteLine(second.Decrement("workers", "count", 2));
        Console.WriteLine(table.GetInt("workers", "count"));
        Console.WriteLine(table.Count());
        PrintBool(table.Exists("workers"));
        PrintBool(table.Delete("workers"));
        Console.WriteLine(table.Count());
        second.Close();
        PrintBool(table.Destroy());
    }
}
