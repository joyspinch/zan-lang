using System;
using System.Collections.Generic;
using Game.Dm;

namespace T;

class Program {
    static void Main() {
        SqliteComponentConfig db = SqliteComponentConfig.Create("数据库");
        Console.WriteLine("dbKind=" + db.Kind());
        Console.WriteLine("dbName=" + db.Name());

        TcpClientConfig tcp = TcpClientConfig.Create("客户端", "127.0.0.1", 17173);
        Console.WriteLine("tcpKind=" + tcp.Kind());
        Console.WriteLine("tcpIp=" + tcp.Ip());
        Console.WriteLine("tcpPort=" + Convert.ToString(tcp.Port()));
        Console.WriteLine("tcpMsgLen=" + Convert.ToString(tcp.MessageLength()));

        WebSocketClientConfig ws = WebSocketClientConfig.Create("网络客户端");
        ws.SetUrl("wss://example.com/game");
        Console.WriteLine("wsKind=" + ws.Kind());
        Console.WriteLine("wsUrl=" + ws.Url());

        ServerConfig server = ServerConfig.Create("服务端 v0.1", 17173)
            .AddComponent("SqliteDB.lua")
            .AddScript("logic.lua");
        Console.WriteLine("srvName=" + server.Name());
        Console.WriteLine("srvPort=" + Convert.ToString(server.Port()));
        Console.WriteLine("srvMsgLen=" + Convert.ToString(server.MessageLength()));
        Console.WriteLine("srvComps=" + Convert.ToString(server.ComponentCount()));
    }
}
