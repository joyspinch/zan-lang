using System;
using Game.Board;

namespace Tests.GameBoard;

class ThreeRules : IBoardRules {
    bool Validate(BoardMatch match, BoardCommand command) {
        return command.Type() == "place"
            && match.Board().Inside(command.ToX(), command.ToY())
            && match.Board().Get(command.ToX(), command.ToY()) == 0;
    }

    int Count(
        GridBoard board,
        int x,
        int y,
        int dx,
        int dy,
        int stone
    ) {
        int count = 0;
        int cx = x + dx;
        int cy = y + dy;
        while (board.Inside(cx, cy) && board.Get(cx, cy) == stone) {
            count = count + 1;
            cx = cx + dx;
            cy = cy + dy;
        }
        return count;
    }

    bool Apply(BoardMatch match, BoardCommand command) {
        int stone = command.Player() + 1;
        match.Board().Set(command.ToX(), command.ToY(), stone);
        int horizontal = 1
            + this.Count(match.Board(), command.ToX(), command.ToY(), -1, 0, stone)
            + this.Count(match.Board(), command.ToX(), command.ToY(), 1, 0, stone);
        int vertical = 1
            + this.Count(match.Board(), command.ToX(), command.ToY(), 0, -1, stone)
            + this.Count(match.Board(), command.ToX(), command.ToY(), 0, 1, stone);
        if (horizontal >= 3 || vertical >= 3) {
            match.Turn().Finish(command.Player());
        } else {
            match.Turn().NextPlayer();
        }
        return true;
    }
}

class Program {
    static void Main() {
        GridBoard board = GridBoard.Create(3, 3, 0);
        BoardMatch match = BoardMatch.Create(board, 2, new ThreeRules());
        Console.WriteLine(
            "m1=" + Convert.ToString(match.TryApply(BoardCommand.Place(0, 0, 0, 1))));
        Console.WriteLine(
            "wrong=" + Convert.ToString(match.TryApply(BoardCommand.Place(0, 1, 0, 1))));
        match.TryApply(BoardCommand.Place(1, 0, 1, 2));
        BoardSnapshot saved = match.Snapshot();
        match.TryApply(BoardCommand.Place(0, 1, 0, 1));
        match.TryApply(BoardCommand.Place(1, 1, 1, 2));
        match.TryApply(BoardCommand.Place(0, 2, 0, 1));
        Console.WriteLine(
            "winner=" + Convert.ToString(match.Turn().Winner())
            + ",seq=" + Convert.ToString(match.Sequence())
            + ",log=" + Convert.ToString(match.Log().Count()));
        match.Restore(saved);
        Console.WriteLine(
            "restore=" + Convert.ToString(match.Board().CountValue(1))
            + "," + Convert.ToString(match.Board().CountValue(2))
            + "," + Convert.ToString(match.Turn().CurrentPlayer())
            + "," + Convert.ToString(match.Sequence()));

        GridBoard map = GridBoard.Create(5, 4, 0);
        map.Set(1, 0, 9);
        map.Set(1, 1, 9);
        map.Set(1, 2, 9);
        GridPath path = GridPathfinder.Find(map, 0, 0, 4, 0, 9, false);
        Console.WriteLine(
            "path=" + Convert.ToString(path.Count())
            + "," + Convert.ToString(path.At(0).X())
            + "," + Convert.ToString(path.At(path.Count() - 1).X()));
    }
}
