// Conformance: stdlib IO error model (EXECUTION_PLAN A2).
// File open/read/write/copy failures throw FileNotFoundException/IOException
// instead of silently returning "" / -1 / doing nothing.
using System;
using System.IO;

class Program {
    static void Main() {
        // Missing file: ReadAllText throws FileNotFoundException.
        try {
            string s = File.ReadAllText("io_errors_missing.txt");
            Console.WriteLine("read: no-throw");
        } catch (FileNotFoundException e) {
            Console.WriteLine("read: " + e.Message);
        }

        // FileNotFoundException is catchable as its base IOException.
        try {
            int n = File.GetSize("io_errors_missing.txt");
            Console.WriteLine("size: no-throw");
        } catch (IOException e) {
            Console.WriteLine("size: " + e.Message);
        }

        // ...and as the root Exception.
        try {
            string b = File.ReadBytes("io_errors_missing.txt", 0, 4);
            Console.WriteLine("bytes: no-throw");
        } catch (Exception e) {
            Console.WriteLine("bytes: " + e.Message);
        }

        // Copy with a missing source throws.
        try {
            File.Copy("io_errors_missing.txt", "io_errors_copy.tmp");
            Console.WriteLine("copy: no-throw");
        } catch (FileNotFoundException e) {
            Console.WriteLine("copy: " + e.Message);
        }

        // ReadAllLines goes through ReadAllText and throws too.
        try {
            List<string> lines = File.ReadAllLines("io_errors_missing.txt");
            Console.WriteLine("lines: no-throw");
        } catch (FileNotFoundException e) {
            Console.WriteLine("lines: " + e.Message);
        }

        // Exists stays a boolean probe (no exception).
        Console.WriteLine("exists=" + Convert.ToString(File.Exists("io_errors_missing.txt")));

        // Happy path: write, append, read back, size, copy, delete.
        File.WriteAllText("io_errors_a.tmp", "hello");
        File.AppendAllText("io_errors_a.tmp", " world");
        Console.WriteLine("roundtrip=" + File.ReadAllText("io_errors_a.tmp"));
        Console.WriteLine("size=" + Convert.ToString(File.GetSize("io_errors_a.tmp")));
        File.Copy("io_errors_a.tmp", "io_errors_b.tmp");
        Console.WriteLine("copied=" + File.ReadAllText("io_errors_b.tmp"));
        File.Delete("io_errors_a.tmp");
        File.Delete("io_errors_b.tmp");
        Console.WriteLine("done");
    }
}
