// Conformance: compile-time JSON entity mapping.
// Json.Deserialize<T>(text) / Json.Serialize<T>(obj) are lowered by the
// jsongen pass into generated per-class binders. Mapping is lenient:
// missing keys keep defaults, scalars coerce (string "7" -> int 7), a
// single object binds into a List<T> as one element, unknown keys are
// ignored, and a JsonValue-typed field passes its subtree through for
// dynamic access.
using System;
using System.Json;

class Address {
    string city;
    string zip;
}

class Item {
    string sku;
    int qty;
    double price;
}

class User {
    int id;
    long big;
    string name;
    bool active;
    double score;
    Address address;
    List<Item> items;
    List<string> tags;
    List<int> nums;
    JsonValue extra;
}

class Program {
    static void Main() {
        string doc = "{\"id\":7,\"big\":9000000000,\"name\":\"alice\",\"active\":true,"
            + "\"score\":98.5,"
            + "\"address\":{\"city\":\"Springfield\",\"zip\":\"12345\",\"ignored\":1},"
            + "\"items\":[{\"sku\":\"a1\",\"qty\":2,\"price\":9.75},{\"sku\":\"b2\",\"qty\":1,\"price\":0.5}],"
            + "\"tags\":[\"x\",\"y\"],"
            + "\"nums\":[3,4,5],"
            + "\"extra\":{\"weird\":[1,2,{\"deep\":true}]},"
            + "\"unknown_key\":\"whatever\"}";

        User u = Json.Deserialize<User>(doc);
        Console.WriteLine("id=" + Convert.ToString(u.id));
        Console.WriteLine("big=" + Convert.ToString(u.big));
        Console.WriteLine("name=" + u.name);
        Console.WriteLine("active=" + Convert.ToString(u.active));
        Console.WriteLine("score=" + Convert.ToString(u.score));
        Console.WriteLine("city=" + u.address.city);
        Console.WriteLine("items=" + Convert.ToString(u.items.Count));
        Console.WriteLine("sku1=" + u.items[1].sku + " qty1=" + Convert.ToString(u.items[1].qty));
        Console.WriteLine("price0=" + Convert.ToString(u.items[0].price));
        Console.WriteLine("tags=" + u.tags[0] + u.tags[1]);
        Console.WriteLine("nums2=" + Convert.ToString(u.nums[2]));
        Console.WriteLine("extra.weird[2].deep=" + Convert.ToString(u.extra.Get("weird").At(2).Bool("deep", false)));

        // lenient: missing keys keep defaults, "7" coerces to 7, a single
        // object binds into List<Item> as one element
        string loose = "{\"id\":\"7\",\"items\":{\"sku\":\"only\",\"qty\":\"3\"}}";
        User v = Json.Deserialize<User>(loose);
        Console.WriteLine("loose.id=" + Convert.ToString(v.id));
        Console.WriteLine("loose.name=[" + v.name + "]");
        Console.WriteLine("loose.items=" + Convert.ToString(v.items.Count));
        Console.WriteLine("loose.sku=" + v.items[0].sku + " qty=" + Convert.ToString(v.items[0].qty));
        Console.WriteLine("loose.address=" + Convert.ToString(v.address == null));

        // serialize round-trip
        string s = Json.Serialize<User>(u);
        User w = Json.Deserialize<User>(s);
        Console.WriteLine("rt.name=" + w.name);
        Console.WriteLine("rt.items=" + Convert.ToString(w.items.Count));
        Console.WriteLine("rt.price0=" + Convert.ToString(w.items[0].price));
        Console.WriteLine("rt.extra=" + Convert.ToString(w.extra.Get("weird").Count()));

        // root-level array
        string arr = "[{\"sku\":\"r1\",\"qty\":1,\"price\":1.5},{\"sku\":\"r2\",\"qty\":2,\"price\":2.5}]";
        List<Item> list = Json.Deserialize<List<Item>>(arr);
        Console.WriteLine("list=" + Convert.ToString(list.Count) + " sku=" + list[1].sku);
        string sl = Json.Serialize<List<Item>>(list);
        List<Item> list2 = Json.Deserialize<List<Item>>(sl);
        Console.WriteLine("list2=" + Convert.ToString(list2.Count) + " price=" + Convert.ToString(list2[0].price));
    }
}
