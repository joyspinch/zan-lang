using System;

namespace GenericConstraints;

interface IShape {
    int Area();
}

class Rect : IShape {
    public int W;
    public int H;

    public int Area() {
        return W * H;
    }
}

class Square : Rect {
}

class Holder<T> where T : IShape {
    public T Item;
}

class Program {
    static void Main() {
        Rect r = new Rect();
        r.W = 3;
        r.H = 5;
        Holder<Rect> h = new Holder<Rect>();
        h.Item = r;
        Rect back = h.Item;
        Console.WriteLine(back.Area());

        Square s = new Square();
        s.W = 4;
        s.H = 4;
        Holder<Square> hs = new Holder<Square>();
        hs.Item = s;
        Square back2 = hs.Item;
        Console.WriteLine(back2.Area());
    }
}
