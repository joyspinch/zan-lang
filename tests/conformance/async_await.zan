// S3 async/await: a non-async Main awaits an async method. The root drive
// spins up the cooperative scheduler, runs ComputeAsync to completion, and
// reads the frame result. ComputeAsync(21) -> 42.
class Program {
    static async int ComputeAsync(int x) {
        int result = x * 2;
        return result;
    }

    static void Main() {
        int val = await ComputeAsync(21);
        Console.WriteLine(val);
    }
}
