// Exercises the typed ZGM skill formula evaluator without Lua parsing:
// attributes, arithmetic precedence, power, parentheses, min/max/clamp and
// invalid-expression fallback.
using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        NpcConfig left = NpcConfig.Create("left")
            .SetVitals(100, 100, 20, 20)
            .AddAttr("ж”»еҮ»", 12)
            .AddAttr("йҳІеҫЎ", 4);
        NpcConfig right = NpcConfig.Create("right")
            .SetVitals(100, 100, 20, 20)
            .AddAttr("ж”»еҮ»", 3)
            .AddAttr("йҳІеҫЎ", 5);

        ZgmActor a = ZgmActor.FromConfig("a", left, Faction.Friendly);
        ZgmActor b = ZgmActor.FromConfig("b", right, Faction.Enemy);

        Console.WriteLine("attrs=" + Convert.ToString(
            ZgmFormula.Create("a.ж”»еҮ» + b.йҳІеҫЎ * 2",
                a.EffectiveAttributes(), b.EffectiveAttributes()).Evaluate()));
        Console.WriteLine("group=" + Convert.ToString(
            ZgmFormula.Create("(a.ж”»еҮ» + b.йҳІеҫЎ) * 2",
                a.EffectiveAttributes(), b.EffectiveAttributes()).Evaluate()));
        Console.WriteLine("power=" + Convert.ToString(
            ZgmFormula.Create("2 ^ 3 + a.йҳІеҫЎ",
                a.EffectiveAttributes(), b.EffectiveAttributes()).Evaluate()));
        Console.WriteLine("minmax=" + Convert.ToString(
            ZgmFormula.Create("max(min(a.ж”»еҮ», b.йҳІеҫЎ), 7)",
                a.EffectiveAttributes(), b.EffectiveAttributes()).Evaluate()));
        Console.WriteLine("clamp=" + Convert.ToString(
            ZgmFormula.Create("clamp(a.ж”»еҮ» * 10, 0, 100)",
                a.EffectiveAttributes(), b.EffectiveAttributes()).Evaluate()));

        ZgmFormula invalid = ZgmFormula.Create(
            "a.ж”»еҮ» / 0",
            a.EffectiveAttributes(),
            b.EffectiveAttributes());
        Console.WriteLine("invalid=" + Convert.ToString(invalid.Evaluate())
            + "|" + Convert.ToString(invalid.IsValid()));

        a.Dispose();
        b.Dispose();
    }
}
