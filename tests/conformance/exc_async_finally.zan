// Exceptions: a finally inside an async coroutine runs across the await point
// on both the exception and the normal completion paths.
class Program {
    static async int inner(int x) {
        if (x < 0) { throw new Exception("neg"); }
        return x + 1;
    }
    static async int outer(int y) {
        try {
            int v = await inner(y);
            return v;
        } catch (Exception e) {
            return -1;
        } finally {
            Console.WriteLine("finally");
        }
    }
    static void Main() {
        Console.WriteLine(await outer(-1));
        Console.WriteLine(await outer(41));
    }
}
