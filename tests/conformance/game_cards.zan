using System;
using Game.Cards;

namespace Tests.GameCards;

class Program {
    static int Find(CardZone hand, string id) {
        int i = 0;
        while (i < hand.Count()) {
            if (hand.At(i).Definition().Id() == id) { return i; }
            i = i + 1;
        }
        return -1;
    }

    static void Main() {
        CardDefinition strike = CardDefinition.Create(
            "strike", "Strike", 1, "attack")
            .AddEffect(CardEffectKind.Damage(), 6, CardTarget.Enemy());
        CardDefinition guard = CardDefinition.Create(
            "guard", "Guard", 1, "skill")
            .AddEffect(CardEffectKind.Block(), 5, CardTarget.Self());
        CardDefinition focus = CardDefinition.Create(
            "focus", "Focus", 1, "power")
            .AddEffect(CardEffectKind.Strength(), 2, CardTarget.Self())
            .AddEffect(CardEffectKind.Draw(), 1, CardTarget.Self());

        CardDeck deck = CardDeck.Create(77);
        deck.Add(strike);
        deck.Add(strike);
        deck.Add(guard);
        deck.Add(guard);
        deck.Add(focus);
        deck.Add(strike);

        CardBattle battle = CardBattle.Create(
            CardActor.Create("hero", 40),
            CardActor.Create("slime", 30),
            deck);
        battle.Start();
        Console.WriteLine(
            "zones=" + Convert.ToString(deck.DrawPile().Count())
            + "," + Convert.ToString(deck.Hand().Count())
            + "," + Convert.ToString(deck.DiscardPile().Count()));

        int focusIndex = Program.Find(deck.Hand(), "focus");
        CardPlayResult focusResult = battle.Play(focusIndex);
        Console.WriteLine(
            "focus=" + Convert.ToString(focusResult.Success())
            + "," + Convert.ToString(battle.Player().Strength())
            + "," + Convert.ToString(focusResult.Drawn())
            + "," + Convert.ToString(battle.Energy()));

        int strikeIndex = Program.Find(deck.Hand(), "strike");
        CardPlayResult strikeResult = battle.Play(strikeIndex);
        Console.WriteLine(
            "strike=" + Convert.ToString(strikeResult.Damage())
            + "," + Convert.ToString(battle.Enemy().Hp())
            + "," + Convert.ToString(battle.Energy()));

        int enemyDamage = battle.EndPlayerTurn();
        Console.WriteLine(
            "turn=" + Convert.ToString(battle.Turn())
            + ",hurt=" + Convert.ToString(enemyDamage)
            + ",hp=" + Convert.ToString(battle.Player().Hp())
            + ",hand=" + Convert.ToString(deck.Hand().Count()));
    }
}
