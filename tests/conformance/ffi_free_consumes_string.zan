using System;

class BufferHolder {
    string buf;

    [DllImport("crt")]
    static extern void free(string ptr);

    void Drop() {
        free(this.buf);
        this.buf = null;
    }
}

class Program {
    [DllImport("crt")]
    static extern string calloc(int count, int size);

    [DllImport("crt")]
    static extern void free(string ptr);

    [DllImport("crt", EntryPoint = "free")]
    static extern void release(string ptr);

    static void Main() {
        string buf = calloc(17, 1);
        buf[0] = 65;
        free(buf);
        Console.WriteLine(Convert.ToString(buf == null));

        string aliased = calloc(17, 1);
        release(aliased);
        Console.WriteLine(Convert.ToString(aliased == null));

        BufferHolder holder = new BufferHolder();
        holder.buf = calloc(17, 1);
        free(holder.buf);
        Console.WriteLine(Convert.ToString(holder.buf == null));

        holder.buf = calloc(17, 1);
        holder.Drop();
        Console.WriteLine(Convert.ToString(holder.buf == null));

        free(calloc(17, 1));
        Console.WriteLine("done");
    }
}
