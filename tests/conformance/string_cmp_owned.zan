// Regression: comparing an *owned* string temporary (one returned by a call,
// not bound to a local) against another string must release that temporary.
// Previously `method() == "literal"` leaked the callee's +1 result because the
// `==` path never released owned operands (unlike the string-concat path).
using System;

class Box {
    string s;
    Box() { this.s = ""; }
    // Mixed returns (a field plus a literal) make the result an owned (+1)
    // value the caller is responsible for releasing.
    string pick() {
        if (this.s.Length > 0) { return this.s; }
        return "";
    }
}

class Program {
    static string fresh(string tail) {
        string x = "__" + tail;
        return x.Substring(2);
    }

    static int Run() {
        Box b = new Box();
        b.s = fresh("PONG");

        int hits = 0;
        if (b.pick() == "PONG") { hits = hits + 1; }        // owned == literal
        if (b.pick() != "NOPE") { hits = hits + 1; }        // owned != literal
        if (fresh("OK") == "OK") { hits = hits + 1; }      // owned == owned/literal
        if ("PONG" == b.pick()) { hits = hits + 1; }        // literal == owned

        b.s = null;
        return hits;
    }

    static void Main() {
        int r = Run();
        Console.WriteLine(r);
    }
}
