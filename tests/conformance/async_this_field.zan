using System;

// Regression test: explicit `this.field` inside an async instance method must
// read the receiver (not the resume function's frame pointer), both before and
// after a suspension. Instance async methods must also return their result.

class Accumulator {
    int total;
    int step;

    static Accumulator Make(int start, int step) {
        Accumulator a = new Accumulator();
        a.total = start;
        a.step = step;
        return a;
    }

    // explicit `this` read with no suspension
    async int Peek() {
        return this.total;
    }

    // explicit `this` read/write across a suspension
    async int Bump() {
        int before = this.total;
        await Task.Delay(1);
        this.total = this.total + this.step;
        await Task.Delay(1);
        return before * 1000 + this.total;
    }
}

class Program {
    static async int Run() {
        Accumulator a = Accumulator.Make(10, 5);
        Console.WriteLine(await a.Peek());   // 10
        Console.WriteLine(await a.Bump());   // before=10, total=15 -> 10015
        Console.WriteLine(await a.Bump());   // before=15, total=20 -> 15020
        Console.WriteLine(await a.Peek());   // 20
        return 0;
    }

    static void Main() {
        int r = await Run();
    }
}
