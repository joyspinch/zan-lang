using System;
using System.Data;

class Program {
    [DllImport("crt")]
    static extern string calloc(int count, int size);

    [DllImport("crt")]
    static extern void free(string ptr);

    static void Main() {
        string buf = calloc(9, 1);
        int i = 0;
        while (i < 8) {
            buf[i] = i + 1;
            i = i + 1;
        }
        Console.WriteLine(DbConnection.HandleFromBuf(buf));
        buf[0] = 52;
        buf[1] = 18;
        Console.WriteLine(DbConnection.Int16FromBuf(buf));
        buf[0] = 97;
        buf[1] = 98;
        buf[2] = 0;
        Console.WriteLine(DbConnection.ScanNul(buf, 8));
        Console.WriteLine(DbConnection.BufToString(buf, 8));
        free(buf);

        DbConnection db = DbConnection.OpenODBC("Driver={ZanMissingDriver};");
        Console.WriteLine(db.IsConnected());
        Console.WriteLine(db.GetError());
    }
}
