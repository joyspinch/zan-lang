// Exceptions: multiple typed catch clauses dispatch on the runtime type via
// RTTI, matching the first clause whose type is a base of the thrown object.
class NotFound : Exception { NotFound(string m) { this.Message = m; } }
class Denied : Exception { Denied(string m) { this.Message = m; } }
class Program {
    static void raise(int k) {
        if (k == 1) { throw new NotFound("nf"); }
        if (k == 2) { throw new Denied("dn"); }
        throw new Exception("other");
    }
    static void run(int k) {
        try {
            raise(k);
        } catch (NotFound e) {
            Console.WriteLine("NotFound:" + e.Message);
        } catch (Denied e) {
            Console.WriteLine("Denied:" + e.Message);
        } catch (Exception e) {
            Console.WriteLine("Exception:" + e.Message);
        }
    }
    static void Main() {
        run(1);
        run(2);
        run(3);
    }
}
