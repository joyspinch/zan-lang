using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Counter Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default");
        SkillConfig slash = SkillConfig.Create("slash", "Slash")
            .SetRange(1, 0)
            .SetPriority(5)
            .SetFormula("a.ж”»еҮ» - b.йҳІеҫЎ")
            .SetAbsolute(true, false);
        SkillConfig counter = SkillConfig.Create("counter", "Counter")
            .SetRange(1, 0)
            .SetPriority(10)
            .SetFormula("a.ж”»еҮ» - b.йҳІеҫЎ")
            .SetAbsolute(true, false);
        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetVitals(100, 100, 0, 0)
            .SetCombat(100, 0, 0)
            .AddAttr("ж”»еҮ»", 20)
            .AddSkill("slash");
        NpcConfig enemyConfig = NpcConfig.Create("enemy")
            .SetVitals(100, 100, 0, 0)
            .SetCombat(100, 0, 0)
            .SetBehavior(0, 1)
            .AddAttr("ж”»еҮ»", 10)
            .AddSkill("counter");
        MapConfig field = MapConfig.Create("field")
            .SetGrid(10, 10, 6, 4)
            .SetDefault(true)
            .SetStart(1, 1)
            .AddSpawn(MapSpawn.Of(
                "enemy", Faction.Enemy, 2, 1, 0, 1));
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddSkill(slash)
            .AddSkill(counter)
            .AddNpc(heroConfig)
            .AddNpc(enemyConfig)
            .AddMap(field);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Start("");
        ZgmWorld world = engine.World();
        ZgmActor hero = world.Hero();
        ZgmActor enemy = world.ActorAt(1);
        ZgmSkillResult result = world.CastSkill(
            hero, "slash", enemy);
        Console.WriteLine(
            "cast=" + Convert.ToString((int)result.Status()));
        Console.WriteLine(
            "hp=" + Convert.ToString(hero.Hp()) + "|"
                + Convert.ToString(enemy.Hp()));
    }
}
