// LINQ B4: Contains/Distinct/In with an EqualityComparer delegate give
// Equals-style structural semantics for reference types (plain == is
// reference identity there).
using System;
using System.Linq;

class Point {
    public int X;
    public int Y;
    public Point(int x, int y) { X = x; Y = y; }
}

class Program {
    static bool Eq(Point a, Point b) {
        return a.X == b.X && a.Y == b.Y;
    }

    static void Main() {
        List<Point> pts = new List<Point>();
        pts.Add(new Point(1, 1));
        pts.Add(new Point(2, 2));
        pts.Add(new Point(1, 1));

        Point probe = new Point(1, 1);
        Console.WriteLine("id.contains=" + Convert.ToString(pts.Contains(probe)));
        Console.WriteLine("eq.contains=" + Convert.ToString(pts.Contains(probe, Eq)));

        List<Point> uniq = pts.Distinct(Eq);
        Console.WriteLine("eq.distinct=" + Convert.ToString(uniq.Count));

        List<Point> vals = new List<Point>();
        vals.Add(new Point(1, 1));
        List<Point> hits = pts.In(vals, Eq);
        Console.WriteLine("eq.in=" + Convert.ToString(hits.Count));
        Console.WriteLine("done");
    }
}
