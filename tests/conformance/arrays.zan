using System;
namespace Conf;
class Program {
    static void Main() {
        int[] a = new int[5];
        int i = 0;
        while (i < 5) { a[i] = i * i; i = i + 1; }
        int sum = 0;
        i = 0;
        while (i < 5) { sum = sum + a[i]; i = i + 1; }
        Console.WriteLine(sum);
        Console.WriteLine(a[3]);
    }
}
