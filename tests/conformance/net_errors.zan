// Net error model: connection failures surface as null / HttpRequestException
// instead of silently returning empty values. Uses localhost port 1 (reserved,
// nothing listens there) as a deterministic refused-connection target.
using System;
using System.Net.Sockets;
using System.Net.Http;

class Program {
    static async void Run() {
        TcpClient conn = await TcpClient.ConnectAsync("127.0.0.1", 1);
        if (conn == null) {
            Console.WriteLine("tcp=null");
        } else {
            Console.WriteLine("tcp=connected");
            conn.Close();
        }

        HttpClient client = HttpClient.Create("127.0.0.1", 1);
        try {
            string body = await client.GetAsync("/");
            Console.WriteLine("http=no-throw");
        } catch (HttpRequestException e) {
            Console.WriteLine("http=" + e.Message);
        }
        Console.WriteLine("done");
    }

    static void Main() {
        await Run();
    }
}
