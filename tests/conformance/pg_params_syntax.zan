using System;
using System.Data;
using System.Data.Postgres;

// Compile-and-logic check for the parameterized PG layer (no server needed):
// verifies ?->$n placeholder rewriting and that the parameterized overloads
// short-circuit safely on an unconnected handle.
class Program {
    static void Main() {
        Console.WriteLine(PgConnection.ToDollarParams(
            "SELECT * FROM t WHERE a = ? AND b = 'x?y' AND c = ?"));

        PgConnection db = new PgConnection();
        DbParams p = DbParams.Create().Add("v").AddInt(2).AddNull();
        Console.WriteLine("exec: " + Convert.ToString(db.Execute("UPDATE t SET a=? WHERE b=?", p)));
        Console.WriteLine("rows: " + Convert.ToString(db.Query("SELECT ?", p).RowCount()));
        Console.WriteLine("scalar: [" + db.ExecuteScalar("SELECT ?", p) + "]");
    }
}
