// Conformance: indexing a List<string> that is stored in a class field, from
// inside an instance method, via explicit `this.field[i]`. This previously
// mis-typed the element load (returning an integer 0 instead of the string
// pointer), corrupting StringBuilder.Append and string comparisons.
using System;

class Bag {
    List<string> items;

    Bag() { this.items = new List<string>(); }

    void Add(string s) { this.items.Add(s); }

    string Join() {
        StringBuilder sb = new StringBuilder();
        int i = 0;
        while (i < this.items.Count) {
            sb.Append(this.items[i]);              // append string element
            if (this.items[i] == "x") {            // compare string element
                sb.Append("!");
            }
            i = i + 1;
        }
        return sb.ToString();
    }
}

class Program {
    static void Main() {
        Bag bag = new Bag();
        bag.Add("a");
        bag.Add("x");
        bag.Add("b");
        Console.WriteLine(bag.Join());             // ax!b
    }
}
