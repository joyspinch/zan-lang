// Json error model: JsonValue.Parse throws JsonException on malformed input
// (validated by an allocation-free scan before the tree is built), while
// ParseLenient keeps the old best-effort behaviour for authored UI docs.
using System;
using System.Json;

class Program {
    static void TryParse(string label, string src) {
        try {
            JsonValue v = JsonValue.Parse(src);
            Console.WriteLine(label + "=ok kind.obj=" + Convert.ToString(v.IsObject()));
        } catch (JsonException e) {
            Console.WriteLine(label + "=" + e.Message);
        }
    }

    static void Main() {
        JsonValue doc = JsonValue.Parse("{\"a\": 1, \"b\": [true, null, \"x\"], \"s\": \"he\\nllo\"}");
        Console.WriteLine("a=" + Convert.ToString(doc.Int("a", 0)));
        Console.WriteLine("b1=" + Convert.ToString(doc.Get("b").At(0).AsBool(false)));
        Console.WriteLine("count=" + Convert.ToString(doc.Get("b").Count()));

        TryParse("truncobj", "{\"a\":");
        TryParse("truncarr", "[1, 2");
        TryParse("nocolon", "{\"a\" 1}");
        TryParse("badlit", "trux");
        TryParse("trailing", "true x");
        TryParse("unterm", "\"abc");
        TryParse("badnum", "[1, -x]");

        JsonValue part = JsonValue.ParseLenient("{\"a\": 5, \"b\":");
        Console.WriteLine("lenient.a=" + Convert.ToString(part.Int("a", 0)));
        Console.WriteLine("done");
    }
}
