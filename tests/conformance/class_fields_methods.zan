using System;
namespace Conf;
class Counter {
    public int total;
    public Counter() { }
    void Add(int n) { total = total + n; }
    int Get() { return total; }
    public int Run() {
        Add(10);
        Add(5);
        return Get();
    }
}
class Program {
    static void Main() {
        var c = new Counter();
        Console.WriteLine(c.Run());
    }
}
