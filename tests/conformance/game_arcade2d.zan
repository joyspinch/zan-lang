using System;
using Game.Arcade2D;

namespace Tests.GameArcade2D;

class Program {
    static void Main() {
        Console.WriteLine(
            "rect=" + Convert.ToString(Collision2D.Rects(
                Rect2.Create(0.0, 0.0, 10.0, 10.0),
                Rect2.Create(9.0, 9.0, 4.0, 4.0))));
        Console.WriteLine(
            "circle=" + Convert.ToString(Collision2D.Circles(
                Circle2.Create(0.0, 0.0, 4.0),
                Circle2.Create(7.0, 0.0, 4.0))));

        AnimationClip clip = AnimationClip.Create("pulse", false)
            .Add(0, 0, 16, 16, 50)
            .Add(16, 0, 16, 16, 50)
            .Add(32, 0, 16, 16, 50);
        AnimationPlayer player = AnimationPlayer.Create(clip);
        player.Update(120);
        Console.WriteLine(
            "anim=" + Convert.ToString(player.FrameIndex())
            + "," + Convert.ToString(player.Playing()));
        player.Update(50);
        Console.WriteLine(
            "done=" + Convert.ToString(player.FrameIndex())
            + "," + Convert.ToString(player.Finished()));

        ArcadeWorld world = ArcadeWorld.Create();
        ArcadeEntity hero = world.Spawn(1, 1, 0.0, 0.0, 20.0, 20.0);
        hero.SetHealth(20);
        ArcadeEntity enemy = world.Spawn(1, 2, 30.0, 0.0, 20.0, 20.0);
        enemy.SetHealth(10);
        Console.WriteLine(
            "closest=" + Convert.ToString(
                world.FindClosestEnemy(hero, 100.0).Id()));

        ArcadePath path = ArcadePath.Create()
            .Add(0.0, 0.0)
            .Add(10.0, 0.0)
            .Add(10.0, 10.0);
        path.Follow(hero, 10.0, 0.5);
        world.Update(1000);
        path.Follow(hero, 10.0, 0.5);
        world.Update(1000);
        path.Follow(hero, 10.0, 0.5);
        Console.WriteLine(
            "path=" + Convert.ToString((int)hero.X())
            + "," + Convert.ToString((int)hero.Y())
            + "," + Convert.ToString(hero.PathIndex()));

        int oldEnemyId = enemy.Id();
        enemy.Damage(10);
        ArcadeEntity reused = world.Spawn(
            2, 2, 50.0, 50.0, 8.0, 8.0);
        Console.WriteLine(
            "pool=" + Convert.ToString(world.Capacity())
            + "," + Convert.ToString(reused.Kind())
            + "," + Convert.ToString(reused.Id() > oldEnemyId));
    }
}
