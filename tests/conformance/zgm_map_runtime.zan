using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Map Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default");
        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetVitals(100, 100, 0, 0);
        MapConfig field = MapConfig.Create("field")
            .SetGrid(10, 10, 6, 5)
            .SetDefault(true)
            .SetStart(1, 1)
            .SetViewport(MapViewport.Create(0, 0, 20, 20));
        field.AddCell(MapCell.Of(2, 0, 1));
        field.AddCell(MapCell.Of(2, 1, 1));
        field.AddCell(MapCell.Of(2, 2, 1));
        field.AddCell(MapCell.Of(2, 3, 1));

        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddNpc(heroConfig)
            .AddMap(field);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Start("");
        ZgmWorld world = engine.World();
        ZgmCamera camera = world.Camera();
        Console.WriteLine(
            "camera=" + Convert.ToString(camera.OffsetX())
                + "," + Convert.ToString(camera.OffsetY()));
        Console.WriteLine(
            "screen=" + Convert.ToString(camera.WorldToScreenX(1))
                + "," + Convert.ToString(camera.WorldToScreenY(1))
                + "|cell=" + Convert.ToString(camera.ScreenToWorldX(5))
                + "," + Convert.ToString(camera.ScreenToWorldY(5)));

        ZgmActor hero = world.Hero();
        world.MoveActor(hero, 5, 4);
        Console.WriteLine(
            "follow=" + Convert.ToString(camera.OffsetX())
                + "," + Convert.ToString(camera.OffsetY()));
        Console.WriteLine(
            "edgeScreen=" + Convert.ToString(camera.WorldToScreenX(5))
                + "," + Convert.ToString(camera.WorldToScreenY(4)));

        ZgmPath path = world.FindPath(0, 0, 4, 0);
        Console.WriteLine(
            "path=" + Convert.ToString(path != null)
                + "|" + Convert.ToString(path.Count()) + "|"
                + Convert.ToString(path.Next().X()) + ","
                + Convert.ToString(path.Next().Y()) + "|"
                + Convert.ToString(path.CellAt(path.Count() - 1).X())
                + "," + Convert.ToString(
                    path.CellAt(path.Count() - 1).Y()));

        MapConfig blocked = MapConfig.Create("blocked")
            .SetGrid(10, 10, 3, 3);
        blocked.AddCell(MapCell.Of(1, 0, 1));
        blocked.AddCell(MapCell.Of(1, 1, 1));
        blocked.AddCell(MapCell.Of(1, 2, 1));
        ZgmPath noPath = ZgmPathfinder.Find(
            blocked, 0, 1, 2, 1);
        Console.WriteLine("unreachable=" + Convert.ToString(noPath == null));
    }
}
