using System;

namespace StrIndex;

class Program {
    static void Main() {
        string s = "Hello";
        Console.WriteLine(s.Length);   // 5
        Console.WriteLine(s[0]);       // 72
        Console.WriteLine(s[1]);       // 101
        Console.WriteLine(s[4]);       // 111
        int sum = 0;
        int i = 0;
        while (i < s.Length) {
            sum = sum + s[i];
            i = i + 1;
        }
        Console.WriteLine(sum);        // 500
        int cnt = 0;
        i = 0;
        while (i < s.Length) {
            if (s[i] == 108) { cnt = cnt + 1; }
            i = i + 1;
        }
        Console.WriteLine(cnt);        // 2
    }
}
