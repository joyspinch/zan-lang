// RTTI: `is` tests runtime type against a base/derived, `as` yields the object
// on a successful cast or null otherwise.
class Animal { int tag; Animal() { this.tag = 0; } }
class Dog : Animal { Dog() { this.tag = 1; } }
class Cat : Animal { Cat() { this.tag = 2; } }
class Program {
    static void Main() {
        Animal a = new Dog();
        Console.WriteLine(a is Animal);
        Console.WriteLine(a is Dog);
        Console.WriteLine(a is Cat);
        Dog d = a as Dog;
        Console.WriteLine(d == null);
        Cat c = a as Cat;
        Console.WriteLine(c == null);
    }
}
