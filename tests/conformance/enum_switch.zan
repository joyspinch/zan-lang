using System;
namespace P;
enum Color { Red, Green, Blue }
class Program {
    static int Weight(Color c) {
        switch (c) {
            case Color.Red: return 1;
            case Color.Green: return 2;
            case Color.Blue: return 3;
            default: return 0;
        }
    }
    static string Name(int n) {
        switch (n) {
            case 1: return "one";
            case 2: return "two";
            default: return "many";
        }
    }
    static void Main() {
        Console.WriteLine(Weight(Color.Red));
        Console.WriteLine(Weight(Color.Blue));
        Console.WriteLine(Name(2));
        Console.WriteLine(Name(9));
        Color c = Color.Green;
        Console.WriteLine(Weight(c));
    }
}
