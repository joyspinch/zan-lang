using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Occupancy Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default");
        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetVitals(100, 100, 0, 0);
        NpcConfig enemyConfig = NpcConfig.Create("enemy")
            .SetVitals(50, 50, 0, 0);
        MapConfig field = MapConfig.Create("field")
            .SetGrid(10, 10, 8, 3)
            .SetDefault(true)
            .SetStart(6, 1);
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddNpc(heroConfig)
            .AddNpc(enemyConfig)
            .AddMap(field);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Start("");
        ZgmWorld world = engine.World();
        ZgmActor blocker = world.CreateActor(
            "enemy", Faction.Enemy, 2, 1);
        ZgmActor chaser = world.CreateActor(
            "enemy", Faction.Enemy, 0, 1);
        ZgmActor hero = world.Hero();
        Console.WriteLine(
            "occupied=" + Convert.ToString(
                world.IsOccupied(2, 1, chaser)));
        Console.WriteLine(
            "move=" + Convert.ToString(
                world.MoveActor(chaser, 2, 1)));
        ZgmPath path = world.FindPathForActor(
            chaser, hero.X(), hero.Y());
        bool containsBlocked = false;
        int i = 0;
        while (i < path.Count()) {
            if (path.CellAt(i).X() == blocker.X()
                && path.CellAt(i).Y() == blocker.Y()) {
                containsBlocked = true;
            }
            i = i + 1;
        }
        Console.WriteLine(
            "path=" + Convert.ToString(path != null) + "|"
                + Convert.ToString(path.Count()) + "|blocked="
                + Convert.ToString(containsBlocked) + "|first="
                + Convert.ToString(path.Next().X()) + ","
                + Convert.ToString(path.Next().Y()) + "|last="
                + Convert.ToString(
                    path.CellAt(path.Count() - 1).X()) + ","
                + Convert.ToString(
                    path.CellAt(path.Count() - 1).Y()));
    }
}
