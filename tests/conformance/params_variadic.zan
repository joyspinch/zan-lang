class Calc {
    public static int Sum(params int[] xs) {
        int t = 0;
        int i = 0;
        while (i < xs.Count) { t = t + xs[i]; i = i + 1; }
        return t;
    }
    public static string Join(string sep, params string[] parts) {
        string r = "";
        int i = 0;
        while (i < parts.Count) {
            if (i > 0) { r = r + sep; }
            r = r + parts[i];
            i = i + 1;
        }
        return r;
    }
    public int Mul(params int[] xs) {
        int t = 1;
        int i = 0;
        while (i < xs.Count) { t = t * xs[i]; i = i + 1; }
        return t;
    }
}
class Program {
    static void Main() {
        Console.WriteLine(Calc.Sum(1, 2, 3, 4));
        Console.WriteLine(Calc.Sum());
        Console.WriteLine(Calc.Join("-", "a", "b", "c"));
        Calc c = new Calc();
        Console.WriteLine(c.Mul(2, 3, 4));
        List<int> pre = new List<int>();
        pre.Add(5); pre.Add(6);
        Console.WriteLine(Calc.Sum(pre));
    }
}
