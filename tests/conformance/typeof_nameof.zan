using System;

namespace TypeofNameof;

class Widget {
    public int Size;
}

class Program {
    static void Main(string[] args) {
        int count = 42;
        Console.WriteLine(typeof(int));            // int
        Console.WriteLine(typeof(string));         // string
        Console.WriteLine(typeof(List<int>));      // List<int>
        Console.WriteLine(typeof(Widget));         // Widget
        Console.WriteLine(typeof(double[]));       // double[]
        Console.WriteLine(nameof(count));          // count
        Console.WriteLine(nameof(Widget));         // Widget
        Widget w = new Widget();
        w.Size = count;
        Console.WriteLine(nameof(w.Size));         // Size
        Console.WriteLine("t=" + typeof(bool) + " n=" + nameof(args));
    }
}
