using System;
using Game.Arpg;

namespace Tests.ArpgUiRuntime;

class Program {
    static int nodeDown;
    static int controlDown;
    static int windowDown;
    static int controlLinks;
    static int systemLinks;
    static int nodeCreated;
    static int nodeUpdated;
    static int nodeCustom;
    static int controlCreated;
    static int controlUpdated;
    static int controlFocus;
    static int controlCustom;
    static int windowCreated;
    static int windowUpdated;
    static int windowCustom;

    static void OnNodeCreated(string nodeId) {
        Program.nodeCreated = Program.nodeCreated + 1;
    }

    static void OnNodeUpdated(string nodeId, int deltaMilliseconds) {
        Program.nodeUpdated = Program.nodeUpdated + 1;
    }

    static void OnNodeCustom(
        string nodeId,
        string name,
        string payload
    ) {
        Program.nodeCustom = Program.nodeCustom + 1;
    }

    static void OnControlCreated(string controlId) {
        Program.controlCreated = Program.controlCreated + 1;
    }

    static void OnControlUpdated(string controlId, int deltaMilliseconds) {
        Program.controlUpdated = Program.controlUpdated + 1;
    }

    static void OnControlFocus(string controlId, bool focused) {
        if (focused) {
            Program.controlFocus = Program.controlFocus + 1;
        }
    }

    static void OnControlCustom(
        string controlId,
        string name,
        string payload
    ) {
        Program.controlCustom = Program.controlCustom + 1;
    }

    static void OnWindowCreated(string windowId) {
        Program.windowCreated = Program.windowCreated + 1;
    }

    static void OnWindowUpdated(string windowId, int deltaMilliseconds) {
        Program.windowUpdated = Program.windowUpdated + 1;
    }

    static void OnWindowCustom(
        string windowId,
        string name,
        string payload
    ) {
        Program.windowCustom = Program.windowCustom + 1;
    }

    static bool OnNodeDown(
        string nodeId,
        int button,
        int modifiers,
        double x,
        double y
    ) {
        Program.nodeDown = Program.nodeDown + 1;
        return false;
    }

    static bool OnControlDown(
        string controlId,
        string nodeId,
        int button,
        int modifiers,
        double x,
        double y
    ) {
        Program.controlDown = Program.controlDown + 1;
        return false;
    }

    static bool OnWindowDown(
        string windowId,
        string controlId,
        int button,
        int modifiers,
        double x,
        double y
    ) {
        Program.windowDown = Program.windowDown + 1;
        return true;
    }

    static void OnControlLink(
        string controlId,
        string link
    ) {
        Program.controlLinks = Program.controlLinks + 1;
        Console.WriteLine("control.link=" + link);
    }

    static void OnSystemLink(
        string windowId,
        string controlId,
        string link
    ) {
        Program.systemLinks = Program.systemLinks + 1;
        Console.WriteLine(
            "system.link=" + windowId + "," + controlId + "," + link);
    }

    static void Main() {
        ArpgDataSource source = ArpgDataSource.Create();
        source.SetText("名称", "青云");
        source.SetText("职业", "战士");
        source.SetNumber("hp", 88.0);
        source.SetNumber("maxhp", 100.0);
        source.SetNumber("属性.攻击", 25.0);

        string template = "&名称& &hp&/&maxhp& "
            + "{if &职业& == '战士'}剑:{if &属性.攻击& >= 20}强{else}弱{end}"
            + "{elseif &职业& == '法师'}法{else}其他{end}";
        Console.WriteLine("template=" + ArpgTemplate.Evaluate(template, source));

        ArpgRichTextDocument parsed = ArpgRichText.Parse(
            "#R红#c(0,255,0,255)绿#p(icon,1,2,16,16)"
            + "#@open,42|1@打开@#item(potion,3)",
            source);
        Console.WriteLine("runs=" + Convert.ToString(parsed.RunCount()));
        Console.WriteLine(
            "run2=" + Convert.ToString(parsed.RunAt(2).Kind())
            + "," + parsed.RunAt(2).Resource());
        Console.WriteLine(
            "link=" + parsed.RunAt(3).Link().At(0)
            + "," + parsed.RunAt(3).Link().At(1));

        ArpgNodeDefinition node = ArpgNodeDefinition.Create(
            "caption", ArpgNodeKind.Text(), 0, 0, 80, 20);
        node.SetMouseEvents(true);
        node.SetContent("&name&", false);
        node.Events().OnPointerDown(Program.OnNodeDown);
        node.Events().OnCreated(Program.OnNodeCreated);
        node.Events().OnUpdated(Program.OnNodeUpdated);
        node.Events().OnCustomEvent(Program.OnNodeCustom);

        ArpgDataSource controlSource = ArpgDataSource.Create();
        controlSource.SetText("name", "Hero");
        controlSource.SetNumber("hp", 1.0);

        ArpgControlDefinition control = ArpgControlDefinition.Create(
            "status", ArpgControlKind.RichTextBox(), 10, 10, 120, 40);
        control.SetMouseEvents(true);
        control.SetDraggable(true);
        control.SetDataSource(controlSource);
        control.SetContent(
            "&name& {if &hp& > 0}alive{else}dead{end} #@open,42@go@",
            true);
        control.AddNode(node);
        control.Events().OnPointerDown(Program.OnControlDown);
        control.Events().OnLinkActivated(Program.OnControlLink);
        control.Events().OnCreated(Program.OnControlCreated);
        control.Events().OnUpdated(Program.OnControlUpdated);
        control.Events().OnFocusChanged(Program.OnControlFocus);
        control.Events().OnCustomEvent(Program.OnControlCustom);

        ArpgWindowDefinition window = ArpgWindowDefinition.Create(
            "hud", 200, 100);
        window.SetVisibleByDefault(true);
        window.AddControl(control);
        window.Events().OnPointerDown(Program.OnWindowDown);
        window.Events().OnCreated(Program.OnWindowCreated);
        window.Events().OnUpdated(Program.OnWindowUpdated);
        window.Events().OnCustomEvent(Program.OnWindowCustom);

        ArpgControlDefinition playerStatus = ArpgControlDefinition.Create(
            "player", ArpgControlKind.Label(), 10, 60, 180, 20);
        playerStatus.SetContent(
            "&名称& &hp&/&maxhp& attack=&属性.攻击&", false);
        window.AddControl(playerStatus);

        ArpgProject project = ArpgProject.Create();
        project.AddWindow(window);
        ArpgActorDefinition hero = ArpgActorDefinition.Create(
            "hero", "Default Hero");
        hero.SetDefaultPlayer(true);
        hero.Attributes().SetHp(75.0);
        hero.Attributes().SetMaxHp(100.0);
        hero.Attributes().SetCustom("攻击", 33.0);
        project.AddActor(hero);
        project.AddItem(ArpgItemDefinition.Create("potion", "Potion"));
        ArpgMapDefinition map = ArpgMapDefinition.Create("start", 4, 4);
        map.SetDefaultMap(true);
        project.AddMap(map);
        ArpgEvents events = ArpgEvents.Create();
        events.OnRichTextLink(Program.OnSystemLink);
        ArpgGameplayEvents gameplay = ArpgGameplayEvents.Create();
        ArpgWorld world = ArpgWorld.CreateWithEvents(project, events, gameplay);
        ArpgUiRuntime ui = ArpgUiRuntime.Create(project, world, events);
        world.EnterDefaultMap();
        ui.Update(16);
        ArpgControl runtimeControl = ui.FindControl("hud", "status");

        Console.WriteLine(
            "player=" + ui.FindControl("hud", "player").Content());
        Console.WriteLine("content=" + runtimeControl.Content());
        ui.PointerDown(ArpgPointerButton.Left(), 0, 15.0, 15.0);
        ui.PointerMove(
            ArpgPointerButton.Left(), 0, 20.0, 18.0, 5.0, 3.0);
        ui.PointerUp(ArpgPointerButton.Left(), 0, 20.0, 18.0);
        Console.WriteLine(
            "events=" + Convert.ToString(Program.nodeDown)
            + "," + Convert.ToString(Program.controlDown)
            + "," + Convert.ToString(Program.windowDown));
        Console.WriteLine(
            "drag=" + Convert.ToString(runtimeControl.X())
            + "," + Convert.ToString(runtimeControl.Y()));

        int linkRun = -1;
        int i = 0;
        while (i < runtimeControl.Document().RunCount()) {
            if (runtimeControl.Document().RunAt(i).IsLink()) {
                linkRun = i;
            }
            i = i + 1;
        }
        runtimeControl.ActivateLink(linkRun);
        Console.WriteLine(
            "links=" + Convert.ToString(Program.controlLinks)
            + "," + Convert.ToString(Program.systemLinks));

        runtimeControl.NodeAt(0).FireCustom("node", "payload");
        runtimeControl.FireCustom("control", "payload");
        ui.FindWindow("hud").FireCustom("window", "payload");
        Console.WriteLine(
            "custom=" + Convert.ToString(Program.nodeCustom)
            + "," + Convert.ToString(Program.controlCustom)
            + "," + Convert.ToString(Program.windowCustom));

        controlSource.SetNumber("hp", 0.0);
        ui.Update(16);
        Console.WriteLine("updated=" + runtimeControl.Content());
        Console.WriteLine(
            "lifecycle=" + Convert.ToString(Program.nodeCreated)
            + "," + Convert.ToString(Program.nodeUpdated)
            + "," + Convert.ToString(Program.controlCreated)
            + "," + Convert.ToString(Program.controlUpdated)
            + "," + Convert.ToString(Program.windowCreated)
            + "," + Convert.ToString(Program.windowUpdated)
            + "," + Convert.ToString(Program.controlFocus));
    }
}
