using System;

namespace Conf;

// Entity mapper lambdas: a delegate whose parameter is a class must receive the
// object pointer so field access (r.revenue / r.month) works, in var-decl,
// call-argument and stored-delegate contexts.
class Row { string month; int revenue; }
delegate double NumOf(Row r);
delegate string StrOf(Row r);

class Prog {
    static double SumBy(List<Row> rows, NumOf sel) {
        double a = 0.0; int i = 0;
        while (i < rows.Count) { a = a + sel(rows[i]); i = i + 1; }
        return a;
    }
    static void Main() {
        List<Row> rows = new List<Row>();
        rows.Add(new Row { month = "Q1", revenue = 10 });
        rows.Add(new Row { month = "Q2", revenue = 25 });
        NumOf f = r => (double)r.revenue;
        Console.WriteLine(Convert.ToString((int)f(rows[0])));
        Console.WriteLine(Convert.ToString((int)Prog.SumBy(rows, r => (double)r.revenue)));
        StrOf g = r => r.month;
        Console.WriteLine(g(rows[1]));
    }
}
