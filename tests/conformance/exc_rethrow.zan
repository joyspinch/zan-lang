// Exceptions: a bare `throw;` in a catch re-raises the current exception, which
// propagates to the caller's handler after the inner finally runs.
class Program {
    static void inner() {
        try {
            throw new Exception("orig");
        } catch (Exception e) {
            Console.WriteLine("inner sees:" + e.Message);
            throw;
        } finally {
            Console.WriteLine("inner finally");
        }
    }
    static void Main() {
        try {
            inner();
        } catch (Exception e) {
            Console.WriteLine("outer sees:" + e.Message);
        }
    }
}
