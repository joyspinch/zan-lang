using System;

class Program {
    static void Main() {
        // string switch
        string k = "beta";
        switch (k) {
            case "alpha": Console.WriteLine("A"); break;
            case "beta": Console.WriteLine("B"); break;
            default: Console.WriteLine("D"); break;
        }
        switch ("nope") {
            case "alpha": Console.WriteLine("A"); break;
            default: Console.WriteLine("DEF"); break;
        }

        // StringBuilder: Append(string/int), AppendLine, Length
        StringBuilder sb = new StringBuilder();
        sb.Append("ab");
        sb.AppendLine("cd");
        sb.Append(42);
        Console.WriteLine(sb.Length);
        Console.WriteLine(sb.ToString());

        // array .Length
        int[] xs = new int[3];
        Console.WriteLine(xs.Length);
        string[] ss = new string[5];
        Console.WriteLine(ss.Length);

        // string.Split
        string csv = "a,bb,ccc";
        List<string> parts = csv.Split(",");
        Console.WriteLine(parts.Count);
        for (int i = 0; i < parts.Count; i++) {
            Console.WriteLine(parts[i]);
        }
        string s2 = "x--y--";
        List<string> p2 = s2.Split("--");
        Console.WriteLine(p2.Count);
        Console.WriteLine(p2[2].Length);

        // Dictionary: indexer set/get, Add, ContainsKey, Remove, Count
        Dictionary<string, int> d = new Dictionary<string, int>();
        d["a"] = 1;
        d["b"] = 2;
        d["a"] = 10;
        Console.WriteLine(d.Count);
        Console.WriteLine(d["a"]);
        Console.WriteLine(d["b"]);
        Console.WriteLine(d.ContainsKey("a"));
        Console.WriteLine(d.ContainsKey("zz"));
        d.Remove("a");
        Console.WriteLine(d.Count);

        Dictionary<int, string> m = new Dictionary<int, string>();
        m[7] = "seven";
        m[9] = "nine";
        Console.WriteLine(m[7]);
        Console.WriteLine(m[9]);
        Console.WriteLine(m.ContainsKey(9));

        // numeric parsing and conversion
        int n = int.Parse("42");
        Console.WriteLine(n);
        double dd = double.Parse("3.5");
        Console.WriteLine(dd);
        Console.WriteLine(Convert.ToDouble("2.25"));
        bool ok = int.TryParse("13", out int v);
        Console.WriteLine(ok);
        Console.WriteLine(v);
        bool bad = int.TryParse("xy", out int w);
        Console.WriteLine(bad);

        // Math.Round
        Console.WriteLine(Math.Round(2.6));
        Console.WriteLine(Math.Round(2.34567, 2));

        // string statics
        Console.WriteLine(string.IsNullOrEmpty(""));
        Console.WriteLine(string.IsNullOrEmpty("a"));
        Console.WriteLine(string.Join(",", new List<string> { "a", "b", "c" }));
        Console.WriteLine(string.Format("{0}-{1}", 5, "x"));
    }
}
