using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Prefab Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default");
        PrefabConfig prefab = PrefabConfig.Create("button")
            .SetSize(80, 30)
            .SetMouseEvent(true);
        TextNode label = new TextNode("label");
        label.SetTitle("OK").At(8, 4);
        prefab.AddNode(label);
        SpriteNode icon = new SpriteNode("icon");
        icon.SetImage("res/icon.png").At(2, 2);
        prefab.AddNode(icon);
        Skin skin = Skin.Create("button-skin")
            .SetFont("default", 2)
            .SetImage("res/button.png")
            .SetNineGrid(NineGrid.Of(4, 4, 4, 4))
            .SetThreeLayer(true);
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddPrefab(prefab)
            .AddSkin(skin);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Start("");
        ZgmUiRuntime ui = engine.Ui();
        ZgmPrefabInstance instance = ui.InstantiatePrefab(
            "button", 10, 20, "button-skin");
        Console.WriteLine(
            "created=" + Convert.ToString(instance != null)
                + "|" + Convert.ToString(ui.PrefabCount()));
        Console.WriteLine(
            "box=" + Convert.ToString(instance.X()) + ","
                + Convert.ToString(instance.Y()) + "|"
                + Convert.ToString(instance.Width()) + ","
                + Convert.ToString(instance.Height()) + "|"
                + Convert.ToString(instance.NodeCount()));
        Console.WriteLine(
            "skin=" + instance.SkinName() + "|"
                + instance.Style().Image() + "|"
                + Convert.ToString(instance.Style().Nine().Left())
                + "|" + Convert.ToString(
                    instance.Style().ThreeLayer()));
        Console.WriteLine(
            "node=" + Convert.ToString(
                instance.SetNodePosition("label", 12, 6))
                + "|" + Convert.ToString(
                    instance.FindNode("label").X()) + ","
                + Convert.ToString(instance.FindNode("label").Y()));
        instance.SetProperty("x", 5.0, true);
        instance.SetAlpha(0.5);
        Console.WriteLine(
            "state=" + Convert.ToString(instance.X()) + "|"
                + Convert.ToString(instance.Alpha()));
        Tween tween = Tween.Create().Add(
            TweenStep.To("button", 100, Easing.Linear)
                .Set("x", 100.0));
        ui.StartTween(tween, null);
        ui.Update(50);
        Console.WriteLine("tween=" + Convert.ToString(instance.X()));
        Console.WriteLine(
            "remove=" + Convert.ToString(ui.RemovePrefab(instance))
                + "|" + Convert.ToString(ui.PrefabCount()));
    }
}
