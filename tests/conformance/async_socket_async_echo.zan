// Conformance: reactor-driven echo over the migrated canonical Socket.*Async
// (B-full). A single async task plays both ends over loopback:
// Socket.ConnectAsync suspends until the client socket is writable (connection
// established), Socket.AcceptAsync suspends until the listener is readable,
// then PING -> Socket.RecvAsync(server) -> Socket.SendStringAsync(server) ->
// Socket.RecvAsync(client). Every Socket.*Async call genuinely suspends to the
// IO reactor and resumes when the fd is ready. Prints the echoed "PING".
using System;
using System.Net.Sockets;

class Program {
    static async int Echo() {
        Socket.Initialize();

        int listener = Socket.CreateTcp();
        Socket.SetReuseAddr(listener);
        Socket.Bind(listener, "127.0.0.1", 54331);
        Socket.Listen(listener, 8);
        Socket.SetNonBlocking(listener);

        int client = Socket.CreateTcp();
        Socket.SetNonBlocking(client);
        int rc = await Socket.ConnectAsync(client, "127.0.0.1", 54331);

        int server = await Socket.AcceptAsync(listener);
        Socket.SetNonBlocking(server);

        int sent = await Socket.SendStringAsync(client, "PING");

        string req = await Socket.RecvAsync(server, 64);
        int echoed = await Socket.SendStringAsync(server, req);

        string reply = await Socket.RecvAsync(client, 64);
        Console.WriteLine(reply);

        Socket.Close(client);
        Socket.Close(server);
        Socket.Close(listener);
        Socket.Cleanup();
        return 0;
    }

    static void Main() {
        int r = await Echo();
    }
}
