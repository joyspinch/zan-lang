using System;
using Game.Zgm;

namespace T;

class Program {
    static int stateEvents;
    static int lastState;
    static string lastLink;

    static void OnWindowState(int state) {
        Program.stateEvents = Program.stateEvents + 1;
        Program.lastState = state;
    }
    static void OnRichTextLink(
        string windowName,
        string widgetName,
        string link
    ) {
        Program.lastLink = windowName + "|" + widgetName + "|" + link;
    }

    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM UI Events")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        RichTextBox message = new RichTextBox("message")
            .SetContent(
                RichText.Create()
                    .Text("Menu ")
                    .Link("open-inventory", "Inventory")
                    .Build());
        message.At(0, 0).Size(200, 40);
        WindowConfig hud = WindowConfig.Create("hud")
            .SetSize(220, 80)
            .SetDefaultVisible(true)
            .AddWidget(message);
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddWindow(hud);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Events().OnWindowStateChanged(Program.OnWindowState);
        engine.Events().OnRichTextLink(Program.OnRichTextLink);
        Console.WriteLine("start=" + Convert.ToString(engine.Start("")));
        ZgmUiRuntime ui = engine.Ui();
        Console.WriteLine(
            "initial=" + Convert.ToString(ui.WindowState())
                + "|" + Convert.ToString(
                ui.SetWindowState(0))
                + "|" + Convert.ToString(ui.WindowState()));
        Console.WriteLine(
            "states=" + Convert.ToString(ui.SetWindowState(1))
                + "|" + Convert.ToString(ui.SetWindowState(2))
                + "|" + Convert.ToString(ui.SetWindowState(3))
                + "|" + Convert.ToString(Program.stateEvents)
                + "|" + Convert.ToString(Program.lastState));
        Console.WriteLine(
            "link=" + Convert.ToString(
                ui.ActivateRichTextLink(
                    "hud", "message", "open-inventory"))
                + "|" + Program.lastLink);
        Console.WriteLine(
            "bad=" + Convert.ToString(
                ui.ActivateRichTextLink("hud", "message", ""))
                + "|" + Convert.ToString(
                ui.ActivateRichTextLink("hud", "missing", "x")));
        engine.Stop();
        engine.Dispose();
        project.Dispose();
    }
}
