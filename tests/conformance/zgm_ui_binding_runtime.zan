using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("UI Binding Test")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        ItemConfig potion = ItemConfig.Create("potion", "Potion")
            .SetCategory("道具", "消耗")
            .SetIcon("res/potion.png")
            .SetMaxStack(5)
            .SetCooldown("potion", 500);
        ItemConfig sword = ItemConfig.Create("sword", "Sword")
            .SetCategory("装备", "武器")
            .SetIcon("res/sword.png");
        SkillConfig slash = SkillConfig.Create("slash", "Slash")
            .SetIcon("res/slash.png")
            .SetTooltip("A quick strike")
            .SetInterval(1000);
        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetDisplayName("Hero")
            .SetVitals(100, 100, 30, 30)
            .AddSkill("slash");
        MapConfig field = MapConfig.Create("field")
            .SetGrid(32, 32, 10, 10)
            .SetDefault(true)
            .SetStart(1, 1);

        ProgressBar hp = new ProgressBar("hp");
        ShowBox show = new ShowBox("show");
        SkillBox skill = new SkillBox("skill");
        ItemBox item = new ItemBox("item");
        BagBox bag = new BagBox("bag").SetGrid(4, 4);
        WindowConfig hud = WindowConfig.Create("hud")
            .SetSize(400, 200)
            .SetDefaultVisible(true)
            .AddWidget(hp)
            .AddWidget(show)
            .AddWidget(skill)
            .AddWidget(item)
            .AddWidget(bag);

        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddItem(potion)
            .AddItem(sword)
            .AddSkill(slash)
            .AddNpc(heroConfig)
            .AddMap(field)
            .AddWindow(hud);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        bool started = engine.Start("");
        Console.WriteLine("start=" + Convert.ToString(started));
        if (!started) {
            ZgmDiagnostics failed = engine.Diagnostics();
            int failedIndex = 0;
            while (failedIndex < failed.Count()) {
                Console.WriteLine(failed.At(failedIndex).Message());
                failedIndex = failedIndex + 1;
            }
            return;
        }
        ZgmActor hero = engine.World().Hero();
        engine.World().AddItem(hero, "potion", 3);
        engine.World().AddItem(hero, "sword", 1);

        ZgmUiRuntime ui = engine.Ui();
        Console.WriteLine(
            "bind=" + Convert.ToString(
                ui.BindHeroProgress("hud", "hp", "hp", "maxhp"))
                + "|" + Convert.ToString(
                ui.BindHeroShowBox("hud", "show", 0))
                + "|" + Convert.ToString(
                ui.BindHeroSkillBox("hud", "skill", "slash"))
                + "|" + Convert.ToString(
                ui.BindHeroItemBox("hud", "item", "potion"))
                + "|" + Convert.ToString(
                ui.BindHeroBagBox("hud", "bag", "", ""))
                + "|" + Convert.ToString(ui.BindingCount()));

        ZgmWidgetState hpState = ui.FindWidget("hud", "hp");
        ZgmWidgetState showState = ui.FindWidget("hud", "show");
        ZgmWidgetState skillState = ui.FindWidget("hud", "skill");
        ZgmWidgetState itemState = ui.FindWidget("hud", "item");
        Console.WriteLine(
            "initial=" + Convert.ToString(hpState.Data().Value())
                + "/" + Convert.ToString(hpState.Data().Maximum())
                + "|" + showState.Data().DisplayName()
                + "|" + skillState.Data().Icon()
                + "|" + Convert.ToString(skillState.Data().Ready())
                + "|" + Convert.ToString(itemState.Data().Quantity())
                + "|" + Convert.ToString(
                    ui.BoundBagSlotCount("hud", "bag")));
        Console.WriteLine(
            "slots=" + ui.BoundBagItemNameAt("hud", "bag", 0)
                + ":" + Convert.ToString(
                    ui.BoundBagQuantityAt("hud", "bag", 0))
                + "|" + ui.BoundBagItemNameAt("hud", "bag", 1)
                + ":" + Convert.ToString(
                    ui.BoundBagQuantityAt("hud", "bag", 1)));

        hero.TakeDamage(25);
        hero.Cooldowns().Start("skill:slash", 300);
        engine.Update(100);
        Console.WriteLine(
            "refresh=" + Convert.ToString(hpState.Data().Value())
                + "/" + Convert.ToString(hpState.Data().Maximum())
                + "|" + Convert.ToString(skillState.Data().Cooldown())
                + "|" + Convert.ToString(skillState.Data().Ready()));

        engine.World().UseItem(hero, "potion");
        engine.Update(500);
        Console.WriteLine(
            "itemRefresh=" + Convert.ToString(itemState.Data().Quantity())
                + "|" + Convert.ToString(itemState.Data().Ready()));
        Console.WriteLine(
            "remove=" + Convert.ToString(
                ui.RemoveWidgetBinding("hud", "bag"))
                + "|" + Convert.ToString(ui.BindingCount())
                + "|" + Convert.ToString(
                    ui.BoundBagSlotCount("hud", "bag")));
        engine.Stop();
        engine.Dispose();
        project.Dispose();
    }
}
