using System;
using Game.Scene;

namespace T;

class Program {
    static void L(string tag, SceneRect r) {
        Console.WriteLine(tag + " " + SceneDoc.IntStr(r.Xi()) + "," + SceneDoc.IntStr(r.Yi())
            + " " + SceneDoc.IntStr(r.Wi()) + "x" + SceneDoc.IntStr(r.Hi()));
    }

    static void Main() {
        SceneDoc d = SceneDoc.Create("hud", 1280, 720);
        d.SetBackground("bg/field.png");
        d.Add(SceneElement.Create("bar", "hpBar")
            .At(24, 24).Size(220, 20)
            .AnchorTo(Anchor.Min(), Anchor.Min())
            .Caption("HP"));
        d.Add(SceneElement.Create("sprite", "crosshair")
            .At(0, 0).Size(48, 48)
            .AnchorTo(Anchor.Mid(), Anchor.Mid()));
        d.Add(SceneElement.Create("button", "skill1")
            .At(-80, -80).Size(64, 64)
            .AnchorTo(Anchor.Max(), Anchor.Max()));

        d.Add(SceneElement.Create("bagslot", "bag")
            .At(10, 10).Size(44, 44)
            .AnchorTo(Anchor.Min(), Anchor.Max())
            .Grid(5, 8, 4, 4));

        // Round-trip through the .zscene JSON format.
        SceneDoc s = SceneDoc.Parse(d.ToJson());
        Console.WriteLine("count=" + SceneDoc.IntStr(s.Count()));
        Console.WriteLine("bg=" + s.Background());
        SceneElement bag = s.Find("bag");
        Console.WriteLine("bag=" + SceneDoc.IntStr(bag.Rows()) + "x" + SceneDoc.IntStr(bag.Cols())
            + " total " + SceneDoc.IntStr(bag.TotalW()) + "x" + SceneDoc.IntStr(bag.TotalH()));

        s.SetMode(ScaleMode.Fit());
        Program.L("fit-1920 cross", s.Resolve(s.Find("crosshair"), 1920, 1080));
        Program.L("fit-1920 hp", s.Resolve(s.Find("hpBar"), 1920, 1080));
        Program.L("fit-1920 skill", s.Resolve(s.Find("skill1"), 1920, 1080));
        Program.L("fit-800 hp", s.Resolve(s.Find("hpBar"), 800, 600));

        s.SetMode(ScaleMode.Stretch());
        Program.L("stretch-800 hp", s.Resolve(s.Find("hpBar"), 800, 600));

        s.SetMode(ScaleMode.None());
        Program.L("none-800 cross", s.Resolve(s.Find("crosshair"), 800, 600));
    }
}
