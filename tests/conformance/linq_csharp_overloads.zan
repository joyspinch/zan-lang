// C#-style LINQ overloads resolved by type-aware extension overload
// resolution: the lambda's inferred body type picks between int/string/double
// key delegates, and the receiver's concrete element type picks typed
// overloads (List<string> Contains/Distinct/In, List<double> aggregates).
using System;
using System.Linq;

class User {
    public string name;
    public int age;
    public double score;
    public User(string n, int a, double s) { name = n; age = a; score = s; }
}

class Program {
    static void Main() {
        List<User> us = new List<User>();
        us.Add(new User("carol", 35, 88.5));
        us.Add(new User("alice", 30, 92.0));
        us.Add(new User("bob", 25, 75.5));

        List<User> byName = us.OrderBy(u => u.name);
        Console.WriteLine("byname=" + byName[0].name);
        List<User> byAge = us.OrderBy(u => u.age);
        Console.WriteLine("byage=" + byAge[0].name);
        List<User> byScore = us.OrderByDescending(u => u.score);
        Console.WriteLine("byscore=" + byScore[0].name);

        List<Grouping<User>> gs = us.GroupBy(u => u.name.Substring(0, 1));
        Console.WriteLine("groups=" + Convert.ToString(gs.Count));

        Console.WriteLine("sumage=" + Convert.ToString(us.Sum(u => u.age)));
        Console.WriteLine("sumscore=" + Convert.ToString(us.Sum(u => u.score)));

        List<string> xs = new List<string>();
        xs.Add("he" + "llo");
        xs.Add("world");
        xs.Add("hel" + "lo");
        Console.WriteLine("contains=" + Convert.ToString(xs.Contains("hello")));
        Console.WriteLine("distinct=" + Convert.ToString(xs.Distinct().Count));
        List<string> vals = new List<string>();
        vals.Add("world");
        Console.WriteLine("in=" + Convert.ToString(xs.In(vals).Count));

        List<double> ds = new List<double>();
        ds.Add(1.5);
        ds.Add(2.5);
        ds.Add(0.5);
        Console.WriteLine("sum=" + Convert.ToString(ds.Sum()));
        Console.WriteLine("min=" + Convert.ToString(ds.Min()));
        Console.WriteLine("max=" + Convert.ToString(ds.Max()));
        Console.WriteLine("avg=" + Convert.ToString(ds.Average()));
        Console.WriteLine("done");
    }
}
