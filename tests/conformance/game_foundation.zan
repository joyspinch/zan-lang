using System;
using Game.Foundation;

namespace Tests.GameFoundation;

class DemoScene : IGameScene {
    string id;
    int enters;
    int pauses;
    int resumes;
    int fixedTicks;

    DemoScene(string id) { this.id = id; }

    string Name() { return this.id; }
    void Enter() { this.enters = this.enters + 1; }
    void Exit() {}
    void Pause() { this.pauses = this.pauses + 1; }
    void Resume() { this.resumes = this.resumes + 1; }
    void FixedUpdate(int deltaMilliseconds) {
        this.fixedTicks = this.fixedTicks + deltaMilliseconds;
    }
    void Update(int deltaMilliseconds) {}

    int Enters() { return this.enters; }
    int Pauses() { return this.pauses; }
    int Resumes() { return this.resumes; }
    int FixedTicks() { return this.fixedTicks; }
}

class Program {
    static void Main() {
        FixedStepClock clock = FixedStepClock.Create(20, 4);
        Console.WriteLine("steps=" + Convert.ToString(clock.Advance(55)));
        int simulated = 0;
        while (clock.HasStep()) {
            simulated = simulated + clock.ConsumeStep();
        }
        Console.WriteLine("simulated=" + Convert.ToString(simulated));
        Console.WriteLine("alpha=" + Convert.ToString((int)(clock.Alpha() * 10.0)));

        GameTimer timer = GameTimer.Repeating(30);
        Console.WriteLine("triggers=" + Convert.ToString(timer.Tick(95)));
        Console.WriteLine("remaining=" + Convert.ToString(timer.Remaining()));

        InputMap input = InputMap.Create()
            .BindKey("accept", 40)
            .BindKey("accept", 44);
        input.BeginFrame();
        input.ProcessKey(40, true);
        Console.WriteLine(
            "pressed=" + Convert.ToString(input.Pressed("accept"))
            + ",down=" + Convert.ToString(input.Down("accept")));
        input.BeginFrame();
        input.ProcessKey(44, true);
        input.ProcessKey(40, false);
        Console.WriteLine(
            "held=" + Convert.ToString(input.Down("accept"))
            + ",released=" + Convert.ToString(input.Released("accept")));
        input.BeginFrame();
        input.ProcessKey(44, false);
        Console.WriteLine(
            "up=" + Convert.ToString(input.Down("accept"))
            + ",released=" + Convert.ToString(input.Released("accept")));

        DeterministicRandom random = DeterministicRandom.Create(42);
        int first = random.NextBelow(100);
        int state = random.State();
        int second = random.NextBelow(100);
        random.Restore(state);
        Console.WriteLine(
            "random=" + Convert.ToString(first)
            + "," + Convert.ToString(second)
            + "," + Convert.ToString(random.NextBelow(100)));

        SceneStack stack = SceneStack.Create();
        DemoScene a = new DemoScene("a");
        DemoScene b = new DemoScene("b");
        stack.Push(a);
        stack.Push(b);
        stack.FixedUpdate(16);
        stack.Pop();
        stack.FixedUpdate(20);
        Console.WriteLine(
            "scene=" + a.Name()
            + "," + Convert.ToString(a.Enters())
            + "," + Convert.ToString(a.Pauses())
            + "," + Convert.ToString(a.Resumes())
            + "," + Convert.ToString(a.FixedTicks())
            + "," + Convert.ToString(b.FixedTicks()));
    }
}
