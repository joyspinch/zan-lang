// Conformance: reactor-driven AsyncSocket end-to-end echo (B-lite).
// A single async task plays both ends over loopback: AsyncSocket.Connect
// suspends until the client socket is writable (connection established),
// AsyncSocket.Accept suspends until the listener is readable, then
// PING -> AsyncSocket.Receive(server) -> AsyncSocket.SendString(server) ->
// AsyncSocket.Receive(client). Every AsyncSocket.* call genuinely suspends to
// the IO reactor and resumes when the fd is ready. Prints the echoed "PING".
using System;
using System.Net.Sockets;

class Program {
    static async int Echo() {
        Socket.Initialize();

        int listener = Socket.CreateTcp();
        Socket.SetReuseAddr(listener);
        Socket.Bind(listener, "127.0.0.1", 54329);
        Socket.Listen(listener, 8);
        Socket.SetNonBlocking(listener);

        int client = Socket.CreateTcp();
        Socket.SetNonBlocking(client);
        int rc = await AsyncSocket.Connect(client, "127.0.0.1", 54329);

        int server = await AsyncSocket.Accept(listener);
        Socket.SetNonBlocking(server);

        int sent = await AsyncSocket.SendString(client, "PING");

        string req = await AsyncSocket.Receive(server, 64);
        int echoed = await AsyncSocket.SendString(server, req);

        string reply = await AsyncSocket.Receive(client, 64);
        Console.WriteLine(reply);

        Socket.Close(client);
        Socket.Close(server);
        Socket.Close(listener);
        Socket.Cleanup();
        return 0;
    }

    static void Main() {
        int r = await Echo();
    }
}
