using System;
using System.IO;
using Game.Rts.Formats;

namespace T;

class Program {
    static extern int fopen(string path, string mode);
    static extern int fwrite(string buf, int size, int count, int fp);
    static extern int fclose(int fp);
    static extern string calloc(int count, int size);
    static extern void free(string ptr);

    static void Main() {
        // Synthesize a clean-room 256-entry 6-bit palette (no original assets):
        //   entry i -> R = i % 64, G = (i * 2) % 64, B = 63 - (i % 64)
        string buf = calloc(769, 1);
        int i = 0;
        while (i < 256) {
            int r = i % 64;
            int g = (i * 2) % 64;
            int b = 63 - (i % 64);
            buf[i * 3 + 0] = (char)r;
            buf[i * 3 + 1] = (char)g;
            buf[i * 3 + 2] = (char)b;
            i = i + 1;
        }
        // Scratch file lives in the process CWD (a relative path) so the test
        // is portable: a hardcoded POSIX "/tmp/..." path does not exist on
        // native Windows, where fopen would fail and the parse would diverge.
        int fp = fopen("rts_test.pal", "wb");
        fwrite(buf, 1, 768, fp);
        fclose(fp);
        free(buf);

        Palette p = Palette.FromFile("rts_test.pal");
        Console.WriteLine("count=" + Convert.ToString(p.Count()));
        Console.WriteLine("e0=" + Convert.ToString(p.R(0)) + "," + Convert.ToString(p.G(0)) + "," + Convert.ToString(p.B(0)));
        Console.WriteLine("e1=" + Convert.ToString(p.R(1)) + "," + Convert.ToString(p.G(1)) + "," + Convert.ToString(p.B(1)));
        Console.WriteLine("e63=" + Convert.ToString(p.R(63)) + "," + Convert.ToString(p.G(63)) + "," + Convert.ToString(p.B(63)));
        Console.WriteLine("scale0=" + Convert.ToString(Palette.Scale8(0)));
        Console.WriteLine("scale32=" + Convert.ToString(Palette.Scale8(32)));
        Console.WriteLine("scale63=" + Convert.ToString(Palette.Scale8(63)));
        Console.WriteLine("rgb63=" + Convert.ToString(p.Rgb8(63)));
    }
}
