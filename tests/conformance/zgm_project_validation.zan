using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Validation")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        MapConfig start = MapConfig.Create("start")
            .SetGrid(32, 32, 4, 4)
            .SetDefault(true)
            .SetStart(0, 0);
        start.AddSpawn(
            MapSpawn.Of("missing", Faction.Enemy, 9, 9, -1, 0));
        start.AddPortal(MapPortal.Of(1, 5, 5, "target", 9, 9));
        MapConfig target = MapConfig.Create("target")
            .SetGrid(32, 32, 2, 2);
        NpcConfig enemy = NpcConfig.Create("enemy")
            .SetDropChance(101)
            .AddDrop(DropEntry.Of("missing-item", 0, 0));
        Label first = new Label("duplicate");
        Label second = new Label("duplicate");
        WindowConfig hud = WindowConfig.Create("hud")
            .SetSize(0, 0)
            .SetSkin("missing-skin")
            .AddWidget(first)
            .AddWidget(second);
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddMap(start)
            .AddMap(target)
            .AddNpc(enemy)
            .AddWindow(hud);
        ZgmDiagnostics diagnostics = project.Validate();
        string codes = "";
        int i = 0;
        while (i < diagnostics.Count()) {
            if (i > 0) { codes = codes + "|"; }
            codes = codes + diagnostics.At(i).Code();
            i = i + 1;
        }
        Console.WriteLine(
            "errors=" + Convert.ToString(diagnostics.ErrorCount()));
        Console.WriteLine("codes=" + codes);
        project.Dispose();
    }
}
