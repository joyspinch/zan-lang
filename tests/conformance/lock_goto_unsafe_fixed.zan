using System;

class Counter {
    public int n;
}

class Program {
    static Counter shared = new Counter();

    static void Bump() {
        lock (shared) {
            shared.n = shared.n + 1;
        }
    }

    static void Main() {
        lock (shared) {
            lock (shared) {
                shared.n = 5;
            }
            Console.WriteLine(shared.n);
        }
        Bump();
        Console.WriteLine(shared.n);

        int i = 0;
    top:
        if (i < 3) {
            Console.WriteLine(i);
            i = i + 1;
            goto top;
        }

        goto done;
        Console.WriteLine(99);
    done:
        Console.WriteLine("done");

        unsafe {
            int x = 7;
            Console.WriteLine(x);
        }

        fixed (string s = "pinned") {
            Console.WriteLine(s);
        }
    }
}
