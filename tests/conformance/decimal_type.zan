// Conformance: decimal type (mapped to double) and m/M literal suffix.
using System;

class Program {
    static decimal Scale(decimal v, decimal f) {
        return v * f;
    }

    static void Main() {
        decimal price = 19.5m;
        decimal qty = 3M;
        decimal total = price * qty;
        Console.WriteLine(Convert.ToString(total));        // 58.5
        Console.WriteLine(Convert.ToString(Scale(2.5m, 4m))); // 10

        decimal sum = 0m;
        List<decimal> vals = new List<decimal> { 0.25m, 0.5m, 1m };
        int i = 0;
        while (i < vals.Count) { sum = sum + vals[i]; i = i + 1; }
        Console.WriteLine(Convert.ToString(sum));          // 1.75

        decimal half = (decimal)1 / 2m;
        Console.WriteLine(Convert.ToString(half));         // 0.5
    }
}
