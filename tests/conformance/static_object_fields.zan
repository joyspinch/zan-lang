using System;
namespace Conf;

// Regression: static fields of reference types (user classes and collections)
// must round-trip through their backing global. A field read such as
// `Store.box.num` or `Store.items.Count` must load the stored object, not
// fold to a default num, and mutations made through a static field passed
// into a helper must persist.

class Box {
    int num;
    static Box Of(int v) { Box b = new Box(); b.num = v; return b; }
}

class Store {
    static Box box;
    static List<int> items;

    static void Fill(List<int> list) {
        list.Add(1);
        list.Add(2);
        list.Add(3);
    }

    static void Main() {
        Store.box = Box.Of(42);
        Console.WriteLine(Store.box.num);

        Store.items = new List<int>();
        Store.Fill(Store.items);
        Console.WriteLine(Store.items.Count);
        Store.items.Add(4);
        Console.WriteLine(Store.items.Count);
        Console.WriteLine(Store.items[0]);
    }
}
