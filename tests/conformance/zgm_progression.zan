using System;
using System.Collections.Generic;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Progression")
            .SetScreen(640, 480)
            .SetDefaultFont("default");

        LevelGrowth growth = LevelGrowth.Create("hero-growth");
        List<ZgmAttr> level1 = new List<ZgmAttr>();
        level1.Add(ZgmAttr.Of("maxhp", 100));
        level1.Add(ZgmAttr.Of("升级经验", 50));
        growth.AddLevel(level1);
        List<ZgmAttr> level2 = new List<ZgmAttr>();
        level2.Add(ZgmAttr.Of("maxhp", 120));
        level2.Add(ZgmAttr.Of("升级经验", 100));
        growth.AddLevel(level2);
        List<ZgmAttr> level3 = new List<ZgmAttr>();
        level3.Add(ZgmAttr.Of("maxhp", 140));
        growth.AddLevel(level3);

        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetGrowth("hero-growth", 1)
            .SetVitals(100, 100, 0, 0);
        MapConfig field = MapConfig.Create("field")
            .SetGrid(64, 32, 8, 8)
            .SetDefault(true)
            .SetStart(1, 1);

        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddGrowth(growth)
            .AddNpc(heroConfig)
            .AddMap(field);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        engine.Start("");

        ZgmActor hero = engine.World().Hero();
        Console.WriteLine(
            "initial=" + Convert.ToString(hero.Level()) + "|"
                + Convert.ToString(hero.Experience()) + "|"
                + Convert.ToString(hero.Attribute("maxhp")));
        Console.WriteLine(
            "gain1=" + Convert.ToString(
                engine.World().GainExperience(hero, 25))
                + "|" + Convert.ToString(hero.Level()) + "|"
                + Convert.ToString(hero.Experience()));
        Console.WriteLine(
            "gain2=" + Convert.ToString(
                engine.World().GainExperience(hero, 25))
                + "|" + Convert.ToString(hero.Level()) + "|"
                + Convert.ToString(hero.Experience()) + "|"
                + Convert.ToString(hero.Attribute("maxhp")));
        Console.WriteLine(
            "gain3=" + Convert.ToString(
                engine.World().GainExperience(hero, 125))
                + "|" + Convert.ToString(hero.Level()) + "|"
                + Convert.ToString(hero.Experience()) + "|"
                + Convert.ToString(hero.Attribute("maxhp")));
    }
}
