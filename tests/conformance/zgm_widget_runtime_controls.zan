using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("Widget Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        SkillConfig slash = SkillConfig.Create("slash", "Slash")
            .SetIcon("res/slash.png")
            .SetInterval(1000);
        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetHero(true)
            .SetDisplayName("Hero")
            .SetVitals(100, 100, 20, 20)
            .AddSkill("slash");
        MapConfig field = MapConfig.Create("field")
            .SetGrid(32, 32, 10, 10)
            .SetDefault(true)
            .SetStart(3, 4);

        CheckBox warrior = new CheckBox("warrior")
            .SetTitle("Warrior")
            .SetGroup(1);
        warrior.At(0, 0).Size(50, 20);
        CheckBox mage = new CheckBox("mage")
            .SetTitle("Mage")
            .SetGroup(1);
        mage.At(60, 0).Size(50, 20);
        ComboBox combo = new ComboBox("class");
        combo.AddItem(ComboItem.Of("warrior", "Warrior"))
            .AddItem(ComboItem.Of("mage", "Mage"));
        combo.At(0, 30).Size(120, 20);
        TabBox tabs = new TabBox("pages");
        tabs.AddTab("Stats").AddTab("Skills").AddTab("Items");
        tabs.At(0, 60).Size(160, 20);
        ListBox list = new ListBox("ranking");
        list.At(0, 90).Size(200, 60);
        QuickBox quick = new QuickBox("quick");
        quick.At(0, 160).Size(40, 40);
        MapBox mini = new MapBox("mini");
        mini.At(200, 0).Size(120, 120);
        WindowConfig hud = WindowConfig.Create("hud")
            .SetSize(400, 240)
            .SetDefaultVisible(true)
            .AddWidget(warrior)
            .AddWidget(mage)
            .AddWidget(combo)
            .AddWidget(tabs)
            .AddWidget(list)
            .AddWidget(quick)
            .AddWidget(mini);

        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddSkill(slash)
            .AddNpc(heroConfig)
            .AddMap(field)
            .AddWindow(hud);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        Console.WriteLine("start=" + Convert.ToString(engine.Start("")));
        ZgmUiRuntime ui = engine.Ui();
        ZgmWidgetState warriorState = ui.FindWidget("hud", "warrior");
        ZgmWidgetState mageState = ui.FindWidget("hud", "mage");
        ZgmWidgetState comboState = ui.FindWidget("hud", "class");
        ZgmWidgetState tabState = ui.FindWidget("hud", "pages");
        ZgmWidgetState listState = ui.FindWidget("hud", "ranking");
        ZgmWidgetState quickState = ui.FindWidget("hud", "quick");
        ZgmWidgetState mapState = ui.FindWidget("hud", "mini");

        Console.WriteLine(
            "check=" + Convert.ToString(
                ui.SetCheckBox("hud", "warrior", true))
                + "|" + Convert.ToString(warriorState.Selected())
                + "|" + Convert.ToString(
                ui.SetCheckBox("hud", "mage", true))
                + "|" + Convert.ToString(warriorState.Selected())
                + "|" + Convert.ToString(mageState.Selected()));
        ui.PointerDown(5, 5);
        ui.PointerUp(5, 5);
        Console.WriteLine(
            "clickCheck=" + Convert.ToString(warriorState.Selected())
                + "|" + Convert.ToString(mageState.Selected()));

        Console.WriteLine(
            "combo=" + Convert.ToString(
                ui.ToggleCombo("hud", "class"))
                + "|" + Convert.ToString(comboState.Expanded())
                + "|" + Convert.ToString(
                ui.SetComboSelection("hud", "class", 1))
                + "|" + Convert.ToString(comboState.SelectedIndex())
                + "|" + Convert.ToString(comboState.Expanded()));
        Console.WriteLine(
            "tab=" + Convert.ToString(
                ui.SetTabPage("hud", "pages", 2))
                + "|" + Convert.ToString(tabState.ActivePage())
                + "|" + Convert.ToString(
                ui.SetTabPage("hud", "pages", 9)));

        ZgmListRow first = ZgmListRow.Create()
            .Add("1").Add("Alice").Add("1200");
        ZgmListRow second = ZgmListRow.Create()
            .Add("2").Add("Bob").Add("1100");
        ui.AddListRow("hud", "ranking", first);
        ui.AddListRow("hud", "ranking", second);
        Console.WriteLine(
            "list=" + Convert.ToString(listState.RowCount())
                + "|" + listState.RowAt(0).ValueAt(1)
                + "|" + Convert.ToString(
                ui.SetListSelection("hud", "ranking", 1))
                + "|" + Convert.ToString(listState.SelectedIndex()));

        Console.WriteLine(
            "quick=" + Convert.ToString(
                ui.BindHeroQuickBox("hud", "quick", "skill", "slash"))
                + "|" + quickState.Data().SourceKind()
                + "|" + quickState.Data().Icon()
                + "|" + Convert.ToString(quickState.Data().Ready()));
        ZgmActor hero = engine.World().Hero();
        Console.WriteLine(
            "map=" + Convert.ToString(mapState.MapCellX())
                + "," + Convert.ToString(mapState.MapCellY())
                + "|" + Convert.ToString(mapState.MapZoom()));
        hero.SetPosition(7, 8);
        engine.Update(1);
        Console.WriteLine(
            "mapRefresh=" + Convert.ToString(mapState.MapCellX())
                + "," + Convert.ToString(mapState.MapCellY()));
        Console.WriteLine(
            "mapSet=" + Convert.ToString(
                ui.SetMapBoxView("hud", "mini", 1, 2, 0.5))
                + "|" + Convert.ToString(mapState.MapCellX())
                + "," + Convert.ToString(mapState.MapCellY())
                + "|" + Convert.ToString(mapState.MapZoom()));
        engine.Stop();
        engine.Dispose();
        project.Dispose();
    }
}
