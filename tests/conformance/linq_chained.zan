// Conformance: chained extension-method LINQ over entities with lambda
// parameter type inference (untyped `x => ...` gets its type from the
// receiver's element type through the generic delegate parameter).
using System;
using System.Linq;

class User {
    string name;
    int age;
}

class Program {
    static User Mk(string n, int a) {
        User u = new User();
        u.name = n;
        u.age = a;
        return u;
    }

    static void Main() {
        List<int> nums = new List<int>();
        int i = 1;
        while (i <= 10) { nums.Add(i); i = i + 1; }

        // chained + untyped lambda params
        List<int> evens = nums.Where(x => x % 2 == 0);
        Console.WriteLine("evens=" + Convert.ToString(evens.Count));
        List<int> mid = nums.Where(x => x > 2).Where(x => x < 9).Skip(1).Take(3);
        Console.WriteLine("mid=" + Convert.ToString(mid.Count) + " first=" + Convert.ToString(mid[0]));
        Console.WriteLine("any=" + Convert.ToString(nums.Any(x => x > 9)));
        Console.WriteLine("all=" + Convert.ToString(nums.All(x => x > 0)));
        Console.WriteLine("cnt=" + Convert.ToString(nums.Count(x => x % 3 == 0)));
        Console.WriteLine("first=" + Convert.ToString(nums.First(x => x > 4)));
        Console.WriteLine("sum=" + Convert.ToString(nums.Where(x => x % 2 == 1).Sum()));
        List<int> rev = nums.Take(3);
        rev.Reverse();
        Console.WriteLine("rev0=" + Convert.ToString(rev[0]));

        // entities: field access inside untyped lambdas
        List<User> users = new List<User>();
        users.Add(Program.Mk("carol", 41));
        users.Add(Program.Mk("alice", 17));
        users.Add(Program.Mk("bob", 25));
        List<User> adults = users.Where(u => u.age >= 18).OrderBy(u => u.age);
        Console.WriteLine("adults=" + Convert.ToString(adults.Count));
        Console.WriteLine("youngest=" + adults[0].name);
        Console.WriteLine("oldest=" + adults[adults.Count - 1].name);
        User firstB = users.First(u => u.age > 20);
        Console.WriteLine("firstB=" + firstB.name);
        List<User> desc = users.OrderByDescending(u => u.age);
        Console.WriteLine("desc0=" + desc[0].name);

        // Select projection (typed lambda: R is inferred from the annotation)
        List<string> names = adults.Select((User u) => u.name);
        Console.WriteLine("names=" + names[0] + "," + names[1]);

        // like / in
        List<string> all = users.Select((User u) => u.name);
        List<string> liked = all.Like("%aro%");
        Console.WriteLine("liked=" + Convert.ToString(liked.Count) + " " + liked[0]);
        Console.WriteLine("likeB=" + Convert.ToString(Enumerable.LikeMatch("bob", "b_b")));
        List<string> wanted = new List<string>();
        wanted.Add("bob");
        wanted.Add("dave");
        List<string> got = all.In(wanted);
        Console.WriteLine("in=" + Convert.ToString(got.Count) + " " + got[0]);
    }
}
