// S3 async/await: an async method awaits another async method (chained await,
// exercising the in-frame await protocol — register awaiter, suspend, resume-k,
// read the sub-frame result). InnerAsync(21) -> 121; OuterAsync adds 21 -> 142.
class Program {
    static async int InnerAsync(int x) {
        int r = x + 100;
        return r;
    }

    static async int OuterAsync(int y) {
        int inner = await InnerAsync(y);
        return inner + 21;
    }

    static void Main() {
        int v = await OuterAsync(21);
        Console.WriteLine(v);
    }
}
