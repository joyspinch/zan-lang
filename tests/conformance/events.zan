using System;

delegate void Action();
delegate void Notify(string msg);

class Button {
    public event Action Click;
    public event Notify Message;

    public void Press() {
        if (Click != null) { Click.Invoke(); }
    }

    public void Send(string m) {
        if (Message != null) { Message.Invoke(m); }
    }
}

class Program {
    static void Hi() { Console.WriteLine("hi"); }
    static void Bye() { Console.WriteLine("bye"); }
    static void Show(string m) { Console.WriteLine(m); }

    static void Main() {
        Button b = new Button();
        b.Press();
        Console.WriteLine("none");

        b.Click += Program.Hi;
        b.Click += Program.Bye;
        b.Click += () => { Console.WriteLine("lambda"); };
        b.Press();
        Console.WriteLine(Convert.ToString(b.Click.Count()));

        b.Click -= Program.Bye;
        b.Press();

        b.Message += Program.Show;
        b.Send("payload");
    }
}
