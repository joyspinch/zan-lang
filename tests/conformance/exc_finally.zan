// Exceptions: finally runs on the normal path, the exception-caught path, and
// when control leaves the try via return.
class Program {
    static int viaReturn() {
        try {
            return 7;
        } finally {
            Console.WriteLine("fin.return");
        }
    }
    static void Main() {
        try {
            Console.WriteLine("t1");
        } finally {
            Console.WriteLine("fin.normal");
        }
        try {
            throw new Exception("x");
        } catch (Exception e) {
            Console.WriteLine("caught");
        } finally {
            Console.WriteLine("fin.caught");
        }
        Console.WriteLine(viaReturn());
    }
}
