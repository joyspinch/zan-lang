using System;
using System.Net.Sse;

class Program {
    static SseServer srv;

    static async void ServerLoop() {
        srv.Start();
        SseConnection c = await srv.AcceptAsync();
        if (c == null) { Console.WriteLine("accept failed"); return; }
        Console.WriteLine("subscriber on " + c.Path());
        await c.SendAsync("tick", "hello");
        await c.PingAsync();
        await c.SendAsync("multi", "line1\nline2");
        await c.SendDataAsync("plain payload");
        c.Close();
    }

    static async int Run() {
        srv = SseServer.Create("127.0.0.1", 54345);
        int port = 54345;
        Task.Spawn(ServerLoop());
        await Task.Delay(50);

        SseClient c = await SseClient.ConnectAsync("127.0.0.1", port, "/events");
        Console.WriteLine("client connected: " + Convert.ToString(c.IsConnected()));
        int n = 0;
        while (true) {
            SseEvent e = await c.NextAsync();
            if (e == null) { break; }
            Console.WriteLine("event " + e.Name() + ": " + e.Data());
            n = n + 1;
        }
        Console.WriteLine("total " + Convert.ToString(n));
        c.Close();
        srv.Stop();
        return 0;
    }

    static void Main() {
        int r = await Run();
    }
}
