using System;

class Program {
    static IEnumerable<int> Range(int start, int count) {
        int i = 0;
        while (i < count) {
            yield return start + i;
            i = i + 1;
        }
    }

    static IEnumerable<int> Evens(int limit) {
        int i = 0;
        while (true) {
            if (i >= limit) {
                yield break;
            }
            if (i % 2 == 0) {
                yield return i;
            }
            i = i + 1;
        }
    }

    static IEnumerable<string> Words() {
        yield return "alpha";
        yield return "beta";
        yield return "gamma";
    }

    static void Main() {
        foreach (int x in Range(10, 4)) {
            Console.WriteLine(x);
        }

        foreach (int e in Evens(7)) {
            Console.WriteLine(e);
        }

        foreach (string w in Words()) {
            Console.WriteLine(w);
        }

        int sum = 0;
        foreach (int x in Range(1, 5)) {
            sum = sum + x;
        }
        Console.WriteLine(sum);
    }
}
