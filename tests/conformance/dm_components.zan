using System;
using System.Collections.Generic;
using Game.Dm;

namespace T;

class Program {
    static void Main() {
        // 成长 (level growth)
        LevelGrowth growth = LevelGrowth.Create("主角成长");
        List<DmAttr> lv1 = new List<DmAttr>();
        lv1.Add(DmAttr.Of("maxhp", 60));
        lv1.Add(DmAttr.Of("maxmp", 30));
        growth.AddLevel(lv1);
        List<DmAttr> lv2 = new List<DmAttr>();
        lv2.Add(DmAttr.Of("maxhp", 65));
        growth.AddLevel(lv2);
        Console.WriteLine("growthMax=" + Convert.ToString(growth.MaxLevel()));
        List<DmAttr> at1 = growth.Level(1);
        Console.WriteLine("growthLv1Count=" + Convert.ToString(at1.Count));

        // 状态 (buff)
        BuffConfig buff = BuffConfig.Create("持续恢复", "持续恢复")
            .SetDuration(-1)
            .SetTriggerInterval(2000)
            .AddPercentAttr("hp", 10)
            .AddPercentAttr("mp", 10)
            .AddPercentAttr("攻击", 5);
        Console.WriteLine("buffInf=" + Convert.ToString(buff.Infinite()));
        Console.WriteLine("buffTrig=" + Convert.ToString(buff.TriggerInterval()));
        Console.WriteLine("buffPct=" + Convert.ToString(buff.PercentAttrCount()));

        // 窗口 (window)
        WindowConfig win = WindowConfig.Create("新窗口")
            .SetTitle("窗口标题")
            .SetSize(400, 200)
            .SetMovable(true)
            .SetDefaultVisible(true)
            .SetModalMask(120);
        Console.WriteLine("winW=" + Convert.ToString(win.Width()));
        Console.WriteLine("winMove=" + Convert.ToString(win.Movable()));
        Console.WriteLine("winModal=" + Convert.ToString(win.Modal()));

        // 道具 (item)
        ItemConfig item = ItemConfig.Create("八荒刀", "八荒刀")
            .SetCategory("装备", "武器")
            .SetMaxStack(1)
            .AddAttr("攻击", 10)
            .AddResource("图集_道具", "atlas/items.dmstore");
        item.AddInner(Appearance.Image("武器", "图集_内观|00009").At(-216, -180));
        item.AddOuter(Appearance.Anim("武器", "角色动画_八荒刀"));
        Console.WriteLine("itemCat=" + item.Category());
        Console.WriteLine("itemSubFine=" + item.SubtypeFine());
        Console.WriteLine("itemEquip=" + Convert.ToString(item.IsEquipment()));
        Console.WriteLine("itemAttrs=" + Convert.ToString(item.AttrCount()));

        // 技能 (skill)
        HurtEffect hurt = HurtEffect.Create().Chance(100).Flash(DmColor.Rgba(255, 255, 255, 255));
        SkillConfig skill = SkillConfig.Create("普通攻击", "普通攻击")
            .SetRange(1, 0)
            .SetAction("攻击")
            .SetFaction("敌方")
            .SetTarget(SkillTarget.Character)
            .SetInterval(2000)
            .SetDamageDelay(500)
            .SetFormula("a.攻击 ^ 2 / ( a.攻击 + b.防御 )")
            .SetHurt(hurt);
        Console.WriteLine("skillRange=" + Convert.ToString(skill.AttackRange()));
        Console.WriteLine("skillTarget=" + Convert.ToString((int)skill.Target()));
        Console.WriteLine("skillAuto=" + Convert.ToString(skill.AutoCastable()));

        // 角色 (npc)
        NpcConfig npc = NpcConfig.Create("主角")
            .SetDisplayName("勇者")
            .SetHero(true)
            .SetGrowth("主角成长", 1)
            .SetVitals(100, 100, 100, 100)
            .SetCombat(100, 0, 0)
            .AddAttr("攻击", 10);
        npc.AddEquip(EquipSlot.Of("武器", "八荒刀").Grid("角色窗口/主角武器"));
        npc.AddDrop(DropEntry.Of("八荒刀", 1, 2));
        npc.AddDrop(DropEntry.Of("金创药小", 1, 2));
        npc.AddHealthBar(HealthBar.Create("通用血条").Offset(-110).Show(1, 1));
        Console.WriteLine("npcHero=" + Convert.ToString(npc.IsHero()));
        Console.WriteLine("npcMaxhp=" + Convert.ToString(npc.Maxhp()));
        Console.WriteLine("npcEquip=" + Convert.ToString(npc.EquipCount()));
        Console.WriteLine("npcDrops=" + Convert.ToString(npc.DropCount()));

        // 地图 (map)
        MapConfig map = MapConfig.Create("新手地图")
            .SetGrid(64, 32, 24, 48)
            .SetDefault(true)
            .SetStart(12, 24);
        map.AddObject(MapObject.Of(0, 986, 619, "美女图", 0, 0));
        map.AddCell(MapCell.Of(25, 19, 1));
        map.AddCell(MapCell.Of(17, 22, 2));
        map.AddSpawn(MapSpawn.Of("将军", Faction.Neutral, 22, 10, 0, 1).SetLevel(5));
        Console.WriteLine("mapCols=" + Convert.ToString(map.Columns()));
        Console.WriteLine("mapDefault=" + Convert.ToString(map.IsDefault()));
        Console.WriteLine("mapObjs=" + Convert.ToString(map.ObjectCount()));
        Console.WriteLine("mapCells=" + Convert.ToString(map.CellCount()));
        Console.WriteLine("mapSpawns=" + Convert.ToString(map.SpawnCount()));
        MapCell c0 = map.cells[0];
        Console.WriteLine("mapCell0Obstacle=" + Convert.ToString(c0.IsObstacle()));
    }
}
