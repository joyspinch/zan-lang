// Conformance + leak regression: class-typed locals declared inside loop and
// if bodies (direct `new` and factory-returned) must be released each time the
// enclosing block exits, not leaked per iteration. Before the fix these leaked
// one object per allocation per iteration; now --check-leaks reports zero.
using System;

class Node {
    int v;
    string tag;
    Node(int v, string tag) { this.v = v; this.tag = tag; }
}

class Program {
    static Node Make(int v) { return new Node(v, "n"); }

    static void Main() {
        int sum = 0;
        int i = 0;
        while (i < 1000) {
            Node a = new Node(i, "a");
            Node b = Program.Make(i);
            if (i % 2 == 0) {
                Node c = new Node(i * 2, "c");
                sum = sum + c.v;
            }
            sum = sum + a.v + b.v;
            i = i + 1;
        }
        for (int j = 0; j < 500; j = j + 1) {
            Node d = new Node(j, "d");
            sum = sum + d.v;
        }
        Console.WriteLine(sum);
    }
}
