using System;
namespace P;
class Counter {
    public int n;
    public Counter() { n = 0; }
    public void Inc(int by) { n = n + by; }
    public int Get() { return n; }
}
class Program {
    static void Main() {
        Counter c = new Counter();
        c.Inc(3);
        c.Inc(4);
        Console.WriteLine(c.Get());
        Counter d = new Counter();
        d.Inc(100);
        Console.WriteLine(d.Get());
        Console.WriteLine(c.Get());
    }
}
