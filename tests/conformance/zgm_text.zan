using System;
using System.Collections.Generic;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        // 丰富文本 (rich text) builder
        RichText rt = RichText.Create()
            .Light().Text("不要杀我！")
            .Green().Text("我是帮你测试")
            .Red().Text("接口的")
            .White().Text("！");
        Console.WriteLine("rt1=" + rt.Build());

        RichText rt2 = RichText.Create()
            .Text("这是")
            .Color(ZgmColor.Rgba(200, 0, 0, 200)).Text("铁匠")
            .White().Text("打造的")
            .Image("图标_炼狱")
            .Item("八荒刀")
            .Link("回去", "回上个地图");
        Console.WriteLine("rt2=" + rt2.Build());

        RichText rt3 = RichText.Create()
            .Center().Font("宋体14粗").Text("完美的疾风炼狱")
            .NewLine()
            .Placeholder(158, 100).Reset()
            .Wrap(260).Text("说明文本");
        Console.WriteLine("rt3=" + rt3.Build());

        // 模板变量 (template variables)
        TemplateVars vars = TemplateVars.Create()
            .SetInt("hp", 80).SetInt("maxhp", 100)
            .SetInt("mp", 30).SetInt("maxmp", 50)
            .Set("名称", "刘亦菲");
        Console.WriteLine("varCount=" + Convert.ToString(vars.Count()));
        Console.WriteLine("tpl1=" + vars.Render("生命: &hp&/&maxhp& 法力: &mp&/&maxmp&"));
        Console.WriteLine("tpl2=" + vars.Render("昵称: &名称& 未知: &未知&"));
        Console.WriteLine("lookupHp=" + vars.Lookup("hp"));
        string missing = vars.Lookup("nope");
        Console.WriteLine("lookupMissing=" + Convert.ToString(missing == null));

        vars.SetInt("hp", 45);
        Console.WriteLine("updatedCount=" + Convert.ToString(vars.Count()));
        Console.WriteLine("updatedHp=" + vars.Lookup("hp"));
        Console.WriteLine("updatedTpl=" + vars.Render("生命: &hp&/&maxhp&"));
        Console.WriteLine("containsHp=" + Convert.ToString(vars.Contains("hp")));
        Console.WriteLine("removeHp=" + Convert.ToString(vars.Remove("hp")));
        Console.WriteLine("containsHpAfterRemove="
            + Convert.ToString(vars.Contains("hp")));
        Console.WriteLine("removedTpl=" + vars.Render("生命: &hp&/&maxhp&"));
        vars.Clear();
        Console.WriteLine("clearCount=" + Convert.ToString(vars.Count()));
    }
}
