using System;
using System.Collections;
namespace P;
class Program {
    static void Main() {
        // int mixed with string.Length (i64), long, and casts
        string s = "hello";
        int n = s.Length;            // i64 length -> int
        long big = 1000000000;
        long sum = big + n;          // long + int
        Console.WriteLine(n);
        Console.WriteLine(sum);

        // int loop var compared against List.Count (i64)
        List<int> xs = new List<int>();
        xs.Add(7);
        xs.Add(8);
        xs.Add(9);
        int i = 0;
        int acc = 0;
        while (i < xs.Count) { acc = acc + xs[i]; i = i + 1; }
        Console.WriteLine(acc);

        // char (i64) from a cast, used as int
        int c = (int)'A';
        Console.WriteLine(c);

        // cast long -> int narrowing then widen back in arithmetic
        long L = 300;
        int t = (int)L + 5;
        Console.WriteLine(t);
    }
}
