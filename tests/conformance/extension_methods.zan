using System;

namespace ExtensionMethods;

class Point {
    public int X;
    public int Y;
}

class IntExtensions {
    public static int Twice(this int x) {
        return x * 2;
    }

    public static int Plus(this int x, int y) {
        return x + y;
    }
}

class StringExtensions {
    public static string Shout(this string s) {
        return s + "!";
    }
}

class PointExtensions {
    public static int Sum(this Point p) {
        return p.X + p.Y;
    }

    public static int Scaled(this Point p, int factor) {
        return (p.X + p.Y) * factor;
    }
}

class Program {
    static void Main() {
        int n = 21;
        Console.WriteLine(n.Twice());
        Console.WriteLine(n.Plus(9));
        Console.WriteLine(n.Twice().Twice());

        string greeting = "hello";
        Console.WriteLine(greeting.Shout());

        Point p = new Point();
        p.X = 3;
        p.Y = 4;
        Console.WriteLine(p.Sum());
        Console.WriteLine(p.Scaled(10));
    }
}
