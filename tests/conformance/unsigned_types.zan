using System;

namespace UnsignedTypes;

class Program {
    static void Main() {
        uint a = 4000000000;
        Console.WriteLine(a);          // 4000000000
        uint b = (uint)(a + a);        // wraps at 32 bits
        Console.WriteLine(b);          // 3705032704
        ushort c = (ushort)70000;      // wraps at 16 bits
        Console.WriteLine(c);          // 4464
        sbyte d = (sbyte)200;          // sign-extends from 8 bits
        Console.WriteLine(d);          // -56
        long neg = -1;
        ulong e = (ulong)neg;
        Console.WriteLine(e);          // 18446744073709551615
        Console.WriteLine(e / 3);      // 6148914691236517205
        Console.WriteLine(e % 10);     // 5
        Console.WriteLine(e >> 4);     // 1152921504606846975
        ulong hundred = 100;
        if (e > hundred) { Console.WriteLine(1); } else { Console.WriteLine(0); }
        ulong f = e / 5;
        Console.WriteLine($"e={e} f={f}");
        Console.WriteLine(typeof(uint));
        Console.WriteLine(typeof(ulong));
    }
}
