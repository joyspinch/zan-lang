using System;
namespace Conf;
class Program {
    static int Gcd(int a, int b) {
        while (b != 0) {
            int t = b;
            b = a % b;
            a = t;
        }
        return a;
    }
    static void Main() {
        Console.WriteLine(Gcd(1071, 462));
        Console.WriteLine(Gcd(48, 18));
    }
}
