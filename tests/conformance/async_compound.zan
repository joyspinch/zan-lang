// Compound await inside a loop: a value computed before the await (`acc`) must
// survive the suspension. Exercises the await A-normal-form (ANF) pass.
class Program {
    static async int Twice(int x) {
        return x * 2;
    }
    static async int SumTwice(int n) {
        int acc = 0;
        int i = 0;
        while (i < n) {
            acc = acc + await Twice(i);
            i = i + 1;
        }
        return acc;
    }
    static void Main() {
        int v = await SumTwice(4);
        Console.WriteLine(v);
    }
}
