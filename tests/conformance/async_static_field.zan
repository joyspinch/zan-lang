using System;

// Regression test: a bare static-field name read/written inside an instance
// async method must resolve to the static global, not to an instance field
// slot. Static fields must also not shift the instance struct layout (here
// `Total` precedes `inst`; `inst` is instance field 0).

class Counter {
    static int Total = 0;
    int inst = 0;

    async int Bump() {
        Total = Total + 1;
        this.inst = this.inst + 1;
        await Task.Delay(1);
        Total = Total + 10;
        return 0;
    }

    static async int Run() {
        Counter c = new Counter();
        int r = await c.Bump();
        Console.WriteLine("Total=" + Convert.ToString(Total)); // 11
        Console.WriteLine("inst=" + Convert.ToString(c.inst)); // 1
        return 0;
    }

    static void Main() {
        int x = await Run();
    }
}
