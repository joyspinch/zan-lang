using System;
namespace Conf;
class Program {
    static int Boom() { int z = 0; return 1 / z; }
    static void Main() {
        int a = 0;
        // right side must NOT evaluate (would divide by zero)
        if (a != 0 && Boom() > 0) { Console.WriteLine(99); }
        Console.WriteLine(1);
        if (a == 0 || Boom() > 0) { Console.WriteLine(2); }
    }
}
