// Conformance: System.Text.Encoding.Base64Encode.
// Also exercises transitive stdlib import: the program only imports
// System.Text, yet compiles and runs (Encoding previously failed codegen).
using System;
using System.Text;

class Program {
    static void Main() {
        Console.WriteLine(Encoding.Base64Encode("M"));             // TQ==
        Console.WriteLine(Encoding.Base64Encode("Ma"));            // TWE=
        Console.WriteLine(Encoding.Base64Encode("Man"));           // TWFu
        Console.WriteLine(Encoding.Base64Encode("foobar"));        // Zm9vYmFy
        Console.WriteLine(Encoding.Base64Encode("Hello, World!")); // SGVsbG8sIFdvcmxkIQ==
    }
}
