using System;
namespace Conf;
class Program {
    static int IsPrime(int n) {
        if (n < 2) { return 0; }
        int i = 2;
        while (i * i <= n) {
            if (n % i == 0) { return 0; }
            i = i + 1;
        }
        return 1;
    }
    static void Main() {
        int count = 0;
        int k = 2;
        while (k < 30) {
            if (IsPrime(k) == 1) { count = count + 1; }
            k = k + 1;
        }
        Console.WriteLine(count);
    }
}
