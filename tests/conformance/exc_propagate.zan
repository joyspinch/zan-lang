// Exceptions: an exception thrown deep in a call chain unwinds through frames
// that have no handler until it reaches one, running finally blocks on the way.
class Program {
    static void c() { throw new Exception("deep"); }
    static void b() {
        try { c(); } finally { Console.WriteLine("b.finally"); }
    }
    static void a() { b(); }
    static void Main() {
        try {
            a();
        } catch (Exception e) {
            Console.WriteLine("main caught:" + e.Message);
        }
    }
}
