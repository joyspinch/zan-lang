using System;
using System.Collections.Generic;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        Program.Run();
    }

    static void Run() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Runtime")
            .SetScreen(800, 600)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf")
            .AddResource("hero-icon", "res/hero.png");

        LevelGrowth growth = LevelGrowth.Create("hero-growth");
        List<ZgmAttr> level1 = new List<ZgmAttr>();
        level1.Add(ZgmAttr.Of("maxhp", 120));
        growth.AddLevel(level1);

        ItemConfig sword = ItemConfig.Create("sword", "Sword")
            .SetCategory("装备", "武器")
            .AddAttr("攻击", 20);
        ItemConfig potion = ItemConfig.Create("potion", "Potion")
            .SetMaxStack(5)
            .SetCooldown("potion", 500)
            .AddAttr("hp", 25);
        List<ZgmAttr> setEffect = new List<ZgmAttr>();
        setEffect.Add(ZgmAttr.Of("攻击", 15));
        EquipSet warriorSet = EquipSet.Create("warrior")
            .AddPart("sword")
            .AddEffect(setEffect);
        app.AddEquipSet(warriorSet);

        SkillConfig attack = SkillConfig.Create("attack", "Attack")
            .SetRange(3, 0)
            .SetFormula("a.攻击 ^ 2 / (a.攻击 + b.防御)")
            .SetAbsolute(true, false)
            .SetInterval(1000);

        BuffConfig regen = BuffConfig.Create("regen", "Regeneration")
            .SetDuration(1500)
            .SetTriggerInterval(500)
            .AddAttr("hp", 5);

        NpcConfig heroConfig = NpcConfig.Create("hero")
            .SetDisplayName("Zan Hero")
            .SetHero(true)
            .SetGrowth("hero-growth", 1)
            .SetVitals(100, 100, 40, 40)
            .SetCombat(100, 0, 0)
            .AddAttr("攻击", 10);
        heroConfig.AddEquip(EquipSlot.Of("武器", "sword"));

        NpcConfig enemyConfig = NpcConfig.Create("enemy")
            .SetDisplayName("Training Target")
            .SetVitals(80, 80, 0, 0)
            .SetCombat(100, 0, 0)
            .AddAttr("防御", 5);

        MapConfig field = MapConfig.Create("field")
            .SetGrid(64, 32, 10, 10)
            .SetDefault(true)
            .SetStart(1, 1);
        field.AddSpawn(
            MapSpawn.Of("enemy", Faction.Enemy, 3, 1, 0, 1));
        field.AddPortal(MapPortal.Of(7, 2, 1, "town", 1, 1));

        MapConfig town = MapConfig.Create("town")
            .SetGrid(64, 32, 8, 8)
            .SetStart(1, 1);

        ButtonWidget button = new ButtonWidget("start-button");
        button.SetTitle("Start");
        button.At(0, 0).Size(80, 30);
        Label label = new Label("hero-label");
        label.SetTitle("&name&:&hp&");
        label.At(0, 40).Size(160, 24);
        RichTextBox log = new RichTextBox("message-log");
        log.SetContent("#WReady").SetTypingInterval(10);
        log.At(90, 0).Size(100, 60);
        WindowConfig window = WindowConfig.Create("hud")
            .SetPos(10, 10)
            .SetSize(200, 100)
            .SetDefaultVisible(true)
            .AddWidget(button)
            .AddWidget(label)
            .AddWidget(log);

        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddGrowth(growth)
            .AddItem(sword)
            .AddItem(potion)
            .AddSkill(attack)
            .AddBuff(regen)
            .AddNpc(heroConfig)
            .AddNpc(enemyConfig)
            .AddMap(field)
            .AddMap(town)
            .AddWindow(window)
            .AddTcpClient(TcpClientConfig.Create("game", "127.0.0.1", 9000))
            .AddWebSocket(
                WebSocketClientConfig.Create("chat").SetUrl(
                    "ws://127.0.0.1:9001/chat"))
            .AddDatabase(SqliteComponentConfig.Create("save-db"));

        ZgmEngine engine = ZgmEngine.FromProject(project);
        Console.WriteLine(
            "valid=" + Convert.ToString(!engine.Diagnostics().HasErrors()));
        Console.WriteLine("start=" + Convert.ToString(engine.Start("--test")));
        Console.WriteLine("map=" + engine.World().CurrentMap().Name());
        Console.WriteLine(
            "actors=" + Convert.ToString(engine.World().ActorCount()));

        ZgmGlobals globals = engine.Globals();
        globals.Set("chapter", "opening")
            .SetInt("coins", 25)
            .SetBool("bossAlive", true);
        Console.WriteLine("globalCount=" + Convert.ToString(globals.Count()));
        Console.WriteLine("globalChapter=" + globals.Get("chapter", ""));
        Console.WriteLine(
            "globalCoins=" + Convert.ToString(globals.GetInt("coins", -1)));
        Console.WriteLine(
            "globalBoss=" + Convert.ToString(
                globals.GetBool("bossAlive", false)));
        globals.SetInt("coins", 40);
        Console.WriteLine(
            "globalUpdatedCoins=" + Convert.ToString(
                globals.GetInt("coins", -1)));
        Console.WriteLine(
            "globalKinds=" + Convert.ToString(
                globals.KindAt(0)) + ","
                + Convert.ToString(globals.KindAt(1)) + ","
                + Convert.ToString(globals.KindAt(2)));

        ZgmMenu mainMenu = ZgmMenu.Create("main")
            .AddItem(ZgmMenuItem.Create("inventory", "Inventory", "bag"))
            .AddItem(ZgmMenuItem.Create("settings", "Settings", "options"));
        engine.Menus().AddMenu(mainMenu);
        Console.WriteLine(
            "menuCount=" + Convert.ToString(engine.Menus().MenuCount()));
        Console.WriteLine(
            "menuOpen=" + Convert.ToString(
                engine.Menus().Activate("main", "inventory")));
        mainMenu.FindItem("settings").SetEnabled(false);
        Console.WriteLine(
            "menuDisabled=" + Convert.ToString(
                engine.Menus().Activate("main", "settings")));

        ZgmActor hero = engine.World().Hero();
        ZgmActor enemy = engine.World().ActorAt(1);
        hero.AddSkill("attack");
        Console.WriteLine(
            "heroMax=" + Convert.ToString(hero.Attribute("maxhp")));
        Console.WriteLine(
            "heroAttack=" + Convert.ToString(hero.Attribute("攻击")));

        ZgmSkillResult cast =
            engine.World().CastSkill(hero, "attack", enemy);
        Console.WriteLine(
            "cast=" + Convert.ToString((int)cast.Status()));
        Console.WriteLine(
            "damage=" + Convert.ToString(cast.Damage()));
        Console.WriteLine(
            "enemyHp=" + Convert.ToString(enemy.Hp()));

        engine.World().AddItem(hero, "potion", 2);
        hero.TakeDamage(30);
        Console.WriteLine(
            "use=" + Convert.ToString(
                engine.World().UseItem(hero, "potion")));
        Console.WriteLine(
            "heroHp=" + Convert.ToString(hero.Hp()));
        Console.WriteLine(
            "potions=" + Convert.ToString(
                hero.Inventory().QuantityOf("potion")));
        Console.WriteLine(
            "cooldownBlock=" + Convert.ToString(
                engine.World().UseItem(hero, "potion")));

        engine.World().ApplyBuff(hero, "regen", hero, true);
        engine.Update(500);
        Console.WriteLine(
            "regenHp=" + Convert.ToString(hero.Hp()));
        Console.WriteLine(
            "buffs=" + Convert.ToString(hero.BuffCount()));

        Console.WriteLine(
            "move=" + Convert.ToString(
                engine.World().MoveActor(hero, 2, 1)));
        Console.WriteLine(
            "portal=" + Convert.ToString(
                engine.World().TryPortal(hero)));
        Console.WriteLine(
            "map2=" + engine.World().CurrentMap().Name());
        Console.WriteLine(
            "actorsAfterPortal=" + Convert.ToString(
                engine.World().ActorCount()));
        Console.WriteLine(
            "heroPos=" + Convert.ToString(hero.X()) + ","
                + Convert.ToString(hero.Y()));
        ZgmGroundItem ground =
            engine.World().DropItem("potion", 1, hero.X(), hero.Y());
        Console.WriteLine(
            "ground=" + Convert.ToString(
                engine.World().GroundItemCount()));
        Console.WriteLine(
            "pickup=" + Convert.ToString(
                engine.World().Pickup(hero, ground)));

        ZgmUiRuntime ui = engine.Ui();
        ui.PointerDown(15, 15);
        ui.PointerUp(15, 15);
        ZgmWidgetState buttonState =
            ui.FindWidget("hud", "start-button");
        Console.WriteLine(
            "windowWidgets=" + Convert.ToString(
                ui.FindWindow("hud").WidgetCount()));
        Console.WriteLine(
            "selected=" + Convert.ToString(buttonState.Selected()));
        Console.WriteLine(
            "template=" + ui.Render("&name&:&hp&"));

        Tween tween = Tween.Create().Add(
            TweenStep.To(
                "start-button", 100, Easing.Linear).Set("x", 100.0));
        ui.StartTween(tween, null);
        ui.Update(50);
        Console.WriteLine(
            "tweenHalf=" + Convert.ToString(buttonState.X()));
        ui.Update(50);
        Console.WriteLine(
            "tweenEnd=" + Convert.ToString(buttonState.X()));

        Console.WriteLine(
            "resource=" + engine.ResolveResource("hero-icon"));
        Console.WriteLine(
            "tcp=" + Convert.ToString(
                engine.CreateTcpClient("game") != null));
        Console.WriteLine(
            "ws=" + Convert.ToString(
                engine.CreateWebSocket("chat") != null));
        Console.WriteLine(
            "dbs=" + Convert.ToString(project.DatabaseCount()));
        ZgmMusic music = engine.CreateMusic("hero-icon");
        music.Play();
        Console.WriteLine(
            "musicPlay=" + Convert.ToString((int)music.State()));
        music.Pause();
        Console.WriteLine(
            "musicPause=" + Convert.ToString((int)music.State()));

        ZgmSaveState save = engine.Save();
        Console.WriteLine("saveMap=" + save.MapName());
        Console.WriteLine(
            "saveItems=" + Convert.ToString(save.ItemCount()));
        hero.SetExperience(17);
        hero.SetRage(22);
        save = engine.Save();
        Console.WriteLine(
            "saveProgress=" + Convert.ToString(save.HeroExperience())
                + "|" + Convert.ToString(save.HeroRage()));
        Console.WriteLine(
            "saveExtras=" + Convert.ToString(save.EquipmentCount())
                + "|" + Convert.ToString(save.SkillCount())
                + "|" + Convert.ToString(save.BuffCount()));
        Console.WriteLine(
            "loadState=" + Convert.ToString(engine.Load(save)));
        ZgmActor loadedHero = engine.World().Hero();
        Console.WriteLine(
            "loaded=" + Convert.ToString(loadedHero.Experience())
                + "|" + Convert.ToString(loadedHero.Rage()) + "|"
                + Convert.ToString(loadedHero.Equipment().Count()) + "|"
                + Convert.ToString(loadedHero.SkillCount()) + "|"
                + Convert.ToString(loadedHero.BuffCount()));
        Console.WriteLine(
            "stop=" + Convert.ToString(engine.Stop()));
        save.Dispose();
        music.Dispose();
        tween.Dispose();
        cast.Dispose();
        ground.Dispose();
        engine.Dispose();
        project.Dispose();
        save = null;
        music = null;
        tween = null;
        buttonState = null;
        ui = null;
        ground = null;
        cast = null;
        enemy = null;
        hero = null;
        engine = null;
        project = null;
        window = null;
        log = null;
        label = null;
        button = null;
        town = null;
        field = null;
        enemyConfig = null;
        heroConfig = null;
        regen = null;
        attack = null;
        potion = null;
        sword = null;
        level1 = null;
        growth = null;
        app = null;
        globals = null;
        mainMenu = null;
    }
}
