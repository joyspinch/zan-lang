// Builtin string methods and scalar ToString. Previously IndexOf/LastIndexOf/
// Replace/Trim/StartsWith/EndsWith/ToUpper/ToLower and `n.ToString()` had no
// irgen lowering and silently produced the constant-0 fallback.
using System;

class Program {
    static string mk(string tail) {
        string x = "__" + tail;
        return x.Substring(2);
    }

    static void Main() {
        string s = "hello world";
        int i = 42;
        int neg = -7;
        long big = 123456789012345;
        double d = 3.5;
        bool t = true;
        bool f = false;

        Console.WriteLine(i.ToString());                    // 42
        Console.WriteLine(neg.ToString());                  // -7
        Console.WriteLine(big.ToString());                  // 123456789012345
        Console.WriteLine(d.ToString());                    // 3.5
        Console.WriteLine(t.ToString());                    // true
        Console.WriteLine(f.ToString());                    // false
        Console.WriteLine(s.ToString());                    // hello world

        Console.WriteLine(s.IndexOf("world"));              // 6
        Console.WriteLine(s.IndexOf("hello"));              // 0
        Console.WriteLine(s.IndexOf("zzz"));                // -1
        Console.WriteLine(s.LastIndexOf("o"));              // 7
        Console.WriteLine(s.LastIndexOf("l"));              // 9
        Console.WriteLine(s.LastIndexOf("zzz"));            // -1
        Console.WriteLine(mk("abcabc").IndexOf("b"));       // 1

        Console.WriteLine(s.Replace("world", "zan"));       // hello zan
        Console.WriteLine(s.Replace("l", "LL"));            // heLLLLo worLLd
        Console.WriteLine(s.Replace("zzz", "x"));           // hello world
        Console.WriteLine(mk("aaa").Replace("a", ""));      // (empty)

        Console.WriteLine("  padded \t ".Trim());           // padded
        Console.WriteLine(mk("  x  ").Trim());              // x

        if (s.StartsWith("hello")) { Console.WriteLine("sw1"); }
        if (!s.StartsWith("world")) { Console.WriteLine("sw2"); }
        if (s.EndsWith("world")) { Console.WriteLine("ew1"); }
        if (!s.EndsWith("hello")) { Console.WriteLine("ew2"); }
        if (!"hi".EndsWith("longer than hi")) { Console.WriteLine("ew3"); }

        Console.WriteLine(s.ToUpper());                     // HELLO WORLD
        Console.WriteLine("MiXeD 123".ToLower());           // mixed 123

        // results feed back into expressions
        string r = s.Replace("world", "zan").ToUpper();
        Console.WriteLine(r);                               // HELLO ZAN
        int total = s.IndexOf("world") + s.LastIndexOf("d");
        Console.WriteLine(total);                           // 16
        Console.WriteLine("n=" + i.ToString());             // n=42
    }
}
