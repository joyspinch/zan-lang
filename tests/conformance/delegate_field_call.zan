using System;

namespace Conf;

delegate void IntSink(int amount);
delegate int Transform(int amount);
delegate bool Predicate(int amount);

class Hub {
    IntSink sink;
    Transform transform;
    Predicate predicate;
    static IntSink staticSink;

    void Configure(
        IntSink sink,
        Transform transform,
        Predicate predicate
    ) {
        this.sink = sink;
        this.transform = transform;
        this.predicate = predicate;
    }

    static void ConfigureStatic(IntSink sink) {
        Hub.staticSink = sink;
    }

    void FireThis(int amount) {
        this.sink(amount);
    }

    void FireImplicit(int amount) {
        sink(amount);
    }

    int Apply(int amount) {
        return this.transform(amount);
    }

    bool Check(int amount) {
        return this.predicate(amount);
    }

    static void FireStatic(int amount) {
        Hub.staticSink(amount);
    }
}

class Box {
    Hub hub;

    static Box Create(Hub hub) {
        Box box = new Box();
        box.hub = hub;
        return box;
    }

    void FireNested(int amount) {
        this.hub.sink(amount);
    }
}

class Program {
    static int total;

    static void Add(int amount) {
        Program.total = Program.total + amount;
    }

    static int Double(int amount) {
        return amount * 2;
    }

    static bool Positive(int amount) {
        return amount > 0;
    }

    static void Main() {
        Hub hub = new Hub();
        hub.Configure(Program.Add, Program.Double, Program.Positive);
        Hub.ConfigureStatic(Program.Add);

        hub.FireThis(1);
        hub.FireImplicit(2);
        hub.sink(3);
        Box.Create(hub).FireNested(4);
        Hub.FireStatic(5);

        Console.WriteLine(Convert.ToString(Program.total));
        Console.WriteLine(Convert.ToString(hub.Apply(6)));
        Console.WriteLine(Convert.ToString(hub.Check(1)));
    }
}
