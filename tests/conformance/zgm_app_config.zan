using System;
using System.Collections.Generic;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZanGameMaker Demo")
            .SetScreen(1024, 768)
            .SetFps(60)
            .SetVsync(false)
            .SetBackground(ZgmColor.Rgba(0, 32, 0, 255))
            .SetScreenScale(ScreenScale.Transparent)
            .SetRepeatKey(true)
            .SetDefaultFont("宋体14")
            .AddResource("格子底图3", "ui/slot3.png")
            .AddResource("主角", "npc/hero.png")
            .AddExtraAttr("攻击", 0)
            .AddExtraAttr("防御", 0)
            .AddComponent("UI/底部UI.lua")
            .AddComponent("DB/Npc/主角.lua")
            .AddScript("DB/系统.lua");

        EquipSet gold = EquipSet.Create("全村的希望")
            .AddPart("黄金手镯")
            .AddPart("黄金戒指")
            .AddPart("黄金项链");
        List<ZgmAttr> tier1 = new List<ZgmAttr>();
        gold.AddEffect(tier1);
        List<ZgmAttr> tier2 = new List<ZgmAttr>();
        tier2.Add(ZgmAttr.Of("maxhp", 20));
        tier2.Add(ZgmAttr.Of("maxmp", 20));
        gold.AddEffect(tier2);
        List<ZgmAttr> tier3 = new List<ZgmAttr>();
        tier3.Add(ZgmAttr.Of("移动速度", 20));
        tier3.Add(ZgmAttr.Of("攻击速度", 20));
        gold.AddEffect(tier3);
        app.AddEquipSet(gold);

        Console.WriteLine("title=" + app.Title());
        Console.WriteLine("w=" + Convert.ToString(app.ScreenWidth()));
        Console.WriteLine("h=" + Convert.ToString(app.ScreenHeight()));
        Console.WriteLine("fps=" + Convert.ToString(app.Fps()));
        Console.WriteLine("scale=" + Convert.ToString((int)app.ScreenScaleMode()));
        Console.WriteLine("repeat=" + Convert.ToString(app.RepeatKey()));
        Console.WriteLine("font=" + app.DefaultFont());
        Console.WriteLine("bgG=" + Convert.ToString(app.Background().G()));
        Console.WriteLine("res=" + Convert.ToString(app.ResourceCount()));
        Console.WriteLine("attrs=" + Convert.ToString(app.ExtraAttrCount()));
        Console.WriteLine("comps=" + Convert.ToString(app.ComponentCount()));
        Console.WriteLine("scripts=" + Convert.ToString(app.ScriptCount()));
        Console.WriteLine("sets=" + Convert.ToString(app.EquipSetCount()));
        Console.WriteLine("baseAttrs=" + Convert.ToString(BaseAttrs.Count()));
        ItemSlotConfig slot = app.ItemSlot();
        Console.WriteLine("slotMargin=" + Convert.ToString(slot.countMargin));
        DropItemConfig drop = app.DropItem();
        ZgmColor dropBg = drop.background;
        Console.WriteLine("dropBgA=" + Convert.ToString(dropBg.A()));
        Console.WriteLine("valid=" + Convert.ToString(app.IsValid()));
        Console.WriteLine("goldParts=" + Convert.ToString(gold.PartCount()));
        Console.WriteLine("goldTiers=" + Convert.ToString(gold.EffectTiers()));
    }
}
