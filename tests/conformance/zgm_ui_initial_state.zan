using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Initial State")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        Label label = new Label("label")
            .SetTitle("Hello")
            .SetMouseEvent(true);
        label.At(0, 0).Size(100, 20);
        EditBox edit = new EditBox("edit")
            .SetContent("42");
        edit.At(0, 25).Size(100, 20);
        CheckBox check = new CheckBox("check")
            .SetChecked(true);
        check.At(0, 50).Size(100, 20);
        ButtonWidget button = new ButtonWidget("button")
            .SetSelected(true)
            .SetDisabled(true);
        button.At(0, 75).Size(100, 20);
        ComboBox combo = new ComboBox("combo")
            .AddItem(ComboItem.Of("a", "A"))
            .AddItem(ComboItem.Of("b", "B"))
            .SetSelectedIndex(1);
        combo.At(0, 100).Size(100, 20);
        TabBox tabs = new TabBox("tabs")
            .AddTab("One")
            .AddTab("Two")
            .SetActivePage(1);
        tabs.At(0, 125).Size(100, 20);
        RichTextBox log = new RichTextBox("log")
            .SetContent("click-through")
            .SetClickThrough(true);
        log.At(105, 0).Size(50, 20);
        TextNode node = new TextNode("node")
            .SetTitle("node-text")
            .SetMouseEvent(true);
        WindowConfig hud = WindowConfig.Create("hud")
            .SetSize(180, 150)
            .SetDefaultVisible(true)
            .AddWidget(label)
            .AddWidget(edit)
            .AddWidget(check)
            .AddWidget(button)
            .AddWidget(combo)
            .AddWidget(tabs)
            .AddWidget(log)
            .AddNode(node);
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddWindow(hud);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        Console.WriteLine("start=" + Convert.ToString(engine.Start("")));
        ZgmUiRuntime ui = engine.Ui();
        Console.WriteLine(
            "text=" + ui.FindWidget("hud", "label").Text()
                + "|" + ui.FindWidget("hud", "edit").Text());
        Console.WriteLine(
            "selected=" + Convert.ToString(
                ui.FindWidget("hud", "check").Selected())
                + "|" + Convert.ToString(
                ui.FindWidget("hud", "button").Selected()));
        Console.WriteLine(
            "controls=" + Convert.ToString(
                ui.FindWidget("hud", "button").Enabled())
                + "|" + Convert.ToString(
                ui.FindWidget("hud", "combo").SelectedIndex())
                + "|" + Convert.ToString(
                ui.FindWidget("hud", "tabs").ActivePage()));
        ui.PointerDown(110, 5);
        Console.WriteLine(
            "clickThrough=" + Convert.ToString(
                ui.FocusedWidget() == null));
        Console.WriteLine(
            "config=" + Convert.ToString(label.MouseEvent())
                + "|" + Convert.ToString(node.MouseEvent())
                + "|" + node.Title());
        engine.Stop();
        engine.Dispose();
        project.Dispose();
    }
}
