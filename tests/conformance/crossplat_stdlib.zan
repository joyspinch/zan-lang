using System;
using System.IO;
using System.Threading;

/// Exercises stdlib paths whose native layout/constants differ per OS, so the
/// same golden output must hold on Windows, Linux and macOS:
///   - Directory listing (struct dirent field offsets differ glibc vs Darwin)
///   - Semaphore (macOS has no unnamed POSIX semaphores; uses GCD dispatch)
///   - Stopwatch (CLOCK_MONOTONIC id differs: 1 on Linux, 6 on macOS)
class Program {
    static int Has(List<string> xs, string want) {
        int i = 0;
        while (i < xs.Count) {
            if (xs[i] == want) { return 1; }
            i = i + 1;
        }
        return 0;
    }

    static void Main() {
        Console.WriteLine("=== directory ===");
        string dir = "zan_xplat_dirtest";
        string fa = dir + "/alpha.txt";
        string fb = dir + "/beta.txt";
        string sub = dir + "/subdir";
        if (Directory.Exists(dir)) { Directory.Delete(dir); }
        Directory.CreateDirectory(dir);
        File.WriteAllText(fa, "a");
        File.WriteAllText(fb, "b");
        Directory.CreateDirectory(sub);

        List<string> files = Directory.GetFiles(dir);
        List<string> dirs = Directory.GetDirectories(dir);
        Console.WriteLine(files.Count);
        Console.WriteLine(Has(files, "alpha.txt"));
        Console.WriteLine(Has(files, "beta.txt"));
        Console.WriteLine(dirs.Count);
        Console.WriteLine(Has(dirs, "subdir"));

        File.Delete(fa);
        File.Delete(fb);
        Directory.Delete(sub);
        Directory.Delete(dir);
        Console.WriteLine(Directory.Exists(dir));

        Console.WriteLine("=== semaphore ===");
        #if WINDOWS
        int sem = Semaphore.Create(1, 1);
        #else
        string sem = Semaphore.Create(1, 1);
        #endif
        Semaphore.Wait(sem);
        Semaphore.Release(sem);
        Semaphore.Wait(sem);
        Semaphore.Release(sem);
        Semaphore.Destroy(sem);
        Console.WriteLine("sem ok");

        Console.WriteLine("=== stopwatch ===");
        int t0 = Stopwatch.GetMilliseconds();
        int spin = 0;
        int i = 0;
        while (i < 200000) { spin = spin + i; i = i + 1; }
        int t1 = Stopwatch.GetMilliseconds();
        if (t0 > 0 && t1 >= t0) {
            Console.WriteLine("clock ok");
        } else {
            Console.WriteLine("clock bad");
        }
    }
}
