// Exceptions: a thrown exception is caught by an enclosing try/catch and the
// caught object's Message is readable.
class Program {
    static void Main() {
        try {
            Console.WriteLine("before");
            throw new Exception("boom");
        } catch (Exception e) {
            Console.WriteLine("caught");
            Console.WriteLine(e.Message);
        }
        Console.WriteLine("after");
    }
}
