using System;
namespace Conf;
class Program {
    static void Main() {
        int i = 1;
        int total = 0;
        while (i <= 3) {
            int j = 1;
            while (j <= 3) {
                total = total + i * j;
                j = j + 1;
            }
            i = i + 1;
        }
        Console.WriteLine(total);
    }
}
