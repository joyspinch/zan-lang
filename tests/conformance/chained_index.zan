// Conformance: indexing through a chained base whose object is itself an
// index or a nested member (e.g. `arr[i].values[j]`). The C host compiler
// only resolved the element type when the index base was a bare identifier /
// this-field, so chained subscripts silently loaded a zero constant. It now
// infers the base type generally.
using System;

class Box {
    List<int> vals;
    static Box Make(int a, int b) {
        Box x = new Box();
        x.vals = new List<int>();
        x.vals.Add(a);
        x.vals.Add(b);
        return x;
    }
}

class Grid {
    List<Box> rows;
    Grid() { this.rows = new List<Box>(); }
}

class Program {
    static void Main() {
        List<Box> arr = new List<Box>();
        arr.Add(Box.Make(72, 99));
        arr.Add(Box.Make(13, 40));

        // chained: index -> member -> index
        Console.WriteLine(Convert.ToString(arr[0].vals[0]));   // 72
        Console.WriteLine(Convert.ToString(arr[0].vals[1]));   // 99
        Console.WriteLine(Convert.ToString(arr[1].vals[0]));   // 13

        // nested member -> index
        Grid g = new Grid();
        g.rows.Add(Box.Make(5, 6));
        Console.WriteLine(Convert.ToString(g.rows[0].vals[1])); // 6

        // chained write then read back
        arr[0].vals[0] = 100;
        Console.WriteLine(Convert.ToString(arr[0].vals[0]));   // 100
    }
}
