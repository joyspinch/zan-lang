using System;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Registry")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        TcpClientConfig tcp = TcpClientConfig.Create(
            "game", "127.0.0.1", 9000);
        WebSocketClientConfig ws = WebSocketClientConfig.Create("chat")
            .SetUrl("ws://127.0.0.1:9001/chat");
        SqliteComponentConfig db =
            SqliteComponentConfig.Create("save-db");
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddTcpClient(tcp)
            .AddWebSocket(ws)
            .AddDatabase(db);
        Console.WriteLine(
            "counts=" + Convert.ToString(project.TcpClientCount())
                + "|" + Convert.ToString(project.WebSocketCount())
                + "|" + Convert.ToString(project.DatabaseCount()));
        Console.WriteLine(
            "tcp=" + project.TcpClientAt(0).Name()
                + "|" + project.TcpClientAt(0).Ip()
                + "|" + Convert.ToString(project.TcpClientAt(0).Port()));
        Console.WriteLine(
            "ws=" + project.WebSocketAt(0).Name()
                + "|" + project.WebSocketAt(0).Url());
        Console.WriteLine(
            "db=" + project.DatabaseAt(0).Name()
                + "|" + project.FindDatabase("save-db").Kind());
        project.AddTcpClient(
            TcpClientConfig.Create("game", "localhost", 9100));
        Console.WriteLine(
            "overwrite=" + Convert.ToString(project.TcpClientCount())
                + "|" + project.TcpClientAt(0).Ip()
                + "|" + Convert.ToString(project.TcpClientAt(0).Port()));
        project.Dispose();
    }
}
