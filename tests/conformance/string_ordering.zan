// Regression: relational operators on strings (`<`, `<=`, `>`, `>=`) must
// compare content lexicographically (via strcmp), not the raw pointer
// addresses of the operands. Previously `"P" <= "Z"` could evaluate to false
// because the codegen compared i8* pointers with a signed integer predicate.
using System;
namespace Conf;
class Program {
    static void Main() {
        string p = "P";
        string z = "Z";
        if (p <= z) { Console.WriteLine(1); } else { Console.WriteLine(0); }        // 1
        if (z <= p) { Console.WriteLine(1); } else { Console.WriteLine(0); }        // 0
        if (p < z)  { Console.WriteLine(1); } else { Console.WriteLine(0); }        // 1
        if (z > p)  { Console.WriteLine(1); } else { Console.WriteLine(0); }        // 1
        if (p >= p) { Console.WriteLine(1); } else { Console.WriteLine(0); }        // 1
        if ("abc" < "abd")      { Console.WriteLine(1); } else { Console.WriteLine(0); } // 1
        if ("abc" < "ab")       { Console.WriteLine(1); } else { Console.WriteLine(0); } // 0
        if ("apple" < "banana") { Console.WriteLine(1); } else { Console.WriteLine(0); } // 1
    }
}
