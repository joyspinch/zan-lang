using System;
namespace P;
class Program {
    static void Main() {
        long big = 300;
        int i = (int)big;
        Console.WriteLine(i);
        char c = (char)(65 + i - i);
        Console.WriteLine((int)c);
        double d = 3.9;
        Console.WriteLine((int)d);
        int n = 5;
        double dn = (double)n;
        Console.WriteLine((int)(dn + 0.5));
    }
}
