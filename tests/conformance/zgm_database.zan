// Exercises the Game.Zgm SQLite runtime (ZgmDatabase) against an in-memory
// database: create table, insert rows, query them back, scalar + last-insert-id
// and a rolled-back transaction. Requires the sqlite3 native driver.
using System;
using System.Data;
using Game.Zgm;
using Game.Zgm.Data;

namespace T;

class Program {
    static void Main() {
        ZgmDatabase db = ZgmDatabase.OpenMemory("save");
        Console.WriteLine("name=" + db.Name());
        Console.WriteLine("open=" + Convert.ToString(db.IsOpen()));

        db.Execute("CREATE TABLE hero(id INTEGER PRIMARY KEY, name TEXT, lv INTEGER)");
        db.Execute("INSERT INTO hero(name, lv) VALUES('Aki', 3)");
        db.Execute("INSERT INTO hero(name, lv) VALUES('Rin', 7)");
        Console.WriteLine("lastid=" + Convert.ToString(db.LastInsertId()));

        DbResult r = db.Query("SELECT name, lv FROM hero ORDER BY lv");
        Console.WriteLine("rows=" + Convert.ToString(r.RowCount()));
        int i = 0;
        while (i < r.RowCount()) {
            Console.WriteLine("row=" + r.GetString(i, 0) + ":" + r.GetString(i, 1));
            i = i + 1;
        }

        Console.WriteLine("scalar=" + db.Scalar("SELECT name FROM hero WHERE lv=7"));

        // Rolled-back transaction leaves the table unchanged.
        db.Begin();
        db.Execute("INSERT INTO hero(name, lv) VALUES('Ghost', 99)");
        db.Rollback();
        Console.WriteLine("count=" + db.Scalar("SELECT COUNT(*) FROM hero"));

        db.Close();
        Console.WriteLine("closed=" + Convert.ToString(db.IsOpen()));

        ZgmProject project = ZgmProject.Create();
        project.AddDatabase(SqliteComponentConfig.Create("project-save"));
        ZgmDatabase projectDb =
            ZgmDatabase.OpenProject(project, "project-save", ":memory:");
        Console.WriteLine("projectDb=" + projectDb.Name());
        projectDb.Close();
    }
}
