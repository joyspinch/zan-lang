using System;
using Game.Zgm;

namespace T;

class Program {
    static int focusOn;
    static int focusOff;
    static int keyDownCount;
    static int keyUpCount;
    static int resizeCount;
    static int textEvents;
    static int submitEvents;
    static int valueEvents;

    static void OnFocusChanged(bool focused) {
        if (focused) { Program.focusOn = Program.focusOn + 1; }
        else { Program.focusOff = Program.focusOff + 1; }
    }
    static void OnKeyDown(
        int keycode,
        bool alt,
        bool shift,
        bool control
    ) {
        Program.keyDownCount = Program.keyDownCount + 1;
    }
    static void OnKeyUp(
        int keycode,
        bool alt,
        bool shift,
        bool control
    ) {
        Program.keyUpCount = Program.keyUpCount + 1;
    }
    static void OnSizeChanged(int width, int height) {
        Program.resizeCount = Program.resizeCount + 1;
    }
    static string OnItemTooltip(string name, string current) {
        return name + "|" + current;
    }
    static string OnSkillTooltip(string name, string current) {
        return name + "|" + current;
    }
    static void OnWidgetEvent(
        string windowName,
        string widgetName,
        string eventName,
        string payload
    ) {
        if (eventName == "文本变化") {
            Program.textEvents = Program.textEvents + 1;
        } else if (eventName == "提交") {
            Program.submitEvents = Program.submitEvents + 1;
        } else if (eventName == "数值变化") {
            Program.valueEvents = Program.valueEvents + 1;
        }
    }

    static void Main() {
        AppConfig app = AppConfig.Create()
            .SetTitle("ZGM Input Runtime")
            .SetScreen(640, 480)
            .SetDefaultFont("default-font")
            .AddResource("default-font", "res/font.ttf");
        ItemConfig potion = ItemConfig.Create("potion", "Potion")
            .SetTooltip("restore hp");
        SkillConfig slash = SkillConfig.Create("slash", "Slash")
            .SetTooltip("attack target");
        EditBox edit = new EditBox("edit")
            .SetMaxLength(5)
            .SetNumeric(true);
        edit.At(0, 0).Size(120, 24);
        Slider slider = new Slider("slider")
            .SetRange(-10, 10)
            .SetPosition(-5);
        slider.At(0, 30).Size(120, 20);
        Scrollbar scroll = new Scrollbar("scroll")
            .SetRange(0, 5)
            .SetPosition(2);
        scroll.At(0, 60).Size(120, 20);
        WindowConfig hud = WindowConfig.Create("hud")
            .SetSize(200, 100)
            .SetDefaultVisible(true)
            .AddWidget(edit)
            .AddWidget(slider)
            .AddWidget(scroll);
        ZgmProject project = ZgmProject.Create()
            .SetApp(app)
            .AddItem(potion)
            .AddSkill(slash)
            .AddWindow(hud);
        ZgmEngine engine = ZgmEngine.FromProject(project);
        ZgmEvents events = engine.Events();
        events.OnFocusChanged(Program.OnFocusChanged);
        events.OnKeyDown(Program.OnKeyDown);
        events.OnKeyUp(Program.OnKeyUp);
        events.OnSizeChanged(Program.OnSizeChanged);
        events.OnItemTooltip(Program.OnItemTooltip);
        events.OnSkillTooltip(Program.OnSkillTooltip);
        events.OnWidgetEvent(Program.OnWidgetEvent);

        Console.WriteLine("start=" + Convert.ToString(engine.Start("")));
        ZgmUiRuntime ui = engine.Ui();
        ZgmWidgetState editState = ui.FindWidget("hud", "edit");
        ZgmWidgetState sliderState = ui.FindWidget("hud", "slider");
        ZgmWidgetState scrollState = ui.FindWidget("hud", "scroll");
        Console.WriteLine(
            "range=" + Convert.ToString(sliderState.Position())
                + "|" + Convert.ToString(scrollState.Position()));

        Console.WriteLine(
            "focus=" + Convert.ToString(ui.SetFocus("hud", "edit"))
                + "|" + Convert.ToString(editState.Focused()));
        Console.WriteLine(
            "input=" + Convert.ToString(ui.TextInput("12a34"))
                + "|" + editState.Text()
                + "|" + Convert.ToString(editState.Caret()));
        Console.WriteLine(
            "limit=" + Convert.ToString(ui.TextInput("56"))
                + "|" + editState.Text());
        Console.WriteLine(
            "backspace=" + Convert.ToString(ui.KeyDown(8, false, false, false))
                + "|" + editState.Text()
                + "|" + Convert.ToString(editState.Caret()));
        Console.WriteLine(
            "submit=" + Convert.ToString(ui.KeyDown(13, false, false, false))
                + "|" + Convert.ToString(ui.KeyUp(13, false, false, false)));

        Console.WriteLine(
            "values=" + Convert.ToString(
                ui.SetSliderPosition("hud", "slider", 99))
                + "|" + Convert.ToString(sliderState.Position())
                + "|" + Convert.ToString(
                ui.SetScrollbarPosition("hud", "scroll", -4))
                + "|" + Convert.ToString(scrollState.Position()));
        Console.WriteLine(
            "resize=" + Convert.ToString(ui.Resize(800, 600))
                + "|" + Convert.ToString(ui.ScreenWidth())
                + "," + Convert.ToString(ui.ScreenHeight()));
        Console.WriteLine(
            "tips=" + ui.RequestItemTooltip("potion", "")
                + "|" + ui.RequestSkillTooltip("slash", ""));
        Console.WriteLine(
            "events=" + Convert.ToString(Program.focusOn)
                + "|" + Convert.ToString(Program.focusOff)
                + "|" + Convert.ToString(Program.keyDownCount)
                + "|" + Convert.ToString(Program.keyUpCount)
                + "|" + Convert.ToString(Program.resizeCount)
                + "|" + Convert.ToString(Program.textEvents)
                + "|" + Convert.ToString(Program.submitEvents)
                + "|" + Convert.ToString(Program.valueEvents));

        ui.SetFocus("", "");
        Console.WriteLine(
            "clearFocus=" + Convert.ToString(editState.Focused())
                + "|" + Convert.ToString(Program.focusOff));
        engine.Stop();
        engine.Dispose();
        project.Dispose();
    }
}
