using System;
using System.Data;
using System.Data.MySql;

// Offline checks for the MySQL prepared-statement layer: length-encoded
// integer writer and binary-protocol value decoding (ints, IEEE floats,
// temporal types) without needing a live server.
class Program {
    [DllImport("crt")]
    static extern string calloc(int count, int size);

    static void Main() {
        // lenenc writer: 1-byte, 2-byte and 3-byte forms.
        string buf = calloc(16, 1);
        int p = MySqlConnection.writeLenenc(buf, 0, 250);
        Console.WriteLine("lenenc250: " + Convert.ToString(p) + " " + Convert.ToString(buf[0] & 255));
        p = MySqlConnection.writeLenenc(buf, 0, 65535);
        Console.WriteLine("lenenc65535: " + Convert.ToString(p) + " " + Convert.ToString(buf[0] & 255));
        p = MySqlConnection.writeLenenc(buf, 0, 70000);
        Console.WriteLine("lenenc70000: " + Convert.ToString(p) + " " + Convert.ToString(buf[0] & 255));

        // Binary LONG value: -2 little-endian (0xFFFFFFFE), signed.
        string v = calloc(16, 1);
        v[0]=254; v[1]=255; v[2]=255; v[3]=255;
        List<int> cur = new List<int>(); cur.Add(0);
        Console.WriteLine("long: " + MySqlConnection.readBinValue(v, cur, 3, 0));

        // Binary DOUBLE 1.5 = 0x3FF8000000000000 little-endian.
        string d = calloc(16, 1);
        d[6]=248; d[7]=63;
        cur = new List<int>(); cur.Add(0);
        Console.WriteLine("double: " + MySqlConnection.readBinValue(d, cur, 5, 0));

        // Binary DATETIME 2024-03-07 08:05:09 (len 7).
        string t = calloc(16, 1);
        t[0]=7; t[1]=232; t[2]=7; t[3]=3; t[4]=7; t[5]=8; t[6]=5; t[7]=9;
        cur = new List<int>(); cur.Add(0);
        Console.WriteLine("dt: " + MySqlConnection.readBinValue(t, cur, 12, 0));
    }
}
