// Conformance: List<double> element load/store. Slots physically hold an i64,
// so double elements must be bitcast on the way in (Add / collection init) and
// on the way out (index read). The C host previously returned the raw i64 for a
// double element, producing an fadd/i64 type clash and wrong values.
using System;

class Program {
    static void Main() {
        List<double> ds = new List<double>();
        ds.Add(1.5);
        ds.Add(2.25);
        double sum = 0.0;
        int i = 0;
        while (i < ds.Count) { sum = sum + ds[i]; i = i + 1; }
        Console.WriteLine(Convert.ToString(ds[0]));   // 1.5
        Console.WriteLine(Convert.ToString(ds[1]));   // 2.25
        Console.WriteLine(Convert.ToString(sum));     // 3.75

        // collection initializer
        List<double> init = new List<double> { 0.5, 1.25, 2.0 };
        Console.WriteLine(Convert.ToString(init[1])); // 1.25
        double s2 = init[0] + init[1] + init[2];
        Console.WriteLine(Convert.ToString(s2));      // 3.75
    }
}
