using System;

class Program {
    static void Main() {
        int i = 10;
        i += 5;
        i -= 3;
        i *= 2;
        i /= 5;
        i %= 3;
        Console.WriteLine(Convert.ToString(i));

        int b = 12;
        b &= 10;
        b |= 1;
        b ^= 3;
        b <<= 2;
        b >>= 1;
        Console.WriteLine(Convert.ToString(b));

        string s = "a";
        s += "b";
        s += "cd";
        Console.WriteLine(s);
    }
}
