using System;
using System.Collections.Generic;
using Game.Dm;

namespace T;

class Program {
    static void Main() {
        Label lab = new Label("血量标签");
        lab.SetTitle("HP").SetFont("宋体14").SetAlign(1, 1);
        lab.At(10, 20).Size(120, 24);
        Console.WriteLine("labKind=" + lab.Kind());
        Console.WriteLine("labName=" + lab.Name());
        Console.WriteLine("labTitle=" + lab.Title());
        Console.WriteLine("labX=" + Convert.ToString(lab.X()));
        Console.WriteLine("labW=" + Convert.ToString(lab.Width()));

        ButtonWidget btn = new ButtonWidget("确定按钮");
        btn.SetTitle("确定").SetSkin("默认皮肤").SetGroup(1);
        btn.At(0, 0).Size(80, 30);
        Console.WriteLine("btnKind=" + btn.Kind());
        Console.WriteLine("btnTitle=" + btn.Title());
        Console.WriteLine("btnToggle=" + Convert.ToString(btn.Toggle()));

        ImageBox img = new ImageBox("背景图");
        img.SetImage("ui/bg.png").SetDisplayMode(1).SetAnchor(0.5, 0.5);
        Console.WriteLine("imgKind=" + img.Kind());
        Console.WriteLine("imgImage=" + img.Image());

        ProgressBar pb = new ProgressBar("血条");
        pb.SetRange(0, 100).SetPosition(75).SetMode(0);
        pb.Size(100, 10);
        Console.WriteLine("pbKind=" + pb.Kind());
        Console.WriteLine("pbPos=" + Convert.ToString(pb.Position()));

        EditBox eb = new EditBox("聊天输入");
        eb.SetContent("").SetNumeric(false);
        eb.Size(200, 24);
        Console.WriteLine("ebKind=" + eb.Kind());

        Slider sl = new Slider("音量");
        sl.SetImages("ui/slider_bg.png", "ui/knob.png").SetRange(0, 100).SetPosition(50);
        Console.WriteLine("slKind=" + sl.Kind());
        Console.WriteLine("slPos=" + Convert.ToString(sl.Position()));

        ShowBox sb = new ShowBox("主角框");
        sb.SetShowType(0).SetOffset(0, -40);
        Console.WriteLine("sbKind=" + sb.Kind());
        Console.WriteLine("sbType=" + Convert.ToString(sb.ShowType()));

        ItemBox ib = new ItemBox("武器格子");
        ib.SetCell(42, 42).SetLimit("装备", "武器");
        Console.WriteLine("ibKind=" + ib.Kind());
        Console.WriteLine("ibCellW=" + Convert.ToString(ib.CellWidth()));

        MapBox mb = new MapBox("小地图");
        mb.SetSight(20).SetMapScale(0.5);
        mb.Size(160, 160);
        Console.WriteLine("mbKind=" + mb.Kind());
        Console.WriteLine("mbSight=" + Convert.ToString(mb.Sight()));

        AnimBox ab = new AnimBox("特效框");
        ab.SetAnim("火焰动画", "燃烧").SetLoop(true);
        Console.WriteLine("abKind=" + ab.Kind());
        Console.WriteLine("abAnim=" + ab.Anim());

        CheckBox cb = new CheckBox("性别");
        cb.SetTitle("男").SetGroup(1).SetChecked(true);
        Console.WriteLine("cbKind=" + cb.Kind());
        Console.WriteLine("cbRadio=" + Convert.ToString(cb.Radio()));

        Container ct = new Container("列表容器", 1);
        ct.SetScroll(0, -1).SetPadding(4, 4, 4, 4);
        ct.Add(new ButtonWidget("项1")).Add(new ButtonWidget("项2"));
        Console.WriteLine("ctKind=" + ct.Kind());
        Console.WriteLine("ctLayout=" + Convert.ToString(ct.Layout()));
        Console.WriteLine("ctItems=" + Convert.ToString(ct.ItemCount()));

        Scrollbar sc = new Scrollbar("竖条");
        sc.SetRange(0, 200).SetVertical(true).SetPosition(20);
        Console.WriteLine("scKind=" + sc.Kind());
        Console.WriteLine("scPos=" + Convert.ToString(sc.Position()));

        ComboBox cbo = new ComboBox("职业选择");
        cbo.AddItem(ComboItem.Of("zs", "战士")).AddItem(ComboItem.Of("fs", "法师"));
        cbo.SetVisibleRows(8);
        Console.WriteLine("cboKind=" + cbo.Kind());
        Console.WriteLine("cboItems=" + Convert.ToString(cbo.ItemCount()));
        Console.WriteLine("cboRows=" + Convert.ToString(cbo.VisibleRows()));

        ListBox lb = new ListBox("排行榜");
        lb.AddColumn(ListColumn.Of("名次", 60)).AddColumn(ListColumn.Of("名称", 120)).SetMultiSelect(false);
        Console.WriteLine("lbKind=" + lb.Kind());
        Console.WriteLine("lbCols=" + Convert.ToString(lb.ColumnCount()));

        TabBox tb = new TabBox("属性夹");
        tb.AddTab("基础").AddTab("装备").AddTab("技能");
        Console.WriteLine("tbKind=" + tb.Kind());
        Console.WriteLine("tbTabs=" + Convert.ToString(tb.TabCount()));

        SkillBox skb = new SkillBox("技能位1");
        skb.SetCell(42, 42).SetSkill("烈火剑法");
        Console.WriteLine("skbKind=" + skb.Kind());
        Console.WriteLine("skbSkill=" + skb.Skill());

        QuickBox qb = new QuickBox("快捷1");
        qb.SetCell(40, 40).SetLimitType("道具");
        Console.WriteLine("qbKind=" + qb.Kind());
        Console.WriteLine("qbLimit=" + qb.LimitType());

        BagBox bag = new BagBox("背包");
        bag.SetCell(42, 42).SetGrid(6, 8);
        Console.WriteLine("bagKind=" + bag.Kind());
        Console.WriteLine("bagCols=" + Convert.ToString(bag.Cols()));
        Console.WriteLine("bagRows=" + Convert.ToString(bag.Rows()));
    }
}
