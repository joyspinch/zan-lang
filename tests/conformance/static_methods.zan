using System;
namespace Conf;
class MathX {
    public static int Square(int x) { return x * x; }
    public static int Max(int a, int b) { if (a > b) { return a; } return b; }
}
class Program {
    static void Main() {
        Console.WriteLine(MathX.Square(7));
        Console.WriteLine(MathX.Max(3, 9));
        Console.WriteLine(MathX.Max(12, 4));
    }
}
