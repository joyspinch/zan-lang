// Regression: List and StringBuilder backing buffers + structs must be freed by
// ARC (rc header + per-site collection destructor). Churns them as locals, in
// loops, as class fields, and through method returns; the --check-leaks runtime
// must report zero objects reachable at exit.
using System;
using System.Text;

namespace Conf;

class Resp {
    public List<string> headers;
    public string body;

    static Resp Ok(string b) {
        Resp r = new Resp();
        r.headers = new List<string>();
        r.headers.Add("Content-Type: text/plain");
        r.headers.Add("Connection: keep-alive");
        r.body = b;
        return r;
    }

    string Build() {
        StringBuilder sb = new StringBuilder();
        sb.Append("HTTP/1.1 200 OK\r\n");
        int i = 0;
        while (i < headers.Count) { sb.Append(headers[i]); sb.Append("\r\n"); i = i + 1; }
        sb.Append("\r\n");
        sb.Append(body);
        return sb.ToString();
    }
}

class Program {
    static void Main() {
        int total = 0;
        int r = 0;
        while (r < 300) {
            // plain List local churn
            var xs = new List<int>();
            int i = 0;
            while (i < 8) { xs.Add(i); i = i + 1; }
            total = total + xs.Count;

            // plain StringBuilder local churn
            StringBuilder sb = new StringBuilder();
            int j = 0;
            while (j < 16) { sb.Append("abc"); j = j + 1; }

            // class with List<string> + StringBuilder-built response (server path)
            Resp resp = Resp.Ok("hello-" + r.ToString());
            string wire = resp.Build();
            total = total + wire.Length;

            r = r + 1;
        }
        Console.WriteLine(total);
    }
}
