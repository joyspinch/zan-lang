// Exercises the Game.Rts.Formats INI parser: section merging, comment and
// whitespace handling, last-wins overrides, typed getters and fallbacks.
using System;
using Game.Rts.Formats;

namespace Conf;

class Program {
    static string Yn(bool flag) {
        if (flag) { return "yes"; }
        return "no";
    }

    static void Main() {
        string text =
            "; RA2-style rules fragment\n" +
            "[General]\n" +
            "  Name = Allied Nations   ; inline comment\n" +
            "MaxCredits=10000\n" +
            "Buildable = yes\n" +
            "\n" +
            "[General]\n" +
            "MaxCredits = 20000\n" +
            "\n" +
            "[Unit]\n" +
            "Cost=  750\n" +
            "Amphibious = no\n" +
            "orphan-before-section-is-ignored\n";

        IniDocument doc = IniParser.Parse(text);

        Console.WriteLine("sections=" + Convert.ToString(doc.Count()));
        Console.WriteLine("general.Name=" + doc.Get("General", "Name"));
        Console.WriteLine("general.MaxCredits=" + Convert.ToString(doc.GetIntOr("General", "MaxCredits", 0)));
        Console.WriteLine("general.Buildable=" + Program.Yn(doc.GetBoolOr("General", "Buildable", false)));
        Console.WriteLine("general.keys=" + Convert.ToString(doc.Section("General").Count()));
        Console.WriteLine("unit.Cost=" + Convert.ToString(doc.GetIntOr("Unit", "Cost", -1)));
        Console.WriteLine("unit.Amphibious=" + Program.Yn(doc.GetBoolOr("Unit", "Amphibious", true)));
        Console.WriteLine("unit.Armor=" + doc.GetOr("Unit", "Armor", "none"));
        Console.WriteLine("hasUnit=" + Program.Yn(doc.ContainsSection("Unit")));
        Console.WriteLine("hasNope=" + Program.Yn(doc.ContainsSection("Nope")));
    }
}
