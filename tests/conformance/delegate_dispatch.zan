using System;

namespace Conf;

// A parameterless delegate, as used by the GUI EventHub / dispatch queue.
delegate void Action();

// Verifies two building blocks of the GUI delegate/event system without a
// window: (1) a multicast list of delegates (static method groups and a
// lambda) all fire in order, and (2) the runtime UI-thread dispatch queue
// (zan_dispatch_*) drains posted delegates in FIFO order.
class Prog {
    [DllImport("crt", EntryPoint = "zan_dispatch_init")]
    static extern void DispInit();

    [DllImport("crt", EntryPoint = "zan_dispatch_post")]
    static extern int DispPost(Action handler);

    [DllImport("crt", EntryPoint = "zan_dispatch_take")]
    static extern Action DispTake();

    static int total;

    static void AddOne() { Prog.total = Prog.total + 1; }
    static void AddTen() { Prog.total = Prog.total + 10; }

    static void Main() {
        DispInit();

        List<Action> handlers = new List<Action>();
        handlers.Add(Prog.AddOne);
        handlers.Add(Prog.AddTen);
        handlers.Add(() => { Prog.total = Prog.total + 100; });
        int i = 0;
        while (i < handlers.Count) {
            Action h = handlers[i];
            h();
            i = i + 1;
        }
        Console.WriteLine(Convert.ToString(Prog.total));

        DispPost(Prog.AddOne);
        DispPost(() => { Prog.total = Prog.total + 1000; });
        DispPost(Prog.AddTen);
        int drained = 0;
        Action a = DispTake();
        while (a != null) {
            a();
            drained = drained + 1;
            a = DispTake();
        }
        Console.WriteLine(Convert.ToString(Prog.total));
        Console.WriteLine(Convert.ToString(drained));
    }
}
