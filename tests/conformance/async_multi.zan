// Multiple awaits in one expression and as call arguments: the first await's
// result must survive the second suspension. Exercises the ANF pass.
class Program {
    static async int A(int x) {
        return x + 10;
    }
    static async int B(int x) {
        return x + 20;
    }
    static int Add(int a, int b) {
        return a + b;
    }
    static async int Combine(int c) {
        int r = await A(c) + await B(c);
        int s = Add(await A(c), await B(c));
        return r + s;
    }
    static void Main() {
        int v = await Combine(1);
        Console.WriteLine(v);
    }
}
