using System;
namespace P;
class Cell {
    public int v;
    public Cell(int x) { v = x; }
}
class Program {
    static void Main() {
        Cell[] a = new Cell[3];
        a[0] = new Cell(5);
        a[1] = new Cell(7);
        a[2] = new Cell(9);
        a[1].v = 70;
        int s = 0;
        int i = 0;
        while (i < 3) { s = s + a[i].v; i = i + 1; }
        Console.WriteLine(s);
        Console.WriteLine(a[0].v);
    }
}
