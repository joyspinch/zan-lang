// Exercises the ZGM-native SQLite save repository on top of the generic
// System.Data.Sqlite connection: schema creation, save/load, overwrite,
// quoted slot/item names, existence and deletion.
using System;
using Game.Zgm;
using Game.Zgm.Data;

namespace T;

class Program {
    static void Main() {
        ZgmDatabase db = ZgmDatabase.OpenMemory("save");
        ZgmSaveRepository saves = ZgmSaveRepository.Open(db);
        Console.WriteLine("ready=" + Convert.ToString(saves.IsReady()));

        ZgmSaveState first = ZgmSaveState.Create(
            "field", 2, 3, 1, 4, 90, 20)
            .SetProgress(37, 18)
            .AddItem("potion", 3)
            .AddItem("iron'shard", 1)
            .AddEquipment("武器", "sword")
            .AddSkill("slash")
            .AddBuff("poison", 750);
        Console.WriteLine("save=" + Convert.ToString(
            saves.Save("slot'one", first)));
        Console.WriteLine("exists=" + Convert.ToString(
            saves.Exists("slot'one")));
        Console.WriteLine("slots=" + Convert.ToString(saves.SlotCount()));
        Console.WriteLine("slot0=" + saves.SlotAt(0));
        Console.WriteLine("slotBad=" + saves.SlotAt(4));

        ZgmSaveState loaded = saves.Load("slot'one");
        Console.WriteLine(
            "load=" + loaded.MapName() + "|"
            + Convert.ToString(loaded.HeroX()) + ","
            + Convert.ToString(loaded.HeroY()) + "|"
            + Convert.ToString(loaded.ItemCount()));
        Console.WriteLine(
            "item0=" + loaded.ItemAt(0).Name() + ":"
            + Convert.ToString(loaded.ItemAt(0).Quantity()));
        Console.WriteLine(
            "progress=" + Convert.ToString(loaded.HeroExperience())
                + "|" + Convert.ToString(loaded.HeroRage()));
        Console.WriteLine(
            "extra=" + loaded.EquipmentAt(0).Slot() + ":"
                + loaded.EquipmentAt(0).ItemName() + "|"
                + loaded.SkillAt(0).Name() + "|"
                + loaded.BuffAt(0).Name() + ":"
                + Convert.ToString(loaded.BuffAt(0).Remaining()));

        ZgmSaveState replacement = ZgmSaveState.Create(
            "town", 7, 8, 2, 5, 100, 30)
            .SetProgress(99, 7)
            .AddItem("gold", 99);
        Console.WriteLine("overwrite=" + Convert.ToString(
            saves.Save("slot'one", replacement)));
        ZgmSaveState loadedAgain = saves.Load("slot'one");
        Console.WriteLine(
            "reload=" + loadedAgain.MapName() + "|"
            + Convert.ToString(loadedAgain.HeroLevel()) + "|"
            + loadedAgain.ItemAt(0).Name() + "|"
            + Convert.ToString(loadedAgain.HeroExperience()) + "|"
            + Convert.ToString(loadedAgain.EquipmentCount()) + "|"
            + Convert.ToString(loadedAgain.BuffCount()));

        Console.WriteLine("delete=" + Convert.ToString(
            saves.Delete("slot'one")));
        Console.WriteLine("existsAfter=" + Convert.ToString(
            saves.Exists("slot'one")));

        loaded.Dispose();
        loadedAgain.Dispose();
        first.Dispose();
        replacement.Dispose();
        saves.Close();
        Console.WriteLine("closed=" + Convert.ToString(db.IsOpen()));
    }
}
