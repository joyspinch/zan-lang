// Conformance: LINQ query syntax - from/where/select over lists.
using System;

class Program {
    static void Main() {
        List<int> nums = new List<int> { 1, 2, 3, 4, 5, 6 };

        List<int> evens = from n in nums where n % 2 == 0 select n;
        foreach (int e in evens) {
            Console.WriteLine(e);
        }

        List<int> squares = from n in nums where n > 3 select n * n;
        foreach (int s in squares) {
            Console.WriteLine(s);
        }

        List<string> words = new List<string> { "apple", "fig", "banana" };
        List<string> shortWords = from w in words where w.Length <= 5 select w;
        foreach (string w in shortWords) {
            Console.WriteLine(w);
        }

        int total = 0;
        foreach (int v in from n in nums where n < 4 select n * 10) {
            total = total + v;
        }
        Console.WriteLine(total);
    }
}
