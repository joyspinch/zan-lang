// Conformance: partial classes/structs merged across declarations.
using System;

partial class Widget {
    public int width;

    public int Area() { return width * height; }
}

partial class Widget {
    public int height;

    public string Describe() {
        return Convert.ToString(width) + "x" + Convert.ToString(height);
    }
}

partial struct Point {
    public int x;
}

partial struct Point {
    public int y;

    public int Sum() { return x + y; }
}

class Program {
    static void Main() {
        Widget w = new Widget();
        w.width = 4;
        w.height = 5;
        Console.WriteLine(w.Area());
        Console.WriteLine(w.Describe());

        Point p;
        p.x = 2;
        p.y = 9;
        Console.WriteLine(p.Sum());
    }
}
