using System;

namespace Conf;

class User {
    string name;
    int age;
    bool vip;
}

class Vm {
    string title;
}

class Input {
    Binding<string> data;
}

class Button {
    Binding<string> text;
}

class Counter {
    Binding<int> val;
    Binding<bool> on;
}

class Program {
    static void Main() {
        User u = new User();
        u.name = "alice";
        u.age = 30;
        u.vip = false;

        Input input = new Input();
        input.data = u.name;
        Console.WriteLine(input.data.Get());

        input.data.Set("bob");
        Console.WriteLine(u.name);

        u.name = "carol";
        Console.WriteLine(input.data.Get());

        Counter c = new Counter();
        c.val = u.age;
        c.on = u.vip;
        Console.WriteLine(Convert.ToString(c.val.Get()));
        c.val.Set(41);
        Console.WriteLine(Convert.ToString(u.age));
        c.on.Set(true);
        Console.WriteLine(Convert.ToString(u.vip));

        Button b = new Button();
        b.text = "确定";
        Console.WriteLine(b.text.Get());
        Console.WriteLine(Convert.ToString(b.text.IsLive()));

        Vm vm = new Vm();
        vm.title = "标题";
        b.text = vm.title;
        Console.WriteLine(b.text.Get());
        Console.WriteLine(Convert.ToString(b.text.IsLive()));

        // sharing an existing binding stays a plain reference assignment
        Input input2 = new Input();
        input2.data = input.data;
        Console.WriteLine(input2.data.Get());
    }
}
