using System;
using Game.Core;

class Program {
    static void Main() {
        // Loop clip: 8 directions x 6 frames at 10 fps (100 ms/frame).
        AnimClip run = AnimClip.Create(8, 6, 10, 1, 0);
        AnimPlayer p = AnimPlayer.Create();
        p.Play(run);
        p.SetDir(3);
        Console.WriteLine(p.SheetFrame());   // 3*6+0 = 18
        p.Update(250);                        // -> frame 2
        Console.WriteLine(p.SheetFrame());   // 20
        p.SetDir(4);                          // turn: frame progress kept
        Console.WriteLine(p.SheetFrame());   // 4*6+2 = 26
        p.Update(400);                        // frame 2+4 = 6 -> wraps to 0
        Console.WriteLine(p.SheetFrame());   // 24

        // Once clip: holds the last frame and reports Done.
        AnimClip hit = AnimClip.Create(8, 4, 10, 0, 0);
        p.Play(hit);
        p.SetDir(0);
        p.Update(1000);
        Console.WriteLine(p.Frame());        // 3
        if (p.Done()) { Console.WriteLine(1); } else { Console.WriteLine(0); }

        // Section clip: intro 0..1 once, then repeat 2..5.
        AnimClip cast = AnimClip.Create(8, 6, 10, 2, 2);
        p.Play(cast);
        p.Update(600);                        // 6 steps -> wraps to loopStart
        Console.WriteLine(p.Frame());        // 2
        p.Update(400);                        // 3,4,5, wrap -> 2
        Console.WriteLine(p.Frame());        // 2

        // JSON parsing of the .anim side-car format.
        string js = "{\"version\":1,\"image\":\"run.png\",\"frameW\":96,\"frameH\":96,\"base\":48,\"dirs\":8,\"framesPerDir\":6,\"fps\":12,\"loop\":\"section\",\"loopStart\":1}";
        AnimClip c = AnimClip.ParseJson(js);
        Console.WriteLine(c.Image());        // run.png
        Console.WriteLine(c.Base());         // 48
        Console.WriteLine(c.Dirs());         // 8
        Console.WriteLine(c.FramesPerDir()); // 6
        Console.WriteLine(c.Fps());          // 12
        Console.WriteLine(c.LoopMode());     // 2
        Console.WriteLine(c.LoopStart());    // 1
        AnimPlayer q = AnimPlayer.Create();
        q.Play(c);
        q.SetDir(7);
        Console.WriteLine(q.SheetFrame());   // 48 + 7*6 = 90
    }
}
