using System;

namespace Conf;

// Interface method dispatch: an interface-typed reference (and interface-typed
// List elements) must call the concrete implementation, not fall back to 0.
interface IShape { int Area(); string Name(); }

class Rect : IShape {
    int w; int h;
    int Area() { return w * h; }
    string Name() { return "rect"; }
}
class Circle : IShape {
    int r;
    int Area() { return 3 * r * r; }
    string Name() { return "circle"; }
}

class Prog {
    static int TotalArea(List<IShape> xs) {
        int a = 0; int i = 0;
        while (i < xs.Count) { a = a + xs[i].Area(); i = i + 1; }
        return a;
    }
    static void Main() {
        Rect a = new Rect { w = 3, h = 4 };
        IShape s = a;
        Console.WriteLine(Convert.ToString(s.Area()));
        Console.WriteLine(s.Name());
        IShape c = new Circle { r = 2 };
        Console.WriteLine(Convert.ToString(c.Area()));
        Console.WriteLine(c.Name());
        List<IShape> xs = new List<IShape>();
        xs.Add(a); xs.Add(c);
        Console.WriteLine(Convert.ToString(Prog.TotalArea(xs)));
    }
}
