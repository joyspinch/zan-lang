// Conformance: positional records - fields, ctor, value equality, ToString.
using System;

record Point(int x, int y);
record Person(string name, int age);

class Program {
    static void Main() {
        Point a = new Point(1, 2);
        Point b = new Point(1, 2);
        Point c = new Point(3, 4);

        Console.WriteLine(a.x);
        Console.WriteLine(a.y);
        if (a == b) { Console.WriteLine("eq"); }
        if (a != c) { Console.WriteLine("neq"); }
        if (a != null) { Console.WriteLine("notnull"); }
        Console.WriteLine(a.ToString());

        Person p = new Person("ada", 36);
        Console.WriteLine(p.ToString());
        Person q = new Person("ada", 36);
        if (p == q) { Console.WriteLine("same"); }
    }
}
