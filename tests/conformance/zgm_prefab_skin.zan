using System;
using System.Collections.Generic;
using Game.Zgm;

namespace T;

class Program {
    static void Main() {
        // 自定义组件 (prefab): a 文本按钮 built from a label node
        PrefabConfig prefab = PrefabConfig.Create("文本按钮")
            .SetSize(48, 24)
            .SetBackground(ZgmColor.Rgba(30, 30, 30, 255))
            .SetBorder(1, ZgmColor.Rgba(168, 168, 168, 255))
            .SetCorner(4, 8)
            .SetMouseEvent(true);
        TextNode label = new TextNode("按钮标签");
        label.SetAlign(1, 1).SetFont("宋体12").SetTitle("");
        prefab.AddNode(label);
        SpriteNode deco = new SpriteNode("角标");
        deco.SetImage("图集|角标");
        prefab.AddNode(deco);
        Console.WriteLine("prefabKind=" + prefab.Kind());
        Console.WriteLine("prefabName=" + prefab.Name());
        Console.WriteLine("prefabW=" + Convert.ToString(prefab.Width()));
        Console.WriteLine("prefabNodes=" + Convert.ToString(prefab.NodeCount()));
        Node n0 = prefab.NodeAt(0);
        Console.WriteLine("prefabNode0Kind=" + n0.Kind());

        // 皮肤 (skin library)
        SkinLibrary lib = SkinLibrary.Create();
        Skin btnSkin = Skin.Create("Long_九宫按钮1")
            .SetFont("宋体12", 2)
            .SetImage("Long_皮肤_按钮_九宫1")
            .SetNineGrid(NineGrid.Of(10, 10, 10, 10))
            .SetThreeLayer(true)
            .AddTextColor(ZgmColor.Rgba(243, 243, 243, 255))
            .AddTextColor(ZgmColor.Rgba(0, 220, 0, 255))
            .AddTextColor(ZgmColor.Rgba(240, 70, 70, 255))
            .SetStroke(ZgmColor.Rgba(0, 0, 0, 200));
        lib.Add(btnSkin);
        Skin winSkin = Skin.Create("Long_窗口")
            .SetBackground(ZgmColor.Rgba(20, 20, 20, 200))
            .SetBorder(2, ZgmColor.Rgba(255, 255, 255, 200))
            .SetImage("Long_皮肤_窗口背景")
            .SetNineGrid(NineGrid.Of(68, 42, 72, 42));
        lib.Add(winSkin);
        Console.WriteLine("libCount=" + Convert.ToString(lib.Count()));
        Skin got = lib.Get("Long_九宫按钮1");
        Console.WriteLine("gotFont=" + got.Font());
        Console.WriteLine("gotTextColors=" + Convert.ToString(got.TextColorCount()));
        NineGrid ng = got.nineGrid;
        Console.WriteLine("gotNineLeft=" + Convert.ToString(ng.Left()));
        Skin missing = lib.Get("不存在");
        Console.WriteLine("missing=" + Convert.ToString(missing == null));
    }
}
