using System;
using System.Data.MySql;
using System.Security.Cryptography;

class Program {
    [DllImport("crt")]
    static extern void free(string ptr);

    static void Main() {
        string nonce = "12345678901234567890";
        string native = MySqlConnection.scrambleNative("secret", nonce);
        string caching = MySqlConnection.scramble41("secret", nonce);
        Console.WriteLine(Hex.Encode(native, 20));
        Console.WriteLine(Hex.Encode(caching, 32));
        free(native);
        free(caching);
    }
}
