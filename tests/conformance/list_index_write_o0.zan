using System;

// Regression test: at -O0, an indexed List write whose index expression is
// recomputed every iteration must not grow the stack (each local declared in
// the loop body reuses one entry-block slot instead of a fresh alloca per
// iteration). 1M iterations overflowed the stack before the fix.

class Repro {
    static void Main() {
        List<int> a = new List<int>();
        int c = 0;
        while (c < 70) { a.Add(0); c = c + 1; }
        int k = 0;
        while (k < 1000000) {
            int idx = k % 5 + 1;
            a[idx] = a[idx] + 1;
            k = k + 1;
        }
        Console.WriteLine("ok " + Convert.ToString(a[1]));
    }
}
