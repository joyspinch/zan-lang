using System;

class Program {
    static int Accumulate(int n) {
        int acc = 0;
        int i = 0;
        while (i <= n) {
            acc = acc + i;
            i = i + 1;
        }
        return acc;
    }

    static void Main() {
        int n = 5;
        int s = Accumulate(n);
        Console.WriteLine(s);
        Console.WriteLine(acc_done());
    }

    static int acc_done() {
        return 0;
    }
}
