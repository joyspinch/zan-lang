using System;
using Gui;

namespace LayoutTest;

/// Headless verification of the Gui.Stack layout cursor. Prints the computed
/// child rectangles so the math can be diffed against a golden file.
class Program {
    static void PrintRect(string label, Rect r) {
        Console.WriteLine($"{label} {r.x},{r.y} {r.width}x{r.height}");
    }

    static void Main() {
        Console.WriteLine("=== column ===");
        Stack col = Stack.Column(10, 20, 200, 400);
        col.SetPad(8);
        col.SetGap(4);
        Rect header = col.Slot(32);
        Rect body = col.Slot(100);
        Rect footer = col.Fill();
        PrintRect("header", header);
        PrintRect("body", body);
        PrintRect("footer", footer);
        Console.WriteLine($"remaining {col.Remaining()}");

        Console.WriteLine("=== row ===");
        Stack bar = Stack.Row(0, 0, 300, 40);
        bar.SetGap(10);
        Rect a = bar.Slot(80);
        Rect b = bar.Slot(80);
        Rect rest = bar.Fill();
        PrintRect("a", a);
        PrintRect("b", b);
        PrintRect("rest", rest);

        Console.WriteLine("=== fraction + room ===");
        Stack split = Stack.Row(0, 0, 1000, 50);
        Rect side = split.SlotFraction(300);
        Rect main = split.Fill();
        PrintRect("side", side);
        PrintRect("main", main);
        if (split.HasRoom(10)) {
            Console.WriteLine("room yes");
        } else {
            Console.WriteLine("room no");
        }
    }
}
