using System;
using Gui;
using Gui.Widget;

namespace CodeEditorTest;

/// Headless verification of the CodeEditor autocomplete + snippet pipeline:
/// UpdateCompletion candidate lists, Tab-accepting a word, and Tab-expanding
/// a code-block snippet (caret placement + indentation preserved).
class Program {
    static bool Has(List<string> xs, string v) {
        int i = 0;
        while (i < xs.Count) {
            if (xs[i] == v) { return true; }
            i = i + 1;
        }
        return false;
    }

    static void Main() {
        // ---- word completion candidates ----
        CodeEditor e = CodeEditor.Create();
        e.lines[0] = "    fo";
        e.curLine = 0;
        e.curCol = 6;
        e.UpdateCompletion();
        Console.WriteLine(e.acActive);
        Console.WriteLine(Has(e.acItems, "for"));
        Console.WriteLine(Has(e.acItems, "foreach"));

        // ---- Tab-accept a snippet: expands the block, keeps indentation ----
        int sel = 0;
        while (sel < e.acItems.Count) {
            if (e.acItems[sel] == "for") { e.acSel = sel; sel = e.acItems.Count; }
            else { sel = sel + 1; }
        }
        e.AcceptCompletion(true);
        Console.WriteLine(e.lines.Count);
        Console.WriteLine(e.lines[0]);
        Console.WriteLine(e.lines[1]);
        Console.WriteLine(e.lines[2]);
        Console.WriteLine(e.curLine);
        Console.WriteLine(e.acActive);

        // ---- Enter-accept a word: inserts the text, no block expansion ----
        CodeEditor w = CodeEditor.Create();
        w.lines[0] = "whi";
        w.curLine = 0;
        w.curCol = 3;
        w.UpdateCompletion();
        Console.WriteLine(w.acActive);
        int wi = 0;
        while (wi < w.acItems.Count) {
            if (w.acItems[wi] == "while") { w.acSel = wi; wi = w.acItems.Count; }
            else { wi = wi + 1; }
        }
        w.AcceptCompletion(false);
        Console.WriteLine(w.lines[0]);
        Console.WriteLine(w.curCol);

        // ---- Enter accepts too (viaTab=false inserts the word, no expansion) --
        CodeEditor n = CodeEditor.Create();
        n.lines[0] = "if";
        n.curLine = 0;
        n.curCol = 2;
        n.UpdateCompletion();
        if (n.acActive) {
            int ni = 0;
            while (ni < n.acItems.Count) {
                if (n.acItems[ni] == "ifelse") { n.acSel = ni; ni = n.acItems.Count; }
                else { ni = ni + 1; }
            }
            n.AcceptCompletion(false);
        }
        Console.WriteLine(n.lines.Count);
        Console.WriteLine(n.lines[0]);

        // ---- try snippet: caret lands inside the try block ----
        CodeEditor t = CodeEditor.Create();
        t.lines[0] = "tr";
        t.curLine = 0;
        t.curCol = 2;
        t.UpdateCompletion();
        int ti = 0;
        while (ti < t.acItems.Count) {
            if (t.acItems[ti] == "try") { t.acSel = ti; ti = t.acItems.Count; }
            else { ti = ti + 1; }
        }
        t.AcceptCompletion(true);
        Console.WriteLine(t.lines.Count);
        Console.WriteLine(t.lines[0]);
        Console.WriteLine(t.lines[2]);
        Console.WriteLine(t.curLine);
    }
}
