class Calc { public int acc; public weak Calc twin; public Calc() { acc = 0; } public void Add(int x) { acc = acc + x; } public int Get() { return acc; } }
class Row { public List<int> vals; public Row() { vals = new List<int>(); } }
class Acc2 {
  public int bs;
  public Acc2(int b) { bs = b; }
  async int Add(int v) { return v + this.bs; }
  async int Go(int a) { int x = await this.Add(a); return x + a; }
}
class SReg {
  static int total = 3;
  static List<int> bag = new List<int>();
  static void Add(int v) { SReg.total = SReg.total + v; SReg.bag.Add(v); }
  static int BagSum() { int s = 0; int i = 0; while (i < SReg.bag.Count) { s = s + SReg.bag[i]; i = i + 1; } return s; }
}
class P {
  [DllImport("crt")] static extern string calloc(int n, int sz);
  static int Fib(int n) { if (n < 2) { return n; } return Fib(n-1) + Fib(n-2); }
  static int Cnt<T>(List<T> xs) { return xs.Count; }
  static async int AsBase() { return 20; }
  static async int AsTwice(int n) { int b = await AsBase(); return b + n + 1; }
  static void Main() {
    Calc c = new Calc();
    int i = 1;
    while (i <= 5) { c.Add(i); i = i + 1; }
    Console.WriteLine(c.Get());
    Console.WriteLine(Fib(10));
    string s = "n=" + c.Get();
    Console.WriteLine(s);
    List<int> vs = new List<int> { 7, 8, 9 };
    Console.WriteLine(vs[0] + vs[1] + vs[2]);
    Calc d = new Calc { acc = 100 };
    Console.WriteLine(d.Get());
    List<Row> rows = new List<Row>();
    rows.Add(new Row { vals = new List<int> { 3, 4 } });
    Console.WriteLine(rows[0].vals[1]);
    List<double> ds = new List<double> { 1.5, 2.25 };
    Console.WriteLine(ds[0] + ds[1]);
    string vp = @"C:\zan\build";
    Console.WriteLine(vp);
    string vq = @"say ""hi""";
    Console.WriteLine(vq);
    int yr = 2026;
    string vv = $@"win C:\zan\{yr}\bin";
    Console.WriteLine(vv);
    string vw = $@"n=""{c.Get()}""";
    Console.WriteLine(vw);
    string vx = @$"alt\{yr}";
    Console.WriteLine(vx);
    int sh = 1; sh <<= 5; Console.WriteLine(sh);
    int bw = 12; bw &= 10; Console.WriteLine(bw);
    int rs = 100; rs = rs >> 2; Console.WriteLine(rs);
    string qn = null; Console.WriteLine(qn ?? "dv");
    string qh = "hh"; Console.WriteLine(qh ?? "x");
    int sr = 64; sr >>= 2; Console.WriteLine(sr);
    string qc = null; qc ??= "z"; Console.WriteLine(qc);
    c.twin = d; Console.WriteLine(c.twin.Get());
    Console.WriteLine(P.Cnt<int>(vs));
    int av = await P.AsTwice(21); Console.WriteLine(av);
    Acc2 ac = new Acc2(50); int gg = await ac.Go(5); Console.WriteLine(gg);
    SReg.Add(10); SReg.Add(20); Console.WriteLine(SReg.total); Console.WriteLine(SReg.BagSum());
    int[] arr = new int[4]; arr[0] = 5; arr[1] = 9; arr[2] = arr[0] + arr[1]; arr[3] = arr[2] * 2; Console.WriteLine(arr[2] + arr[3]);
    string bb = P.calloc(8, 1); bb[0] = 65; bb[1] = 66; bb[3] = 67; bb[7] = 90; Console.WriteLine(bb[0] + bb[1] + bb[3] + bb[7]);
  }
}