class Calc { public int acc; public Calc() { acc = 0; } public void Add(int x) { acc = acc + x; } public int Get() { return acc; } }
class P {
  static int Fib(int n) { if (n < 2) { return n; } return Fib(n-1) + Fib(n-2); }
  static void Main() {
    Calc c = new Calc();
    int i = 1;
    while (i <= 5) { c.Add(i); i = i + 1; }
    Console.WriteLine(c.Get());
    Console.WriteLine(Fib(10));
    string s = "n=" + c.Get();
    Console.WriteLine(s);
  }
}