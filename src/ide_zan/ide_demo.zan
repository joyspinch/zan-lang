using System;
using System.IO;
using System.Diagnostics;
using Gui;
using Gui.Widget;

/// Describes one project template: the category it appears under, its display
/// name / icon / description, the scaffolding "kind" (console / dll-class /
/// gui-empty / webview / server / custom / ...), and, for custom templates, the
/// source directory to copy from.
class Tpl {
    string cat;
    string name;
    string icon;
    string desc;
    string kind;
    string src;

    static Tpl Make(string cat, string name, string icon, string kind, string desc) {
        Tpl t = new Tpl();
        t.cat = cat;
        t.name = name;
        t.icon = icon;
        t.kind = kind;
        t.desc = desc;
        t.src = "";
        return t;
    }
}

/// A miniature aardio/VS-Code-style IDE built from the enterprise GUI components
/// (Ribbon / TreeView / TabView / CodeEditor / Panel / Split / Modal / Input /
/// Button) wired to a REAL project on disk and the real Zan toolchain.
///
///   * Project ("New Project"): a modal wizard with categorized templates
///     (Console / GUI App / DLL Library / Executable / Empty), a project name
///     and a location — scaffolds the folder + starter files + zan.proj config.
///   * New ("New File"): a modal wizard with file templates (Program / Class /
///     GUI Window / Interface / Empty).
///   * Explorer tree scanned from disk; click a file to open it in a tab.
///   * Save writes to disk; Build/Run/Publish invoke zanc (+clang) via Process
///     and stream output to the Output panel.
class IdeDemo {
    #if WINDOWS
    [DllImport("kernel32", EntryPoint = "GetModuleFileNameA")]
    static extern int WinGetModuleFileName(int hModule, string buf, int size);
    #elif MACOS
    // _NSGetExecutablePath(char* buf, uint32_t* bufsize): fills buf with the
    // executable path; bufsize points to a 4-byte little-endian capacity.
    [DllImport("crt", EntryPoint = "_NSGetExecutablePath")]
    static extern int MacGetExecutablePath(string buf, string bufsize);
    #else
    // Linux exposes the running executable via the /proc/self/exe symlink.
    [DllImport("crt", EntryPoint = "readlink")]
    static extern int LinuxReadlink(string path, string buf, int bufsize);
    #endif

    [DllImport("crt")]
    static extern string calloc(int count, int size);

    /// Full path of the running IDE executable. Platform-specific: Win32
    /// GetModuleFileNameA, macOS _NSGetExecutablePath, Linux /proc/self/exe.
    /// The buffer is calloc-zeroed so the returned path stays NUL-terminated.
    static string ExePath() {
        string buf = calloc(4096, 1);
        #if WINDOWS
        WinGetModuleFileName(0, buf, 4096);
        #elif MACOS
        string cap = calloc(4, 1);
        cap[1] = 16;
        MacGetExecutablePath(buf, cap);
        #else
        LinuxReadlink("/proc/self/exe", buf, 4096);
        #endif
        return buf;
    }

    /// Directory that contains the running IDE executable, with no trailing
    /// separator. Used so the toolchain (zanc + its stdlib) is located relative
    /// to the IDE rather than a hard-coded absolute path — makes the IDE portable.
    static string ExeDir() {
        string p = IdeDemo.ExePath();
        int cut = 0 - 1;
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "\\" || ch == "/") { cut = i; }
            i = i + 1;
        }
        if (cut < 0) { return "."; }
        return p.Substring(0, cut);
    }

    /// Executable file suffix for produced binaries: ".exe" on Windows, none
    /// on POSIX (where the extension is irrelevant and conventionally absent).
    #if WINDOWS
    static string ExeSuffix() { return ".exe"; }
    #else
    static string ExeSuffix() { return ""; }
    #endif

    /// Basename of the Zan compiler shipped next to the IDE.
    static string ZancName() { return "zanc" + IdeDemo.ExeSuffix(); }

    /// C library getenv, for locating per-user directories (mirrors the
    /// approach in System.IO.Path). Returns null when the variable is unset.
    [DllImport("crt")]
    static extern string getenv(string name);

    /// User home directory (USERPROFILE on Windows, HOME on POSIX).
    static string HomeDir() {
        #if WINDOWS
        string h = getenv("USERPROFILE");
        #else
        string h = getenv("HOME");
        #endif
        if (h == null || h == "") { return "."; }
        return h;
    }

    /// Per-user, writable directory for IDE config + custom templates. Kept out
    /// of the (possibly read-only) install dir so nothing user-owned lives there.
    static string UserConfigDir() {
        #if WINDOWS
        string a = getenv("APPDATA");
        if (a == null || a == "") { a = IdeDemo.HomeDir(); }
        return a + "/ZanIDE";
        #elif MACOS
        return IdeDemo.HomeDir() + "/Library/Application Support/ZanIDE";
        #else
        string x = getenv("XDG_CONFIG_HOME");
        if (x != null && x != "") { return x + "/zan-ide"; }
        return IdeDemo.HomeDir() + "/.config/zan-ide";
        #endif
    }

    /// Default parent for user projects. Projects are user-owned and never
    /// created under the install dir; the wizard lets the user pick any path.
    static string ProjectsHome() { return IdeDemo.HomeDir() + "/ZanProjects"; }

    /// Shipped (read-only) resource roots, laid out relative to the IDE exe:
    ///   <ExeDir>/toolchain/zanc[.exe]   <ExeDir>/stdlib   (+ examples, templates)
    static string ToolchainDir() { return IdeDemo.ExeDir() + "/toolchain"; }
    static string StdlibDir() { return IdeDemo.ExeDir() + "/stdlib"; }

    /// Per-project build scratch dir (writable, colocated with the sources),
    /// created on demand so build artifacts never touch the install dir.
    static string EnsureBuildDir(string root) {
        string d = root + "/.build";
        if (!Directory.Exists(d)) { Directory.CreateDirectoryRecursive(d); }
        return d;
    }

    /// Resolve the Zan compiler under <ExeDir>/toolchain. Falls back to the bare
    /// name so the shell resolves it via PATH -- no hard-coded absolute path.
    static string Zanc() {
        string cand = IdeDemo.ToolchainDir() + "/" + IdeDemo.ZancName();
        if (File.Exists(cand)) { return cand; }
        return IdeDemo.ZancName();
    }

    /// Quoted zanc invocation prefix with an explicit --stdlib-path so stdlib
    /// resolution never depends on relative (../stdlib) lookup or the cwd.
    static string ZancCmd() {
        return "\"" + IdeDemo.Zanc() + "\" --stdlib-path \"" + IdeDemo.StdlibDir() + "\"";
    }

    static void Main() {
        // Restore the last-used window / panel sizes (see SaveSettings).
        string cfg = "";
        if (File.Exists(IdeDemo.CfgPath())) { cfg = File.ReadAllText(IdeDemo.CfgPath()); }
        int cfgW = IdeDemo.CfgClamp(IdeDemo.CfgInt(cfg, "winW", 1180), 640, 4000);
        int cfgH = IdeDemo.CfgClamp(IdeDemo.CfgInt(cfg, "winH", 780), 480, 3000);
        App app = App.CreateDark("Zan IDE", cfgW, cfgH);
        app.Show();
        int savedW = cfgW;
        int savedH = cfgH;

        string root = IdeDemo.ProjectsHome() + "/hello";
        IdeDemo.EnsureWorkspace(root);

        List<TreeNode> tree = IdeDemo.ScanTree(root);
        bool rescan = false;

        List<string> tabNames = new List<string>();
        List<string> tabBodies = new List<string>();
        List<string> tabPaths = new List<string>();

        SignalInt activeTab = SignalInt.Create(0);
        CodeEditor editor = CodeEditor.Create();
        int lastActive = 0 - 1;
        // Which .zform tab the designer is currently bound to, and the last
        // serialized layout (to detect changes and persist them back to disk).
        string loadedFormPath = "";
        string formCache = "";

        IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, activeTab,
                         root + "/src/main.zan", "main.zan");
        // Start page is a real tab (path sentinel "@start"), shown first like
        // VS's Start Page. Rendered specially instead of the code editor.
        tabNames.Insert(0, "Start");
        tabBodies.Insert(0, "");
        tabPaths.Insert(0, "@start");
        activeTab.Set(0);

        List<string> log = new List<string>();
        log.Add("> Zan IDE ready. Workspace: " + root);

        List<RibbonCmd> cmds = new List<RibbonCmd>();
        cmds.Add(RibbonCmd.Create("plus", "Project"));
        cmds.Add(RibbonCmd.Group("file", "New"));
        cmds.Add(RibbonCmd.Create("folder", "Open"));
        cmds.Add(RibbonCmd.Group("download", "Save"));
        cmds.Add(RibbonCmd.Create("arrow-right", "Run"));
        cmds.Add(RibbonCmd.Create("refresh", "Build"));
        cmds.Add(RibbonCmd.Create("upload", "Publish"));
        cmds.Add(RibbonCmd.Create("bug", "Debug"));
        cmds.Add(RibbonCmd.Group("copy", "Template"));
        cmds.Add(RibbonCmd.Create("layout", "Designer"));
        cmds.Add(RibbonCmd.Create("home", "Start"));
        cmds.Add(RibbonCmd.Create("refresh", "Hot"));

        // ---- New Project categories (built-in + user "Custom") ----
        List<string> catNames = new List<string>();
        catNames.Add("Console");
        catNames.Add("Library");
        catNames.Add("Window App");
        catNames.Add("WebView");
        catNames.Add("Server");
        catNames.Add("Custom");

        // The template catalog + its parallel projections; rebuilt whenever the
        // New Project wizard opens so freshly-saved custom templates show up.
        List<Tpl> tpls = new List<Tpl>();
        List<string> tCats = new List<string>();
        List<string> tNames = new List<string>();
        List<string> tIcons = new List<string>();
        List<string> tDescs = new List<string>();

        // ---- New File template catalog ----
        List<string> fNames = new List<string>();
        List<string> fIcons = new List<string>();
        List<string> fDescs = new List<string>();
        fNames.Add("Program (Main)"); fIcons.Add("arrow-right"); fDescs.Add("Code file: class with a static Main() entry point.");
        fNames.Add("Class");          fIcons.Add("grid");        fDescs.Add("Code file: an empty class with fields and methods.");
        fNames.Add("GUI Window");     fIcons.Add("maximize");    fDescs.Add("Code file: a Gui window with an event loop.");
        fNames.Add("Interface");      fIcons.Add("copy");        fDescs.Add("Code file: a base class defining a contract.");
        fNames.Add("Empty File");     fIcons.Add("file");        fDescs.Add("Code file: a blank .zan file.");
        fNames.Add("Form (Designer)"); fIcons.Add("layout");     fDescs.Add("Form: creates Name.zform (visual layout) + Name.zan (code-behind).");

        // ---- Dialog state ----
        // The New Project / New File wizards are REAL secondary top-level windows
        // (draggable anywhere on the desktop), driven from this same event pump.
        // dlg is null when no wizard is open.
        // dlgMode: 1=new-project, 2=new-file, 3=save-as-template.
        App dlg = null;
        int dlgMode = 0;
        SignalInt catSel = SignalInt.Create(0);
        SignalInt pSel = SignalInt.Create(0);
        SignalInt fSel = SignalInt.Create(0);

        // Target platforms for New Project (multi-select OS + architecture);
        // platSel holds a 0/1 flag per entry, parallel to platformNames.
        // One column per OS; two architecture chips stacked per column. Chip
        // labels are arch-only (the OS is the column header). Order is
        // column-major: [Win x64, Win ARM64, Linux x64, Linux ARM64, ...].
        List<string> platformGroups = new List<string>();
        platformGroups.Add("Windows");
        platformGroups.Add("Linux");
        platformGroups.Add("macOS");
        List<string> platformNames = new List<string>();
        platformNames.Add("x64"); platformNames.Add("ARM64");
        platformNames.Add("x64"); platformNames.Add("ARM64");
        platformNames.Add("x64"); platformNames.Add("ARM64");
        List<int> platSel = new List<int>();
        platSel.Add(1); platSel.Add(0); platSel.Add(0);
        platSel.Add(0); platSel.Add(0); platSel.Add(0);
        Input pNameInput = Input.Bind(SignalString.Create("NewProject"), "project name");
        Input pLocInput = Input.Bind(SignalString.Create(IdeDemo.ProjectsHome()), "location");
        Input fNameInput = Input.Bind(SignalString.Create("NewFile"), "file name");

        // Right-click context menu (file tree + tab bar) state.
        // ctxKind: 0 = none, 1 = project tree row, 3 = editor tab.
        int ctxKind = 0;
        int ctxX = 0;
        int ctxY = 0;
        int ctxTarget = 0 - 1;

        // Save-current-project-as-custom-template state.
        SignalInt tmplCatSel = SignalInt.Create(0);
        Input tmplNameInput = Input.Bind(SignalString.Create("MyTemplate"), "template name");
        List<string> saveCats = new List<string>();
        List<string> saveIcons = new List<string>();
        List<string> saveDescs = new List<string>();
        saveCats.Add("Console");    saveIcons.Add("menu");        saveDescs.Add("Save under the Console category.");
        saveCats.Add("Library");    saveIcons.Add("grid");        saveDescs.Add("Save under the Library category.");
        saveCats.Add("Window App"); saveIcons.Add("maximize");    saveDescs.Add("Save under the Window App category.");
        saveCats.Add("WebView");    saveIcons.Add("folder");      saveDescs.Add("Save under the WebView category.");
        saveCats.Add("Server");     saveIcons.Add("arrow-right"); saveDescs.Add("Save under the Server category.");
        saveCats.Add("Custom");     saveIcons.Add("file");        saveDescs.Add("Save under the Custom category.");

        // ---- Find/Replace & GoToLine state ----
        int findMode = 0;    // 0=hidden, 1=find, 2=replace, 3=gotoLine
        string findText = "";
        string replText = "";
        string gotoText = "";
        int findMatch = -1;   // line of current match

        // ---- Publish dialog state ----
        // pubSel holds a 0/1 flag per platform, parallel to the id list in
        // PlatformCsv (windows-x64, windows-arm64, linux-x64, linux-arm64,
        // macos-x64, macos-arm64). Non-Windows targets are locked on Windows.
        bool pubOpen = false;
        List<int> pubSel = new List<int>();

        // Pending "go to definition" jump, applied after the target tab loads.
        int pendingGotoLine = 0 - 1;
        int pendingGotoCol = 0;

        // ---- Output console text selection (drag to select, right-click copy) ----
        // Anchor/head positions are absolute (row = index into `log`, col = char).
        int coSelDrag = 0;
        int coSelA = 0 - 1;
        int coSelAc = 0;
        int coSelB = 0 - 1;
        int coSelBc = 0;

        // ---- Debug state ----
        int dbgState = 0;
        int dbgExecLine = -1;
        List<string> dbgConsole = new List<string>();
        List<string> dbgVarInfo = new List<string>();
        List<string> dbgStack = new List<string>();
        int dbgPanelTab = 0;

        // ---- Designer state ----
        bool designerMode = false;
        List<string> dNames = new List<string>();
        List<int> dX = new List<int>();
        List<int> dY = new List<int>();
        List<int> dW = new List<int>();
        List<int> dH = new List<int>();
        List<string> dTypes = new List<string>();
        List<string> dProps = new List<string>();
        List<string> dEvents = new List<string>();
        SignalInt dSel = SignalInt.Create(-1);
        SignalInt dDragMode = SignalInt.Create(0);  // 0=idle 1=move 2=resize
        SignalInt dDragOffX = SignalInt.Create(0);
        SignalInt dDragOffY = SignalInt.Create(0);
        SignalInt dResizeH = SignalInt.Create(0);   // resize handle 0-7

        SignalInt treeW = SignalInt.Create(IdeDemo.CfgClamp(IdeDemo.CfgInt(cfg, "treeW", 240), 120, 900));
        // The code editor is the primary area: it fills the space left over
        // after the bottom output panel, so it grows with the window instead of
        // being pinned to a fixed height that leaves a huge output pane. We
        // persist the compact OUTPUT height; `editorAreaH` is recomputed from it
        // each frame and only used to drive the resize handle.
        SignalInt bottomPanelH = SignalInt.Create(IdeDemo.CfgClamp(IdeDemo.CfgInt(cfg, "bottomH", 190), 70, 2000));
        SignalInt editorAreaH = SignalInt.Create(430);
        // Bottom panel active tab: 0 = Output, 1 = Error List.
        SignalInt bottomTab = SignalInt.Create(IdeDemo.CfgClamp(IdeDemo.CfgInt(cfg, "bottomTab", 0), 0, 1));
        // Hot reload: when ON, saving rebuilds and restarts the running app.
        bool autoRun = IdeDemo.CfgInt(cfg, "autoRun", 0) == 1;
        // Designer live-preview toggle (0 = design view, 1 = clean preview).
        SignalInt dPreview = SignalInt.Create(0);
        SignalInt treeSel = SignalInt.Create(-1);
        int lastTreeSel = -1;

        // Vertical scroll offsets for the sidebar sections, so long lists stay
        // inside their region (EXPLORER in pixels, COMPONENTS/EXAMPLES in rows).
        SignalInt treeScrollY = SignalInt.Create(0);

        // Examples panel is a collapsible tree (categories -> sample leaves).
        List<TreeNode> exTree = IdeDemo.BuildExampleTree();
        SignalInt exSel = SignalInt.Create(-1);
        int lastExSel = -1;
        SignalInt exTreeScrollY = SignalInt.Create(0);

        int lastPresent = 0;
        while (app.isRunning) {
            // One shared event pump drives BOTH the main window and any open
            // wizard child window. Poll (to keep animating) when either needs a
            // repaint; otherwise block until the OS delivers an event.
            bool want = app.needsRedraw;
            if (dlg != null) {
                if (dlg.needsRedraw) { want = true; }
            }
            int r;
            if (want) {
                int since = Window.GetTickMs() - lastPresent;
                if (lastPresent > 0 && since < 16) { Window.SleepMs(16 - since); }
                r = app.window.PollEvent();
            } else {
                r = app.window.WaitEvent();
            }
            if (r < 0) { break; }

            int evh = Window.EventHwnd();
            int kind = app.window.EventKind();

            if (kind == 8) {
                // Close: only the main window quits the app; a wizard window that
                // closes simply dismisses the wizard.
                if (evh == app.WindowHandle()) { break; }
                dlg = null;
                dlgMode = 0;
                app.RequestRedraw();
            } else {
                app.ApplyEvent(evh);
                if (dlg != null) { dlg.ApplyEvent(evh); }
            }

            // The form designer is bound to .zform tabs (C#-style form files):
            // the active tab's extension decides whether the designer or the code
            // editor is shown, rather than a global toggle.
            int actDM = activeTab.Get();
            if (actDM >= 0 && actDM < tabPaths.Count) {
                designerMode = IdeDemo.IsFormPath(tabPaths[actDM]);
            } else {
                designerMode = false;
            }

            // ---- keyboard shortcuts for debug ----
            if (kind == 5) {
                int kc = app.window.EventKey();
                if (kc == 116 && dbgState == 0) {
                    // F5 = Start Debug (same as clicking Debug button)
                    List<int> bpF5 = editor.Breakpoints();
                    if (bpF5.Count > 0) {
                        dbgExecLine = IdeDemo.FindFirstBp(bpF5);
                        dbgState = 2;
                        editor.SetExecLine(dbgExecLine);
                        dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                        dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                        dbgPanelTab = 1;
                        log.Add("> [Debug] Started. Paused at line " + Convert.ToString(dbgExecLine + 1));
                        IdeDemo.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                    } else {
                        log.Add("> [Debug] No breakpoints set.");
                    }
                    app.RequestRedraw();
                } else if (kc == 116 && dbgState == 2) {
                    // F5 = Continue to next breakpoint
                    List<int> bpF5c = editor.Breakpoints();
                    int nBpF5 = IdeDemo.FindNextBp(bpF5c, dbgExecLine);
                    if (nBpF5 >= 0) {
                        dbgExecLine = nBpF5;
                        editor.SetExecLine(dbgExecLine);
                        dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                        dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                        log.Add("> [Debug] Continue -> line " + Convert.ToString(dbgExecLine + 1));
                        IdeDemo.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                    } else {
                        log.Add("> [Debug] Finished.");
                        dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                    }
                    app.RequestRedraw();
                } else if (kc == 121 && dbgState == 2) {
                    // F10 = Step Over
                    dbgExecLine = dbgExecLine + 1;
                    if (dbgExecLine >= editor.LineCount()) {
                        dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                        log.Add("> [Debug] Finished (end).");
                    } else {
                        editor.SetExecLine(dbgExecLine);
                        dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                        dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                        log.Add("> [Debug] Step -> line " + Convert.ToString(dbgExecLine + 1));
                        IdeDemo.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                    }
                    app.RequestRedraw();
                } else if (kc == 122 && dbgState == 2) {
                    // F11 = Step Into
                    dbgExecLine = dbgExecLine + 1;
                    if (dbgExecLine >= editor.LineCount()) {
                        dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                    } else {
                        editor.SetExecLine(dbgExecLine);
                        dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                        dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                    }
                    app.RequestRedraw();
                } else if (kc == 27 && dbgState == 2) {
                    // Escape = Stop debugging
                    dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                    log.Add("> [Debug] Stopped.");
                    app.RequestRedraw();
                } else if (kc == 27 && findMode > 0) {
                    // Escape = close find/replace/goto
                    findMode = 0;
                    app.RequestRedraw();
                } else if (kc == 27 && pubOpen) {
                    // Escape = close publish dialog
                    pubOpen = false;
                    app.RequestRedraw();
                } else if (kc == 123 && !designerMode && dbgState == 0) {
                    // F12 = Go to Definition
                    int gl12 = IdeDemo.GoToDefinition(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    if (gl12 >= 0) { pendingGotoLine = gl12; pendingGotoCol = 0; lastActive = 0 - 1; }
                    app.RequestRedraw();
                } else if (kc == 118 && !designerMode && dbgState == 0) {
                    // F7 = View Designer: open the .zform paired with this code-behind.
                    int actF7 = activeTab.Get();
                    if (actF7 >= 0 && actF7 < tabPaths.Count) {
                        string ap7 = tabPaths[actF7];
                        if (ap7.Length > 4 && ap7.Substring(ap7.Length - 4, 4) == ".zan") {
                            string cand7 = ap7.Substring(0, ap7.Length - 4) + ".zform";
                            if (File.Exists(cand7)) {
                                int ci7 = IdeDemo.FindTabByPath(tabPaths, cand7);
                                if (ci7 >= 0) { activeTab.Set(ci7); }
                                else { IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, activeTab, cand7, Path.GetFileName(cand7)); }
                                loadedFormPath = "";
                                lastActive = 0 - 1;
                            } else {
                                log.Add("> No paired .zform for " + Path.GetFileName(ap7) + ".");
                            }
                        }
                    }
                    app.RequestRedraw();
                }
            }
            // Ctrl+key via WM_CHAR (kind == 6)
            if (kind == 6) {
                int cc = app.window.EventKeyCode();
                if (cc == 6) {
                    // Ctrl+F = Find
                    findMode = 1;
                    app.RequestRedraw();
                } else if (cc == 7) {
                    // Ctrl+G = Go to Line
                    findMode = 3;
                    gotoText = "";
                    app.RequestRedraw();
                } else if (cc == 18) {
                    // Ctrl+R = Replace (Ctrl+H is 8 which conflicts with Backspace)
                    findMode = 2;
                    app.RequestRedraw();
                } else if (cc == 19) {
                    // Ctrl+S = Save (+ hot reload when enabled)
                    int aSv = activeTab.Get();
                    if (!designerMode && aSv >= 0 && aSv < tabPaths.Count && tabPaths[aSv] != "@start") {
                        IdeDemo.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        if (autoRun) { IdeDemo.HotReloadRun(tabPaths, activeTab, root, log); }
                        rescan = true;
                    }
                    app.RequestRedraw();
                }
            }

            // ---------------- main IDE window ----------------
            if (app.needsRedraw) {
                app.BeginFrame();
                Canvas c = app.canvas;
                Theme t = app.theme;
                int W = c.Width();
                int H = c.Height();
                savedW = W; savedH = H;
                int top = app.titlebarH;
                int ribbonH = Ribbon.Height(app);
                int sbH = app.Scale(22);

                int rc = Ribbon.Render(app, 0, top, W, ribbonH, cmds);
                if (rc == 0) {
                    // Rebuild the catalog (built-ins + custom templates on disk).
                    tpls = IdeDemo.BuildCatalog(root);
                    tCats = new List<string>();
                    tNames = new List<string>();
                    tIcons = new List<string>();
                    tDescs = new List<string>();
                    IdeDemo.SplitTemplates(tpls, tCats, tNames, tIcons, tDescs);
                    catSel.Set(0);
                    pSel.Set(0);
                    pNameInput.SetText("NewProject");
                    pLocInput.SetText(Path.GetDirectoryName(root));
                    dlg = App.CreateDark("New Project", 900, 640);
                    dlg.Show();
                    dlgMode = 1;
                } else if (rc == 1) {
                    dlg = IdeDemo.OpenWizard("New File", fSel, fNameInput, "NewFile");
                    dlgMode = 2;
                } else if (rc == 2) {
                    log.Add("> Open: click a file in the Explorer to open it.");
                    rescan = true;
                } else if (rc == 3) {
                    IdeDemo.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    if (autoRun) { IdeDemo.HotReloadRun(tabPaths, activeTab, root, log); }
                    rescan = true;
                } else if (rc == 4) {
                    IdeDemo.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    IdeDemo.RunActive(tabPaths, activeTab, root, log);
                } else if (rc == 5) {
                    IdeDemo.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    IdeDemo.BuildActive(tabPaths, activeTab, root, log);
                } else if (rc == 6) {
                    IdeDemo.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    pubSel = IdeDemo.ReadProjectPlatforms(root);
                    pubOpen = true;
                    app.RequestRedraw();
                } else if (rc == 7) {
                    // Debug (F5)
                    designerMode = false;
                    if (dbgState == 0) {
                        List<int> bpList = editor.Breakpoints();
                        if (bpList.Count > 0) {
                            dbgExecLine = IdeDemo.FindFirstBp(bpList);
                            dbgState = 2;
                            editor.SetExecLine(dbgExecLine);
                            dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                            dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                            dbgPanelTab = 1;
                            log.Add("> [Debug] Started. Paused at line " + Convert.ToString(dbgExecLine + 1));
                            log.Add(">   F5=Continue  F10=StepOver  F11=StepInto  Esc=Stop");
                        } else {
                            log.Add("> [Debug] No breakpoints set. Click the line number margin to add breakpoints.");
                        }
                    } else if (dbgState == 2) {
                        List<int> bpList2 = editor.Breakpoints();
                        int nBp = IdeDemo.FindNextBp(bpList2, dbgExecLine);
                        if (nBp >= 0) {
                            dbgExecLine = nBp;
                            editor.SetExecLine(dbgExecLine);
                            dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                            dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                            log.Add("> [Debug] Continue -> line " + Convert.ToString(dbgExecLine + 1));
                        } else {
                            log.Add("> [Debug] Finished. No more breakpoints.");
                            dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                        }
                    }
                } else if (rc == 8) {
                    tmplCatSel.Set(5);
                    tmplNameInput.SetText(Path.GetFileName(root));
                    dlg = App.CreateDark("Save as Template", 640, 470);
                    dlg.Show();
                    dlgMode = 3;
                } else if (rc == 9) {
                    // Open the form designer (C#-style .zform files). If a code-behind
                    // is active, open its sibling .zform; otherwise open/create Form1.zform.
                    int actR = activeTab.Get();
                    string formP = "";
                    if (actR >= 0 && actR < tabPaths.Count) {
                        string ap = tabPaths[actR];
                        if (IdeDemo.IsFormPath(ap)) {
                            formP = ap;
                        } else if (ap.Length > 4 && ap.Substring(ap.Length - 4, 4) == ".zan") {
                            string cand = ap.Substring(0, ap.Length - 4) + ".zform";
                            if (File.Exists(cand)) { formP = cand; }
                        }
                    }
                    if (formP == "") {
                        formP = root + "/src/Form1.zform";
                        Directory.CreateDirectory(root + "/src");
                        if (!File.Exists(formP)) {
                            File.WriteAllText(formP,
                                "# Zan Form Design File\n# Visual layout for Form1; edit in the IDE form designer.\n# Application logic lives in the code-behind file Form1.zan\nform Form1\n");
                        }
                    }
                    int fti = IdeDemo.FindTabByPath(tabPaths, formP);
                    if (fti >= 0) {
                        activeTab.Set(fti);
                    } else {
                        IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, activeTab, formP, Path.GetFileName(formP));
                    }
                    loadedFormPath = "";
                    lastActive = 0 - 1;
                    app.RequestRedraw();
                } else if (rc == 10) {
                    // Focus the Start tab, opening one if it was closed.
                    int si = IdeDemo.FindTabByPath(tabPaths, "@start");
                    if (si >= 0) {
                        activeTab.Set(si);
                    } else {
                        tabNames.Add("Start"); tabBodies.Add(""); tabPaths.Add("@start");
                        activeTab.Set(tabNames.Count - 1);
                    }
                    lastActive = 0 - 1;
                    app.RequestRedraw();
                } else if (rc == 11) {
                    autoRun = !autoRun;
                    if (autoRun) { log.Add("> Hot reload: ON (save rebuilds & restarts the app)."); }
                    else { log.Add("> Hot reload: OFF."); }
                    app.RequestRedraw();
                }

                // ---- Debug toolbar (when debugging) ----
                int dbgBarH = 0;
                if (dbgState == 2) {
                    dbgBarH = app.Scale(32);
                    IdeDemo.RenderDebugToolbar(app, c, t, 0, top + ribbonH, W, dbgBarH,
                        dbgExecLine);
                    // Handle debug toolbar button clicks
                    if (app.window.EventKind() == 3 && app.mouseY >= top + ribbonH
                            && app.mouseY < top + ribbonH + dbgBarH) {
                        int btnW = app.Scale(80);
                        int btnX = app.Scale(10);
                        int relX = app.mouseX - btnX;
                        int btnIdx = relX / (btnW + app.Scale(6));
                        if (btnIdx == 0) {
                            // Continue
                            List<int> bpTb = editor.Breakpoints();
                            int nBpTb = IdeDemo.FindNextBp(bpTb, dbgExecLine);
                            if (nBpTb >= 0) {
                                dbgExecLine = nBpTb;
                                editor.SetExecLine(dbgExecLine);
                                dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                                dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                            } else {
                                dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                                log.Add("> [Debug] Finished.");
                            }
                            app.RequestRedraw();
                        } else if (btnIdx == 1) {
                            // Step Over
                            dbgExecLine = dbgExecLine + 1;
                            if (dbgExecLine >= editor.LineCount()) {
                                dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                            } else {
                                editor.SetExecLine(dbgExecLine);
                                dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                                dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                            }
                            app.RequestRedraw();
                        } else if (btnIdx == 2) {
                            // Step Into
                            dbgExecLine = dbgExecLine + 1;
                            if (dbgExecLine >= editor.LineCount()) {
                                dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                            } else {
                                editor.SetExecLine(dbgExecLine);
                                dbgVarInfo = IdeDemo.DebugVarsAt(root, IdeDemo.PathOf(tabPaths, activeTab), editor.GetText(), dbgExecLine, dbgConsole);
                                dbgStack = IdeDemo.BuildStack(tabNames, activeTab, dbgExecLine);
                            }
                            app.RequestRedraw();
                        } else if (btnIdx == 3) {
                            // Stop
                            dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                            log.Add("> [Debug] Stopped.");
                            app.RequestRedraw();
                        }
                    }
                }

                Rect area = Rect.Create(0, top + ribbonH + dbgBarH, W, H - top - ribbonH - dbgBarH - sbH);
                Split cols = Split.Vertical(app, area, treeW, app.Scale(170), app.Scale(440));

                Rect tr = cols.first;
                c.FillRect(tr.x, tr.y, tr.width, tr.height, t.bgTertiary);
                int sectionH = app.Scale(24);
                int explorerH = (tr.height * 55) / 100;
                int exampleH = tr.height - explorerH;

                // Section 1: Explorer
                c.DrawText(tr.x + t.paddingMedium, tr.y + t.paddingSmall, "EXPLORER", t.textTertiary, t.fontSizeSmall);
                Rect treeArea = Rect.Create(tr.x, tr.y + sectionH, tr.width, explorerH - sectionH);
                // Wheel-scroll the tree when the pointer is over it. Scroll in
                // whole-row steps so rows always align to the region top (the
                // renderer only draws rows fully inside the area).
                int treeRowH = TreeView.RowHeight(app);
                int treeVis = treeArea.height / treeRowH;
                if (treeVis < 1) { treeVis = 1; }
                int treeContentH = TreeView.ContentHeight(app, tree);
                int treeMaxScroll = treeContentH - treeVis * treeRowH;
                if (treeMaxScroll < 0) { treeMaxScroll = 0; }
                int tScroll = treeScrollY.Get();
                if (app.window.EventKind() == 13
                    && app.mouseX >= treeArea.x && app.mouseX < treeArea.x + treeArea.width
                    && app.mouseY >= treeArea.y && app.mouseY < treeArea.y + treeArea.height) {
                    int td = app.window.EventKeyCode();
                    int step = td / 120;
                    if (step == 0) {
                        if (td > 0) { step = 1; }
                        else if (td < 0) { step = 0 - 1; }
                    }
                    tScroll = tScroll - step * treeRowH;
                    app.RequestRedraw();
                }
                if (tScroll > treeMaxScroll) { tScroll = treeMaxScroll; }
                if (tScroll < 0) { tScroll = 0; }
                treeScrollY.Set(tScroll);
                int trRight = TreeView.Render(app, treeArea, tree, treeSel, tScroll);
                if (trRight >= 0) {
                    ctxKind = 1; ctxX = app.mouseX; ctxY = app.mouseY;
                    ctxTarget = trRight; app.RequestRedraw();
                }

                // Section 2: Examples (collapsible tree, click a leaf to open)
                int exY = tr.y + explorerH;
                c.FillRect(tr.x, exY, tr.width, 1, t.divider);
                c.DrawText(tr.x + t.paddingMedium, exY + t.paddingSmall, "EXAMPLES", t.textTertiary, t.fontSizeSmall);
                Rect exArea = Rect.Create(tr.x, exY + sectionH, tr.width, exampleH - sectionH);
                int exRowH = TreeView.RowHeight(app);
                int exVis = exArea.height / exRowH;
                if (exVis < 1) { exVis = 1; }
                int exContentH = TreeView.ContentHeight(app, exTree);
                int exMaxScroll = exContentH - exVis * exRowH;
                if (exMaxScroll < 0) { exMaxScroll = 0; }
                int exSc = exTreeScrollY.Get();
                if (app.window.EventKind() == 13
                    && app.mouseX >= exArea.x && app.mouseX < exArea.x + exArea.width
                    && app.mouseY >= exArea.y && app.mouseY < exArea.y + exArea.height) {
                    int exd = app.window.EventKeyCode();
                    int exstep = exd / 120;
                    if (exstep == 0) {
                        if (exd > 0) { exstep = 1; }
                        else if (exd < 0) { exstep = 0 - 1; }
                    }
                    exSc = exSc - exstep * exRowH;
                    app.RequestRedraw();
                }
                if (exSc > exMaxScroll) { exSc = exMaxScroll; }
                if (exSc < 0) { exSc = 0; }
                exTreeScrollY.Set(exSc);
                TreeView.Render(app, exArea, exTree, exSel, exSc);

                int sel = treeSel.Get();
                if (sel != lastTreeSel) {
                    lastTreeSel = sel;
                    if (ctxKind == 0 && sel >= 0 && sel < tree.Count) {
                        TreeNode node = tree[sel];
                        if (!node.isDir) {
                            IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, activeTab, node.path, node.label);
                            log.Add("> Opened " + node.path + ".");
                        }
                    }
                }

                // Open an example when its tree leaf is clicked.
                int exSelV = exSel.Get();
                if (exSelV != lastExSel) {
                    lastExSel = exSelV;
                    if (exSelV >= 0 && exSelV < exTree.Count) {
                        TreeNode en = exTree[exSelV];
                        if (!en.isDir && en.path.Length > 4) {
                            int eidx = IdeDemo.ParseInt(en.path.Substring(4, en.path.Length - 4));
                            string eCode = IdeDemo.GetExampleCode(eidx);
                            string eName = IdeDemo.GetExampleName(eidx);
                            if (eCode.Length > 0) {
                                IdeDemo.OpenNewTab(tabNames, tabBodies, tabPaths, activeTab, eName, eCode);
                                lastActive = 0 - 1;
                                log.Add("> Opened example: " + eName);
                                app.RequestRedraw();
                            }
                        }
                    }
                }

                int bottomMin = app.Scale(90);
                if (dbgState == 2) { bottomMin = app.Scale(160); }
                int editorMin = app.Scale(140);
                int splitHandleH = 5;
                // Editor fills everything above the (compact) output panel.
                int wantEditorH = cols.second.height - bottomPanelH.Get() - splitHandleH;
                if (wantEditorH < editorMin) { wantEditorH = editorMin; }
                editorAreaH.Set(wantEditorH);
                Split rows = Split.Horizontal(app, cols.second, editorAreaH, editorMin, bottomMin);
                Rect ea = rows.first;
                // Persist the resulting output height (not the editor height) so
                // resizing the window keeps the editor as the dominant area.
                int newBottomH = cols.second.height - editorAreaH.Get() - splitHandleH;
                if (newBottomH < bottomMin) { newBottomH = bottomMin; }
                bottomPanelH.Set(newBottomH);

                int tabH = TabView.Height(app);
                TabHit hit = TabView.Render(app, ea.x, ea.y, ea.width, tabH, tabNames, activeTab, true);
                if (hit.action == 4) {
                    ctxKind = 3; ctxX = app.mouseX; ctxY = app.mouseY;
                    ctxTarget = hit.index; app.RequestRedraw();
                } else if (ctxKind == 0) {
                    if (hit.action == 3) {
                        dlg = IdeDemo.OpenWizard("New File", fSel, fNameInput, "NewFile");
                        dlgMode = 2;
                    } else if (hit.action == 2) {
                        if (tabNames.Count > 1) {
                            tabNames.RemoveAt(hit.index);
                            tabBodies.RemoveAt(hit.index);
                            tabPaths.RemoveAt(hit.index);
                            int a = activeTab.Get();
                            if (a > hit.index) { a = a - 1; }
                            if (a >= tabNames.Count) { a = tabNames.Count - 1; }
                            if (a < 0) { a = 0; }
                            activeTab.Set(a);
                            lastActive = 0 - 1;
                        }
                    } else if (hit.action == 1) {
                        activeTab.Set(hit.index);
                    }
                }

                int act = activeTab.Get();
                if (act != lastActive) {
                    // Only sync editor text for code tabs; .zform tabs are owned by
                    // the designer and must not be overwritten with editor contents.
                    if (lastActive >= 0 && lastActive < tabBodies.Count
                        && !IdeDemo.IsFormPath(tabPaths[lastActive])) {
                        tabBodies[lastActive] = editor.GetText();
                    }
                    if (act >= 0 && act < tabBodies.Count
                        && !IdeDemo.IsFormPath(tabPaths[act])) {
                        editor.LoadText(tabBodies[act]);
                        // Feed the other open source files to the editor so it can
                        // resolve cross-file types (e.g. a `Utils` class defined
                        // in another tab) for accurate completion.
                        List<string> projFiles = new List<string>();
                        int pf = 0;
                        while (pf < tabBodies.Count) {
                            if (pf != act && pf < tabPaths.Count
                                && !IdeDemo.IsFormPath(tabPaths[pf])
                                && tabPaths[pf] != "@start") {
                                projFiles.Add(tabBodies[pf]);
                            }
                            pf = pf + 1;
                        }
                        editor.SetProjectFiles(projFiles);
                    }
                    lastActive = act;
                }

                if (pendingGotoLine >= 0) {
                    editor.GoToLineCol(pendingGotoLine, pendingGotoCol);
                    pendingGotoLine = 0 - 1;
                    app.RequestRedraw();
                }

                Rect edRect = Rect.Create(ea.x, ea.y + tabH, ea.width, ea.height - tabH);
                bool activeIsStart = (act >= 0 && act < tabPaths.Count && tabPaths[act] == "@start");
                if (designerMode) {
                    // Bind the designer to the active .zform tab. On first display of
                    // a form (path change) load its controls from the tab body.
                    string fpath = tabPaths[act];
                    string fname = IdeDemo.FormBaseName(fpath);
                    if (fpath != loadedFormPath) {
                        IdeDemo.ParseForm(tabBodies[act], dNames, dTypes, dX, dY, dW, dH);
                        dSel.Set(0 - 1);
                        loadedFormPath = fpath;
                        formCache = tabBodies[act];
                    }
                    int dact = IdeDemo.RenderDesigner(app, c, t, edRect, dNames, dX, dY, dW, dH, dTypes,
                        dSel, dDragMode, dDragOffX, dDragOffY, dResizeH, dPreview);
                    // Persist any layout change back to the tab body and the .zform file.
                    string newser = IdeDemo.SerializeForm(fname, dNames, dTypes, dX, dY, dW, dH);
                    if (newser != formCache) {
                        tabBodies[act] = newser;
                        if (fpath.Length > 0 && fpath.Substring(0, 1) != "@") {
                            File.WriteAllText(fpath, newser);
                        }
                        formCache = newser;
                    }
                    if (dact == 1) {
                        // "View Code": open the code-behind, generating/refreshing its
                        // designer region from the current layout.
                        string cbp = IdeDemo.CodeBehindPath(fpath);
                        string cbtext = "";
                        if (File.Exists(cbp)) {
                            cbtext = IdeDemo.RegenerateCodeBehind(File.ReadAllText(cbp), fname,
                                dNames, dTypes, dX, dY, dW, dH);
                        } else {
                            cbtext = IdeDemo.BuildCodeBehind(fname, dNames, dTypes, dX, dY, dW, dH);
                        }
                        File.WriteAllText(cbp, cbtext);
                        int cbi = IdeDemo.FindTabByPath(tabPaths, cbp);
                        if (cbi >= 0) {
                            tabBodies[cbi] = cbtext;
                            activeTab.Set(cbi);
                        } else {
                            IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, activeTab, cbp, Path.GetFileName(cbp));
                        }
                        lastActive = 0 - 1;
                        log.Add("> Code-behind -> " + cbp + " (design region regenerated).");
                        app.RequestRedraw();
                    }
                } else if (activeIsStart) {
                    List<string> spFiles = IdeDemo.ListZanFiles(root + "/src");
                    int sact = IdeDemo.RenderStartPage(app, c, t, edRect, spFiles);
                    if (sact == 1) {
                        tpls = IdeDemo.BuildCatalog(root);
                        tCats = new List<string>();
                        tNames = new List<string>();
                        tIcons = new List<string>();
                        tDescs = new List<string>();
                        IdeDemo.SplitTemplates(tpls, tCats, tNames, tIcons, tDescs);
                        catSel.Set(0);
                        pSel.Set(0);
                        pNameInput.SetText("NewProject");
                        pLocInput.SetText(Path.GetDirectoryName(root));
                        dlg = App.CreateDark("New Project", 900, 640);
                        dlg.Show();
                        dlgMode = 1;
                        app.RequestRedraw();
                    } else if (sact == 2) {
                        dlg = IdeDemo.OpenWizard("New File", fSel, fNameInput, "NewFile");
                        dlgMode = 2;
                        app.RequestRedraw();
                    } else if (sact >= 100) {
                        int fidx = sact - 100;
                        if (fidx >= 0 && fidx < spFiles.Count) {
                            IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, activeTab,
                                spFiles[fidx], Path.GetFileName(spFiles[fidx]));
                            lastActive = 0 - 1;
                            app.RequestRedraw();
                        }
                    }
                } else {
                    // Sync debug vars into editor for hover tooltips
                    if (dbgState == 2) { editor.SetDebugVars(dbgVarInfo); }
                    else { editor.SetDebugVars(new List<string>()); }
                    editor.Render(app, edRect);
                    // Ctrl+click in the editor requests Go to Definition.
                    if (editor.ConsumeGotoRequest()) {
                        int glc = IdeDemo.GoToDefinition(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        if (glc >= 0) { pendingGotoLine = glc; pendingGotoCol = 0; lastActive = 0 - 1; }
                        app.RequestRedraw();
                    }
                    // Draw inline debug annotations
                    if (dbgState == 2 && dbgExecLine >= 0) {
                        IdeDemo.RenderInlineVars(app, c, t, edRect, dbgVarInfo, dbgExecLine);
                    }
                }

                // ---- Find / Replace / GoToLine overlay ----
                if (findMode > 0 && !designerMode && !activeIsStart) {
                    int fpH = app.Scale(36);
                    if (findMode == 2) { fpH = app.Scale(68); }
                    int fpW = app.Scale(360);
                    int fpX = edRect.x + edRect.width - fpW - app.Scale(8);
                    int fpY = edRect.y + app.Scale(4);
                    c.FillRoundRect(fpX, fpY, fpW, fpH, app.Scale(4), 0xFF252526);
                    c.DrawRect(fpX, fpY, fpW, fpH, t.borderPrimary, 1);
                    int inpX = fpX + app.Scale(8);
                    int inpY = fpY + app.Scale(8);
                    int inpW = fpW - app.Scale(100);
                    int inpH = app.Scale(22);
                    if (findMode == 1) {
                        c.DrawText(fpX + app.Scale(4), fpY + app.Scale(2), "Find (Ctrl+F)", 0xFF888888, t.fontSizeSmall);
                        c.FillRect(inpX, inpY, inpW, inpH, 0xFF1E1E1E);
                        c.DrawRect(inpX, inpY, inpW, inpH, 0xFF3E3E42, 1);
                        c.DrawText(inpX + app.Scale(4), inpY + app.Scale(4), findText, 0xFFCCCCCC, t.fontSizeSmall);
                        // Find/Next buttons
                        int btnX = inpX + inpW + app.Scale(6);
                        c.FillRoundRect(btnX, inpY, app.Scale(36), inpH, app.Scale(3), 0xFF0E639C);
                        c.DrawText(btnX + app.Scale(6), inpY + app.Scale(4), "Find", 0xFFFFFFFF, t.fontSizeSmall);
                        int btn2X = btnX + app.Scale(42);
                        c.FillRoundRect(btn2X, inpY, app.Scale(36), inpH, app.Scale(3), 0xFF555555);
                        c.DrawText(btn2X + app.Scale(4), inpY + app.Scale(4), "Next", 0xFFCCCCCC, t.fontSizeSmall);
                        // Handle key input into find box
                        if (kind == 6) {
                            int fcc = app.window.EventKeyCode();
                            if (fcc == 8 && findText.Length > 0) {
                                findText = findText.Substring(0, findText.Length - 1);
                                app.RequestRedraw();
                            } else if (fcc == 13) {
                                findMatch = IdeDemo.FindInEditor(editor, findText, findMatch);
                                app.RequestRedraw();
                            } else if (fcc > 31) {
                                findText = findText + Text.CharStr(fcc);
                                app.RequestRedraw();
                            }
                        }
                        // Click Find/Next buttons
                        if (app.window.EventKind() == 3) {
                            if (app.mouseX >= btnX && app.mouseX < btn2X && app.mouseY >= inpY && app.mouseY < inpY + inpH) {
                                findMatch = IdeDemo.FindInEditor(editor, findText, -1);
                                app.RequestRedraw();
                            }
                            if (app.mouseX >= btn2X && app.mouseX < btn2X + app.Scale(36) && app.mouseY >= inpY && app.mouseY < inpY + inpH) {
                                findMatch = IdeDemo.FindInEditor(editor, findText, findMatch);
                                app.RequestRedraw();
                            }
                        }
                    } else if (findMode == 2) {
                        c.DrawText(fpX + app.Scale(4), fpY + app.Scale(2), "Replace (Ctrl+R)", 0xFF888888, t.fontSizeSmall);
                        c.FillRect(inpX, inpY, inpW, inpH, 0xFF1E1E1E);
                        c.DrawRect(inpX, inpY, inpW, inpH, 0xFF3E3E42, 1);
                        c.DrawText(inpX + app.Scale(4), inpY + app.Scale(4), findText, 0xFFCCCCCC, t.fontSizeSmall);
                        int row2Y = inpY + inpH + app.Scale(6);
                        c.FillRect(inpX, row2Y, inpW, inpH, 0xFF1E1E1E);
                        c.DrawRect(inpX, row2Y, inpW, inpH, 0xFF3E3E42, 1);
                        c.DrawText(inpX + app.Scale(4), row2Y + app.Scale(4), replText, 0xFFCCCCCC, t.fontSizeSmall);
                        int rbX = inpX + inpW + app.Scale(6);
                        c.FillRoundRect(rbX, inpY, app.Scale(70), inpH, app.Scale(3), 0xFF0E639C);
                        c.DrawText(rbX + app.Scale(6), inpY + app.Scale(4), "Replace", 0xFFFFFFFF, t.fontSizeSmall);
                        c.FillRoundRect(rbX, row2Y, app.Scale(70), inpH, app.Scale(3), 0xFF555555);
                        c.DrawText(rbX + app.Scale(4), row2Y + app.Scale(4), "Repl All", 0xFFCCCCCC, t.fontSizeSmall);
                    } else if (findMode == 3) {
                        c.DrawText(fpX + app.Scale(4), fpY + app.Scale(2), "Go to Line (Ctrl+G)", 0xFF888888, t.fontSizeSmall);
                        c.FillRect(inpX, inpY, inpW, inpH, 0xFF1E1E1E);
                        c.DrawRect(inpX, inpY, inpW, inpH, 0xFF3E3E42, 1);
                        c.DrawText(inpX + app.Scale(4), inpY + app.Scale(4), gotoText, 0xFFCCCCCC, t.fontSizeSmall);
                        int gbX = inpX + inpW + app.Scale(6);
                        c.FillRoundRect(gbX, inpY, app.Scale(30), inpH, app.Scale(3), 0xFF0E639C);
                        c.DrawText(gbX + app.Scale(6), inpY + app.Scale(4), "Go", 0xFFFFFFFF, t.fontSizeSmall);
                        // Handle key input for goto line
                        if (kind == 6) {
                            int gcc = app.window.EventKeyCode();
                            if (gcc == 8 && gotoText.Length > 0) {
                                gotoText = gotoText.Substring(0, gotoText.Length - 1);
                                app.RequestRedraw();
                            } else if (gcc == 13) {
                                int gLine = IdeDemo.ParseInt(gotoText);
                                if (gLine > 0) { editor.GoToLine(gLine - 1); }
                                findMode = 0;
                                app.RequestRedraw();
                            } else if (gcc >= 48 && gcc <= 57) {
                                gotoText = gotoText + Text.CharStr(gcc);
                                app.RequestRedraw();
                            }
                        }
                        // Click Go button
                        if (app.window.EventKind() == 3 && app.mouseX >= gbX && app.mouseY >= inpY && app.mouseY < inpY + inpH) {
                            int gLine2 = IdeDemo.ParseInt(gotoText);
                            if (gLine2 > 0) { editor.GoToLine(gLine2 - 1); }
                            findMode = 0;
                            app.RequestRedraw();
                        }
                    }
                }

                Rect orr = rows.second;
                if (dbgState == 2) {
                    IdeDemo.RenderDebugBottom(app, c, t, orr, dbgPanelTab,
                        dbgConsole, dbgVarInfo, dbgStack, log);
                    // Handle tab clicks
                    if (app.window.EventKind() == 3) {
                        int tabClickW = app.Scale(80);
                        int tabClickY = orr.y;
                        int tabClickH = app.Scale(28);
                        if (app.mouseY >= tabClickY && app.mouseY < tabClickY + tabClickH) {
                            int tabIdx = (app.mouseX - orr.x) / tabClickW;
                            if (tabIdx >= 0 && tabIdx < 4) {
                                dbgPanelTab = tabIdx;
                                app.RequestRedraw();
                            }
                        }
                    }
                } else {
                    int botTab = bottomTab.Get();
                    List<string> ePath = new List<string>();
                    List<string> eLine = new List<string>();
                    List<string> eMsg = new List<string>();
                    IdeDemo.ParseErrorList(log, ePath, eLine, eMsg);
                    IdeDemo.RenderOutputBottom(app, c, t, orr, botTab, log, ePath, eLine, eMsg,
                        coSelA, coSelAc, coSelB, coSelBc);
                    int obTabH = app.Scale(28);
                    // Drag-to-select over the Output console. Register a hit region
                    // so pointer-move events keep repainting while dragging.
                    int coId = app.focus.AllocId();
                    int coContentY = orr.y + obTabH;
                    int coContentH = orr.height - obTabH;
                    app.hitTester.Register(HitRegion.Create(coId, orr.x, coContentY,
                        orr.width, coContentH, 1));
                    if (botTab == 0) {
                        int coRowH = app.Scale(18);
                        int coPad = app.Scale(6);
                        int coTextX = orr.x + coPad;
                        int coMaxRows = coContentH / coRowH;
                        bool coOver = app.mouseX >= orr.x && app.mouseX < orr.x + orr.width
                            && app.mouseY >= coContentY && app.mouseY < coContentY + coContentH;
                        if (app.window.EventKind() == 2 && app.window.EventButton() == 0 && coOver) {
                            int rr = IdeDemo.ConsoleRowAt(app, coContentY, coRowH, coPad,
                                log.Count, coMaxRows, app.mouseY);
                            int cc = 0;
                            if (rr >= 0 && rr < log.Count) {
                                cc = IdeDemo.ConsoleColAt(log[rr], coTextX, t.fontSizeSmall, app.mouseX);
                            }
                            coSelA = rr; coSelAc = cc; coSelB = rr; coSelBc = cc; coSelDrag = 1;
                            app.RequestRedraw();
                        }
                        if (app.window.EventKind() == 1 && coSelDrag == 1) {
                            int rr = IdeDemo.ConsoleRowAt(app, coContentY, coRowH, coPad,
                                log.Count, coMaxRows, app.mouseY);
                            int cc = 0;
                            if (rr >= 0 && rr < log.Count) {
                                cc = IdeDemo.ConsoleColAt(log[rr], coTextX, t.fontSizeSmall, app.mouseX);
                            }
                            coSelB = rr; coSelBc = cc;
                            app.RequestRedraw();
                        }
                        if (app.window.EventKind() == 3 && app.window.EventButton() == 0
                            && coSelDrag == 1) {
                            coSelDrag = 0;
                            app.RequestRedraw();
                        }
                    }
                    if (app.window.EventKind() == 3) {
                        int obTabW = app.Scale(90);
                        if (app.mouseY >= orr.y && app.mouseY < orr.y + obTabH
                            && app.mouseX >= orr.x && app.mouseX < orr.x + obTabW * 2) {
                            int ti = 0;
                            if (app.mouseX >= orr.x + obTabW) { ti = 1; }
                            bottomTab.Set(ti);
                            app.RequestRedraw();
                        } else if (botTab == 1 && app.mouseX >= orr.x && app.mouseX < orr.x + orr.width) {
                            // Click an error row -> jump to its file:line.
                            int rowH = app.Scale(20);
                            int cy0 = orr.y + obTabH + app.Scale(6);
                            if (app.mouseY >= cy0) {
                                int idx = (app.mouseY - cy0) / rowH;
                                if (idx >= 0 && idx < ePath.Count) {
                                    int j = IdeDemo.FindTabByBase(tabPaths, IdeDemo.BaseName(ePath[idx]));
                                    int gl = IdeDemo.ParseInt(eLine[idx]);
                                    if (j >= 0) {
                                        activeTab.Set(j);
                                        lastActive = 0 - 1;
                                        pendingGotoLine = gl - 1;
                                        pendingGotoCol = 0;
                                    }
                                    app.RequestRedraw();
                                }
                            }
                        }
                    }
                    // Right-click the panel to copy the active tab's text.
                    if (app.window.EventKind() == 2 && app.window.EventButton() == 1
                        && app.mouseX >= orr.x && app.mouseX < orr.x + orr.width
                        && app.mouseY >= orr.y && app.mouseY < orr.y + orr.height) {
                        string clip = "";
                        bool haveSel = coSelA >= 0
                            && !(coSelA == coSelB && coSelAc == coSelBc);
                        if (botTab == 0 && haveSel) {
                            clip = IdeDemo.ConsoleSelectionText(log,
                                coSelA, coSelAc, coSelB, coSelBc);
                        } else if (botTab == 0) {
                            int ci = 0;
                            while (ci < log.Count) { clip = clip + log[ci] + "\n"; ci = ci + 1; }
                        } else {
                            int ci = 0;
                            while (ci < ePath.Count) {
                                clip = clip + IdeDemo.BaseName(ePath[ci]) + ":" + eLine[ci]
                                    + "  " + eMsg[ci] + "\n";
                                ci = ci + 1;
                            }
                        }
                        Clipboard.SetText(clip);
                        log.Add("> Copied to clipboard.");
                        app.RequestRedraw();
                    }
                }

                // Status bar
                int sbY = H - sbH;
                c.FillRect(0, sbY, W, sbH, 0xFF007ACC);
                int curLn = editor.CurLine();
                int curCl = editor.CurCol();
                string posInfo = "Ln " + Convert.ToString(curLn + 1) + ", Col " + Convert.ToString(curCl + 1);
                c.DrawText(app.Scale(8), sbY + app.Scale(3), posInfo, 0xFFFFFFFF, t.fontSizeSmall);
                string modeInfo = "Zan";
                if (designerMode) { modeInfo = "Designer"; }
                if (dbgState == 2) { modeInfo = "Debugging"; }
                c.DrawText(W - app.Scale(100), sbY + app.Scale(3), modeInfo, 0xFFFFFFFF, t.fontSizeSmall);
                c.DrawText(W / 2 - app.Scale(40), sbY + app.Scale(3), "UTF-8", 0xFFFFFFFF, t.fontSizeSmall);

                // Top-level editor context menu overlay (drawn last so nothing
                // paints over it), then bridge its host commands.
                if (!designerMode && !activeIsStart) {
                    editor.RenderCtxMenu(app);
                    string ecmd = editor.TakeCommand();
                    if (ecmd == "find") { findMode = 1; app.RequestRedraw(); }
                    else if (ecmd == "gotoline") { findMode = 3; gotoText = ""; app.RequestRedraw(); }
                    else if (ecmd == "gotodef") {
                        int gl = IdeDemo.GoToDefinition(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        if (gl >= 0) { pendingGotoLine = gl; pendingGotoCol = 0; lastActive = 0 - 1; }
                        app.RequestRedraw();
                    } else if (ecmd == "findrefs") {
                        IdeDemo.FindReferences(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        app.RequestRedraw();
                    }
                }
                // File-tree / tab right-click context menus, drawn above the
                // editor overlay. ctxKind: 1 = project tree row, 3 = editor tab.
                if (ctxKind != 0) {
                    List<string> cmLabels = new List<string>();
                    if (ctxKind == 1) {
                        cmLabels.Add("New File");
                        cmLabels.Add("Refresh");
                        cmLabels.Add("-");
                        cmLabels.Add("Copy Path");
                        cmLabels.Add("Reveal in Explorer");
                    } else if (ctxKind == 3) {
                        cmLabels.Add("Close");
                        cmLabels.Add("Close Others");
                        cmLabels.Add("-");
                        cmLabels.Add("Copy Path");
                    }
                    int chosen = IdeDemo.RenderMenu(app, c, t, ctxX, ctxY, cmLabels);
                    if (chosen == 0 - 2) {
                        ctxKind = 0;
                        app.RequestRedraw();
                    } else if (chosen >= 0) {
                        string lbl = cmLabels[chosen];
                        if (ctxKind == 1) {
                            if (lbl == "New File") {
                                dlg = IdeDemo.OpenWizard("New File", fSel, fNameInput, "NewFile");
                                dlgMode = 2;
                            } else if (lbl == "Refresh") {
                                rescan = true;
                            } else if (lbl == "Copy Path") {
                                if (ctxTarget >= 0 && ctxTarget < tree.Count) {
                                    Clipboard.SetText(tree[ctxTarget].path);
                                    log.Add("> Copied path: " + tree[ctxTarget].path);
                                }
                            } else if (lbl == "Reveal in Explorer") {
                                if (ctxTarget >= 0 && ctxTarget < tree.Count) {
                                    IdeDemo.RevealInFileManager(tree[ctxTarget].path);
                                }
                            }
                        } else if (ctxKind == 3) {
                            if (lbl == "Close") {
                                IdeDemo.CloseTabAt(tabNames, tabBodies, tabPaths, activeTab, ctxTarget);
                                lastActive = 0 - 1;
                            } else if (lbl == "Close Others") {
                                IdeDemo.CloseOtherTabs(tabNames, tabBodies, tabPaths, activeTab, ctxTarget);
                                lastActive = 0 - 1;
                            } else if (lbl == "Copy Path") {
                                if (ctxTarget >= 0 && ctxTarget < tabPaths.Count) {
                                    Clipboard.SetText(tabPaths[ctxTarget]);
                                    log.Add("> Copied path: " + tabPaths[ctxTarget]);
                                }
                            }
                        }
                        ctxKind = 0;
                        app.RequestRedraw();
                    }
                }

                // Publish dialog overlay (modal, topmost).
                if (pubOpen) {
                    string pubName = "project";
                    int at = activeTab.Get();
                    if (at >= 0 && at < tabNames.Count) { pubName = tabNames[at]; }
                    int pAct = IdeDemo.RenderPublishDialog(app, pubName, pubSel);
                    if (pAct == 1) {
                        IdeDemo.PublishPlatforms(tabNames, tabPaths, activeTab, root, pubSel, log);
                        pubOpen = false;
                        app.RequestRedraw();
                    } else if (pAct == 2) {
                        pubOpen = false;
                        app.RequestRedraw();
                    }
                }
                app.RenderChrome("Zan IDE  —  " + root);
                app.PresentFrame();
                lastPresent = Window.GetTickMs();
            }

            // ---------------- wizard child window ----------------
            if (dlg != null) {
                if (dlg.needsRedraw) {
                    dlg.BeginFrame();
                    int action = 0;
                    if (dlgMode == 1) {
                        action = Wizard.RenderCategorized(dlg, "New Project", catNames, catSel,
                                                          tCats, tNames, tIcons, tDescs, pSel,
                                                          pNameInput, pLocInput,
                                                          platformNames, platformGroups, platSel);
                    } else if (dlgMode == 3) {
                        action = Wizard.Render(dlg, "Save as Template", saveCats, saveIcons, saveDescs,
                                               tmplCatSel, tmplNameInput, tmplNameInput, false);
                    } else {
                        action = Wizard.Render(dlg, "New File", fNames, fIcons, fDescs, fSel,
                                               fNameInput, fNameInput, false);
                    }
                    dlg.PresentFrame();
                    lastPresent = Window.GetTickMs();

                    if (action == 1) {
                        if (dlgMode == 1) {
                            string parent = pLocInput.GetText();
                            string name = pNameInput.GetText();
                            int gi = pSel.Get();
                            if (gi >= 0 && gi < tpls.Count) {
                                string plats = IdeDemo.PlatformCsv(platSel);
                                string newDir = IdeDemo.CreateProjectT(tpls[gi], parent, name, plats, log);
                                root = newDir;
                                tabNames = new List<string>();
                                tabBodies = new List<string>();
                                tabPaths = new List<string>();
                                activeTab.Set(0);
                                lastActive = 0 - 1;
                                IdeDemo.OpenFirst(tabNames, tabBodies, tabPaths, activeTab, root);
                            }
                        } else if (dlgMode == 3) {
                            string cat = saveCats[tmplCatSel.Get()];
                            string tname = tmplNameInput.GetText();
                            IdeDemo.SaveAsTemplate(root, cat, tname, log);
                        } else {
                            string name = fNameInput.GetText();
                            string p = IdeDemo.CreateFile(fSel.Get(), root, name, log);
                            IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, activeTab, p, Path.GetFileName(p));
                        }
                        rescan = true;
                        dlg.window.Close();
                        dlg = null;
                        dlgMode = 0;
                        app.RequestRedraw();
                    } else if (action == 2) {
                        dlg.window.Close();
                        dlg = null;
                        dlgMode = 0;
                        app.RequestRedraw();
                    }
                }
            }

            if (rescan) {
                rescan = false;
                tree = IdeDemo.ScanTree(root);
                treeSel.Set(-1);
                lastTreeSel = -1;
            }
        }
        // Persist window + panel sizes so the next launch restores them.
        int arv = 0;
        if (autoRun) { arv = 1; }
        IdeDemo.SaveSettings(treeW.Get(), bottomPanelH.Get(), savedW, savedH, bottomTab.Get(), arv);
    }

    /// Spawns a fresh wizard child window (a real draggable top-level window),
    /// resetting the selection and name field, and returns its App.
    static App OpenWizard(string title, SignalInt sel, Input nameInput, string defName) {
        App w = App.CreateDark(title, 720, 470);
        w.Show();
        sel.Set(0);
        nameInput.SetText(defName);
        return w;
    }

    /// Draws a floating context menu at (mx, my) and reports the user's choice
    /// this frame: -1 = nothing yet, -2 = dismissed (clicked outside), or the
    /// index of the chosen label. Entries equal to "-" render as separators.
    static int RenderMenu(App app, Canvas c, Theme t, int mx, int my, List<string> labels) {
        int fontSize = t.fontSizeMedium;
        int itemH = Canvas.FontHeight(fontSize) + app.Scale(8);
        int sepH = app.Scale(7);
        int mW = app.Scale(150);
        int i = 0;
        while (i < labels.Count) {
            if (labels[i] != "-") {
                int lw = Canvas.MeasureText(labels[i], fontSize) + app.Scale(28);
                if (lw > mW) { mW = lw; }
            }
            i = i + 1;
        }
        int mH = app.Scale(6);
        int hi = 0;
        while (hi < labels.Count) {
            if (labels[hi] == "-") { mH = mH + sepH; } else { mH = mH + itemH; }
            hi = hi + 1;
        }

        int winW = c.Width();
        int winH = c.Height();
        if (mx + mW > winW) { mx = winW - mW - app.Scale(4); }
        if (my + mH > winH) { my = winH - mH - app.Scale(4); }
        if (mx < 0) { mx = 0; }
        if (my < app.titlebarH) { my = app.titlebarH; }

        c.FillRoundRect(mx + 2, my + 2, mW, mH, app.Scale(4), 0x50000000);
        c.FillRoundRect(mx, my, mW, mH, app.Scale(4), 0xFF252526);
        c.DrawRect(mx, my, mW, mH, 0xFF3E3E42, 1);

        int ry = my + app.Scale(3);
        int ri = 0;
        while (ri < labels.Count) {
            if (labels[ri] == "-") {
                c.FillRect(mx + app.Scale(6), ry + sepH / 2, mW - app.Scale(12), 1, 0xFF3E3E42);
                ry = ry + sepH;
            } else {
                bool hov = app.mouseX >= mx && app.mouseX < mx + mW
                           && app.mouseY >= ry && app.mouseY < ry + itemH;
                int tcol = 0xFFD4D4D4;
                if (hov) {
                    c.FillRect(mx + app.Scale(2), ry, mW - app.Scale(4), itemH, 0xFF094771);
                    tcol = 0xFFFFFFFF;
                }
                int ty = ry + (itemH - Canvas.FontHeight(fontSize)) / 2;
                c.DrawText(mx + app.Scale(12), ty, labels[ri], tcol, fontSize);
                ry = ry + itemH;
            }
            ri = ri + 1;
        }

        if (app.window.EventKind() == 3 && app.window.EventButton() == 0) {
            bool inside = app.mouseX >= mx && app.mouseX < mx + mW
                          && app.mouseY >= my && app.mouseY < my + mH;
            if (inside) {
                int cy = my + app.Scale(3);
                int ci = 0;
                while (ci < labels.Count) {
                    int rh = itemH;
                    if (labels[ci] == "-") { rh = sepH; }
                    if (labels[ci] != "-" && app.mouseY >= cy && app.mouseY < cy + rh) {
                        return ci;
                    }
                    cy = cy + rh;
                    ci = ci + 1;
                }
                return 0 - 1;
            }
            return 0 - 2;
        }
        return 0 - 1;
    }

    /// Reveals a path in the OS file manager: Explorer (Windows), Finder via
    /// `open -R` (macOS), or the containing directory via `xdg-open` (Linux).
    static void RevealInFileManager(string path) {
        #if WINDOWS
        Process.Run("explorer /select,\"" + IdeDemo.ToWinPath(path) + "\"");
        #elif MACOS
        Process.Run("open -R \"" + path + "\"");
        #else
        Process.Run("xdg-open \"" + IdeDemo.DirOf(path) + "\"");
        #endif
    }

    /// Converts forward slashes to Windows backslashes (for explorer.exe).
    static string ToWinPath(string p) {
        string outp = "";
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "/") { outp = outp + "\\"; } else { outp = outp + ch; }
            i = i + 1;
        }
        return outp;
    }

    /// Closes the tab at `idx`, keeping at least one tab open and clamping the
    /// active index.
    static void CloseTabAt(List<string> names, List<string> bodies,
            List<string> paths, SignalInt active, int idx) {
        if (idx < 0 || idx >= names.Count) { return; }
        if (names.Count <= 1) { return; }
        names.RemoveAt(idx);
        bodies.RemoveAt(idx);
        paths.RemoveAt(idx);
        int a = active.Get();
        if (a > idx) { a = a - 1; }
        if (a >= names.Count) { a = names.Count - 1; }
        if (a < 0) { a = 0; }
        active.Set(a);
    }

    /// Closes every tab except the one at `idx`, which becomes active.
    static void CloseOtherTabs(List<string> names, List<string> bodies,
            List<string> paths, SignalInt active, int idx) {
        if (idx < 0 || idx >= names.Count) { return; }
        int k = names.Count - 1;
        while (k >= 0) {
            if (k != idx) {
                names.RemoveAt(k);
                bodies.RemoveAt(k);
                paths.RemoveAt(k);
            }
            k = k - 1;
        }
        active.Set(0);
    }

    // ---- workspace / scaffolding ----

    static void EnsureWorkspace(string root) {
        if (Directory.Exists(root)) { return; }
        Directory.CreateDirectoryRecursive(root + "/src");
        File.WriteAllText(root + "/src/main.zan",
            "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello, Zan!\");\n        int sum = Utils.Add(2, 3);\n        Console.WriteLine(\"2 + 3 = \" + sum);\n    }\n}\n");
        File.WriteAllText(root + "/src/utils.zan",
            "using System;\n\nclass Utils {\n    static int Add(int a, int b) {\n        return a + b;\n    }\n}\n");
        File.WriteAllText(root + "/README.md",
            "# MyProject\n\nA sample Zan project scaffolded by the Zan IDE.\n");
        File.WriteAllText(root + "/zan.proj",
            "name = MyProject\ntype = console\nentry = src/main.zan\ntarget = exe\n");
    }

    // ---- template catalog ----

    /// The built-in project templates, grouped by category. Category labels here
    /// must match the New Project wizard's category list exactly.
    static List<Tpl> BuiltinTemplates() {
        List<Tpl> ts = new List<Tpl>();
        ts.Add(Tpl.Make("Console", "Hello World", "menu", "console",
            "Minimal console program that prints a line of text."));
        ts.Add(Tpl.Make("Console", "Command-line Args", "menu", "console-args",
            "Console program that reads command-line arguments."));
        ts.Add(Tpl.Make("Console", "Multi-file Project", "copy", "console-multi",
            "Console project split into main + utils source files."));
        ts.Add(Tpl.Make("Library", "Class Library", "grid", "dll-class",
            "A reusable library of classes, compiled to a DLL."));
        ts.Add(Tpl.Make("Library", "Export DLL", "copy", "dll-export",
            "A DLL exposing functions callable from other programs."));
        ts.Add(Tpl.Make("Window App", "Empty Window", "maximize", "gui-empty",
            "A blank window app built on the Gui standard library."));
        ts.Add(Tpl.Make("Window App", "Component Showcase", "grid", "gui-components",
            "A window with panels/toolbars from the Gui components."));
        ts.Add(Tpl.Make("WebView", "WebView Window", "folder", "webview",
            "A window that hosts web content (needs a WebView runtime)."));
        ts.Add(Tpl.Make("Server", "HTTP Server", "arrow-right", "server",
            "A minimal HTTP server skeleton."));
        ts.Add(Tpl.Make("Server", "TCP Echo Server", "refresh", "server-tcp",
            "A minimal TCP echo server skeleton."));
        return ts;
    }

    /// Built-in templates plus any user templates found under root/.templates.
    static List<Tpl> BuildCatalog(string root) {
        List<Tpl> ts = IdeDemo.BuiltinTemplates();
        IdeDemo.LoadCustomTemplates(ts, root);
        return ts;
    }

    /// Projects the catalog into the parallel lists the wizard consumes.
    static void SplitTemplates(List<Tpl> ts, List<string> cats, List<string> names,
                               List<string> icons, List<string> descs) {
        int i = 0;
        while (i < ts.Count) {
            Tpl t = ts[i];
            cats.Add(t.cat);
            names.Add(t.name);
            icons.Add(t.icon);
            descs.Add(t.desc);
            i = i + 1;
        }
    }

    /// Scans root/.templates/<name>/ and appends each as a "Custom" template.
    /// GetDirectories on a missing directory yields an empty list, so no
    /// separate existence check is needed.
    static void LoadCustomTemplates(List<Tpl> ts, string root) {
        string dir = IdeDemo.UserConfigDir() + "/templates";
        List<string> subs = Directory.GetDirectories(dir);
        int i = 0;
        while (i < subs.Count) {
            string tname = subs[i];
            string tdir = dir + "/" + tname;
            string desc = "Custom template.";
            string icon = "file";
            string mpath = tdir + "/manifest.txt";
            if (File.Exists(mpath)) {
                string m = File.ReadAllText(mpath);
                desc = IdeDemo.ManifestField(m, "desc", desc);
                icon = IdeDemo.ManifestField(m, "icon", icon);
            }
            Tpl t = Tpl.Make("Custom", tname, icon, "custom", desc);
            t.src = tdir;
            ts.Add(t);
            i = i + 1;
        }
    }

    /// Reads a "key=value" field from a simple manifest, or returns def.
    /// Scans char-by-char (rather than splitting into a list) to stay robust.
    static string ManifestField(string content, string key, string def) {
        string prefix = key + "=";
        int n = content.Length;
        int pl = prefix.Length;
        int i = 0;
        while (i < n) {
            bool atLineStart = (i == 0) || (content.Substring(i - 1, 1) == "\n");
            if (atLineStart && i + pl <= n && content.Substring(i, pl) == prefix) {
                int j = i + pl;
                string val = "";
                while (j < n) {
                    string ch = content.Substring(j, 1);
                    if (ch == "\n" || ch == "\r") { break; }
                    val = val + ch;
                    j = j + 1;
                }
                return val;
            }
            i = i + 1;
        }
        return def;
    }

    /// Recursively copies a template's files (skipping its manifest) into dst.
    static void CopyTree(string srcDir, string dstDir) {
        Directory.CreateDirectory(dstDir);
        List<string> files = Directory.GetFiles(srcDir);
        int i = 0;
        while (i < files.Count) {
            string fn = files[i];
            if (fn != "manifest.txt") {
                File.WriteAllText(dstDir + "/" + fn, File.ReadAllText(srcDir + "/" + fn));
            }
            i = i + 1;
        }
        List<string> subs = Directory.GetDirectories(srcDir);
        int j = 0;
        while (j < subs.Count) {
            IdeDemo.CopyTree(srcDir + "/" + subs[j], dstDir + "/" + subs[j]);
            j = j + 1;
        }
    }

    /// Saves the current project (its src/ tree + zan.proj) as a reusable custom
    /// template under root/.templates/<tname>/ with a small manifest.
    static void SaveAsTemplate(string root, string cat, string tname, List<string> log) {
        string tdir = IdeDemo.UserConfigDir() + "/templates/" + tname;
        Directory.CreateDirectoryRecursive(tdir);
        if (Directory.Exists(root + "/src")) {
            IdeDemo.CopyTree(root + "/src", tdir + "/src");
        }
        if (File.Exists(root + "/zan.proj")) {
            File.WriteAllText(tdir + "/zan.proj", File.ReadAllText(root + "/zan.proj"));
        }
        File.WriteAllText(tdir + "/manifest.txt",
            "name=" + tname + "\ncategory=" + cat + "\nicon=file\ndesc=Custom template from " + Path.GetFileName(root) + ".\n");
        log.Add("> Saved current project as template '" + tname + "' (" + tdir + ").");
    }

    /// Maps the multi-select platform flags to a comma-separated id list
    /// (e.g. "windows-x64,linux-arm64"); defaults to windows-x64 if none chosen.
    static string PlatformCsv(List<int> flags) {
        List<string> ids = new List<string>();
        ids.Add("windows-x64"); ids.Add("windows-arm64");
        ids.Add("linux-x64"); ids.Add("linux-arm64");
        ids.Add("macos-x64"); ids.Add("macos-arm64");
        string outp = "";
        int i = 0;
        while (i < flags.Count) {
            if (i < ids.Count && flags[i] == 1) {
                if (outp.Length > 0) { outp = outp + ","; }
                outp = outp + ids[i];
            }
            i = i + 1;
        }
        if (outp.Length == 0) { outp = "windows-x64"; }
        return outp;
    }

    /// Scaffolds a new project from a template descriptor; returns its directory.
    /// platforms is a comma-separated target-platform id list written to zan.proj.
    static string CreateProjectT(Tpl tpl, string parent, string name, string platforms, List<string> log) {
        string dir = parent + "/" + name;
        Directory.CreateDirectory(dir);
        Directory.CreateDirectory(dir + "/src");

        string typeName = "console";
        string target = "exe";
        string entry = "src/main.zan";
        string kind = tpl.kind;

        if (kind == "console") {
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.ConsoleTemplate(name));
        } else if (kind == "console-args") {
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.ConsoleArgsTemplate(name));
        } else if (kind == "console-multi") {
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.ConsoleTemplate(name));
            File.WriteAllText(dir + "/src/utils.zan",
                "using System;\n\nclass Utils {\n    static int Add(int a, int b) { return a + b; }\n}\n");
        } else if (kind == "dll-class") {
            typeName = "library"; target = "dll"; entry = "src/lib.zan";
            File.WriteAllText(dir + "/src/lib.zan", IdeDemo.LibraryTemplate(name));
        } else if (kind == "dll-export") {
            typeName = "library"; target = "dll"; entry = "src/lib.zan";
            File.WriteAllText(dir + "/src/lib.zan", IdeDemo.DllExportTemplate(name));
        } else if (kind == "gui-empty") {
            typeName = "gui"; target = "exe";
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.GuiTemplate(name));
        } else if (kind == "gui-components") {
            typeName = "gui"; target = "exe";
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.GuiComponentsTemplate(name));
        } else if (kind == "webview") {
            typeName = "gui"; target = "exe";
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.WebViewTemplate(name));
        } else if (kind == "server") {
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.ServerHttpTemplate(name));
        } else if (kind == "server-tcp") {
            File.WriteAllText(dir + "/src/main.zan", IdeDemo.ServerTcpTemplate(name));
        } else if (kind == "custom") {
            IdeDemo.CopyTree(tpl.src, dir);
        } else {
            typeName = "empty";
        }

        if (!File.Exists(dir + "/README.md")) {
            File.WriteAllText(dir + "/README.md",
                "# " + name + "\n\nGenerated by the Zan IDE (template: " + tpl.name + ").\n");
        }
        if (kind != "custom") {
            File.WriteAllText(dir + "/zan.proj",
                "name = " + name + "\ntype = " + typeName + "\nentry = " + entry
                + "\ntarget = " + target + "\nplatform = " + platforms + "\n");
        }
        log.Add("> Created " + typeName + " project for [" + platforms + "] at " + dir + " (template: " + tpl.name + ").");
        return dir;
    }

    /// Creates a file from the chosen file template; returns the path to open.
    /// For a Form (kind 5) this follows the C#-style rule and creates BOTH the
    /// visual layout file (Name.zform) and its code-behind (Name.zan), returning
    /// the .zform so it opens in the designer.
    static string CreateFile(int kind, string root, string name, List<string> log) {
        Directory.CreateDirectory(root + "/src");
        if (kind == 5) {
            string formPath = root + "/src/" + name + ".zform";
            string cbPath = root + "/src/" + name + ".zan";
            List<string> dNames = new List<string>();
            List<string> dTypes = new List<string>();
            List<int> dX = new List<int>();
            List<int> dY = new List<int>();
            List<int> dW = new List<int>();
            List<int> dH = new List<int>();
            File.WriteAllText(formPath, IdeDemo.SerializeForm(name, dNames, dTypes, dX, dY, dW, dH));
            if (!File.Exists(cbPath)) {
                File.WriteAllText(cbPath, IdeDemo.BuildCodeBehind(name, dNames, dTypes, dX, dY, dW, dH));
            }
            log.Add("> Created form " + formPath + " + code-behind " + cbPath + ".");
            return formPath;
        }
        string path = root + "/src/" + name + ".zan";
        File.WriteAllText(path, IdeDemo.FileTemplateBody(kind, name));
        log.Add("> Created file " + path + ".");
        return path;
    }

    static void OpenFirst(List<string> names, List<string> bodies, List<string> paths, SignalInt active, string root) {
        string main = root + "/src/main.zan";
        string lib = root + "/src/lib.zan";
        if (File.Exists(main)) {
            IdeDemo.OpenPath(names, bodies, paths, active, main, "main.zan");
        } else if (File.Exists(lib)) {
            IdeDemo.OpenPath(names, bodies, paths, active, lib, "lib.zan");
        } else {
            names.Add("README.md");
            bodies.Add(File.ReadAllText(root + "/README.md"));
            paths.Add(root + "/README.md");
            active.Set(0);
        }
    }

    // ---- template bodies ----

    static string ConsoleTemplate(string name) {
        return "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello from " + name + "\");\n    }\n}\n";
    }

    static string GuiTemplate(string name) {
        return "using System;\nusing Gui;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"" + name + "\", 800, 600);\n        app.Show();\n        while (app.isRunning) {\n            if (!app.ProcessEvent()) { break; }\n            if (!app.needsRedraw) { continue; }\n            app.BeginFrame();\n            app.RenderChrome(\"" + name + "\");\n            app.PresentFrame();\n        }\n    }\n}\n";
    }

    static string LibraryTemplate(string name) {
        return "using System;\n\n/// " + name + " library.\nclass " + name + " {\n    static int Version() { return 1; }\n}\n";
    }

    static string ConsoleArgsTemplate(string name) {
        return "using System;\n\nclass Program {\n    static void Main() {\n        // TODO: read and parse command-line arguments here.\n        Console.WriteLine(\"" + name + ": pass arguments on the command line\");\n    }\n}\n";
    }

    static string DllExportTemplate(string name) {
        return "using System;\n\n/// Functions exported from this library for use by other programs.\nclass " + name + " {\n    static int Add(int a, int b) { return a + b; }\n    static int Version() { return 1; }\n}\n";
    }

    static string GuiComponentsTemplate(string name) {
        return "using System;\nusing Gui;\nusing Gui.Widget;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"" + name + "\", 900, 640);\n        app.Show();\n        while (app.isRunning) {\n            if (!app.ProcessEvent()) { break; }\n            if (!app.needsRedraw) { continue; }\n            app.BeginFrame();\n            Canvas c = app.canvas;\n            int w = c.Width();\n            int h = c.Height();\n            int top = app.titlebarH;\n            Rect box = Panel.Section(app, 20, top + 20, w - 40, h - top - 40, \"" + name + "\");\n            c.DrawText(box.x + 12, box.y + 12, \"Build your UI from Gui components here.\", app.theme.textPrimary, app.theme.fontSizeMedium);\n            app.RenderChrome(\"" + name + "\");\n            app.PresentFrame();\n        }\n    }\n}\n";
    }

    static string WebViewTemplate(string name) {
        return "using System;\nusing Gui;\n\n// WebView window skeleton. Hosting real web content needs a WebView2\n// runtime binding; this placeholder window stands in until that lands.\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"" + name + "\", 1000, 700);\n        app.Show();\n        while (app.isRunning) {\n            if (!app.ProcessEvent()) { break; }\n            if (!app.needsRedraw) { continue; }\n            app.BeginFrame();\n            app.RenderChrome(\"WebView: " + name + "\");\n            app.PresentFrame();\n        }\n    }\n}\n";
    }

    static string ServerHttpTemplate(string name) {
        return "using System;\n\n// HTTP server skeleton. Wire in System.Net once its socket API is ready.\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"" + name + " listening on http://localhost:8080\");\n        Console.WriteLine(\"(network binding pending)\");\n    }\n}\n";
    }

    static string ServerTcpTemplate(string name) {
        return "using System;\n\n// TCP echo server skeleton. Wire in System.Net once its socket API is ready.\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"" + name + " TCP echo server on :9000\");\n        Console.WriteLine(\"(network binding pending)\");\n    }\n}\n";
    }

    static string FileTemplateBody(int kind, string name) {
        if (kind == 0) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello from " + name + "\");\n    }\n}\n";
        }
        if (kind == 1) {
            return "using System;\n\nclass " + name + " {\n    // fields and methods\n}\n";
        }
        if (kind == 2) {
            return IdeDemo.GuiTemplate(name);
        }
        if (kind == 3) {
            return "using System;\n\n/// Contract implemented by concrete types.\nclass " + name + " {\n    void Execute() { }\n}\n";
        }
        return "";
    }

    // ---- tree scanning ----

    static List<TreeNode> ScanTree(string root) {
        List<TreeNode> nodes = new List<TreeNode>();
        IdeDemo.ScanInto(nodes, root, "MyProject", 0, true);
        return nodes;
    }

    static void ScanInto(List<TreeNode> nodes, string dirPath, string dirName, int depth, bool expanded) {
        TreeNode d = TreeNode.Dir(dirName, depth, expanded);
        d.path = dirPath;
        nodes.Add(d);
        List<string> subs = Directory.GetDirectories(dirPath);
        int i = 0;
        while (i < subs.Count) {
            IdeDemo.ScanInto(nodes, dirPath + "/" + subs[i], subs[i], depth + 1, false);
            i = i + 1;
        }
        List<string> files = Directory.GetFiles(dirPath);
        int j = 0;
        while (j < files.Count) {
            if (!IdeDemo.EndsWith(files[j], ".proj")) {
                TreeNode f = TreeNode.File(files[j], depth + 1);
                f.path = dirPath + "/" + files[j];
                nodes.Add(f);
            }
            j = j + 1;
        }
    }

    /// True when `s` ends with `suffix` (used to hide project manifests from
    /// the explorer tree).
    static bool EndsWith(string s, string suffix) {
        int sl = s.Length;
        int fl = suffix.Length;
        if (fl > sl) { return false; }
        return s.Substring(sl - fl, fl) == suffix;
    }

    // ---- tabs ----

    static void OpenPath(List<string> names, List<string> bodies, List<string> paths,
                         SignalInt active, string path, string name) {
        int idx = paths.IndexOf(path);
        if (idx >= 0) {
            active.Set(idx);
            return;
        }
        string content = File.ReadAllText(path);
        names.Add(name);
        bodies.Add(content);
        paths.Add(path);
        active.Set(names.Count - 1);
    }

    static void SaveActive(CodeEditor editor, List<string> names, List<string> bodies,
                           List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        if (a < 0 || a >= names.Count) { return; }
        bodies[a] = editor.GetText();
        string p = paths[a];
        if (p == "") {
            p = root + "/" + names[a];
            paths[a] = p;
        }
        File.WriteAllText(p, bodies[a]);
        log.Add("> Saved " + p + ".");
    }

    // ---- toolchain ----

    static void BuildActive(List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        string p = paths[a];
        if (p == "") { log.Add("> Nothing to build (save the file first)."); return; }
        string bd = IdeDemo.EnsureBuildDir(root);
        string ll = bd + "/.zanbuild.ll";
        string inputs = IdeDemo.ProjectInputs(IdeDemo.DirOf(p), p, "");
        string cmd = IdeDemo.ZancCmd() + " --emit-ir " + inputs + " > \"" + ll + "\"";
        log.Add("> Building " + p + " ...");
        List<string> outp = Process.RunCapture(cmd);
        IdeDemo.AppendAll(log, outp);
        if (outp.Count == 0) {
            log.Add("> Build succeeded. 0 errors, 0 warnings.");
        }
    }

    static void RunActive(List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        string p = paths[a];
        if (p == "") { log.Add("> Nothing to run (save the file first)."); return; }
        string bd = IdeDemo.EnsureBuildDir(root);
        string ll = bd + "/.zanrun.ll";
        string exe = bd + "/.zanrun" + IdeDemo.ExeSuffix();
        string z = IdeDemo.ZancCmd();
        string inputs = IdeDemo.ProjectInputs(IdeDemo.DirOf(p), p, "");
        string cmd = z + " --emit-ir " + inputs + " > \"" + ll + "\""
            + " && clang \"" + ll + "\" -o \"" + exe + "\""
            + " && \"" + exe + "\"";
        log.Add("> Running " + p + " ...");
        List<string> outp = Process.RunCapture(cmd);
        IdeDemo.AppendAll(log, outp);
        log.Add("> (run finished)");
    }

    /// Hot reload: rebuild the active file and (re)launch it detached, killing
    /// the previous hot instance so the IDE stays responsive across saves.
    static void HotReloadRun(List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        if (a < 0 || a >= paths.Count) { return; }
        string p = paths[a];
        if (p == "" || p == "@start") { log.Add("> [Hot] Nothing to run (save the file first)."); return; }
        string bd = IdeDemo.EnsureBuildDir(root);
        string ll = bd + "/.zanhot.ll";
        string exe = bd + "/zanhot_run" + IdeDemo.ExeSuffix();
        // Stop the previous hot instance so the exe can be overwritten.
        #if WINDOWS
        Process.Run("taskkill /F /IM zanhot_run.exe >nul 2>nul");
        Process.Run("cmd /c del /f /q \"" + exe + "\" >nul 2>nul");
        #else
        Process.Run("pkill -f zanhot_run >/dev/null 2>&1");
        Process.Run("rm -f \"" + exe + "\" >/dev/null 2>&1");
        #endif
        string z = IdeDemo.ZancCmd();
        string inputs = IdeDemo.ProjectInputs(IdeDemo.DirOf(p), p, "");
        string cmd = z + " --emit-ir " + inputs + " > \"" + ll + "\""
            + " && clang \"" + ll + "\" -o \"" + exe + "\"";
        log.Add("> [Hot] Rebuilding ...");
        List<string> outp = Process.RunCapture(cmd);
        IdeDemo.AppendAll(log, outp);
        if (File.Exists(exe)) {
            // Launch detached so the IDE stays responsive.
            #if WINDOWS
            Process.Run("cmd /c start \"\" \"" + exe + "\"");
            #else
            Process.Run("\"" + exe + "\" >/dev/null 2>&1 &");
            #endif
            log.Add("> [Hot] Reloaded -> restarted app.");
        } else {
            log.Add("> [Hot] Build failed; app not restarted.");
        }
    }

    static void PublishActive(List<string> names, List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        string p = paths[a];
        if (p == "") { log.Add("> Nothing to publish (save the file first)."); return; }
        Directory.CreateDirectory(root + "/publish");
        string bd = IdeDemo.EnsureBuildDir(root);
        string ll = bd + "/.zanpub.ll";
        string exe = root + "/publish/" + names[a] + ".exe";
        string z = IdeDemo.ZancCmd();
        string inputs = IdeDemo.ProjectInputs(IdeDemo.DirOf(p), p, "");
        string cmd = z + " --emit-ir " + inputs + " > \"" + ll + "\""
            + " && clang \"" + ll + "\" -o \"" + exe + "\"";
        log.Add("> Publishing console exe ...");
        List<string> outp = Process.RunCapture(cmd);
        IdeDemo.AppendAll(log, outp);
        log.Add("> Published " + exe);
    }

    /// Naive substring search (the stdlib string type here exposes only
    /// Substring/Length), used to detect platform ids inside zan.proj.
    static bool Has(string hay, string needle) {
        int n = needle.Length;
        int h = hay.Length;
        if (n == 0) { return true; }
        int i = 0;
        while (i + n <= h) {
            if (hay.Substring(i, n) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// Reads the active project's target platforms from zan.proj into 6 flags
    /// parallel to PlatformCsv's id list. Non-Windows targets are force-cleared
    /// because this Windows host cannot produce them without a cross toolchain.
    static List<int> ReadProjectPlatforms(string root) {
        List<int> flags = new List<int>();
        int z = 0;
        while (z < 6) { flags.Add(0); z = z + 1; }
        string content = "";
        string pj = root + "/zan.proj";
        if (File.Exists(pj)) { content = File.ReadAllText(pj); }
        List<string> ids = new List<string>();
        ids.Add("windows-x64"); ids.Add("windows-arm64");
        ids.Add("linux-x64"); ids.Add("linux-arm64");
        ids.Add("macos-x64"); ids.Add("macos-arm64");
        int k = 0;
        while (k < ids.Count) {
            if (IdeDemo.Has(content, ids[k])) { flags[k] = 1; }
            k = k + 1;
        }
        flags[2] = 0; flags[3] = 0; flags[4] = 0; flags[5] = 0;
        if (flags[0] == 0 && flags[1] == 0) { flags[0] = 1; }
        return flags;
    }

    /// Publishes the active file for each selected Windows target into
    /// <root>/publish. Non-Windows targets are locked and only logged.
    static void PublishPlatforms(List<string> names, List<string> paths, SignalInt active, string root, List<int> sel, List<string> log) {
        int a = active.Get();
        if (a < 0 || a >= paths.Count) { log.Add("> Nothing to publish."); return; }
        string p = paths[a];
        if (p == "") { log.Add("> Nothing to publish (save the file first)."); return; }
        Directory.CreateDirectory(root + "/publish");
        string bd = IdeDemo.EnsureBuildDir(root);
        string zc = IdeDemo.ZancCmd();
        string inputs = IdeDemo.ProjectInputs(IdeDemo.DirOf(p), p, "");
        string baseName = names[a];
        if (baseName.Length > 4 && baseName.Substring(baseName.Length - 4, 4) == ".zan") {
            baseName = baseName.Substring(0, baseName.Length - 4);
        }
        int published = 0;
        if (sel.Count > 0 && sel[0] == 1) {
            string exe = root + "/publish/" + baseName + "-windows-x64.exe";
            string ll = bd + "/.zanpub_x64.ll";
            string cmd = zc + " --emit-ir " + inputs + " > \"" + ll + "\""
                + " && clang \"" + ll + "\" -o \"" + exe + "\"";
            log.Add("> Publishing windows-x64 ...");
            List<string> outp = Process.RunCapture(cmd);
            IdeDemo.AppendAll(log, outp);
            log.Add("> Published " + exe);
            published = published + 1;
        }
        if (sel.Count > 1 && sel[1] == 1) {
            string exe = root + "/publish/" + baseName + "-windows-arm64.exe";
            string ll = bd + "/.zanpub_arm64.ll";
            string cmd = zc + " --emit-ir " + inputs + " > \"" + ll + "\""
                + " && clang --target=aarch64-pc-windows-msvc \"" + ll + "\" -o \"" + exe + "\"";
            log.Add("> Publishing windows-arm64 (requires ARM64 toolchain) ...");
            List<string> outp = Process.RunCapture(cmd);
            IdeDemo.AppendAll(log, outp);
            log.Add("> Published " + exe);
            published = published + 1;
        }
        bool anyLocked = false;
        if (sel.Count > 2 && sel[2] == 1) { anyLocked = true; }
        if (sel.Count > 3 && sel[3] == 1) { anyLocked = true; }
        if (sel.Count > 4 && sel[4] == 1) { anyLocked = true; }
        if (sel.Count > 5 && sel[5] == 1) { anyLocked = true; }
        if (anyLocked) {
            log.Add("> Skipped Linux/macOS targets: cross-compiling from Windows needs their toolchains (locked).");
        }
        if (published == 0) {
            log.Add("> No Windows target selected; nothing published.");
        }
    }

    /// Renders the modal Publish dialog. Returns 0 (none), 1 (publish), 2 (cancel).
    /// Windows targets are toggleable; non-Windows rows are drawn locked.
    static int RenderPublishDialog(App app, string projName, List<int> sel) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int W = c.Width();
        int H = c.Height();
        c.FillRect(0, 0, W, H, t.overlay);

        int w = app.Scale(470);
        int h = app.Scale(380);
        int x = (W - w) / 2;
        int y = (H - h) / 2;
        c.FillRoundRect(x + 2, y + 3, w, h, app.Scale(6), t.shadowColor);
        c.FillRoundRect(x, y, w, h, app.Scale(6), 0xFF252526);
        c.DrawRect(x, y, w, h, t.borderPrimary, 1);

        int pad = app.Scale(18);
        c.DrawText(x + pad, y + pad, "Publish Project", 0xFFFFFFFF, t.fontSizeLarge);
        c.DrawText(x + pad, y + pad + app.Scale(24), "Target file: " + projName, 0xFF888888, t.fontSizeSmall);
        c.FillRect(x + 1, y + app.Scale(60), w - 2, 1, t.divider);
        c.DrawText(x + pad, y + app.Scale(72), "Platforms", 0xFFCCCCCC, t.fontSizeSmall);

        List<string> disp = new List<string>();
        disp.Add("Windows   x64"); disp.Add("Windows   ARM64");
        disp.Add("Linux   x64"); disp.Add("Linux   ARM64");
        disp.Add("macOS   x64"); disp.Add("macOS   ARM64");

        int rowH = app.Scale(30);
        int listX = x + pad;
        int listY = y + app.Scale(94);
        int boxSize = app.Scale(18);
        int clicked = 0 - 1;

        int i = 0;
        while (i < 6) {
            int ry = listY + i * rowH;
            bool isWin = i < 2;
            bool on = false;
            if (i < sel.Count && sel[i] == 1) { on = true; }
            int boxX = listX;
            int boxY = ry + (rowH - boxSize) / 2;
            int boxCol = 0xFF1E1E1E;
            int borderCol = 0xFF3E3E42;
            int labelCol = 0xFFCCCCCC;
            if (!isWin) { labelCol = 0xFF6A6A6A; borderCol = 0xFF333333; }
            if (isWin && on) { boxCol = 0xFF0E639C; }
            c.FillRoundRect(boxX, boxY, boxSize, boxSize, app.Scale(3), boxCol);
            c.DrawRect(boxX, boxY, boxSize, boxSize, borderCol, 1);
            if (isWin && on) {
                Icon.Draw(c, "check", boxX + app.Scale(3), boxY + app.Scale(3), boxSize - app.Scale(6), 0xFFFFFFFF);
            }
            int lblY = ry + (rowH - Canvas.FontHeight(t.fontSizeMedium)) / 2;
            c.DrawText(boxX + boxSize + app.Scale(10), lblY, disp[i], labelCol, t.fontSizeMedium);
            if (!isWin) {
                c.DrawText(x + w - pad - app.Scale(118), lblY, "locked on Windows", 0xFF6A6A6A, t.fontSizeSmall);
            }
            if (isWin && app.window.EventKind() == 3
                && app.mouseX >= boxX && app.mouseX < x + w - pad
                && app.mouseY >= ry && app.mouseY < ry + rowH) {
                clicked = i;
            }
            i = i + 1;
        }

        if (clicked >= 0 && clicked < sel.Count) {
            if (sel[clicked] == 1) { sel[clicked] = 0; } else { sel[clicked] = 1; }
            app.RequestRedraw();
        }

        c.DrawText(x + pad, listY + 6 * rowH + app.Scale(8),
            "Non-Windows targets need a cross toolchain — unavailable on this host.",
            0xFF888888, t.fontSizeSmall);

        int btnH = app.Scale(30);
        int btnY = y + h - btnH - app.Scale(16);
        int pubW = app.Scale(100);
        int canW = app.Scale(86);
        int pubX = x + w - pad - pubW;
        int canX = pubX - app.Scale(10) - canW;
        c.FillRoundRect(canX, btnY, canW, btnH, app.Scale(4), 0xFF3E3E42);
        c.DrawText(canX + app.Scale(24), btnY + app.Scale(8), "Cancel", 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRoundRect(pubX, btnY, pubW, btnH, app.Scale(4), 0xFF0E639C);
        c.DrawText(pubX + app.Scale(28), btnY + app.Scale(8), "Publish", 0xFFFFFFFF, t.fontSizeSmall);

        int action = 0;
        if (app.window.EventKind() == 3) {
            if (app.mouseX >= pubX && app.mouseX < pubX + pubW
                && app.mouseY >= btnY && app.mouseY < btnY + btnH) {
                action = 1;
            } else if (app.mouseX >= canX && app.mouseX < canX + canW
                       && app.mouseY >= btnY && app.mouseY < btnY + btnH) {
                action = 2;
            }
        }
        return action;
    }

    // ---- code navigation (go to definition / find references) ----

    static string RTrimS(string s) {
        int e = s.Length;
        while (e > 0) {
            string ch = s.Substring(e - 1, 1);
            if (ch == " " || ch == "\t") { e = e - 1; } else { break; }
        }
        return s.Substring(0, e);
    }

    /// True if `after` begins with `word` followed by a non-identifier char.
    static bool StartsWithWord(string after, string word) {
        int wl = word.Length;
        if (after.Length < wl) { return false; }
        if (after.Substring(0, wl) != word) { return false; }
        if (after.Length == wl) { return true; }
        return !CodeEditor.IsIdentChar(after.Substring(wl, 1));
    }

    /// True if the line declares a type named `word` (class/struct/enum/interface).
    static bool IsTypeDecl(string line, string word) {
        string s = CodeEditor.LTrim(line);
        List<string> kws = new List<string>();
        kws.Add("class "); kws.Add("struct "); kws.Add("enum "); kws.Add("interface ");
        int i = 0;
        while (i < kws.Count) {
            string kw = kws[i];
            if (s.Length >= kw.Length && s.Substring(0, kw.Length) == kw) {
                string after = s.Substring(kw.Length, s.Length - kw.Length);
                if (IdeDemo.StartsWithWord(CodeEditor.LTrim(after), word)) { return true; }
            }
            i = i + 1;
        }
        return false;
    }

    /// Index of a whole-word `word(` occurrence in s, or -1.
    static int FindWordCall(string s, string word) {
        int wl = word.Length;
        if (wl == 0) { return 0 - 1; }
        int i = 0;
        while (i + wl < s.Length) {
            if (s.Substring(i, wl) == word && s.Substring(i + wl, 1) == "(") {
                bool leftOk = true;
                if (i > 0) { leftOk = !CodeEditor.IsIdentChar(s.Substring(i - 1, 1)); }
                if (leftOk) { return i; }
            }
            i = i + 1;
        }
        return 0 - 1;
    }

    /// Heuristic: the line is a method/function definition header for `word`
    /// (a return-type token precedes `word(` and the line opens a block / ends
    /// the signature), as opposed to a call site.
    static bool IsMethodDef(string line, string word) {
        string s = CodeEditor.LTrim(line);
        if (IdeDemo.StartsWithWord(s, "if") || IdeDemo.StartsWithWord(s, "while")
            || IdeDemo.StartsWithWord(s, "for") || IdeDemo.StartsWithWord(s, "foreach")
            || IdeDemo.StartsWithWord(s, "switch") || IdeDemo.StartsWithWord(s, "return")
            || IdeDemo.StartsWithWord(s, "else")) { return false; }
        int pos = IdeDemo.FindWordCall(s, word);
        if (pos <= 0) { return false; }
        if (s.Substring(pos - 1, 1) != " ") { return false; }
        string rt = IdeDemo.RTrimS(s);
        if (rt.Length == 0) { return false; }
        string last = rt.Substring(rt.Length - 1, 1);
        return last == "{" || last == ")";
    }

    /// First line index declaring `word` in `body` (type decls first, then
    /// method definitions), or -1 when not found.
    static int FindDeclLine(string body, string word) {
        List<string> ls = CodeEditor.SplitLines(body);
        int i = 0;
        while (i < ls.Count) {
            if (IdeDemo.IsTypeDecl(ls[i], word)) { return i; }
            i = i + 1;
        }
        int k = 0;
        while (k < ls.Count) {
            if (IdeDemo.IsMethodDef(ls[k], word)) { return k; }
            k = k + 1;
        }
        return 0 - 1;
    }

    /// Recursively collects every .zan file path under `dir`.
    static List<string> ListZanFiles(string dir) {
        List<string> outp = new List<string>();
        IdeDemo.CollectZan(dir, outp);
        return outp;
    }

    static void CollectZan(string dir, List<string> outp) {
        if (!Directory.Exists(dir)) { return; }
        List<string> files = Directory.GetFiles(dir);
        int i = 0;
        while (i < files.Count) {
            string nm = files[i];
            if (nm.Length > 4 && nm.Substring(nm.Length - 4, 4) == ".zan") {
                outp.Add(dir + "/" + nm);
            } else if (nm.Length > 6 && nm.Substring(nm.Length - 6, 6) == ".zform") {
                outp.Add(dir + "/" + nm);
            }
            i = i + 1;
        }
        List<string> subs = Directory.GetDirectories(dir);
        int j = 0;
        while (j < subs.Count) {
            IdeDemo.CollectZan(dir + "/" + subs[j], outp);
            j = j + 1;
        }
    }

    /// Finds the definition of the symbol under the caret across the current
    /// file, other open tabs, then the project's src tree. Switches/opens the
    /// target tab and returns the destination line (-1 when not found).
    static int GoToDefinition(CodeEditor editor, List<string> tabNames, List<string> tabBodies,
                              List<string> tabPaths, SignalInt active, string root, List<string> log) {
        string word = editor.WordAtCaret();
        if (word == "") { log.Add("> Go to Definition: no symbol under caret."); return 0 - 1; }
        int a = active.Get();
        if (a >= 0 && a < tabBodies.Count) { tabBodies[a] = editor.GetText(); }
        if (a >= 0 && a < tabBodies.Count) {
            int ln = IdeDemo.FindDeclLine(tabBodies[a], word);
            if (ln >= 0) {
                log.Add("> Definition of '" + word + "' at line " + Convert.ToString(ln + 1) + " (this file).");
                return ln;
            }
        }
        int i = 0;
        while (i < tabBodies.Count) {
            if (i != a) {
                int ln = IdeDemo.FindDeclLine(tabBodies[i], word);
                if (ln >= 0) {
                    active.Set(i);
                    log.Add("> Definition of '" + word + "' in " + tabNames[i]
                        + " at line " + Convert.ToString(ln + 1) + ".");
                    return ln;
                }
            }
            i = i + 1;
        }
        List<string> files = IdeDemo.ListZanFiles(root + "/src");
        int fi = 0;
        while (fi < files.Count) {
            string fp = files[fi];
            if (tabPaths.IndexOf(fp) < 0) {
                string body = File.ReadAllText(fp);
                int ln = IdeDemo.FindDeclLine(body, word);
                if (ln >= 0) {
                    IdeDemo.OpenPath(tabNames, tabBodies, tabPaths, active, fp, Path.GetFileName(fp));
                    log.Add("> Definition of '" + word + "' in " + Path.GetFileName(fp)
                        + " at line " + Convert.ToString(ln + 1) + ".");
                    return ln;
                }
            }
            fi = fi + 1;
        }
        log.Add("> Go to Definition: '" + word + "' not found in project.");
        return 0 - 1;
    }

    /// Counts whole-word occurrences of `word` in `line`.
    static int CountWord(string line, string word) {
        int wl = word.Length;
        if (wl == 0) { return 0; }
        int count = 0;
        int i = 0;
        while (i + wl <= line.Length) {
            if (line.Substring(i, wl) == word) {
                bool leftOk = true;
                bool rightOk = true;
                if (i > 0) { leftOk = !CodeEditor.IsIdentChar(line.Substring(i - 1, 1)); }
                if (i + wl < line.Length) { rightOk = !CodeEditor.IsIdentChar(line.Substring(i + wl, 1)); }
                if (leftOk && rightOk) { count = count + 1; i = i + wl; }
                else { i = i + 1; }
            } else { i = i + 1; }
        }
        return count;
    }

    static int CountRefsInFile(string name, string body, string word, List<string> log) {
        List<string> ls = CodeEditor.SplitLines(body);
        int count = 0;
        int i = 0;
        while (i < ls.Count) {
            int occ = IdeDemo.CountWord(ls[i], word);
            if (occ > 0) {
                count = count + occ;
                log.Add("   " + name + ":" + Convert.ToString(i + 1) + ": " + CodeEditor.LTrim(ls[i]));
            }
            i = i + 1;
        }
        return count;
    }

    /// Lists every whole-word reference to the symbol under the caret across
    /// open tabs and the project's src tree, into the output log.
    static void FindReferences(CodeEditor editor, List<string> tabNames, List<string> tabBodies,
                               List<string> tabPaths, SignalInt active, string root, List<string> log) {
        string word = editor.WordAtCaret();
        if (word == "") { log.Add("> Find All References: no symbol under caret."); return; }
        int a = active.Get();
        if (a >= 0 && a < tabBodies.Count) { tabBodies[a] = editor.GetText(); }
        log.Add("> References to '" + word + "':");
        int total = 0;
        int i = 0;
        while (i < tabBodies.Count) {
            total = total + IdeDemo.CountRefsInFile(tabNames[i], tabBodies[i], word, log);
            i = i + 1;
        }
        List<string> files = IdeDemo.ListZanFiles(root + "/src");
        int fi = 0;
        while (fi < files.Count) {
            string fp = files[fi];
            if (tabPaths.IndexOf(fp) < 0) {
                string body = File.ReadAllText(fp);
                total = total + IdeDemo.CountRefsInFile(Path.GetFileName(fp), body, word, log);
            }
            fi = fi + 1;
        }
        log.Add("> " + Convert.ToString(total) + " reference(s) found.");
    }

    // ---- designer <-> code (form serialization) ----

    /// Splits a string on runs of spaces/tabs into tokens.
    static List<string> SplitSpaces(string s) {
        List<string> outp = new List<string>();
        string cur = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == " " || ch == "\t") {
                if (cur.Length > 0) { outp.Add(cur); cur = ""; }
            } else { cur = cur + ch; }
            i = i + 1;
        }
        if (cur.Length > 0) { outp.Add(cur); }
        return outp;
    }

    /// Serializes the designer's controls into a compilable Zan source file.
    /// The `// @control` markers are the canonical design model that
    /// LoadFormFromCode reads back, so the designer and this file round-trip.
    static string GenerateFormCode(string formName, List<string> dNames, List<string> dTypes,
                                   List<int> dX, List<int> dY, List<int> dW, List<int> dH) {
        string s = "";
        s = s + "using System;\n";
        s = s + "using Gui;\n\n";
        s = s + "// Auto-generated by the Zan IDE form designer.\n";
        s = s + "// The '@control <Type> <Name> <X> <Y> <W> <H>' markers below are the\n";
        s = s + "// serialized design model; the designer reads them back via Load Design.\n\n";
        s = s + "class " + formName + " {\n";
        s = s + "    // Design surface: " + Convert.ToString(dNames.Count) + " control(s).\n";
        s = s + "    static void InitializeComponent(App app) {\n";
        int i = 0;
        while (i < dNames.Count) {
            s = s + "        // @control " + dTypes[i] + " " + dNames[i] + " "
                  + Convert.ToString(dX[i]) + " " + Convert.ToString(dY[i]) + " "
                  + Convert.ToString(dW[i]) + " " + Convert.ToString(dH[i]) + "\n";
            i = i + 1;
        }
        s = s + "    }\n";
        s = s + "}\n";
        return s;
    }

    /// Rebuilds the designer's control lists from GenerateFormCode markers.
    static void LoadFormFromCode(string src, List<string> dNames, List<string> dTypes,
                                 List<int> dX, List<int> dY, List<int> dW, List<int> dH,
                                 List<string> log) {
        while (dNames.Count > 0) {
            int last = dNames.Count - 1;
            dNames.RemoveAt(last); dTypes.RemoveAt(last);
            dX.RemoveAt(last); dY.RemoveAt(last);
            dW.RemoveAt(last); dH.RemoveAt(last);
        }
        List<string> ls = CodeEditor.SplitLines(src);
        string marker = "// @control ";
        int n = 0;
        int i = 0;
        while (i < ls.Count) {
            string s = CodeEditor.LTrim(ls[i]);
            if (s.Length > marker.Length && s.Substring(0, marker.Length) == marker) {
                string rest = s.Substring(marker.Length, s.Length - marker.Length);
                List<string> toks = IdeDemo.SplitSpaces(rest);
                if (toks.Count >= 6) {
                    dTypes.Add(toks[0]);
                    dNames.Add(toks[1]);
                    dX.Add(IdeDemo.ParseInt(toks[2]));
                    dY.Add(IdeDemo.ParseInt(toks[3]));
                    dW.Add(IdeDemo.ParseInt(toks[4]));
                    dH.Add(IdeDemo.ParseInt(toks[5]));
                    n = n + 1;
                }
            }
            i = i + 1;
        }
        log.Add("> Loaded " + Convert.ToString(n) + " control(s) from Form1.designer.zan into the designer.");
    }

    static void AppendAll(List<string> log, List<string> lines) {
        int i = 0;
        while (i < lines.Count) {
            log.Add("  " + lines[i]);
            i = i + 1;
        }
    }

    // ==== C#-style form file model (.zform design file + .zan code-behind) ====

    /// True when the path names a visual form design file (opened in the designer).
    static bool IsFormPath(string p) {
        int n = p.Length;
        if (n < 6) { return false; }
        return p.Substring(n - 6, 6) == ".zform";
    }

    /// Base name of a .zform (the form/class name), e.g. src/Login.zform -> Login.
    static string FormBaseName(string p) {
        string fn = Path.GetFileName(p);
        int n = fn.Length;
        if (n >= 6 && fn.Substring(n - 6, 6) == ".zform") { return fn.Substring(0, n - 6); }
        return fn;
    }

    /// Code-behind path for a .zform, e.g. src/Login.zform -> src/Login.zan.
    static string CodeBehindPath(string formPath) {
        int n = formPath.Length;
        if (n >= 6 && formPath.Substring(n - 6, 6) == ".zform") {
            return formPath.Substring(0, n - 6) + ".zan";
        }
        return formPath + ".zan";
    }

    /// Serializes the designer controls into .zform text (layout only, no logic).
    static string SerializeForm(string name, List<string> dNames, List<string> dTypes,
                                List<int> dX, List<int> dY, List<int> dW, List<int> dH) {
        string s = "# Zan Form Design File\n";
        s = s + "# Visual layout for " + name + "; edit in the IDE form designer.\n";
        s = s + "# Application logic lives in the code-behind file " + name + ".zan\n";
        s = s + "form " + name + "\n";
        int i = 0;
        while (i < dNames.Count) {
            s = s + "control " + dTypes[i] + " " + dNames[i] + " "
                  + Convert.ToString(dX[i]) + " " + Convert.ToString(dY[i]) + " "
                  + Convert.ToString(dW[i]) + " " + Convert.ToString(dH[i]) + "\n";
            i = i + 1;
        }
        return s;
    }

    /// Parses .zform text back into the designer control lists.
    static void ParseForm(string text, List<string> dNames, List<string> dTypes,
                          List<int> dX, List<int> dY, List<int> dW, List<int> dH) {
        while (dNames.Count > 0) {
            int last = dNames.Count - 1;
            dNames.RemoveAt(last); dTypes.RemoveAt(last);
            dX.RemoveAt(last); dY.RemoveAt(last);
            dW.RemoveAt(last); dH.RemoveAt(last);
        }
        List<string> ls = CodeEditor.SplitLines(text);
        int i = 0;
        while (i < ls.Count) {
            string s = CodeEditor.LTrim(ls[i]);
            if (s.Length > 8 && s.Substring(0, 8) == "control ") {
                List<string> toks = IdeDemo.SplitSpaces(s.Substring(8, s.Length - 8));
                if (toks.Count >= 6) {
                    dTypes.Add(toks[0]);
                    dNames.Add(toks[1]);
                    dX.Add(IdeDemo.ParseInt(toks[2]));
                    dY.Add(IdeDemo.ParseInt(toks[3]));
                    dW.Add(IdeDemo.ParseInt(toks[4]));
                    dH.Add(IdeDemo.ParseInt(toks[5]));
                }
            }
            i = i + 1;
        }
    }

    /// The generated designer region (InitializeComponent), delimited by markers so
    /// it can be regenerated in place while preserving the user's own code around it.
    static string BuildDesignerRegion(string name, List<string> dNames, List<string> dTypes,
                                      List<int> dX, List<int> dY, List<int> dW, List<int> dH) {
        string s = "    // <<< ZAN-DESIGNER BEGIN (generated from " + name + ".zform - do not edit) >>>\n";
        s = s + "    // Fields for each designed control.\n";
        int i = 0;
        while (i < dNames.Count) {
            s = s + "    " + dTypes[i] + " " + dNames[i] + ";\n";
            i = i + 1;
        }
        s = s + "    void InitializeComponent(App app) {\n";
        i = 0;
        while (i < dNames.Count) {
            s = s + "        // " + dTypes[i] + " " + dNames[i] + " @ ("
                  + Convert.ToString(dX[i]) + "," + Convert.ToString(dY[i]) + ") "
                  + Convert.ToString(dW[i]) + "x" + Convert.ToString(dH[i]) + "\n";
            i = i + 1;
        }
        if (dNames.Count == 0) {
            s = s + "        // (no controls yet - add some in the form designer)\n";
        }
        s = s + "    }\n";
        s = s + "    // <<< ZAN-DESIGNER END >>>\n";
        return s;
    }

    /// A fresh code-behind file: designer region + a Main entry the user can extend.
    static string BuildCodeBehind(string name, List<string> dNames, List<string> dTypes,
                                  List<int> dX, List<int> dY, List<int> dW, List<int> dH) {
        string s = "using System;\n";
        s = s + "using Gui;\n";
        s = s + "using Gui.Widget;\n\n";
        s = s + "// Code-behind for " + name + ".zform.\n";
        s = s + "// The layout is defined visually in " + name + ".zform; the region below is\n";
        s = s + "// regenerated from it. Write your own logic outside that region.\n";
        s = s + "class " + name + " {\n";
        s = s + IdeDemo.BuildDesignerRegion(name, dNames, dTypes, dX, dY, dW, dH);
        s = s + "\n";
        s = s + "    void Load() {\n";
        s = s + "        // TODO: your form initialization logic here.\n";
        s = s + "    }\n";
        s = s + "}\n";
        return s;
    }

    /// Replaces the designer region of an existing code-behind in place, keeping all
    /// user code outside the BEGIN/END markers. If markers are missing, returns the
    /// text unchanged (the designer will not clobber a hand-written file).
    static string RegenerateCodeBehind(string existing, string name, List<string> dNames,
            List<string> dTypes, List<int> dX, List<int> dY, List<int> dW, List<int> dH) {
        List<string> ls = CodeEditor.SplitLines(existing);
        int bi = 0 - 1;
        int ei = 0 - 1;
        int i = 0;
        while (i < ls.Count) {
            string tr = CodeEditor.LTrim(ls[i]);
            if (bi < 0 && tr.Length >= 20 && tr.Substring(0, 20) == "// <<< ZAN-DESIGNER B") { bi = i; }
            else if (bi >= 0 && ei < 0 && tr.Length >= 20 && tr.Substring(0, 20) == "// <<< ZAN-DESIGNER E") { ei = i; }
            i = i + 1;
        }
        if (bi < 0 || ei < 0 || ei < bi) { return existing; }
        string region = IdeDemo.BuildDesignerRegion(name, dNames, dTypes, dX, dY, dW, dH);
        string outp = "";
        i = 0;
        while (i < bi) { outp = outp + ls[i] + "\n"; i = i + 1; }
        outp = outp + region;
        i = ei + 1;
        while (i < ls.Count) { outp = outp + ls[i] + "\n"; i = i + 1; }
        return outp;
    }

    // ---- dialog rendering ----

    /// Renders a modal template picker: a selectable list on the left, a name
    /// field (+ optional location field) on the right, and Create/Cancel.
    /// Returns 0 none, 1 create, 2 cancel.
    static int RenderTemplateDialog(App app, string title, List<string> names, List<string> icons,
                                    List<string> descs, SignalInt sel, Input nameInput, Input locInput,
                                    bool showLoc) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        int w = app.Scale(700);
        int h = app.Scale(440);
        int closeId = Modal.Render(app, w, h, title);
        int x = (c.Width() - w) / 2;
        int y = (c.Height() - h) / 2;
        int pad = t.paddingLarge;
        int contentY = y + pad + t.heightMedium + t.paddingMedium;

        int listW = app.Scale(250);
        int listX = x + pad;
        int listH = h - (contentY - y) - app.Scale(72);
        IdeDemo.RenderTemplateList(app, listX, contentY, listW, listH, names, icons, sel);

        int fx = listX + listW + pad;
        int fw = x + w - pad - fx;
        int fy = contentY;

        c.DrawText(fx, fy, "Name", t.textSecondary, t.fontSizeSmall);
        nameInput.Render(app, fx, fy + app.Scale(20), fw, t.heightMedium);
        int nextY = fy + app.Scale(20) + t.heightMedium + t.paddingMedium;

        if (showLoc) {
            c.DrawText(fx, nextY, "Location", t.textSecondary, t.fontSizeSmall);
            locInput.Render(app, fx, nextY + app.Scale(20), fw, t.heightMedium);
            nextY = nextY + app.Scale(20) + t.heightMedium + t.paddingMedium;
        }

        int s = sel.Get();
        if (s >= 0 && s < descs.Count) {
            c.DrawText(fx, nextY, descs[s], t.textTertiary, t.fontSizeSmall);
        }

        int bw = app.Scale(100);
        int by = y + h - t.heightMedium - pad;
        int okX = x + w - pad - bw;
        int cancelX = okX - t.gapMedium - bw;

        int result = 0;
        int cancelId = Button.Create("Cancel").Render(app, cancelX, by, bw);
        if (Button.WasClicked(app, cancelId)) { result = 2; }
        int okId = Button.Primary("Create").Render(app, okX, by, bw);
        if (Button.WasClicked(app, okId)) { result = 1; }

        if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == closeId) {
            result = 2;
        }
        return result;
    }

    static void RenderTemplateList(App app, int x, int y, int w, int h, List<string> names,
                                   List<string> icons, SignalInt sel) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium, t.bgSecondary);

        int rowH = app.Scale(42);
        int n = names.Count;
        int firstId = app.focus.AllocId();
        int i = 1;
        while (i < n) { app.focus.AllocId(); i = i + 1; }

        int selv = sel.Get();
        int glyph = t.fontSizeLarge;
        int k = 0;
        while (k < n) {
            int id = firstId + k;
            int rowY = y + k * rowH;
            bool hovered = app.focus.IsHovered(id);
            bool active = k == selv;
            if (active) {
                c.FillRect(x, rowY, w, rowH, t.bgActive);
                c.FillRect(x, rowY, app.Scale(3), rowH, t.primary);
            } else if (hovered) {
                c.FillRect(x, rowY, w, rowH, t.bgHover);
            }
            int iconColor = t.textSecondary;
            int textColor = t.textPrimary;
            if (active) { iconColor = t.primary; textColor = t.primary; }
            Icon.DrawCenteredIn(c, icons[k], x + t.paddingMedium, rowY, glyph, rowH, glyph, iconColor);
            int textX = x + t.paddingMedium + glyph + t.gapMedium;
            int textY = rowY + (rowH - Canvas.FontHeight(t.fontSizeMedium)) / 2;
            c.DrawText(textX, textY, names[k], textColor, t.fontSizeMedium);
            app.hitTester.Register(HitRegion.Create(id, x, rowY, w, rowH, 0));
            k = k + 1;
        }

        if (app.window.EventKind() == 3) {
            int hitv = app.hitTester.HitTest(app.mouseX, app.mouseY);
            int idx = hitv - firstId;
            if (idx >= 0 && idx < n) {
                sel.Set(idx);
                app.RequestRedraw();
            }
        }
    }

    // ================================================================
    // Settings persistence (window + panel sizes)
    // ================================================================

    static string CfgPath() { return IdeDemo.UserConfigDir() + "/config.cfg"; }

    static bool IsDigit(string ch) {
        return ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4"
            || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9";
    }

    /// Finds the first index of `sub` in `s`, or -1.
    static int StrFind(string s, string sub) {
        if (sub.Length == 0) { return 0; }
        if (sub.Length > s.Length) { return -1; }
        int n = s.Length - sub.Length;
        int i = 0;
        while (i <= n) {
            if (s.Substring(i, sub.Length) == sub) { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// The file name portion of a path (after the last '/' or '\').
    static string BaseName(string p) {
        int best = -1;
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "/" || ch == "\\") { best = i; }
            i = i + 1;
        }
        if (best >= 0 && best + 1 <= p.Length) { return p.Substring(best + 1, p.Length - best - 1); }
        return p;
    }

    /// Reads an integer "key=NNN" from a settings blob, or `def` when absent.
    static int CfgInt(string cfg, string key, int def) {
        int idx = IdeDemo.StrFind(cfg, key + "=");
        if (idx < 0) { return def; }
        int p = idx + key.Length + 1;
        string num = "";
        while (p < cfg.Length) {
            string ch = cfg.Substring(p, 1);
            if (IdeDemo.IsDigit(ch)) { num = num + ch; p = p + 1; } else { break; }
        }
        if (num.Length == 0) { return def; }
        return IdeDemo.ParseInt(num);
    }

    /// Clamps a restored dimension into a sane range.
    static int CfgClamp(int v, int lo, int hi) {
        if (v < lo) { return lo; }
        if (v > hi) { return hi; }
        return v;
    }

    static void SaveSettings(int treeW, int botH, int winW, int winH, int botTab, int autoRun) {
        string s = "treeW=" + Convert.ToString(treeW)
            + ";bottomH=" + Convert.ToString(botH)
            + ";winW=" + Convert.ToString(winW)
            + ";winH=" + Convert.ToString(winH)
            + ";bottomTab=" + Convert.ToString(botTab)
            + ";autoRun=" + Convert.ToString(autoRun) + ";";
        Directory.CreateDirectoryRecursive(IdeDemo.UserConfigDir());
        File.WriteAllText(IdeDemo.CfgPath(), s);
    }

    /// Index of the open tab whose file name matches `base`, or -1.
    static int FindTabByBase(List<string> tabPaths, string bn) {
        int i = 0;
        while (i < tabPaths.Count) {
            if (IdeDemo.BaseName(tabPaths[i]) == bn) { return i; }
            i = i + 1;
        }
        return -1;
    }

    // ================================================================
    // Error list (parsed from build/run output) + tabbed bottom panel
    // ================================================================

    /// Scans the log for compiler/linker diagnostics of the form
    /// `...<file>.zan:<line>[:col]: ... message`, filling parallel lists.
    static void ParseErrorList(List<string> log, List<string> outPath,
            List<string> outLine, List<string> outMsg) {
        int i = 0;
        while (i < log.Count) {
            string ln = log[i];
            int idx = IdeDemo.StrFind(ln, ".zan:");
            if (idx >= 0) {
                // path: from first non-prefix char up to and including ".zan"
                int ps = 0;
                while (ps < ln.Length) {
                    string pc = ln.Substring(ps, 1);
                    if (pc == " " || pc == ">" || pc == "\t") { ps = ps + 1; } else { break; }
                }
                string path = ln.Substring(ps, (idx + 4) - ps);
                int p = idx + 5;
                string num = "";
                while (p < ln.Length) {
                    string ch = ln.Substring(p, 1);
                    if (IdeDemo.IsDigit(ch)) { num = num + ch; p = p + 1; } else { break; }
                }
                if (num.Length > 0) {
                    string msg = ln;
                    int me = IdeDemo.StrFind(ln, "error");
                    if (me < 0) { me = IdeDemo.StrFind(ln, "warning"); }
                    if (me >= 0) { msg = ln.Substring(me, ln.Length - me); }
                    outPath.Add(path);
                    outLine.Add(num);
                    outMsg.Add(msg);
                }
            }
            i = i + 1;
        }
    }

    /// Draws the parsed error rows; each row is clickable (hover-highlighted).
    static void RenderErrorList(App app, Canvas c, Theme t,
            int x, int y, int w, int h, List<string> ePath, List<string> eLine, List<string> eMsg) {
        int rowH = app.Scale(20);
        int pad = app.Scale(6);
        if (ePath.Count == 0) {
            c.DrawText(x + pad, y + pad, "No errors.", 0xFF6A9955, t.fontSizeSmall);
            return;
        }
        int i = 0;
        int cy = y + pad;
        while (i < ePath.Count && cy + rowH <= y + h) {
            if (app.mouseX >= x && app.mouseX < x + w && app.mouseY >= cy && app.mouseY < cy + rowH) {
                c.FillRect(x, cy, w, rowH, 0xFF2A2D2E);
            }
            string row = IdeDemo.BaseName(ePath[i]) + ":" + eLine[i] + "   " + eMsg[i];
            c.DrawText(x + pad, cy, row, 0xFFF48771, t.fontSizeSmall);
            cy = cy + rowH;
            i = i + 1;
        }
    }

    /// Tabbed bottom panel (Output / Error List) with tight padding, replacing
    /// the single bordered Output section.
    static void RenderOutputBottom(App app, Canvas c, Theme t, Rect orr, int tab,
            List<string> log, List<string> ePath, List<string> eLine, List<string> eMsg,
            int selR0, int selC0, int selR1, int selC1) {
        int tabH = app.Scale(28);
        int tabW = app.Scale(90);
        c.FillRect(orr.x, orr.y, orr.width, tabH, 0xFF252526);
        c.FillRect(orr.x, orr.y + tabH - 1, orr.width, 1, t.divider);
        int bg0 = 0xFF333333;
        if (tab == 0) { bg0 = 0xFF1E1E1E; }
        c.FillRect(orr.x, orr.y, tabW, tabH, bg0);
        c.DrawText(orr.x + app.Scale(8), orr.y + app.Scale(6), "Output", t.textPrimary, t.fontSizeSmall);
        int bg1 = 0xFF333333;
        if (tab == 1) { bg1 = 0xFF1E1E1E; }
        c.FillRect(orr.x + tabW, orr.y, tabW, tabH, bg1);
        string elabel = "Errors";
        if (eLine.Count > 0) { elabel = "Errors (" + Convert.ToString(eLine.Count) + ")"; }
        c.DrawText(orr.x + tabW + app.Scale(8), orr.y + app.Scale(6), elabel, t.textPrimary, t.fontSizeSmall);
        c.DrawText(orr.x + orr.width - app.Scale(190), orr.y + app.Scale(7), "drag: select · right-click: copy", 0xFF808080, t.fontSizeSmall);
        int contentY = orr.y + tabH;
        int contentH = orr.height - tabH;
        c.FillRect(orr.x, contentY, orr.width, contentH, 0xFF1E1E1E);
        if (tab == 0) {
            IdeDemo.RenderConsoleTab(app, c, t, orr.x, contentY, orr.width, contentH, log,
                selR0, selC0, selR1, selC1);
        } else {
            IdeDemo.RenderErrorList(app, c, t, orr.x, contentY, orr.width, contentH, ePath, eLine, eMsg);
        }
    }

    static void RenderLog(App app, Rect r, List<string> log) {
        Theme t = app.theme;
        int lineH = app.Scale(18);
        if (lineH < 1) { lineH = 1; }
        int maxLines = r.height / lineH;
        if (maxLines < 1) { maxLines = 1; }
        int start = log.Count - maxLines;
        if (start < 0) { start = 0; }
        int i = start;
        int row = 0;
        while (i < log.Count) {
            string ln = log[i];
            int col = t.textSecondary;
            if (ln.Length >= 2) {
                string head = ln.Substring(0, 2);
                if (head == "> ") { col = t.textPrimary; }
            }
            app.canvas.DrawText(r.x, r.y + row * lineH, ln, col, t.fontSizeSmall);
            i = i + 1;
            row = row + 1;
        }
    }

    // ================================================================
    // Debug helpers
    // ================================================================

    static List<string> DebugBuildRun(List<string> tabPaths, SignalInt activeTab,
            string root, List<string> log) {
        List<string> console = new List<string>();
        int a = activeTab.Get();
        if (a < 0 || a >= tabPaths.Count) { return console; }
        string p = tabPaths[a];
        if (p == "") {
            log.Add("> [Debug] Save the file first.");
            return console;
        }
        string bd = IdeDemo.EnsureBuildDir(root);
        string ll = bd + "/.zandbg.ll";
        string exe = bd + "/.zandbg" + IdeDemo.ExeSuffix();
        string buildCmd = IdeDemo.ZancCmd() + " --emit-ir \"" + p + "\" > \"" + ll + "\""
            + " && clang \"" + ll + "\" -o \"" + exe + "\"";
        log.Add("> [Debug] Building ...");
        List<string> buildOut = Process.RunCapture(buildCmd);
        int bo = 0;
        while (bo < buildOut.Count) {
            log.Add("  " + buildOut[bo]);
            bo = bo + 1;
        }
        log.Add("> [Debug] Running ...");
        List<string> runOut = Process.RunCapture("\"" + exe + "\"");
        int ri = 0;
        while (ri < runOut.Count) {
            console.Add(runOut[ri]);
            ri = ri + 1;
        }
        if (console.Count == 0) {
            console.Add("(no output)");
        }
        return console;
    }

    static int FindInEditor(CodeEditor editor, string query, int afterLine) {
        if (query.Length == 0) { return -1; }
        int lc = editor.LineCount();
        int startLine = afterLine + 1;
        if (startLine < 0) { startLine = 0; }
        string text = editor.GetText();
        List<string> edLines = new List<string>();
        string cur = "";
        int ii = 0;
        while (ii < text.Length) {
            string ch = text.Substring(ii, 1);
            if (ch == "\n") { edLines.Add(cur); cur = ""; }
            else if (ch == "\r") { cur = cur; }
            else { cur = cur + ch; }
            ii = ii + 1;
        }
        edLines.Add(cur);
        int li = startLine;
        while (li < edLines.Count) {
            string ln = edLines[li];
            int fi = 0;
            while (fi + query.Length <= ln.Length) {
                string sub = ln.Substring(fi, query.Length);
                if (sub == query) {
                    editor.GoToLineCol(li, fi);
                    return li;
                }
                fi = fi + 1;
            }
            li = li + 1;
        }
        // Wrap around from beginning
        li = 0;
        while (li < startLine && li < edLines.Count) {
            string ln = edLines[li];
            int fi = 0;
            while (fi + query.Length <= ln.Length) {
                string sub = ln.Substring(fi, query.Length);
                if (sub == query) {
                    editor.GoToLineCol(li, fi);
                    return li;
                }
                fi = fi + 1;
            }
            li = li + 1;
        }
        return -1;
    }

    static int ParseInt(string s) {
        int result = 0;
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "0") { result = result * 10; }
            else if (ch == "1") { result = result * 10 + 1; }
            else if (ch == "2") { result = result * 10 + 2; }
            else if (ch == "3") { result = result * 10 + 3; }
            else if (ch == "4") { result = result * 10 + 4; }
            else if (ch == "5") { result = result * 10 + 5; }
            else if (ch == "6") { result = result * 10 + 6; }
            else if (ch == "7") { result = result * 10 + 7; }
            else if (ch == "8") { result = result * 10 + 8; }
            else if (ch == "9") { result = result * 10 + 9; }
            i = i + 1;
        }
        return result;
    }

    static int FindFirstBp(List<int> bpList) {
        if (bpList.Count == 0) { return 0; }
        int best = bpList[0];
        int i = 1;
        while (i < bpList.Count) {
            if (bpList[i] < best) { best = bpList[i]; }
            i = i + 1;
        }
        return best;
    }

    static int FindNextBp(List<int> bpList, int currentLine) {
        int best = -1;
        int i = 0;
        while (i < bpList.Count) {
            if (bpList[i] > currentLine) {
                if (best < 0 || bpList[i] < best) { best = bpList[i]; }
            }
            i = i + 1;
        }
        return best;
    }

    /// Net change in brace nesting for a line (approximate: counts { and }
    /// literally, which is good enough for well-formed source).
    static int BraceDelta(string ln) {
        int d = 0;
        int i = 0;
        while (i < ln.Length) {
            string ch = ln.Substring(i, 1);
            if (ch == "{") { d = d + 1; }
            else if (ch == "}") { d = d - 1; }
            i = i + 1;
        }
        return d;
    }

    /// Returns "" if `elem` is not a primitive the debugger can stringify in an
    /// injected `foreach`, else the element type. (bool is excluded from lists:
    /// it stringifies to -1/0.)
    static string ListElemKind(string elem) {
        if (elem == "int" || elem == "string" || elem == "long"
            || elem == "float" || elem == "double" || elem == "char") {
            return elem;
        }
        return "";
    }

    /// If `tr` (a trimmed line) declares a local the debugger can evaluate,
    /// records its name, type, brace depth, and a category:
    ///   "scalar" = int/string/long/float/double/char, "bool", or
    ///   "list" = List<primitive> (element type stored in `elems`).
    /// Other types are left to the source-expression fallback.
    static void CollectVar(List<string> names, List<string> types,
            List<int> declDepth, List<int> alive, List<string> cats,
            List<string> elems, string tr, int depth) {
        List<string> prefixes = new List<string>();
        prefixes.Add("int "); prefixes.Add("string "); prefixes.Add("long ");
        prefixes.Add("float "); prefixes.Add("double "); prefixes.Add("char ");
        prefixes.Add("bool ");
        int pi = 0;
        while (pi < prefixes.Count) {
            string pfx = prefixes[pi];
            if (tr.Length > pfx.Length && tr.Substring(0, pfx.Length) == pfx) {
                string rest = tr.Substring(pfx.Length, tr.Length - pfx.Length);
                string name = IdeDemo.ExtractIdent(rest, 0);
                if (name.Length > 0) {
                    int ni = name.Length;
                    while (ni < rest.Length && rest.Substring(ni, 1) == " ") { ni = ni + 1; }
                    bool isDecl = ni >= rest.Length;
                    if (ni < rest.Length) {
                        string after = rest.Substring(ni, 1);
                        if (after == "=" || after == ";") { isDecl = true; }
                    }
                    if (isDecl) {
                        string tn = IdeDemo.TrimTrailSpaces(pfx);
                        names.Add(name);
                        types.Add(tn);
                        declDepth.Add(depth);
                        alive.Add(1);
                        if (tn == "bool") { cats.Add("bool"); } else { cats.Add("scalar"); }
                        elems.Add("");
                        return;
                    }
                }
            }
            pi = pi + 1;
        }
        // List<primitive> foo = ...
        if (tr.Length > 5 && tr.Substring(0, 5) == "List<") {
            int gt = IdeDemo.StrFind(tr, ">");
            if (gt > 5) {
                string elem = tr.Substring(5, gt - 5);
                string ek = IdeDemo.ListElemKind(elem);
                if (ek.Length > 0) {
                    string rest = tr.Substring(gt + 1, tr.Length - (gt + 1));
                    rest = IdeDemo.TrimLeadSpaces(rest);
                    string name = IdeDemo.ExtractIdent(rest, 0);
                    if (name.Length > 0) {
                        names.Add(name);
                        types.Add("List<" + elem + ">");
                        declDepth.Add(depth);
                        alive.Add(1);
                        cats.Add("list");
                        elems.Add(ek);
                    }
                }
            }
        }
    }

    /// Emits the instrumented print statement(s) for one variable, sized to its
    /// category. `level` 0 includes lists; level 1 emits only scalar/bool so a
    /// list that fails to compile can be dropped on retry.
    static string EmitVarProbe(string nm, string cat, string elem, int level) {
        if (cat == "scalar") {
            return "Console.WriteLine(\"@ZV@" + nm + "\\t\" + " + nm + ");\n";
        }
        if (cat == "bool") {
            return "if (" + nm + ") { Console.WriteLine(\"@ZV@" + nm + "\\ttrue\"); }"
                + " else { Console.WriteLine(\"@ZV@" + nm + "\\tfalse\"); }\n";
        }
        if (cat == "list" && level == 0) {
            string s = nm + "__zv";
            return "string " + s + " = \"[\";\n"
                + "int " + s + "i = 0;\n"
                + "foreach (" + elem + " " + s + "e in " + nm + ") {"
                + " if (" + s + "i > 0) { " + s + " = " + s + " + \", \"; }"
                + " " + s + " = " + s + " + (\"\" + " + s + "e); " + s + "i = " + s + "i + 1; }\n"
                + s + " = " + s + " + \"]\";\n"
                + "Console.WriteLine(\"@ZV@" + nm + "\\t\" + " + s + ");\n";
        }
        return "";
    }

    static bool StartsWith(string s, string pfx) {
        if (s.Length < pfx.Length) { return false; }
        return s.Substring(0, pfx.Length) == pfx;
    }

    /// Path of the active tab, or "" if none.
    static string PathOf(List<string> paths, SignalInt active) {
        int a = active.Get();
        if (a >= 0 && a < paths.Count) { return paths[a]; }
        return "";
    }

    /// Computes real variable values at `line` by running an instrumented copy
    /// of the program: after the breakpoint line we inject prints of each
    /// in-scope variable, compile the whole project (`curPath` replaced by the
    /// instrumented probe, plus every sibling project .zan file), run it, and
    /// read back the actual values (so `1+5` shows `6`, lists show `[1, 2]`).
    /// The program's own stdout is captured into `consoleOut`. Variables the
    /// debugger can't evaluate keep their source-expression text so every
    /// declared variable is still listed.
    static List<string> DebugVarsAt(string root, string curPath, string src, int line,
            List<string> consoleOut) {
        while (consoleOut.Count > 0) { consoleOut.RemoveAt(consoleOut.Count - 1); }
        // Base list: every declared variable with its source-expression value.
        List<string> vars = IdeDemo.ParseVarsSimple(src, line);
        if (line < 0) { return vars; }

        List<string> lines = CodeEditor.SplitLines(src);
        int maxL = line;
        if (maxL >= lines.Count) { maxL = lines.Count - 1; }

        // Collect in-scope evaluable locals declared up to the breakpoint line.
        List<string> names = new List<string>();
        List<string> types = new List<string>();
        List<int> declDepth = new List<int>();
        List<int> alive = new List<int>();
        List<string> cats = new List<string>();
        List<string> elems = new List<string>();
        int depth = 0;
        int li = 0;
        while (li <= maxL) {
            string tr = IdeDemo.TrimLeadSpaces(lines[li]);
            IdeDemo.CollectVar(names, types, declDepth, alive, cats, elems, tr, depth);
            depth = depth + IdeDemo.BraceDelta(lines[li]);
            int ki = 0;
            while (ki < declDepth.Count) {
                if (declDepth[ki] > depth) { alive[ki] = 0; }
                ki = ki + 1;
            }
            li = li + 1;
        }
        int insertDepth = depth;

        // Only instrument when the breakpoint is inside a function body.
        if (insertDepth < 1) { return vars; }

        string bd = IdeDemo.EnsureBuildDir(root);
        string probe = bd + "/.zandbg_probe.zan";
        string ll = bd + "/.zandbg.ll";
        string exe = bd + "/.zandbg" + IdeDemo.ExeSuffix();
        string gatherDir = root;
        if (curPath.Length > 0) { gatherDir = IdeDemo.DirOf(curPath); }

        // level 0 = include lists; level 1 = scalar/bool only (retry).
        List<string> runOut = new List<string>();
        bool ok = false;
        int level = 0;
        while (level <= 1 && !ok) {
            string instr = "";
            int lj = 0;
            while (lj < lines.Count) {
                instr = instr + lines[lj] + "\n";
                if (lj == maxL) {
                    int ki = 0;
                    while (ki < names.Count) {
                        if (alive[ki] == 1 && declDepth[ki] <= insertDepth && declDepth[ki] >= 1) {
                            instr = instr + IdeDemo.EmitVarProbe(names[ki], cats[ki], elems[ki], level);
                        }
                        ki = ki + 1;
                    }
                }
                lj = lj + 1;
            }
            File.WriteAllText(probe, instr);
            #if WINDOWS
            Process.Run("cmd /c del /f /q \"" + exe + "\" >nul 2>nul");
            #else
            Process.Run("rm -f \"" + exe + "\" >/dev/null 2>&1");
            #endif
            string inputs = IdeDemo.ProjectInputs(gatherDir, probe, curPath);
            string buildCmd = IdeDemo.ZancCmd() + " --emit-ir " + inputs + " > \"" + ll + "\""
                + " && clang \"" + ll + "\" -o \"" + exe + "\"";
            List<string> buildOut = Process.RunCapture(buildCmd);
            if (File.Exists(exe)) {
                runOut = Process.RunCapture("\"" + exe + "\"");
                ok = true;
            } else if (level == 1) {
                consoleOut.Add("(could not evaluate live values; showing source expressions)");
                int bo = 0;
                while (bo < buildOut.Count && bo < 8) {
                    consoleOut.Add(buildOut[bo]);
                    bo = bo + 1;
                }
                return vars;
            }
            level = level + 1;
        }

        // Merge real values over the source-expression base (first hit only),
        // and collect the program's own stdout.
        List<string> gotName = new List<string>();
        int ri = 0;
        while (ri < runOut.Count) {
            string ln = runOut[ri];
            if (IdeDemo.StartsWith(ln, "@ZV@")) {
                string bodyv = ln.Substring(4, ln.Length - 4);
                int tabAt = IdeDemo.StrFind(bodyv, "\t");
                if (tabAt >= 0) {
                    string nm = bodyv.Substring(0, tabAt);
                    string vv = bodyv.Substring(tabAt + 1, bodyv.Length - (tabAt + 1));
                    if (gotName.IndexOf(nm) < 0) {
                        gotName.Add(nm);
                        IdeDemo.OverrideVarValue(vars, nm, vv);
                    }
                }
            } else {
                if (consoleOut.Count < 500) { consoleOut.Add(ln); }
            }
            ri = ri + 1;
        }
        if (consoleOut.Count == 0) { consoleOut.Add("(no output)"); }
        return vars;
    }

    /// Replaces the value field (3rd tab-separated field) of the variable named
    /// `nm` in `vars` with `vv`; appends a new entry if it wasn't listed.
    static void OverrideVarValue(List<string> vars, string nm, string vv) {
        int i = 0;
        while (i < vars.Count) {
            if (IdeDemo.GetTabField(vars[i], 0) == nm) {
                string ty = IdeDemo.GetTabField(vars[i], 1);
                vars[i] = nm + "\t" + ty + "\t" + vv;
                return;
            }
            i = i + 1;
        }
        vars.Add(nm + "\t\t" + vv);
    }

    /// Directory portion of a path (before the last '/' or '\'), or "." if none.
    static string DirOf(string path) {
        int last = 0 - 1;
        int i = 0;
        while (i < path.Length) {
            string ch = path.Substring(i, 1);
            if (ch == "/" || ch == "\\") { last = i; }
            i = i + 1;
        }
        if (last < 0) { return "."; }
        return path.Substring(0, last);
    }

    static bool IsZanFile(string name) {
        int n = name.Length;
        if (n < 4) { return false; }
        return name.Substring(n - 4, 4) == ".zan";
    }

    /// Recursively collects full paths of project .zan source files under `dir`,
    /// skipping IDE temp files (names starting with ".") and build/publish output
    /// directories, so a project can span multiple files.
    static void GatherZanFiles(string dir, List<string> outp) {
        List<string> files = Directory.GetFiles(dir);
        int j = 0;
        while (j < files.Count) {
            string nm = files[j];
            if (IdeDemo.IsZanFile(nm) && nm.Substring(0, 1) != ".") {
                outp.Add(dir + "/" + nm);
            }
            j = j + 1;
        }
        List<string> subs = Directory.GetDirectories(dir);
        int i = 0;
        while (i < subs.Count) {
            string sn = subs[i];
            if (sn.Substring(0, 1) != "." && sn != "publish" && sn != "build"
                && sn != "bin" && sn != "obj" && sn != "dist") {
                IdeDemo.GatherZanFiles(dir + "/" + sn, outp);
            }
            i = i + 1;
        }
    }

    /// Builds the quoted, space-joined zanc input list for a whole-project build:
    /// `entry` first (so it becomes the compiler's primary input), then every
    /// other project .zan file except `skip` (e.g. the original of a probe).
    static string ProjectInputs(string dir, string entry, string skip) {
        string args = "\"" + entry + "\"";
        List<string> all = new List<string>();
        IdeDemo.GatherZanFiles(dir, all);
        int i = 0;
        while (i < all.Count) {
            string f = all[i];
            if (f != entry && f != skip) {
                args = args + " \"" + f + "\"";
            }
            i = i + 1;
        }
        return args;
    }

    static List<string> ParseVarsSimple(string src, int line) {
        List<string> result = new List<string>();
        if (line < 0) { return result; }
        List<string> lines = CodeEditor.SplitLines(src);
        int maxL = line;
        if (maxL >= lines.Count) { maxL = lines.Count - 1; }
        int li = 0;
        while (li <= maxL) {
            string ln = lines[li];
            string tr = IdeDemo.TrimLeadSpaces(ln);
            if (tr.Length > 2) {
                IdeDemo.TryAddVar(result, tr, "int ");
                IdeDemo.TryAddVar(result, tr, "string ");
                IdeDemo.TryAddVar(result, tr, "bool ");
                IdeDemo.TryAddVar(result, tr, "float ");
                IdeDemo.TryAddVar(result, tr, "double ");
                IdeDemo.TryAddVar(result, tr, "long ");
                IdeDemo.TryAddVar(result, tr, "char ");
                IdeDemo.TryAddVar(result, tr, "var ");
                // Also detect List<...> and other generic types
                IdeDemo.TryAddGenericVar(result, tr);
            }
            li = li + 1;
        }
        return result;
    }

    static string TrimLeadSpaces(string s) {
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == " " || ch == "\t") { i = i + 1; }
            else { break; }
        }
        if (i == 0) { return s; }
        return s.Substring(i, s.Length - i);
    }

    static void TryAddVar(List<string> result, string tr, string typePrefix) {
        if (tr.Length <= typePrefix.Length) { return; }
        string head = tr.Substring(0, typePrefix.Length);
        if (head != typePrefix) { return; }
        string rest = tr.Substring(typePrefix.Length, tr.Length - typePrefix.Length);
        string name = IdeDemo.ExtractIdent(rest, 0);
        if (name.Length == 0) { return; }
        int ni = name.Length;
        while (ni < rest.Length && rest.Substring(ni, 1) == " ") { ni = ni + 1; }
        string val = IdeDemo.ExtractValue(rest, ni);
        string typeName = IdeDemo.TrimTrailSpaces(typePrefix);
        result.Add(name + "\t" + typeName + "\t" + val);
    }

    static void TryAddGenericVar(List<string> result, string tr) {
        // Match patterns like: List<string> foo = ...
        string idc = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        int i = 0;
        while (i < tr.Length && CodeEditor.InSet(idc, tr.Substring(i, 1))) { i = i + 1; }
        if (i == 0) { return; }
        if (i >= tr.Length) { return; }
        if (tr.Substring(i, 1) != "<") { return; }
        // Found a generic type name
        string typeName = tr.Substring(0, i);
        // skip to closing >
        int depth = 1;
        int j = i + 1;
        while (j < tr.Length && depth > 0) {
            string ch = tr.Substring(j, 1);
            if (ch == "<") { depth = depth + 1; }
            if (ch == ">") { depth = depth - 1; }
            j = j + 1;
        }
        if (depth != 0) { return; }
        string fullType = tr.Substring(0, j);
        // skip spaces
        while (j < tr.Length && tr.Substring(j, 1) == " ") { j = j + 1; }
        if (j >= tr.Length) { return; }
        string rest = tr.Substring(j, tr.Length - j);
        string name = IdeDemo.ExtractIdent(rest, 0);
        if (name.Length == 0) { return; }
        int ni = name.Length;
        while (ni < rest.Length && rest.Substring(ni, 1) == " ") { ni = ni + 1; }
        string val = IdeDemo.ExtractValue(rest, ni);
        result.Add(name + "\t" + fullType + "\t" + val);
    }

    static string ExtractIdent(string s, int start) {
        string idc = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string name = "";
        int i = start;
        while (i < s.Length && CodeEditor.InSet(idc, s.Substring(i, 1))) {
            name = name + s.Substring(i, 1);
            i = i + 1;
        }
        return name;
    }

    static string ExtractValue(string rest, int ni) {
        if (ni >= rest.Length) { return "(uninitialized)"; }
        if (rest.Substring(ni, 1) != "=") { return "(uninitialized)"; }
        ni = ni + 1;
        while (ni < rest.Length && rest.Substring(ni, 1) == " ") { ni = ni + 1; }
        string val = "";
        while (ni < rest.Length && rest.Substring(ni, 1) != ";") {
            val = val + rest.Substring(ni, 1);
            ni = ni + 1;
        }
        if (val.Length == 0) { return "(empty)"; }
        return val;
    }

    static string TrimTrailSpaces(string s) {
        int e = s.Length;
        while (e > 0 && s.Substring(e - 1, 1) == " ") { e = e - 1; }
        if (e == s.Length) { return s; }
        return s.Substring(0, e);
    }

    static List<string> BuildStack(List<string> tabNames, SignalInt activeTab, int line) {
        List<string> stack = new List<string>();
        string fname = "";
        int at = activeTab.Get();
        if (at >= 0 && at < tabNames.Count) { fname = tabNames[at]; }
        stack.Add(fname + " : line " + Convert.ToString(line + 1));
        return stack;
    }

    static void RenderDebugBottom(App app, Canvas c, Theme t, Rect orr, int tab,
            List<string> console, List<string> vars, List<string> stack, List<string> log) {
        int tabH = app.Scale(28);
        int tabW = app.Scale(80);
        int pad = app.Scale(4);
        int rowH = app.Scale(18);

        // Tab bar
        c.FillRect(orr.x, orr.y, orr.width, tabH, 0xFF252526);
        c.FillRect(orr.x, orr.y + tabH - 1, orr.width, 1, t.divider);

        // Tab 0: Console
        int bg0 = 0xFF333333;
        if (tab == 0) { bg0 = 0xFF1E1E1E; }
        c.FillRect(orr.x, orr.y, tabW, tabH, bg0);
        c.DrawText(orr.x + app.Scale(6), orr.y + app.Scale(6), "Console", t.textPrimary, t.fontSizeSmall);
        // Tab 1: Variables
        int bg1 = 0xFF333333;
        if (tab == 1) { bg1 = 0xFF1E1E1E; }
        c.FillRect(orr.x + tabW, orr.y, tabW, tabH, bg1);
        c.DrawText(orr.x + tabW + app.Scale(6), orr.y + app.Scale(6), "Variables", t.textPrimary, t.fontSizeSmall);
        // Tab 2: Watch
        int bg2 = 0xFF333333;
        if (tab == 2) { bg2 = 0xFF1E1E1E; }
        c.FillRect(orr.x + tabW + tabW, orr.y, tabW, tabH, bg2);
        c.DrawText(orr.x + tabW + tabW + app.Scale(6), orr.y + app.Scale(6), "Watch", t.textPrimary, t.fontSizeSmall);
        // Tab 3: Call Stack
        int bg3 = 0xFF333333;
        if (tab == 3) { bg3 = 0xFF1E1E1E; }
        c.FillRect(orr.x + tabW + tabW + tabW, orr.y, tabW + app.Scale(10), tabH, bg3);
        c.DrawText(orr.x + tabW + tabW + tabW + app.Scale(6), orr.y + app.Scale(6), "CallStack", t.textPrimary, t.fontSizeSmall);

        // Content area
        int contentY = orr.y + tabH;
        int contentH = orr.height - tabH;
        c.FillRect(orr.x, contentY, orr.width, contentH, 0xFF1E1E1E);

        if (tab == 0) {
            IdeDemo.RenderConsoleTab(app, c, t, orr.x, contentY, orr.width, contentH, console,
                0 - 1, 0, 0 - 1, 0);
        } else if (tab == 1) {
            IdeDemo.RenderVarsTab(app, c, t, orr.x, contentY, orr.width, contentH, vars);
        } else if (tab == 2) {
            IdeDemo.RenderVarsTab(app, c, t, orr.x, contentY, orr.width, contentH, vars);
        } else if (tab == 3) {
            IdeDemo.RenderStackTab(app, c, t, orr.x, contentY, orr.width, contentH, stack);
        }
    }

    static void LogVarsToConsole(List<string> log, List<string> vars, int execLine) {
        log.Add("> --- Line " + Convert.ToString(execLine + 1) + " ---");
        int vi = 0;
        while (vi < vars.Count) {
            string entry = vars[vi];
            string vn = IdeDemo.GetTabField(entry, 0);
            string vt = IdeDemo.GetTabField(entry, 1);
            string vv = IdeDemo.GetTabField(entry, 2);
            log.Add(">   " + vn + " : " + vt + " = " + vv);
            vi = vi + 1;
        }
    }

    static void RenderConsoleTab(App app, Canvas c, Theme t,
            int x, int y, int w, int h, List<string> lines,
            int selR0, int selC0, int selR1, int selC1) {
        int rowH = app.Scale(18);
        int pad = app.Scale(6);
        int maxRows = h / rowH;
        int startIdx = 0;
        if (lines.Count > maxRows) { startIdx = lines.Count - maxRows; }
        // Normalize the selection so (selR0,selC0) precedes (selR1,selC1).
        if (selR0 >= 0) {
            if (selR0 > selR1 || (selR0 == selR1 && selC0 > selC1)) {
                int tr = selR0; selR0 = selR1; selR1 = tr;
                int tc = selC0; selC0 = selC1; selC1 = tc;
            }
        }
        int ri = startIdx;
        int cy = y + pad;
        while (ri < lines.Count && cy + rowH <= y + h) {
            string ln = lines[ri];
            // Selection highlight for this row (drawn behind the text).
            if (selR0 >= 0 && ri >= selR0 && ri <= selR1) {
                int hs = 0;
                int he = ln.Length;
                if (ri == selR0) { hs = selC0; }
                if (ri == selR1) { he = selC1; }
                if (hs < 0) { hs = 0; }
                if (he > ln.Length) { he = ln.Length; }
                if (hs > he) { hs = he; }
                int hx0 = x + pad + Canvas.MeasureText(Text.Left(ln, hs), t.fontSizeSmall);
                int hx1 = x + pad + Canvas.MeasureText(Text.Left(ln, he), t.fontSizeSmall);
                // Full lines in the middle of a multi-line selection extend to the
                // right edge so the trailing newline reads as selected.
                if (ri < selR1) { hx1 = hx1 + app.Scale(6); }
                if (hx1 < hx0 + 2) { hx1 = hx0 + 2; }
                c.FillRect(hx0, cy, hx1 - hx0, rowH, 0xFF264F78);
            }
            int textColor = 0xFFCCCCCC;
            // Color debug output lines
            if (ln.Length > 2) {
                string prefix = ln.Substring(0, 2);
                if (prefix == "> ") {
                    if (ln.Length > 8) {
                        string sub6 = ln.Substring(2, 6);
                        if (sub6 == "[Debug") { textColor = 0xFF4EC9B0; }
                        else if (sub6 == "--- Li") { textColor = 0xFF569CD6; }
                        else if (sub6 == "  ") { textColor = 0xFFCE9178; }
                    }
                }
            }
            c.DrawText(x + pad, cy, ln, textColor, t.fontSizeSmall);
            cy = cy + rowH;
            ri = ri + 1;
        }
        if (lines.Count == 0) {
            c.DrawText(x + pad, y + pad, "(no console output)", 0xFF666666, t.fontSizeSmall);
        }
    }

    /// Map a pointer Y within the console content rect to an absolute line index
    /// (into `lines`), matching RenderConsoleTab's tail-scroll layout.
    static int ConsoleRowAt(App app, int contentY, int rowH, int pad,
            int count, int maxRows, int mouseY) {
        if (count == 0) { return 0 - 1; }
        int startIdx = 0;
        if (count > maxRows) { startIdx = count - maxRows; }
        int rel = (mouseY - (contentY + pad)) / rowH;
        if (rel < 0) { rel = 0; }
        int ri = startIdx + rel;
        if (ri < 0) { ri = 0; }
        if (ri >= count) { ri = count - 1; }
        return ri;
    }

    /// Map a pointer X to the nearest character boundary within `line`.
    static int ConsoleColAt(string line, int textX, int fontSize, int mouseX) {
        int i = 0;
        while (i < line.Length) {
            int wa = Canvas.MeasureText(Text.Left(line, i), fontSize);
            int wb = Canvas.MeasureText(Text.Left(line, i + 1), fontSize);
            int mid = textX + (wa + wb) / 2;
            if (mouseX < mid) { return i; }
            i = i + 1;
        }
        return line.Length;
    }

    /// Extract the selected text spanning (r0,c0)..(r1,c1) as newline-joined text.
    static string ConsoleSelectionText(List<string> lines,
            int r0, int c0, int r1, int c1) {
        if (r0 < 0 || r1 < 0) { return ""; }
        if (r0 > r1 || (r0 == r1 && c0 > c1)) {
            int tr = r0; r0 = r1; r1 = tr;
            int tc = c0; c0 = c1; c1 = tc;
        }
        string outp = "";
        int r = r0;
        while (r <= r1 && r < lines.Count) {
            string ln = lines[r];
            int s = 0;
            int e = ln.Length;
            if (r == r0) { s = c0; }
            if (r == r1) { e = c1; }
            if (s < 0) { s = 0; }
            if (e > ln.Length) { e = ln.Length; }
            if (s > e) { s = e; }
            outp = outp + ln.Substring(s, e - s);
            if (r < r1) { outp = outp + "\n"; }
            r = r + 1;
        }
        return outp;
    }

    static void RenderVarsTab(App app, Canvas c, Theme t,
            int x, int y, int w, int h, List<string> vars) {
        int rowH = app.Scale(20);
        int pad = app.Scale(4);
        int colName = app.Scale(120);
        int colType = app.Scale(100);
        // Header
        c.FillRect(x, y, w, rowH, 0xFF2D2D30);
        c.DrawText(x + pad, y + pad, "Name", 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRect(x + colName - 1, y, 1, rowH, 0xFF444444);
        c.DrawText(x + colName + pad, y + pad, "Type", 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRect(x + colName + colType - 1, y, 1, rowH, 0xFF444444);
        c.DrawText(x + colName + colType + pad, y + pad, "Value", 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRect(x, y + rowH, w, 1, t.divider);
        int cy = y + rowH + 1;
        int ri = 0;
        while (ri < vars.Count && cy + rowH <= y + h) {
            int bg = 0xFF1E1E1E;
            if (ri % 2 == 1) { bg = 0xFF252526; }
            c.FillRect(x, cy, w, rowH, bg);
            // Parse tab-separated: name\ttype\tvalue
            string entry = vars[ri];
            string vName = IdeDemo.GetTabField(entry, 0);
            string vType = IdeDemo.GetTabField(entry, 1);
            string vVal = IdeDemo.GetTabField(entry, 2);
            c.DrawText(x + pad, cy + pad, vName, 0xFF9CDCFE, t.fontSizeSmall);
            c.FillRect(x + colName - 1, cy, 1, rowH, 0xFF333333);
            c.DrawText(x + colName + pad, cy + pad, vType, 0xFF4EC9B0, t.fontSizeSmall);
            c.FillRect(x + colName + colType - 1, cy, 1, rowH, 0xFF333333);
            c.DrawText(x + colName + colType + pad, cy + pad, vVal, 0xFFCE9178, t.fontSizeSmall);
            cy = cy + rowH;
            ri = ri + 1;
        }
        if (vars.Count == 0) {
            c.DrawText(x + pad, y + rowH + pad + pad, "(no variables in scope)", 0xFF666666, t.fontSizeSmall);
        }
    }

    static string GetTabField(string s, int fieldIdx) {
        int fi = 0;
        int start = 0;
        int i = 0;
        while (i < s.Length) {
            if (s.Substring(i, 1) == "\t") {
                if (fi == fieldIdx) {
                    return s.Substring(start, i - start);
                }
                fi = fi + 1;
                start = i + 1;
            }
            i = i + 1;
        }
        if (fi == fieldIdx) {
            return s.Substring(start, s.Length - start);
        }
        return "";
    }

    static void RenderStackTab(App app, Canvas c, Theme t,
            int x, int y, int w, int h, List<string> stack) {
        int rowH = app.Scale(22);
        int pad = app.Scale(6);
        c.FillRect(x, y, w, rowH, 0xFF2D2D30);
        c.DrawText(x + pad, y + pad, "Call Stack", 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRect(x, y + rowH, w, 1, t.divider);
        int cy = y + rowH + 1;
        int ri = 0;
        while (ri < stack.Count && cy + rowH <= y + h) {
            int bg = 0xFF1E1E1E;
            if (ri == 0) { bg = 0xFF264F78; }
            c.FillRect(x, cy, w, rowH, bg);
            c.DrawText(x + pad, cy + pad, stack[ri], 0xFFDCDCAA, t.fontSizeSmall);
            cy = cy + rowH;
            ri = ri + 1;
        }
    }

    static void RenderInlineVars(App app, Canvas c, Theme t, Rect edRect,
            List<string> varInfo, int execLine) {
        if (varInfo.Count == 0) { return; }
        int fontSize = t.fontSizeSmall;
        int lineH = Canvas.FontHeight(t.fontSizeMedium) + app.Scale(4);
        if (lineH < 1) { lineH = 1; }
        // Build inline text from all variables
        string inlineText = "";
        int vi = 0;
        while (vi < varInfo.Count) {
            string entry = varInfo[vi];
            string vName = IdeDemo.GetTabField(entry, 0);
            string vVal = IdeDemo.GetTabField(entry, 2);
            if (inlineText.Length > 0) { inlineText = inlineText + "  |  "; }
            inlineText = inlineText + vName + " = " + vVal;
            vi = vi + 1;
        }
        if (inlineText.Length == 0) { return; }
        // Draw at top-right of editor area as an overlay
        int tw = Canvas.MeasureText(inlineText, fontSize) + app.Scale(16);
        int th = app.Scale(22);
        int tx = edRect.x + edRect.width - tw - app.Scale(8);
        int ty = edRect.y + app.Scale(4);
        c.FillRoundRect(tx, ty, tw, th, app.Scale(4), 0xDD1E1E1E);
        c.DrawRect(tx, ty, tw, th, 0xFF569CD6, 1);
        c.DrawText(tx + app.Scale(8), ty + app.Scale(4), inlineText, 0xFFCE9178, fontSize);
    }

    static void RenderDebugToolbar(App app, Canvas c, Theme t,
            int x, int y, int w, int h, int execLine) {
        c.FillRect(x, y, w, h, 0xFF1E1E1E);
        c.FillRect(x, y + h - 1, w, 1, t.divider);
        int btnW = app.Scale(80);
        int btnH = app.Scale(26);
        int gap = app.Scale(6);
        int bx = x + app.Scale(10);
        int by = y + (h - btnH) / 2;
        // Continue (green)
        c.FillRoundRect(bx, by, btnW, btnH, app.Scale(4), 0xFF388E3C);
        c.DrawText(bx + app.Scale(8), by + app.Scale(5), "Continue", 0xFFFFFFFF, t.fontSizeSmall);
        bx = bx + btnW + gap;
        // Step Over (blue)
        c.FillRoundRect(bx, by, btnW, btnH, app.Scale(4), 0xFF1565C0);
        c.DrawText(bx + app.Scale(6), by + app.Scale(5), "Step Over", 0xFFFFFFFF, t.fontSizeSmall);
        bx = bx + btnW + gap;
        // Step Into (blue)
        c.FillRoundRect(bx, by, btnW, btnH, app.Scale(4), 0xFF1565C0);
        c.DrawText(bx + app.Scale(6), by + app.Scale(5), "Step Into", 0xFFFFFFFF, t.fontSizeSmall);
        bx = bx + btnW + gap;
        // Stop (red)
        c.FillRoundRect(bx, by, btnW, btnH, app.Scale(4), 0xFFC62828);
        c.DrawText(bx + app.Scale(18), by + app.Scale(5), "Stop", 0xFFFFFFFF, t.fontSizeSmall);
        bx = bx + btnW + gap + gap;
        // Line info
        string lineInfo = "Line: " + Convert.ToString(execLine + 1);
        c.DrawText(bx, by + app.Scale(5), lineInfo, 0xFFCCCCCC, t.fontSizeSmall);
    }

    // ================================================================
    // Designer
    // ================================================================

    static int SnapGrid(int v, int grid) {
        int r = v / grid;
        if (v - r * grid > grid / 2) { r = r + 1; }
        return r * grid;
    }

    /// Draws a [-][+] stepper pair right-aligned to `rightX` on row `rowY`.
    static void DrawStepper(App app, Canvas c, Theme t, int rightX, int rowY) {
        int btnW = app.Scale(18);
        int btnH = app.Scale(15);
        int btnY = rowY - app.Scale(1);
        int plusX = rightX - app.Scale(8) - btnW;
        int minusX = plusX - app.Scale(2) - btnW;
        c.FillRoundRect(minusX, btnY, btnW, btnH, app.Scale(2), 0xFF3E3E42);
        c.DrawText(minusX + app.Scale(6), btnY + app.Scale(1), "-", 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRoundRect(plusX, btnY, btnW, btnH, app.Scale(2), 0xFF0E639C);
        c.DrawText(plusX + app.Scale(5), btnY + app.Scale(1), "+", 0xFFFFFFFF, t.fontSizeSmall);
    }

    /// Hit-tests a DrawStepper pair. Returns +1 (plus), -1 (minus), 0 (none).
    static int StepperHit(App app, int mx, int my, int rightX, int rowY) {
        int btnW = app.Scale(18);
        int btnH = app.Scale(15);
        int btnY = rowY - app.Scale(1);
        int plusX = rightX - app.Scale(8) - btnW;
        int minusX = plusX - app.Scale(2) - btnW;
        if (my < btnY || my >= btnY + btnH) { return 0; }
        if (mx >= minusX && mx < minusX + btnW) { return 0 - 1; }
        if (mx >= plusX && mx < plusX + btnW) { return 1; }
        return 0;
    }

    static string ExampleCat(int idx) {
        if (idx == 0 || idx == 1 || idx == 2) { return "Basics"; }
        if (idx == 3 || idx == 6 || idx == 7 || idx == 8) { return "GUI & Apps"; }
        return "Network & Data";
    }

    static string ExampleDesc(int idx) {
        if (idx == 0) { return "Console I/O: print and read a line."; }
        if (idx == 1) { return "Read/write files and list a directory."; }
        if (idx == 2) { return "List operations with LINQ (OrderBy/Where/Sum)."; }
        if (idx == 3) { return "A Gui window with an event loop."; }
        if (idx == 4) { return "HTTP GET/POST with HttpClient."; }
        if (idx == 5) { return "Parse and build JSON."; }
        if (idx == 6) { return "Timers and event handling."; }
        if (idx == 7) { return "A small calculator app."; }
        if (idx == 8) { return "A minimal text editor."; }
        return "";
    }

    // Builds the sidebar Examples tree: category folders with sample leaves.
    // Each leaf carries "@ex:<idx>" in its path so a click can open the sample.
    static List<TreeNode> BuildExampleTree() {
        List<TreeNode> n = new List<TreeNode>();
        n.Add(TreeNode.Dir("Basics", 0, true));
        n.Add(IdeDemo.ExLeaf("Hello World", 0));
        n.Add(IdeDemo.ExLeaf("File Read/Write", 1));
        n.Add(IdeDemo.ExLeaf("List & LINQ", 2));
        n.Add(TreeNode.Dir("GUI & Apps", 0, true));
        n.Add(IdeDemo.ExLeaf("GUI Window", 3));
        n.Add(IdeDemo.ExLeaf("Timer & Events", 6));
        n.Add(IdeDemo.ExLeaf("Calculator", 7));
        n.Add(IdeDemo.ExLeaf("Text Editor", 8));
        n.Add(TreeNode.Dir("Network & Data", 0, true));
        n.Add(IdeDemo.ExLeaf("HTTP Client", 4));
        n.Add(IdeDemo.ExLeaf("JSON Parse", 5));
        return n;
    }

    static TreeNode ExLeaf(string label, int idx) {
        TreeNode f = TreeNode.FileIcon(label, 1, "file");
        f.path = "@ex:" + Convert.ToString(idx);
        return f;
    }

    // Returns the index of the first tab whose path equals p, or -1.
    static int FindTabByPath(List<string> paths, string p) {
        int i = 0;
        while (i < paths.Count) {
            if (paths[i] == p) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    // Start page (welcome): quick actions + project file list.
    // Returns 0 = none, 1 = New Project, 2 = New File, 100+idx = open files[idx].
    static int RenderStartPage(App app, Canvas c, Theme t, Rect area, List<string> files) {
        int result = 0;
        c.FillRect(area.x, area.y, area.width, area.height, 0xFF1E1E1E);
        int pad = app.Scale(32);
        int x0 = area.x + pad;
        int y = area.y + pad;
        c.DrawText(x0, y, "Zan IDE", 0xFFFFFFFF, t.fontSizeLarge);
        y = y + app.Scale(30);
        c.DrawText(x0, y, "Self-hosted IDE  -  Start", 0xFF888888, t.fontSizeSmall);
        y = y + app.Scale(34);

        int mx = app.mouseX;
        int my = app.mouseY;
        int evKind = app.window.EventKind();

        // ---- Quick actions ----
        c.DrawText(x0, y, "Get started", 0xFFCCCCCC, t.fontSizeMedium);
        y = y + app.Scale(26);
        int btnW = app.Scale(240);
        int btnH = app.Scale(40);
        int gap = app.Scale(10);

        int npY = y;
        c.FillRoundRect(x0, npY, btnW, btnH, app.Scale(4), 0xFF0E639C);
        c.DrawText(x0 + app.Scale(14), npY + app.Scale(13), "New Project...", 0xFFFFFFFF, t.fontSizeSmall);
        y = y + btnH + gap;

        int nfY = y;
        c.FillRoundRect(x0, nfY, btnW, btnH, app.Scale(4), 0xFF3E3E42);
        c.DrawText(x0 + app.Scale(14), nfY + app.Scale(13), "New File...", 0xFFCCCCCC, t.fontSizeSmall);
        y = y + btnH + gap;

        if (evKind == 3) {
            if (mx >= x0 && mx < x0 + btnW && my >= npY && my < npY + btnH) { result = 1; }
            else if (mx >= x0 && mx < x0 + btnW && my >= nfY && my < nfY + btnH) { result = 2; }
        }

        // ---- Project files list (right column) ----
        int colX = x0 + btnW + app.Scale(48);
        int colY = area.y + pad + app.Scale(64);
        c.DrawText(colX, colY - app.Scale(26), "Project files (src)", 0xFFCCCCCC, t.fontSizeMedium);
        int rowH = app.Scale(24);
        int maxRows = (area.y + area.height - app.Scale(16) - colY) / rowH;
        int shown = files.Count;
        if (shown > maxRows) { shown = maxRows; }
        int i = 0;
        while (i < shown) {
            int ry = colY + i * rowH;
            bool hot = (mx >= colX && mx < colX + app.Scale(320) && my >= ry && my < ry + rowH);
            if (hot) { c.FillRect(colX - app.Scale(4), ry, app.Scale(324), rowH, 0xFF2A2D2E); }
            c.DrawText(colX, ry + app.Scale(5), Path.GetFileName(files[i]), 0xFF9CDCFE, t.fontSizeSmall);
            if (evKind == 3 && hot) { result = 100 + i; }
            i = i + 1;
        }
        if (files.Count == 0) {
            c.DrawText(colX, colY + app.Scale(5), "(no .zan files under src/)", 0xFF666666, t.fontSizeSmall);
        }

        c.DrawText(x0, area.y + area.height - app.Scale(16),
            "Tip: click Start in the ribbon to toggle this page.", 0xFF666666, t.fontSizeSmall);
        return result;
    }

    static int RenderDesigner(App app, Canvas c, Theme t, Rect area,
            List<string> dNames, List<int> dX, List<int> dY,
            List<int> dW, List<int> dH, List<string> dTypes, SignalInt dSel,
            SignalInt dragMode, SignalInt dragOffX, SignalInt dragOffY, SignalInt resizeH,
            SignalInt preview) {
        int dSelV = dSel.Get();
        int result = 0;
        int previewOn = preview.Get();
        int gridSz = app.Scale(8);
        c.FillRect(area.x, area.y, area.width, area.height, 0xFF2D2D30);

        // Toolbox panel on left
        int toolW = app.Scale(140);
        c.FillRect(area.x, area.y, toolW, area.height, 0xFF252526);
        c.FillRect(area.x + toolW - 1, area.y, 1, area.height, t.divider);
        c.DrawText(area.x + app.Scale(8), area.y + app.Scale(6), "TOOLBOX", 0xFFCCCCCC, t.fontSizeSmall);
        int ty = area.y + app.Scale(28);
        int toolH2 = app.Scale(24);
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "Button", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "Label", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "TextBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "CheckBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ComboBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ListBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "Panel", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "GroupBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "TabControl", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "TreeView", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ListView", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "DataGrid", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "MenuStrip", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ToolStrip", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "StatusBar", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ProgressBar", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "PictureBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "RichTextBox", t);

        // "View Code" opens the associated code-behind (.zan), like WinForms.
        // The form layout itself is auto-saved to the .zform file by the host.
        int dbBtnH = app.Scale(26);
        int dbGenY = area.y + area.height - dbBtnH - app.Scale(8);
        c.FillRoundRect(area.x + app.Scale(8), dbGenY, toolW - app.Scale(16), dbBtnH, app.Scale(3), 0xFF0E639C);
        int dbGenTw = Canvas.MeasureText("View Code (F7)", t.fontSizeSmall);
        c.DrawText(area.x + (toolW - dbGenTw) / 2, dbGenY + app.Scale(7), "View Code (F7)", 0xFFFFFFFF, t.fontSizeSmall);
        // Live-preview toggle: hides the grid + selection handles for a clean,
        // runtime-like view that still updates as the layout changes.
        int pvBtnY = dbGenY - dbBtnH - app.Scale(6);
        int pvBg = 0xFF3C3C3C;
        if (previewOn == 1) { pvBg = 0xFF0E7A45; }
        c.FillRoundRect(area.x + app.Scale(8), pvBtnY, toolW - app.Scale(16), dbBtnH, app.Scale(3), pvBg);
        string pvLabel = "Preview: Off";
        if (previewOn == 1) { pvLabel = "Preview: On"; }
        int pvTw = Canvas.MeasureText(pvLabel, t.fontSizeSmall);
        c.DrawText(area.x + (toolW - pvTw) / 2, pvBtnY + app.Scale(7), pvLabel, 0xFFFFFFFF, t.fontSizeSmall);

        // Properties panel on right
        int propW = app.Scale(180);
        int propX = area.x + area.width - propW;
        c.FillRect(propX, area.y, propW, area.height, 0xFF252526);
        c.FillRect(propX, area.y, 1, area.height, t.divider);
        c.DrawText(propX + app.Scale(8), area.y + app.Scale(6), "PROPERTIES", 0xFFCCCCCC, t.fontSizeSmall);

        if (dSelV >= 0 && dSelV < dNames.Count) {
            int py = area.y + app.Scale(28);
            int lblW = app.Scale(60);
            c.DrawText(propX + app.Scale(8), py, "Name:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, dNames[dSelV], 0xFFCCCCCC, t.fontSizeSmall);
            py = py + app.Scale(20);
            c.DrawText(propX + app.Scale(8), py, "Type:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, dTypes[dSelV], 0xFF4EC9B0, t.fontSizeSmall);
            py = py + app.Scale(20);
            int xRowY = py;
            c.DrawText(propX + app.Scale(8), py, "X:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dX[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            py = py + app.Scale(20);
            int yRowY = py;
            c.DrawText(propX + app.Scale(8), py, "Y:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dY[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            py = py + app.Scale(20);
            int wRowY = py;
            c.DrawText(propX + app.Scale(8), py, "Width:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dW[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            py = py + app.Scale(20);
            int hRowY = py;
            c.DrawText(propX + app.Scale(8), py, "Height:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dH[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);

            // Property stepper clicks (grid-sized nudge of the selected control).
            if (app.window.EventKind() == 3) {
                int step = app.Scale(8);
                int sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, xRowY);
                if (sd != 0) { dX[dSelV] = dX[dSelV] + sd * step; if (dX[dSelV] < 0) { dX[dSelV] = 0; } app.RequestRedraw(); }
                sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, yRowY);
                if (sd != 0) { dY[dSelV] = dY[dSelV] + sd * step; if (dY[dSelV] < 0) { dY[dSelV] = 0; } app.RequestRedraw(); }
                sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, wRowY);
                if (sd != 0) { dW[dSelV] = dW[dSelV] + sd * step; if (dW[dSelV] < app.Scale(16)) { dW[dSelV] = app.Scale(16); } app.RequestRedraw(); }
                sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, hRowY);
                if (sd != 0) { dH[dSelV] = dH[dSelV] + sd * step; if (dH[dSelV] < app.Scale(16)) { dH[dSelV] = app.Scale(16); } app.RequestRedraw(); }
            }
            py = py + app.Scale(24);
            c.FillRect(propX + app.Scale(4), py, propW - app.Scale(8), 1, t.divider);
            py = py + app.Scale(8);
            c.DrawText(propX + app.Scale(8), py, "Events:", 0xFF999999, t.fontSizeSmall);
            py = py + app.Scale(18);
            c.DrawText(propX + app.Scale(8), py, "Click", 0xFF569CD6, t.fontSizeSmall);
            py = py + app.Scale(18);
            c.DrawText(propX + app.Scale(8), py, "Load", 0xFF569CD6, t.fontSizeSmall);
            py = py + app.Scale(18);
            c.DrawText(propX + app.Scale(8), py, "TextChanged", 0xFF569CD6, t.fontSizeSmall);
        } else {
            c.DrawText(propX + app.Scale(8), area.y + app.Scale(28), "(no selection)", 0xFF666666, t.fontSizeSmall);
        }

        // Design surface (center area)
        int surfX = area.x + toolW;
        int surfW = area.width - toolW - propW;

        // Draw grid dots (design view only).
        if (previewOn == 0) {
            int gx = surfX + gridSz;
            while (gx < surfX + surfW) {
                int gy2 = area.y + gridSz;
                while (gy2 < area.y + area.height) {
                    c.FillRect(gx, gy2, 1, 1, 0xFF444444);
                    gy2 = gy2 + gridSz * 2;
                }
                gx = gx + gridSz * 2;
            }
        }

        // Form outline
        int formX = surfX + app.Scale(20);
        int formY = area.y + app.Scale(16);
        int formW = surfW - app.Scale(40);
        int formH = area.height - app.Scale(32);
        c.FillRect(formX, formY, formW, formH, 0xFF1E1E1E);
        int titleH = app.Scale(28);
        c.FillRect(formX, formY, formW, titleH, 0xFF333333);
        c.DrawText(formX + app.Scale(8), formY + app.Scale(6), "Form1", 0xFFCCCCCC, t.fontSizeSmall);
        // Close/min/max buttons
        int btnSz = app.Scale(12);
        c.FillRect(formX + formW - app.Scale(22), formY + app.Scale(8), btnSz, btnSz, 0xFFE81123);
        c.FillRect(formX + formW - app.Scale(40), formY + app.Scale(8), btnSz, btnSz, 0xFF888888);
        c.FillRect(formX + formW - app.Scale(58), formY + app.Scale(8), btnSz, btnSz, 0xFF888888);
        // Form border
        c.DrawRect(formX, formY, formW, formH, 0xFF555555, 1);

        // Draw placed controls
        int cntX = formX;
        int cntY = formY + titleH;
        int di = 0;
        while (di < dNames.Count) {
            int cx = cntX + dX[di];
            int cy = cntY + dY[di];
            int cw = dW[di];
            int ch = dH[di];
            string cType = dTypes[di];
            // Control rendering per type
            int cbg = 0xFF3C3C3C;
            if (cType == "Button") { cbg = 0xFF404040; }
            if (cType == "TextBox" || cType == "RichTextBox") { cbg = 0xFF1E1E1E; }
            if (cType == "Panel" || cType == "GroupBox") { cbg = 0xFF2D2D30; }
            c.FillRect(cx, cy, cw, ch, cbg);
            if (cType == "Button") {
                c.FillRoundRect(cx + 1, cy + 1, cw - 2, ch - 2, app.Scale(3), 0xFF555555);
                int tw = Canvas.MeasureText(dNames[di], t.fontSizeSmall);
                c.DrawText(cx + (cw - tw) / 2, cy + (ch - app.Scale(12)) / 2, dNames[di], 0xFFFFFFFF, t.fontSizeSmall);
            } else if (cType == "CheckBox") {
                int cbSz = app.Scale(14);
                c.DrawRect(cx + app.Scale(4), cy + (ch - cbSz) / 2, cbSz, cbSz, 0xFF888888, 1);
                c.DrawText(cx + app.Scale(22), cy + app.Scale(4), dNames[di], 0xFFCCCCCC, t.fontSizeSmall);
            } else if (cType == "ProgressBar") {
                c.DrawRect(cx, cy, cw, ch, 0xFF555555, 1);
                c.FillRect(cx + 2, cy + 2, (cw - 4) * 60 / 100, ch - 4, 0xFF007ACC);
            } else {
                c.DrawRect(cx, cy, cw, ch, 0xFF555555, 1);
                c.DrawText(cx + app.Scale(4), cy + app.Scale(3), dNames[di], 0xFFCCCCCC, t.fontSizeSmall);
            }

            // Selection handles (8 handles around control) - design view only.
            if (di == dSelV && previewOn == 0) {
                c.DrawRect(cx - 1, cy - 1, cw + 2, ch + 2, t.primary, 1);
                int hs = app.Scale(6);
                int hh = hs / 2;
                // Top-left, Top-center, Top-right
                c.FillRect(cx - hh, cy - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw / 2 - hh, cy - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw - hh, cy - hh, hs, hs, 0xFFFFFFFF);
                // Mid-left, Mid-right
                c.FillRect(cx - hh, cy + ch / 2 - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw - hh, cy + ch / 2 - hh, hs, hs, 0xFFFFFFFF);
                // Bot-left, Bot-center, Bot-right
                c.FillRect(cx - hh, cy + ch - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw / 2 - hh, cy + ch - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw - hh, cy + ch - hh, hs, hs, 0xFFFFFFFF);
            }
            di = di + 1;
        }

        // ---- Mouse interaction ----
        int mx = app.mouseX;
        int my = app.mouseY;
        int evKind = app.window.EventKind();
        int dm = dragMode.Get();

        // Mouse down - start drag or select
        if (evKind == 3) {
            // Designer action buttons take priority over toolbox rows.
            if (mx >= area.x + app.Scale(8) && mx < area.x + toolW - app.Scale(8)
                && my >= dbGenY && my < dbGenY + dbBtnH) {
                result = 1;
            } else if (mx >= area.x + app.Scale(8) && mx < area.x + toolW - app.Scale(8)
                && my >= pvBtnY && my < pvBtnY + dbBtnH) {
                if (previewOn == 1) { preview.Set(0); } else { preview.Set(1); }
                app.RequestRedraw();
            } else if (mx >= area.x && mx < area.x + toolW && my >= area.y + app.Scale(28)
                && my < pvBtnY - app.Scale(4)) {
                int toolIdx = (my - area.y - app.Scale(28)) / app.Scale(24);
                string newType = IdeDemo.ToolByIndex(toolIdx);
                if (newType != "") {
                    int newIdx = dNames.Count;
                    string newName = newType + Convert.ToString(newIdx + 1);
                    dNames.Add(newName);
                    dX.Add(app.Scale(20));
                    dY.Add(app.Scale(20));
                    dW.Add(app.Scale(100));
                    dH.Add(app.Scale(30));
                    dTypes.Add(newType);
                    dSel.Set(newIdx);
                    app.RequestRedraw();
                }
            }
            // Check click on design surface
            if (mx >= cntX && mx < formX + formW && my >= cntY && my < formY + formH) {
                // Check resize handles first (if something selected)
                if (dSelV >= 0 && dSelV < dNames.Count) {
                    int rh = IdeDemo.HitHandle(app, mx, my, cntX + dX[dSelV], cntY + dY[dSelV], dW[dSelV], dH[dSelV]);
                    if (rh >= 0) {
                        dragMode.Set(2);
                        resizeH.Set(rh);
                        dragOffX.Set(mx);
                        dragOffY.Set(my);
                        app.RequestRedraw();
                    } else {
                        // Check click on controls (top-to-bottom z-order, last is on top)
                        int ci = dNames.Count - 1;
                        bool found = false;
                        while (ci >= 0 && !found) {
                            int ccx = cntX + dX[ci];
                            int ccy = cntY + dY[ci];
                            if (mx >= ccx && mx < ccx + dW[ci] && my >= ccy && my < ccy + dH[ci]) {
                                dSel.Set(ci);
                                dragMode.Set(1);
                                dragOffX.Set(mx - ccx);
                                dragOffY.Set(my - ccy);
                                found = true;
                            }
                            ci = ci - 1;
                        }
                        if (!found) { dSel.Set(-1); }
                        app.RequestRedraw();
                    }
                } else {
                    // No selection, try to select
                    int ci = dNames.Count - 1;
                    bool found = false;
                    while (ci >= 0 && !found) {
                        int ccx = cntX + dX[ci];
                        int ccy = cntY + dY[ci];
                        if (mx >= ccx && mx < ccx + dW[ci] && my >= ccy && my < ccy + dH[ci]) {
                            dSel.Set(ci);
                            dragMode.Set(1);
                            dragOffX.Set(mx - ccx);
                            dragOffY.Set(my - ccy);
                            found = true;
                        }
                        ci = ci - 1;
                    }
                    if (!found) { dSel.Set(-1); }
                    app.RequestRedraw();
                }
            }
        }

        // Mouse move - drag or resize
        if (evKind == 7 && dm > 0 && dSelV >= 0 && dSelV < dNames.Count) {
            if (dm == 1) {
                // Move control
                int newX = mx - dragOffX.Get() - cntX;
                int newY = my - dragOffY.Get() - cntY;
                newX = IdeDemo.SnapGrid(newX, gridSz);
                newY = IdeDemo.SnapGrid(newY, gridSz);
                if (newX < 0) { newX = 0; }
                if (newY < 0) { newY = 0; }
                dX[dSelV] = newX;
                dY[dSelV] = newY;
                app.RequestRedraw();
            }
            if (dm == 2) {
                // Resize control
                int rhi = resizeH.Get();
                int dx = mx - dragOffX.Get();
                int dy = my - dragOffY.Get();
                int ox = dX[dSelV]; int oy = dY[dSelV];
                int ow = dW[dSelV]; int oh = dH[dSelV];
                // Handle 0=TL 1=TC 2=TR 3=ML 4=MR 5=BL 6=BC 7=BR
                if (rhi == 0 || rhi == 3 || rhi == 5) { ox = ox + dx; ow = ow - dx; }
                if (rhi == 0 || rhi == 1 || rhi == 2) { oy = oy + dy; oh = oh - dy; }
                if (rhi == 2 || rhi == 4 || rhi == 7) { ow = ow + dx; }
                if (rhi == 5 || rhi == 6 || rhi == 7) { oh = oh + dy; }
                ow = IdeDemo.SnapGrid(ow, gridSz);
                oh = IdeDemo.SnapGrid(oh, gridSz);
                if (ow < gridSz * 2) { ow = gridSz * 2; }
                if (oh < gridSz * 2) { oh = gridSz * 2; }
                dX[dSelV] = IdeDemo.SnapGrid(ox, gridSz);
                dY[dSelV] = IdeDemo.SnapGrid(oy, gridSz);
                dW[dSelV] = ow;
                dH[dSelV] = oh;
                dragOffX.Set(mx);
                dragOffY.Set(my);
                app.RequestRedraw();
            }
        }

        // Mouse up - end drag
        if (evKind == 10) {
            if (dm > 0) {
                dragMode.Set(0);
                app.RequestRedraw();
            }
        }

        // Delete key removes selected control
        if (evKind == 4 && app.window.EventKeyCode() == 46) {
            if (dSelV >= 0 && dSelV < dNames.Count) {
                dNames.RemoveAt(dSelV);
                dX.RemoveAt(dSelV);
                dY.RemoveAt(dSelV);
                dW.RemoveAt(dSelV);
                dH.RemoveAt(dSelV);
                dTypes.RemoveAt(dSelV);
                dSel.Set(-1);
                dragMode.Set(0);
                app.RequestRedraw();
            }
        }

        // Status text at bottom of design surface
        string statusTxt = "Controls: " + Convert.ToString(dNames.Count);
        if (dSelV >= 0 && dSelV < dNames.Count) {
            statusTxt = statusTxt + "  |  Selected: " + dNames[dSelV]
                + " (" + Convert.ToString(dX[dSelV]) + "," + Convert.ToString(dY[dSelV])
                + " " + Convert.ToString(dW[dSelV]) + "x" + Convert.ToString(dH[dSelV]) + ")";
        }
        c.DrawText(surfX + app.Scale(8), area.y + area.height - app.Scale(16), statusTxt, 0xFF888888, t.fontSizeSmall);
        return result;
    }

    static int HitHandle(App app, int mx, int my, int cx, int cy, int cw, int ch) {
        int hs = app.Scale(8);
        // 0=TL 1=TC 2=TR 3=ML 4=MR 5=BL 6=BC 7=BR
        if (mx >= cx - hs && mx <= cx + hs && my >= cy - hs && my <= cy + hs) { return 0; }
        if (mx >= cx + cw / 2 - hs && mx <= cx + cw / 2 + hs && my >= cy - hs && my <= cy + hs) { return 1; }
        if (mx >= cx + cw - hs && mx <= cx + cw + hs && my >= cy - hs && my <= cy + hs) { return 2; }
        if (mx >= cx - hs && mx <= cx + hs && my >= cy + ch / 2 - hs && my <= cy + ch / 2 + hs) { return 3; }
        if (mx >= cx + cw - hs && mx <= cx + cw + hs && my >= cy + ch / 2 - hs && my <= cy + ch / 2 + hs) { return 4; }
        if (mx >= cx - hs && mx <= cx + hs && my >= cy + ch - hs && my <= cy + ch + hs) { return 5; }
        if (mx >= cx + cw / 2 - hs && mx <= cx + cw / 2 + hs && my >= cy + ch - hs && my <= cy + ch + hs) { return 6; }
        if (mx >= cx + cw - hs && mx <= cx + cw + hs && my >= cy + ch - hs && my <= cy + ch + hs) { return 7; }
        return -1;
    }

    static void DrawToolItem(Canvas c, int x, int y, int w, int h, string label, Theme t) {
        c.DrawText(x + 28, y + 4, label, 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRect(x + 8, y + 5, 14, 14, 0xFF3C3C3C);
        c.FillRect(x + 8, y + 5, 14, 1, 0xFF666666);
        c.FillRect(x + 8, y + 18, 14, 1, 0xFF666666);
        c.FillRect(x + 8, y + 5, 1, 14, 0xFF666666);
        c.FillRect(x + 21, y + 5, 1, 14, 0xFF666666);
    }

    static string ToolByIndex(int idx) {
        if (idx == 0) { return "Button"; }
        if (idx == 1) { return "Label"; }
        if (idx == 2) { return "TextBox"; }
        if (idx == 3) { return "CheckBox"; }
        if (idx == 4) { return "ComboBox"; }
        if (idx == 5) { return "ListBox"; }
        if (idx == 6) { return "Panel"; }
        if (idx == 7) { return "GroupBox"; }
        if (idx == 8) { return "TabControl"; }
        if (idx == 9) { return "TreeView"; }
        if (idx == 10) { return "ListView"; }
        if (idx == 11) { return "DataGrid"; }
        if (idx == 12) { return "MenuStrip"; }
        if (idx == 13) { return "ToolStrip"; }
        if (idx == 14) { return "StatusBar"; }
        if (idx == 15) { return "ProgressBar"; }
        if (idx == 16) { return "PictureBox"; }
        if (idx == 17) { return "RichTextBox"; }
        return "";
    }

    /// Draws a vertically-scrollable icon+label list clipped to [y, y+h): only
    /// rows that fully fit are drawn (Canvas has no clip region), the wheel
    /// scrolls when the pointer is over the area, and a thin thumb shows the
    /// position. Returns the row index clicked this frame, or -1.
    static int RenderScrollList(App app, Canvas c, Theme t,
            int x, int y, int w, int h, int rowH,
            List<string> names, List<int> colors, SignalInt scroll, bool roundIcon) {
        int count = names.Count;
        int maxRows = h / rowH;
        if (maxRows < 1) { maxRows = 1; }
        int maxOff = count - maxRows;
        if (maxOff < 0) { maxOff = 0; }
        int off = scroll.Get();

        int mx = app.mouseX;
        int my = app.mouseY;
        bool over = mx >= x && mx < x + w && my >= y && my < y + h;
        if (app.window.EventKind() == 13 && over) {
            int delta = app.window.EventKeyCode();
            int step = delta / 120;
            if (step == 0) {
                if (delta > 0) { step = 1; }
                else if (delta < 0) { step = 0 - 1; }
            }
            off = off - step;
            app.RequestRedraw();
        }
        if (off > maxOff) { off = maxOff; }
        if (off < 0) { off = 0; }
        scroll.Set(off);

        int pad = app.Scale(6);
        int iconSz = app.Scale(14);
        int shown = 0;
        int cy = y;
        while (off + shown < count && shown < maxRows) {
            int i = off + shown;
            if (roundIcon) {
                c.FillRoundRect(x + pad, cy + app.Scale(3), iconSz, iconSz, app.Scale(2), colors[i]);
            } else {
                c.FillRoundRect(x + pad, cy + app.Scale(4), iconSz, iconSz, app.Scale(2), 0xFF333333);
                c.DrawText(x + pad + app.Scale(2), cy + app.Scale(5), "E", colors[i], t.fontSizeSmall);
            }
            int tx = x + pad + iconSz + app.Scale(4);
            if (roundIcon) { tx = x + pad + app.Scale(16); }
            c.DrawText(tx, cy + app.Scale(3), names[i], 0xFFD4D4D4, t.fontSizeSmall);
            cy = cy + rowH;
            shown = shown + 1;
        }

        // Scroll thumb on the right edge when content overflows.
        if (count > maxRows) {
            int thumbH = h * maxRows / count;
            if (thumbH < app.Scale(16)) { thumbH = app.Scale(16); }
            int thumbY = y;
            if (maxOff > 0) { thumbY = y + (h - thumbH) * off / maxOff; }
            c.FillRect(x + w - app.Scale(3), y, app.Scale(3), h, 0xFF2A2A2A);
            c.FillRect(x + w - app.Scale(3), thumbY, app.Scale(3), thumbH, 0xFF555555);
        }

        // Report a click on a visible row (mouse-up over the area).
        if (app.window.EventKind() == 3 && over) {
            int rel = (my - y) / rowH;
            if (rel >= 0 && rel < shown) { return off + rel; }
        }
        return 0 - 1;
    }

    // ================================================================
    // Example Code Library
    // ================================================================

    static void OpenNewTab(List<string> tabNames, List<string> tabBodies,
            List<string> tabPaths, SignalInt activeTab, string name, string code) {
        tabNames.Add(name);
        tabBodies.Add(code);
        tabPaths.Add("");
        activeTab.Set(tabNames.Count - 1);
    }

    static string GetExampleName(int idx) {
        if (idx == 0) { return "hello.zan"; }
        if (idx == 1) { return "fileio.zan"; }
        if (idx == 2) { return "linq.zan"; }
        if (idx == 3) { return "gui_window.zan"; }
        if (idx == 4) { return "http.zan"; }
        if (idx == 5) { return "json.zan"; }
        if (idx == 6) { return "timer.zan"; }
        if (idx == 7) { return "calculator.zan"; }
        if (idx == 8) { return "texteditor.zan"; }
        return "";
    }

    static string GetExampleCode(int idx) {
        if (idx == 0) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello, Zan!\");\n        string name = Console.ReadLine();\n        Console.WriteLine(\"Welcome, \" + name + \"!\");\n    }\n}\n";
        }
        if (idx == 1) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        // Write to file\n        File.WriteAllText(\"test.txt\", \"Hello File!\");\n        \n        // Read from file\n        string content = File.ReadAllText(\"test.txt\");\n        Console.WriteLine(content);\n        \n        // List directory\n        List<string> files = Directory.GetFiles(\".\");\n        foreach (string f in files) {\n            Console.WriteLine(f);\n        }\n    }\n}\n";
        }
        if (idx == 2) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        List<int> nums = new List<int>();\n        nums.Add(5); nums.Add(3); nums.Add(8);\n        nums.Add(1); nums.Add(9); nums.Add(2);\n        \n        // LINQ chain operations\n        var sorted = nums.OrderBy(x => x).ToList();\n        var even = nums.Where(x => x % 2 == 0).ToList();\n        int sum = nums.Sum();\n        int max = nums.Max();\n        \n        Console.WriteLine(\"Sum: \" + Convert.ToString(sum));\n        Console.WriteLine(\"Max: \" + Convert.ToString(max));\n    }\n}\n";
        }
        if (idx == 3) {
            return "using System;\nusing Gui;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"My Window\", 800, 600);\n        app.Show();\n        while (app.isRunning) {\n            if (app.BeginFrame()) {\n                Canvas c = app.canvas;\n                Theme t = app.theme;\n                app.RenderChrome();\n                c.FillRect(10, 40, 200, 100, t.primary);\n                c.DrawText(20, 60, \"Hello GUI!\",\n                    0xFFFFFFFF, t.fontSizeMedium);\n                app.PresentFrame();\n            }\n            app.ProcessEvent();\n        }\n    }\n}\n";
        }
        if (idx == 4) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        // HTTP GET request\n        HttpClient client = new HttpClient();\n        string url = \"https://api.example.com/data\";\n        string response = client.GetString(url);\n        Console.WriteLine(response);\n        \n        // HTTP POST\n        string body = \"{\\\"key\\\": \\\"value\\\"}\";\n        string result = client.PostString(url, body);\n        Console.WriteLine(result);\n    }\n}\n";
        }
        if (idx == 5) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        string json = \"{\\\"name\\\": \\\"Zan\\\", \\\"version\\\": 1}\";\n        \n        // Parse JSON\n        var obj = JsonSerializer.Parse(json);\n        string name = obj.GetString(\"name\");\n        int ver = obj.GetInt(\"version\");\n        \n        Console.WriteLine(\"Name: \" + name);\n        Console.WriteLine(\"Version: \" + Convert.ToString(ver));\n        \n        // Create JSON\n        var builder = JsonSerializer.CreateObject();\n        builder.Set(\"lang\", \"Zan\");\n        builder.Set(\"year\", 2026);\n        Console.WriteLine(builder.ToString());\n    }\n}\n";
        }
        if (idx == 6) {
            return "using System;\nusing Gui;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"Timer\", 400, 300);\n        app.Show();\n        int count = 0;\n        int lastTick = 0;\n        while (app.isRunning) {\n            if (app.BeginFrame()) {\n                Canvas c = app.canvas;\n                app.RenderChrome();\n                int now = app.window.GetTickMs();\n                if (now - lastTick > 1000) {\n                    count = count + 1;\n                    lastTick = now;\n                    app.RequestRedraw();\n                }\n                c.DrawText(20, 60, \"Count: \" +\n                    Convert.ToString(count),\n                    0xFFFFFFFF, 24);\n                app.PresentFrame();\n            }\n            app.ProcessEvent();\n        }\n    }\n}\n";
        }
        if (idx == 7) {
            return "using System;\n\nclass Calculator {\n    static int Eval(string expr) {\n        // Simple expression evaluator\n        int result = 0;\n        int num = 0;\n        string op = \"+\";\n        int i = 0;\n        while (i < expr.Length) {\n            string ch = expr.Substring(i, 1);\n            if (ch == \"+\" || ch == \"-\") {\n                if (op == \"+\") { result = result + num; }\n                else { result = result - num; }\n                num = 0; op = ch;\n            } else {\n                num = num * 10 + Convert.ToInt32(ch);\n            }\n            i = i + 1;\n        }\n        if (op == \"+\") { result = result + num; }\n        else { result = result - num; }\n        return result;\n    }\n    \n    static void Main() {\n        Console.WriteLine(\"Calculator\");\n        string expr = Console.ReadLine();\n        int val = Calculator.Eval(expr);\n        Console.WriteLine(\"= \" + Convert.ToString(val));\n    }\n}\n";
        }
        if (idx == 8) {
            return "using System;\nusing Gui;\nusing Gui.Widget;\n\nclass TextEditor {\n    static void Main() {\n        App app = App.CreateDark(\"Editor\", 800, 600);\n        app.Show();\n        CodeEditor ed = CodeEditor.Create();\n        ed.LoadText(\"Hello World!\\nLine 2\\nLine 3\");\n        while (app.isRunning) {\n            if (app.BeginFrame()) {\n                app.RenderChrome();\n                Rect area = Rect.Create(0, 32, 800, 568);\n                ed.Render(app, area);\n                app.PresentFrame();\n            }\n            app.ProcessEvent();\n        }\n    }\n}\n";
        }
        return "";
    }
}
