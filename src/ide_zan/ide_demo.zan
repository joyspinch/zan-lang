            "// Ribbon: Publish -> choose platforms\n// Output: publish/MyApp-windows-x64.exe");
        IdeDemo.DocAdd(cat, title, body, code, cErr, IdeDemo.T("Reading Compiler Errors", "读懂编译器错误"),
            IdeDemo.T("After Run/Build, errors appear as red underlines in the editor; the reason shows above the current line. Click a problem to jump to it.",
                "运行/构建后，错误会在编辑器中显示为红色下划线；原因显示在当前行上方。点击问题即可跳转。"),
            "// error: expected ';'\nint x = 1   // <- missing semicolon\nint y = 2;");
        IdeDemo.DocAdd(cat, title, body, code, cErr, IdeDemo.T("Undefined Symbol", "未定义的符号"),
            IdeDemo.T("An 'undefined reference' at link time usually means a needed library was not linked. GUI apps must include the Gui runtime.",
                "链接期出现 “undefined reference” 通常意味着缺少所需的库。GUI 程序必须包含 Gui 运行时。"),
