        IdeDemo.DocAdd(cat, title, body, code, cWidgets, "Slider",
            IdeDemo.T("Slider.Render(app, x, y, width, min, max, model) edits a SignalInt within a range.",
                "Slider.Render(app, x, y, width, min, max, model) 在区间内编辑一个 SignalInt。"),
            "SignalInt volume = SignalInt.Create(50);\nSlider.Render(app, 40, 80, 200, 0, 100, volume);");
        IdeDemo.DocAdd(cat, title, body, code, cWidgets, IdeDemo.T("Select (Dropdown)", "下拉选择"),
            IdeDemo.T("Select shows a dropdown of options; the chosen index lives in a SignalInt.",
                "Select 显示下拉选项；选中的索引保存在一个 SignalInt 中。"),
            "List<string> opts = new List<string>();\nopts.Add(\"Red\"); opts.Add(\"Green\"); opts.Add(\"Blue\");\nSignalInt sel = SignalInt.Create(0);\nSelect.Render(app, 40, 80, 200, 28, opts, sel, \"pick a color\");");
        IdeDemo.DocAdd(cat, title, body, code, cWidgets, "Tabs",
            IdeDemo.T("Tabs render a row of labels; the active tab index is a SignalInt.",
                "Tabs 渲染一行标签；当前激活的标签索引是一个 SignalInt。"),
            "List<string> labels = new List<string>();\nlabels.Add(\"General\"); labels.Add(\"Advanced\");\nSignalInt active = SignalInt.Create(0);\nTabs.Render(app, 40, 40, 400, labels, active);");
        IdeDemo.DocAdd(cat, title, body, code, cWidgets, "Card",
            IdeDemo.T("Card draws a titled panel. Card.ContentY gives the y where your content should start.",
                "Card 绘制带标题的面板。Card.ContentY 给出内容应开始的 y 坐标。"),
            "Card.Render(app, 40, 40, 260, 160, \"Profile\");\nint cy = Card.ContentY(40, app.theme);\nLabel.Render(app, 56, cy, \"Card body goes here\");");
