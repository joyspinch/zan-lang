    /// Renders the Help / documentation browser: a searchable sidebar of topics
    /// (language + GUI components) and a detail pane with a copyable code
    /// example, in the spirit of a component showcase.
    static void RenderDocsPage(App app, Canvas c, Theme t, Rect area, Input search,
                               SignalInt selSig, SignalInt scrollSig, List<string> log) {
        c.FillRect(area.x, area.y, area.width, area.height, t.bgPrimary);

        List<string> dCat = new List<string>();
        List<string> dTitle = new List<string>();
        List<string> dBody = new List<string>();
        List<string> dCode = new List<string>();
        IdeDemo.BuildDocs(dCat, dTitle, dBody, dCode);

        int sw = app.Scale(268);
        c.FillRect(area.x, area.y, sw, area.height, t.bgSecondary);
        c.FillRect(area.x + sw - 1, area.y, 1, area.height, t.divider);
        app.CaptureWheel(area.x, area.y, sw, area.height);

        // Search box.
        int sx = area.x + app.Scale(12);
        int sy = area.y + app.Scale(12);
        int swid = sw - app.Scale(24);
        int sh = app.Scale(28);
        search.Render(app, sx, sy, swid, sh);
        string query = IdeDemo.ToLowerS(search.GetText());

        // Filter the doc entries by the query.
        List<int> filt = new List<int>();
        int fi = 0;
        while (fi < dTitle.Count) {
            string hay = IdeDemo.ToLowerS(dTitle[fi] + " " + dCat[fi] + " " + dBody[fi]);
            if (IdeDemo.ContainsS(hay, query)) { filt.Add(fi); }
            fi = fi + 1;
        }

        // Ensure the selection points at a visible entry.
        int selAbs = selSig.Get();
        if (filt.IndexOf(selAbs) < 0) {
            if (filt.Count > 0) { selAbs = filt[0]; } else { selAbs = 0 - 1; }
            selSig.Set(selAbs);
        }

        // Build the display rows (category headers interleaved with entries).
        List<int> rowDoc = new List<int>();   // -1 = header row
        List<string> rowText = new List<string>();
        string lastCat = "";
        int k = 0;
        while (k < filt.Count) {
            int d = filt[k];
            if (dCat[d] != lastCat) {
                rowDoc.Add(0 - 1);
                rowText.Add(dCat[d]);
                lastCat = dCat[d];
            }
            rowDoc.Add(d);
            rowText.Add(dTitle[d]);
            k = k + 1;
        }

        int listTop = sy + sh + app.Scale(10);
        int listBottom = area.y + area.height - app.Scale(8);
        int rowH = app.Scale(26);
        int visRows = (listBottom - listTop) / rowH;
        if (visRows < 1) { visRows = 1; }

        // Mouse-wheel scroll over the sidebar.
        if (app.window.EventKind() == 13
            && app.mouseX >= area.x && app.mouseX < area.x + sw
            && app.mouseY >= area.y && app.mouseY < area.y + area.height) {
            int delta = app.window.EventKeyCode();
            int step = delta / 120;
            if (step == 0) { if (delta > 0) { step = 1; } else if (delta < 0) { step = 0 - 1; } }
            scrollSig.Set(scrollSig.Get() - step * 3);
            app.RequestRedraw();
        }
        int maxScroll = rowDoc.Count - visRows;
        if (maxScroll < 0) { maxScroll = 0; }
        int scroll = scrollSig.Get();
        if (scroll > maxScroll) { scroll = maxScroll; }
        if (scroll < 0) { scroll = 0; }
        scrollSig.Set(scroll);

        bool click = app.window.EventKind() == 3;
        int r = 0;
        while (r < visRows) {
            int idx = scroll + r;
            if (idx < rowDoc.Count) {
                int ry = listTop + r * rowH;
                int d = rowDoc[idx];
                if (d < 0) {
                    c.DrawText(sx, ry + app.Scale(8), IdeDemo.ToUpperCat(rowText[idx]),
                        t.textTertiary, t.fontSizeSmall);
                } else {
                    bool selected = d == selAbs;
                    bool hot = app.mouseX >= area.x && app.mouseX < area.x + sw
                        && app.mouseY >= ry && app.mouseY < ry + rowH;
                    if (selected) {
                        c.FillRoundRect(sx - app.Scale(4), ry, swid + app.Scale(8), rowH - app.Scale(2), app.Scale(4), 0xFF094771);
                    } else if (hot) {
                        c.FillRoundRect(sx - app.Scale(4), ry, swid + app.Scale(8), rowH - app.Scale(2), app.Scale(4), t.bgHover);
                    }
                    int tc = t.textPrimary;
                    if (selected) { tc = 0xFFFFFFFF; }
                    c.DrawText(sx + app.Scale(8), ry + app.Scale(5), rowText[idx], tc, t.fontSizeSmall);
                    IdeDemo.HandRegion(app, sx - app.Scale(4), ry, swid + app.Scale(8), rowH - app.Scale(2));
                    if (click && hot) { selSig.Set(d); app.RequestRedraw(); }
                }
            }
            r = r + 1;
        }

        // ---- Detail pane ----
        int cx = area.x + sw + app.Scale(28);
        int cyTop = area.y + app.Scale(26);
        int cw = area.x + area.width - app.Scale(28) - cx;
        if (selAbs < 0) {
            c.DrawText(cx, cyTop, IdeDemo.T("No topics match your search.", "没有匹配搜索的主题。"), t.textTertiary, t.fontSizeMedium);
            return;
        }
        int cy = cyTop;
        c.DrawText(cx, cy, IdeDemo.ToUpperCat(dCat[selAbs]), t.info, t.fontSizeSmall);
        cy = cy + app.Scale(20);
        c.DrawText(cx, cy, dTitle[selAbs], t.textPrimary, t.fontSizeLarge);
        cy = cy + app.Scale(30);
        c.FillRect(cx, cy, cw, 1, t.divider);
        cy = cy + app.Scale(16);

        int bodyLineH = Canvas.FontHeight(t.fontSizeMedium) + app.Scale(4);
        List<string> bl = IdeDemo.WrapText(dBody[selAbs], cw, t.fontSizeMedium);
        int bi = 0;
        while (bi < bl.Count) {
            c.DrawText(cx, cy, bl[bi], t.textSecondary, t.fontSizeMedium);
            cy = cy + bodyLineH;
            bi = bi + 1;
        }
        cy = cy + app.Scale(10);

        // Code example panel with a Copy button.
        List<string> codeLines = CodeEditor.SplitLines(dCode[selAbs]);
        int codeLineH = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(4);
        int hdrH = app.Scale(28);
        int panelH = hdrH + codeLines.Count * codeLineH + app.Scale(16);
        int maxPanelH = area.y + area.height - app.Scale(16) - cy;
        if (panelH > maxPanelH) { panelH = maxPanelH; }
        c.FillRoundRect(cx, cy, cw, panelH, app.Scale(6), 0xFF1E1E1E);
        c.DrawRect(cx, cy, cw, panelH, t.borderPrimary, 1);
        c.FillRect(cx, cy + hdrH, cw, 1, 0xFF2D2D30);
        c.DrawText(cx + app.Scale(12), cy + app.Scale(7), "Zan", t.textTertiary, t.fontSizeSmall);

        int cpW = app.Scale(74);
        int cpH = app.Scale(20);
        int cpX = cx + cw - cpW - app.Scale(8);
        int cpY = cy + app.Scale(4);
        c.FillRoundRect(cpX, cpY, cpW, cpH, app.Scale(3), 0xFF0E639C);
        Icon.Draw(c, "copy", cpX + app.Scale(8), cpY + app.Scale(4), app.Scale(12), 0xFFFFFFFF);
        c.DrawText(cpX + app.Scale(24), cpY + app.Scale(3), IdeDemo.T("Copy", "复制"), 0xFFFFFFFF, t.fontSizeSmall);
        IdeDemo.HandRegion(app, cpX, cpY, cpW, cpH);
        if (click && app.mouseX >= cpX && app.mouseX < cpX + cpW
            && app.mouseY >= cpY && app.mouseY < cpY + cpH) {
            Clipboard.SetText(dCode[selAbs]);
            log.Add("> Copied \"" + dTitle[selAbs] + "\" example to the clipboard.");
            app.RequestRedraw();
        }

        int codeY = cy + hdrH + app.Scale(8);
        int codeBottom = cy + panelH - app.Scale(6);
        int ci = 0;
        while (ci < codeLines.Count) {
            if (codeY + codeLineH > codeBottom) {
                c.DrawText(cx + app.Scale(12), codeY, "...", t.textTertiary, t.fontSizeSmall);
                ci = codeLines.Count;
            } else {
                c.DrawText(cx + app.Scale(12), codeY, codeLines[ci], 0xFFD4D4D4, t.fontSizeSmall);
                codeY = codeY + codeLineH;
                ci = ci + 1;
            }
        }
    }

    /// Renders a category label as an uppercase-ish section header. (Kept simple:
    /// returns the category text prefixed for visual separation.)
    static string ToUpperCat(string s) {
        return s;
    }

    // Start page (welcome): quick actions + project file list.
    // Returns 0 = none, 1 = New Project, 2 = New File, 100+idx = open files[idx].
    static int RenderStartPage(App app, Canvas c, Theme t, Rect area, List<string> files) {
        int result = 0;
        c.FillRect(area.x, area.y, area.width, area.height, t.bgPrimary);
        int pad = app.Scale(32);
        int x0 = area.x + pad;
        int y = area.y + pad;
        c.DrawText(x0, y, "Zan IDE", t.textPrimary, t.fontSizeLarge);
        y = y + app.Scale(30);
        c.DrawText(x0, y, IdeDemo.T("Self-hosted IDE  -  Start", "自托管 IDE  -  开始"), t.textTertiary, t.fontSizeSmall);
        y = y + app.Scale(34);

        int mx = app.mouseX;
        int my = app.mouseY;
        int evKind = app.window.EventKind();

        // ---- Quick actions ----
        c.DrawText(x0, y, IdeDemo.T("Get started", "快速开始"), t.textSecondary, t.fontSizeMedium);
        y = y + app.Scale(26);
        int btnW = app.Scale(240);
        int btnH = app.Scale(40);
        int gap = app.Scale(10);

        int npY = y;
        c.FillRoundRect(x0, npY, btnW, btnH, app.Scale(4), t.primary);
        c.DrawText(x0 + app.Scale(14), npY + app.Scale(13), IdeDemo.T("New Project...", "新建项目..."), 0xFFFFFFFF, t.fontSizeSmall);
        y = y + btnH + gap;

        int nfY = y;
        c.FillRoundRect(x0, nfY, btnW, btnH, app.Scale(4), t.bgTertiary);
        c.DrawText(x0 + app.Scale(14), nfY + app.Scale(13), IdeDemo.T("New File...", "新建文件..."), t.textPrimary, t.fontSizeSmall);
        y = y + btnH + gap;

        if (evKind == 3) {
            if (mx >= x0 && mx < x0 + btnW && my >= npY && my < npY + btnH) { result = 1; }
            else if (mx >= x0 && mx < x0 + btnW && my >= nfY && my < nfY + btnH) { result = 2; }
        }

        // ---- Project files list (right column) ----
        int colX = x0 + btnW + app.Scale(48);
        int colY = area.y + pad + app.Scale(64);
        c.DrawText(colX, colY - app.Scale(26), IdeDemo.T("Project files (src)", "项目文件 (src)"), t.textSecondary, t.fontSizeMedium);
        int rowH = app.Scale(24);
        int maxRows = (area.y + area.height - app.Scale(16) - colY) / rowH;
        int shown = files.Count;
        if (shown > maxRows) { shown = maxRows; }
        int i = 0;
        while (i < shown) {
            int ry = colY + i * rowH;
            bool hot = (mx >= colX && mx < colX + app.Scale(320) && my >= ry && my < ry + rowH);
            if (hot) { c.FillRect(colX - app.Scale(4), ry, app.Scale(324), rowH, t.bgHover); }
            c.DrawText(colX, ry + app.Scale(5), Path.GetFileName(files[i]), t.info, t.fontSizeSmall);
            if (evKind == 3 && hot) { result = 100 + i; }
            i = i + 1;
        }
        if (files.Count == 0) {
            c.DrawText(colX, colY + app.Scale(5), IdeDemo.T("(no .zan files under src/)", "(src/ 下没有 .zan 文件)"), t.textDisabled, t.fontSizeSmall);
        }

        c.DrawText(x0, area.y + area.height - app.Scale(16),
            IdeDemo.T("Tip: click Start in the ribbon to toggle this page.", "提示：点击功能区的“开始”可切换此页面。"), t.textDisabled, t.fontSizeSmall);
        return result;
    }

    static int RenderDesigner(App app, Canvas c, Theme t, Rect area,
            List<string> dNames, List<int> dX, List<int> dY,
            List<int> dW, List<int> dH, List<string> dTypes, SignalInt dSel,
            SignalInt dragMode, SignalInt dragOffX, SignalInt dragOffY, SignalInt resizeH,
            SignalInt preview, SignalInt newTool, List<string> dAnchor, List<string> dDock,
            SignalInt formW, SignalInt formH) {
        int dSelV = dSel.Get();
        int result = 0;
        int previewOn = preview.Get();
        int gridSz = app.Scale(8);
        c.FillRect(area.x, area.y, area.width, area.height, 0xFF2D2D30);

        // Toolbox panel on left
        int toolW = app.Scale(140);
        c.FillRect(area.x, area.y, toolW, area.height, 0xFF252526);
        c.FillRect(area.x + toolW - 1, area.y, 1, area.height, t.divider);
        c.DrawText(area.x + app.Scale(8), area.y + app.Scale(6), IdeDemo.T("TOOLBOX", "工具箱"), 0xFFCCCCCC, t.fontSizeSmall);
        int ty = area.y + app.Scale(28);
        int toolH2 = app.Scale(24);
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "Button", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "Label", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "TextBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "CheckBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ComboBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ListBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "Panel", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "GroupBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "TabControl", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "TreeView", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ListView", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "DataGrid", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "MenuStrip", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ToolStrip", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "StatusBar", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "ProgressBar", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "PictureBox", t); ty = ty + toolH2;
        IdeDemo.DrawToolItem(c, area.x, ty, toolW, toolH2, "RichTextBox", t);

        // "View Code" opens the associated code-behind (.zan), like WinForms.
        // The form layout itself is auto-saved to the .zform file by the host.
        int dbBtnH = app.Scale(26);
        int dbGenY = area.y + area.height - dbBtnH - app.Scale(8);
        c.FillRoundRect(area.x + app.Scale(8), dbGenY, toolW - app.Scale(16), dbBtnH, app.Scale(3), 0xFF0E639C);
        string vcLabel = IdeDemo.T("View Code (F7)", "查看代码 (F7)");
        int dbGenTw = Canvas.MeasureText(vcLabel, t.fontSizeSmall);
        c.DrawText(area.x + (toolW - dbGenTw) / 2, dbGenY + app.Scale(7), vcLabel, 0xFFFFFFFF, t.fontSizeSmall);
        // Live-preview toggle: hides the grid + selection handles for a clean,
        // runtime-like view that still updates as the layout changes.
        int pvBtnY = dbGenY - dbBtnH - app.Scale(6);
        int pvBg = 0xFF3C3C3C;
        if (previewOn == 1) { pvBg = 0xFF0E7A45; }
        c.FillRoundRect(area.x + app.Scale(8), pvBtnY, toolW - app.Scale(16), dbBtnH, app.Scale(3), pvBg);
        string pvLabel = IdeDemo.T("Preview: Off", "预览：关");
        if (previewOn == 1) { pvLabel = IdeDemo.T("Preview: On", "预览：开"); }
        int pvTw = Canvas.MeasureText(pvLabel, t.fontSizeSmall);
        c.DrawText(area.x + (toolW - pvTw) / 2, pvBtnY + app.Scale(7), pvLabel, 0xFFFFFFFF, t.fontSizeSmall);

        // Properties panel on right
        int propW = app.Scale(180);
        int propX = area.x + area.width - propW;
        c.FillRect(propX, area.y, propW, area.height, 0xFF252526);
        c.FillRect(propX, area.y, 1, area.height, t.divider);
        c.DrawText(propX + app.Scale(8), area.y + app.Scale(6), IdeDemo.T("PROPERTIES", "属性"), 0xFFCCCCCC, t.fontSizeSmall);

        if (dSelV >= 0 && dSelV < dNames.Count) {
            int py = area.y + app.Scale(28);
            int lblW = app.Scale(60);
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Name:", "名称："), 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, dNames[dSelV], 0xFFCCCCCC, t.fontSizeSmall);
            py = py + app.Scale(20);
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Type:", "类型："), 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, dTypes[dSelV], 0xFF4EC9B0, t.fontSizeSmall);
            py = py + app.Scale(20);
            int xRowY = py;
            c.DrawText(propX + app.Scale(8), py, "X:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dX[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            py = py + app.Scale(20);
            int yRowY = py;
            c.DrawText(propX + app.Scale(8), py, "Y:", 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dY[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            py = py + app.Scale(20);
            int wRowY = py;
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Width:", "宽度："), 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dW[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            py = py + app.Scale(20);
            int hRowY = py;
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Height:", "高度："), 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(dH[dSelV]), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);

            // Property stepper clicks (grid-sized nudge of the selected control).
            if (app.window.EventKind() == 3) {
                int step = app.Scale(8);
                int sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, xRowY);
                if (sd != 0) { dX[dSelV] = dX[dSelV] + sd * step; if (dX[dSelV] < 0) { dX[dSelV] = 0; } app.RequestRedraw(); }
                sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, yRowY);
                if (sd != 0) { dY[dSelV] = dY[dSelV] + sd * step; if (dY[dSelV] < 0) { dY[dSelV] = 0; } app.RequestRedraw(); }
                sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, wRowY);
                if (sd != 0) { dW[dSelV] = dW[dSelV] + sd * step; if (dW[dSelV] < app.Scale(16)) { dW[dSelV] = app.Scale(16); } app.RequestRedraw(); }
                sd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, hRowY);
                if (sd != 0) { dH[dSelV] = dH[dSelV] + sd * step; if (dH[dSelV] < app.Scale(16)) { dH[dSelV] = app.Scale(16); } app.RequestRedraw(); }
            }
            py = py + app.Scale(24);
            c.FillRect(propX + app.Scale(4), py, propW - app.Scale(8), 1, t.divider);
            py = py + app.Scale(8);
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Events:", "事件："), 0xFF999999, t.fontSizeSmall);
            py = py + app.Scale(18);
            c.DrawText(propX + app.Scale(8), py, "Click", 0xFF569CD6, t.fontSizeSmall);
            py = py + app.Scale(18);
            c.DrawText(propX + app.Scale(8), py, "Load", 0xFF569CD6, t.fontSizeSmall);
            py = py + app.Scale(18);
            c.DrawText(propX + app.Scale(8), py, "TextChanged", 0xFF569CD6, t.fontSizeSmall);
        } else {
            // No control selected: edit the form window size (logical px).
            int py = area.y + app.Scale(28);
            int lblW = app.Scale(70);
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Form", "表单"), 0xFF4EC9B0, t.fontSizeSmall);
            py = py + app.Scale(22);
            int fwRowY = py;
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Width:", "宽度："), 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(formW.Get()), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            py = py + app.Scale(20);
            int fhRowY = py;
            c.DrawText(propX + app.Scale(8), py, IdeDemo.T("Height:", "高度："), 0xFF999999, t.fontSizeSmall);
            c.DrawText(propX + lblW, py, Convert.ToString(formH.Get()), 0xFFB5CEA8, t.fontSizeSmall);
            IdeDemo.DrawStepper(app, c, t, propX + propW, py);
            if (app.window.EventKind() == 3) {
                int fsd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, fwRowY);
                if (fsd != 0) { int nv = formW.Get() + fsd * 20; if (nv < 200) { nv = 200; } formW.Set(nv); app.RequestRedraw(); }
                fsd = IdeDemo.StepperHit(app, app.mouseX, app.mouseY, propX + propW, fhRowY);
                if (fsd != 0) { int nv = formH.Get() + fsd * 20; if (nv < 150) { nv = 150; } formH.Set(nv); app.RequestRedraw(); }
            }
        }

        // Design surface (center area)
        int surfX = area.x + toolW;
        int surfW = area.width - toolW - propW;

        // Draw grid dots (design view only).
        if (previewOn == 0) {
            int gx = surfX + gridSz;
            while (gx < surfX + surfW) {
                int gy2 = area.y + gridSz;
                while (gy2 < area.y + area.height) {
                    c.FillRect(gx, gy2, 1, 1, 0xFF444444);
                    gy2 = gy2 + gridSz * 2;
                }
                gx = gx + gridSz * 2;
            }
        }

        // Form outline
        int formX = surfX + app.Scale(20);
        int formY = area.y + app.Scale(16);
        int formW = surfW - app.Scale(40);
        int formH = area.height - app.Scale(32);
        c.FillRect(formX, formY, formW, formH, 0xFF1E1E1E);
        int titleH = app.Scale(28);
        c.FillRect(formX, formY, formW, titleH, 0xFF333333);
        c.DrawText(formX + app.Scale(8), formY + app.Scale(6), "Form1", 0xFFCCCCCC, t.fontSizeSmall);
        // Close/min/max buttons
        int btnSz = app.Scale(12);
        c.FillRect(formX + formW - app.Scale(22), formY + app.Scale(8), btnSz, btnSz, 0xFFE81123);
        c.FillRect(formX + formW - app.Scale(40), formY + app.Scale(8), btnSz, btnSz, 0xFF888888);
        c.FillRect(formX + formW - app.Scale(58), formY + app.Scale(8), btnSz, btnSz, 0xFF888888);
        // Form border
        c.DrawRect(formX, formY, formW, formH, 0xFF555555, 1);

        // Draw placed controls
        int cntX = formX;
        int cntY = formY + titleH;
        int di = 0;
        while (di < dNames.Count) {
            int cx = cntX + dX[di];
            int cy = cntY + dY[di];
            int cw = dW[di];
            int ch = dH[di];
            string cType = dTypes[di];
            // Control rendering per type
            int cbg = 0xFF3C3C3C;
            if (cType == "Button") { cbg = 0xFF404040; }
            if (cType == "TextBox" || cType == "RichTextBox") { cbg = 0xFF1E1E1E; }
            if (cType == "Panel" || cType == "GroupBox") { cbg = 0xFF2D2D30; }
            c.FillRect(cx, cy, cw, ch, cbg);
            if (cType == "Button") {
                c.FillRoundRect(cx + 1, cy + 1, cw - 2, ch - 2, app.Scale(3), 0xFF555555);
                int tw = Canvas.MeasureText(dNames[di], t.fontSizeSmall);
                c.DrawText(cx + (cw - tw) / 2, cy + (ch - app.Scale(12)) / 2, dNames[di], 0xFFFFFFFF, t.fontSizeSmall);
            } else if (cType == "CheckBox") {
                int cbSz = app.Scale(14);
                c.DrawRect(cx + app.Scale(4), cy + (ch - cbSz) / 2, cbSz, cbSz, 0xFF888888, 1);
                c.DrawText(cx + app.Scale(22), cy + app.Scale(4), dNames[di], 0xFFCCCCCC, t.fontSizeSmall);
            } else if (cType == "ProgressBar") {
                c.DrawRect(cx, cy, cw, ch, 0xFF555555, 1);
                c.FillRect(cx + 2, cy + 2, (cw - 4) * 60 / 100, ch - 4, 0xFF007ACC);
            } else {
                c.DrawRect(cx, cy, cw, ch, 0xFF555555, 1);
                c.DrawText(cx + app.Scale(4), cy + app.Scale(3), dNames[di], 0xFFCCCCCC, t.fontSizeSmall);
            }

            // Selection handles (8 handles around control) - design view only.
            if (di == dSelV && previewOn == 0) {
                c.DrawRect(cx - 1, cy - 1, cw + 2, ch + 2, t.primary, 1);
                int hs = app.Scale(6);
                int hh = hs / 2;
                // Top-left, Top-center, Top-right
                c.FillRect(cx - hh, cy - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw / 2 - hh, cy - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw - hh, cy - hh, hs, hs, 0xFFFFFFFF);
                // Mid-left, Mid-right
                c.FillRect(cx - hh, cy + ch / 2 - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw - hh, cy + ch / 2 - hh, hs, hs, 0xFFFFFFFF);
                // Bot-left, Bot-center, Bot-right
                c.FillRect(cx - hh, cy + ch - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw / 2 - hh, cy + ch - hh, hs, hs, 0xFFFFFFFF);
                c.FillRect(cx + cw - hh, cy + ch - hh, hs, hs, 0xFFFFFFFF);
            }
            di = di + 1;
        }

        // ---- Mouse interaction ----
        // Register the whole designer as a hit region. App.ProcessEvent only
        // repaints on pointer-move while something is pressed; without this the
        // designer would not re-render during a drag and move/resize wouldn't
        // track the cursor.
        int dHitId = app.focus.AllocId();
        app.hitTester.Register(HitRegion.Create(dHitId, area.x, area.y, area.width, area.height, 1));

        int mx = app.mouseX;
        int my = app.mouseY;
        // Canonical event kinds (see the native runtime): 1 = move, 2 = button
        // down, 3 = button up / click. EventButton 0 = left.
        int evKind = app.window.EventKind();
        int evBtn = app.window.EventButton();
        int dm = dragMode.Get();

        // Mouse down (left) on the design surface: grab a resize handle of the
        // current selection, else select/begin-moving a control, else clear the
        // selection. Dragging itself happens on the following move events.
        if (evKind == 2 && evBtn == 0
            && mx >= cntX && mx < formX + formW && my >= cntY && my < formY + formH) {
            bool started = false;
            if (dSelV >= 0 && dSelV < dNames.Count) {
                int rh = IdeDemo.HitHandle(app, mx, my, cntX + dX[dSelV], cntY + dY[dSelV], dW[dSelV], dH[dSelV]);
                if (rh >= 0) {
                    dragMode.Set(2);
                    resizeH.Set(rh);
                    dragOffX.Set(mx);
                    dragOffY.Set(my);
                    started = true;
                }
            }
            if (!started) {
                int ci = dNames.Count - 1;
                bool found = false;
                while (ci >= 0 && !found) {
                    int ccx = cntX + dX[ci];
                    int ccy = cntY + dY[ci];
                    if (mx >= ccx && mx < ccx + dW[ci] && my >= ccy && my < ccy + dH[ci]) {
                        dSel.Set(ci);
                        dragMode.Set(1);
                        dragOffX.Set(mx - ccx);
                        dragOffY.Set(my - ccy);
                        found = true;
                    }
                    ci = ci - 1;
                }
                if (!found) { dSel.Set(0 - 1); dragMode.Set(0); }
            }
            app.RequestRedraw();
        }

        // Mouse move - drag or resize
        if (evKind == 1 && dm > 0 && dSelV >= 0 && dSelV < dNames.Count) {
            if (dm == 1) {
                // Move control
                int newX = mx - dragOffX.Get() - cntX;
                int newY = my - dragOffY.Get() - cntY;
                newX = IdeDemo.SnapGrid(newX, gridSz);
                newY = IdeDemo.SnapGrid(newY, gridSz);
                if (newX < 0) { newX = 0; }
                if (newY < 0) { newY = 0; }
                dX[dSelV] = newX;
                dY[dSelV] = newY;
                app.RequestRedraw();
            }
            if (dm == 2) {
                // Resize control
                int rhi = resizeH.Get();
                int dx = mx - dragOffX.Get();
                int dy = my - dragOffY.Get();
                int ox = dX[dSelV]; int oy = dY[dSelV];
                int ow = dW[dSelV]; int oh = dH[dSelV];
                // Handle 0=TL 1=TC 2=TR 3=ML 4=MR 5=BL 6=BC 7=BR
                if (rhi == 0 || rhi == 3 || rhi == 5) { ox = ox + dx; ow = ow - dx; }
                if (rhi == 0 || rhi == 1 || rhi == 2) { oy = oy + dy; oh = oh - dy; }
                if (rhi == 2 || rhi == 4 || rhi == 7) { ow = ow + dx; }
                if (rhi == 5 || rhi == 6 || rhi == 7) { oh = oh + dy; }
                ow = IdeDemo.SnapGrid(ow, gridSz);
                oh = IdeDemo.SnapGrid(oh, gridSz);
                if (ow < gridSz * 2) { ow = gridSz * 2; }
                if (oh < gridSz * 2) { oh = gridSz * 2; }
                dX[dSelV] = IdeDemo.SnapGrid(ox, gridSz);
                dY[dSelV] = IdeDemo.SnapGrid(oy, gridSz);
                dW[dSelV] = ow;
                dH[dSelV] = oh;
                dragOffX.Set(mx);
                dragOffY.Set(my);
                app.RequestRedraw();
            }
        }

        // Click (press+release) - toolbox rows add a control, action buttons
        // fire, and any in-progress drag is committed/ended here.
        if (evKind == 3) {
            if (mx >= area.x + app.Scale(8) && mx < area.x + toolW - app.Scale(8)
                && my >= dbGenY && my < dbGenY + dbBtnH) {
                result = 1;
            } else if (mx >= area.x + app.Scale(8) && mx < area.x + toolW - app.Scale(8)
                && my >= pvBtnY && my < pvBtnY + dbBtnH) {
                if (previewOn == 1) { preview.Set(0); } else { preview.Set(1); }
                app.RequestRedraw();
            } else if (dm == 0 && mx >= area.x && mx < area.x + toolW && my >= area.y + app.Scale(28)
                && my < pvBtnY - app.Scale(4)) {
                int toolIdx = (my - area.y - app.Scale(28)) / app.Scale(24);
                string newType = IdeDemo.ToolByIndex(toolIdx);
                if (newType != "") {
                    int newIdx = dNames.Count;
                    string newName = newType + Convert.ToString(newIdx + 1);
                    dNames.Add(newName);
                    dX.Add(app.Scale(20));
                    dY.Add(app.Scale(20));
                    dW.Add(app.Scale(100));
                    dH.Add(app.Scale(30));
                    dTypes.Add(newType);
                    dAnchor.Add("LT");
                    dDock.Add("None");
                    dSel.Set(newIdx);
                    app.RequestRedraw();
                }
            }
            if (dm > 0) {
                dragMode.Set(0);
                app.RequestRedraw();
            }
        }

        // Delete key removes selected control
        if (evKind == 4 && app.window.EventKeyCode() == 46) {
            if (dSelV >= 0 && dSelV < dNames.Count) {
                dNames.RemoveAt(dSelV);
                dX.RemoveAt(dSelV);
                dY.RemoveAt(dSelV);
                dW.RemoveAt(dSelV);
                dH.RemoveAt(dSelV);
                dTypes.RemoveAt(dSelV);
                if (dSelV < dAnchor.Count) { dAnchor.RemoveAt(dSelV); }
                if (dSelV < dDock.Count) { dDock.RemoveAt(dSelV); }
                dSel.Set(-1);
                dragMode.Set(0);
                app.RequestRedraw();
            }
        }

        // Arrow keys nudge the selected control by one logical pixel — precise
        // positioning like a mature form designer. Coordinates are clamped so a
        // control can't be nudged off the top/left of the form.
        if (evKind == 4 && dSelV >= 0 && dSelV < dNames.Count) {
            int akc = app.window.EventKeyCode();
            int ndx = 0;
            int ndy = 0;
            if (akc == 37) { ndx = -1; }
            else if (akc == 39) { ndx = 1; }
            else if (akc == 38) { ndy = -1; }
            else if (akc == 40) { ndy = 1; }
            if (ndx != 0 || ndy != 0) {
                int nx = dX[dSelV] + ndx;
                int ny = dY[dSelV] + ndy;
                if (nx < 0) { nx = 0; }
                if (ny < 0) { ny = 0; }
                dX[dSelV] = nx;
                dY[dSelV] = ny;
                app.RequestRedraw();
            }
        }

        // Status text at bottom of design surface
        string statusTxt = "Controls: " + Convert.ToString(dNames.Count);
        if (dSelV >= 0 && dSelV < dNames.Count) {
            statusTxt = statusTxt + "  |  Selected: " + dNames[dSelV]
                + " (" + Convert.ToString(dX[dSelV]) + "," + Convert.ToString(dY[dSelV])
                + " " + Convert.ToString(dW[dSelV]) + "x" + Convert.ToString(dH[dSelV]) + ")";
        }
        c.DrawText(surfX + app.Scale(8), area.y + area.height - app.Scale(16), statusTxt, 0xFF888888, t.fontSizeSmall);
        return result;
    }

    static int HitHandle(App app, int mx, int my, int cx, int cy, int cw, int ch) {
        int hs = app.Scale(8);
        // 0=TL 1=TC 2=TR 3=ML 4=MR 5=BL 6=BC 7=BR
        if (mx >= cx - hs && mx <= cx + hs && my >= cy - hs && my <= cy + hs) { return 0; }
        if (mx >= cx + cw / 2 - hs && mx <= cx + cw / 2 + hs && my >= cy - hs && my <= cy + hs) { return 1; }
        if (mx >= cx + cw - hs && mx <= cx + cw + hs && my >= cy - hs && my <= cy + hs) { return 2; }
        if (mx >= cx - hs && mx <= cx + hs && my >= cy + ch / 2 - hs && my <= cy + ch / 2 + hs) { return 3; }
        if (mx >= cx + cw - hs && mx <= cx + cw + hs && my >= cy + ch / 2 - hs && my <= cy + ch / 2 + hs) { return 4; }
        if (mx >= cx - hs && mx <= cx + hs && my >= cy + ch - hs && my <= cy + ch + hs) { return 5; }
        if (mx >= cx + cw / 2 - hs && mx <= cx + cw / 2 + hs && my >= cy + ch - hs && my <= cy + ch + hs) { return 6; }
        if (mx >= cx + cw - hs && mx <= cx + cw + hs && my >= cy + ch - hs && my <= cy + ch + hs) { return 7; }
        return -1;
    }

    static void DrawToolItem(Canvas c, int x, int y, int w, int h, string label, Theme t) {
        c.DrawText(x + 28, y + 4, label, 0xFFCCCCCC, t.fontSizeSmall);
        c.FillRect(x + 8, y + 5, 14, 14, 0xFF3C3C3C);
        c.FillRect(x + 8, y + 5, 14, 1, 0xFF666666);
        c.FillRect(x + 8, y + 18, 14, 1, 0xFF666666);
        c.FillRect(x + 8, y + 5, 1, 14, 0xFF666666);
        c.FillRect(x + 21, y + 5, 1, 14, 0xFF666666);
    }

