using System;
using System.IO;
using System.Diagnostics;
using System.Json;
using Gui;
using Gui.Widget;
using Game.Scene;

/// Describes one project template: the category it appears under, its display
/// name / icon / description, the scaffolding "kind" (console / dll-class /
/// gui-empty / webview / server / custom / ...), and, for custom templates, the
/// source directory to copy from.
class Tpl {
    string cat;
    string name;
    string icon;
    string desc;
    string kind;
    string src;
    int order;       // sort key inside the wizard (lower = earlier)
    string ptype;    // zan.proj type for copied templates (console/gui/library)
    string ptarget;  // zan.proj target (exe/dll)
    string pentry;   // zan.proj entry

    static Tpl Make(string cat, string name, string icon, string kind, string desc) {
        Tpl t = new Tpl();
        t.cat = cat;
        t.name = name;
        t.icon = icon;
        t.kind = kind;
        t.desc = desc;
        t.src = "";
        t.order = 1000;
        t.ptype = "console";
        t.ptarget = "exe";
        t.pentry = "src/main.zan";
        return t;
    }
}

/// A miniature aardio/VS-Code-style IDE built from the enterprise GUI components
/// (Ribbon / TreeView / TabView / CodeEditor / Panel / Split / Modal / Input /
/// Button) wired to a REAL project on disk and the real Zan toolchain.
///
///   * Project ("New Project"): a modal wizard with categorized templates
///     (Console / GUI App / DLL Library / Executable / Empty), a project name
///     and a location — scaffolds the folder + starter files + zan.proj config.
///   * New ("New File"): a modal wizard with file templates (Program / Class /
///     GUI Window / Interface / Empty).
///   * Explorer tree scanned from disk; click a file to open it in a tab.
///   * Save writes to disk; Build/Run/Publish invoke zanc via Process and
///     stream output to the Output panel. Console/library targets link with
///     zanc's own bundled linker (no external clang/LLVM needed); GUI targets
///     still route through clang to link the native GUI runtime.
class ZanIDE {
    #if WINDOWS
    [DllImport("kernel32", EntryPoint = "GetModuleFileNameA")]
    static extern int WinGetModuleFileName(int hModule, string buf, int size);
    #elif MACOS
    // _NSGetExecutablePath(char* buf, uint32_t* bufsize): fills buf with the
    // executable path; bufsize points to a 4-byte little-endian capacity.
    [DllImport("crt", EntryPoint = "_NSGetExecutablePath")]
    static extern int MacGetExecutablePath(string buf, string bufsize);
    #else
    // Linux exposes the running executable via the /proc/self/exe symlink.
    [DllImport("crt", EntryPoint = "readlink")]
    static extern int LinuxReadlink(string path, string buf, int bufsize);
    #endif

    [DllImport("crt")]
    static extern string calloc(int count, int size);

    /// Full path of the running IDE executable. Platform-specific: Win32
    /// GetModuleFileNameA, macOS _NSGetExecutablePath, Linux /proc/self/exe.
    /// The buffer is calloc-zeroed so the returned path stays NUL-terminated.
    static string ExePath() {
        string buf = calloc(4096, 1);
        #if WINDOWS
        WinGetModuleFileName(0, buf, 4096);
        #elif MACOS
        string cap = calloc(4, 1);
        cap[1] = 16;
        MacGetExecutablePath(buf, cap);
        #else
        LinuxReadlink("/proc/self/exe", buf, 4096);
        #endif
        return buf;
    }

    /// Directory that contains the running IDE executable, with no trailing
    /// separator. Used so the toolchain (zanc + its stdlib) is located relative
    /// to the IDE rather than a hard-coded absolute path — makes the IDE portable.
    static string ExeDir() {
        string p = ZanIDE.ExePath();
        int cut = 0 - 1;
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "\\" || ch == "/") { cut = i; }
            i = i + 1;
        }
        if (cut < 0) { return "."; }
        return p.Substring(0, cut);
    }

    /// Executable file suffix for produced binaries: ".exe" on Windows, none
    /// on POSIX (where the extension is irrelevant and conventionally absent).
    #if WINDOWS
    static string ExeSuffix() { return ".exe"; }
    #else
    static string ExeSuffix() { return ""; }
    #endif

    /// Basename of the Zan compiler shipped next to the IDE.
    static string ZancName() { return "zanc" + ZanIDE.ExeSuffix(); }

    /// C library getenv, for locating per-user directories (mirrors the
    /// approach in System.IO.Path). Returns null when the variable is unset.
    [DllImport("crt")]
    static extern string getenv(string name);

    /// User home directory (USERPROFILE on Windows, HOME on POSIX).
    static string HomeDir() {
        #if WINDOWS
        string h = getenv("USERPROFILE");
        #else
        string h = getenv("HOME");
        #endif
        if (h == null || h == "") { return "."; }
        return h;
    }

    /// Per-user, writable directory for IDE config + custom templates. Kept out
    /// of the (possibly read-only) install dir so nothing user-owned lives there.
    static string UserConfigDir() {
        #if WINDOWS
        string a = getenv("APPDATA");
        if (a == null || a == "") { a = ZanIDE.HomeDir(); }
        return a + "/ZanIDE";
        #elif MACOS
        return ZanIDE.HomeDir() + "/Library/Application Support/ZanIDE";
        #else
        string x = getenv("XDG_CONFIG_HOME");
        if (x != null && x != "") { return x + "/zan-ide"; }
        return ZanIDE.HomeDir() + "/.config/zan-ide";
        #endif
    }

    /// Default parent for user projects. Projects are user-owned and never
    /// created under the install dir; the wizard lets the user pick any path.
    static string ProjectsHome() { return ZanIDE.HomeDir() + "/ZanProjects"; }

    /// File remembering the last project the user opened, so the IDE reopens it
    /// next launch instead of scaffolding a throwaway sample project.
    static string LastProjectPath() { return ZanIDE.UserConfigDir() + "/lastproject.txt"; }

    static string ReadLastProject() {
        string f = ZanIDE.LastProjectPath();
        if (!File.Exists(f)) { return ""; }
        string s = ZanIDE.NormSlashes(File.ReadAllText(f));
        int e = s.Length;
        while (e > 0) {
            string ch = s.Substring(e - 1, 1);
            if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") { e = e - 1; }
            else { break; }
        }
        return s.Substring(0, e);
    }

    static void WriteLastProject(string root) {
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.LastProjectPath(), root);
        ZanIDE.AddRecentProject(root);
    }

    // ---- Recently opened projects (start page MRU, newest first) ----
    static string RecentProjectsPath() { return ZanIDE.UserConfigDir() + "/recent_projects.txt"; }

    static string TrimWs(string s) {
        int b = 0;
        int e = s.Length;
        while (b < e) {
            string ch = s.Substring(b, 1);
            if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") { b = b + 1; }
            else { break; }
        }
        while (e > b) {
            string ch = s.Substring(e - 1, 1);
            if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") { e = e - 1; }
            else { break; }
        }
        return s.Substring(b, e - b);
    }

    /// The most recently opened project roots (existing dirs only, max 10).
    static List<string> ReadRecentProjects() {
        List<string> outp = new List<string>();
        if (!File.Exists(ZanIDE.RecentProjectsPath())) { return outp; }
        List<string> lines = CodeEditor.SplitLines(File.ReadAllText(ZanIDE.RecentProjectsPath()));
        int i = 0;
        while (i < lines.Count && outp.Count < 10) {
            string p = ZanIDE.TrimWs(ZanIDE.NormSlashes(lines[i]));
            bool dup = false;
            int j = 0;
            while (j < outp.Count) {
                if (outp[j] == p) { dup = true; }
                j = j + 1;
            }
            if (p != "" && !dup && Directory.Exists(p)) { outp.Add(p); }
            i = i + 1;
        }
        return outp;
    }

    static void AddRecentProject(string root) {
        string p = ZanIDE.TrimWs(ZanIDE.NormSlashes(root));
        if (p == "") { return; }
        List<string> cur = ZanIDE.ReadRecentProjects();
        StringBuilder sb = new StringBuilder();
        sb.Append(p);
        sb.Append("\n");
        int n = 1;
        int i = 0;
        while (i < cur.Count && n < 10) {
            if (cur[i] != p) {
                sb.Append(cur[i]);
                sb.Append("\n");
                n = n + 1;
            }
            i = i + 1;
        }
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.RecentProjectsPath(), sb.ToString());
    }

    /// Fills the start-page article list: docs/news.json in the project (or
    /// start_news.json in the user config dir) when present, else the built-in
    /// entries. `links` are URLs, or "@docs" to open the built-in help tab.
    static void StartNewsInto(string root, List<string> tags, List<string> titles, List<string> links) {
        string p = root + "/docs/news.json";
        if (!File.Exists(p)) { p = ZanIDE.UserConfigDir() + "/start_news.json"; }
        if (File.Exists(p)) {
            JsonValue v = JsonValue.Parse(File.ReadAllText(p));
            if (v != null) {
                JsonValue items = v.Get("items");
                if (items != null && items.IsArray()) {
                    int i = 0;
                    while (i < items.Count()) {
                        JsonValue it = items.At(i);
                        string ti = it.Str("title", "");
                        if (ti != "") {
                            tags.Add(it.Str("tag", ZanIDE.T("Info", "资讯")));
                            titles.Add(ti);
                            links.Add(it.Str("url", "@docs"));
                        }
                        i = i + 1;
                    }
                }
            }
            if (tags.Count > 0) { return; }
        }
        tags.Add(ZanIDE.T("Must read", "必读"));
        titles.Add(ZanIDE.T("Quick start: create a project and run it", "快速入门：新建项目并运行"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Must read", "必读"));
        titles.Add(ZanIDE.T("Zan language syntax overview", "Zan 语法速览"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Tutorial", "教程"));
        titles.Add(ZanIDE.T("Design game UI with the scene designer (.zscene)", "用场景设计器制作游戏 UI（.zscene）"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Tutorial", "教程"));
        titles.Add(ZanIDE.T("Visual forms with the form designer (.zform)", "窗体设计器与 .zform 可视化开发"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Tool", "工具"));
        titles.Add(ZanIDE.T("AI assistant: provider profiles and model switching", "AI 助手：多配置与模型切换"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Tool", "工具"));
        titles.Add(ZanIDE.T("Debugger: breakpoints, stepping and watches", "调试器：断点、单步与监视"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Tool", "工具"));
        titles.Add(ZanIDE.T("Hot reload: save to rebuild and restart", "热重载：保存即重建重启"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Sample", "示例"));
        titles.Add(ZanIDE.T("Browse the built-in examples (right panel)", "浏览内置示例（右侧“示例”页签）"));
        links.Add("@docs");
        tags.Add(ZanIDE.T("Open source", "开源"));
        titles.Add(ZanIDE.T("zan-lang on GitHub: source, issues and releases", "GitHub 仓库 zan-lang：源码与发布"));
        links.Add("https://github.com/joyspinch/zan-lang");
        tags.Add(ZanIDE.T("Feedback", "反馈"));
        titles.Add(ZanIDE.T("Report a problem or request a feature", "提交问题或功能建议"));
        links.Add("https://github.com/joyspinch/zan-lang/issues");
    }

    /// Built-in official AI provider presets: display name, OpenAI-compatible
    /// base URL, a sensible default model, and the key/registration portal.
    static void AiPresetsInto(List<string> names, List<string> bases,
            List<string> models, List<string> regs) {
        names.Add("Agnes AI");
        bases.Add("https://platform.agnes-ai.com/v1");
        models.Add("");
        regs.Add("https://platform.agnes-ai.com/");
        names.Add(ZanIDE.T("Zhipu GLM", "智谱 GLM"));
        bases.Add("https://open.bigmodel.cn/api/paas/v4");
        models.Add("glm-4-flash");
        regs.Add("https://open.bigmodel.cn/");
        names.Add("Kimi (Moonshot)");
        bases.Add("https://api.moonshot.cn/v1");
        models.Add("moonshot-v1-8k");
        regs.Add("https://platform.moonshot.cn/");
        names.Add("DeepSeek");
        bases.Add("https://api.deepseek.com/v1");
        models.Add("deepseek-chat");
        regs.Add("https://platform.deepseek.com/");
        names.Add(ZanIDE.T("Alibaba Qwen", "通义千问 Qwen"));
        bases.Add("https://dashscope.aliyuncs.com/compatible-mode/v1");
        models.Add("qwen-plus");
        regs.Add("https://bailian.console.aliyun.com/");
        names.Add("OpenAI");
        bases.Add("https://api.openai.com/v1");
        models.Add("gpt-4o-mini");
        regs.Add("https://platform.openai.com/");
    }

    /// Opens `url` in the system browser (detached).
    static void OpenExternal(string url) {
        #if WINDOWS
        Process.RunDetached("cmd /c start \"\" \"" + url + "\"");
        #else
        Process.RunDetached("xdg-open \"" + url + "\"");
        #endif
    }

    // ---- UI language (one-click EN / 中文) ----
    // 0 = English, 1 = 简体中文. Set once at startup from editor.cfg and updated
    // live from the Settings dialog; read everywhere via T(en, zh).
    static int uiLang;

    /// Picks the string for the current UI language. API names, keywords and
    /// project-file syntax are never translated — only human-facing labels.
    static string T(string en, string zh) {
        if (ZanIDE.uiLang == 1) { return zh; }
        return en;
    }

    static int ReadUiLang() {
        string f = ZanIDE.EditorPrefsPath();
        if (!File.Exists(f)) { return 0; }
        return ZanIDE.CfgInt(File.ReadAllText(f), "lang", 0);
    }

    /// Number of selectable UI languages (see uiLang). The Settings dialog
    /// renders one language segment per index via LangName(i).
    static int LangCount() { return 2; }

    /// Display label for UI language `i` (0 = English, 1 = 简体中文).
    static string LangName(int i) {
        if (i == 1) { return "中文"; }
        return "English";
    }

    /// Builds the top ribbon commands, localized to the current UI language.
    /// Rebuilt (not mutated) whenever the language changes so labels update live.
    /// The command *order* is a stable contract — dispatch is by index (rc==N),
    /// never by label — so translating labels is display-only.
    static List<RibbonCmd> BuildRibbon() {
        // Grouped by workflow: file ops | start page | run & debug |
        // design & project | app. Dispatch uses RibbonAction(), never the
        // position, so this order can change freely.
        List<RibbonCmd> cmds = new List<RibbonCmd>();
        cmds.Add(RibbonCmd.Create("plus", ZanIDE.T("Project", "项目")));
        cmds.Add(RibbonCmd.Create("file", ZanIDE.T("New", "新建")));
        cmds.Add(RibbonCmd.Create("folder", ZanIDE.T("Open", "打开")));
        cmds.Add(RibbonCmd.Create("save", ZanIDE.T("Save", "保存")));
        cmds.Add(RibbonCmd.Group("home", ZanIDE.T("Start", "开始")));
        cmds.Add(RibbonCmd.Group("play", ZanIDE.T("Run", "运行")));
        cmds.Add(RibbonCmd.Create("bug", ZanIDE.T("Debug", "调试")));
        cmds.Add(RibbonCmd.Create("check", ZanIDE.T("Build", "构建")));
        cmds.Add(RibbonCmd.Create("upload", ZanIDE.T("Publish", "发布")));
        cmds.Add(RibbonCmd.Create("refresh", ZanIDE.T("Hot", "热重载")));
        cmds.Add(RibbonCmd.Group("layout", ZanIDE.T("Design/Code", "设计/代码")));
        cmds.Add(RibbonCmd.Create("copy", ZanIDE.T("Template", "模板")));
        cmds.Add(RibbonCmd.Create("grid", ZanIDE.T("Config", "配置")));
        cmds.Add(RibbonCmd.Create("image", ZanIDE.T("Assets", "素材")));
        cmds.Add(RibbonCmd.Group("settings", ZanIDE.T("Settings", "设置")));
        cmds.Add(RibbonCmd.Create("info", ZanIDE.T("Help", "帮助")));
        return cmds;
    }

    /// Maps a ribbon position (from Ribbon.Render) to its stable action id.
    /// Action ids: 0 Project, 1 New, 2 Open, 3 Save, 4 Run, 5 Build,
    /// 6 Publish, 7 Debug, 8 Template, 9 Designer, 10 Start, 11 Hot,
    /// 12 Config, 13 Settings, 14 Help, 15 Assets.
    static int RibbonAction(int pos) {
        if (pos == 4) { return 10; }
        if (pos == 5) { return 4; }
        if (pos == 6) { return 7; }
        if (pos == 7) { return 5; }
        if (pos == 8) { return 6; }
        if (pos == 9) { return 11; }
        if (pos == 10) { return 9; }
        if (pos == 11) { return 8; }
        if (pos == 13) { return 15; }
        if (pos == 14) { return 13; }
        if (pos == 15) { return 14; }
        return pos;
    }

    // ---- editor appearance (font + syntax color themes) ----

    static string EditorPrefsPath() { return ZanIDE.UserConfigDir() + "/editor.cfg"; }

    static int ReadEditorTheme() {
        string f = ZanIDE.EditorPrefsPath();
        if (!File.Exists(f)) { return 0; }
        return ZanIDE.CfgInt(File.ReadAllText(f), "theme", 0);
    }

    static int ReadEditorFont() {
        string f = ZanIDE.EditorPrefsPath();
        if (!File.Exists(f)) { return 0; }
        return ZanIDE.CfgInt(File.ReadAllText(f), "font", 0);
    }

    static void WriteEditorPrefs(int themeIdx, int fontPx) {
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.EditorPrefsPath(),
            "theme=" + Convert.ToString(themeIdx) + ";font=" + Convert.ToString(fontPx)
            + ";lang=" + Convert.ToString(ZanIDE.uiLang) + ";");
    }

    static int EditorThemeCount() { return 6; }

    static string EditorThemeName(int i) {
        if (i == 1) { return "Monokai"; }
        if (i == 2) { return "Dracula"; }
        if (i == 3) { return "Solarized Dark"; }
        if (i == 4) { return "Night Owl"; }
        if (i == 5) { return "High Contrast"; }
        return "Dark+ (default)";
    }

    /// The effective font size: the explicit override, or the theme default.
    static int EditorFontOr(int fontPx, int defFontPx) {
        if (fontPx > 0) { return fontPx; }
        return defFontPx;
    }

    /// One syntax color of a preset theme. role: 0=keyword 1=type 2=string
    /// 3=comment 4=number 5=default text. The palettes themselves live in
    /// the Gui skin layer (EditorPalette.Preset).
    static int EditorThemeColor(int themeIdx, int role) {
        EditorPalette p = EditorPalette.Preset(themeIdx);
        if (role == 0) { return p.keyword; }
        if (role == 1) { return p.type; }
        if (role == 2) { return p.str; }
        if (role == 3) { return p.comment; }
        if (role == 4) { return p.number; }
        return p.plain;
    }

    /// Machine-readable snapshot of the editor for the AI automation driver:
    /// caret, live completion popup (candidates + selection) and buffer text.
    static string EditorProbeJson(CodeEditor ed) {
        string s = "{\"caretLine\":" + Convert.ToString(ed.CurLine())
            + ",\"caretCol\":" + Convert.ToString(ed.CurCol())
            + ",\"completionActive\":" + UiDriver.JsonBool(ed.CompletionActive())
            + ",\"completionSel\":" + Convert.ToString(ed.CompletionSel())
            + ",\"completion\":[";
        int n = ed.CompletionCount();
        int i = 0;
        while (i < n) {
            if (i > 0) { s = s + ","; }
            s = s + "{\"label\":\"" + UiDriver.JsonEsc(ed.CompletionItem(i))
                + "\",\"kind\":\"" + UiDriver.JsonEsc(ed.CompletionKind(i)) + "\"}";
            i = i + 1;
        }
        s = s + "],\"text\":\"" + UiDriver.JsonEsc(ed.GetText()) + "\"}";
        return s;
    }

    /// Pushes the selected preset's colors and font size into the editor.
    static void ApplyEditorTheme(CodeEditor editor, int themeIdx, int fontPx) {
        editor.ApplyTheme(fontPx,
            ZanIDE.EditorThemeColor(themeIdx, 0), ZanIDE.EditorThemeColor(themeIdx, 1),
            ZanIDE.EditorThemeColor(themeIdx, 2), ZanIDE.EditorThemeColor(themeIdx, 3),
            ZanIDE.EditorThemeColor(themeIdx, 4), ZanIDE.EditorThemeColor(themeIdx, 5));
    }

    // ---- Editor Settings dialog: JSON declarative + two-way binding ----
    // The Settings modal is described as a JSON UiDoc bound to a JsonValue model
    // {themeIdx, font, lang}. Handlers are parameterless Actions resolved by the
    // registry, so button clicks flip these static flags which Run() consumes.
    static bool setDone;
    static bool setResetFont;

    static void OnSettingsDone() { ZanIDE.setDone = true; }
    static void OnSettingsResetFont() { ZanIDE.setResetFont = true; }

    /// Escapes a label for embedding as a JSON string literal.
    static string JsonEsc(string s) {
        string outp = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\\") { outp = outp + "\\\\"; }
            else if (ch == "\"") { outp = outp + "\\\""; }
            else { outp = outp + ch; }
            i = i + 1;
        }
        return outp;
    }

    /// Builds the Settings modal as a JSON UiDoc document: a title, the color
    /// theme preview cards (custom ThemeCard component, one per preset, all
    /// two-way bound to model.themeIdx), a font-size slider + live readout, a
    /// segmented language chooser (Segment component bound to model.lang), and
    /// the Default / Done buttons.
    static string SettingsDocJson() {
        string s = "{ \"type\":\"Column\", \"pad\":18, \"gap\":8, \"children\":[";
        s = s + "{ \"type\":\"Title\", \"dock\":\"top\", \"height\":34, \"text\":\""
            + ZanIDE.JsonEsc(ZanIDE.T("Editor Settings", "编辑器设置")) + "\" },";
        s = s + "{ \"type\":\"Label\", \"variant\":2, \"dock\":\"top\", \"height\":20, \"text\":\""
            + ZanIDE.JsonEsc(ZanIDE.T("Color Theme", "配色主题")) + "\" },";
        int i = 0;
        while (i < ZanIDE.EditorThemeCount()) {
            s = s + "{ \"type\":\"ThemeCard\", \"index\":" + Convert.ToString(i)
                + ", \"dock\":\"top\", \"height\":38, \"bind\":\"themeIdx\" },";
            i = i + 1;
        }
        s = s + "{ \"type\":\"Label\", \"variant\":2, \"dock\":\"top\", \"height\":20, \"text\":\""
            + ZanIDE.JsonEsc(ZanIDE.T("Font Size", "字体大小")) + "\" },";
        s = s + "{ \"type\":\"Row\", \"dock\":\"top\", \"height\":34, \"gap\":10, \"children\":[";
        s = s + "{ \"type\":\"Slider\", \"min\":9, \"max\":30, \"bind\":\"font\", \"dock\":\"left\", \"width\":300 },";
        s = s + "{ \"type\":\"Label\", \"dock\":\"left\", \"width\":44, \"bind\":{\"path\":\"font\",\"prop\":\"text\"} },";
        s = s + "{ \"type\":\"Label\", \"dock\":\"left\", \"width\":24, \"text\":\"px\" },";
        s = s + "{ \"type\":\"Button\", \"onClick\":\"resetFont\", \"dock\":\"left\", \"width\":100, \"text\":\""
            + ZanIDE.JsonEsc(ZanIDE.T("Default", "默认")) + "\" } ] },";
        s = s + "{ \"type\":\"Label\", \"variant\":2, \"dock\":\"top\", \"height\":20, \"text\":\""
            + ZanIDE.JsonEsc(ZanIDE.T("Language", "界面语言")) + "\" },";
        s = s + "{ \"type\":\"Row\", \"dock\":\"top\", \"height\":34, \"gap\":8, \"children\":[";
        int j = 0;
        while (j < ZanIDE.LangCount()) {
            s = s + "{ \"type\":\"Segment\", \"index\":" + Convert.ToString(j)
                + ", \"label\":\"" + ZanIDE.JsonEsc(ZanIDE.LangName(j))
                + "\", \"dock\":\"left\", \"width\":130, \"bind\":\"lang\" }";
            j = j + 1;
            if (j < ZanIDE.LangCount()) { s = s + ","; }
        }
        s = s + "] },";
        s = s + "{ \"type\":\"Row\", \"dock\":\"top\", \"height\":40, \"gap\":10, \"children\":[";
        s = s + "{ \"type\":\"Button\", \"onClick\":\"done\", \"dock\":\"right\", \"width\":120, \"text\":\""
            + ZanIDE.JsonEsc(ZanIDE.T("Done", "完成")) + "\" } ] }";
        s = s + "] }";
        return s;
    }

    /// Converts Windows backslashes to forward slashes, the IDE-internal path
    /// form (Windows file APIs accept either separator).
    static string NormSlashes(string p) {
        string outp = "";
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "\\") { outp = outp + "/"; } else { outp = outp + ch; }
            i = i + 1;
        }
        return outp;
    }

    static string LastPickerPath() { return ZanIDE.UserConfigDir() + "/lastpicker.txt"; }

    static string ReadLastPickerDirectory(string fallback) {
        string dir = "";
        string f = ZanIDE.LastPickerPath();
        if (File.Exists(f)) {
            dir = ZanIDE.NormSlashes(File.ReadAllText(f));
            dir = ZanIDE.TrimTrailSpaces(ZanIDE.TrimLeadSpaces(dir));
        }
        if (Directory.Exists(dir)) { return dir; }
        fallback = ZanIDE.NormSlashes(fallback);
        if (File.Exists(fallback)) { fallback = Path.GetDirectoryName(fallback); }
        if (Directory.Exists(fallback)) { return fallback; }
        return ZanIDE.ProjectsHome();
    }

    static void WriteLastPickerDirectory(string dir) {
        dir = ZanIDE.NormSlashes(dir);
        if (!Directory.Exists(dir)) { return; }
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.LastPickerPath(), dir);
    }

    /// Shipped (read-only) resource roots, laid out relative to the IDE exe:
    ///   <ExeDir>/toolchain/zanc[.exe] + linker      <ExeDir>/stdlib
    /// This matches scripts/publish_ide.ps1: the compiler and its linker bundle
    /// live together under <ExeDir>/toolchain, and zanc finds its linker next to
    /// itself in that same folder.
    static string ToolchainDir() { return ZanIDE.ExeDir() + "/toolchain"; }
    static string StdlibDir() { return ZanIDE.ExeDir() + "/stdlib"; }

    /// Shipped example programs. Published next to the IDE as <ExeDir>/examples
    /// (scripts/publish_ide.ps1); when running from the build tree it sits one
    /// level up at the repo root. Returns "" when neither exists.
    static string ExamplesDir() {
        string a = ZanIDE.ExeDir() + "/examples";
        if (Directory.Exists(a)) { return a; }
        string b = ZanIDE.ExeDir() + "/../examples";
        if (Directory.Exists(b)) { return b; }
        return "";
    }

    /// Per-project build scratch dir (writable, colocated with the sources),
    /// created on demand so build artifacts never touch the install dir.
    static string EnsureBuildDir(string root) {
        string d = root + "/.build";
        if (!Directory.Exists(d)) { Directory.CreateDirectoryRecursive(d); }
        return d;
    }

    /// Resolve the Zan compiler. It lives together with its linker under
    /// <ExeDir>/toolchain/zanc.exe (see scripts/publish_ide.ps1). Falls back to
    /// the bare name (PATH) -- no hard-coded absolute path.
    static string Zanc() {
        string cand = ZanIDE.ToolchainDir() + "/" + ZanIDE.ZancName();
        if (File.Exists(cand)) { return cand; }
        return ZanIDE.ZancName();
    }

    /// Quoted zanc invocation prefix with an explicit --stdlib-path so stdlib
    /// resolution never depends on relative (../stdlib) lookup or the cwd.
    static string ZancCmd() {
        return "\"" + ZanIDE.Zanc() + "\" --stdlib-path \"" + ZanIDE.StdlibDir() + "\"";
    }

    /// True when the project at `root` targets the GUI runtime (zan.proj
    /// `type = gui`). GUI apps must link the native GUI runtime and use the
    /// borderless-window entry, whereas console apps link with the defaults.
    static bool IsGuiProject(string root) {
        string pj = root + "/zan.proj";
        if (!File.Exists(pj)) { return false; }
        string c = File.ReadAllText(pj);
        return ZanIDE.Has(c, "type = gui") || ZanIDE.Has(c, "type=gui");
    }

    /// Extra clang link arguments for GUI projects: the native GUI runtime
    /// (zan_gui.lib, shipped next to the IDE and under toolchain\), the stdio
    /// shim sprintf resolves against, and the windowed subsystem/entry the GUI
    /// runtime expects. Returns "" for console projects (link with defaults).
    static bool IsGuiTarget(string root, string sourcePath) {
        bool isGui = ZanIDE.IsGuiProject(root);
        if (!isGui && File.Exists(sourcePath)) {
            string source = File.ReadAllText(sourcePath);
            isGui = ZanIDE.Has(source, "using Gui;");
        }
        return isGui;
    }

    static string GuiLinkArgs(string root, string sourcePath) {
        bool isGui = ZanIDE.IsGuiTarget(root, sourcePath);
        if (!isGui) { return ""; }
        string args = " -L\"" + ZanIDE.ExeDir() + "\" -L\"" + ZanIDE.ToolchainDir() + "\""
            + " -lzan_gui -llegacy_stdio_definitions"
            + " -Xlinker /SUBSYSTEM:WINDOWS -Xlinker /ENTRY:mainCRTStartup"
            + " -Xlinker /STACK:268435456";
        string res = "";
        if (ZanIDE.IsGuiProject(root)) {
            res = ZanIDE.EnsureProjectIconRes(root);
        }
        if (res != "") { args = args + " \"" + res + "\""; }
        return args;
    }

    /// Extra link input for programs that use the synchronization runtime
    /// (Thread.Start / AtomicInt / SharedTable / Dispatcher). Those symbols
    /// (zan_thread_start / zan_atomic_int_* / zan_shared_table_* /
    /// zan_dispatch_*) live in the prebuilt zanrt_sync object rather than the
    /// emitted IR, so the IDE's `clang <ir>.ll` step must link it explicitly.
    /// Prefer the MSVC-target object (zanrt_sync_ide.obj) since the IDE links
    /// against clang's default MSVC target; the GNU-target zanrt_sync.obj pulls
    /// in __mingw_* and won't resolve. Returns "" when no object is present so
    /// ordinary programs still link unchanged. The object only references
    /// kernel32 (threads / mutexes / file mappings), so linking it into a
    /// program that doesn't call it is harmless dead code.
    static string RtSyncArg() {
        string cand = ZanIDE.ToolchainDir() + "/zanrt_sync_ide.obj";
        if (File.Exists(cand)) { return " \"" + cand + "\""; }
        cand = ZanIDE.ExeDir() + "/zanrt_sync_ide.obj";
        if (File.Exists(cand)) { return " \"" + cand + "\""; }
        cand = ZanIDE.ToolchainDir() + "/zanrt_sync.obj";
        if (File.Exists(cand)) { return " \"" + cand + "\""; }
        cand = ZanIDE.ExeDir() + "/zanrt_sync.obj";
        if (File.Exists(cand)) { return " \"" + cand + "\""; }
        return "";
    }

    /// Produces `exe` from `inputs` through zanc's OWN bundled linker (the GNU
    /// ld shipped in toolchain\), so Build/Run/Debug/Publish need no external
    /// clang or LLVM on the machine -- the IDE is as self-contained as the CLI
    /// (verified with clang/gcc/ld off PATH). GUI targets add --subsystem
    /// windows; the native GUI runtime is auto-bundled by zanc as the `zan_gui`
    /// stdlib driver (stdlib\Gui\drivers), copied next to the exe. `ll` is
    /// retained for signature stability but no longer used. `publish` adds
    /// --publish (optimize + strip).
    static string CompileToExe(string root, string p, string inputs, string ll, string exe, bool publish) {
        string pub = "";
        if (publish) { pub = " --publish"; }
        string sub = "";
        if (ZanIDE.IsGuiTarget(root, p)) { sub = " --subsystem windows"; }
        return ZanIDE.ZancCmd() + pub + " " + inputs + " -o \"" + exe + "\"" + sub;
    }

    /// Reads a `key = value` field from the project's zan.proj, or "" if absent.
    static string ProjField(string root, string key) {
        string proj = root + "/zan.proj";
        if (!File.Exists(proj)) { return ""; }
        List<string> ls = CodeEditor.SplitLines(File.ReadAllText(proj));
        int i = 0;
        while (i < ls.Count) {
            string tr = ZanIDE.TrimLeadSpaces(ls[i]);
            if (tr.Length >= key.Length && tr.Substring(0, key.Length) == key) {
                string rest = ZanIDE.TrimLeadSpaces(tr.Substring(key.Length, tr.Length - key.Length));
                if (rest.Length > 0 && rest.Substring(0, 1) == "=") {
                    string val = ZanIDE.TrimLeadSpaces(rest.Substring(1, rest.Length - 1));
                    int e = val.Length;
                    while (e > 0) {
                        string ch = val.Substring(e - 1, 1);
                        if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") { e = e - 1; }
                        else { break; }
                    }
                    return val.Substring(0, e);
                }
            }
            i = i + 1;
        }
        return "";
    }

    /// Writes/updates the project icon path (relative to the project root) in
    /// zan.proj, dropping any prior `icon =` line so it stays single-valued.
    static void SetProjectIcon(string root, string rel) {
        string proj = root + "/zan.proj";
        string content = "";
        if (File.Exists(proj)) { content = File.ReadAllText(proj); }
        List<string> ls = CodeEditor.SplitLines(content);
        string outp = "";
        int i = 0;
        while (i < ls.Count) {
            string ln = ls[i];
            string tr = ZanIDE.TrimLeadSpaces(ln);
            if (tr.Length >= 4 && tr.Substring(0, 4) == "icon") {
                // drop the previous icon line; the new one is appended below
            } else if (tr.Length > 0) {
                outp = outp + ln + "\n";
            }
            i = i + 1;
        }
        outp = outp + "icon = " + rel + "\n";
        File.WriteAllText(proj, outp);
    }

    /// Compiles the project's custom .ico into a Windows resource so it can be
    /// linked into (packaged inside) the produced exe. Returns the .res path, or
    /// "" when no icon is configured / the .ico is missing / llvm-rc is absent.
    static string EnsureProjectIconRes(string root) {
        string rel = ZanIDE.ProjField(root, "icon");
        if (rel == "") { return ""; }
        string ico = root + "/" + rel;
        if (!File.Exists(ico)) { return ""; }
        string bd = ZanIDE.EnsureBuildDir(root);
        string rc = bd + "/app.rc";
        string res = bd + "/app.res";
        File.WriteAllText(rc, "1 ICON \"" + ico + "\"\n");
        Process.RunCapture("llvm-rc /fo \"" + res + "\" \"" + rc + "\"");
        if (!File.Exists(res)) { return ""; }
        return res;
    }

    static void Main() {
        // Restore the last-used window / panel sizes (see SaveSettings).
        string cfg = "";
        if (File.Exists(ZanIDE.CfgPath())) { cfg = File.ReadAllText(ZanIDE.CfgPath()); }
        // Default is a standard 1080 (logical, 96-dpi) width; App.Show scales it
        // up by the display DPI, so it stays a sensible size on HiDPI screens.
        int cfgW = ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "winW", 1080), 640, 4000);
        int cfgH = ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "winH", 720), 480, 3000);
        App app = App.CreateDark("Zan IDE", cfgW, cfgH);
        // Restore the last-used title-bar skin (index into Theme.PresetNames);
        // the skin picker itself is a built-in window feature (EnableSkins).
        app.ApplySkin(ZanIDE.CfgInt(cfg, "skin", 0));
        app.Show();
        // Whole-window opacity (percent), persisted like the skin.
        int winOpacity = ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "opacity", 100), 30, 100);
        app.SetWindowOpacity(winOpacity);
        int savedW = cfgW;
        int savedH = cfgH;

        // Reopen the last project the user worked on; when there is none yet,
        // start with just the Start page (no sample project is scaffolded).
        Directory.CreateDirectoryRecursive(ZanIDE.ProjectsHome());
        string lastProj = ZanIDE.ReadLastProject();
        bool haveProject = lastProj != "" && File.Exists(lastProj + "/zan.proj");
        string root = ZanIDE.ProjectsHome();
        if (haveProject) { root = lastProj; }
        if (haveProject) { ZanIDE.AddRecentProject(root); }

        List<TreeNode> tree = new List<TreeNode>();
        if (haveProject) { tree = ZanIDE.ScanTree(root); }
        bool rescan = false;

        List<string> tabNames = new List<string>();
        List<string> tabBodies = new List<string>();
        List<string> tabPaths = new List<string>();

        SignalInt activeTab = SignalInt.Create(0);
        CodeEditor editor = CodeEditor.Create();
        StatusBar statusBar = new StatusBar();
        ErrorList errorList = new ErrorList();
        Button outClearBtn = Button.Typed("Clear", 0);
        outClearBtn.size = 0;
        int lastActive = 0 - 1;
        // Which .zform tab the designer is currently bound to, and the last
        // serialized layout (to detect changes and persist them back to disk).
        string loadedFormPath = "";
        string formCache = "";
        // Same for the .zscene tab bound to the scene designer.
        string loadedScenePath = "";
        string sceneCache = "";

        if (haveProject) {
            ZanIDE.OpenFirst(tabNames, tabBodies, tabPaths, activeTab, root);
        }
        // Start page is a real tab (path sentinel "@start"), shown first like
        // VS's Start Page. Rendered specially instead of the code editor.
        tabNames.Insert(0, "Start");
        tabBodies.Insert(0, "");
        tabPaths.Insert(0, "@start");
        activeTab.Set(0);

        List<string> log = new List<string>();
        if (haveProject) {
            log.Add("> Zan IDE ready. Workspace: " + root);
        } else {
            log.Add("> Zan IDE ready. No project is open.");
        }

        ZanIDE.uiLang = ZanIDE.ReadUiLang();
        Wizard.lang = ZanIDE.uiLang;
        Designer.lang = ZanIDE.uiLang;
        SceneDesigner.lang = ZanIDE.uiLang;
        List<RibbonCmd> cmds = ZanIDE.BuildRibbon();

        // ---- New Project categories (built-in + user "Custom") ----
        List<string> catNames = new List<string>{
            "Console", "Library", "Window App", "WebView", "Server", "Custom" };

        // The template catalog and the wizard's entity view of it; both rebuilt
        // whenever the New Project wizard opens so freshly-saved custom
        // templates show up.
        List<Tpl> tpls = new List<Tpl>();
        List<WizardTemplate> wizTpls = new List<WizardTemplate>();

        // ---- New File template catalog ----
        List<WizardItem> fileItems = new List<WizardItem>{
            new WizardItem(ZanIDE.T("Program (Main)", "程序 (Main)"), "arrow-right", ZanIDE.T("Code file: class with a static Main() entry point.", "代码文件：带静态 Main() 入口的类。")),
            new WizardItem(ZanIDE.T("Class", "类"), "grid", ZanIDE.T("Code file: an empty class with fields and methods.", "代码文件：带字段和方法的空类。")),
            new WizardItem(ZanIDE.T("GUI Window", "GUI 窗口"), "maximize", ZanIDE.T("Code file: a Gui window with an event loop.", "代码文件：带事件循环的 Gui 窗口。")),
            new WizardItem(ZanIDE.T("Interface", "接口"), "copy", ZanIDE.T("Code file: a base class defining a contract.", "代码文件：定义契约的基类。")),
            new WizardItem(ZanIDE.T("Empty File", "空文件"), "file", ZanIDE.T("Code file: a blank .zan file.", "代码文件：空白的 .zan 文件。")),
            new WizardItem(ZanIDE.T("Form (Designer)", "表单 (设计器)"), "layout", ZanIDE.T("Form: creates Name.zform (visual layout) + Name.zan (code-behind).", "表单：创建 Name.zform（可视化布局）+ Name.zan（代码后置）。")),
            new WizardItem(ZanIDE.T("Game Scene (Designer)", "游戏场景 (设计器)"), "maximize", ZanIDE.T("Scene: creates Name.zscene, a free-canvas game window layout.", "场景：创建 Name.zscene，自由画布式游戏窗口布局。")) };

        // ---- Dialog state ----
        // The New Project / New File wizards are REAL secondary top-level windows
        // (draggable anywhere on the desktop), driven from this same event pump.
        // dlg is null when no wizard is open.
        // dlgMode: 1=new-project, 2=new-file, 3=save-as-template.
        App dlg = null;
        int dlgMode = 0;
        FilePicker pathPicker = FilePicker.Create();
        int pathPickerOwner = 0;
        SignalInt catSel = SignalInt.Create(0);
        SignalInt pSel = SignalInt.Create(0);
        SignalInt fSel = SignalInt.Create(0);

        // Target platforms for New Project (multi-select OS + architecture).
        // One column per OS; two architecture chips stacked per column. Chip
        // labels are arch-only (the OS is the column header). Order is
        // column-major: [Win x64, Win ARM64, Linux x64, Linux ARM64, ...].
        List<string> platformGroups = new List<string>{ "Windows", "Linux", "macOS" };
        // One entry per (OS column, architecture), column-major, all selected by
        // default. The order matches PlatformCsv's id list.
        List<WizardTarget> platforms = new List<WizardTarget>{
            new WizardTarget("x64", 1), new WizardTarget("ARM64", 1),
            new WizardTarget("x64", 1), new WizardTarget("ARM64", 1),
            new WizardTarget("x64", 1), new WizardTarget("ARM64", 1) };
        Input pNameInput = Input.Bind(SignalString.Create("NewProject"), ZanIDE.T("project name", "项目名称"));
        Input pLocInput = Input.Bind(
            SignalString.Create(ZanIDE.ReadLastPickerDirectory(ZanIDE.ProjectsHome())), ZanIDE.T("location", "位置"));
        Input fNameInput = Input.Bind(SignalString.Create("NewFile"), ZanIDE.T("file name", "文件名称"));

        // Right-click context menu (file tree + tab bar) state.
        // ctxKind: 0 = none, 1 = project tree row, 3 = editor tab.
        int ctxKind = 0;
        int ctxX = 0;
        int ctxY = 0;
        int ctxTarget = 0 - 1;

        // Save-current-project-as-custom-template state.
        SignalInt tmplCatSel = SignalInt.Create(0);
        Input tmplNameInput = Input.Bind(SignalString.Create("MyTemplate"), ZanIDE.T("template name", "模板名称"));
        List<WizardItem> saveItems = new List<WizardItem>{
            new WizardItem("Console", "menu", ZanIDE.T("Save under the Console category.", "保存到 Console 分类下。")),
            new WizardItem("Library", "grid", ZanIDE.T("Save under the Library category.", "保存到 Library 分类下。")),
            new WizardItem("Window App", "maximize", ZanIDE.T("Save under the Window App category.", "保存到 Window App 分类下。")),
            new WizardItem("WebView", "folder", ZanIDE.T("Save under the WebView category.", "保存到 WebView 分类下。")),
            new WizardItem("Server", "arrow-right", ZanIDE.T("Save under the Server category.", "保存到 Server 分类下。")),
            new WizardItem("Custom", "file", ZanIDE.T("Save under the Custom category.", "保存到 Custom 分类下。")) };

        // ---- Find/Replace & GoToLine state ----
        int findMode = 0;    // 0=hidden, 1=find, 2=replace, 3=gotoLine, 4=bpCondition
        string findText = "";
        string replText = "";
        string gotoText = "";
        int findMatch = -1;   // line of current match
        // Persistent framework Button instances for the find/replace/goto bar so
        // it renders through the themed, glass-aware component (not hand-drawn
        // hex) and matches every skin. Text is set per frame by mode.
        Button findBtn = Button.Primary(ZanIDE.T("Find", "查找")).SetSize(1);
        Button findNextBtn = Button.Create(ZanIDE.T("Next", "下一个")).SetSize(1);
        Button replBtn = Button.Primary(ZanIDE.T("Replace", "替换")).SetSize(1);
        Button replAllBtn = Button.Create(ZanIDE.T("Repl All", "全部替换")).SetSize(1);
        Button gotoBtn = Button.Primary(ZanIDE.T("Go", "跳转")).SetSize(1);
        // Start-page quick-action buttons (framework Button components).
        Button startNewProjBtn = Button.WithIcon(ZanIDE.T("New Project...", "新建项目..."), "plus");
        startNewProjBtn.SetType(1);
        Button startNewFileBtn = Button.WithIcon(ZanIDE.T("New File...", "新建文件..."), "file");
        Button startOpenBtn = Button.WithIcon(ZanIDE.T("Open...", "打开..."), "folder");
        SignalInt startNewsScroll = SignalInt.Create(0);
        StartPage startPage = new StartPage();
        Button debugContinueBtn = Button.IconTextTyped(
            ZanIDE.T("Continue", "继续"), "play", 3);
        debugContinueBtn.SetSize(1);
        Button debugStepOverBtn = Button.IconTextTyped(
            ZanIDE.T("Step Over", "单步跳过"), "arrow-right", 2);
        debugStepOverBtn.SetSize(1);
        Button debugStepIntoBtn = Button.IconTextTyped(
            ZanIDE.T("Step Into", "单步进入"), "arrow-down", 2);
        debugStepIntoBtn.SetSize(1);
        Button debugStopBtn = Button.IconTextTyped(
            ZanIDE.T("Stop", "停止"), "stop", 5);
        debugStopBtn.SetSize(1);

        // ---- Publish dialog state ----
        // pubSel holds a 0/1 flag per platform, parallel to the id list in
        // PlatformCsv (windows-x64, windows-arm64, linux-x64, linux-arm64,
        // macos-x64, macos-arm64). All targets are cross-compiled by zanc
        // via --target, so non-Windows targets are selectable too.
        bool pubOpen = false;
        bool pubPending = false;
        List<int> pubSel = new List<int>();
        // In-flight detached publish: exe paths to verify on completion plus
        // the consumed length of its streamed log (see the poll below).
        bool pubBusy = false;
        List<string> pubExes = new List<string>();
        int pubLogLen = 0;

        // ---- Editor appearance (color theme + font size) ----
        // edThemeIdx selects a syntax-color preset (see EditorThemeName); edFontPx
        // is the code font size (0 = follow the UI theme). Persisted to editor.cfg.
        bool cfgOpen = false;
        // Asset Manager overlay (browse/import/organize assets/ recursively).
        bool assetMgrOpen = false;
        int edThemeIdx = ZanIDE.ReadEditorTheme();
        int edFontPx = ZanIDE.ReadEditorFont();
        int defFontPx = app.theme.fontSizeMedium;
        EditorSettingsWindow settingsWindow = null;

        // ---- Help / Docs browser state ----
        // The docs page is a real tab (path sentinel "@docs"). docsSearch filters
        // the entry list; docsSel is the selected entry; docsScroll scrolls the
        // sidebar list.
        Input docsSearch = Input.Bind(SignalString.Create(""), ZanIDE.T("Search syntax & components...", "搜索语法与组件..."));
        SignalInt docsSel = SignalInt.Create(0);
        SignalInt docsSection = SignalInt.Create(0);
        SignalInt docsScroll = SignalInt.Create(0);
        SignalInt docsCodeScroll = SignalInt.Create(0);
        SignalBool docsDemoBool = SignalBool.Create(true);
        SignalInt docsDemoInt = SignalInt.Create(2);
        Input docsDemoInput = Input.Bind(
            SignalString.Create("Zan"), ZanIDE.T("Type here", "在此输入"));

        // Pending "go to definition" jump, applied after the target tab loads.
        int pendingGotoLine = 0 - 1;
        int pendingGotoCol = 0;

        // ---- Output console text selection (drag to select, right-click copy) ----
        // Anchor/head positions are absolute (row = index into `log`, col = char).
        int coSelDrag = 0;
        int coSelA = 0 - 1;
        int coSelAc = 0;
        int coSelB = 0 - 1;
        int coSelBc = 0;
        // Output console scroll (lines up from the bottom; 0 = follow the tail),
        // a scrollbar-drag flag, and a substring filter box. The console owns its
        // own scrolling/filtering rather than the caller wiring it up each time.
        int coScroll = 0;
        int coSbDrag = 0;
        // Output/Errors right-click context menu (copy line / copy all / clear).
        bool coCtxOpen = false;
        int coCtxX = 0;
        int coCtxY = 0;
        int coCtxRow = 0 - 1;
        Input coFilter = Input.Bind(SignalString.Create(""),
            ZanIDE.T("Filter output...", "筛选输出..."));

        // ---- Debug state ----
        int dbgState = 0;
        int dbgExecLine = -1;
        DebugSession dbg = null;
        List<string> dbgConsole = new List<string>();
        List<string> dbgVarInfo = new List<string>();
        List<string> dbgStack = new List<string>();
        SignalInt dbgPanelTab = SignalInt.Create(0);
        // Conditional breakpoints: expression per 0-based line (edited via
        // Ctrl+B, passed through DAP setBreakpoints as `condition`).
        List<int> bpCondLines = new List<int>();
        List<string> bpCondExprs = new List<string>();
        string bpCondText = "";
        // Watch expressions, re-evaluated via DAP `evaluate` on every stop.
        List<string> dbgWatches = new List<string>();
        List<string> dbgWatchVals = new List<string>();
        string watchText = "";
        // Semantic language server (zan-lsp), started lazily on first
        // navigation request; falls back to text scanning when unavailable.
        LspSession lspSess = null;
        bool lspTried = false;

        // ---- Designer state ----
        // The single unified designer: .zform tabs host the component-based
        // form designer (stdlib Gui.Designer) with palette, containers,
        // inspector and event bindings. Its design document round-trips
        // through the .zform file.
        bool designerMode = false;
        Designer formDesigner = Designer.Create();
        // Design/Code toggle: codeViewForm holds the path of the .zform currently
        // shown as code ("" = design view). The code view reuses a dedicated,
        // in-place editor over the paired code-behind -- it never opens a new tab
        // or creates a file just from switching modes. Only .zform tabs toggle.
        string codeViewForm = "";
        CodeEditor formCodeEd = CodeEditor.Create();
        string formCodeLoaded = "";
        // .zscene tabs host the free-canvas game scene designer (stdlib
        // Game.Scene.SceneDesigner): background reference, absolute placement,
        // nine-grid anchors, grid snapping, slot grid groups, z-order. The
        // Design/Code toggle shows the .zscene JSON in place.
        bool sceneMode = false;
        SceneDesigner sceneDesigner = SceneDesigner.Create();
        AssetManager assetMgr = AssetManager.Create();

        SignalInt treeW = SignalInt.Create(ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "treeW", 240), 120, 900));
        // The code editor is the primary area: it fills the space left over
        // after the bottom output panel, so it grows with the window instead of
        // being pinned to a fixed height that leaves a huge output pane. We
        // persist the compact OUTPUT height; `editorAreaH` is recomputed from it
        // each frame and only used to drive the resize handle.
        SignalInt bottomPanelH = SignalInt.Create(ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "bottomH", 190), 70, 2000));
        SignalInt editorAreaH = SignalInt.Create(430);
        // Bottom panel active tab: 0 = Output, 1 = Error List, 2 = Terminal.
        SignalInt bottomTab = SignalInt.Create(ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "bottomTab", 0), 0, 1));

        // ---- Right side panel (AI assistant / integrated terminal) ----
        // Third column of the aardio-style 3-pane layout: sidebar | editor |
        // side panel. rightW persists across launches; centerW is derived from
        // it each frame so the Split drag handle moves the panel edge.
        SignalInt rightW = SignalInt.Create(ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "rightW", 300), 120, 1600));
        SignalInt centerW = SignalInt.Create(0);
        // 0 = AI chat, 1 = tools/ tree, 2 = examples/ tree, 3 = git panel.
        SignalInt rightTab = SignalInt.Create(ZanIDE.CfgClamp(ZanIDE.CfgInt(cfg, "rightTab", 0), 0, 3));
        // ---- Git panel state (right panel "Git" tab) ----
        // gitFiles holds `git status --porcelain` lines; gitLoaded gates the
        // first (and refresh-triggered) status scan so git only runs on demand.
        List<string> gitFiles = new List<string>();
        string gitBranch = "";
        bool gitLoaded = false;
        SignalInt gitSel = SignalInt.Create(0 - 1);
        SignalInt gitScroll = SignalInt.Create(0);
        Input gitMsgIn = Input.Bind(SignalString.Create(""),
            ZanIDE.T("Commit message...", "提交信息..."));
        // Tools / Examples trees for the right panel tabs.
        List<TreeNode> rtToolTree = ZanIDE.BuildDirTree(root + "/tools");
        List<TreeNode> rtExTree = ZanIDE.BuildExampleTree();
        SignalInt rtToolSel = SignalInt.Create(-1);
        SignalInt rtExSel = SignalInt.Create(-1);
        Input rtToolFilter = Input.Bind(SignalString.Create(""), ZanIDE.T("Filter...", "筛选..."));
        Input rtExFilter = Input.Bind(SignalString.Create(""), ZanIDE.T("Filter...", "筛选..."));
        SignalInt rtToolScroll = SignalInt.Create(0);
        SignalInt rtExScroll = SignalInt.Create(0);
        // Chat transcript: parallel role ("user"/"assistant"/"error") + text.
        List<string> aiRole = new List<string>();
        List<string> aiText = new List<string>();
        SignalInt aiScroll = SignalInt.Create(0);
        // 1 while a completion request is in flight (curl runs detached and the
        // event loop polls for its done-marker file, so the UI never blocks).
        SignalInt aiBusy = SignalInt.Create(0);
        Input aiInput = Input.Bind(SignalString.Create(""),
            ZanIDE.T("Ask AI about your code...", "向 AI 提问，辅助开发..."));
        Button aiSendBtn = Button.Primary(ZanIDE.T("Send", "发送")).SetSize(1);
        // "Insert code" applies the code block of the last AI answer at the
        // editor cursor, making the assistant a real pair-programming tool.
        Button aiApplyBtn = Button.WithIcon(ZanIDE.T("Insert code", "插入代码"), "code").SetSize(1);
        // "Replace file" swaps the whole active file for the last AI code block.
        Button aiReplaceBtn = Button.Create(ZanIDE.T("Replace file", "替换整文件")).SetSize(1);
        // ---- AI provider profiles (ai_profiles.json) ----
        // Parallel lists: profile name / base URL / API key / default model /
        // `;`-joined fetched model ids. `aiProfActive` is the enabled profile.
        List<string> aiProfNames = new List<string>();
        List<string> aiProfBases = new List<string>();
        List<string> aiProfKeys = new List<string>();
        List<string> aiProfModels = new List<string>();
        List<string> aiProfLists = new List<string>();
        int aiProfActive = ZanIDE.AiProfilesLoad(aiProfNames, aiProfBases,
            aiProfKeys, aiProfModels, aiProfLists);
        SignalInt aiCfgShow = SignalInt.Create(0);
        SignalInt aiModelsBusy = SignalInt.Create(0);
        int aiUiProf = aiProfActive;  // profile shown in the config editor
        bool aiUiLoaded = false;      // inputs already filled for aiUiProf
        // Chat model switcher: the dropdown lists the active profile's models
        // (default model first); no selection = the profile's default model.
        SelectBox aiModelSel = SelectBox.Create(ZanIDE.T("Model (default)", "模型（默认）"));
        List<string> aiModelOpts = new List<string>();
        int aiModelSelProf = 0 - 1;
        Input aiNameIn = Input.Bind(SignalString.Create(""), ZanIDE.T("Profile name", "配置名称"));
        Input aiBaseIn = Input.Bind(SignalString.Create(""), "https://api.openai.com/v1");
        Input aiKeyIn = Input.Bind(SignalString.Create(""), "API Key");
        Input aiModelIn = Input.Bind(SignalString.Create(""), ZanIDE.T("Default model", "默认模型"));
        Button aiCfgBtn = Button.Create(ZanIDE.T("Config", "配置")).SetSize(1);
        Button aiPredictBtn = Button.Create(ZanIDE.T("Continue", "续写")).SetSize(1);
        Button aiProfPrevBtn = Button.Create("<").SetSize(1);
        Button aiProfNextBtn = Button.Create(">").SetSize(1);
        Button aiProfAddBtn = Button.Create(ZanIDE.T("Add", "新增")).SetSize(1);
        Button aiProfDelBtn = Button.Create(ZanIDE.T("Delete", "删除")).SetSize(1);
        Button aiProfUseBtn = Button.Primary(ZanIDE.T("Save & enable", "保存并启用")).SetSize(1);
        Button aiFetchBtn = Button.Create(ZanIDE.T("Fetch models", "获取模型")).SetSize(1);
        // Official provider presets: one click adds a profile with the
        // provider's base URL + default model; "Sign up" opens its portal.
        List<string> aiPreNames = new List<string>();
        List<string> aiPreBases = new List<string>();
        List<string> aiPreModels = new List<string>();
        List<string> aiPreRegs = new List<string>();
        ZanIDE.AiPresetsInto(aiPreNames, aiPreBases, aiPreModels, aiPreRegs);
        SelectBox aiPresetSel = SelectBox.Create(ZanIDE.T("Official presets", "官方预设"));
        int preI = 0;
        while (preI < aiPreNames.Count) {
            aiPresetSel.AddOption(aiPreNames[preI]);
            preI = preI + 1;
        }
        Button aiPresetAddBtn = Button.Create(ZanIDE.T("Use preset", "用预设新增")).SetSize(1);
        Button aiRegBtn = Button.Create(ZanIDE.T("Sign up", "注册")).SetSize(1);
        // Chat sessions: switch / new / clear the transcript context. Inactive
        // sessions are kept serialized in `aiSessions` (\u0002-joined records).
        List<string> aiSessions = new List<string>();
        int aiSessCur = 0;
        aiSessions.Add("");
        Button aiSessPrevBtn = Button.Create("<").SetSize(1);
        Button aiSessNextBtn = Button.Create(">").SetSize(1);
        Button aiSessNewBtn = Button.Create(ZanIDE.T("New chat", "新会话")).SetSize(1);
        Button aiSessClearBtn = Button.Create(ZanIDE.T("Clear", "清空")).SetSize(1);
        // Chat transcript wrapped-line cache (rebuilt only when the transcript,
        // width or theme changes — rewrapping every frame is too slow).
        List<string> aiCacheLines = new List<string>();
        List<int> aiCacheColors = new List<int>();
        List<int> aiCacheKinds = new List<int>();
        string aiCacheKey = "";
        // In-flight "AI continue at caret" request (tab it was started from).
        SignalInt aiPredBusy = SignalInt.Create(0);
        int aiPredTab = 0 - 1;
        // Run shell: a persistent interactive shell session used to stream a
        // launched program's output into the Output tab without blocking the
        // UI. Its stdin is a pipe (Process.ShellSend) and its stdout/stderr
        // stream to a session log file polled each frame.
        int termFp = 0;
        int termLogLen = 0;
        // Hot reload: when ON, saving rebuilds and restarts the running app.
        bool autoRun = ZanIDE.CfgInt(cfg, "autoRun", 0) == 1;
        SignalInt treeSel = SignalInt.Create(-1);
        int lastTreeSel = -1;

        // Vertical scroll offsets for the sidebar sections, so long lists stay
        // inside their region (EXPLORER in pixels, COMPONENTS/EXAMPLES in rows).
        SignalInt treeScrollY = SignalInt.Create(0);

        // Third sidebar section: the standard library as a collapsible tree
        // (browse/open stdlib sources directly, like aardio's 库 pane).
        List<TreeNode> exTree = ZanIDE.BuildStdlibTree();
        SignalInt exSel = SignalInt.Create(-1);

        // Per-section filter boxes: each sidebar tree can be narrowed by a
        // case-insensitive substring; the displayed (possibly filtered) lists
        // are recomputed every frame so click handlers index into them.
        Input treeFilter = Input.Bind(SignalString.Create(""), ZanIDE.T("Filter...", "筛选..."));
        Input structFilter = Input.Bind(SignalString.Create(""), ZanIDE.T("Filter...", "筛选..."));
        Input exFilter = Input.Bind(SignalString.Create(""), ZanIDE.T("Filter...", "筛选..."));
        List<TreeNode> treeShow = new List<TreeNode>();
        List<TreeNode> structShow = new List<TreeNode>();
        List<TreeNode> exShow = new List<TreeNode>();
        int lastExSel = -1;
        SignalInt exTreeScrollY = SignalInt.Create(0);

        // STRUCTURE (code outline): types + their members for the active code
        // file, rebuilt only when the buffer signature changes so navigation
        // stays cheap. Clicking a member jumps the editor to its line.
        List<TreeNode> structTree = new List<TreeNode>();
        SignalInt structSel = SignalInt.Create(-1);
        int lastStructSel = -1;
        SignalInt structScrollY = SignalInt.Create(0);
        string structSig = "@none";

        int lastPresent = 0;
        int lastSkinIdx = app.ThemeMenuIndex();
        while (app.isRunning) {
            // Advance any active AI automation script (ZAN_UI_SCRIPT). This
            // pump bypasses App.ProcessEvent, so drive the driver here too;
            // it injects synthetic events this loop then polls & dispatches.
            UiDriver.Tick();
            FilePicker.lang = ZanIDE.uiLang;
            CodeEditor.lang = ZanIDE.uiLang;
            Designer.lang = ZanIDE.uiLang;
            pathPicker.ApplySkin(app.ThemeMenuIndex());
            // Skin follow: App.SyncSkin raises themeMenuChange (delegate event)
            // when the user picks a new skin; every child window then follows
            // the main window's look here, once per change.
            if (app.ThemeMenuIndex() != lastSkinIdx) {
                lastSkinIdx = app.ThemeMenuIndex();
                if (dlg != null) {
                    dlg.ApplySkin(lastSkinIdx);
                    dlg.RequestRedraw();
                }
                if (settingsWindow != null && settingsWindow.IsOpen()) {
                    settingsWindow.FollowSkin(lastSkinIdx);
                }
            }
            // Opacity follow: the appearance drawer sets it on the main
            // window; children inherit it and the value is persisted.
            if (app.WindowOpacity() != winOpacity) {
                winOpacity = app.WindowOpacity();
                if (dlg != null) { dlg.SetWindowOpacity(winOpacity); }
                if (settingsWindow != null && settingsWindow.IsOpen()) {
                    settingsWindow.FollowOpacity(winOpacity);
                }
            }
            // One shared event pump drives BOTH the main window and any open
            // wizard child window. Poll (to keep animating) when either needs a
            // repaint; otherwise block until the OS delivers an event.
            bool want = pathPicker.NeedsRedraw();
            if (!pathPicker.IsOpen() && app.needsRedraw) { want = true; }
            if (!pathPicker.IsOpen() && dlg != null) {
                if (dlg.needsRedraw) { want = true; }
            }
            if (!pathPicker.IsOpen() && settingsWindow != null) {
                if (settingsWindow.NeedsRedraw()) { want = true; }
            }
            int r;
            if (want) {
                int since = Window.GetTickMs() - lastPresent;
                if (lastPresent > 0 && since < 16) { Window.SleepMs(16 - since); }
                r = app.window.PollEvent();
            } else {
                // Mirror App.ProcessEvent's idle path: this pump bypasses
                // ProcessEvent, so it must serve the throttled animation /
                // skin-effect deadlines itself — otherwise backdrop effects
                // only tick when the mouse generates events.
                r = 1;
                bool idleWait = true;
                while (idleWait) {
                    int deadline = app.animNextMs;
                    if (app.fxNextMs >= 0 && (deadline < 0 || app.fxNextMs < deadline)) {
                        deadline = app.fxNextMs;
                    }
                    // Fold the wizard child window's animation deadlines in too, so
                    // its button hover/press cross-fades and ripples keep ticking
                    // after the mouse stops (otherwise a fade-out freezes mid-way
                    // until the next OS event).
                    if (dlg != null) {
                        if (dlg.animNextMs >= 0 && (deadline < 0 || dlg.animNextMs < deadline)) {
                            deadline = dlg.animNextMs;
                        }
                        if (dlg.fxNextMs >= 0 && (deadline < 0 || dlg.fxNextMs < deadline)) {
                            deadline = dlg.fxNextMs;
                        }
                    }
                    if (deadline < 0) {
                        r = app.window.WaitEvent();
                        idleWait = false;
                    } else {
                        int idleNow = Window.GetTickMs();
                        if (idleNow >= deadline) {
                            bool childDue = false;
                            if (dlg != null) {
                                if (dlg.animNextMs >= 0 && idleNow >= dlg.animNextMs) { childDue = true; }
                                if (dlg.fxNextMs >= 0 && idleNow >= dlg.fxNextMs) { childDue = true; }
                            }
                            bool fxOnly = app.animNextMs < 0 || idleNow < app.animNextMs;
                            if (!childDue && fxOnly && app.FxPresent()) {
                                // Effect tick presented in place; keep idling.
                            } else {
                                app.needsRedraw = true;
                                if (childDue) { dlg.RequestRedraw(); }
                                r = app.window.PollEvent();
                                idleWait = false;
                            }
                        } else {
                            r = app.window.WaitEventTimeout(deadline - idleNow);
                            if (r != 1) { idleWait = false; }
                        }
                    }
                }
            }
            if (r < 0) { break; }

            int evh = Window.EventHwnd();
            int kind = app.window.EventKind();

            if (kind == 8) {
                if (settingsWindow != null
                    && settingsWindow.OwnsWindow(evh)) {
                    settingsWindow.ApplyEvent(evh);
                    app.RequestRedraw();
                } else if (pathPicker.OwnsWindow(evh)) {
                    pathPicker.ApplyEvent(evh);
                } else if (!pathPicker.IsOpen()) {
                    // Close: only the main window quits the app; a wizard window
                    // that closes simply dismisses the wizard.
                    if (evh == app.WindowHandle()) { break; }
                    dlg = null;
                    dlgMode = 0;
                    if (pathPickerOwner == 1) {
                        pathPicker.Close();
                        pathPickerOwner = 0;
                    }
                    app.RequestRedraw();
                }
            } else if (pathPicker.IsOpen()
                       || pathPicker.OwnsWindow(evh)) {
                pathPicker.ApplyEvent(evh);
            } else {
                app.ApplyEvent(evh);
                if (dlg != null) { dlg.ApplyEvent(evh); }
                if (settingsWindow != null) {
                    settingsWindow.ApplyEvent(evh);
                }
            }
            // The form designer is bound to .zform tabs (C#-style form files):
            // the active tab's extension decides whether the designer or the code
            // editor is shown, rather than a global toggle.
            int actDM = activeTab.Get();
            if (actDM >= 0 && actDM < tabPaths.Count) {
                designerMode = ZanIDE.IsFormPath(tabPaths[actDM]) && tabPaths[actDM] != codeViewForm;
                sceneMode = ZanIDE.IsScenePath(tabPaths[actDM]) && tabPaths[actDM] != codeViewForm;
            } else {
                designerMode = false;
                sceneMode = false;
            }

            // ---- keyboard shortcuts for debug ----
            if (kind == 5) {
                int kc = app.window.EventKeyCode();
                if (kc == 116 && dbgState == 0) {
                    // F5 = Start Debug (same as clicking Debug button)
                    ZanIDE.SaveActive(
                        editor, tabNames, tabBodies,
                        tabPaths, activeTab, root, log);
                    if (ZanIDE.DebugBuild(
                            tabPaths, activeTab, root, log, editor)) {
                        dbg = ZanIDE.DbgBegin(root,
                            ZanIDE.PathOf(tabPaths, activeTab),
                            editor.Breakpoints(),
                            ZanIDE.FirstDebugLine(editor), bpCondLines, bpCondExprs, log);
                        dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                        dbgExecLine = ZanIDE.DbgLine(dbg);
                        dbgVarInfo = ZanIDE.DbgVars(dbg);
                        dbgStack = ZanIDE.DbgStack(dbg);
                        dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                        dbgPanelTab.Set(1);
                        if (dbgState == 2) {
                            log.Add(">   F5=Continue  F10=StepOver  F11=StepInto  Ctrl+B=Condition  Esc=Stop");
                            ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                        } else {
                            dbg = null;
                        }
                    }
                    app.RequestRedraw();
                } else if (kc == 116 && dbgState == 2) {
                    // F5 = Continue
                    if (dbg != null) { dbg.Continue(); }
                    dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                    dbgExecLine = ZanIDE.DbgLine(dbg);
                    dbgVarInfo = ZanIDE.DbgVars(dbg);
                    dbgStack = ZanIDE.DbgStack(dbg);
                    dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                    if (dbgState == 2) {
                        ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                    } else {
                        dbg = null;
                    }
                    app.RequestRedraw();
                } else if (kc == 121 && dbgState == 2) {
                    // F10 = Step Over
                    if (dbg != null) { dbg.StepOver(); }
                    dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                    dbgExecLine = ZanIDE.DbgLine(dbg);
                    dbgVarInfo = ZanIDE.DbgVars(dbg);
                    dbgStack = ZanIDE.DbgStack(dbg);
                    dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                    if (dbgState == 2) {
                        ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                    } else {
                        dbg = null;
                    }
                    app.RequestRedraw();
                } else if (kc == 122 && dbgState == 2) {
                    // F11 = Step Into
                    if (dbg != null) { dbg.StepIn(); }
                    dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                    dbgExecLine = ZanIDE.DbgLine(dbg);
                    dbgVarInfo = ZanIDE.DbgVars(dbg);
                    dbgStack = ZanIDE.DbgStack(dbg);
                    dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                    if (dbgState == 2) {
                        ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                    } else {
                        dbg = null;
                    }
                    app.RequestRedraw();
                } else if (kc == 27 && dbgState == 2) {
                    // Escape = Stop debugging
                    if (dbg != null) { dbg.Stop(); dbg = null; }
                    dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                    log.Add("> [Debug] Stopped.");
                    app.RequestRedraw();
                } else if (kc == 27 && findMode > 0) {
                    // Escape = close find/replace/goto
                    findMode = 0;
                    app.RequestRedraw();
                } else if (kc == 27 && pubOpen) {
                    // Escape = close publish dialog
                    pubOpen = false;
                    app.RequestRedraw();
                } else if (kc == 27 && assetMgrOpen) {
                    // Escape = close the asset manager
                    assetMgrOpen = false;
                    app.RequestRedraw();
                } else if (kc == 123 && !designerMode && dbgState == 0) {
                    // F12 = Go to Definition
                    if (lspSess == null && !lspTried) {
                        lspTried = true;
                        lspSess = LspSession.Start(root);
                        if (lspSess != null) { log.Add("> zan-lsp connected: semantic navigation enabled."); }
                    }
                    int gl12 = ZanIDE.GoToDefinitionSmart(lspSess, editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    if (gl12 >= 0) { pendingGotoLine = gl12; pendingGotoCol = 0; lastActive = 0 - 1; }
                    app.RequestRedraw();
                } else if (kc == 118 && !designerMode && dbgState == 0) {
                    // F7 = View Designer: open the .zform paired with this code-behind.
                    int actF7 = activeTab.Get();
                    if (actF7 >= 0 && actF7 < tabPaths.Count) {
                        string ap7 = tabPaths[actF7];
                        if (ap7.Length > 4 && ap7.Substring(ap7.Length - 4, 4) == ".zan") {
                            string cand7 = ap7.Substring(0, ap7.Length - 4) + ".zform";
                            if (File.Exists(cand7)) {
                                int ci7 = ZanIDE.FindTabByPath(tabPaths, cand7);
                                if (ci7 >= 0) { activeTab.Set(ci7); }
                                else { ZanIDE.OpenPath(tabNames, tabBodies, tabPaths, activeTab, cand7, Path.GetFileName(cand7)); }
                                loadedFormPath = "";
                                lastActive = 0 - 1;
                            } else {
                                log.Add("> No paired .zform for " + Path.GetFileName(ap7) + ".");
                            }
                        }
                    }
                    app.RequestRedraw();
                }
            }
            // Ctrl+key via WM_CHAR (kind == 6)
            if (kind == 6) {
                int cc = app.window.EventKeyCode();
                if (cc == 6) {
                    // Ctrl+F = Find
                    findMode = 1;
                    app.RequestRedraw();
                } else if (cc == 7) {
                    // Ctrl+G = Go to Line
                    findMode = 3;
                    gotoText = "";
                    app.RequestRedraw();
                } else if (cc == 18) {
                    // Ctrl+R = Replace (Ctrl+H is 8 which conflicts with Backspace)
                    findMode = 2;
                    app.RequestRedraw();
                } else if (cc == 2) {
                    // Ctrl+B = edit the breakpoint condition on the caret line
                    if (!designerMode) {
                        findMode = 4;
                        bpCondText = ZanIDE.CondFor(bpCondLines, bpCondExprs,
                            editor.CurLine());
                    }
                    app.RequestRedraw();
                } else if (cc == 19) {
                    // Ctrl+S = Save (+ hot reload when enabled)
                    int aSv = activeTab.Get();
                    if (aSv >= 0 && aSv < tabPaths.Count
                            && ZanIDE.IsFormPath(tabPaths[aSv]) && codeViewForm == tabPaths[aSv]) {
                        // In the .zform code view, save the code-behind, not the form.
                        ZanIDE.SaveFormCode(formCodeEd, tabPaths[aSv], root, log);
                        rescan = true;
                    } else if (aSv >= 0 && aSv < tabPaths.Count
                            && ZanIDE.IsScenePath(tabPaths[aSv]) && codeViewForm == tabPaths[aSv]) {
                        // In the .zscene code view, save the scene JSON itself.
                        File.WriteAllText(tabPaths[aSv], formCodeEd.GetText());
                        tabBodies[aSv] = formCodeEd.GetText();
                        loadedScenePath = "";
                        log.Add("> Saved " + tabPaths[aSv] + ".");
                        rescan = true;
                        Layer.Msg(ZanIDE.T("Saved", "已保存"), 3);
                    } else if (!designerMode && !sceneMode && aSv >= 0 && aSv < tabPaths.Count && tabPaths[aSv] != "@start") {
                        ZanIDE.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        if (autoRun) { ZanIDE.HotReloadRun(tabPaths, activeTab, root, log); }
                        rescan = true;
                        Layer.Msg(ZanIDE.T("Saved", "已保存"), 3);
                    }
                    app.RequestRedraw();
                }
            }

            // ---------------- main IDE window ----------------
            if (app.needsRedraw && !pathPicker.IsOpen()) {
                app.BeginFrame();
                Canvas c = app.canvas;
                Theme t = app.theme;
                int W = c.Width();
                int H = c.Height();
                // Persist the LOGICAL (96-dpi) window size, not the physical
                // canvas size. The window is created from a logical size that the
                // runtime scales up by the display DPI; saving the scaled size and
                // re-creating from it would re-scale every launch (the window kept
                // growing/shrinking). Divide back out by dpiScale (a percentage).
                int dscale = app.dpiScale;
                if (dscale <= 0) { dscale = 100; }
                savedW = W * 100 / dscale;
                savedH = H * 100 / dscale;
                int top = app.titlebarH;
                int ribbonH = Ribbon.Height(app);
                int sbH = app.Scale(22);
                // Themed window backdrop (gradient/glass wallpaper or flat fill)
                // behind the whole shell, so the IDE renders every skin exactly
                // like the gallery. Translucent surfaces below let it show.
                app.RenderBackground(0, top, W, H - top, 0);

                // Enable/disable ribbon commands by context. Build/Publish/Hot/
                // Config need an open project (zan.proj); Run/Debug/Designer work
                // on a single open file; all are disabled on the Start page.
                int atE = activeTab.Get();
                string apE = "";
                if (atE >= 0 && atE < tabPaths.Count) { apE = tabPaths[atE]; }
                bool activeIsFile = apE != "" && apE != "@start";
                bool haveProj = File.Exists(root + "/zan.proj");
                // Run/Debug/Build follow the active file, or fall back to the
                // project entry (so a designer/start tab can still run the app).
                bool canRun = activeIsFile || haveProj;
                cmds[5].SetEnabled(canRun);
                cmds[6].SetEnabled(canRun);
                cmds[7].SetEnabled(canRun);
                cmds[8].SetEnabled(haveProj);
                cmds[9].SetEnabled(haveProj);
                cmds[10].SetEnabled(activeIsFile
                    && (ZanIDE.IsFormPath(apE) || ZanIDE.IsScenePath(apE)));
                cmds[12].SetEnabled(haveProj);
                cmds[13].SetEnabled(haveProj);
                int rc = ZanIDE.RibbonAction(
                    Ribbon.Render(app, 0, top, W, ribbonH, cmds));
                if (rc == 0 && dlg == null) {
                    // Rebuild the catalog (built-ins + custom templates on disk).
                    tpls = ZanIDE.BuildCatalog(root);
                    wizTpls = ZanIDE.WizTemplates(tpls);
                    catNames = ZanIDE.CatsOf(tpls);
                    catSel.Set(0);
                    pSel.Set(0);
                    pNameInput.SetText("NewProject");
                    pLocInput.SetText(ZanIDE.ReadLastPickerDirectory(ZanIDE.ProjectsHome()));
                    Wizard.notice = "";
                    dlg = App.CreateDark(ZanIDE.T("New Project", "新建项目"), 900, 640);
                    dlg.ApplySkin(app.ThemeMenuIndex());
                    dlg.Show();
                    dlgMode = 1;
                } else if (rc == 1 && dlg == null) {
                    dlg = ZanIDE.OpenWizard(app, ZanIDE.T("New File", "新建文件"), fSel, fNameInput, "NewFile");
                    dlgMode = 2;
                } else if (rc == 2) {
                    pathPicker.BeginOpenFile(
                        ZanIDE.ReadLastPickerDirectory(root), ".zan",
                        ZanIDE.T("Open Zan source file", "打开 Zan 源文件"));
                    pathPickerOwner = 4;
                    app.RequestRedraw();
                } else if (rc == 3) {
                    int aSv3 = activeTab.Get();
                    if (aSv3 >= 0 && aSv3 < tabPaths.Count
                            && ZanIDE.IsFormPath(tabPaths[aSv3]) && codeViewForm == tabPaths[aSv3]) {
                        ZanIDE.SaveFormCode(formCodeEd, tabPaths[aSv3], root, log);
                    } else if (aSv3 >= 0 && aSv3 < tabPaths.Count
                            && ZanIDE.IsScenePath(tabPaths[aSv3]) && codeViewForm == tabPaths[aSv3]) {
                        File.WriteAllText(tabPaths[aSv3], formCodeEd.GetText());
                        tabBodies[aSv3] = formCodeEd.GetText();
                        loadedScenePath = "";
                        log.Add("> Saved " + tabPaths[aSv3] + ".");
                    } else {
                        ZanIDE.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        if (autoRun) { ZanIDE.HotReloadRun(tabPaths, activeTab, root, log); }
                    }
                    Layer.Msg(ZanIDE.T("Saved", "已保存"), 3);
                    rescan = true;
                } else if (rc == 4) {
                    Layer.Msg(ZanIDE.T("Building & running…", "正在构建并运行…"), 2);
                    ZanIDE.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    string runExe = ZanIDE.RunBuildActive(tabPaths, activeTab, root, log, editor);
                    if (runExe != "") {
                        // Stream the program through the persistent terminal shell so a
                        // long-running server keeps printing into the IDE without blocking
                        // the UI (Ctrl+C in the terminal stops it).
                        if (termFp == 0) {
                            termFp = ZanIDE.TermOpen(root);
                            termLogLen = 0;
                        }
                        if (termFp != 0) {
                            bottomTab.Set(0);
                            log.Add("> " + runExe);
                            Process.ShellSend(termFp, "\"" + runExe + "\"");
                            app.RequestRedraw();
                        } else {
                            log.Add(ZanIDE.T("[error] Could not start the shell session.", "[错误] 无法启动 shell 会话。"));
                        }
                    }
                } else if (rc == 5) {
                    Layer.Msg(ZanIDE.T("Building…", "正在构建…"), 2);
                    ZanIDE.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    ZanIDE.BuildActive(tabPaths, activeTab, root, log, editor);
                } else if (rc == 6) {
                    ZanIDE.SaveActive(editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                    pubSel = ZanIDE.ReadProjectPlatforms(root);
                    pubOpen = true;
                    app.RequestRedraw();
                } else if (rc == 7) {
                    // Debug (F5)
                    designerMode = false;
                    if (dbgState == 0) {
                        ZanIDE.SaveActive(
                            editor, tabNames, tabBodies,
                            tabPaths, activeTab, root, log);
                        if (ZanIDE.DebugBuild(
                                tabPaths, activeTab, root, log, editor)) {
                            dbg = ZanIDE.DbgBegin(root,
                                ZanIDE.PathOf(tabPaths, activeTab),
                                editor.Breakpoints(),
                                ZanIDE.FirstDebugLine(editor), bpCondLines, bpCondExprs, log);
                            dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                            dbgExecLine = ZanIDE.DbgLine(dbg);
                            dbgVarInfo = ZanIDE.DbgVars(dbg);
                            dbgStack = ZanIDE.DbgStack(dbg);
                            dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                            dbgPanelTab.Set(1);
                            if (dbgState == 2) {
                                log.Add(">   F5=Continue  F10=StepOver  F11=StepInto  Ctrl+B=Condition  Esc=Stop");
                                ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                            } else {
                                dbg = null;
                            }
                        }
                    } else if (dbgState == 2) {
                        if (dbg != null) { dbg.Continue(); }
                        dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                        dbgExecLine = ZanIDE.DbgLine(dbg);
                        dbgVarInfo = ZanIDE.DbgVars(dbg);
                        dbgStack = ZanIDE.DbgStack(dbg);
                        dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                        if (dbgState == 2) {
                            ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                        } else {
                            dbg = null;
                        }
                    }
                } else if (rc == 8 && dlg == null) {
                    tmplCatSel.Set(5);
                    tmplNameInput.SetText(Path.GetFileName(root));
                    dlg = App.CreateDark(ZanIDE.T("Save as Template", "另存为模板"), 640, 470);
                    dlg.ApplySkin(app.ThemeMenuIndex());
                    dlg.Show();
                    dlgMode = 3;
                } else if (rc == 9) {
                    // Design/Code: toggle the CURRENT .zform/.zscene tab in place
                    // between the visual designer and a view of its code. It never
                    // opens a new tab nor creates a file, and only design tabs have
                    // it -- other files stay in code and cannot enter design mode.
                    int act9 = activeTab.Get();
                    if (act9 >= 0 && act9 < tabPaths.Count
                            && (ZanIDE.IsFormPath(tabPaths[act9]) || ZanIDE.IsScenePath(tabPaths[act9]))) {
                        string fp9 = tabPaths[act9];
                        if (codeViewForm == fp9) {
                            codeViewForm = "";
                            // Leaving a .zscene code view: apply the edited JSON
                            // to the designer so the two views stay in sync.
                            if (ZanIDE.IsScenePath(fp9) && formCodeLoaded == fp9) {
                                string sedit = formCodeEd.GetText();
                                if (ZanIDE.LooksLikeJson(sedit)) {
                                    tabBodies[act9] = sedit;
                                    File.WriteAllText(fp9, sedit);
                                    loadedScenePath = "";
                                }
                            }
                            log.Add(ZanIDE.T("> Design view.", "> 设计视图。"));
                        } else {
                            codeViewForm = fp9;
                            formCodeLoaded = "";
                            log.Add(ZanIDE.T("> Code view.", "> 代码视图。"));
                        }
                    } else {
                        log.Add(ZanIDE.T("> Design/Code applies only to .zform/.zscene files.", "> 设计/代码切换仅适用于 .zform/.zscene 文件。"));
                    }
                    lastActive = 0 - 1;
                    app.RequestRedraw();
                } else if (rc == 10) {
                    // Focus the Start tab, opening one if it was closed.
                    int si = ZanIDE.FindTabByPath(tabPaths, "@start");
                    if (si >= 0) {
                        activeTab.Set(si);
                    } else {
                        tabNames.Add("Start"); tabBodies.Add(""); tabPaths.Add("@start");
                        activeTab.Set(tabNames.Count - 1);
                    }
                    lastActive = 0 - 1;
                    app.RequestRedraw();
                } else if (rc == 11) {
                    autoRun = !autoRun;
                    if (autoRun) { log.Add("> Hot reload: ON (save rebuilds & restarts the app)."); }
                    else { log.Add("> Hot reload: OFF."); }
                    app.RequestRedraw();
                } else if (rc == 12) {
                    // Open the visual Project Configuration panel (icon + static
                    // resources bundled with the app).
                    if (File.Exists(root + "/zan.proj")) {
                        cfgOpen = true;
                    } else {
                        log.Add("> Open or create a project first to configure it.");
                    }
                    app.RequestRedraw();
                } else if (rc == 13) {
                    if (settingsWindow == null
                        || !settingsWindow.IsOpen()) {
                        settingsWindow = EditorSettingsWindow.Open(
                            app, edThemeIdx, edFontPx,
                            ZanIDE.uiLang, defFontPx);
                    }
                } else if (rc == 15) {
                    // Open the Asset Manager (assets/ browser + batch import).
                    if (File.Exists(root + "/zan.proj")) {
                        assetMgrOpen = true;
                    } else {
                        log.Add("> Open or create a project first to manage its assets.");
                    }
                    app.RequestRedraw();
                } else if (rc == 14) {
                    // Open the Help / documentation browser (a real "@docs" tab).
                    int di = ZanIDE.FindTabByPath(tabPaths, "@docs");
                    if (di >= 0) {
                        activeTab.Set(di);
                    } else {
                        tabNames.Add(ZanIDE.T("Help", "帮助")); tabBodies.Add(""); tabPaths.Add("@docs");
                        activeTab.Set(tabNames.Count - 1);
                    }
                    lastActive = 0 - 1;
                    app.RequestRedraw();
                }

                // ---- Debug toolbar (when debugging) ----
                int dbgBarH = 0;
                if (dbgState == 2) {
                    dbgBarH = app.Scale(38);
                    int dbgAction = DebugPanel.RenderDebugToolbar(
                        app, c, t, 0, top + ribbonH, W, dbgBarH, dbgExecLine,
                        debugContinueBtn, debugStepOverBtn,
                        debugStepIntoBtn, debugStopBtn);
                    if (dbgAction == 0) {
                        if (dbg != null) { dbg.Continue(); }
                        dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                        dbgExecLine = ZanIDE.DbgLine(dbg);
                        dbgVarInfo = ZanIDE.DbgVars(dbg);
                        dbgStack = ZanIDE.DbgStack(dbg);
                        dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                        if (dbgState == 2) {
                            ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                        } else { dbg = null; }
                        app.RequestRedraw();
                    } else if (dbgAction == 1) {
                        if (dbg != null) { dbg.StepOver(); }
                        dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                        dbgExecLine = ZanIDE.DbgLine(dbg);
                        dbgVarInfo = ZanIDE.DbgVars(dbg);
                        dbgStack = ZanIDE.DbgStack(dbg);
                        dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                        if (dbgState == 2) {
                            ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                        } else { dbg = null; }
                        app.RequestRedraw();
                    } else if (dbgAction == 2) {
                        if (dbg != null) { dbg.StepIn(); }
                        dbgState = ZanIDE.DbgSync(dbg, editor, log, dbgConsole);
                        dbgExecLine = ZanIDE.DbgLine(dbg);
                        dbgVarInfo = ZanIDE.DbgVars(dbg);
                        dbgStack = ZanIDE.DbgStack(dbg);
                        dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                        if (dbgState == 2) {
                            ZanIDE.LogVarsToConsole(log, dbgVarInfo, dbgExecLine);
                        } else { dbg = null; }
                        app.RequestRedraw();
                    } else if (dbgAction == 3) {
                        if (dbg != null) { dbg.Stop(); dbg = null; }
                        dbgState = 0; dbgExecLine = -1; editor.SetExecLine(-1);
                        log.Add("> [Debug] Stopped.");
                        app.RequestRedraw();
                    }
                }

                Rect area = Rect.Create(0, top + ribbonH + dbgBarH, W, H - top - ribbonH - dbgBarH - sbH);
                Split cols = Split.Vertical(app, area, treeW, app.Scale(170), app.Scale(440));

                Rect tr = cols.first;
                ZanIDE.ShellSurface(app, tr.x, tr.y, tr.width, tr.height, 0, t.bgTertiary);
                int sectionH = app.Scale(24);
                int explorerH = (tr.height * 40) / 100;
                int structH = (tr.height * 32) / 100;
                int exampleH = tr.height - explorerH - structH;

                // Section 1: Explorer (inline filter bar owned by the tree)
                c.DrawText(tr.x + t.paddingMedium, tr.y + t.paddingSmall, ZanIDE.T("EXPLORER", "资源管理器"), t.textTertiary, t.fontSizeSmall);
                Rect treeArea = Rect.Create(tr.x, tr.y + sectionH, tr.width, explorerH - sectionH);
                treeArea = TreeView.FilterBar(app, treeArea, treeFilter);
                treeShow = ZanIDE.FilterNodes(tree, treeFilter.GetText());
                // Wheel-scroll the tree when the pointer is over it. Scroll in
                // whole-row steps so rows always align to the region top (the
                // renderer only draws rows fully inside the area).
                int treeRowH = TreeView.RowHeight(app);
                int treeVis = treeArea.height / treeRowH;
                if (treeVis < 1) { treeVis = 1; }
                int treeContentH = TreeView.ContentHeight(app, treeShow);
                int treeMaxScroll = treeContentH - treeVis * treeRowH;
                if (treeMaxScroll < 0) { treeMaxScroll = 0; }
                int tScroll = treeScrollY.Get();
                bool ownsTreeWheel = app.CaptureWheel(
                    treeArea.x, treeArea.y, treeArea.width, treeArea.height);
                if (ownsTreeWheel) {
                    int td = app.window.EventKeyCode();
                    int step = td / 120;
                    if (step == 0) {
                        if (td > 0) { step = 1; }
                        else if (td < 0) { step = 0 - 1; }
                    }
                    tScroll = tScroll - step * treeRowH;
                    app.RequestRedraw();
                }
                if (tScroll > treeMaxScroll) { tScroll = treeMaxScroll; }
                if (tScroll < 0) { tScroll = 0; }
                treeScrollY.Set(tScroll);
                int trRight = TreeView.Render(app, treeArea, treeShow, treeSel, tScroll);
                if (trRight >= 0) {
                    ctxKind = 1; ctxX = app.mouseX; ctxY = app.mouseY;
                    ctxTarget = trRight; app.RequestRedraw();
                }

                // Section 2: Structure / Components. Shows a code outline for
                // source tabs, and the form's component tree in the designer.
                int stY = tr.y + explorerH;
                c.FillRect(tr.x, stY, tr.width, 1, t.divider);
                string stTitle = ZanIDE.T("STRUCTURE", "结构");
                if (designerMode || sceneMode) { stTitle = ZanIDE.T("COMPONENTS", "组件"); }
                c.DrawText(tr.x + t.paddingMedium, stY + t.paddingSmall, stTitle, t.textTertiary, t.fontSizeSmall);
                // Rebuild the tree only when the active buffer/form changes so
                // typing and clicking stay cheap. The signature prefix (C/F)
                // also flips the panel between code outline and components.
                int stActTab = activeTab.Get();
                string newSig = "";
                if (designerMode) {
                    List<FormField> flatSig = new List<FormField>();
                    ZanIDE.FlattenFields(formDesigner.fields, flatSig);
                    newSig = "F:" + Convert.ToString(stActTab) + ":" + Convert.ToString(flatSig.Count);
                } else if (sceneMode) {
                    newSig = "S:" + Convert.ToString(stActTab) + ":"
                        + Convert.ToString(sceneDesigner.doc.Count()) + ":"
                        + Convert.ToString(sceneDesigner.doc.ToJson().Length);
                } else {
                    // TextStamp is O(lines) with no allocation; the full text is
                    // only materialised when the outline actually needs rebuilding.
                    newSig = "C:" + Convert.ToString(stActTab) + ":" + Convert.ToString(editor.TextStamp());
                    if (newSig != structSig) { structTree = ZanIDE.BuildOutline(editor.GetText()); }
                }
                if (newSig != structSig) {
                    structSig = newSig;
                    if (designerMode) {
                        string sfn = "Form";
                        if (stActTab >= 0 && stActTab < tabPaths.Count) {
                            sfn = ZanIDE.FormBaseName(tabPaths[stActTab]);
                        }
                        structTree = ZanIDE.BuildFieldTree(sfn, formDesigner.fields);
                    } else if (sceneMode) {
                        string scn = "Scene";
                        if (stActTab >= 0 && stActTab < tabPaths.Count) {
                            scn = ZanIDE.BaseName(tabPaths[stActTab]);
                        }
                        structTree = ZanIDE.BuildSceneTree(scn, sceneDesigner);
                    }
                    structSel.Set(0 - 1);
                    lastStructSel = 0 - 1;
                }
                Rect stArea = Rect.Create(tr.x, stY + sectionH, tr.width, structH - sectionH);
                stArea = TreeView.FilterBar(app, stArea, structFilter);
                structShow = ZanIDE.FilterNodes(structTree, structFilter.GetText());
                int stRowH = TreeView.RowHeight(app);
                int stVis = stArea.height / stRowH;
                if (stVis < 1) { stVis = 1; }
                int stContentH = TreeView.ContentHeight(app, structShow);
                int stMaxScroll = stContentH - stVis * stRowH;
                if (stMaxScroll < 0) { stMaxScroll = 0; }
                int stSc = structScrollY.Get();
                bool ownsStructWheel = app.CaptureWheel(stArea.x, stArea.y, stArea.width, stArea.height);
                if (ownsStructWheel) {
                    int std2 = app.window.EventKeyCode();
                    int ststep = std2 / 120;
                    if (ststep == 0) {
                        if (std2 > 0) { ststep = 1; }
                        else if (std2 < 0) { ststep = 0 - 1; }
                    }
                    stSc = stSc - ststep * stRowH;
                    app.RequestRedraw();
                }
                if (stSc > stMaxScroll) { stSc = stMaxScroll; }
                if (stSc < 0) { stSc = 0; }
                structScrollY.Set(stSc);
                if (structShow.Count == 0) {
                    c.DrawText(stArea.x + t.paddingMedium, stArea.y + t.paddingSmall,
                        ZanIDE.T("No symbols", "无符号"), t.textTertiary, t.fontSizeSmall);
                } else {
                    TreeView.Render(app, stArea, structShow, structSel, stSc);
                }
                // Clicking a node navigates: an outline symbol jumps the editor
                // to its line; a component selects that control in the designer.
                int stSelV = structSel.Get();
                if (stSelV != lastStructSel) {
                    lastStructSel = stSelV;
                    if (stSelV >= 0 && stSelV < structShow.Count) {
                        if (designerMode) {
                            int ci = ZanIDE.OutlineLineOf(structShow[stSelV].path);
                            List<FormField> flatSel = new List<FormField>();
                            ZanIDE.FlattenFields(formDesigner.fields, flatSel);
                            if (ci >= 0 && ci < flatSel.Count) {
                                formDesigner.sel = flatSel[ci];
                                app.RequestRedraw();
                            }
                        } else if (sceneMode) {
                            int ci = ZanIDE.OutlineLineOf(structShow[stSelV].path);
                            List<SceneElement> ordSel = sceneDesigner.OrderedByZ();
                            if (ci >= 0 && ci < ordSel.Count) {
                                sceneDesigner.sel = ordSel[ci];
                                sceneDesigner.selExtra = new List<SceneElement>();
                                app.RequestRedraw();
                            }
                        } else {
                            int gln = ZanIDE.OutlineLineOf(structShow[stSelV].path);
                            if (gln >= 0) {
                                pendingGotoLine = gln; pendingGotoCol = 0;
                                app.RequestRedraw();
                            }
                        }
                    }
                }

                // Section 3: Examples (collapsible tree, click a leaf to open)
                int exY = tr.y + explorerH + structH;
                c.FillRect(tr.x, exY, tr.width, 1, t.divider);
                c.DrawText(tr.x + t.paddingMedium, exY + t.paddingSmall, ZanIDE.T("STDLIB", "标准库"), t.textTertiary, t.fontSizeSmall);
                Rect exArea = Rect.Create(tr.x, exY + sectionH, tr.width, exampleH - sectionH);
                exArea = TreeView.FilterBar(app, exArea, exFilter);
                exShow = ZanIDE.FilterNodes(exTree, exFilter.GetText());
                int exRowH = TreeView.RowHeight(app);
                int exVis = exArea.height / exRowH;
                if (exVis < 1) { exVis = 1; }
                int exContentH = TreeView.ContentHeight(app, exShow);
                int exMaxScroll = exContentH - exVis * exRowH;
                if (exMaxScroll < 0) { exMaxScroll = 0; }
                int exSc = exTreeScrollY.Get();
                bool ownsExampleWheel = app.CaptureWheel(
                    exArea.x, exArea.y, exArea.width, exArea.height);
                if (ownsExampleWheel) {
                    int exd = app.window.EventKeyCode();
                    int exstep = exd / 120;
                    if (exstep == 0) {
                        if (exd > 0) { exstep = 1; }
                        else if (exd < 0) { exstep = 0 - 1; }
                    }
                    exSc = exSc - exstep * exRowH;
                    app.RequestRedraw();
                }
                if (exSc > exMaxScroll) { exSc = exMaxScroll; }
                if (exSc < 0) { exSc = 0; }
                exTreeScrollY.Set(exSc);
                TreeView.Render(app, exArea, exShow, exSel, exSc);

                int sel = treeSel.Get();
                if (sel != lastTreeSel) {
                    lastTreeSel = sel;
                    if (ctxKind == 0 && sel >= 0 && sel < treeShow.Count) {
                        TreeNode node = treeShow[sel];
                        if (!node.isDir) {
                            ZanIDE.OpenPath(tabNames, tabBodies, tabPaths, activeTab, node.path, node.label);
                            log.Add("> Opened " + node.path + ".");
                        }
                    }
                }

                // Open an example when its tree leaf is clicked. Real files
                // (scanned from examples/) open by path so Run/Debug compile
                // the actual source; the "@ex:" pseudo-leaf is the built-in
                // component center used only when no examples ship on disk.
                int exSelV = exSel.Get();
                if (exSelV != lastExSel) {
                    lastExSel = exSelV;
                    if (exSelV >= 0 && exSelV < exShow.Count) {
                        TreeNode en = exShow[exSelV];
                        if (!en.isDir && ZanIDE.StartsWith(en.path, "@ex:")) {
                            int di = ZanIDE.FindTabByPath(tabPaths, "@docs");
                            if (di >= 0) {
                                activeTab.Set(di);
                            } else {
                                tabNames.Add(ZanIDE.T("Components", "组件中心"));
                                tabBodies.Add("");
                                tabPaths.Add("@docs");
                                activeTab.Set(tabNames.Count - 1);
                            }
                            lastActive = 0 - 1;
                            log.Add("> Opened the GUI component center.");
                            app.RequestRedraw();
                        } else if (!en.isDir && en.path != "") {
                            ZanIDE.OpenPath(tabNames, tabBodies, tabPaths,
                                activeTab, en.path, en.label);
                            log.Add("> Opened " + en.path + ".");
                            app.RequestRedraw();
                        }
                    }
                }

                // Third column: split the remaining area into the editor stack
                // and the right side panel (AI / terminal). The persisted value
                // is the RIGHT panel width, so window resizes keep the editor
                // as the dominant area; centerW only drives the drag handle.
                int rightMin = app.Scale(140);
                int centerMin = app.Scale(260);
                int splitHandleW = app.Scale(5);
                int wantCenter = cols.second.width - rightW.Get() - splitHandleW;
                if (wantCenter < centerMin) { wantCenter = centerMin; }
                centerW.Set(wantCenter);
                Split mid = Split.Vertical(app, cols.second, centerW, centerMin, rightMin);
                Rect centerArea = mid.first;
                Rect rightArea = mid.second;
                int newRightW = cols.second.width - centerW.Get() - splitHandleW;
                if (newRightW < rightMin) { newRightW = rightMin; }
                rightW.Set(newRightW);

                // The designer takes the whole center column (full-height design
                // surface, aardio-style); code tabs keep the editor/output split.
                Rect ea = centerArea;
                Rect orr = Rect.Create(centerArea.x, centerArea.y + centerArea.height, centerArea.width, 0);
                if (!designerMode && !sceneMode) {
                    int bottomMin = app.Scale(90);
                    if (dbgState == 2) { bottomMin = app.Scale(160); }
                    int editorMin = app.Scale(140);
                    int splitHandleH = 5;
                    // Editor fills everything above the (compact) output panel.
                    int wantEditorH = centerArea.height - bottomPanelH.Get() - splitHandleH;
                    if (wantEditorH < editorMin) { wantEditorH = editorMin; }
                    editorAreaH.Set(wantEditorH);
                    Split rows = Split.Horizontal(app, centerArea, editorAreaH, editorMin, bottomMin);
                    ea = rows.first;
                    orr = rows.second;
                    // Persist the resulting output height (not the editor height) so
                    // resizing the window keeps the editor as the dominant area.
                    int newBottomH = centerArea.height - editorAreaH.Get() - splitHandleH;
                    if (newBottomH < bottomMin) { newBottomH = bottomMin; }
                    bottomPanelH.Set(newBottomH);
                }

                int tabH = TabView.Height(app);
                TabHit hit = TabView.Render(app, ea.x, ea.y, ea.width, tabH, tabNames, activeTab, true);
                if (hit.action == 4) {
                    ctxKind = 3; ctxX = app.mouseX; ctxY = app.mouseY;
                    ctxTarget = hit.index; app.RequestRedraw();
                } else if (ctxKind == 0) {
                    if (hit.action == 3 && dlg == null) {
                        dlg = ZanIDE.OpenWizard(app, ZanIDE.T("New File", "新建文件"), fSel, fNameInput, "NewFile");
                        dlgMode = 2;
                    } else if (hit.action == 2) {
                        if (tabNames.Count > 1) {
                            tabNames.RemoveAt(hit.index);
                            tabBodies.RemoveAt(hit.index);
                            tabPaths.RemoveAt(hit.index);
                            int a = activeTab.Get();
                            if (a > hit.index) { a = a - 1; }
                            if (a >= tabNames.Count) { a = tabNames.Count - 1; }
                            if (a < 0) { a = 0; }
                            activeTab.Set(a);
                            lastActive = 0 - 1;
                        }
                    } else if (hit.action == 1) {
                        activeTab.Set(hit.index);
                    }
                }

                int act = activeTab.Get();
                if (act != lastActive) {
                    // Only sync editor text for code tabs; .zform tabs are owned by
                    // the designer and must not be overwritten with editor contents.
                    if (lastActive >= 0 && lastActive < tabBodies.Count
                        && !ZanIDE.IsFormPath(tabPaths[lastActive])
                        && !ZanIDE.IsScenePath(tabPaths[lastActive])) {
                        tabBodies[lastActive] = editor.GetText();
                    }
                    if (act >= 0 && act < tabBodies.Count
                        && !ZanIDE.IsFormPath(tabPaths[act])
                        && !ZanIDE.IsScenePath(tabPaths[act])) {
                        editor.LoadText(tabBodies[act]);
                        // Feed the other open source files to the editor so it can
                        // resolve cross-file types (e.g. a `Utils` class defined
                        // in another tab) for accurate completion.
                        List<string> projFiles = new List<string>();
                        int pf = 0;
                        while (pf < tabBodies.Count) {
                            if (pf != act && pf < tabPaths.Count
                                && !ZanIDE.IsFormPath(tabPaths[pf])
                                && !ZanIDE.IsScenePath(tabPaths[pf])
                                && tabPaths[pf] != "@start") {
                                projFiles.Add(tabBodies[pf]);
                            }
                            pf = pf + 1;
                        }
                        editor.SetProjectFiles(projFiles);
                    }
                    lastActive = act;
                }

                if (pendingGotoLine >= 0) {
                    editor.GoToLineCol(pendingGotoLine, pendingGotoCol);
                    pendingGotoLine = 0 - 1;
                    app.RequestRedraw();
                }

                Rect edRect = Rect.Create(ea.x, ea.y + tabH, ea.width, ea.height - tabH);
                bool activeIsStart = (act >= 0 && act < tabPaths.Count && tabPaths[act] == "@start");
                bool activeIsDocs = (act >= 0 && act < tabPaths.Count && tabPaths[act] == "@docs");

                if (designerMode) {
                    // The .zform tab hosts the full component-based form designer
                    // (stdlib Gui.Designer): palette, containers, inspector, event
                    // bindings, JSON drawer. The .zform file stores its design
                    // document; legacy coordinate-based .zform files are converted
                    // on first open.
                    string fpath = tabPaths[act];
                    string fname = ZanIDE.FormBaseName(fpath);
                    if (fpath != loadedFormPath) {
                        string fbody = tabBodies[act];
                        if (ZanIDE.LooksLikeJson(fbody)) {
                            formDesigner.LoadJson(fbody);
                        } else {
                            formDesigner.LoadJson(ZanIDE.LegacyFormToJson(fname, fbody));
                        }
                        loadedFormPath = fpath;
                        formCache = formDesigner.SaveJson();
                        ZanIDE.LoadUserComponents(root, formDesigner);
                        // Offer the code-behind's variables in the designer's
                        // bind-path picker (two-way binding targets).
                        string cbpB = ZanIDE.CodeBehindPath(fpath);
                        if (File.Exists(cbpB)) {
                            formDesigner.SetBindVars(ZanIDE.ScanBindVars(File.ReadAllText(cbpB)));
                        } else {
                            formDesigner.SetBindVars(new List<string>());
                        }
                    }
                    formDesigner.Render(app, edRect.x, edRect.y, edRect.width, edRect.height);
                    // Persist design changes to the .zform file and keep the
                    // runnable code-behind's designer region in sync.
                    string newser = formDesigner.SaveJson();
                    if (newser != formCache) {
                        tabBodies[act] = newser;
                        if (fpath.Length > 0 && fpath.Substring(0, 1) != "@") {
                            File.WriteAllText(fpath, newser);
                            string cbpS = ZanIDE.CodeBehindPath(fpath);
                            if (File.Exists(cbpS)) {
                                string cbNew = ZanIDE.ReplaceDesignerRegion(File.ReadAllText(cbpS),
                                    ZanIDE.FieldsRegion(fname, formDesigner.fields, formDesigner.winW, formDesigner.winH));
                                File.WriteAllText(cbpS, cbNew);
                                int cbTab = ZanIDE.FindTabByPath(tabPaths, cbpS);
                                if (cbTab >= 0) { tabBodies[cbTab] = cbNew; }
                            }
                        }
                        formCache = newser;
                    }
                    // "Save as component": persist the whole design as a reusable
                    // project component (components/<name>.zcomp) and refresh the
                    // designer's "My Components" palette group.
                    if (formDesigner.ConsumeSaveComponent()) {
                        string compName = ZanIDE.SanitizeName(formDesigner.formNameSig.Get());
                        if (compName == "") { compName = fname; }
                        string compDir = root + "/components";
                        Directory.CreateDirectoryRecursive(compDir);
                        string compPath = compDir + "/" + compName + ".zcomp";
                        File.WriteAllText(compPath, formDesigner.SaveJson());
                        ZanIDE.LoadUserComponents(root, formDesigner);
                        log.Add("> Saved component -> " + compPath + ".");
                        app.RequestRedraw();
                    }
                } else if (sceneMode) {
                    // The .zscene tab hosts the free-canvas game scene designer
                    // (stdlib Game.Scene.SceneDesigner). The .zscene file stores
                    // the scene JSON document.
                    string spath = tabPaths[act];
                    if (spath != loadedScenePath) {
                        string sbody = tabBodies[act];
                        if (ZanIDE.LooksLikeJson(sbody)) {
                            sceneDesigner.LoadJson(sbody);
                        } else {
                            sceneDesigner.LoadJson(SceneDoc.Create(
                                ZanIDE.SceneBaseName(spath), 1280, 720).ToJson());
                        }
                        loadedScenePath = spath;
                        sceneCache = sceneDesigner.SaveJson();
                    }
                    SceneDesigner.assetsDir = ZanIDE.AssetsDir(root);
                    sceneDesigner.Render(app, edRect.x, edRect.y, edRect.width, edRect.height);
                    // Persist design changes to the .zscene file.
                    string snewser = sceneDesigner.SaveJson();
                    if (snewser != sceneCache) {
                        tabBodies[act] = snewser;
                        if (spath.Length > 0 && spath.Substring(0, 1) != "@") {
                            File.WriteAllText(spath, snewser);
                        }
                        sceneCache = snewser;
                    }
                } else if (activeIsDocs) {
                    DocsPage.RenderDocsPage(
                        app, c, t, edRect, docsSearch,
                        docsSel, docsSection, docsScroll, docsCodeScroll, docsDemoBool,
                        docsDemoInt, docsDemoInput, log);
                } else if (activeIsStart) {
                    List<string> spRecents = ZanIDE.ReadRecentProjects();
                    List<string> spTags = new List<string>();
                    List<string> spTitles = new List<string>();
                    List<string> spLinks = new List<string>();
                    ZanIDE.StartNewsInto(root, spTags, spTitles, spLinks);
                    startPage.SetData(spRecents, spTags, spTitles);
                    startPage.RenderAt(app, edRect.x, edRect.y, edRect.width, edRect.height,
                        startNewProjBtn, startNewFileBtn, startOpenBtn, startNewsScroll);
                    int sact = startPage.TakeAction();
                    if (sact == 1 && dlg == null) {
                        tpls = ZanIDE.BuildCatalog(root);
                        wizTpls = ZanIDE.WizTemplates(tpls);
                        catNames = ZanIDE.CatsOf(tpls);
                        catSel.Set(0);
                        pSel.Set(0);
                        pNameInput.SetText("NewProject");
                        pLocInput.SetText(ZanIDE.ReadLastPickerDirectory(ZanIDE.ProjectsHome()));
                        Wizard.notice = "";
                        dlg = App.CreateDark(ZanIDE.T("New Project", "新建项目"), 900, 640);
                        dlg.ApplySkin(app.ThemeMenuIndex());
                        dlg.Show();
                        dlgMode = 1;
                        app.RequestRedraw();
                    } else if (sact == 2 && dlg == null) {
                        dlg = ZanIDE.OpenWizard(app, ZanIDE.T("New File", "新建文件"), fSel, fNameInput, "NewFile");
                        dlgMode = 2;
                        app.RequestRedraw();
                    } else if (sact == 3) {
                        pathPicker.BeginOpenFile(
                            ZanIDE.ReadLastPickerDirectory(root), ".zan",
                            ZanIDE.T("Open Zan source file", "打开 Zan 源文件"));
                        pathPickerOwner = 4;
                        app.RequestRedraw();
                    } else if (sact >= 200) {
                        int nidx = sact - 200;
                        if (nidx >= 0 && nidx < spLinks.Count) {
                            string nurl = spLinks[nidx];
                            if (nurl == "@docs" || nurl == "") {
                                int di = ZanIDE.FindTabByPath(tabPaths, "@docs");
                                if (di < 0) {
                                    tabNames.Add(ZanIDE.T("Help", "帮助"));
                                    tabBodies.Add("");
                                    tabPaths.Add("@docs");
                                    di = tabPaths.Count - 1;
                                }
                                activeTab.Set(di);
                                lastActive = 0 - 1;
                            } else {
                                ZanIDE.OpenExternal(nurl);
                            }
                            app.RequestRedraw();
                        }
                    } else if (sact >= 100) {
                        int fidx = sact - 100;
                        if (fidx >= 0 && fidx < spRecents.Count) {
                            string newRoot = spRecents[fidx];
                            if (newRoot != root && Directory.Exists(newRoot)) {
                                root = newRoot;
                                haveProject = true;
                                ZanIDE.WriteLastProject(root);
                                tabNames = new List<string>();
                                tabBodies = new List<string>();
                                tabPaths = new List<string>();
                                activeTab.Set(0);
                                lastActive = 0 - 1;
                                ZanIDE.OpenFirst(tabNames, tabBodies, tabPaths, activeTab, root);
                                rescan = true;
                                log.Add("> Opened project " + root + ".");
                            }
                            app.RequestRedraw();
                        }
                    }
                } else if (act >= 0 && act < tabPaths.Count
                        && ZanIDE.IsScenePath(tabPaths[act]) && codeViewForm == tabPaths[act]) {
                    // Code view of the current .zscene: show and edit the scene
                    // JSON in place; Save writes it back to the same file.
                    string spC = tabPaths[act];
                    if (formCodeLoaded != spC) {
                        string sTxt = "";
                        if (File.Exists(spC)) { sTxt = File.ReadAllText(spC); }
                        else { sTxt = tabBodies[act]; }
                        formCodeEd.LoadText(sTxt);
                        formCodeLoaded = spC;
                    }
                    ZanIDE.ApplyEditorTheme(formCodeEd, edThemeIdx, edFontPx);
                    formCodeEd.Render(app, edRect);
                } else if (act >= 0 && act < tabPaths.Count
                        && ZanIDE.IsFormPath(tabPaths[act]) && codeViewForm == tabPaths[act]) {
                    // Code view of the current .zform: show its code (read from the
                    // paired code-behind, kept in sync by the designer) in place --
                    // no new tab, no new file. Editing + Save writes the code-behind.
                    string fpC = tabPaths[act];
                    string fnC = ZanIDE.FormBaseName(fpC);
                    if (formCodeLoaded != fpC) {
                        string cbpC = ZanIDE.CodeBehindPath(fpC);
                        string codeTxt = "";
                        if (File.Exists(cbpC)) {
                            codeTxt = File.ReadAllText(cbpC);
                        } else {
                            codeTxt = ZanIDE.CodeBehindShell(fnC,
                                ZanIDE.FieldsRegion(fnC, new List<FormField>(), 480, 520));
                        }
                        formCodeEd.LoadText(codeTxt);
                        formCodeLoaded = fpC;
                    }
                    ZanIDE.ApplyEditorTheme(formCodeEd, edThemeIdx, edFontPx);
                    formCodeEd.Render(app, edRect);
                } else {
                    // Sync debug vars into editor for hover tooltips
                    if (dbgState == 2) { editor.SetDebugVars(dbgVarInfo); }
                    else { editor.SetDebugVars(new List<string>()); }
                    ZanIDE.ApplyEditorTheme(editor, edThemeIdx, edFontPx);
                    editor.Render(app, edRect);
                    // Publish live editor state to the AI automation driver
                    // (ZAN_UI_SCRIPT) so scripts can assert buffer/caret and the
                    // completion popup without screen-scraping. Inert otherwise.
                    if (UiDriver.Active()) {
                        UiDriver.SetProbe("editor", ZanIDE.EditorProbeJson(editor));
                        UiDriver.SetProbe("log", string.Join("\n", log));
                    }
                    // Ctrl+click in the editor requests Go to Definition.
                    if (editor.ConsumeGotoRequest()) {
                        if (lspSess == null && !lspTried) {
                            lspTried = true;
                            lspSess = LspSession.Start(root);
                            if (lspSess != null) { log.Add("> zan-lsp connected: semantic navigation enabled."); }
                        }
                        int glc = ZanIDE.GoToDefinitionSmart(lspSess, editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        if (glc >= 0) { pendingGotoLine = glc; pendingGotoCol = 0; lastActive = 0 - 1; }
                        app.RequestRedraw();
                    }
                    // Draw inline debug annotations
                    if (dbgState == 2 && dbgExecLine >= 0) {
                        DebugPanel.RenderInlineVars(app, c, t, edRect, dbgVarInfo, dbgExecLine);
                    }
                }

                // ---- Find / Replace / GoToLine overlay ----
                if (findMode > 0 && !designerMode && !sceneMode && !activeIsStart && !activeIsDocs) {
                    int fpH = app.Scale(36);
                    if (findMode == 2) { fpH = app.Scale(68); }
                    int fpW = app.Scale(360);
                    int fpX = edRect.x + edRect.width - fpW - app.Scale(8);
                    int fpY = edRect.y + app.Scale(4);
                    ZanIDE.ShellSurface(app, fpX, fpY, fpW, fpH, app.Scale(4), t.bgSecondary);
                    c.DrawRect(fpX, fpY, fpW, fpH, t.borderPrimary, 1);
                    int inpX = fpX + app.Scale(8);
                    int inpY = fpY + app.Scale(8);
                    int inpW = fpW - app.Scale(100);
                    int inpH = app.Scale(22);
                    if (findMode == 1) {
                        c.DrawText(fpX + app.Scale(4), fpY + app.Scale(2), ZanIDE.T("Find (Ctrl+F)", "查找 (Ctrl+F)"), t.textTertiary, t.fontSizeSmall);
                        ZanIDE.ShellField(app, inpX, inpY, inpW, inpH);
                        c.DrawText(inpX + app.Scale(4), inpY + app.Scale(4), findText, t.textPrimary, t.fontSizeSmall);
                        // Find/Next buttons (framework Button components).
                        int btnX = inpX + inpW + app.Scale(6);
                        int fbId = findBtn.Render(app, btnX, inpY, app.Scale(36));
                        int btn2X = btnX + app.Scale(42);
                        int nbId = findNextBtn.Render(app, btn2X, inpY, app.Scale(36));
                        // Handle key input into find box
                        if (kind == 6) {
                            int fcc = app.window.EventKeyCode();
                            if (fcc == 8 && findText.Length > 0) {
                                findText = findText.Substring(0, findText.Length - 1);
                                app.RequestRedraw();
                            } else if (fcc == 13) {
                                findMatch = ZanIDE.FindInEditor(editor, findText, findMatch);
                                app.RequestRedraw();
                            } else if (fcc > 31) {
                                findText = findText + Text.CharStr(fcc);
                                app.RequestRedraw();
                            }
                        }
                        // Click Find/Next buttons
                        if (Button.WasClicked(app, fbId)) {
                            findMatch = ZanIDE.FindInEditor(editor, findText, -1);
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, nbId)) {
                            findMatch = ZanIDE.FindInEditor(editor, findText, findMatch);
                            app.RequestRedraw();
                        }
                    } else if (findMode == 2) {
                        c.DrawText(fpX + app.Scale(4), fpY + app.Scale(2), ZanIDE.T("Replace (Ctrl+R)", "替换 (Ctrl+R)"), t.textTertiary, t.fontSizeSmall);
                        ZanIDE.ShellField(app, inpX, inpY, inpW, inpH);
                        c.DrawText(inpX + app.Scale(4), inpY + app.Scale(4), findText, t.textPrimary, t.fontSizeSmall);
                        int row2Y = inpY + inpH + app.Scale(6);
                        ZanIDE.ShellField(app, inpX, row2Y, inpW, inpH);
                        c.DrawText(inpX + app.Scale(4), row2Y + app.Scale(4), replText, t.textPrimary, t.fontSizeSmall);
                        int rbX = inpX + inpW + app.Scale(6);
                        replBtn.Render(app, rbX, inpY, app.Scale(70));
                        replAllBtn.Render(app, rbX, row2Y, app.Scale(70));
                    } else if (findMode == 3) {
                        c.DrawText(fpX + app.Scale(4), fpY + app.Scale(2), ZanIDE.T("Go to Line (Ctrl+G)", "跳转到行 (Ctrl+G)"), t.textTertiary, t.fontSizeSmall);
                        ZanIDE.ShellField(app, inpX, inpY, inpW, inpH);
                        c.DrawText(inpX + app.Scale(4), inpY + app.Scale(4), gotoText, t.textPrimary, t.fontSizeSmall);
                        int gbX = inpX + inpW + app.Scale(6);
                        int gId = gotoBtn.Render(app, gbX, inpY, app.Scale(30));
                        // Handle key input for goto line
                        if (kind == 6) {
                            int gcc = app.window.EventKeyCode();
                            if (gcc == 8 && gotoText.Length > 0) {
                                gotoText = gotoText.Substring(0, gotoText.Length - 1);
                                app.RequestRedraw();
                            } else if (gcc == 13) {
                                int gLine = ZanIDE.ParseInt(gotoText);
                                if (gLine > 0) { editor.GoToLine(gLine - 1); }
                                findMode = 0;
                                app.RequestRedraw();
                            } else if (gcc >= 48 && gcc <= 57) {
                                gotoText = gotoText + Text.CharStr(gcc);
                                app.RequestRedraw();
                            }
                        }
                        // Click Go button
                        if (Button.WasClicked(app, gId)) {
                            int gLine2 = ZanIDE.ParseInt(gotoText);
                            if (gLine2 > 0) { editor.GoToLine(gLine2 - 1); }
                            findMode = 0;
                            app.RequestRedraw();
                        }
                    } else if (findMode == 4) {
                        c.DrawText(fpX + app.Scale(4), fpY + app.Scale(2),
                            ZanIDE.T("Breakpoint Condition (Ctrl+B) - line ", "断点条件 (Ctrl+B) - 行 ")
                            + Convert.ToString(editor.CurLine() + 1),
                            t.textTertiary, t.fontSizeSmall);
                        ZanIDE.ShellField(app, inpX, inpY, inpW, inpH);
                        c.DrawText(inpX + app.Scale(4), inpY + app.Scale(4), bpCondText, t.textPrimary, t.fontSizeSmall);
                        if (kind == 6) {
                            int bcc = app.window.EventKeyCode();
                            if (bcc == 8 && bpCondText.Length > 0) {
                                bpCondText = bpCondText.Substring(0, bpCondText.Length - 1);
                                app.RequestRedraw();
                            } else if (bcc == 13) {
                                int bLine = editor.CurLine();
                                ZanIDE.SetCond(bpCondLines, bpCondExprs, bLine, bpCondText);
                                if (bpCondText.Length > 0 && !editor.HasBreakpoint(bLine)) {
                                    editor.ToggleBreakpoint(bLine);
                                }
                                if (bpCondText.Length > 0) {
                                    log.Add("> [Debug] Breakpoint condition on line "
                                        + Convert.ToString(bLine + 1) + ": " + bpCondText);
                                } else {
                                    log.Add("> [Debug] Breakpoint condition cleared on line "
                                        + Convert.ToString(bLine + 1) + ".");
                                }
                                findMode = 0;
                                app.RequestRedraw();
                            } else if (bcc > 31) {
                                bpCondText = bpCondText + Text.CharStr(bcc);
                                app.RequestRedraw();
                            }
                        }
                    }
                }

                if (designerMode) {
                    // Output panel is hidden while designing.
                } else if (dbgState == 2) {
                    DebugPanel.RenderDebugBottom(app, c, t, orr, dbgPanelTab,
                        dbgConsole, dbgVarInfo, dbgWatchVals, watchText,
                        dbgStack, log);
                    // Tab clicks are handled by the TabStrip widget inside
                    // RenderDebugBottom (bound to the dbgPanelTab signal).
                    if (app.ClickAvailable()) {
                        int tabClickY = orr.y;
                        int tabClickH = t.heightMedium;
                        if (app.mouseY >= tabClickY && app.mouseY < tabClickY + tabClickH) {
                            // TabStrip owns this strip.
                        } else if (dbgPanelTab.Get() == 2) {
                            // Click a watch row to remove that expression.
                            int wRowH = t.heightMedium;
                            int wTop = orr.y + t.heightMedium + app.Scale(26)
                                + t.heightMedium;
                            if (app.mouseY >= wTop) {
                                int wIdx = (app.mouseY - wTop) / wRowH;
                                if (wIdx >= 0 && wIdx < dbgWatches.Count) {
                                    dbgWatches.RemoveAt(wIdx);
                                    dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                                    app.RequestRedraw();
                                }
                            }
                        }
                    }
                    // Type into the Watch tab's expression field.
                    if (kind == 6 && dbgPanelTab.Get() == 2 && findMode == 0) {
                        int wcc = app.window.EventKeyCode();
                        if (wcc == 8 && watchText.Length > 0) {
                            watchText = watchText.Substring(0, watchText.Length - 1);
                            app.RequestRedraw();
                        } else if (wcc == 13 && watchText.Length > 0) {
                            dbgWatches.Add(watchText);
                            watchText = "";
                            dbgWatchVals = ZanIDE.DbgEvalWatches(dbg, dbgWatches);
                            app.RequestRedraw();
                        } else if (wcc > 31) {
                            watchText = watchText + Text.CharStr(wcc);
                            app.RequestRedraw();
                        }
                    }
                } else {
                    int botTab = bottomTab.Get();
                    List<string> ePath = new List<string>();
                    List<string> eLine = new List<string>();
                    List<string> eMsg = new List<string>();
                    ZanIDE.ParseErrorList(log, ePath, eLine, eMsg);
                    // Build the (optionally) filtered view the console shows. The
                    // real `log` is untouched; selection/copy operate on the view.
                    string coFilterText = coFilter.GetText();
                    List<string> coView = log;
                    if (coFilterText != "") {
                        coView = new List<string>();
                        int cvi = 0;
                        while (cvi < log.Count) {
                            if (ZanIDE.Has(log[cvi], coFilterText)) { coView.Add(log[cvi]); }
                            cvi = cvi + 1;
                        }
                    }
                    int obTabH = t.heightMedium;
                    int coContentY = orr.y + obTabH;
                    int coContentH = orr.height - obTabH;
                    int coRowH = app.Scale(18);
                    int coPad = app.Scale(6);
                    int coTextX = orr.x + coPad;
                    int coMaxRows = coContentH / coRowH;
                    if (coMaxRows < 1) { coMaxRows = 1; }
                    int coMaxScroll = coView.Count - coMaxRows;
                    if (coMaxScroll < 0) { coMaxScroll = 0; }
                    // Mouse wheel scrolls through output history (wheel up = older).
                    bool ownsOutputWheel = app.CaptureWheel(
                        orr.x, coContentY, orr.width, coContentH);
                    if (botTab == 0 && ownsOutputWheel) {
                        int wd = app.window.EventKeyCode();
                        int wstep = wd / 120;
                        if (wstep == 0) {
                            if (wd > 0) { wstep = 1; }
                            else if (wd < 0) { wstep = 0 - 1; }
                        }
                        coScroll = coScroll + wstep;
                        app.RequestRedraw();
                    }
                    if (coScroll < 0) { coScroll = 0; }
                    if (coScroll > coMaxScroll) { coScroll = coMaxScroll; }
                    OutputPanel.RenderOutputBottom(app, c, t, orr, bottomTab, coView, ePath, eLine, eMsg,
                        coScroll, coFilter, coSelA, coSelAc, coSelB, coSelBc, errorList, outClearBtn);
                    // Clear button empties the real log and resets the view state.
                    if (!coCtxOpen && Button.WasClicked(app, outClearBtn.wid)) {
                        log = new List<string>();
                        coFilter.SetText("");
                        coScroll = 0;
                        coSelA = 0 - 1; coSelB = 0 - 1;
                        app.RequestRedraw();
                    }
                    // Drag-to-select over the Output console. Register a hit region
                    // so pointer-move events keep repainting while dragging.
                    int coId = app.focus.AllocId();
                    app.hitTester.Register(HitRegion.Create(coId, orr.x, coContentY,
                        orr.width, coContentH, 1));
                    if (botTab == 0) {
                        // Scrollbar thumb drag takes precedence over text selection.
                        int coSbX = orr.x + orr.width - app.Scale(10);
                        bool coSbVisible = coView.Count > coMaxRows;
                        bool overSb = coSbVisible && app.mouseX >= coSbX
                            && app.mouseX < coSbX + app.Scale(10)
                            && app.mouseY >= coContentY && app.mouseY < coContentY + coContentH;
                        if (app.window.EventKind() == 2 && app.window.EventButton() == 0 && overSb) {
                            coSbDrag = 1;
                        }
                        if (coSbDrag == 1
                            && (app.window.EventKind() == 1 || app.window.EventKind() == 2)) {
                            int contentPx = coView.Count * coRowH;
                            int viewPx = coMaxRows * coRowH;
                            int thumbH = viewPx * viewPx / contentPx;
                            if (thumbH < 20) { thumbH = 20; }
                            int denom = viewPx - thumbH;
                            if (denom < 1) { denom = 1; }
                            int rel = (app.mouseY - thumbH / 2) - (coContentY + coPad);
                            if (rel < 0) { rel = 0; }
                            int scrollPx = rel * (contentPx - viewPx) / denom;
                            int startIdx = scrollPx / coRowH;
                            if (startIdx < 0) { startIdx = 0; }
                            if (startIdx > coMaxScroll) { startIdx = coMaxScroll; }
                            coScroll = coMaxScroll - startIdx;
                            app.RequestRedraw();
                        }
                        if (app.window.EventKind() == 3) { coSbDrag = 0; }
                        bool coOver = !overSb && coSbDrag == 0
                            && app.mouseX >= orr.x && app.mouseX < orr.x + orr.width
                            && app.mouseY >= coContentY && app.mouseY < coContentY + coContentH;
                        if (!coCtxOpen && app.window.EventKind() == 2
                            && app.window.EventButton() == 0 && coOver) {
                            int rr = OutputPanel.ConsoleRowAt(app, coContentY, coRowH, coPad,
                                coView.Count, coMaxRows, coScroll, app.mouseY);
                            int cc = 0;
                            if (rr >= 0 && rr < coView.Count) {
                                cc = OutputPanel.ConsoleColAt(coView[rr], coTextX, t.fontSizeSmall, app.mouseX);
                            }
                            coSelA = rr; coSelAc = cc; coSelB = rr; coSelBc = cc; coSelDrag = 1;
                            app.RequestRedraw();
                        }
                        if (app.window.EventKind() == 1 && coSelDrag == 1) {
                            int rr = OutputPanel.ConsoleRowAt(app, coContentY, coRowH, coPad,
                                coView.Count, coMaxRows, coScroll, app.mouseY);
                            int cc = 0;
                            if (rr >= 0 && rr < coView.Count) {
                                cc = OutputPanel.ConsoleColAt(coView[rr], coTextX, t.fontSizeSmall, app.mouseX);
                            }
                            coSelB = rr; coSelBc = cc;
                            app.RequestRedraw();
                        }
                        if (app.window.EventKind() == 3 && app.window.EventButton() == 0
                            && coSelDrag == 1) {
                            coSelDrag = 0;
                            app.RequestRedraw();
                        }
                    }
                    // Error rows are widgets now: the ErrorList component
                    // records clicks during RenderAt; apply them here.
                    if (botTab == 1 && !coCtxOpen) {
                        int efr = errorList.TakeFix();
                        if (efr >= 0) {
                            ZanIDE.AddUsing(editor, tabBodies, activeTab,
                                errorList.FixNs(efr), log);
                            app.RequestRedraw();
                        }
                        int ejr = errorList.TakeJump();
                        if (ejr >= 0 && ejr < ePath.Count) {
                            int j = ZanIDE.FindTabByBase(
                                tabPaths, ZanIDE.BaseName(ePath[ejr]));
                            int gl = ZanIDE.ParseInt(eLine[ejr]);
                            if (j >= 0) {
                                activeTab.Set(j);
                                lastActive = 0 - 1;
                                pendingGotoLine = gl - 1;
                                pendingGotoCol = 0;
                            }
                            app.RequestRedraw();
                        }
                    }
                    // Right-click opens a context menu (copy selection / line /
                    // all, clear) instead of silently copying.
                    if (app.window.EventKind() == 2 && app.window.EventButton() == 1
                        && app.mouseX >= orr.x && app.mouseX < orr.x + orr.width
                        && app.mouseY >= orr.y && app.mouseY < orr.y + orr.height) {
                        coCtxOpen = true;
                        coCtxX = app.mouseX;
                        coCtxY = app.mouseY;
                        if (botTab == 0) {
                            coCtxRow = OutputPanel.ConsoleRowAt(app, coContentY, coRowH, coPad,
                                coView.Count, coMaxRows, coScroll, app.mouseY);
                        } else {
                            coCtxRow = (app.mouseY - (orr.y + obTabH + app.Scale(6))) / app.Scale(20);
                        }
                        app.RequestRedraw();
                    }
                    if (coCtxOpen) {
                        bool haveSel = coSelA >= 0
                            && !(coSelA == coSelB && coSelAc == coSelBc);
                        List<string> cmi = new List<string>();
                        if (botTab == 0 && haveSel) {
                            cmi.Add(ZanIDE.T("Copy selection", "复制选中"));
                        }
                        cmi.Add(ZanIDE.T("Copy line", "复制该行"));
                        cmi.Add(ZanIDE.T("Copy all", "复制全部"));
                        cmi.Add(ZanIDE.T("Clear", "清空"));
                        int cmRowH = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(10);
                        int cmW = app.Scale(150);
                        int cmH = cmi.Count * cmRowH + app.Scale(8);
                        int cmX = coCtxX;
                        int cmY = coCtxY;
                        if (cmX + cmW > orr.x + orr.width) { cmX = orr.x + orr.width - cmW; }
                        if (cmY + cmH > orr.y + orr.height) { cmY = coCtxY - cmH; }
                        c.FillRoundRect(cmX + 1, cmY + 2, cmW, cmH, app.Scale(5), t.shadowColor);
                        c.FillRoundRect(cmX, cmY, cmW, cmH, app.Scale(5), t.bgSecondary);
                        c.DrawRect(cmX, cmY, cmW, cmH, t.borderPrimary, 1);
                        int cmEk = app.window.EventKind();
                        int cmIy = cmY + app.Scale(4);
                        int cmHit = 0 - 1;
                        int cmI = 0;
                        while (cmI < cmi.Count) {
                            bool cmOver = app.mouseX >= cmX && app.mouseX < cmX + cmW
                                && app.mouseY >= cmIy && app.mouseY < cmIy + cmRowH;
                            if (cmOver) {
                                c.FillRoundRect(cmX + app.Scale(3), cmIy, cmW - app.Scale(6),
                                    cmRowH, app.Scale(3), t.bgTertiary);
                                if (cmEk == 3) { cmHit = cmI; }
                            }
                            c.DrawText(cmX + app.Scale(10), cmIy + app.Scale(4), cmi[cmI],
                                t.textPrimary, t.fontSizeSmall);
                            cmIy = cmIy + cmRowH;
                            cmI = cmI + 1;
                        }
                        if (cmHit >= 0) {
                            int base2 = 0;
                            if (botTab == 0 && haveSel) { base2 = 1; }
                            string clip = "";
                            if (botTab == 0 && haveSel && cmHit == 0) {
                                clip = OutputPanel.ConsoleSelectionText(coView,
                                    coSelA, coSelAc, coSelB, coSelBc);
                            } else if (cmHit == base2) {
                                if (botTab == 0) {
                                    if (coCtxRow >= 0 && coCtxRow < coView.Count) {
                                        clip = coView[coCtxRow];
                                    }
                                } else if (coCtxRow >= 0 && coCtxRow < ePath.Count) {
                                    clip = ZanIDE.BaseName(ePath[coCtxRow]) + ":"
                                        + eLine[coCtxRow] + "  " + eMsg[coCtxRow];
                                }
                            } else if (cmHit == base2 + 1) {
                                if (botTab == 0) {
                                    int ci = 0;
                                    while (ci < coView.Count) { clip = clip + coView[ci] + "\n"; ci = ci + 1; }
                                } else {
                                    int ci = 0;
                                    while (ci < ePath.Count) {
                                        clip = clip + ZanIDE.BaseName(ePath[ci]) + ":" + eLine[ci]
                                            + "  " + eMsg[ci] + "\n";
                                        ci = ci + 1;
                                    }
                                }
                            } else {
                                log = new List<string>();
                                coFilter.SetText("");
                                coScroll = 0;
                                coSelA = 0 - 1; coSelB = 0 - 1;
                            }
                            if (clip.Length > 0) {
                                Clipboard.SetText(clip);
                                Layer.Msg(ZanIDE.T("Copied to clipboard", "已复制到剪贴板"), 3);
                            }
                            coCtxOpen = false;
                            app.RequestRedraw();
                        } else if ((cmEk == 2 && app.window.EventButton() == 0
                                || cmEk == 3)
                            && !(app.mouseX >= cmX && app.mouseX < cmX + cmW
                                && app.mouseY >= cmY && app.mouseY < cmY + cmH)) {
                            coCtxOpen = false;
                            app.RequestRedraw();
                        }
                    }
                    // Ctrl+C copies the console selection when the pointer is
                    // over the output panel (the editor keeps its own copy).
                    if (app.window.EventKind() == 4 && app.window.EventKeyCode() == 67
                        && Modifiers.HasCtrl(app.window.EventMods())
                        && coSelA >= 0 && !(coSelA == coSelB && coSelAc == coSelBc)
                        && app.mouseX >= orr.x && app.mouseX < orr.x + orr.width
                        && app.mouseY >= orr.y && app.mouseY < orr.y + orr.height) {
                        Clipboard.SetText(OutputPanel.ConsoleSelectionText(coView,
                            coSelA, coSelAc, coSelB, coSelBc));
                        Layer.Msg(ZanIDE.T("Copied to clipboard", "已复制到剪贴板"), 3);
                        app.RequestRedraw();
                    }
                }

                // ---- Right side panel: AI assistant / integrated terminal ----
                Rect rp = rightArea;
                ZanIDE.ShellSurface(app, rp.x, rp.y, rp.width, rp.height, 0, t.bgTertiary);
                int rTabH = app.Scale(28);
                int rTab = rightTab.Get();
                int rTabW = rp.width / 4;
                if (rTabW > app.Scale(90)) { rTabW = app.Scale(90); }
                c.FillRect(rp.x, rp.y, rp.width, rTabH, t.bgSecondary);
                c.FillRect(rp.x, rp.y + rTabH - 1, rp.width, 1, t.divider);
                List<string> rTabNames = new List<string>();
                rTabNames.Add(ZanIDE.T("AI", "AI 助手"));
                rTabNames.Add(ZanIDE.T("Tools", "工具"));
                rTabNames.Add(ZanIDE.T("Examples", "示例"));
                rTabNames.Add(ZanIDE.T("Git", "Git"));
                int rtI = 0;
                while (rtI < rTabNames.Count) {
                    int rBgN = t.bgTertiary;
                    if (rTab == rtI) { rBgN = t.bgPrimary; }
                    c.FillRect(rp.x + rTabW * rtI, rp.y, rTabW, rTabH, rBgN);
                    c.DrawText(rp.x + rTabW * rtI + app.Scale(8), rp.y + app.Scale(6),
                        rTabNames[rtI], t.textPrimary, t.fontSizeSmall);
                    rtI = rtI + 1;
                }
                if (app.ClickAvailable()
                    && app.mouseY >= rp.y && app.mouseY < rp.y + rTabH
                    && app.mouseX >= rp.x && app.mouseX < rp.x + rTabW * rTabNames.Count) {
                    rightTab.Set((app.mouseX - rp.x) / rTabW);
                    app.RequestRedraw();
                }
                int rPad = app.Scale(6);
                int rInH = app.Scale(30);
                Rect rBody = Rect.Create(rp.x, rp.y + rTabH, rp.width,
                    rp.height - rTabH - rInH - rPad * 2);
                c.FillRect(rBody.x, rBody.y, rBody.width, rBody.height + rInH + rPad * 2, t.bgPrimary);
                int rInY = rp.y + rp.height - rInH - rPad;
                int rBtnW = app.Scale(56);
                int rInW = rp.width - rPad * 3 - rBtnW;
                if (rInW < app.Scale(40)) { rInW = app.Scale(40); }
                if (rTab == 0) {
                    // ---- Header: chat model switcher + Continue + Config ----
                    // The dropdown lists the enabled profile's default model
                    // first, then the fetched model ids; picking one switches
                    // the chat (and Continue) model for this session.
                    if (aiModelSelProf != aiProfActive) {
                        aiModelSel = SelectBox.Create(ZanIDE.T("Model (default)", "模型（默认）"));
                        aiModelOpts = new List<string>();
                        string defM = aiProfModels[aiProfActive];
                        if (defM != "") { aiModelOpts.Add(defM); }
                        List<string> fetched = ZanIDE.SplitList(aiProfLists[aiProfActive]);
                        int fmi = 0;
                        while (fmi < fetched.Count) {
                            if (fetched[fmi] != defM) { aiModelOpts.Add(fetched[fmi]); }
                            fmi = fmi + 1;
                        }
                        int aoi = 0;
                        while (aoi < aiModelOpts.Count) {
                            aiModelSel.AddOption(aiModelOpts[aoi]);
                            aoi = aoi + 1;
                        }
                        aiModelSelProf = aiProfActive;
                    }
                    int aiRow2H = app.Scale(30);
                    int aiHdrH = app.Scale(34) + aiRow2H;
                    int aiSmBtnW = app.Scale(52);
                    int aiSelW = rBody.width - rPad * 4 - aiSmBtnW * 2;
                    if (aiSelW < app.Scale(60)) { aiSelW = app.Scale(60); }
                    aiModelSel.Render(app, rBody.x + rPad, rBody.y + app.Scale(4), aiSelW);
                    int aiPredId = aiPredictBtn.Render(app,
                        rBody.x + rPad * 2 + aiSelW, rBody.y + app.Scale(4), aiSmBtnW);
                    int aiCfgId = aiCfgBtn.Render(app,
                        rBody.x + rPad * 3 + aiSelW + aiSmBtnW, rBody.y + app.Scale(4), aiSmBtnW);
                    if (Button.WasClicked(app, aiCfgId)) {
                        aiCfgShow.Set(1 - aiCfgShow.Get());
                        aiUiLoaded = false;
                        app.RequestRedraw();
                    }
                    // ---- Session row: switch / new / clear chat contexts ----
                    int sNavW = app.Scale(24);
                    int sBtnW = app.Scale(62);
                    int sy = rBody.y + app.Scale(34) + app.Scale(2);
                    int sPrevId = aiSessPrevBtn.Render(app, rBody.x + rPad, sy, sNavW);
                    int sNextId = aiSessNextBtn.Render(app,
                        rBody.x + rPad + sNavW + app.Scale(4), sy, sNavW);
                    c.DrawText(rBody.x + rPad + sNavW * 2 + app.Scale(12), sy + app.Scale(6),
                        ZanIDE.T("Chat ", "会话 ") + Convert.ToString(aiSessCur + 1) + "/"
                        + Convert.ToString(aiSessions.Count), t.textSecondary, t.fontSizeSmall);
                    int sNewId = aiSessNewBtn.Render(app,
                        rBody.x + rBody.width - rPad * 2 - sBtnW * 2, sy, sBtnW);
                    int sClrId = aiSessClearBtn.Render(app,
                        rBody.x + rBody.width - rPad - sBtnW, sy, sBtnW);
                    bool sessSwitch = false;
                    int sessTarget = aiSessCur;
                    if (Button.WasClicked(app, sPrevId) && aiSessions.Count > 1) {
                        sessTarget = aiSessCur - 1;
                        if (sessTarget < 0) { sessTarget = aiSessions.Count - 1; }
                        sessSwitch = true;
                    }
                    if (Button.WasClicked(app, sNextId) && aiSessions.Count > 1) {
                        sessTarget = aiSessCur + 1;
                        if (sessTarget >= aiSessions.Count) { sessTarget = 0; }
                        sessSwitch = true;
                    }
                    if (Button.WasClicked(app, sNewId) && aiBusy.Get() == 0) {
                        aiSessions[aiSessCur] = ChatArea.ChatPack(aiRole, aiText);
                        aiSessions.Add("");
                        sessTarget = aiSessions.Count - 1;
                        sessSwitch = true;
                    }
                    if (Button.WasClicked(app, sClrId) && aiBusy.Get() == 0) {
                        aiRole = new List<string>();
                        aiText = new List<string>();
                        aiSessions[aiSessCur] = "";
                        aiCacheKey = "";
                        aiScroll.Set(0);
                        app.RequestRedraw();
                    }
                    if (sessSwitch && aiBusy.Get() == 0 && sessTarget != aiSessCur) {
                        aiSessions[aiSessCur] = ChatArea.ChatPack(aiRole, aiText);
                        aiRole = new List<string>();
                        aiText = new List<string>();
                        ChatArea.ChatUnpack(aiSessions[sessTarget], aiRole, aiText);
                        aiSessCur = sessTarget;
                        aiCacheKey = "";
                        aiScroll.Set(0);
                        app.RequestRedraw();
                    }
                    // The model in effect: the dropdown selection, or the
                    // enabled profile's default model when nothing is picked.
                    string chatModel = aiProfModels[aiProfActive];
                    int selMi = aiModelSel.Selected();
                    if (selMi >= 0 && selMi < aiModelOpts.Count) { chatModel = aiModelOpts[selMi]; }
                    // ---- Provider profiles editor (toggled by Config) ----
                    int aiCfgH = 0;
                    if (aiCfgShow.Get() == 1) {
                        int cRowH = app.Scale(28);
                        int cGap = app.Scale(4);
                        aiCfgH = cRowH * 7 + cGap * 8;
                        int cx = rBody.x + rPad;
                        int cw = rBody.width - rPad * 2;
                        int cy = rBody.y + aiHdrH + cGap;
                        c.FillRect(rBody.x, rBody.y + aiHdrH, rBody.width, aiCfgH, t.bgSecondary);
                        if (aiUiProf < 0 || aiUiProf >= aiProfNames.Count) { aiUiProf = aiProfActive; }
                        if (!aiUiLoaded) {
                            aiNameIn.SetText(aiProfNames[aiUiProf]);
                            aiBaseIn.SetText(aiProfBases[aiUiProf]);
                            aiKeyIn.SetText(aiProfKeys[aiUiProf]);
                            aiModelIn.SetText(aiProfModels[aiUiProf]);
                            aiUiLoaded = true;
                        }
                        int navBtnW = app.Scale(26);
                        int addBtnW = app.Scale(52);
                        int pPrevId = aiProfPrevBtn.Render(app, cx, cy, navBtnW);
                        int pNextId = aiProfNextBtn.Render(app, cx + navBtnW + cGap, cy, navBtnW);
                        string profLbl = Convert.ToString(aiUiProf + 1) + "/"
                            + Convert.ToString(aiProfNames.Count) + " " + aiProfNames[aiUiProf];
                        if (aiUiProf == aiProfActive) {
                            profLbl = profLbl + ZanIDE.T(" (enabled)", "（已启用）");
                        }
                        c.DrawText(cx + navBtnW * 2 + cGap * 3, cy + app.Scale(6),
                            profLbl, t.textPrimary, t.fontSizeSmall);
                        int pAddId = aiProfAddBtn.Render(app, cx + cw - addBtnW * 2 - cGap, cy, addBtnW);
                        int pDelId = aiProfDelBtn.Render(app, cx + cw - addBtnW, cy, addBtnW);
                        if (Button.WasClicked(app, pPrevId) && aiProfNames.Count > 1) {
                            aiUiProf = aiUiProf - 1;
                            if (aiUiProf < 0) { aiUiProf = aiProfNames.Count - 1; }
                            aiUiLoaded = false;
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, pNextId) && aiProfNames.Count > 1) {
                            aiUiProf = aiUiProf + 1;
                            if (aiUiProf >= aiProfNames.Count) { aiUiProf = 0; }
                            aiUiLoaded = false;
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, pAddId)) {
                            aiProfNames.Add(ZanIDE.T("AI ", "配置 ") + Convert.ToString(aiProfNames.Count + 1));
                            aiProfBases.Add("https://api.openai.com/v1");
                            aiProfKeys.Add("");
                            aiProfModels.Add("");
                            aiProfLists.Add("");
                            aiUiProf = aiProfNames.Count - 1;
                            aiUiLoaded = false;
                            ZanIDE.AiProfilesSave(aiProfActive, aiProfNames, aiProfBases,
                                aiProfKeys, aiProfModels, aiProfLists);
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, pDelId) && aiProfNames.Count > 1) {
                            aiProfNames.RemoveAt(aiUiProf);
                            aiProfBases.RemoveAt(aiUiProf);
                            aiProfKeys.RemoveAt(aiUiProf);
                            aiProfModels.RemoveAt(aiUiProf);
                            aiProfLists.RemoveAt(aiUiProf);
                            if (aiProfActive >= aiProfNames.Count) { aiProfActive = 0; }
                            if (aiUiProf >= aiProfNames.Count) { aiUiProf = aiProfNames.Count - 1; }
                            aiUiLoaded = false;
                            aiModelSelProf = 0 - 1;
                            ZanIDE.AiProfilesSave(aiProfActive, aiProfNames, aiProfBases,
                                aiProfKeys, aiProfModels, aiProfLists);
                            app.RequestRedraw();
                        }
                        aiNameIn.Render(app, cx, cy + (cRowH + cGap) * 1, cw, cRowH);
                        aiBaseIn.Render(app, cx, cy + (cRowH + cGap) * 2, cw, cRowH);
                        aiKeyIn.Render(app, cx, cy + (cRowH + cGap) * 3, cw, cRowH);
                        aiModelIn.Render(app, cx, cy + (cRowH + cGap) * 4, cw, cRowH);
                        // Official presets: pick a provider, "Use preset" adds a
                        // profile with its base/default model, "Sign up" opens
                        // the provider's key/registration portal.
                        int preBtnW = app.Scale(84);
                        int regBtnW = app.Scale(52);
                        int preSelW = cw - preBtnW - regBtnW - cGap * 2;
                        int preY = cy + (cRowH + cGap) * 5;
                        aiPresetSel.Render(app, cx, preY, preSelW);
                        int preAddId = aiPresetAddBtn.Render(app, cx + preSelW + cGap, preY, preBtnW);
                        int regId = aiRegBtn.Render(app, cx + preSelW + preBtnW + cGap * 2, preY, regBtnW);
                        int preSel = aiPresetSel.Selected();
                        if (preSel < 0) { preSel = 0; }
                        if (Button.WasClicked(app, preAddId) && preSel < aiPreNames.Count) {
                            aiProfNames.Add(aiPreNames[preSel]);
                            aiProfBases.Add(aiPreBases[preSel]);
                            aiProfKeys.Add("");
                            aiProfModels.Add(aiPreModels[preSel]);
                            aiProfLists.Add("");
                            aiUiProf = aiProfNames.Count - 1;
                            aiUiLoaded = false;
                            ZanIDE.AiProfilesSave(aiProfActive, aiProfNames, aiProfBases,
                                aiProfKeys, aiProfModels, aiProfLists);
                            log.Add(ZanIDE.T("> AI: added preset ", "> AI：已添加预设 ")
                                + aiPreNames[preSel]
                                + ZanIDE.T(" - fill in the API key and Save & enable.",
                                    " —— 请填入 API 密钥后“保存并启用”。"));
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, regId) && preSel < aiPreRegs.Count) {
                            ZanIDE.OpenExternal(aiPreRegs[preSel]);
                        }
                        int halfW = (cw - cGap) / 2;
                        int useId = aiProfUseBtn.Render(app, cx, cy + (cRowH + cGap) * 6, halfW);
                        int fetchId = aiFetchBtn.Render(app, cx + halfW + cGap, cy + (cRowH + cGap) * 6, halfW);
                        if (Button.WasClicked(app, useId)) {
                            aiProfNames[aiUiProf] = aiNameIn.GetText();
                            aiProfBases[aiUiProf] = aiBaseIn.GetText();
                            aiProfKeys[aiUiProf] = aiKeyIn.GetText();
                            aiProfModels[aiUiProf] = aiModelIn.GetText();
                            aiProfActive = aiUiProf;
                            aiModelSelProf = 0 - 1;
                            ZanIDE.AiProfilesSave(aiProfActive, aiProfNames, aiProfBases,
                                aiProfKeys, aiProfModels, aiProfLists);
                            log.Add(ZanIDE.T("> AI: enabled profile ", "> AI：已启用配置 ")
                                + aiProfNames[aiUiProf] + ".");
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, fetchId) && aiModelsBusy.Get() == 0) {
                            string ferr = ZanIDE.AiFetchModels(aiBaseIn.GetText(), aiKeyIn.GetText());
                            if (ferr != "") {
                                log.Add("> AI: " + ferr);
                            } else {
                                aiModelsBusy.Set(1);
                                log.Add(ZanIDE.T("> AI: fetching model list...", "> AI：正在获取模型列表..."));
                            }
                            app.RequestRedraw();
                        }
                    }
                    // Poll the in-flight /models request.
                    if (aiModelsBusy.Get() == 1) {
                        if (File.Exists(ZanIDE.AiModelsDonePath())) {
                            File.Delete(ZanIDE.AiModelsDonePath());
                            string gotModels = ZanIDE.AiReadModels();
                            if (gotModels != "") {
                                aiProfLists[aiUiProf] = gotModels;
                                if (aiProfModels[aiUiProf] == "") {
                                    List<string> gm = ZanIDE.SplitList(gotModels);
                                    aiProfModels[aiUiProf] = gm[0];
                                    aiModelIn.SetText(gm[0]);
                                }
                                ZanIDE.AiProfilesSave(aiProfActive, aiProfNames, aiProfBases,
                                    aiProfKeys, aiProfModels, aiProfLists);
                                aiModelSelProf = 0 - 1;
                                log.Add(ZanIDE.T("> AI: fetched ", "> AI：已获取 ")
                                    + Convert.ToString(ZanIDE.SplitList(gotModels).Count)
                                    + ZanIDE.T(" models.", " 个模型。"));
                            } else {
                                log.Add(ZanIDE.T("> AI: could not fetch models (check base URL / key).",
                                    "> AI：获取模型失败（请检查接口地址和密钥）。"));
                            }
                            aiModelsBusy.Set(0);
                        }
                        app.RequestRedraw();
                    }
                    Rect aiChat = Rect.Create(rBody.x, rBody.y + aiHdrH + aiCfgH,
                        rBody.width, rBody.height - aiHdrH - aiCfgH);
                    // Wheel-scroll the transcript (lines up from the bottom).
                    bool ownsAiWheel = app.CaptureWheel(aiChat.x, aiChat.y, aiChat.width, aiChat.height);
                    if (ownsAiWheel) {
                        int awd = app.window.EventKeyCode();
                        int awstep = awd / 120;
                        if (awstep == 0) {
                            if (awd > 0) { awstep = 1; }
                            else if (awd < 0) { awstep = 0 - 1; }
                        }
                        aiScroll.Set(aiScroll.Get() + awstep);
                        app.RequestRedraw();
                    }
                    // Rebuild the wrapped/markdown line cache only when the
                    // transcript or width changed (rewrapping per frame is slow).
                    int aiTextW = aiChat.width - app.Scale(12);
                    if (aiTextW < app.Scale(20)) { aiTextW = app.Scale(20); }
                    int aiTotLen = 0;
                    int atli = 0;
                    while (atli < aiText.Count) {
                        aiTotLen = aiTotLen + aiText[atli].Length;
                        atli = atli + 1;
                    }
                    string aiKeyNow = Convert.ToString(aiRole.Count) + ":"
                        + Convert.ToString(aiTotLen) + ":" + Convert.ToString(aiTextW)
                        + ":" + Convert.ToString(edFontPx);
                    if (aiKeyNow != aiCacheKey) {
                        aiCacheLines = new List<string>();
                        aiCacheColors = new List<int>();
                        aiCacheKinds = new List<int>();
                        ChatArea.ChatBuildLines(app, aiRole, aiText, aiTextW,
                            aiCacheLines, aiCacheColors, aiCacheKinds);
                        aiCacheKey = aiKeyNow;
                    }
                    int aiMax = ChatArea.RenderChatArea(app, aiChat,
                        aiCacheLines, aiCacheColors, aiCacheKinds,
                        aiScroll.Get(), aiBusy.Get() == 1);
                    if (aiScroll.Get() > aiMax) { aiScroll.Set(aiMax); }
                    if (aiScroll.Get() < 0) { aiScroll.Set(0); }
                    // "Insert code" / "Replace file": apply the last AI code
                    // block at the editor cursor, or as the whole file.
                    string aiCode = ZanIDE.AiLastCode(aiRole, aiText);
                    bool aiCanApply = aiCode != "" && act >= 0 && act < tabPaths.Count
                        && !designerMode && tabPaths[act] != ""
                        && tabPaths[act].Substring(0, 1) != "@";
                    if (aiCanApply) {
                        int abW = app.Scale(110);
                        int abH = aiApplyBtn.GetHeight(t);
                        int abId = aiApplyBtn.Render(app,
                            rp.x + rp.width - abW - rPad,
                            rBody.y + rBody.height - abH - rPad, abW);
                        if (Button.WasClicked(app, abId)) {
                            editor.InsertBlock(aiCode);
                            tabBodies[act] = editor.GetText();
                            log.Add(ZanIDE.T("> Inserted AI code into ", "> 已将 AI 代码插入 ")
                                + tabPaths[act] + ".");
                            app.RequestRedraw();
                        }
                        int rbId = aiReplaceBtn.Render(app,
                            rp.x + rp.width - abW * 2 - rPad * 2,
                            rBody.y + rBody.height - abH - rPad, abW);
                        if (Button.WasClicked(app, rbId)) {
                            editor.LoadText(aiCode);
                            tabBodies[act] = aiCode;
                            log.Add(ZanIDE.T("> Replaced ", "> 已用 AI 代码替换 ")
                                + tabPaths[act] + ZanIDE.T(" with AI code.", "。"));
                            app.RequestRedraw();
                        }
                    }
                    // "Continue": ask the model to continue the code exactly at
                    // the caret; the reply is inserted there when it arrives.
                    if (Button.WasClicked(app, aiPredId) && aiPredBusy.Get() == 0
                        && act >= 0 && act < tabPaths.Count && !designerMode
                        && tabPaths[act] != "" && tabPaths[act].Substring(0, 1) != "@") {
                        string perr = ZanIDE.AiLaunchPredict(
                            Path.GetFileName(tabPaths[act]), editor.GetText(), editor.CurLine(),
                            aiProfBases[aiProfActive], aiProfKeys[aiProfActive], chatModel);
                        if (perr != "") {
                            log.Add("> AI: " + perr);
                        } else {
                            aiPredBusy.Set(1);
                            aiPredTab = act;
                            log.Add(ZanIDE.T("> AI: continuing code at the caret...",
                                "> AI：正在续写光标处代码..."));
                        }
                        app.RequestRedraw();
                    }
                    if (aiPredBusy.Get() == 1) {
                        if (File.Exists(ZanIDE.AiPredDonePath())) {
                            File.Delete(ZanIDE.AiPredDonePath());
                            string pred = ZanIDE.AiStripFence(
                                ZanIDE.AiReadAnswerFrom(ZanIDE.AiPredRespPath()));
                            if (pred != "" && act == aiPredTab) {
                                editor.InsertBlock(pred);
                                tabBodies[act] = editor.GetText();
                                log.Add(ZanIDE.T("> AI: inserted the continuation.",
                                    "> AI：已插入续写代码。"));
                            } else if (pred == "") {
                                log.Add(ZanIDE.T("> AI: no continuation returned.",
                                    "> AI：未返回续写内容。"));
                            }
                            aiPredBusy.Set(0);
                        }
                        app.RequestRedraw();
                    }
                    int aiInpId = aiInput.Render(app, rp.x + rPad, rInY, rInW, rInH);
                    int sendId = aiSendBtn.Render(app, rp.x + rPad * 2 + rInW, rInY, rBtnW);
                    bool doSend = Button.WasClicked(app, sendId);
                    if (!doSend && app.window.EventKind() == 6
                        && app.window.EventKeyCode() == 13
                        && app.focus.IsFocused(aiInpId)) { doSend = true; }
                    if (doSend && aiBusy.Get() == 0) {
                        string q = aiInput.GetText();
                        if (q != "") {
                            aiRole.Add("user");
                            aiText.Add(q);
                            aiInput.SetText("");
                            // Attach the active file as context so the AI can
                            // help with the code actually on screen.
                            string aiCtxName = "";
                            string aiCtxCode = "";
                            if (act >= 0 && act < tabPaths.Count && tabPaths[act] != ""
                                && tabPaths[act].Substring(0, 1) != "@") {
                                aiCtxName = Path.GetFileName(tabPaths[act]);
                                if (ZanIDE.IsFormPath(tabPaths[act])) { aiCtxCode = tabBodies[act]; }
                                else { aiCtxCode = editor.GetText(); }
                            }
                            string aerr = ZanIDE.AiLaunch(aiRole, aiText, aiCtxName, aiCtxCode, root,
                                aiProfBases[aiProfActive], aiProfKeys[aiProfActive], chatModel);
                            if (aerr != "") {
                                aiRole.Add("error");
                                aiText.Add(aerr);
                            } else {
                                aiBusy.Set(1);
                            }
                            aiScroll.Set(0);
                            app.RequestRedraw();
                        }
                    }
                } else if (rTab == 3) {
                    // ---- Git: repository status + stage / commit / sync ----
                    Rect gArea = Rect.Create(rp.x, rp.y + rTabH, rp.width, rp.height - rTabH);
                    int gPad = app.Scale(6);
                    if (!gitLoaded) {
                        gitBranch = ZanIDE.GitRefresh(root, gitFiles);
                        gitLoaded = true;
                        gitSel.Set(0 - 1);
                    }
                    bool gitRepo = Directory.Exists(root + "/.git");
                    int gy = gArea.y + gPad;
                    if (!gitRepo) {
                        c.DrawText(gArea.x + gPad, gy,
                            ZanIDE.T("Not a git repository.", "当前项目不是 git 仓库。"),
                            t.textSecondary, t.fontSizeSmall);
                        int giId = Button.Primary(ZanIDE.T("Initialize repository", "初始化仓库"))
                            .SetSize(1).Render(app, gArea.x + gPad, gy + app.Scale(24), app.Scale(150));
                        if (Button.WasClicked(app, giId)) {
                            ZanIDE.AppendAll(log, ZanIDE.GitRun(root, "init"));
                            log.Add(ZanIDE.T("> git init done.", "> git 仓库初始化完成。"));
                            gitLoaded = false;
                            app.RequestRedraw();
                        }
                    } else {
                        // Header: current branch + change count, then two rows
                        // of actions (all git commands echo into Output).
                        c.DrawText(gArea.x + gPad, gy + app.Scale(4),
                            Ellipsis.Fit(ZanIDE.T("Branch: ", "分支：") + gitBranch
                                + "   (" + Convert.ToString(gitFiles.Count)
                                + ZanIDE.T(" changes", " 处变更") + ")",
                                gArea.width - gPad * 2, t.fontSizeSmall),
                            t.textPrimary, t.fontSizeSmall);
                        int gBtnW = (gArea.width - gPad * 4) / 3;
                        if (gBtnW < app.Scale(50)) { gBtnW = app.Scale(50); }
                        int gRow1 = gy + app.Scale(22);
                        int gRefId = Button.Create(ZanIDE.T("Refresh", "刷新")).SetSize(1)
                            .Render(app, gArea.x + gPad, gRow1, gBtnW);
                        int gStgId = Button.Create(ZanIDE.T("Stage all", "暂存全部")).SetSize(1)
                            .Render(app, gArea.x + gPad * 2 + gBtnW, gRow1, gBtnW);
                        int gDifId = Button.Create(ZanIDE.T("Diff", "差异")).SetSize(1)
                            .Render(app, gArea.x + gPad * 3 + gBtnW * 2, gRow1, gBtnW);
                        int gRow2 = gRow1 + app.Scale(28);
                        int gLogId = Button.Create(ZanIDE.T("History", "历史")).SetSize(1)
                            .Render(app, gArea.x + gPad, gRow2, gBtnW);
                        int gPulId = Button.Create(ZanIDE.T("Pull", "拉取")).SetSize(1)
                            .Render(app, gArea.x + gPad * 2 + gBtnW, gRow2, gBtnW);
                        int gPshId = Button.Create(ZanIDE.T("Push", "推送")).SetSize(1)
                            .Render(app, gArea.x + gPad * 3 + gBtnW * 2, gRow2, gBtnW);
                        if (Button.WasClicked(app, gRefId)) {
                            gitLoaded = false;
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, gStgId)) {
                            ZanIDE.AppendAll(log, ZanIDE.GitRun(root, "add -A"));
                            log.Add(ZanIDE.T("> Staged all changes.", "> 已暂存全部变更。"));
                            gitLoaded = false;
                            bottomTab.Set(0);
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, gDifId)) {
                            int gsv = gitSel.Get();
                            string gtgt = "";
                            if (gsv >= 0 && gsv < gitFiles.Count) {
                                gtgt = " -- \"" + ZanIDE.GitPathOf(gitFiles[gsv]) + "\"";
                            }
                            ZanIDE.AppendAll(log, ZanIDE.GitRun(root, "diff HEAD" + gtgt));
                            bottomTab.Set(0);
                            coScroll = 0;
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, gLogId)) {
                            ZanIDE.AppendAll(log, ZanIDE.GitRun(root,
                                "log --oneline --decorate -20"));
                            bottomTab.Set(0);
                            coScroll = 0;
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, gPulId)) {
                            log.Add("> git pull ...");
                            ZanIDE.AppendAll(log, ZanIDE.GitRun(root, "pull"));
                            gitLoaded = false;
                            bottomTab.Set(0);
                            app.RequestRedraw();
                        }
                        if (Button.WasClicked(app, gPshId)) {
                            log.Add("> git push ...");
                            ZanIDE.AppendAll(log, ZanIDE.GitRun(root, "push"));
                            bottomTab.Set(0);
                            app.RequestRedraw();
                        }
                        // Changed-file list (porcelain "XY path" rows): click
                        // selects, double-click opens the file in the editor.
                        int gListY = gRow2 + app.Scale(30);
                        int gListH = rInY - gPad - gListY;
                        int gRowH = app.Scale(20);
                        c.FillRect(gArea.x + gPad, gListY, gArea.width - gPad * 2, gListH, t.bgSecondary);
                        int gVis = gListH / gRowH;
                        if (gVis < 1) { gVis = 1; }
                        int gMax = gitFiles.Count - gVis;
                        if (gMax < 0) { gMax = 0; }
                        if (app.CaptureWheel(gArea.x, gListY, gArea.width, gListH)) {
                            int gwd = app.window.EventKeyCode();
                            int gwstep = gwd / 120;
                            if (gwstep == 0) {
                                if (gwd > 0) { gwstep = 1; }
                                else if (gwd < 0) { gwstep = 0 - 1; }
                            }
                            gitScroll.Set(gitScroll.Get() - gwstep);
                            app.RequestRedraw();
                        }
                        if (gitScroll.Get() > gMax) { gitScroll.Set(gMax); }
                        if (gitScroll.Get() < 0) { gitScroll.Set(0); }
                        c.PushClip(gArea.x + gPad, gListY, gArea.width - gPad * 2, gListH);
                        if (gitFiles.Count == 0) {
                            c.DrawText(gArea.x + gPad * 2, gListY + gPad,
                                ZanIDE.T("Working tree clean.", "工作区无变更。"),
                                t.success, t.fontSizeSmall);
                        }
                        int gfi = gitScroll.Get();
                        int gcy = gListY;
                        while (gfi < gitFiles.Count && gcy + gRowH <= gListY + gListH) {
                            if (gitSel.Get() == gfi) {
                                c.FillRect(gArea.x + gPad, gcy, gArea.width - gPad * 2, gRowH, t.bgHover);
                            }
                            int gClr = ZanIDE.GitStatusColor(t, gitFiles[gfi]);
                            c.DrawText(gArea.x + gPad * 2, gcy + app.Scale(2),
                                Ellipsis.Fit(gitFiles[gfi], gArea.width - gPad * 4, t.fontSizeSmall),
                                gClr, t.fontSizeSmall);
                            gcy = gcy + gRowH;
                            gfi = gfi + 1;
                        }
                        c.PopClip();
                        if (app.ClickAvailable() && app.window.EventButton() == 0
                            && app.mouseX >= gArea.x + gPad && app.mouseX < gArea.x + gArea.width - gPad
                            && app.mouseY >= gListY && app.mouseY < gListY + gListH) {
                            int gIdx = gitScroll.Get() + (app.mouseY - gListY) / gRowH;
                            if (gIdx >= 0 && gIdx < gitFiles.Count) {
                                if (app.DoubleClickNow() && gitSel.Get() == gIdx) {
                                    string gp = root + "/" + ZanIDE.GitPathOf(gitFiles[gIdx]);
                                    if (File.Exists(gp)) {
                                        ZanIDE.OpenPath(tabNames, tabBodies, tabPaths,
                                            activeTab, gp, Path.GetFileName(gp));
                                        lastActive = 0 - 1;
                                    }
                                }
                                gitSel.Set(gIdx);
                                app.RequestRedraw();
                            }
                        }
                        // Bottom row: commit message + Commit (stages nothing
                        // itself; commits what is already staged, falling back
                        // to `commit -a` when nothing is staged yet).
                        gitMsgIn.Render(app, rp.x + rPad, rInY, rInW, rInH);
                        int gCmtId = Button.Primary(ZanIDE.T("Commit", "提交")).SetSize(1)
                            .Render(app, rp.x + rPad * 2 + rInW, rInY + app.Scale(2), rBtnW);
                        if (Button.WasClicked(app, gCmtId)) {
                            string gMsg = gitMsgIn.GetText();
                            if (gMsg == "") {
                                log.Add(ZanIDE.T("> Enter a commit message first.",
                                    "> 请先输入提交信息。"));
                            } else {
                                gMsg = ZanIDE.GitEscape(gMsg);
                                List<string> gOut = ZanIDE.GitRun(root,
                                    "diff --cached --quiet && git -C \"" + root
                                    + "\" commit -a -m \"" + gMsg
                                    + "\" || git -C \"" + root + "\" commit -m \"" + gMsg + "\"");
                                ZanIDE.AppendAll(log, gOut);
                                gitMsgIn.SetText("");
                                gitLoaded = false;
                            }
                            bottomTab.Set(0);
                            app.RequestRedraw();
                        }
                    }
                } else if (rTab >= 1) {
                    // Tools / Examples: a filter bar + file tree. Single click
                    // selects; double-click RUNS a tool (tools are Zan code)
                    // or opens the source in the editor (examples).
                    Rect rtArea = Rect.Create(rp.x, rp.y + rTabH, rp.width, rp.height - rTabH);
                    List<TreeNode> rtNodes = rtToolTree;
                    SignalInt rtSel = rtToolSel;
                    SignalInt rtScroll = rtToolScroll;
                    Input rtFilter = rtToolFilter;
                    if (rTab == 2) { rtNodes = rtExTree; rtSel = rtExSel; rtScroll = rtExScroll; rtFilter = rtExFilter; }
                    rtArea = TreeView.FilterBar(app, rtArea, rtFilter);
                    List<TreeNode> rtShow = ZanIDE.FilterNodes(rtNodes, rtFilter.GetText());
                    int rtRowH = TreeView.RowHeight(app);
                    int rtVis = rtArea.height / rtRowH;
                    if (rtVis < 1) { rtVis = 1; }
                    int rtContentH = TreeView.ContentHeight(app, rtShow);
                    int rtMax = rtContentH - rtVis * rtRowH;
                    if (rtMax < 0) { rtMax = 0; }
                    int rtSc = rtScroll.Get();
                    if (app.CaptureWheel(rtArea.x, rtArea.y, rtArea.width, rtArea.height)) {
                        int rtd = app.window.EventKeyCode();
                        int rtstep = rtd / 120;
                        if (rtstep == 0) {
                            if (rtd > 0) { rtstep = 1; }
                            else if (rtd < 0) { rtstep = 0 - 1; }
                        }
                        rtSc = rtSc - rtstep * rtRowH;
                        app.RequestRedraw();
                    }
                    if (rtSc > rtMax) { rtSc = rtMax; }
                    if (rtSc < 0) { rtSc = 0; }
                    rtScroll.Set(rtSc);
                    if (rtShow.Count == 0) {
                        string rtEmpty = ZanIDE.T("No files found in ", "没有找到文件：")
                            + root + "/tools";
                        if (rTab == 2) {
                            rtEmpty = ZanIDE.T("No examples found.", "没有找到示例。");
                        }
                        c.DrawText(rtArea.x + app.Scale(8), rtArea.y + app.Scale(8),
                            rtEmpty, t.textTertiary, t.fontSizeSmall);
                    } else {
                        TreeView.Render(app, rtArea, rtShow, rtSel, rtSc);
                    }
                    // Double-click on a leaf: run the tool / open the example.
                    if (app.ClickAvailable() && app.window.EventButton() == 0
                        && app.DoubleClickNow()
                        && app.mouseX >= rtArea.x && app.mouseX < rtArea.x + rtArea.width
                        && app.mouseY >= rtArea.y && app.mouseY < rtArea.y + rtArea.height) {
                        int rtSelV = rtSel.Get();
                        if (rtSelV >= 0 && rtSelV < rtShow.Count) {
                            TreeNode rtn = rtShow[rtSelV];
                            if (!rtn.isDir && rtn.path != "" && !ZanIDE.StartsWith(rtn.path, "@")) {
                                if (rTab == 1) {
                                    log.Add(ZanIDE.T("> Running tool ", "> 运行工具 ") + rtn.path + " ...");
                                    ZanIDE.RunFile(rtn.path, root, log, editor);
                                } else {
                                    ZanIDE.OpenPath(tabNames, tabBodies, tabPaths, activeTab, rtn.path, rtn.label);
                                    log.Add("> Opened " + rtn.path + ".");
                                }
                                app.RequestRedraw();
                            }
                        }
                    }
                }
                // Stream new shell output from a launched program into the
                // Output tab. Poll on the throttled animation clock so a live
                // session doesn't spin the CPU but output appears promptly.
                if (termFp != 0) {
                    int consumed2 = ZanIDE.TermPoll(termLogLen, log);
                    if (consumed2 != termLogLen) {
                        termLogLen = consumed2;
                        coScroll = 0;
                        app.RequestRedraw();
                    }
                    app.RequestAnimationFrame(250);
                }
                // Poll the in-flight detached publish: compiler output streams
                // into the Output tab and a done-marker file signals completion,
                // so even a slow cross-compile never blocks the UI.
                if (pubBusy) {
                    int pubConsumed = ZanIDE.PubPoll(pubLogLen, log);
                    if (pubConsumed != pubLogLen) {
                        pubLogLen = pubConsumed;
                        coScroll = 0;
                        app.RequestRedraw();
                    }
                    if (File.Exists(ZanIDE.PubDonePath())) {
                        File.Delete(ZanIDE.PubDonePath());
                        pubLogLen = ZanIDE.PubPoll(pubLogLen, log);
                        int pubOk = 0;
                        int pe = 0;
                        while (pe < pubExes.Count) {
                            if (File.Exists(pubExes[pe])) {
                                log.Add("> Published " + pubExes[pe]);
                                pubOk = pubOk + 1;
                            } else {
                                log.Add(ZanIDE.T("> Publish failed for ", "> 发布失败：") + pubExes[pe]);
                            }
                            pe = pe + 1;
                        }
                        if (pubOk > 0) { ZanIDE.CopyResources(root, root + "/publish", log); }
                        pubBusy = false;
                        pubExes = new List<string>();
                        coScroll = 0;
                        app.RequestRedraw();
                    }
                    app.RequestAnimationFrame(250);
                }
                // Poll the in-flight AI request: curl runs detached and drops a
                // done-marker when the response file is complete.
                if (aiBusy.Get() == 1) {
                    if (File.Exists(ZanIDE.AiDonePath())) {
                        File.Delete(ZanIDE.AiDonePath());
                        aiRole.Add("assistant");
                        aiText.Add(ZanIDE.AiReadAnswer());
                        aiBusy.Set(0);
                        aiScroll.Set(0);
                    }
                    app.RequestRedraw();
                }

                // Status bar. Drawn on the same muted panel surface as the
                // title bar / side panels (bgSecondary) so the shell reads as
                // one calm frame; only the debugging state gets a loud tint.
                int sbY = H - sbH;
                bool sbDebug = (dbgState == 2);
                int sbText = t.textPrimary;
                int sbMuted = t.textSecondary;
                if (sbDebug) {
                    sbText = t.onScrim;
                    sbMuted = t.tooltipTextMuted;
                }
                int curLn = editor.CurLine();
                int curCl = editor.CurCol();
                string posInfo = ZanIDE.T("Ln ", "行 ") + Convert.ToString(curLn + 1) + ZanIDE.T(", Col ", "，列 ") + Convert.ToString(curCl + 1);
                string modeInfo = "Zan";
                if (designerMode) { modeInfo = ZanIDE.T("Designer", "设计器"); }
                if (pubBusy) { modeInfo = ZanIDE.T("Publishing...", "发布中..."); }
                if (sbDebug) { modeInfo = ZanIDE.T("Debugging", "调试中"); }
                statusBar.SetState(posInfo, modeInfo, "UTF-8", sbDebug, sbText, sbMuted);
                statusBar.RenderAt(app, 0, sbY, W, sbH);

                // Top-level editor context menu overlay (drawn last so nothing
                // paints over it), then bridge its host commands.
                if (!designerMode && !activeIsStart && !activeIsDocs) {
                    editor.RenderCtxMenu(app);
                    string ecmd = editor.TakeCommand();
                    if (ecmd == "find") { findMode = 1; app.RequestRedraw(); }
                    else if (ecmd == "gotoline") { findMode = 3; gotoText = ""; app.RequestRedraw(); }
                    else if (ecmd == "gotodef") {
                        if (lspSess == null && !lspTried) {
                            lspTried = true;
                            lspSess = LspSession.Start(root);
                            if (lspSess != null) { log.Add("> zan-lsp connected: semantic navigation enabled."); }
                        }
                        int gl = ZanIDE.GoToDefinitionSmart(lspSess, editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        if (gl >= 0) { pendingGotoLine = gl; pendingGotoCol = 0; lastActive = 0 - 1; }
                        app.RequestRedraw();
                    } else if (ecmd == "findrefs") {
                        if (lspSess == null && !lspTried) {
                            lspTried = true;
                            lspSess = LspSession.Start(root);
                            if (lspSess != null) { log.Add("> zan-lsp connected: semantic navigation enabled."); }
                        }
                        ZanIDE.FindReferencesSmart(lspSess, editor, tabNames, tabBodies, tabPaths, activeTab, root, log);
                        app.RequestRedraw();
                    }
                }
                // File-tree / tab right-click context menus, drawn above the
                // editor overlay. ctxKind: 1 = project tree row, 3 = editor tab.
                if (ctxKind != 0) {
                    List<string> cmLabels = new List<string>();
                    if (ctxKind == 1) {
                        cmLabels.Add(ZanIDE.T("New File", "新建文件"));
                        cmLabels.Add(ZanIDE.T("Refresh", "刷新"));
                        cmLabels.Add("-");
                        cmLabels.Add(ZanIDE.T("Copy Path", "复制路径"));
                        cmLabels.Add(ZanIDE.T("Reveal in Explorer", "在资源管理器中显示"));
                    } else if (ctxKind == 3) {
                        cmLabels.Add(ZanIDE.T("Close", "关闭"));
                        cmLabels.Add(ZanIDE.T("Close Others", "关闭其他"));
                        cmLabels.Add("-");
                        cmLabels.Add(ZanIDE.T("Copy Path", "复制路径"));
                    }
                    int chosen = ContextMenu.Render(app, ctxX, ctxY, cmLabels);
                    if (chosen == 0 - 2) {
                        ctxKind = 0;
                        app.RequestRedraw();
                    } else if (chosen >= 0) {
                        if (ctxKind == 1) {
                            if (chosen == 0 && dlg == null) {
                                dlg = ZanIDE.OpenWizard(app, ZanIDE.T("New File", "新建文件"), fSel, fNameInput, "NewFile");
                                dlgMode = 2;
                            } else if (chosen == 1) {
                                rescan = true;
                            } else if (chosen == 3) {
                                if (ctxTarget >= 0 && ctxTarget < treeShow.Count) {
                                    Clipboard.SetText(treeShow[ctxTarget].path);
                                    log.Add("> Copied path: " + treeShow[ctxTarget].path);
                                }
                            } else if (chosen == 4) {
                                if (ctxTarget >= 0 && ctxTarget < treeShow.Count) {
                                    ZanIDE.RevealInFileManager(treeShow[ctxTarget].path);
                                }
                            }
                        } else if (ctxKind == 3) {
                            if (chosen == 0) {
                                ZanIDE.CloseTabAt(tabNames, tabBodies, tabPaths, activeTab, ctxTarget);
                                lastActive = 0 - 1;
                            } else if (chosen == 1) {
                                ZanIDE.CloseOtherTabs(tabNames, tabBodies, tabPaths, activeTab, ctxTarget);
                                lastActive = 0 - 1;
                            } else if (chosen == 3) {
                                if (ctxTarget >= 0 && ctxTarget < tabPaths.Count) {
                                    Clipboard.SetText(tabPaths[ctxTarget]);
                                    log.Add("> Copied path: " + tabPaths[ctxTarget]);
                                }
                            }
                        }
                        ctxKind = 0;
                        app.RequestRedraw();
                    }
                }

                // Publish dialog overlay (modal, topmost).
                if (pubOpen) {
                    string pubName = Path.GetFileName(root);
                    if (pubName == "") { pubName = "project"; }
                    // Pin the dialog's widget ids to a fixed baseline: the main
                    // window's widget count varies frame to frame, and drifting
                    // ids would leave the dialog's buttons dead (see the wizard
                    // child-window comment below).
                    int savedSeqP = WidgetId.SeqValue();
                    WidgetId.SetSeq(860000);
                    int pAct = Dialogs.RenderPublishDialog(app, pubName, pubSel);
                    WidgetId.SetSeq(savedSeqP);
                    if (pAct == 1) {
                        // Close the dialog first, then publish on the next frame so
                        // the (blocking) cross-compile never leaves a frozen modal.
                        pubOpen = false;
                        pubPending = true;
                        app.RequestRedraw();
                    } else if (pAct == 2) {
                        pubOpen = false;
                        app.RequestRedraw();
                    }
                } else if (pubPending && !pubBusy) {
                    pubPending = false;
                    pubExes = ZanIDE.PublishPlatformsBegin(tabNames, tabPaths, activeTab, root, pubSel, log);
                    pubBusy = pubExes.Count > 0;
                    pubLogLen = 0;
                    app.RequestRedraw();
                }

                // Project configuration overlay (modal): icon + static resources.
                if (cfgOpen) {
                    // Same fixed id baseline trick as the publish dialog above.
                    int savedSeqC = WidgetId.SeqValue();
                    WidgetId.SetSeq(870000);
                    int cAct = Dialogs.RenderProjectConfigDialog(app, root, log);
                    WidgetId.SetSeq(savedSeqC);
                    if (cAct == 1) {
                        cfgOpen = false;
                        lastActive = 0 - 1;
                        app.RequestRedraw();
                    } else if (cAct == 2) {
                        pathPicker.BeginOpenFile(
                            ZanIDE.ReadLastPickerDirectory(root), ".ico",
                            ZanIDE.T("Select application icon (.ico)", "选择应用图标 (.ico)"));
                        pathPickerOwner = 2;
                        app.RequestRedraw();
                    } else if (cAct == 3) {
                        pathPicker.BeginOpenFile(
                            ZanIDE.ReadLastPickerDirectory(root), "",
                            ZanIDE.T("Add a static resource (copy)", "导入静态资源（复制）"));
                        pathPickerOwner = 3;
                        app.RequestRedraw();
                    } else if (cAct == 4) {
                        pathPicker.BeginOpenFile(
                            ZanIDE.ReadLastPickerDirectory(root), "",
                            ZanIDE.T("Add a linked resource (referenced in place)", "导入链接资源（引用原位置）"));
                        pathPickerOwner = 5;
                        app.RequestRedraw();
                    } else if (cAct == 5) {
                        cfgOpen = false;
                        assetMgrOpen = true;
                        app.RequestRedraw();
                    }
                }

                // Asset Manager overlay (modal): recursive assets/ browser,
                // batch folder import and .anim clip authoring.
                if (assetMgrOpen) {
                    AssetManager.lang = ZanIDE.uiLang;
                    int savedSeqA = WidgetId.SeqValue();
                    WidgetId.SetSeq(890000);
                    int aAct = assetMgr.Render(app, root, log);
                    WidgetId.SetSeq(savedSeqA);
                    if (aAct == 1) {
                        assetMgrOpen = false;
                        lastActive = 0 - 1;
                        app.RequestRedraw();
                    } else if (aAct == 2) {
                        pathPicker.BeginOpenFile(
                            ZanIDE.ReadLastPickerDirectory(root), "",
                            ZanIDE.T("Import an asset file", "导入素材文件"));
                        pathPickerOwner = 6;
                        app.RequestRedraw();
                    } else if (aAct == 3) {
                        pathPicker.BeginFolder(
                            ZanIDE.ReadLastPickerDirectory(root),
                            ZanIDE.T("Import an asset folder (recursive)", "导入素材文件夹（递归）"));
                        pathPickerOwner = 7;
                        app.RequestRedraw();
                    }
                }
                string windowTitle = "Zan IDE";
                if (haveProject) { windowTitle = windowTitle + "  —  " + root; }
                // Global operation feedback: toast + notification queues drawn
                // above everything so every action gives visible feedback.
                Layer.RenderToasts(app);
                Layer.RenderNotifs(app);
                app.RenderChrome(windowTitle);
                app.PresentFrame();
                lastPresent = Window.GetTickMs();
            }

            // ---------------- wizard child window ----------------
            if (dlg != null) {
                if (dlg.needsRedraw && !pathPicker.IsOpen()) {
                    dlg.BeginFrame();
                    // The wizard is immediate-mode but shares the process-wide
                    // WidgetId counter with the main window (which the IDE never
                    // rewinds). Pin a fixed high baseline for the dialog's own
                    // frame so its buttons (Create/Cancel/Browse) get identical
                    // ids every frame -- otherwise hover/press/click never match
                    // the pointer target resolved on the previous frame and the
                    // Cancel/Create buttons appear dead. Restore afterwards.
                    int savedSeq = WidgetId.SeqValue();
                    WidgetId.SetSeq(850000);
                    int action = 0;
                    if (dlgMode == 1) {
                        action = Wizard.RenderCategorized(dlg, ZanIDE.T("New Project", "新建项目"), catNames, catSel,
                                                          wizTpls, pSel,
                                                          pNameInput, pLocInput,
                                                          platforms, platformGroups);
                    } else if (dlgMode == 3) {
                        action = Wizard.Render(dlg, ZanIDE.T("Save as Template", "另存为模板"), saveItems,
                                               tmplCatSel, tmplNameInput, tmplNameInput, false);
                    } else {
                        action = Wizard.Render(dlg, ZanIDE.T("New File", "新建文件"), fileItems, fSel,
                                               fNameInput, fNameInput, false);
                    }
                    WidgetId.SetSeq(savedSeq);
                    dlg.PresentFrame();
                    lastPresent = Window.GetTickMs();

                    if (action == 1) {
                        bool dlgDone = true;
                        if (dlgMode == 1) {
                            string parent = pLocInput.GetText();
                            string name = pNameInput.GetText();
                            int gi = pSel.Get();
                            if (gi >= 0 && gi < tpls.Count) {
                                string plats = ZanIDE.PlatformCsv(platforms);
                                ZanIDE.WriteLastPickerDirectory(parent);
                                string newDir = ZanIDE.CreateProjectT(tpls[gi], parent, name, plats, log);
                                if (newDir == "") {
                                    // Target folder exists and is not empty: keep the
                                    // wizard open (with an inline notice) so the user
                                    // can pick another name/location.
                                    Wizard.notice = ZanIDE.T(
                                        "Target folder exists and is not empty.",
                                        "目标文件夹已存在且非空。");
                                    dlgDone = false;
                                } else {
                                    root = newDir;
                                    haveProject = true;
                                    Layer.Notify(ZanIDE.T("Project created: ", "项目已创建：") + name, 3);
                                    ZanIDE.WriteLastProject(root);
                                    tabNames = new List<string>();
                                    tabBodies = new List<string>();
                                    tabPaths = new List<string>();
                                    activeTab.Set(0);
                                    lastActive = 0 - 1;
                                    ZanIDE.OpenFirst(tabNames, tabBodies, tabPaths, activeTab, root);
                                }
                            }
                        } else if (dlgMode == 3) {
                            string cat = saveItems[tmplCatSel.Get()].name;
                            string tname = tmplNameInput.GetText();
                            ZanIDE.SaveAsTemplate(root, cat, tname, log);
                            Layer.Notify(ZanIDE.T("Template saved: ", "模板已保存：") + tname, 3);
                        } else {
                            string name = fNameInput.GetText();
                            string p = ZanIDE.CreateFile(fSel.Get(), root, name, log);
                            ZanIDE.OpenPath(tabNames, tabBodies, tabPaths, activeTab, p, Path.GetFileName(p));
                            Layer.Notify(ZanIDE.T("File created: ", "文件已创建：") + Path.GetFileName(p), 3);
                        }
                        if (dlgDone) {
                            rescan = true;
                            Wizard.notice = "";
                            dlg.window.Close();
                            dlg = null;
                            dlgMode = 0;
                        } else {
                            dlg.RequestRedraw();
                        }
                        app.RequestRedraw();
                    } else if (action == 2) {
                        Wizard.notice = "";
                        dlg.window.Close();
                        dlg = null;
                        dlgMode = 0;
                        app.RequestRedraw();
                    } else if (action == 3) {
                        if (dlgMode == 1 && !pathPicker.IsOpen()) {
                            pathPicker.BeginFolder(ZanIDE.ReadLastPickerDirectory(pLocInput.GetText()),
                                ZanIDE.T("Select project location", "选择项目位置"));
                            pathPickerOwner = 1;
                            dlg.RequestRedraw();
                        }
                    }
                }
            }

            if (settingsWindow != null) {
                // Pin the child window's widget ids to a fixed baseline (the
                // main window's per-frame widget count varies, and drifting
                // ids would leave the settings controls unresponsive).
                int savedSeqS = WidgetId.SeqValue();
                WidgetId.SetSeq(880000);
                settingsWindow.Render();
                WidgetId.SetSeq(savedSeqS);
                edThemeIdx = settingsWindow.ThemeIndex();
                edFontPx = settingsWindow.FontSize();
                if (settingsWindow.TakeLanguageChanged()) {
                    ZanIDE.uiLang = settingsWindow.Language();
                    Wizard.lang = ZanIDE.uiLang;
                    Designer.lang = ZanIDE.uiLang;
                    cmds = ZanIDE.BuildRibbon();
                    lastActive = 0 - 1;
                    app.RequestRedraw();
                }
                if (settingsWindow.TakeSaved()) {
                    ZanIDE.WriteEditorPrefs(edThemeIdx, edFontPx);
                    log.Add("> Editor theme: "
                        + ZanIDE.EditorThemeName(edThemeIdx)
                        + "; font " + Convert.ToString(
                            ZanIDE.EditorFontOr(edFontPx, defFontPx))
                        + "px.");
                    app.RequestRedraw();
                }
                if (!settingsWindow.IsOpen()) {
                    settingsWindow = null;
                }
            }

            if (pathPicker.NeedsRedraw()) {
                pathPicker.RenderWindow();
                lastPresent = Window.GetTickMs();
            }
            int pickerResult = pathPicker.TakeResult();
            if (pickerResult == 1) {
                string picked = pathPicker.SelectedPath();
                ZanIDE.WriteLastPickerDirectory(
                    pathPicker.CurrentDirectory());
                if (pathPickerOwner == 1) {
                    pLocInput.SetText(picked);
                    if (dlg != null) { dlg.RequestRedraw(); }
                } else if (pathPickerOwner == 2) {
                    string ad = ZanIDE.AssetsDir(root);
                    Directory.CreateDirectoryRecursive(ad);
                    File.Copy(picked, ad + "/app.ico");
                    ZanIDE.SetProjectIcon(root, "assets/app.ico");
                    log.Add(
                        "> App icon set: assets/app.ico (embedded into the exe on the next Build/Run/Publish).");
                } else if (pathPickerOwner == 3) {
                    string ad = ZanIDE.AssetsDir(root);
                    Directory.CreateDirectoryRecursive(ad);
                    string nm = Path.GetFileName(picked);
                    File.Copy(picked, ad + "/" + nm);
                    log.Add("> Added resource: assets/" + nm);
                    Layer.Msg(ZanIDE.T("Resource copied: ", "已复制资源：") + nm, 3);
                } else if (pathPickerOwner == 6) {
                    assetMgr.ImportFile(picked, root, log);
                    Layer.Msg(ZanIDE.T("Asset imported", "素材已导入"), 3);
                } else if (pathPickerOwner == 7) {
                    assetMgr.ImportFolder(picked, root, log);
                    Layer.Msg(ZanIDE.T("Folder imported", "文件夹已导入"), 3);
                } else if (pathPickerOwner == 5) {
                    ZanIDE.AddProjLink(root, picked);
                    log.Add("> Linked resource: " + picked);
                    Layer.Msg(ZanIDE.T("Resource linked: ", "已链接资源：") + Path.GetFileName(picked), 3);
                } else if (pathPickerOwner == 4) {
                    string projectRoot = ZanIDE.FindProjectRoot(picked);
                    haveProject = projectRoot != "";
                    if (haveProject) {
                        root = projectRoot;
                        ZanIDE.WriteLastProject(root);
                    } else {
                        root = ZanIDE.DirOf(picked);
                    }
                    ZanIDE.OpenPath(
                        tabNames, tabBodies, tabPaths, activeTab,
                        picked, Path.GetFileName(picked));
                    lastActive = 0 - 1;
                    rescan = true;
                    log.Add("> Opened " + picked + ".");
                }
                pathPickerOwner = 0;
                app.RequestRedraw();
            } else if (pickerResult == 2) {
                pathPickerOwner = 0;
                if (dlg != null) { dlg.RequestRedraw(); }
                app.RequestRedraw();
            }

            if (rescan) {
                rescan = false;
                tree = new List<TreeNode>();
                if (haveProject) { tree = ZanIDE.ScanTree(root); }
                treeSel.Set(-1);
                lastTreeSel = -1;
            }
        }
        // Persist window + panel sizes so the next launch restores them.
        int arv = 0;
        if (autoRun) { arv = 1; }
        ZanIDE.SaveSettings(treeW.Get(), bottomPanelH.Get(), savedW, savedH, bottomTab.Get(), arv, app.ThemeMenuIndex(), rightW.Get(), rightTab.Get(), winOpacity);
    }

    /// Spawns a fresh wizard child window (a real draggable top-level window),
    /// resetting the selection and name field, and returns its App.
    static App OpenWizard(App parent, string title, SignalInt sel, Input nameInput, string defName) {
        App w = App.CreateDark(title, 720, 470);
        // Child windows inherit the parent's active skin so the whole app shares
        // one look (the skin picker stays available on the child's title bar).
        w.ApplySkin(parent.ThemeMenuIndex());
        w.Show();
        w.SetWindowOpacity(parent.WindowOpacity());
        sel.Set(0);
        nameInput.SetText(defName);
        return w;
    }

    /// Reveals a path in the OS file manager: Explorer (Windows), Finder via
    /// `open -R` (macOS), or the containing directory via `xdg-open` (Linux).
    static void RevealInFileManager(string path) {
        #if WINDOWS
        Process.Run("explorer /select,\"" + ZanIDE.ToWinPath(path) + "\"");
        #elif MACOS
        Process.Run("open -R \"" + path + "\"");
        #else
        Process.Run("xdg-open \"" + ZanIDE.DirOf(path) + "\"");
        #endif
    }

    /// Converts forward slashes to Windows backslashes (for explorer.exe).
    static string ToWinPath(string p) {
        string outp = "";
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "/") { outp = outp + "\\"; } else { outp = outp + ch; }
            i = i + 1;
        }
        return outp;
    }

    /// Closes the tab at `idx`, keeping at least one tab open and clamping the
    /// active index.
    static void CloseTabAt(List<string> names, List<string> bodies,
            List<string> paths, SignalInt active, int idx) {
        if (idx < 0 || idx >= names.Count) { return; }
        if (names.Count <= 1) { return; }
        names.RemoveAt(idx);
        bodies.RemoveAt(idx);
        paths.RemoveAt(idx);
        int a = active.Get();
        if (a > idx) { a = a - 1; }
        if (a >= names.Count) { a = names.Count - 1; }
        if (a < 0) { a = 0; }
        active.Set(a);
    }

    /// Closes every tab except the one at `idx`, which becomes active.
    static void CloseOtherTabs(List<string> names, List<string> bodies,
            List<string> paths, SignalInt active, int idx) {
        if (idx < 0 || idx >= names.Count) { return; }
        int k = names.Count - 1;
        while (k >= 0) {
            if (k != idx) {
                names.RemoveAt(k);
                bodies.RemoveAt(k);
                paths.RemoveAt(k);
            }
            k = k - 1;
        }
        active.Set(0);
    }

    // ---- workspace / scaffolding ----

    // ---- template catalog ----

    /// The built-in project templates, grouped by category. Category labels here
    /// must match the New Project wizard's category list exactly.
    static List<Tpl> BuiltinTemplates() {
        List<Tpl> ts = new List<Tpl>();
        ts.Add(Tpl.Make("Console", ZanIDE.T("Hello World", "Hello World"), "menu", "console",
            ZanIDE.T("Minimal console program that prints a line of text.", "最小控制台程序，打印一行文本。")));
        ts.Add(Tpl.Make("Console", ZanIDE.T("Command-line Args", "命令行参数"), "menu", "console-args",
            ZanIDE.T("Console program that reads command-line arguments.", "读取命令行参数的控制台程序。")));
        ts.Add(Tpl.Make("Console", ZanIDE.T("Multi-file Project", "多文件项目"), "copy", "console-multi",
            ZanIDE.T("Console project split into main + utils source files.", "拆分为 main + utils 源文件的控制台项目。")));
        ts.Add(Tpl.Make("Library", ZanIDE.T("Class Library", "类库"), "grid", "dll-class",
            ZanIDE.T("A reusable library of classes, compiled to a DLL.", "可复用的类库，编译为 DLL。")));
        ts.Add(Tpl.Make("Library", ZanIDE.T("Export DLL", "导出 DLL"), "copy", "dll-export",
            ZanIDE.T("A DLL exposing functions callable from other programs.", "导出可供其他程序调用函数的 DLL。")));
        ts.Add(Tpl.Make("Window App", ZanIDE.T("Empty Window", "空窗口"), "maximize", "gui-empty",
            ZanIDE.T("A blank window app built on the Gui standard library.", "基于 Gui 标准库的空白窗口程序。")));
        ts.Add(Tpl.Make("Window App", ZanIDE.T("Component Showcase", "组件展示"), "grid", "gui-components",
            ZanIDE.T("A window with panels/toolbars from the Gui components.", "带 Gui 组件面板/工具栏的窗口。")));
        ts.Add(Tpl.Make("WebView", ZanIDE.T("WebView Window", "WebView 窗口"), "folder", "webview",
            ZanIDE.T("A window that hosts web content (needs a WebView runtime).", "承载网页内容的窗口（需要 WebView 运行时）。")));
        ts.Add(Tpl.Make("Server", ZanIDE.T("HTTP Server", "HTTP 服务器"), "arrow-right", "server",
            ZanIDE.T("A minimal HTTP server skeleton.", "最小 HTTP 服务器骨架。")));
        ts.Add(Tpl.Make("Server", ZanIDE.T("TCP Echo Server", "TCP 回显服务器"), "refresh", "server-tcp",
            ZanIDE.T("A minimal TCP echo server skeleton.", "最小 TCP 回显服务器骨架。")));
        return ts;
    }

    /// Where the shipped template tree lives: <ExeDir>/templates when
    /// published, <ExeDir>/../templates when running from the build tree.
    static string TemplatesDir() {
        string a = ZanIDE.ExeDir() + "/templates";
        if (Directory.Exists(a)) { return a; }
        string b = ZanIDE.ExeDir() + "/../templates";
        if (Directory.Exists(b)) { return b; }
        return "";
    }

    /// Templates found on disk (category dirs -> template dirs, each described
    /// by a template.manifest) plus user templates; falls back to the
    /// hard-coded built-ins only when no disk tree exists.
    static List<Tpl> BuildCatalog(string root) {
        List<Tpl> ts = new List<Tpl>();
        ZanIDE.LoadDiskTemplates(ts);
        if (ts.Count == 0) { ts = ZanIDE.BuiltinTemplates(); }
        ZanIDE.LoadCustomTemplates(ts, root);
        return ts;
    }

    /// Scans <templates>/<category>/<template>/template.manifest (also accepts
    /// a template.manifest directly one level down) and appends each template,
    /// sorted by its manifest `order`.
    static void LoadDiskTemplates(List<Tpl> ts) {
        string base_ = ZanIDE.TemplatesDir();
        if (base_.Length == 0) { return; }
        List<Tpl> found = new List<Tpl>();
        List<string> cats = Directory.GetDirectories(base_);
        int i = 0;
        while (i < cats.Count) {
            string catDir = base_ + "/" + cats[i];
            if (File.Exists(catDir + "/template.manifest")) {
                ZanIDE.AddDiskTemplate(found, catDir);
            } else {
                List<string> subs = Directory.GetDirectories(catDir);
                int j = 0;
                while (j < subs.Count) {
                    ZanIDE.AddDiskTemplate(found, catDir + "/" + subs[j]);
                    j = j + 1;
                }
            }
            i = i + 1;
        }
        // Insertion sort by order (catalog stays tiny).
        int k = 0;
        while (k < found.Count) {
            int best = k;
            int m = k + 1;
            while (m < found.Count) {
                if (found[m].order < found[best].order) { best = m; }
                m = m + 1;
            }
            Tpl tmp = found[k]; found[k] = found[best]; found[best] = tmp;
            ts.Add(found[k]);
            k = k + 1;
        }
    }

    /// Parses one template.manifest into a Tpl (localized name/desc).
    static void AddDiskTemplate(List<Tpl> ts, string dir) {
        string mpath = dir + "/template.manifest";
        if (!File.Exists(mpath)) { return; }
        string m = File.ReadAllText(mpath);
        string nameEn = ZanIDE.ManifestField(m, "name", Path.GetFileName(dir));
        string nameZh = ZanIDE.ManifestField(m, "name.zh", nameEn);
        string descEn = ZanIDE.ManifestField(m, "desc", "");
        string descZh = ZanIDE.ManifestField(m, "desc.zh", descEn);
        Tpl t = Tpl.Make(
            ZanIDE.ManifestField(m, "category", "Other"),
            ZanIDE.T(nameEn, nameZh),
            ZanIDE.ManifestField(m, "icon", "file"),
            ZanIDE.ManifestField(m, "kind", "copy"),
            ZanIDE.T(descEn, descZh));
        t.src = dir;
        t.ptype = ZanIDE.ManifestField(m, "type", "console");
        t.ptarget = ZanIDE.ManifestField(m, "target", "exe");
        t.pentry = ZanIDE.ManifestField(m, "entry", "src/main.zan");
        t.order = ZanIDE.ParseInt(ZanIDE.ManifestField(m, "order", "1000"));
        ts.Add(t);
    }

    /// The distinct categories of a catalog, in first-appearance order.
    static List<string> CatsOf(List<Tpl> ts) {
        List<string> outp = new List<string>();
        int i = 0;
        while (i < ts.Count) {
            string c = ts[i].cat;
            bool seen = false;
            int j = 0;
            while (j < outp.Count) {
                if (outp[j] == c) { seen = true; }
                j = j + 1;
            }
            if (!seen) { outp.Add(c); }
            i = i + 1;
        }
        return outp;
    }

    /// Projects the catalog into the entity list the wizard consumes.
    static List<WizardTemplate> WizTemplates(List<Tpl> ts) {
        List<WizardTemplate> outp = new List<WizardTemplate>();
        foreach (Tpl t in ts) {
            outp.Add(new WizardTemplate(t.cat, t.name, t.icon, t.desc));
        }
        return outp;
    }

    /// Scans root/.templates/<name>/ and appends each as a "Custom" template.
    /// GetDirectories on a missing directory yields an empty list, so no
    /// separate existence check is needed.
    static void LoadCustomTemplates(List<Tpl> ts, string root) {
        string dir = ZanIDE.UserConfigDir() + "/templates";
        List<string> subs = Directory.GetDirectories(dir);
        int i = 0;
        while (i < subs.Count) {
            string tname = subs[i];
            string tdir = dir + "/" + tname;
            string desc = "Custom template.";
            string icon = "file";
            string mpath = tdir + "/template.manifest";
            if (!File.Exists(mpath)) { mpath = tdir + "/manifest.txt"; }
            if (File.Exists(mpath)) {
                string m = File.ReadAllText(mpath);
                desc = ZanIDE.ManifestField(m, "desc", desc);
                icon = ZanIDE.ManifestField(m, "icon", icon);
            }
            Tpl t = Tpl.Make("Custom", tname, icon, "custom", desc);
            t.src = tdir;
            ts.Add(t);
            i = i + 1;
        }
    }

    /// Reads a "key=value" field from a simple manifest, or returns def.
    /// Scans char-by-char (rather than splitting into a list) to stay robust.
    static string ManifestField(string content, string key, string def) {
        string prefix = key + "=";
        int n = content.Length;
        int pl = prefix.Length;
        int i = 0;
        while (i < n) {
            bool atLineStart = (i == 0) || (content.Substring(i - 1, 1) == "\n");
            if (atLineStart && i + pl <= n && content.Substring(i, pl) == prefix) {
                int j = i + pl;
                string val = "";
                while (j < n) {
                    string ch = content.Substring(j, 1);
                    if (ch == "\n" || ch == "\r") { break; }
                    val = val + ch;
                    j = j + 1;
                }
                return val;
            }
            i = i + 1;
        }
        return def;
    }

    /// Recursively copies a template's files (skipping its manifest) into dst.
    static void CopyTree(string srcDir, string dstDir) {
        ZanIDE.CopyTreeT(srcDir, dstDir, "");
    }

    /// CopyTree with template-variable substitution: when name is non-empty,
    /// every occurrence of {{NAME}} in file contents becomes the project name.
    static void CopyTreeT(string srcDir, string dstDir, string name) {
        Directory.CreateDirectory(dstDir);
        List<string> files = Directory.GetFiles(srcDir);
        int i = 0;
        while (i < files.Count) {
            string fn = files[i];
            if (fn != "manifest.txt" && fn != "template.manifest") {
                string body = File.ReadAllText(srcDir + "/" + fn);
                if (name.Length > 0) {
                    body = ZanIDE.ReplaceAll(body, "{{NAME}}", name);
                }
                File.WriteAllText(dstDir + "/" + fn, body);
            }
            i = i + 1;
        }
        List<string> subs = Directory.GetDirectories(srcDir);
        int j = 0;
        while (j < subs.Count) {
            ZanIDE.CopyTreeT(srcDir + "/" + subs[j], dstDir + "/" + subs[j], name);
            j = j + 1;
        }
    }

    /// Replaces every occurrence of pat in s (no overlap handling needed for
    /// template variables).
    static string ReplaceAll(string s, string pat, string rep) {
        if (pat.Length == 0) { return s; }
        StringBuilder sb = new StringBuilder();
        int n = s.Length;
        int pl = pat.Length;
        int i = 0;
        while (i < n) {
            bool hit = false;
            if (i + pl <= n) {
                if (s.Substring(i, pl) == pat) { hit = true; }
            }
            if (hit) { sb.Append(rep); i = i + pl; }
            else { sb.Append(s.Substring(i, 1)); i = i + 1; }
        }
        return sb.ToString();
    }

    /// Saves the current project (its src/ tree + zan.proj) as a reusable custom
    /// template under root/.templates/<tname>/ with a small manifest.
    static void SaveAsTemplate(string root, string cat, string tname, List<string> log) {
        string tdir = ZanIDE.UserConfigDir() + "/templates/" + tname;
        Directory.CreateDirectoryRecursive(tdir);
        if (Directory.Exists(root + "/src")) {
            ZanIDE.CopyTree(root + "/src", tdir + "/src");
        }
        if (File.Exists(root + "/zan.proj")) {
            File.WriteAllText(tdir + "/zan.proj", File.ReadAllText(root + "/zan.proj"));
        }
        File.WriteAllText(tdir + "/template.manifest",
            "name=" + tname + "\ncategory=" + cat + "\nicon=file\nkind=custom\ndesc=Custom template from " + Path.GetFileName(root) + ".\n");
        log.Add("> Saved current project as template '" + tname + "' (" + tdir + ").");
    }

    /// Maps the multi-select platform flags to a comma-separated id list
    /// (e.g. "windows-x64,linux-arm64"); defaults to windows-x64 if none chosen.
    static string PlatformCsv(List<WizardTarget> targets) {
        List<string> ids = new List<string>{
            "windows-x64", "windows-arm64",
            "linux-x64", "linux-arm64",
            "macos-x64", "macos-arm64" };
        string outp = "";
        for (int i = 0; i < targets.Count; i = i + 1) {
            if (i < ids.Count && targets[i].selected == 1) {
                if (outp.Length > 0) { outp = outp + ","; }
                outp = outp + ids[i];
            }
        }
        if (outp.Length == 0) { outp = "windows-x64"; }
        return outp;
    }

    /// Scaffolds a new project from a template descriptor; returns its directory.
    /// platforms is a comma-separated target-platform id list written to zan.proj.
    static string CreateProjectT(Tpl tpl, string parent, string name, string platforms, List<string> log) {
        string dir = parent + "/" + name;
        // Scaffolding into an existing non-empty folder would mix template
        // files into unrelated user data, so refuse and return "" (the caller
        // keeps the wizard open).
        if (Directory.Exists(dir)) {
            List<string> exFiles = Directory.GetFiles(dir);
            List<string> exDirs = Directory.GetDirectories(dir);
            if (exFiles.Count > 0 || exDirs.Count > 0) {
                log.Add(ZanIDE.T("> Cannot create project: target folder is not empty: ",
                    "> 无法创建项目：目标文件夹非空：") + dir);
                return "";
            }
        }
        Directory.CreateDirectoryRecursive(dir);
        Directory.CreateDirectoryRecursive(dir + "/src");

        string typeName = "console";
        string target = "exe";
        string entry = "src/main.zan";
        string kind = tpl.kind;

        if (kind == "gui-empty") {
            typeName = "gui"; target = "exe"; entry = "src/" + name + ".zan";
            ZanIDE.WriteFormProject(dir, name, 0);
        } else if (kind == "gui-components") {
            typeName = "gui"; target = "exe"; entry = "src/" + name + ".zan";
            ZanIDE.WriteFormProject(dir, name, 1);
        } else if (kind == "custom") {
            ZanIDE.CopyTree(tpl.src, dir);
        } else if (tpl.src.Length > 0) {
            // Disk template: copy its tree with {{NAME}} substituted, and take
            // project type/target/entry from its manifest.
            typeName = tpl.ptype; target = tpl.ptarget; entry = tpl.pentry;
            ZanIDE.CopyTreeT(tpl.src, dir, name);
        } else if (kind == "console") {
            File.WriteAllText(dir + "/src/main.zan", ZanIDE.ConsoleTemplate(name));
        } else if (kind == "console-args") {
            File.WriteAllText(dir + "/src/main.zan", ZanIDE.ConsoleArgsTemplate(name));
        } else if (kind == "console-multi") {
            File.WriteAllText(dir + "/src/main.zan", ZanIDE.ConsoleTemplate(name));
            File.WriteAllText(dir + "/src/utils.zan",
                "using System;\n\nclass Utils {\n    static int Add(int a, int b) { return a + b; }\n}\n");
        } else if (kind == "dll-class") {
            typeName = "library"; target = "dll"; entry = "src/lib.zan";
            File.WriteAllText(dir + "/src/lib.zan", ZanIDE.LibraryTemplate(name));
        } else if (kind == "dll-export") {
            typeName = "library"; target = "dll"; entry = "src/lib.zan";
            File.WriteAllText(dir + "/src/lib.zan", ZanIDE.DllExportTemplate(name));
        } else if (kind == "webview") {
            typeName = "gui"; target = "exe";
            File.WriteAllText(dir + "/src/main.zan", ZanIDE.WebViewTemplate(name));
        } else if (kind == "server") {
            File.WriteAllText(dir + "/src/main.zan", ZanIDE.ServerHttpTemplate(name));
        } else if (kind == "server-tcp") {
            File.WriteAllText(dir + "/src/main.zan", ZanIDE.ServerTcpTemplate(name));
        } else {
            typeName = "empty";
        }

        if (!File.Exists(dir + "/README.md")) {
            File.WriteAllText(dir + "/README.md",
                "# " + name + "\n\nGenerated by the Zan IDE (template: " + tpl.name + ").\n");
        }
        if (kind != "custom" && !File.Exists(dir + "/zan.proj")) {
            File.WriteAllText(dir + "/zan.proj",
                "name = " + name + "\ntype = " + typeName + "\nentry = " + entry
                + "\ntarget = " + target + "\nplatform = " + platforms + "\n");
        }
        log.Add("> Created " + typeName + " project for [" + platforms + "] at " + dir + " (template: " + tpl.name + ").");
        return dir;
    }

    /// Scaffolds a Window App as a visual form project: writes <name>.zform (the
    /// design surface) plus a runnable code-behind <name>.zan whose generated
    /// region opens the window and renders the designed controls. seedKind 0 is a
    /// minimal starter (label + button); 1 seeds a small component showcase.
    static void WriteFormProject(string dir, string name, int seedKind) {
        List<FormField> fs = ZanIDE.SeedFields(seedKind);
        File.WriteAllText(dir + "/src/" + name + ".zform",
            ZanIDE.FormJsonOf(name, fs));
        File.WriteAllText(dir + "/src/" + name + ".zan",
            ZanIDE.CodeBehindShell(name, ZanIDE.FieldsRegion(name, fs, 480, 520)));
    }

    /// A single seeded designer field (used by the new-form templates).
    static FormField MakeField(int ft, string label, string name) {
        FormField f = new FormField(ft);
        f.SetOptionsFrom("");
        f.label = label;
        f.fname = name;
        f.name = name;
        return f;
    }

    /// Starter fields for a new form: 0 = minimal, 1 = small showcase.
    static List<FormField> SeedFields(int seedKind) {
        List<FormField> fs = new List<FormField>();
        fs.Add(ZanIDE.MakeField(15, "Welcome", "TitleLabel"));
        fs.Add(ZanIDE.MakeField(0, "Name", "NameInput"));
        if (seedKind == 1) {
            fs.Add(ZanIDE.MakeField(5, "Remember me", "RememberCheck"));
            fs.Add(ZanIDE.MakeField(6, "Role", "RoleSelect"));
            fs.Add(ZanIDE.MakeField(9, "Volume", "VolumeSlider"));
        }
        fs.Add(ZanIDE.MakeField(49, "OK", "OkButton"));
        return fs;
    }

    /// Serializes a field list into the form designer's JSON document.
    static string FormJsonOf(string name, List<FormField> fs) {
        Designer d = Designer.Create();
        d.fields = fs;
        d.formNameSig.Set(name);
        return d.SaveJson();
    }

    /// A fresh .zform design document; seedKind < 0 creates an empty form.
    static string NewFormJson(string name, int seedKind) {
        if (seedKind < 0) {
            return ZanIDE.FormJsonOf(name, new List<FormField>());
        }
        return ZanIDE.FormJsonOf(name, ZanIDE.SeedFields(seedKind));
    }

    /// Creates a file from the chosen file template; returns the path to open.
    /// For a Form (kind 5) this follows the C#-style rule and creates BOTH the
    /// visual layout file (Name.zform) and its code-behind (Name.zan), returning
    /// the .zform so it opens in the designer.
    static string CreateFile(int kind, string root, string name, List<string> log) {
        Directory.CreateDirectory(root + "/src");
        if (kind == 6) {
            string scenePath = root + "/src/" + name + ".zscene";
            File.WriteAllText(scenePath, SceneDoc.Create(name, 1280, 720).ToJson());
            log.Add("> Created scene " + scenePath + ".");
            return scenePath;
        }
        if (kind == 5) {
            string formPath = root + "/src/" + name + ".zform";
            string cbPath = root + "/src/" + name + ".zan";
            File.WriteAllText(formPath, ZanIDE.NewFormJson(name, 0 - 1));
            if (!File.Exists(cbPath)) {
                File.WriteAllText(cbPath, ZanIDE.CodeBehindShell(name,
                    ZanIDE.FieldsRegion(name, new List<FormField>(), 480, 520)));
            }
            log.Add("> Created form " + formPath + " + code-behind " + cbPath + ".");
            return formPath;
        }
        string path = root + "/src/" + name + ".zan";
        File.WriteAllText(path, ZanIDE.FileTemplateBody(kind, name));
        log.Add("> Created file " + path + ".");
        return path;
    }

    static void OpenFirst(List<string> names, List<string> bodies, List<string> paths, SignalInt active, string root) {
        string formP = root + "/src/" + Path.GetFileName(root) + ".zform";
        string main = root + "/src/main.zan";
        string lib = root + "/src/lib.zan";
        if (File.Exists(formP)) {
            ZanIDE.OpenPath(names, bodies, paths, active, formP, Path.GetFileName(formP));
        } else if (File.Exists(main)) {
            ZanIDE.OpenPath(names, bodies, paths, active, main, "main.zan");
        } else if (File.Exists(lib)) {
            ZanIDE.OpenPath(names, bodies, paths, active, lib, "lib.zan");
        } else {
            names.Add("README.md");
            bodies.Add(File.ReadAllText(root + "/README.md"));
            paths.Add(root + "/README.md");
            active.Set(0);
        }
    }

    // ---- template bodies ----

    static string ConsoleTemplate(string name) {
        return "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello from " + name + "\");\n    }\n}\n";
    }

    static string GuiTemplate(string name) {
        return "using System;\nusing Gui;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"" + name + "\", 800, 600);\n        // app.Run drives the whole window loop (events + redraw + chrome);\n        // use the BeginFrame/PresentFrame loop directly to draw custom content.\n        app.Run(\"" + name + "\");\n    }\n}\n";
    }

    static string LibraryTemplate(string name) {
        return "using System;\n\n/// " + name + " library.\nclass " + name + " {\n    static int Version() { return 1; }\n}\n";
    }

    static string ConsoleArgsTemplate(string name) {
        return "using System;\n\nclass Program {\n    static void Main() {\n        // TODO: read and parse command-line arguments here.\n        Console.WriteLine(\"" + name + ": pass arguments on the command line\");\n    }\n}\n";
    }

    static string DllExportTemplate(string name) {
        return "using System;\n\n/// Functions exported from this library for use by other programs.\nclass " + name + " {\n    static int Add(int a, int b) { return a + b; }\n    static int Version() { return 1; }\n}\n";
    }

    static string GuiComponentsTemplate(string name) {
        return "using System;\nusing Gui;\nusing Gui.Widget;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"" + name + "\", 900, 640);\n        app.Show();\n        while (app.isRunning) {\n            if (!app.ProcessEvent()) { break; }\n            if (!app.needsRedraw) { continue; }\n            app.BeginFrame();\n            Canvas c = app.canvas;\n            int w = c.Width();\n            int h = c.Height();\n            int top = app.titlebarH;\n            Rect box = Panel.Section(app, 20, top + 20, w - 40, h - top - 40, \"" + name + "\");\n            c.DrawText(box.x + 12, box.y + 12, \"Build your UI from Gui components here.\", app.theme.textPrimary, app.theme.fontSizeMedium);\n            app.RenderChrome(\"" + name + "\");\n            app.PresentFrame();\n        }\n    }\n}\n";
    }

    static string WebViewTemplate(string name) {
        return "using System;\nusing Gui;\n\n// WebView window skeleton. Hosting real web content needs a WebView2\n// runtime binding; this placeholder window stands in until that lands.\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"" + name + "\", 1000, 700);\n        app.Run(\"WebView: " + name + "\");\n    }\n}\n";
    }

    static string ServerHttpTemplate(string name) {
        return "using System;\n\n// HTTP server skeleton. Wire in System.Net once its socket API is ready.\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"" + name + " listening on http://localhost:8080\");\n        Console.WriteLine(\"(network binding pending)\");\n    }\n}\n";
    }

    static string ServerTcpTemplate(string name) {
        return "using System;\n\n// TCP echo server skeleton. Wire in System.Net once its socket API is ready.\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"" + name + " TCP echo server on :9000\");\n        Console.WriteLine(\"(network binding pending)\");\n    }\n}\n";
    }

    static string FileTemplateBody(int kind, string name) {
        if (kind == 0) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello from " + name + "\");\n    }\n}\n";
        }
        if (kind == 1) {
            return "using System;\n\nclass " + name + " {\n    // fields and methods\n}\n";
        }
        if (kind == 2) {
            return ZanIDE.GuiTemplate(name);
        }
        if (kind == 3) {
            return "using System;\n\n/// Contract implemented by concrete types.\nclass " + name + " {\n    void Execute() { }\n}\n";
        }
        return "";
    }

    // ---- tree scanning ----

    static List<TreeNode> ScanTree(string root) {
        List<TreeNode> nodes = new List<TreeNode>();
        ZanIDE.ScanInto(
            nodes, root, Path.GetFileName(root), 0, true);
        return nodes;
    }

    static void ScanInto(List<TreeNode> nodes, string dirPath, string dirName, int depth, bool expanded) {
        TreeNode d = TreeNode.Dir(dirName, depth, expanded);
        d.path = dirPath;
        nodes.Add(d);
        List<string> subs = Directory.GetDirectories(dirPath);
        int i = 0;
        while (i < subs.Count) {
            ZanIDE.ScanInto(nodes, dirPath + "/" + subs[i], subs[i], depth + 1, false);
            i = i + 1;
        }
        List<string> files = Directory.GetFiles(dirPath);
        int j = 0;
        while (j < files.Count) {
            if (!ZanIDE.EndsWith(files[j], ".proj")) {
                TreeNode f = TreeNode.File(files[j], depth + 1);
                f.path = dirPath + "/" + files[j];
                nodes.Add(f);
            }
            j = j + 1;
        }
    }

    /// True when `s` ends with `suffix` (used to hide project manifests from
    /// the explorer tree).
    static bool EndsWith(string s, string suffix) {
        int sl = s.Length;
        int fl = suffix.Length;
        if (fl > sl) { return false; }
        return s.Substring(sl - fl, fl) == suffix;
    }

    // ---- tabs ----

    static void OpenPath(List<string> names, List<string> bodies, List<string> paths,
                         SignalInt active, string path, string name) {
        int idx = paths.IndexOf(path);
        if (idx >= 0) {
            active.Set(idx);
            return;
        }
        string content = File.ReadAllText(path);
        names.Add(name);
        bodies.Add(content);
        paths.Add(path);
        active.Set(names.Count - 1);
    }

    static void SaveActive(CodeEditor editor, List<string> names, List<string> bodies,
                           List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        if (a < 0 || a >= names.Count) { return; }
        string p = paths[a];
        // Virtual tabs (@start / @docs) have no file behind them; saving one
        // used to write a literal "@start" file into the workspace root.
        if (p == "@start" || p == "@docs") { return; }
        bodies[a] = editor.GetText();
        if (p == "") {
            p = root + "/" + names[a];
            paths[a] = p;
        }
        File.WriteAllText(p, bodies[a]);
        log.Add("> Saved " + p + ".");
    }

    /// Saves the .zform code view: writes the in-place code editor to the form's
    /// paired code-behind (.zan). Used instead of SaveActive while a .zform tab is
    /// showing code, so the form JSON is never overwritten with source.
    static void SaveFormCode(CodeEditor ed, string formPath, string root, List<string> log) {
        string cbp = ZanIDE.CodeBehindPath(formPath);
        File.WriteAllText(cbp, ed.GetText());
        log.Add("> Saved " + cbp + ".");
    }

    // ---- toolchain ----

    /// Rows whose label contains the filter (case-insensitive substring);
    /// directories are dropped and matches flattened to depth 0 so every hit
    /// is visible regardless of collapsed ancestors. An empty filter returns
    /// the nodes unchanged.
    static List<TreeNode> FilterNodes(List<TreeNode> nodes, string filter) {
        if (filter == "") { return nodes; }
        string f = ZanIDE.ToLowerS(filter);
        List<TreeNode> outp = new List<TreeNode>();
        int i = 0;
        while (i < nodes.Count) {
            TreeNode n = nodes[i];
            if (!n.isDir && ZanIDE.Has(ZanIDE.ToLowerS(n.label), f)) {
                TreeNode m = TreeNode.FileIcon(n.label, 0, n.icon);
                m.path = n.path;
                outp.Add(m);
            }
            i = i + 1;
        }
        return outp;
    }

    /// Resolves the source file Run/Build/Debug/Publish should compile for
    /// the active tab: a .zform maps to its code-behind (falling back to the
    /// project entry), and the special @start/@docs tabs map to the
    /// project entry when one exists. Returns "" when there is no target.
    static string RunTarget(string p, string root) {
        if (p == "@start" || p == "@docs") {
            string entry = ZanIDE.ProjectEntry(root);
            if (File.Exists(entry)) { return entry; }
            return "";
        }
        if (ZanIDE.IsFormPath(p)) {
            string cb = ZanIDE.CodeBehindPath(p);
            if (File.Exists(cb)) { return cb; }
            return ZanIDE.ProjectEntry(root);
        }
        if (ZanIDE.IsScenePath(p)) { return ZanIDE.ProjectEntry(root); }
        return p;
    }

    /// Run/Build/Debug from the ribbon act on the ACTIVE TAB: the focused code
    /// tab is what gets compiled and run, so a scratch snippet in its own tab
    /// can be tried without touching the project entry. Special tabs
    /// (@start/@docs) and designer tabs (.zform/.zscene) still map to the
    /// project entry via RunTarget.
    static string RibbonRunTarget(string activePath, string root) {
        return ZanIDE.RunTarget(activePath, root);
    }

    static void BuildActive(List<string> paths, SignalInt active, string root, List<string> log, CodeEditor editor) {
        int a = active.Get();
        string activePath = paths[a];
        string p = activePath;
        p = ZanIDE.RibbonRunTarget(p, root);
        if (p == "") { log.Add(ZanIDE.T("> Nothing to build (save the file first).", "> 没有可构建的目标（请先保存文件）。")); return; }
        string bd = ZanIDE.EnsureBuildDir(root);
        string ll = bd + "/.zanbuild.ll";
        string inputs = ZanIDE.SmartInputs(root, ZanIDE.DirOf(p), p);
        string cmd = ZanIDE.ZancCmd() + " --emit-ir " + inputs + " > \"" + ll + "\"";
        log.Add("> Building " + p + " ...");
        List<string> outp = Process.RunCapture(cmd);
        ZanIDE.AppendAll(log, outp);
        ZanIDE.ApplyDiagnostics(editor, activePath, outp, log);
        if (outp.Count == 0) {
            log.Add("> Build succeeded. 0 errors, 0 warnings.");
        }
    }

    static void RunActive(List<string> paths, SignalInt active, string root, List<string> log, CodeEditor editor) {
        int a = active.Get();
        if (a < 0 || a >= paths.Count) {
            log.Add("> Nothing to run (open a source file first).");
            return;
        }
        ZanIDE.RunFile(paths[a], root, log, editor);
    }

    /// Compiles and runs one source file (or a tab sentinel/.zform mapped via
    /// RunTarget). Also used by the Tools panel to run a tool on double-click.
    static void RunFile(string activePath, string root, List<string> log, CodeEditor editor) {
        string p = activePath;
        p = ZanIDE.RunTarget(p, root);
        if (p == "") {
            log.Add(ZanIDE.T("> Nothing to run (open and save a source file first).", "> 没有可运行的目标（请先打开并保存源文件）。"));
            return;
        }
        string bd = ZanIDE.EnsureBuildDir(root);
        string ll = bd + "/.zanrun.ll";
        string exe = bd + "/.zanrun" + ZanIDE.ExeSuffix();
        if (File.Exists(exe)) { File.Delete(exe); }
        string inputs = ZanIDE.SmartInputs(root, ZanIDE.DirOf(p), p);
        bool isGui = ZanIDE.IsGuiTarget(root, p);
        string cmd = ZanIDE.CompileToExe(root, p, inputs, ll, exe, false);
        log.Add("> Building " + p + " ...");
        List<string> outp = Process.RunCapture(cmd);
        ZanIDE.AppendAll(log, outp);
        ZanIDE.ApplyDiagnostics(editor, activePath, outp, log);
        if (!File.Exists(exe)) {
            log.Add(ZanIDE.T("> Build failed; not run.", "> 构建失败，未运行。"));
            return;
        }
        // Launch the program detached so the IDE never blocks: a console app may
        // be a long-running server (e.g. a web server) that never returns, which
        // would otherwise freeze the UI. Console apps get their own persistent
        // window so output is visible and Ctrl+C can stop them; GUI apps launch
        // windowless.
        #if WINDOWS
        if (isGui) { Process.Run("cmd /c start \"\" \"" + exe + "\""); }
        else { Process.Run("cmd /c start \"Zan Run\" cmd /k \"" + exe + "\""); }
        #else
        Process.Run("\"" + exe + "\" >/dev/null 2>&1 &");
        #endif
        log.Add(ZanIDE.T("> Started (running in a separate window).", "> 已启动（在独立窗口中运行）。"));
    }

    /// Builds the active run target and returns the executable path so the caller
    /// can stream it through the IDE terminal (non-blocking). GUI apps open their
    /// own window, so they are launched windowless here and "" is returned.
    /// Returns "" on build failure or when there is nothing to run; compiler
    /// diagnostics still flow to the Output log and editor squiggles.
    static string RunBuildActive(List<string> paths, SignalInt active, string root, List<string> log, CodeEditor editor) {
        int a = active.Get();
        if (a < 0 || a >= paths.Count) {
            log.Add(ZanIDE.T("> Nothing to run (open a source file first).", "> 没有可运行的目标（请先打开源文件）。"));
            return "";
        }
        return ZanIDE.RunBuildFile(paths[a], root, log, editor);
    }

    static string RunBuildFile(string activePath, string root, List<string> log, CodeEditor editor) {
        string p = activePath;
        p = ZanIDE.RibbonRunTarget(p, root);
        if (p == "") {
            log.Add(ZanIDE.T("> Nothing to run (open and save a source file first).", "> 没有可运行的目标（请先打开并保存源文件）。"));
            return "";
        }
        string bd = ZanIDE.EnsureBuildDir(root);
        string ll = bd + "/.zanrun.ll";
        string exe = bd + "/.zanrun" + ZanIDE.ExeSuffix();
        if (File.Exists(exe)) { File.Delete(exe); }
        string inputs = ZanIDE.SmartInputs(root, ZanIDE.DirOf(p), p);
        bool isGui = ZanIDE.IsGuiTarget(root, p);
        string cmd = ZanIDE.CompileToExe(root, p, inputs, ll, exe, false);
        log.Add("> Building " + p + " ...");
        List<string> outp = Process.RunCapture(cmd);
        ZanIDE.AppendAll(log, outp);
        ZanIDE.ApplyDiagnostics(editor, activePath, outp, log);
        if (!File.Exists(exe)) {
            log.Add(ZanIDE.T("> Build failed; not run.", "> 构建失败，未运行。"));
            return "";
        }
        if (isGui) {
            #if WINDOWS
            Process.Run("cmd /c start \"\" \"" + exe + "\"");
            #else
            Process.Run("\"" + exe + "\" >/dev/null 2>&1 &");
            #endif
            log.Add(ZanIDE.T("> GUI app started.", "> GUI 应用已启动。"));
            return "";
        }
        return exe;
    }

    /// Compiler inputs for Run/Build. Inside a project (a zan.proj at the root or
    /// beside the file) all sibling .zan files are compiled together; a loose
    /// single file is compiled on its own so unrelated scratch files in the same
    /// folder don't clash (e.g. two Main methods).
    static string SmartInputs(string root, string dir, string entry) {
        bool proj = File.Exists(root + "/zan.proj") || File.Exists(dir + "/zan.proj");
        if (!proj) { return "\"" + entry + "\""; }
        // Feed the project's other files in for cross-file types, but skip any
        // that declare their own Main: when the focused tab is a runnable
        // snippet, compiling it together with the project entry's Main would
        // fail with a duplicate entry point.
        string args = "\"" + entry + "\"";
        List<string> all = new List<string>();
        ZanIDE.GatherZanFiles(dir, all);
        int i = 0;
        while (i < all.Count) {
            string f = all[i];
            if (f != entry && !ZanIDE.FileHasMain(f)) {
                args = args + " \"" + f + "\"";
            }
            i = i + 1;
        }
        return args;
    }

    /// True when the file declares a `static ... Main(` entry point.
    static bool FileHasMain(string path) {
        if (!File.Exists(path)) { return false; }
        string s = File.ReadAllText(path);
        int i = ZanIDE.IndexOfStr(s, " Main(");
        while (i >= 0) {
            // Require `static` earlier on the same line so a call like
            // `x.Main()` or a comment does not count.
            int ls = i;
            while (ls > 0 && s.Substring(ls - 1, 1) != "\n") { ls = ls - 1; }
            string line = s.Substring(ls, i - ls);
            if (ZanIDE.IndexOfStr(line, "static ") >= 0) { return true; }
            int nxt = ZanIDE.IndexOfStr(s.Substring(i + 1, s.Length - i - 1), " Main(");
            if (nxt < 0) { return false; }
            i = i + 1 + nxt;
        }
        return false;
    }

    /// First index of `needle` in `hay`, or -1.
    static int IndexOfStr(string hay, string needle) {
        int n = needle.Length;
        int h = hay.Length;
        if (n == 0) { return 0; }
        int i = 0;
        while (i + n <= h) {
            if (hay.Substring(i, n) == needle) { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// Last index of `needle` in `hay`, or -1.
    static int LastIndexOfStr(string hay, string needle) {
        int n = needle.Length;
        int h = hay.Length;
        if (n == 0) { return h; }
        int i = h - n;
        while (i >= 0) {
            if (hay.Substring(i, n) == needle) { return i; }
            i = i - 1;
        }
        return -1;
    }

    /// Numeric value of a single-character digit string, or -1.
    static int DigitVal(string ch) {
        return ZanIDE.IndexOfStr("0123456789", ch);
    }

    /// Parses a leading run of digits into an int, or -1 when there are none.
    static int ParseLeadInt(string s) {
        int v = 0;
        int i = 0;
        bool any = false;
        while (i < s.Length) {
            int d = ZanIDE.DigitVal(s.Substring(i, 1));
            if (d < 0) { break; }
            v = v * 10 + d;
            any = true;
            i = i + 1;
        }
        if (!any) { return -1; }
        return v;
    }

    /// Strips ANSI SGR escape sequences (ESC [ ... m) from compiler output so the
    /// text can be matched and shown cleanly.
    static string StripAnsi(string s) {
        string esc = Text.ByteChar(27);
        string outp = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == esc) {
                i = i + 1;
                while (i < s.Length && s.Substring(i, 1) != "m") { i = i + 1; }
                if (i < s.Length) { i = i + 1; }
            } else {
                outp = outp + ch;
                i = i + 1;
            }
        }
        return outp;
    }

    /// Parses compiler output lines of the form `<path>:<line>:<col>: error: <msg>`
    /// that refer to the active file, and pushes them onto the editor as real
    /// diagnostics (red underline + reason tooltip), jumping to the first error.
    static void ApplyDiagnostics(CodeEditor editor, string activePath, List<string> output, List<string> log) {
        List<int> dl = new List<int>();
        List<string> dm = new List<string>();
        bool isZan = activePath.Length > 4
            && activePath.Substring(activePath.Length - 4, 4) == ".zan";
        if (isZan) {
            string baseName = Path.GetFileName(activePath);
            int oi = 0;
            while (oi < output.Count) {
                string raw = ZanIDE.StripAnsi(output[oi]);
                int ep = ZanIDE.IndexOfStr(raw, ": error:");
                if (ep > 0) {
                    string loc = raw.Substring(0, ep);
                    if (ZanIDE.IndexOfStr(loc, baseName) >= 0) {
                        int c2 = ZanIDE.LastIndexOfStr(loc, ":");
                        if (c2 > 0) {
                            int c1 = ZanIDE.LastIndexOfStr(loc.Substring(0, c2), ":");
                            if (c1 >= 0) {
                                string lineStr = loc.Substring(c1 + 1, c2 - (c1 + 1));
                                int lineNo = ZanIDE.ParseLeadInt(lineStr);
                                if (lineNo > 0) {
                                    string msg = raw.Substring(ep + 8, raw.Length - (ep + 8));
                                    dl.Add(lineNo - 1);
                                    dm.Add(ZanIDE.TrimLeadSpaces(msg));
                                }
                            }
                        }
                    }
                }
                oi = oi + 1;
            }
        }
        editor.SetCompilerDiagnostics(dl, dm);
        if (dl.Count > 0) {
            log.Add("> " + Convert.ToString(dl.Count) + " error(s) in this file; jumped to the first.");
        }
    }

    /// Hot reload: rebuild the active file and (re)launch it detached, killing
    /// the previous hot instance so the IDE stays responsive across saves.
    static void HotReloadRun(List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        if (a < 0 || a >= paths.Count) { return; }
        string p = paths[a];
        p = ZanIDE.RibbonRunTarget(p, root);
        if (p == "") { log.Add(ZanIDE.T("> [Hot] Nothing to run (save the file first).", "> [热重载] 没有可运行的目标（请先保存文件）。")); return; }
        string bd = ZanIDE.EnsureBuildDir(root);
        string ll = bd + "/.zanhot.ll";
        string exe = bd + "/zanhot_run" + ZanIDE.ExeSuffix();
        // Stop the previous hot instance so the exe can be overwritten.
        #if WINDOWS
        Process.Run("taskkill /F /IM zanhot_run.exe >nul 2>nul");
        Process.Run("cmd /c del /f /q \"" + exe + "\" >nul 2>nul");
        #else
        Process.Run("pkill -f zanhot_run >/dev/null 2>&1");
        Process.Run("rm -f \"" + exe + "\" >/dev/null 2>&1");
        #endif
        string inputs = ZanIDE.SmartInputs(root, ZanIDE.DirOf(p), p);
        string cmd = ZanIDE.CompileToExe(root, p, inputs, ll, exe, false);
        log.Add("> [Hot] Rebuilding ...");
        List<string> outp = Process.RunCapture(cmd);
        ZanIDE.AppendAll(log, outp);
        if (File.Exists(exe)) {
            // Launch detached so the IDE stays responsive.
            #if WINDOWS
            Process.Run("cmd /c start \"\" \"" + exe + "\"");
            #else
            Process.Run("\"" + exe + "\" >/dev/null 2>&1 &");
            #endif
            log.Add("> [Hot] Reloaded -> restarted app.");
        } else {
            log.Add("> [Hot] Build failed; app not restarted.");
        }
    }

    static void PublishActive(List<string> names, List<string> paths, SignalInt active, string root, List<string> log) {
        int a = active.Get();
        string p = paths[a];
        if (p == "") { log.Add("> Nothing to publish (save the file first)."); return; }
        // The active tab may be the .zform designer surface; publish the project's
        // real code entry, never hand a .zform to the compiler.
        if (ZanIDE.IsFormPath(p)) { p = ZanIDE.ProjectEntry(root); }
        Directory.CreateDirectory(root + "/publish");
        string bd = ZanIDE.EnsureBuildDir(root);
        string ll = bd + "/.zanpub.ll";
        string exe = root + "/publish/" + Path.GetFileName(root) + ".exe";
        string inputs = ZanIDE.ProjectInputs(ZanIDE.DirOf(p), p, "");
        string cmd = ZanIDE.CompileToExe(root, p, inputs, ll, exe, true);
        log.Add("> Publishing console exe ...");
        List<string> outp = Process.RunCapture(cmd);
        ZanIDE.AppendAll(log, outp);
        ZanIDE.CopyResources(root, root + "/publish", log);
        log.Add("> Published " + exe);
    }

    /// Naive substring search (the stdlib string type here exposes only
    /// Substring/Length), used to detect platform ids inside zan.proj.
    static bool Has(string hay, string needle) {
        int n = needle.Length;
        int h = hay.Length;
        if (n == 0) { return true; }
        int i = 0;
        while (i + n <= h) {
            if (hay.Substring(i, n) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// Reads the active project's target platforms from zan.proj into 6 flags
    /// parallel to PlatformCsv's id list. Non-Windows targets are force-cleared
    /// because this Windows host cannot produce them without a cross toolchain.
    static List<int> ReadProjectPlatforms(string root) {
        List<int> flags = new List<int>();
        int z = 0;
        while (z < 6) { flags.Add(0); z = z + 1; }
        string content = "";
        string pj = root + "/zan.proj";
        if (File.Exists(pj)) { content = File.ReadAllText(pj); }
        List<string> ids = new List<string>();
        ids.Add("windows-x64"); ids.Add("windows-arm64");
        ids.Add("linux-x64"); ids.Add("linux-arm64");
        ids.Add("macos-x64"); ids.Add("macos-arm64");
        int k = 0;
        while (k < ids.Count) {
            if (ZanIDE.Has(content, ids[k])) { flags[k] = 1; }
            k = k + 1;
        }
        flags[2] = 0; flags[3] = 0; flags[4] = 0; flags[5] = 0;
        if (flags[0] == 0 && flags[1] == 0) { flags[0] = 1; }
        return flags;
    }

    /// Streamed log + done-marker used by the detached (non-blocking) publish.
    static string PubLogPath() { return ZanIDE.UserConfigDir() + "/publish.log"; }
    static string PubDonePath() { return ZanIDE.UserConfigDir() + "/publish_done.txt"; }

    /// Starts publishing the selected targets in a DETACHED shell so the UI
    /// stays responsive while the (possibly slow) compiles run: compiler
    /// output streams into PubLogPath and PubDonePath marks completion (the
    /// main loop polls both, same pattern as the AI request). Returns the exe
    /// paths the caller must verify once the done-marker appears; an empty
    /// list means nothing was started.
    static List<string> PublishPlatformsBegin(List<string> names, List<string> paths, SignalInt active, string root, List<int> sel, List<string> log) {
        List<string> exes = new List<string>();
        int a = active.Get();
        if (a < 0 || a >= paths.Count) { log.Add("> Nothing to publish."); return exes; }
        // Publish always targets the whole project (its entry + every project
        // .zan file), not whichever tab happens to be focused.
        string p = ZanIDE.RibbonRunTarget(paths[a], root);
        if (p == "") { log.Add("> Nothing to publish (save the file first)."); return exes; }
        Directory.CreateDirectory(root + "/publish");
        string bd = ZanIDE.EnsureBuildDir(root);
        string zc = ZanIDE.ZancCmd();
        string inputs = ZanIDE.ProjectInputs(ZanIDE.DirOf(p), p, "");
        string baseName = Path.GetFileName(root);
        #if WINDOWS
        string sep = " & ";
        #else
        string sep = " ; ";
        #endif
        string seq = "";
        if (sel.Count > 0 && sel[0] == 1) {
            string exe = root + "/publish/" + baseName + "-windows-x64.exe";
            string ll = bd + "/.zanpub_x64.ll";
            if (seq != "") { seq = seq + sep; }
            seq = seq + "(" + ZanIDE.CompileToExe(root, p, inputs, ll, exe, true) + ")";
            exes.Add(exe);
            log.Add("> Publishing windows-x64 ...");
        }
        if (sel.Count > 1 && sel[1] == 1) {
            string exe = root + "/publish/" + baseName + "-windows-arm64.exe";
            string ll = bd + "/.zanpub_arm64.ll";
            if (seq != "") { seq = seq + sep; }
            seq = seq + "(" + zc + " --emit-ir " + inputs + " > \"" + ll + "\""
                + " && clang --target=aarch64-pc-windows-msvc \"" + ll + "\" -o \"" + exe + "\"" + ZanIDE.GuiLinkArgs(root, p) + ")";
            exes.Add(exe);
            log.Add("> Publishing windows-arm64 (requires ARM64 toolchain) ...");
        }
        // Non-Windows targets: cross-compiled through zanc's own bundled linker
        // (--target selects the triple; no external toolchain needed). Linux x64
        // uses the musl static target so the result is a single portable file.
        if (sel.Count > 2 && sel[2] == 1) {
            string exe = root + "/publish/" + baseName + "-linux-x64";
            if (seq != "") { seq = seq + sep; }
            seq = seq + "(" + zc + " --publish " + inputs
                + " --target linux-musl --link-mode static -o \"" + exe + "\")";
            exes.Add(exe);
            log.Add("> Publishing linux-x64 ...");
        }
        if (seq == "") {
            log.Add("> No target selected; nothing published.");
            return exes;
        }
        // Stale outputs would make a failed compile look successful, so drop
        // them before the detached run starts.
        int di = 0;
        while (di < exes.Count) {
            if (File.Exists(exes[di])) { File.Delete(exes[di]); }
            di = di + 1;
        }
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.PubLogPath(), "");
        if (File.Exists(ZanIDE.PubDonePath())) { File.Delete(ZanIDE.PubDonePath()); }
        string run = "((" + seq + ") >> \"" + ZanIDE.PubLogPath() + "\" 2>&1)"
            + sep + "echo ok > \"" + ZanIDE.PubDonePath() + "\"";
        Process.RunDetached(run);
        return exes;
    }

    /// Appends any new complete lines of the detached publish's streamed log
    /// to the Output tab; returns the new consumed length (same contract as
    /// TermPoll).
    static int PubPoll(int consumed, List<string> log) {
        if (!File.Exists(ZanIDE.PubLogPath())) { return consumed; }
        string raw = File.ReadAllText(ZanIDE.PubLogPath());
        if (raw.Length <= consumed) { return consumed; }
        int last = 0 - 1;
        int i = raw.Length - 1;
        while (i >= consumed) {
            if (raw.Substring(i, 1) == "\n") { last = i; i = consumed - 1; }
            i = i - 1;
        }
        if (last < consumed) { return consumed; }
        string chunk = raw.Substring(consumed, last + 1 - consumed);
        List<string> nl = CodeEditor.SplitLines(chunk);
        int k = 0;
        while (k < nl.Count) {
            if (!(k == nl.Count - 1 && nl[k] == "")) { log.Add(nl[k]); }
            k = k + 1;
        }
        return last + 1;
    }

    /// Registers a clickable hit region for a dialog button so the shared
    /// cursor logic shows the hand pointer while hovering it. Dialogs draw
    /// buttons directly on the canvas (not via the Button widget), so they must
    /// opt in explicitly for a consistent hover cursor.
    static void HandRegion(App app, int x, int y, int w, int h) {
        app.hitTester.Register(HitRegion.Create(app.focus.AllocId(), x, y, w, h, 0));
    }

    /// The project's assets directory, where the app icon and bundled static
    /// resources (text, images, data files) live.
    static string AssetsDir(string root) { return root + "/assets"; }

    /// Classifies a resource by extension: 0 image, 1 audio, 2 font, 3 data, 4 other.
    static int ResType(string nm) {
        string lo = SceneDesigner.AsciiLower(nm);
        if (ZanIDE.EndsWith(lo, ".png") || ZanIDE.EndsWith(lo, ".jpg")
            || ZanIDE.EndsWith(lo, ".jpeg") || ZanIDE.EndsWith(lo, ".bmp")
            || ZanIDE.EndsWith(lo, ".gif") || ZanIDE.EndsWith(lo, ".tga")
            || ZanIDE.EndsWith(lo, ".ico")) { return 0; }
        if (ZanIDE.EndsWith(lo, ".wav") || ZanIDE.EndsWith(lo, ".mp3")
            || ZanIDE.EndsWith(lo, ".ogg") || ZanIDE.EndsWith(lo, ".flac")
            || ZanIDE.EndsWith(lo, ".mid")) { return 1; }
        if (ZanIDE.EndsWith(lo, ".ttf") || ZanIDE.EndsWith(lo, ".otf")
            || ZanIDE.EndsWith(lo, ".fnt")) { return 2; }
        if (ZanIDE.EndsWith(lo, ".json") || ZanIDE.EndsWith(lo, ".txt")
            || ZanIDE.EndsWith(lo, ".xml") || ZanIDE.EndsWith(lo, ".csv")
            || ZanIDE.EndsWith(lo, ".ini") || ZanIDE.EndsWith(lo, ".zscene")) { return 3; }
        return 4;
    }

    static string ResTypeLabel(int ty) {
        if (ty == 0) { return ZanIDE.T("IMG", "图片"); }
        if (ty == 1) { return ZanIDE.T("AUD", "音频"); }
        if (ty == 2) { return ZanIDE.T("FONT", "字体"); }
        if (ty == 3) { return ZanIDE.T("DATA", "数据"); }
        return ZanIDE.T("MISC", "其它");
    }

    static int ResTypeColor(Theme t, int ty) {
        if (ty == 0) { return t.success; }
        if (ty == 1) { return t.info; }
        if (ty == 2) { return t.warning; }
        if (ty == 3) { return t.primary; }
        return t.textTertiary;
    }

    /// Linked (referenced-in-place) resources: `link = <path>` lines in zan.proj.
    static List<string> ProjLinks(string root) {
        List<string> outp = new List<string>();
        string proj = root + "/zan.proj";
        if (!File.Exists(proj)) { return outp; }
        List<string> ls = CodeEditor.SplitLines(File.ReadAllText(proj));
        int i = 0;
        while (i < ls.Count) {
            string tr = ZanIDE.TrimLeadSpaces(ls[i]);
            if (tr.Length > 5 && tr.Substring(0, 5) == "link ") {
                string rest = ZanIDE.TrimLeadSpaces(tr.Substring(5, tr.Length - 5));
                if (rest.Length > 1 && rest.Substring(0, 1) == "=") {
                    string val = ZanIDE.TrimLeadSpaces(rest.Substring(1, rest.Length - 1));
                    int e = val.Length;
                    while (e > 0) {
                        string ch = val.Substring(e - 1, 1);
                        if (ch == " " || ch == "\t" || ch == "\r") { e = e - 1; }
                        else { break; }
                    }
                    if (e > 0) { outp.Add(val.Substring(0, e)); }
                }
            }
            i = i + 1;
        }
        return outp;
    }

    static void AddProjLink(string root, string path) {
        string proj = root + "/zan.proj";
        string content = "";
        if (File.Exists(proj)) { content = File.ReadAllText(proj); }
        if (content.Length > 0 && content.Substring(content.Length - 1, 1) != "\n") {
            content = content + "\n";
        }
        File.WriteAllText(proj, content + "link = " + path + "\n");
    }

    static void RemoveProjLink(string root, string path) {
        string proj = root + "/zan.proj";
        if (!File.Exists(proj)) { return; }
        List<string> ls = CodeEditor.SplitLines(File.ReadAllText(proj));
        string outp = "";
        int i = 0;
        while (i < ls.Count) {
            string tr = ZanIDE.TrimLeadSpaces(ls[i]);
            bool drop = false;
            if (tr.Length > 5 && tr.Substring(0, 5) == "link ") {
                if (ZanIDE.ContainsS(tr, path)) { drop = true; }
            }
            if (!drop && tr.Length > 0) { outp = outp + ls[i] + "\n"; }
            i = i + 1;
        }
        File.WriteAllText(proj, outp);
    }

    /// Lists bundled static resources (everything in assets/ except the app icon).
    static List<string> ListResources(string root) {
        List<string> outp = new List<string>();
        string ad = ZanIDE.AssetsDir(root);
        if (!Directory.Exists(ad)) { return outp; }
        List<string> files = Directory.GetFiles(ad);
        int i = 0;
        while (i < files.Count) {
            string nm = Path.GetFileName(files[i]);
            if (nm != "app.ico") { outp.Add(nm); }
            i = i + 1;
        }
        return outp;
    }

    /// Copies the project's bundled resources (assets/, minus app.ico) into an
    /// output directory, so a published program ships with its static files.
    static void CopyResources(string root, string outDir, List<string> log) {
        List<string> res = ZanIDE.ListResources(root);
        List<string> lnks = ZanIDE.ProjLinks(root);
        if (res.Count == 0 && lnks.Count == 0) { return; }
        // Opted-in projects ship one encrypted assets.zrp instead of loose
        // files (toggle in the Asset Manager; opened via generated AssetPack).
        if (AssetManager.PackEnabled(root)) {
            int packed = AssetManager.PackAssets(root, outDir, lnks, log);
            if (packed >= 0) {
                log.Add("> Packed " + Convert.ToString(packed)
                    + " resource file(s) into " + outDir + "/assets/assets.zrp");
                return;
            }
            log.Add("> Falling back to plain resource copy.");
        }
        string dst = outDir + "/assets";
        Directory.CreateDirectoryRecursive(dst);
        string ad = ZanIDE.AssetsDir(root);
        int i = 0;
        while (i < res.Count) {
            File.Copy(ad + "/" + res[i], dst + "/" + res[i]);
            i = i + 1;
        }
        // Asset subfolders (from the Asset Manager) ship recursively too.
        List<string> subs = Directory.GetDirectories(ad);
        int si = 0;
        int scopied = 0;
        while (si < subs.Count) {
            scopied = scopied + AssetManager.copyTree(ad + "/" + subs[si], dst + "/" + subs[si]);
            si = si + 1;
        }
        // Linked resources are referenced in place during development and
        // copied next to the exe only when publishing.
        int li = 0;
        int lcopied = 0;
        while (li < lnks.Count) {
            if (File.Exists(lnks[li])) {
                File.Copy(lnks[li], dst + "/" + Path.GetFileName(lnks[li]));
                lcopied = lcopied + 1;
            } else {
                log.Add("> WARNING: linked resource missing: " + lnks[li]);
            }
            li = li + 1;
        }
        log.Add("> Bundled " + Convert.ToString(res.Count + scopied + lcopied) + " resource file(s) into " + dst);
    }

    // ---- code navigation (go to definition / find references) ----

    static string RTrimS(string s) {
        int e = s.Length;
        while (e > 0) {
            string ch = s.Substring(e - 1, 1);
            if (ch == " " || ch == "\t") { e = e - 1; } else { break; }
        }
        return s.Substring(0, e);
    }

    /// True if `after` begins with `word` followed by a non-identifier char.
    static bool StartsWithWord(string after, string word) {
        int wl = word.Length;
        if (after.Length < wl) { return false; }
        if (after.Substring(0, wl) != word) { return false; }
        if (after.Length == wl) { return true; }
        return !CodeEditor.IsIdentChar(after.Substring(wl, 1));
    }

    /// True if the line declares a type named `word` (class/struct/enum/interface).
    static bool IsTypeDecl(string line, string word) {
        string s = CodeEditor.LTrim(line);
        List<string> kws = new List<string>();
        kws.Add("class "); kws.Add("struct "); kws.Add("enum "); kws.Add("interface ");
        int i = 0;
        while (i < kws.Count) {
            string kw = kws[i];
            if (s.Length >= kw.Length && s.Substring(0, kw.Length) == kw) {
                string after = s.Substring(kw.Length, s.Length - kw.Length);
                if (ZanIDE.StartsWithWord(CodeEditor.LTrim(after), word)) { return true; }
            }
            i = i + 1;
        }
        return false;
    }

    /// Index of a whole-word `word(` occurrence in s, or -1.
    static int FindWordCall(string s, string word) {
        int wl = word.Length;
        if (wl == 0) { return 0 - 1; }
        int i = 0;
        while (i + wl < s.Length) {
            if (s.Substring(i, wl) == word && s.Substring(i + wl, 1) == "(") {
                bool leftOk = true;
                if (i > 0) { leftOk = !CodeEditor.IsIdentChar(s.Substring(i - 1, 1)); }
                if (leftOk) { return i; }
            }
            i = i + 1;
        }
        return 0 - 1;
    }

    /// Heuristic: the line is a method/function definition header for `word`
    /// (a return-type token precedes `word(` and the line opens a block / ends
    /// the signature), as opposed to a call site.
    static bool IsMethodDef(string line, string word) {
        string s = CodeEditor.LTrim(line);
        if (ZanIDE.StartsWithWord(s, "if") || ZanIDE.StartsWithWord(s, "while")
            || ZanIDE.StartsWithWord(s, "for") || ZanIDE.StartsWithWord(s, "foreach")
            || ZanIDE.StartsWithWord(s, "switch") || ZanIDE.StartsWithWord(s, "return")
            || ZanIDE.StartsWithWord(s, "else")) { return false; }
        int pos = ZanIDE.FindWordCall(s, word);
        if (pos <= 0) { return false; }
        if (s.Substring(pos - 1, 1) != " ") { return false; }
        string rt = ZanIDE.RTrimS(s);
        if (rt.Length == 0) { return false; }
        string last = rt.Substring(rt.Length - 1, 1);
        return last == "{" || last == ")";
    }

    /// First line index declaring `word` in `body` (type decls first, then
    /// method definitions), or -1 when not found.
    static int FindDeclLine(string body, string word) {
        List<string> ls = CodeEditor.SplitLines(body);
        int i = 0;
        while (i < ls.Count) {
            if (ZanIDE.IsTypeDecl(ls[i], word)) { return i; }
            i = i + 1;
        }
        int k = 0;
        while (k < ls.Count) {
            if (ZanIDE.IsMethodDef(ls[k], word)) { return k; }
            k = k + 1;
        }
        return 0 - 1;
    }

    /// Net brace-nesting change contributed by one source line, ignoring
    /// braces inside string/char literals or after a `//` line comment.
    static int OutlineBraceDelta(string line) {
        int delta = 0;
        bool inStr = false;
        bool inChar = false;
        int i = 0;
        while (i < line.Length) {
            string ch = line.Substring(i, 1);
            if (inStr) {
                if (ch == "\\") { i = i + 1; }
                else if (ch == "\"") { inStr = false; }
            } else if (inChar) {
                if (ch == "\\") { i = i + 1; }
                else if (ch == "'") { inChar = false; }
            } else {
                if (ch == "/" && i + 1 < line.Length && line.Substring(i + 1, 1) == "/") {
                    return delta;
                } else if (ch == "\"") { inStr = true; }
                else if (ch == "'") { inChar = true; }
                else if (ch == "{") { delta = delta + 1; }
                else if (ch == "}") { delta = delta - 1; }
            }
            i = i + 1;
        }
        return delta;
    }

    /// True when `ch` is an identifier character. Uses a whitelist lookup
    /// rather than string range comparisons, which are unreliable here.
    static bool OutlineIsIdentChar(string ch) {
        string ok = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        return ZanIDE.OutlineFind(ok, ch) >= 0;
    }

    /// Leading identifier of a token ("Foo<T>" -> "Foo", "bar;" -> "bar").
    static string OutlineIdent(string tok) {
        string outp = "";
        int i = 0;
        while (i < tok.Length) {
            string ch = tok.Substring(i, 1);
            if (ZanIDE.OutlineIsIdentChar(ch)) { outp = outp + ch; }
            else { break; }
            i = i + 1;
        }
        return outp;
    }

    /// Index of the first occurrence of single-char `ch` in `s`, or -1.
    static int OutlineFind(string s, string ch) {
        int i = 0;
        while (i < s.Length) {
            if (s.Substring(i, 1) == ch) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    /// The type name declared on `s` (class/struct/enum/interface), or "".
    static string OutlineTypeName(string s) {
        List<string> toks = ZanIDE.SplitSpaces(s);
        int i = 0;
        while (i < toks.Count) {
            string tk = toks[i];
            if (tk == "class" || tk == "struct" || tk == "enum" || tk == "interface") {
                if (i + 1 < toks.Count) { return ZanIDE.OutlineIdent(toks[i + 1]); }
                return "";
            }
            i = i + 1;
        }
        return "";
    }

    /// "Name()" when `s` is a method/ctor definition header, else "".
    static string OutlineMethodName(string s) {
        int paren = ZanIDE.OutlineFind(s, "(");
        if (paren <= 0) { return ""; }
        string header = s.Substring(0, paren);
        if (ZanIDE.OutlineFind(header, "=") >= 0) { return ""; }
        string rt = ZanIDE.RTrimS(s);
        if (rt.Length == 0) { return ""; }
        string last = rt.Substring(rt.Length - 1, 1);
        if (last != "{" && last != ")") { return ""; }
        List<string> toks = ZanIDE.SplitSpaces(header);
        if (toks.Count < 2) { return ""; }
        string name = ZanIDE.OutlineIdent(toks[toks.Count - 1]);
        if (name == "") { return ""; }
        if (name == "if" || name == "while" || name == "for" || name == "foreach"
            || name == "switch" || name == "catch" || name == "lock" || name == "using") {
            return "";
        }
        return name + "()";
    }

    /// The field name when `s` is a field declaration, else "".
    static string OutlineFieldName(string s) {
        string rt = ZanIDE.RTrimS(s);
        if (rt.Length == 0) { return ""; }
        if (rt.Substring(rt.Length - 1, 1) != ";") { return ""; }
        string decl = rt.Substring(0, rt.Length - 1);
        int eq = ZanIDE.OutlineFind(decl, "=");
        if (eq >= 0) { decl = decl.Substring(0, eq); }
        if (ZanIDE.OutlineFind(decl, "(") >= 0) { return ""; }
        List<string> toks = ZanIDE.SplitSpaces(decl);
        if (toks.Count < 2) { return ""; }
        string first = toks[0];
        if (first == "return" || first == "using" || first == "namespace"
            || first == "throw" || first == "break" || first == "continue"
            || first == "case" || first == "default") {
            return "";
        }
        return ZanIDE.OutlineIdent(toks[toks.Count - 1]);
    }

    /// Builds a navigable code-structure outline of a source buffer for the
    /// IDE's STRUCTURE panel: each top-level type becomes an expandable node
    /// whose children are the type's direct methods and fields. Each node's
    /// `path` carries the 0-based line to jump to. Best-effort and brace-depth
    /// driven, so it stays responsive on large files without a full parse.
    static List<TreeNode> BuildOutline(string body) {
        List<TreeNode> outp = new List<TreeNode>();
        List<string> ls = CodeEditor.SplitLines(body);
        int depth = 0;
        int bodyDepth = 0 - 1;
        int i = 0;
        while (i < ls.Count) {
            string raw = ls[i];
            string s = CodeEditor.LTrim(raw);
            int startDepth = depth;
            bool isComment = false;
            if (s.Length >= 1 && s.Substring(0, 1) == "*") { isComment = true; }
            if (s.Length >= 2) {
                string p2 = s.Substring(0, 2);
                if (p2 == "//" || p2 == "/*") { isComment = true; }
            }
            if (!isComment) {
                if (startDepth == 0) {
                    string tn = ZanIDE.OutlineTypeName(s);
                    if (tn != "") {
                        TreeNode n = TreeNode.Dir(tn, 0, true);
                        n.icon = "code";
                        n.path = Convert.ToString(i);
                        outp.Add(n);
                        bodyDepth = 1;
                    }
                } else if (bodyDepth >= 0 && startDepth == bodyDepth) {
                    string mn = ZanIDE.OutlineMethodName(s);
                    if (mn != "") {
                        TreeNode n = TreeNode.FileIcon(mn, 1, "play");
                        n.path = Convert.ToString(i);
                        outp.Add(n);
                    } else {
                        string fn = ZanIDE.OutlineFieldName(s);
                        if (fn != "") {
                            TreeNode n = TreeNode.FileIcon(fn, 1, "minus");
                            n.path = Convert.ToString(i);
                            outp.Add(n);
                        }
                    }
                }
            }
            depth = depth + ZanIDE.OutlineBraceDelta(raw);
            if (depth < 0) { depth = 0; }
            i = i + 1;
        }
        return outp;
    }

    /// A small icon hint for a designer control type.
    static string ComponentIcon(string type) {
        if (type == "Label") { return "font"; }
        if (type == "Button") { return "grid"; }
        if (type == "Input" || type == "TextBox" || type == "TextArea") { return "edit"; }
        if (type == "Checkbox" || type == "Radio" || type == "Switch") { return "check"; }
        if (type == "Image") { return "image"; }
        if (type == "Table" || type == "Grid" || type == "TreeView") { return "table"; }
        return "layout";
    }

    /// Depth-first flattens the designer's (possibly nested) field tree into
    /// `outp`, so tree rows and selections can address fields by flat index.
    static void FlattenFields(List<FormField> fields, List<FormField> outp) {
        int i = 0;
        while (i < fields.Count) {
            outp.Add(fields[i]);
            if (fields[i].IsContainer()) {
                ZanIDE.FlattenFields(fields[i].kids, outp);
            }
            i = i + 1;
        }
    }

    /// Builds the designer component tree from the unified designer's field
    /// model: the form as the root node with each field as a descendant
    /// (label "name : Type", container children indented one level deeper).
    /// A node's `path` carries the field's flat index for click-to-select.
    static List<TreeNode> BuildFieldTree(string formName, List<FormField> fields) {
        List<TreeNode> outp = new List<TreeNode>();
        TreeNode root = TreeNode.Dir(formName, 0, true);
        root.icon = "layout";
        root.path = "@form";
        outp.Add(root);
        List<FormField> flat = new List<FormField>();
        ZanIDE.FlattenFields(fields, flat);
        ZanIDE.AddFieldNodes(outp, fields, flat, 1);
        return outp;
    }

    /// Scene component tree for the sidebar STRUCTURE panel: the scene file as
    /// root, then every element topmost-first. Node paths hold the element's
    /// index into OrderedByZ() so clicks map back to the canvas selection.
    static List<TreeNode> BuildSceneTree(string sceneName, SceneDesigner sd) {
        List<TreeNode> outp = new List<TreeNode>();
        TreeNode root = TreeNode.Dir(sceneName, 0, true);
        root.icon = "layout";
        root.path = "@scene";
        outp.Add(root);
        List<SceneElement> ord = sd.OrderedByZ();
        int i = ord.Count - 1;
        while (i >= 0) {
            SceneElement e = ord[i];
            string nm = SceneDesigner.KindLabel(e.Kind());
            if (e.Name().Length > 0) { nm = nm + " · " + e.Name(); }
            if (e.Locked()) { nm = "◈ " + nm; }
            TreeNode n = TreeNode.FileIcon(nm, 1, "layout");
            n.path = Convert.ToString(i);
            outp.Add(n);
            i = i - 1;
        }
        return outp;
    }

    static void AddFieldNodes(List<TreeNode> outp, List<FormField> fields,
                              List<FormField> flat, int depth) {
        int i = 0;
        while (i < fields.Count) {
            FormField f = fields[i];
            string nm = f.fname;
            if (nm.Length == 0) { nm = f.label; }
            TreeNode n = TreeNode.FileIcon(nm + " : " + FormField.TypeName(f.ftype), depth, "layout");
            int fi = 0;
            while (fi < flat.Count) {
                if (flat[fi] == f) { n.path = Convert.ToString(fi); fi = flat.Count; }
                fi = fi + 1;
            }
            outp.Add(n);
            if (f.IsContainer()) {
                ZanIDE.AddFieldNodes(outp, f.kids, flat, depth + 1);
            }
            i = i + 1;
        }
    }

    /// Parses a decimal line index previously stored in a TreeNode.path by
    /// BuildOutline; returns -1 when the node carries no line.
    static int OutlineLineOf(string path) {
        if (path == "") { return 0 - 1; }
        string digits = "0123456789";
        int val = 0;
        int i = 0;
        while (i < path.Length) {
            string ch = path.Substring(i, 1);
            int d = ZanIDE.OutlineFind(digits, ch);
            if (d < 0) { return 0 - 1; }
            val = val * 10 + d;
            i = i + 1;
        }
        return val;
    }

    /// Loads the project's saved user components (components/*.zcomp) into the
    /// designer's "My Components" palette group.
    static void LoadUserComponents(string root, Designer d) {
        List<string> names = new List<string>();
        List<string> jsons = new List<string>();
        string dir = root + "/components";
        if (Directory.Exists(dir)) {
            List<string> files = Directory.GetFiles(dir);
            int i = 0;
            while (i < files.Count) {
                string nm = files[i];
                if (nm.Length > 6 && nm.Substring(nm.Length - 6, 6) == ".zcomp") {
                    names.Add(nm.Substring(0, nm.Length - 6));
                    jsons.Add(File.ReadAllText(dir + "/" + nm));
                }
                i = i + 1;
            }
        }
        d.SetUserComponents(names, jsons);
    }

    /// Keeps only identifier-safe characters (letters, digits, underscore) of a
    /// display name, for use as a component file / type name.
    static string SanitizeName(string s) {
        string ok = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string r = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            int j = 0;
            while (j < ok.Length) {
                if (ok.Substring(j, 1) == ch) { r = r + ch; j = ok.Length; }
                else { j = j + 1; }
            }
            i = i + 1;
        }
        return r;
    }

    /// Recursively collects every .zan file path under `dir`.
    static List<string> ListZanFiles(string dir) {
        List<string> outp = new List<string>();
        ZanIDE.CollectZan(dir, outp);
        return outp;
    }

    static void CollectZan(string dir, List<string> outp) {
        if (!Directory.Exists(dir)) { return; }
        List<string> files = Directory.GetFiles(dir);
        int i = 0;
        while (i < files.Count) {
            string nm = files[i];
            if (nm.Length > 4 && nm.Substring(nm.Length - 4, 4) == ".zan") {
                outp.Add(dir + "/" + nm);
            } else if (nm.Length > 6 && nm.Substring(nm.Length - 6, 6) == ".zform") {
                outp.Add(dir + "/" + nm);
            }
            i = i + 1;
        }
        List<string> subs = Directory.GetDirectories(dir);
        int j = 0;
        while (j < subs.Count) {
            ZanIDE.CollectZan(dir + "/" + subs[j], outp);
            j = j + 1;
        }
    }

    /// Finds the definition of the symbol under the caret across the current
    /// file, other open tabs, then the project's src tree. Switches/opens the
    /// target tab and returns the destination line (-1 when not found).
    static int GoToDefinition(CodeEditor editor, List<string> tabNames, List<string> tabBodies,
                              List<string> tabPaths, SignalInt active, string root, List<string> log) {
        string word = editor.WordAtCaret();
        if (word == "") { log.Add("> Go to Definition: no symbol under caret."); return 0 - 1; }
        int a = active.Get();
        if (a >= 0 && a < tabBodies.Count) { tabBodies[a] = editor.GetText(); }
        if (a >= 0 && a < tabBodies.Count) {
            int ln = ZanIDE.FindDeclLine(tabBodies[a], word);
            if (ln >= 0) {
                log.Add("> Definition of '" + word + "' at line " + Convert.ToString(ln + 1) + " (this file).");
                return ln;
            }
        }
        int i = 0;
        while (i < tabBodies.Count) {
            if (i != a) {
                int ln = ZanIDE.FindDeclLine(tabBodies[i], word);
                if (ln >= 0) {
                    active.Set(i);
                    log.Add("> Definition of '" + word + "' in " + tabNames[i]
                        + " at line " + Convert.ToString(ln + 1) + ".");
                    return ln;
                }
            }
            i = i + 1;
        }
        List<string> files = ZanIDE.ListZanFiles(root + "/src");
        int fi = 0;
        while (fi < files.Count) {
            string fp = files[fi];
            if (tabPaths.IndexOf(fp) < 0) {
                string body = File.ReadAllText(fp);
                int ln = ZanIDE.FindDeclLine(body, word);
                if (ln >= 0) {
                    ZanIDE.OpenPath(tabNames, tabBodies, tabPaths, active, fp, Path.GetFileName(fp));
                    log.Add("> Definition of '" + word + "' in " + Path.GetFileName(fp)
                        + " at line " + Convert.ToString(ln + 1) + ".");
                    return ln;
                }
            }
            fi = fi + 1;
        }
        log.Add("> Go to Definition: '" + word + "' not found in project.");
        return 0 - 1;
    }

    /// Case-insensitive path equality with slash normalization (Windows
    /// paths mix separators; LSP URIs always use forward slashes).
    static bool SamePath(string a, string b) {
        return ZanIDE.NormPath(a) == ZanIDE.NormPath(b);
    }

    static string NormPath(string p) {
        string o = "";
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "\\") { o = o + "/"; } else { o = o + ch; }
            i = i + 1;
        }
        return ZanIDE.ToLowerS(o);
    }

    /// Go to Definition preferring zan-lsp semantic results (compiler
    /// binder/checker accuracy), with the text-scan heuristic as fallback.
    static int GoToDefinitionSmart(LspSession lsp, CodeEditor editor, List<string> tabNames,
                                   List<string> tabBodies, List<string> tabPaths,
                                   SignalInt active, string root, List<string> log) {
        int a = active.Get();
        if (lsp != null && lsp.Alive() && a >= 0 && a < tabPaths.Count && tabPaths[a].Length > 0) {
            tabBodies[a] = editor.GetText();
            lsp.SyncDoc(tabPaths[a], tabBodies[a]);
            string hit = lsp.Definition(tabPaths[a], editor.CurLine(), editor.CurCol());
            int sep = ZanIDE.IndexOfStr(hit, "\t");
            if (sep > 0) {
                string defPath = hit.Substring(0, sep);
                int ln = ZanIDE.ParseInt(hit.Substring(sep + 1, hit.Length - sep - 1));
                if (ZanIDE.SamePath(defPath, tabPaths[a])) {
                    log.Add("> Definition at line " + Convert.ToString(ln + 1) + " (this file).");
                    return ln;
                }
                int ti = 0;
                while (ti < tabPaths.Count) {
                    if (ZanIDE.SamePath(defPath, tabPaths[ti])) {
                        active.Set(ti);
                        log.Add("> Definition in " + tabNames[ti] + " at line " + Convert.ToString(ln + 1) + ".");
                        return ln;
                    }
                    ti = ti + 1;
                }
                if (File.Exists(defPath)) {
                    ZanIDE.OpenPath(tabNames, tabBodies, tabPaths, active, defPath, Path.GetFileName(defPath));
                    log.Add("> Definition in " + Path.GetFileName(defPath) + " at line " + Convert.ToString(ln + 1) + ".");
                    return ln;
                }
            }
        }
        return ZanIDE.GoToDefinition(editor, tabNames, tabBodies, tabPaths, active, root, log);
    }

    /// Find All References preferring zan-lsp semantic results, with the
    /// whole-word text scan as fallback.
    static void FindReferencesSmart(LspSession lsp, CodeEditor editor, List<string> tabNames,
                                    List<string> tabBodies, List<string> tabPaths,
                                    SignalInt active, string root, List<string> log) {
        int a = active.Get();
        if (lsp != null && lsp.Alive() && a >= 0 && a < tabPaths.Count && tabPaths[a].Length > 0) {
            tabBodies[a] = editor.GetText();
            lsp.SyncDoc(tabPaths[a], tabBodies[a]);
            List<string> rows = lsp.References(tabPaths[a], editor.CurLine(), editor.CurCol());
            if (rows.Count > 0) {
                string word = editor.WordAtCaret();
                log.Add("> References to '" + word + "' (semantic):");
                int i = 0;
                while (i < rows.Count) {
                    int sep = ZanIDE.IndexOfStr(rows[i], "\t");
                    if (sep > 0) {
                        string rp = rows[i].Substring(0, sep);
                        int ln = ZanIDE.ParseInt(rows[i].Substring(sep + 1, rows[i].Length - sep - 1));
                        log.Add("   " + Path.GetFileName(rp) + ":" + Convert.ToString(ln + 1));
                    }
                    i = i + 1;
                }
                log.Add("> " + Convert.ToString(rows.Count) + " reference(s) found.");
                return;
            }
        }
        ZanIDE.FindReferences(editor, tabNames, tabBodies, tabPaths, active, root, log);
    }

    /// Counts whole-word occurrences of `word` in `line`.
    static int CountWord(string line, string word) {
        int wl = word.Length;
        if (wl == 0) { return 0; }
        int count = 0;
        int i = 0;
        while (i + wl <= line.Length) {
            if (line.Substring(i, wl) == word) {
                bool leftOk = true;
                bool rightOk = true;
                if (i > 0) { leftOk = !CodeEditor.IsIdentChar(line.Substring(i - 1, 1)); }
                if (i + wl < line.Length) { rightOk = !CodeEditor.IsIdentChar(line.Substring(i + wl, 1)); }
                if (leftOk && rightOk) { count = count + 1; i = i + wl; }
                else { i = i + 1; }
            } else { i = i + 1; }
        }
        return count;
    }

    static int CountRefsInFile(string name, string body, string word, List<string> log) {
        List<string> ls = CodeEditor.SplitLines(body);
        int count = 0;
        int i = 0;
        while (i < ls.Count) {
            int occ = ZanIDE.CountWord(ls[i], word);
            if (occ > 0) {
                count = count + occ;
                log.Add("   " + name + ":" + Convert.ToString(i + 1) + ": " + CodeEditor.LTrim(ls[i]));
            }
            i = i + 1;
        }
        return count;
    }

    /// Lists every whole-word reference to the symbol under the caret across
    /// open tabs and the project's src tree, into the output log.
    static void FindReferences(CodeEditor editor, List<string> tabNames, List<string> tabBodies,
                               List<string> tabPaths, SignalInt active, string root, List<string> log) {
        string word = editor.WordAtCaret();
        if (word == "") { log.Add("> Find All References: no symbol under caret."); return; }
        int a = active.Get();
        if (a >= 0 && a < tabBodies.Count) { tabBodies[a] = editor.GetText(); }
        log.Add("> References to '" + word + "':");
        int total = 0;
        int i = 0;
        while (i < tabBodies.Count) {
            total = total + ZanIDE.CountRefsInFile(tabNames[i], tabBodies[i], word, log);
            i = i + 1;
        }
        List<string> files = ZanIDE.ListZanFiles(root + "/src");
        int fi = 0;
        while (fi < files.Count) {
            string fp = files[fi];
            if (tabPaths.IndexOf(fp) < 0) {
                string body = File.ReadAllText(fp);
                total = total + ZanIDE.CountRefsInFile(Path.GetFileName(fp), body, word, log);
            }
            fi = fi + 1;
        }
        log.Add("> " + Convert.ToString(total) + " reference(s) found.");
    }

    // ---- designer <-> code (form serialization) ----

    /// Splits a string on runs of spaces/tabs into tokens.
    static List<string> SplitSpaces(string s) {
        List<string> outp = new List<string>();
        string cur = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == " " || ch == "\t") {
                if (cur.Length > 0) { outp.Add(cur); cur = ""; }
            } else { cur = cur + ch; }
            i = i + 1;
        }
        if (cur.Length > 0) { outp.Add(cur); }
        return outp;
    }

    static void AppendAll(List<string> log, List<string> lines) {
        int i = 0;
        while (i < lines.Count) {
            log.Add("  " + lines[i]);
            i = i + 1;
        }
    }

    // ==== C#-style form file model (.zform design file + .zan code-behind) ====

    /// True when the path names a visual form design file (opened in the designer).
    static bool IsFormPath(string p) {
        int n = p.Length;
        if (n < 6) { return false; }
        return p.Substring(n - 6, 6) == ".zform";
    }

    static bool IsScenePath(string p) {
        int n = p.Length;
        if (n < 7) { return false; }
        return p.Substring(n - 7, 7) == ".zscene";
    }

    /// Base name of a .zscene (the scene name), e.g. src/Hud.zscene -> Hud.
    static string SceneBaseName(string p) {
        string fn = Path.GetFileName(p);
        int n = fn.Length;
        if (n >= 7 && fn.Substring(n - 7, 7) == ".zscene") { return fn.Substring(0, n - 7); }
        return fn;
    }

    /// Base name of a .zform (the form/class name), e.g. src/Login.zform -> Login.
    static string FormBaseName(string p) {
        string fn = Path.GetFileName(p);
        int n = fn.Length;
        if (n >= 6 && fn.Substring(n - 6, 6) == ".zform") { return fn.Substring(0, n - 6); }
        return fn;
    }

    /// Code-behind path for a .zform, e.g. src/Login.zform -> src/Login.zan.
    /// Scans a code-behind file for bindable member variables: simple
    /// `type name;` / `type name = ...;` declarations (skipping methods,
    /// comments and the generated designer region). The designer offers the
    /// names in its bind-path picker for two-way binding.
    static List<string> ScanBindVars(string code) {
        List<string> vars = new List<string>();
        List<string> lines = CodeEditor.SplitLines(code);
        bool inRegion = false;
        int i = 0;
        while (i < lines.Count && vars.Count < 60) {
            string ln = ZanIDE.TrimStr(lines[i]);
            i = i + 1;
            if (ZanIDE.Has(ln, "ZAN-DESIGNER BEGIN")) { inRegion = true; }
            if (ZanIDE.Has(ln, "ZAN-DESIGNER END")) { inRegion = false; continue; }
            if (inRegion) { continue; }
            if (ln.Length < 5) { continue; }
            if (ln.Substring(0, 2) == "//") { continue; }
            if (ZanIDE.Has(ln, "(")) { continue; }
            if (ln.Substring(ln.Length - 1, 1) != ";") { continue; }
            string body = ln.Substring(0, ln.Length - 1);
            int eq = ZanIDE.IndexOfStr(body, "=");
            if (eq >= 0) { body = ZanIDE.TrimStr(body.Substring(0, eq)); }
            // Tokenise "type name" (allow static/public prefixes).
            List<string> toks = ZanIDE.SplitWords(body);
            if (toks.Count < 2) { continue; }
            string ty = toks[toks.Count - 2];
            string nm = toks[toks.Count - 1];
            if (!ZanIDE.IsIdent(nm)) { continue; }
            if (ty == "using" || ty == "namespace" || ty == "return" || ty == "new") { continue; }
            bool dup = false;
            int di = 0;
            while (di < vars.Count) { if (vars[di] == nm) { dup = true; } di = di + 1; }
            if (!dup) { vars.Add(nm); }
        }
        return vars;
    }

    static string TrimStr(string s) {
        int a = 0;
        int b = s.Length;
        while (a < b && (s.Substring(a, 1) == " " || s.Substring(a, 1) == "\t")) { a = a + 1; }
        while (b > a && (s.Substring(b - 1, 1) == " " || s.Substring(b - 1, 1) == "\t" || s.Substring(b - 1, 1) == "\r")) { b = b - 1; }
        return s.Substring(a, b - a);
    }

    static int IndexOfStr(string s, string needle) {
        int n = s.Length;
        int m = needle.Length;
        int i = 0;
        while (i + m <= n) {
            if (s.Substring(i, m) == needle) { return i; }
            i = i + 1;
        }
        return -1;
    }

    static List<string> SplitWords(string s) {
        List<string> toks = new List<string>();
        string cur = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == " " || ch == "\t") {
                if (cur != "") { toks.Add(cur); cur = ""; }
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        if (cur != "") { toks.Add(cur); }
        return toks;
    }

    static bool IsIdent(string s) {
        if (s.Length == 0) { return false; }
        string ok = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string digits = "0123456789";
        if (ZanIDE.Has(digits, s.Substring(0, 1))) { return false; }
        int i = 0;
        while (i < s.Length) {
            if (!ZanIDE.Has(ok, s.Substring(i, 1))) { return false; }
            i = i + 1;
        }
        return true;
    }

    static string CodeBehindPath(string formPath) {
        int n = formPath.Length;
        if (n >= 6 && formPath.Substring(n - 6, 6) == ".zform") {
            return formPath.Substring(0, n - 6) + ".zan";
        }
        return formPath + ".zan";
    }

    /// Emits the Zan draw statements for one designed control, used inside the
    /// generated RenderDesign. The y position is offset by the title-bar height
    /// so controls sit in the window's client area.
    /// Emits the draw calls for one control. `sx`/`sy`/`sw`/`sh` are Zan
    /// expressions (absolute window coordinates), so the caller can pass
    /// either literals (free placement) or the dock-layout variables.
    static string EmitControlDraw(string type, string nm, string sx, string sy, string sw, string sh) {
        string s = "        // " + type + " " + nm + "\n";
        if (type == "Label") {
            s = s + "        app.canvas.DrawText(" + sx + ", " + sy + ", \"" + nm + "\", app.theme.textPrimary, app.theme.fontSizeMedium);\n";
        } else if (type == "Button") {
            s = s + "        app.canvas.FillRoundRect(" + sx + ", " + sy + ", " + sw + ", " + sh + ", 4, 0xFF0E639C);\n";
            s = s + "        app.canvas.DrawText(" + sx + " + 10, " + sy + " + 6, \"" + nm + "\", 0xFFFFFFFF, app.theme.fontSizeSmall);\n";
        } else if (type == "TextBox" || type == "RichTextBox") {
            s = s + "        app.canvas.FillRect(" + sx + ", " + sy + ", " + sw + ", " + sh + ", 0xFF1E1E1E);\n";
            s = s + "        app.canvas.DrawRect(" + sx + ", " + sy + ", " + sw + ", " + sh + ", 0xFF555555, 1);\n";
            s = s + "        app.canvas.DrawText(" + sx + " + 6, " + sy + " + 6, \"" + nm + "\", 0xFF888888, app.theme.fontSizeSmall);\n";
        } else if (type == "CheckBox") {
            s = s + "        app.canvas.DrawRect(" + sx + ", " + sy + " + 2, 14, 14, 0xFF888888, 1);\n";
            s = s + "        app.canvas.DrawText(" + sx + " + 20, " + sy + ", \"" + nm + "\", app.theme.textPrimary, app.theme.fontSizeSmall);\n";
        } else if (type == "ProgressBar") {
            s = s + "        app.canvas.DrawRect(" + sx + ", " + sy + ", " + sw + ", " + sh + ", 0xFF555555, 1);\n";
            s = s + "        app.canvas.FillRect(" + sx + " + 2, " + sy + " + 2, (" + sw + " - 4) * 60 / 100, " + sh + " - 4, 0xFF007ACC);\n";
        } else if (type == "Panel" || type == "GroupBox") {
            s = s + "        app.canvas.DrawRect(" + sx + ", " + sy + ", " + sw + ", " + sh + ", 0xFF555555, 1);\n";
            s = s + "        app.canvas.DrawText(" + sx + " + 6, " + sy + " + 4, \"" + nm + "\", app.theme.textSecondary, app.theme.fontSizeSmall);\n";
        } else {
            s = s + "        app.canvas.FillRect(" + sx + ", " + sy + ", " + sw + ", " + sh + ", 0xFF3C3C3C);\n";
            s = s + "        app.canvas.DrawRect(" + sx + ", " + sy + ", " + sw + ", " + sh + ", 0xFF555555, 1);\n";
            s = s + "        app.canvas.DrawText(" + sx + " + 6, " + sy + " + 4, \"" + nm + "\", app.theme.textPrimary, app.theme.fontSizeSmall);\n";
        }
        return s;
    }

    /// True when the .zform body is a designer JSON document (as saved by the
    /// unified form designer) rather than the legacy `control ...` line format.
    static bool LooksLikeJson(string s) {
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch != " " && ch != "\t" && ch != "\n" && ch != "\r") {
                return ch == "{";
            }
            i = i + 1;
        }
        return false;
    }

    /// Maps a legacy .zform control type to the closest form-designer field type.
    static int LegacyFieldType(string ty) {
        if (ty == "Label") { return 16; }
        if (ty == "CheckBox") { return 5; }
        if (ty == "ComboBox") { return 6; }
        if (ty == "ListBox" || ty == "ListView") { return 40; }
        if (ty == "Panel" || ty == "GroupBox") { return 45; }
        if (ty == "TabControl") { return 36; }
        if (ty == "TreeView") { return 25; }
        if (ty == "DataGrid") { return 41; }
        if (ty == "MenuStrip" || ty == "ToolStrip") { return 38; }
        if (ty == "ProgressBar") { return 29; }
        if (ty == "RichTextBox") { return 14; }
        if (ty == "Button") { return 49; }
        return 0;
    }

    /// Converts a legacy coordinate-based .zform file into the form designer's
    /// JSON document so old forms open in the unified designer (each control
    /// becomes a field row; free coordinates are dropped in favour of the
    /// designer's automatic layout).
    static string LegacyFormToJson(string name, string text) {
        string o = "{\n  \"name\": \"" + name + "\",\n  \"fields\": [\n";
        List<string> ls = CodeEditor.SplitLines(text);
        int i = 0;
        while (i < ls.Count) {
            string s = CodeEditor.LTrim(ls[i]);
            if (s.Length > 8 && s.Substring(0, 8) == "control ") {
                List<string> toks = ZanIDE.SplitSpaces(s.Substring(8, s.Length - 8));
                if (toks.Count >= 2) {
                    o = o + "    {\n";
                    o = o + "      \"type\": " + Convert.ToString(ZanIDE.LegacyFieldType(toks[0])) + ",\n";
                    o = o + "      \"label\": \"" + toks[1] + "\",\n";
                    o = o + "      \"name\": \"" + toks[1] + "\",\n";
                    o = o + "      \"options\": []\n";
                    o = o + "    },\n";
                }
            }
            i = i + 1;
        }
        o = o + "  ]\n}\n";
        return o;
    }

    /// Maps a form-designer field type to the legacy draw kind understood by
    /// EmitControlDraw for the generated preview code.
    static string FieldDrawType(int ft) {
        if (ft == 5 || ft == 7) { return "CheckBox"; }
        if (ft == 15 || ft == 16 || ft == 17 || ft == 19) { return "Label"; }
        if (ft == 18 || ft == 45) { return "Panel"; }
        if (ft == 29) { return "ProgressBar"; }
        if (ft == 14) { return "RichTextBox"; }
        if (ft == 49) { return "Button"; }
        return "TextBox";
    }

    /// Emits one label + control-preview row per designer field (recursing into
    /// container children) using a running `fy` so the generated form lays out
    /// vertically like the designer preview.
    static string EmitFieldRows(List<FormField> fields) {
        string o = "";
        int i = 0;
        while (i < fields.Count) {
            FormField f = fields[i];
            string lbl = f.label;
            if (lbl.Length == 0) { lbl = f.fname; }
            o = o + "        app.canvas.DrawText(24, fy, \"" + lbl + "\", app.theme.textSecondary, app.theme.fontSizeSmall);\n";
            o = o + ZanIDE.EmitControlDraw(ZanIDE.FieldDrawType(f.ftype), f.fname, "170", "fy - 6", "280", "30");
            o = o + "        fy = fy + 46;\n";
            if (f.IsContainer()) {
                o = o + ZanIDE.EmitFieldRows(f.kids);
            }
            i = i + 1;
        }
        return o;
    }

    /// Builds the generated designer region of a code-behind from the unified
    /// form designer's field model: a RenderDesign that draws every field row
    /// plus a Main runner sized to the designed window.
    static string FieldsRegion(string name, List<FormField> fields, int fw, int fh) {
        string s = "    // <<< ZAN-DESIGNER BEGIN (generated from " + name + ".zform - do not edit) >>>\n";
        s = s + "    // Generated from the visual design in " + name + ".zform. This whole\n";
        s = s + "    // region is rewritten by the designer - do not edit it; put your own\n";
        s = s + "    // initialization and event logic in OnLoad below.\n";
        s = s + "    static void RenderDesign(App app) {\n";
        s = s + "        int top = app.titlebarH;\n";
        s = s + "        int fy = top + 24;\n";
        if (fields.Count == 0) {
            s = s + "        // (no components yet - add some in the form designer)\n";
        }
        s = s + ZanIDE.EmitFieldRows(fields);
        s = s + "    }\n\n";
        s = s + "    static void Main() {\n";
        s = s + "        App app = App.CreateDark(\"" + name + "\", " + Convert.ToString(fw) + ", " + Convert.ToString(fh) + ");\n";
        s = s + "        app.Show();\n";
        s = s + "        " + name + ".OnLoad(app);\n";
        s = s + "        while (app.isRunning) {\n";
        s = s + "            if (!app.ProcessEvent()) { break; }\n";
        s = s + "            if (!app.needsRedraw) { continue; }\n";
        s = s + "            app.BeginFrame();\n";
        s = s + "            " + name + ".RenderDesign(app);\n";
        s = s + "            app.RenderChrome(\"" + name + "\");\n";
        s = s + "            app.PresentFrame();\n";
        s = s + "        }\n";
        s = s + "    }\n";
        s = s + "    // <<< ZAN-DESIGNER END >>>\n";
        return s;
    }

    /// Replaces the marked designer region of an existing code-behind with
    /// `region`, keeping all user code outside the BEGIN/END markers (returns
    /// the text unchanged when the markers are missing).
    static string ReplaceDesignerRegion(string existing, string region) {
        List<string> ls = CodeEditor.SplitLines(existing);
        int bi = 0 - 1;
        int ei = 0 - 1;
        int i = 0;
        while (i < ls.Count) {
            string tr = CodeEditor.LTrim(ls[i]);
            if (bi < 0 && tr.Length >= 20 && tr.Substring(0, 20) == "// <<< ZAN-DESIGNER B") { bi = i; }
            else if (bi >= 0 && ei < 0 && tr.Length >= 20 && tr.Substring(0, 20) == "// <<< ZAN-DESIGNER E") { ei = i; }
            i = i + 1;
        }
        if (bi < 0 || ei < 0 || ei < bi) { return existing; }
        string outp = "";
        i = 0;
        while (i < bi) { outp = outp + ls[i] + "\n"; i = i + 1; }
        outp = outp + region;
        i = ei + 1;
        while (i < ls.Count) { outp = outp + ls[i] + "\n"; i = i + 1; }
        return outp;
    }

    /// A fresh code-behind file around an already-built designer region.
    static string CodeBehindShell(string name, string region) {
        string s = "using System;\n";
        s = s + "using Gui;\n\n";
        s = s + "// Code-behind for " + name + ".zform.\n";
        s = s + "// The window is designed visually in " + name + ".zform. The region\n";
        s = s + "// between the ZAN-DESIGNER markers is generated from it - do not edit it;\n";
        s = s + "// write your initialization and event logic in OnLoad.\n";
        s = s + "class " + name + " {\n";
        s = s + region;
        s = s + "\n";
        s = s + "    // Runs once after the window opens. Put your logic here.\n";
        s = s + "    static void OnLoad(App app) {\n";
        s = s + "    }\n";
        s = s + "}\n";
        return s;
    }

    // ---- dialog rendering ----

    // ================================================================
    // Settings persistence (window + panel sizes)
    // ================================================================

    static string CfgPath() { return ZanIDE.UserConfigDir() + "/config.cfg"; }

    static bool IsDigit(string ch) {
        return ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4"
            || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9";
    }

    /// Finds the first index of `sub` in `s`, or -1.
    static int StrFind(string s, string sub) {
        if (sub.Length == 0) { return 0; }
        if (sub.Length > s.Length) { return -1; }
        int n = s.Length - sub.Length;
        int i = 0;
        while (i <= n) {
            if (s.Substring(i, sub.Length) == sub) { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// The file name portion of a path (after the last '/' or '\').
    static string BaseName(string p) {
        int best = -1;
        int i = 0;
        while (i < p.Length) {
            string ch = p.Substring(i, 1);
            if (ch == "/" || ch == "\\") { best = i; }
            i = i + 1;
        }
        if (best >= 0 && best + 1 <= p.Length) { return p.Substring(best + 1, p.Length - best - 1); }
        return p;
    }

    /// Reads an integer "key=NNN" from a settings blob, or `def` when absent.
    static int CfgInt(string cfg, string key, int def) {
        int idx = ZanIDE.StrFind(cfg, key + "=");
        if (idx < 0) { return def; }
        int p = idx + key.Length + 1;
        string num = "";
        while (p < cfg.Length) {
            string ch = cfg.Substring(p, 1);
            if (ZanIDE.IsDigit(ch)) { num = num + ch; p = p + 1; } else { break; }
        }
        if (num.Length == 0) { return def; }
        return ZanIDE.ParseInt(num);
    }

    /// Clamps a restored dimension into a sane range.
    static int CfgClamp(int v, int lo, int hi) {
        if (v < lo) { return lo; }
        if (v > hi) { return hi; }
        return v;
    }

    /// A shell panel surface. Under a frosted-glass skin it frosts the themed
    /// backdrop (Layer.GlassFill) so the IDE reads as glass exactly like the
    /// gallery; otherwise a solid themed fill. Use for the IDE's structural
    /// panels (sidebar, tab strip, bottom panel) so all skins render alike.
    static void ShellSurface(App app, int x, int y, int w, int h, int radius, int color) {
        Theme t = app.theme;
        if (t.glass != 0) {
            Layer.GlassFill(app, x, y, w, h, radius, color, 1000);
        } else if (radius > 0) {
            app.canvas.FillRoundRect(x, y, w, h, radius, color);
        } else {
            app.canvas.FillRect(x, y, w, h, color);
        }
    }

    /// A small themed text-field surface (bg + hairline border) for the IDE's
    /// inline input boxes, so they follow the active skin instead of a hardcoded
    /// VS-dark box.
    static void ShellField(App app, int x, int y, int w, int h) {
        Theme t = app.theme;
        app.canvas.FillRect(x, y, w, h, t.bgPrimary);
        app.canvas.DrawRect(x, y, w, h, t.borderPrimary, 1);
    }

    static void SaveSettings(int treeW, int botH, int winW, int winH, int botTab, int autoRun, int skin, int rightW, int rightTab, int opacity) {
        string s = "treeW=" + Convert.ToString(treeW)
            + ";bottomH=" + Convert.ToString(botH)
            + ";winW=" + Convert.ToString(winW)
            + ";winH=" + Convert.ToString(winH)
            + ";bottomTab=" + Convert.ToString(botTab)
            + ";autoRun=" + Convert.ToString(autoRun)
            + ";skin=" + Convert.ToString(skin)
            + ";rightW=" + Convert.ToString(rightW)
            + ";rightTab=" + Convert.ToString(rightTab)
            + ";opacity=" + Convert.ToString(opacity) + ";";
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.CfgPath(), s);
    }

    /// Index of the open tab whose file name matches `base`, or -1.
    static int FindTabByBase(List<string> tabPaths, string bn) {
        int i = 0;
        while (i < tabPaths.Count) {
            if (ZanIDE.BaseName(tabPaths[i]) == bn) { return i; }
            i = i + 1;
        }
        return -1;
    }

    // ================================================================
    // Error list (parsed from build/run output) + tabbed bottom panel
    // ================================================================

    /// Scans the log for compiler/linker diagnostics of the form
    /// `...<file>.zan:<line>[:col]: ... message`, filling parallel lists.
    static void ParseErrorList(List<string> log, List<string> outPath,
            List<string> outLine, List<string> outMsg) {
        int i = 0;
        while (i < log.Count) {
            string ln = log[i];
            int idx = ZanIDE.StrFind(ln, ".zan:");
            if (idx >= 0) {
                // path: from first non-prefix char up to and including ".zan"
                int ps = 0;
                while (ps < ln.Length) {
                    string pc = ln.Substring(ps, 1);
                    if (pc == " " || pc == ">" || pc == "\t") { ps = ps + 1; } else { break; }
                }
                string path = ln.Substring(ps, (idx + 4) - ps);
                int p = idx + 5;
                string num = "";
                while (p < ln.Length) {
                    string ch = ln.Substring(p, 1);
                    if (ZanIDE.IsDigit(ch)) { num = num + ch; p = p + 1; } else { break; }
                }
                if (num.Length > 0) {
                    string msg = ln;
                    int me = ZanIDE.StrFind(ln, "error");
                    if (me < 0) { me = ZanIDE.StrFind(ln, "warning"); }
                    if (me >= 0) { msg = ln.Substring(me, ln.Length - me); }
                    outPath.Add(path);
                    outLine.Add(num);
                    outMsg.Add(msg);
                }
            }
            i = i + 1;
        }
    }

    static string DiagnosticName(string msg) {
        int first = ZanIDE.StrFind(msg, "'");
        if (first < 0) { return ""; }
        int rest = first + 1;
        int secondRel = ZanIDE.StrFind(
            msg.Substring(rest, msg.Length - rest), "'");
        if (secondRel < 0) { return ""; }
        return msg.Substring(rest, secondRel);
    }

    static string SuggestedUsing(string msg) {
        string name = ZanIDE.DiagnosticName(msg);
        string widgets = "|Alert|Avatar|Badge|Breadcrumb|Button|Card|Carousel|Chart|"
            + "Checkbox|CodeEditor|Collapse|DataTable|Dialog|Divider|Drawer|Dropdown|"
            + "Ellipsis|Empty|FilePicker|FloatButton|Input|Label|ListView|Loading|"
            + "Menu|Message|Modal|Notification|PageHeader|Pagination|Panel|PivotTable|"
            + "Popconfirm|Popover|Progress|Radio|Rate|Result|Ribbon|Scrollbar|Select|"
            + "Skeleton|Slider|Spin|Split|Statistic|Steps|Switch|Table|Tabs|TabView|"
            + "Tag|Timeline|Tooltip|TreeView|Typography|Wizard|";
        string gui = "|App|Canvas|Theme|Window|Rect|Color|SignalBool|SignalInt|"
            + "SignalString|HitRegion|TreeNode|Icon|Clipboard|Ui|Stack|Text|Point|"
            + "Size|FlexStyle|FocusManager|";
        string io = "|File|Directory|Path|";
        string system = "|Console|Convert|List|StringBuilder|";
        string text = "|Encoding|";
        string threading = "|Thread|Mutex|Semaphore|Stopwatch|Channel|AtomicInt|";
        string http = "|HttpClient|HttpRequest|HttpResponse|HttpServer|HttpRouter|";
        string sockets = "|Socket|TcpClient|UdpClient|TcpListener|AsyncSocket|";
        string net = "|Dns|IPAddress|";
        string json = "|JsonParser|JsonBuilder|";
        string drawing = "|Graphics|Bitmap|Font|Rectangle|";
        string crypto = "|Sha1|Sha256|Sha512|Md5|Hmac|Aes|AesGcm|Rsa|Base64|Hex|"
            + "RandomNumberGenerator|BigInt|";
        string data = "|DbConnection|DbResult|";
        if (name != "" && ZanIDE.Has(widgets, "|" + name + "|")) {
            return "Gui.Widget";
        }
        if (name != "" && ZanIDE.Has(gui, "|" + name + "|")) {
            return "Gui";
        }
        if (name != "" && ZanIDE.Has(io, "|" + name + "|")) {
            return "System.IO";
        }
        if (name != "" && ZanIDE.Has(system, "|" + name + "|")) {
            return "System";
        }
        if (name != "" && ZanIDE.Has(text, "|" + name + "|")) {
            return "System.Text";
        }
        if (name != "" && ZanIDE.Has(threading, "|" + name + "|")) {
            return "System.Threading";
        }
        if (name != "" && ZanIDE.Has(http, "|" + name + "|")) {
            return "System.Net.Http";
        }
        if (name != "" && ZanIDE.Has(sockets, "|" + name + "|")) {
            return "System.Net.Sockets";
        }
        if (name != "" && ZanIDE.Has(net, "|" + name + "|")) {
            return "System.Net";
        }
        if (name != "" && ZanIDE.Has(json, "|" + name + "|")) {
            return "System.Json";
        }
        if (name != "" && ZanIDE.Has(drawing, "|" + name + "|")) {
            return "System.Drawing";
        }
        if (name != "" && ZanIDE.Has(crypto, "|" + name + "|")) {
            return "System.Security.Cryptography";
        }
        if (name != "" && ZanIDE.Has(data, "|" + name + "|")) {
            return "System.Data";
        }
        if (name == "Process") { return "System.Diagnostics"; }
        return "";
    }

    static void AddUsing(
        CodeEditor editor,
        List<string> bodies,
        SignalInt active,
        string importNs,
        List<string> log
    ) {
        string line = "using " + importNs + ";";
        string text = editor.GetText();
        if (ZanIDE.Has(text, line)) {
            log.Add("> " + line + " is already present.");
            return;
        }
        text = line + "\n" + text;
        editor.LoadText(text);
        int a = active.Get();
        if (a >= 0 && a < bodies.Count) { bodies[a] = text; }
        editor.SetCompilerDiagnostics(
            new List<int>(), new List<string>());
        log.Add("> Added " + line);
    }

    /// The Output panel's "Clear" button rect, right-aligned in the tab strip.
    /// Shared by the renderer (draw) and the caller (hit-test) so they agree.
    static Rect OutClearRect(App app, Rect orr) {
        int tabH = app.theme.heightMedium;
        int bw = app.Scale(52);
        int bh = tabH - app.Scale(8);
        int bx = orr.x + orr.width - bw - app.Scale(8);
        int by = orr.y + app.Scale(4);
        return Rect.Create(bx, by, bw, bh);
    }

    /// The Output panel's filter box rect, left of the Clear button.
    static Rect OutFilterRect(App app, Rect orr) {
        int tabH = app.theme.heightMedium;
        Rect cb = ZanIDE.OutClearRect(app, orr);
        int fw = app.Scale(160);
        int fh = tabH - app.Scale(8);
        int fx = cb.x - fw - app.Scale(6);
        int fy = orr.y + app.Scale(4);
        return Rect.Create(fx, fy, fw, fh);
    }

    // ================================================================
    // Right side panel: AI assistant + integrated terminal
    // ================================================================

    /// Optional AI settings file (`key = value` lines: key / base / model).
    /// Environment variables OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL
    /// are the fallback so the panel works with a plain OpenAI-compatible setup.
    static string AiCfgPath() { return ZanIDE.UserConfigDir() + "/ai.cfg"; }
    static string AiReqPath() { return ZanIDE.UserConfigDir() + "/ai_req.json"; }
    static string AiRespPath() { return ZanIDE.UserConfigDir() + "/ai_resp.json"; }
    static string AiDonePath() { return ZanIDE.UserConfigDir() + "/ai_done.txt"; }

    /// Reads `key = value` from `content` (same line format as zan.proj).
    static string KvField(string content, string key) {
        List<string> ls = CodeEditor.SplitLines(content);
        int i = 0;
        while (i < ls.Count) {
            string tr = ZanIDE.TrimLeadSpaces(ls[i]);
            if (tr.Length >= key.Length && tr.Substring(0, key.Length) == key) {
                string rest = ZanIDE.TrimLeadSpaces(tr.Substring(key.Length, tr.Length - key.Length));
                if (rest.Length > 0 && rest.Substring(0, 1) == "=") {
                    string val = ZanIDE.TrimLeadSpaces(rest.Substring(1, rest.Length - 1));
                    int e = val.Length;
                    while (e > 0) {
                        string ch = val.Substring(e - 1, 1);
                        if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") { e = e - 1; }
                        else { break; }
                    }
                    return val.Substring(0, e);
                }
            }
            i = i + 1;
        }
        return "";
    }

    /// An AI setting: ai.cfg first, then the environment, then `def`.
    static string AiSetting(string key, string envName, string def) {
        if (File.Exists(ZanIDE.AiCfgPath())) {
            string v = ZanIDE.KvField(File.ReadAllText(ZanIDE.AiCfgPath()), key);
            if (v != "") { return v; }
        }
        string e = getenv(envName);
        if (e != null && e != "") { return e; }
        return def;
    }

    // ---- AI provider profiles (ai_profiles.json) ----
    // {"active": 0, "profiles": [{"name", "base", "key", "model", "models": []}]}
    static string AiProfilesPath() { return ZanIDE.UserConfigDir() + "/ai_profiles.json"; }
    static string AiModelsRespPath() { return ZanIDE.UserConfigDir() + "/ai_models.json"; }
    static string AiModelsDonePath() { return ZanIDE.UserConfigDir() + "/ai_models_done.txt"; }
    static string AiPredReqPath() { return ZanIDE.UserConfigDir() + "/ai_pred_req.json"; }
    static string AiPredRespPath() { return ZanIDE.UserConfigDir() + "/ai_pred.json"; }
    static string AiPredDonePath() { return ZanIDE.UserConfigDir() + "/ai_pred_done.txt"; }

    /// Loads the AI provider profiles into the parallel lists and returns the
    /// active index. Falls back to a single profile synthesized from the
    /// legacy ai.cfg / environment settings when ai_profiles.json is missing.
    static int AiProfilesLoad(List<string> names, List<string> bases,
            List<string> keys, List<string> models, List<string> lists) {
        int active = 0;
        if (File.Exists(ZanIDE.AiProfilesPath())) {
            JsonValue v = JsonValue.Parse(File.ReadAllText(ZanIDE.AiProfilesPath()));
            if (v != null) {
                active = v.Int("active", 0);
                JsonValue ps = v.Get("profiles");
                if (ps != null && ps.IsArray()) {
                    int i = 0;
                    while (i < ps.Count()) {
                        JsonValue p = ps.At(i);
                        names.Add(p.Str("name", "AI " + Convert.ToString(i + 1)));
                        bases.Add(p.Str("base", ""));
                        keys.Add(p.Str("key", ""));
                        models.Add(p.Str("model", ""));
                        string ml = "";
                        JsonValue ms = p.Get("models");
                        if (ms != null && ms.IsArray()) {
                            int j = 0;
                            while (j < ms.Count()) {
                                string mid = ms.At(j).AsString("");
                                if (mid != "") {
                                    if (ml != "") { ml = ml + ";"; }
                                    ml = ml + mid;
                                }
                                j = j + 1;
                            }
                        }
                        lists.Add(ml);
                        i = i + 1;
                    }
                }
            }
        }
        if (names.Count == 0) {
            names.Add(ZanIDE.T("Default", "默认"));
            bases.Add(ZanIDE.AiSetting("base", "OPENAI_BASE_URL", "https://api.openai.com/v1"));
            keys.Add(ZanIDE.AiSetting("key", "OPENAI_API_KEY", ""));
            models.Add(ZanIDE.AiSetting("model", "OPENAI_MODEL", "gpt-4o-mini"));
            lists.Add("");
            active = 0;
        }
        if (active < 0 || active >= names.Count) { active = 0; }
        return active;
    }

    static void AiProfilesSave(int active, List<string> names, List<string> bases,
            List<string> keys, List<string> models, List<string> lists) {
        StringBuilder sb = new StringBuilder();
        sb.Append("{\"active\": " + Convert.ToString(active) + ", \"profiles\": [");
        int i = 0;
        while (i < names.Count) {
            if (i > 0) { sb.Append(", "); }
            sb.Append("{\"name\": \"" + ZanIDE.JsonEsc(names[i]) + "\"");
            sb.Append(", \"base\": \"" + ZanIDE.JsonEsc(bases[i]) + "\"");
            sb.Append(", \"key\": \"" + ZanIDE.JsonEsc(keys[i]) + "\"");
            sb.Append(", \"model\": \"" + ZanIDE.JsonEsc(models[i]) + "\"");
            sb.Append(", \"models\": [");
            List<string> ms = ZanIDE.SplitList(lists[i]);
            int j = 0;
            while (j < ms.Count) {
                if (j > 0) { sb.Append(", "); }
                sb.Append("\"" + ZanIDE.JsonEsc(ms[j]) + "\"");
                j = j + 1;
            }
            sb.Append("]}");
            i = i + 1;
        }
        sb.Append("]}");
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.AiProfilesPath(), sb.ToString());
    }

    /// Splits a `;`-separated list, skipping empty entries.
    static List<string> SplitList(string s) {
        List<string> outp = new List<string>();
        string cur = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == ";") {
                if (cur != "") { outp.Add(cur); }
                cur = "";
            } else {
                cur = cur + ch;
            }
            i = i + 1;
        }
        if (cur != "") { outp.Add(cur); }
        return outp;
    }

    /// Launches a detached `GET {base}/models` request. The response and its
    /// done-marker land in the user config dir and are polled by the UI.
    /// Returns "" on success or a user-facing error message.
    static string AiFetchModels(string baseUrl, string key) {
        if (key == "") {
            return ZanIDE.T("Set the API key first.", "请先填写 API 密钥。");
        }
        if (baseUrl == "") { baseUrl = "https://api.openai.com/v1"; }
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        if (File.Exists(ZanIDE.AiModelsRespPath())) { File.Delete(ZanIDE.AiModelsRespPath()); }
        if (File.Exists(ZanIDE.AiModelsDonePath())) { File.Delete(ZanIDE.AiModelsDonePath()); }
        string cmd = "curl -s --max-time 60 \"" + baseUrl + "/models\""
            + " -H \"Authorization: Bearer " + key + "\""
            + " -o \"" + ZanIDE.AiModelsRespPath() + "\"";
        #if WINDOWS
        Process.RunDetached("(" + cmd + ") & echo ok > \"" + ZanIDE.AiModelsDonePath() + "\"");
        #else
        Process.RunDetached("(" + cmd + ") ; echo ok > \"" + ZanIDE.AiModelsDonePath() + "\"");
        #endif
        return "";
    }

    /// Parses the /models response into a `;`-joined id list ("" on failure).
    static string AiReadModels() {
        if (!File.Exists(ZanIDE.AiModelsRespPath())) { return ""; }
        string raw = File.ReadAllText(ZanIDE.AiModelsRespPath());
        if (raw == "") { return ""; }
        JsonValue v = JsonValue.Parse(raw);
        if (v == null) { return ""; }
        JsonValue data = v.Get("data");
        string outp = "";
        if (data != null && data.IsArray()) {
            int i = 0;
            while (i < data.Count()) {
                string id = data.At(i).Str("id", "");
                if (id != "") {
                    if (outp != "") { outp = outp + ";"; }
                    outp = outp + id;
                }
                i = i + 1;
            }
        }
        return outp;
    }

    /// Asks the model to continue the code exactly at the caret: the file is
    /// sent split around a <CURSOR> marker and the model must reply with only
    /// the code to insert there. Detached like AiLaunch; returns "" or error.
    static string AiLaunchPredict(string fileName, string code, int caretLine,
            string baseUrl, string key, string model) {
        if (key == "") {
            return ZanIDE.T(
                "No API key. Open the AI panel's Config editor and fill in the key for the enabled profile.",
                "未配置 API 密钥。请在 AI 面板的“配置”中为启用的配置填写密钥。");
        }
        if (baseUrl == "") { baseUrl = "https://api.openai.com/v1"; }
        if (model == "") { model = "gpt-4o-mini"; }
        // Split around the caret line so the marker lands where the insert
        // happens; keep a bounded window on both sides.
        List<string> lines = CodeEditor.SplitLines(code);
        string before = "";
        string after = "";
        int i = 0;
        while (i < lines.Count) {
            if (i <= caretLine) { before = before + lines[i] + "\n"; }
            else { after = after + lines[i] + "\n"; }
            i = i + 1;
        }
        if (before.Length > 6000) { before = before.Substring(before.Length - 6000, 6000); }
        if (after.Length > 2000) { after = after.Substring(0, 2000); }
        string sysMsg = "You are the inline code completion engine of Zan IDE"
            + " (Zan programming language). The user's file " + fileName
            + " is given with a <CURSOR> marker. Reply with ONLY the code to"
            + " insert at the marker: no explanations, no markdown fences.";
        StringBuilder body = new StringBuilder();
        body.Append("{\"model\":\"" + ZanIDE.JsonEsc(model) + "\",\"messages\":[");
        body.Append("{\"role\":\"system\",\"content\":\"" + ZanIDE.JsonEsc(sysMsg) + "\"},");
        body.Append("{\"role\":\"user\",\"content\":\""
            + ZanIDE.JsonEsc(before + "<CURSOR>" + after) + "\"}");
        body.Append("]}");
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.AiPredReqPath(), body.ToString());
        if (File.Exists(ZanIDE.AiPredRespPath())) { File.Delete(ZanIDE.AiPredRespPath()); }
        if (File.Exists(ZanIDE.AiPredDonePath())) { File.Delete(ZanIDE.AiPredDonePath()); }
        string cmd = "curl -s --max-time 120 \"" + baseUrl + "/chat/completions\""
            + " -H \"Content-Type: application/json\""
            + " -H \"Authorization: Bearer " + key + "\""
            + " --data-binary @\"" + ZanIDE.AiPredReqPath() + "\""
            + " -o \"" + ZanIDE.AiPredRespPath() + "\"";
        #if WINDOWS
        Process.RunDetached("(" + cmd + ") & echo ok > \"" + ZanIDE.AiPredDonePath() + "\"");
        #else
        Process.RunDetached("(" + cmd + ") ; echo ok > \"" + ZanIDE.AiPredDonePath() + "\"");
        #endif
        return "";
    }

    /// Strips a surrounding ``` fence (with optional language tag) from `s`,
    /// and returns "" for error replies so they are never inserted as code.
    static string AiStripFence(string s) {
        if (s.Length >= 7 && s.Substring(0, 7) == "[error]") { return ""; }
        string r = s;
        if (r.Length >= 3 && r.Substring(0, 3) == "```") {
            int nl = 0;
            while (nl < r.Length && r.Substring(nl, 1) != "\n") { nl = nl + 1; }
            if (nl < r.Length) { r = r.Substring(nl + 1, r.Length - nl - 1); }
            else { r = ""; }
            int endF = r.Length - 1;
            while (endF >= 0 && (r.Substring(endF, 1) == "\n" || r.Substring(endF, 1) == " ")) {
                endF = endF - 1;
            }
            if (endF >= 2 && r.Substring(endF - 2, 3) == "```") {
                r = r.Substring(0, endF - 2);
            }
        }
        return r;
    }

    /// Escapes a string for embedding in a JSON string literal.
    static string JsonEsc(string s) {
        StringBuilder sb = new StringBuilder();
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\\") { sb.Append("\\\\"); }
            else if (ch == "\"") { sb.Append("\\\""); }
            else if (ch == "\n") { sb.Append("\\n"); }
            else if (ch == "\r") { }
            else if (ch == "\t") { sb.Append("\\t"); }
            else { sb.Append(ch); }
            i = i + 1;
        }
        return sb.ToString();
    }

    /// Writes the chat transcript as an OpenAI-compatible /chat/completions
    /// request and launches curl DETACHED (response + done-marker files are
    /// polled from the event loop, so the UI stays responsive). Returns "" on
    /// success or a user-facing error message.
    /// The content of the last ``` fenced code block in the newest assistant
    /// reply, or "" when there is none.
    static string AiLastCode(List<string> roles, List<string> texts) {
        int i = roles.Count - 1;
        while (i >= 0) {
            if (roles[i] == "assistant") {
                string s = texts[i];
                int a = ZanIDE.IndexOfStr(s, "```");
                if (a < 0) { return ""; }
                int ls = a + 3;
                while (ls < s.Length && s.Substring(ls, 1) != "\n") { ls = ls + 1; }
                ls = ls + 1;
                if (ls >= s.Length) { return ""; }
                string rest = s.Substring(ls, s.Length - ls);
                int b = ZanIDE.IndexOfStr(rest, "```");
                if (b <= 0) { return ""; }
                return rest.Substring(0, b);
            }
            i = i - 1;
        }
        return "";
    }

    static string AiLaunch(List<string> roles, List<string> texts,
            string ctxName, string ctxCode, string projRoot,
            string baseUrl, string key, string model) {
        if (key == "") {
            return ZanIDE.T(
                "No API key. Open the AI panel's Config editor and fill in the key for the enabled profile.",
                "未配置 API 密钥。请在 AI 面板的“配置”中为启用的配置填写密钥。");
        }
        if (baseUrl == "") { baseUrl = "https://api.openai.com/v1"; }
        if (model == "") { model = "gpt-4o-mini"; }
        StringBuilder body = new StringBuilder();
        body.Append("{\"model\":\"" + ZanIDE.JsonEsc(model) + "\",\"messages\":[");
        string sysMsg = "You are the AI assistant built into Zan IDE, the IDE of the Zan programming language."
            + " Help the user develop their project: answer concisely, in the user's language,"
            + " and include Zan code snippets when helpful.";
        if (ctxName != "") {
            string ctx = ctxCode;
            if (ctx.Length > 6000) { ctx = ctx.Substring(0, 6000); }
            sysMsg = sysMsg + " The user is currently editing " + ctxName
                + ". Its current content:\n" + ctx;
        }
        // Attach the RepoMap outline (whole-codebase structure) when the tool
        // has been run for this project, so the AI can reason across files.
        if (projRoot != "") {
            string mapPath = projRoot + "/.zanmap/repo.map.txt";
            if (File.Exists(mapPath)) {
                string rm = File.ReadAllText(mapPath);
                if (rm.Length > 8000) { rm = rm.Substring(0, 8000); }
                sysMsg = sysMsg + "\n\nProject structure (RepoMap outline of the"
                    + " whole codebase -- files, classes and method signatures):\n" + rm;
            }
        }
        body.Append("{\"role\":\"system\",\"content\":\"" + ZanIDE.JsonEsc(sysMsg) + "\"}");
        int i = 0;
        while (i < roles.Count) {
            if (roles[i] == "user" || roles[i] == "assistant") {
                body.Append(",{\"role\":\"" + roles[i] + "\",\"content\":\""
                    + ZanIDE.JsonEsc(texts[i]) + "\"}");
            }
            i = i + 1;
        }
        body.Append("]}");
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.AiReqPath(), body.ToString());
        if (File.Exists(ZanIDE.AiRespPath())) { File.Delete(ZanIDE.AiRespPath()); }
        if (File.Exists(ZanIDE.AiDonePath())) { File.Delete(ZanIDE.AiDonePath()); }
        string cmd = "curl -s --max-time 180 \"" + baseUrl + "/chat/completions\""
            + " -H \"Content-Type: application/json\""
            + " -H \"Authorization: Bearer " + key + "\""
            + " --data-binary @\"" + ZanIDE.AiReqPath() + "\""
            + " -o \"" + ZanIDE.AiRespPath() + "\"";
        #if WINDOWS
        Process.RunDetached("(" + cmd + ") & echo ok > \"" + ZanIDE.AiDonePath() + "\"");
        #else
        Process.RunDetached("(" + cmd + ") ; echo ok > \"" + ZanIDE.AiDonePath() + "\"");
        #endif
        return "";
    }

    /// Extracts the assistant reply (or a readable error) from the response.
    static string AiReadAnswer() {
        return ZanIDE.AiReadAnswerFrom(ZanIDE.AiRespPath());
    }

    static string AiReadAnswerFrom(string path) {
        if (!File.Exists(path)) {
            return ZanIDE.T("[error] No response received (network problem?).",
                "[错误] 未收到响应（网络问题？）。");
        }
        string raw = File.ReadAllText(path);
        if (raw == "") {
            return ZanIDE.T("[error] Empty response from the AI endpoint.",
                "[错误] AI 服务返回为空。");
        }
        JsonValue v = JsonValue.Parse(raw);
        JsonValue ch = v.Get("choices");
        if (ch != null && ch.IsArray() && ch.Count() > 0) {
            JsonValue msg = ch.At(0).Get("message");
            if (msg != null) { return msg.Str("content", ""); }
        }
        JsonValue err = v.Get("error");
        if (err != null) { return "[error] " + err.Str("message", raw); }
        if (raw.Length > 400) { raw = raw.Substring(0, 400) + "..."; }
        return "[error] " + raw;
    }

    /// Runs a shell command in the project root, appending its output to the
    /// terminal history (capped so the transcript can't grow without bound).
    static string TermLogPath() { return ZanIDE.UserConfigDir() + "/term_session.log"; }

    /// Starts the persistent interactive shell session rooted at the project
    /// directory. The session's stdin is the returned pipe; stdout/stderr
    /// stream into the session log file, which the UI polls each frame.
    static int TermOpen(string root) {
        Directory.CreateDirectoryRecursive(ZanIDE.UserConfigDir());
        File.WriteAllText(ZanIDE.TermLogPath(), "");
        #if WINDOWS
        string cmd = "cmd /q /k cd /d \"" + root + "\" >>\"" + ZanIDE.TermLogPath() + "\" 2>&1";
        #else
        string cmd = "cd \"" + root + "\" && exec sh >>\"" + ZanIDE.TermLogPath() + "\" 2>&1";
        #endif
        return Process.ShellOpen(cmd);
    }

    /// Appends any new complete lines from the session log to the terminal
    /// view. Returns the new consumed length (only whole lines are consumed,
    /// so a partially-written line is picked up on a later poll).
    static int TermPoll(int consumed, List<string> termLog) {
        if (!File.Exists(ZanIDE.TermLogPath())) { return consumed; }
        string raw = File.ReadAllText(ZanIDE.TermLogPath());
        if (raw.Length <= consumed) { return consumed; }
        // Consume up to the last newline only.
        int last = 0 - 1;
        int i = raw.Length - 1;
        while (i >= consumed) {
            if (raw.Substring(i, 1) == "\n") { last = i; i = consumed - 1; }
            i = i - 1;
        }
        if (last < consumed) { return consumed; }
        string chunk = raw.Substring(consumed, last + 1 - consumed);
        List<string> nl = CodeEditor.SplitLines(chunk);
        int k = 0;
        while (k < nl.Count) {
            if (!(k == nl.Count - 1 && nl[k] == "")) { termLog.Add(nl[k]); }
            k = k + 1;
        }
        while (termLog.Count > 2000) { termLog.RemoveAt(0); }
        return last + 1;
    }

    // ================================================================
    // Git panel helpers (right panel "Git" tab)
    // ================================================================

    /// Runs a git command inside `root`, capturing stdout+stderr.
    static List<string> GitRun(string root, string args) {
        return Process.RunCapture("git -C \"" + root + "\" " + args);
    }

    /// Refills `files` with `git status --porcelain` lines and returns the
    /// current branch name ("" when not a repository).
    static string GitRefresh(string root, List<string> files) {
        while (files.Count > 0) { files.RemoveAt(files.Count - 1); }
        if (!Directory.Exists(root + "/.git")) { return ""; }
        List<string> st = ZanIDE.GitRun(root, "status --porcelain");
        int i = 0;
        while (i < st.Count) {
            if (st[i] != "") { files.Add(st[i]); }
            i = i + 1;
        }
        List<string> br = ZanIDE.GitRun(root, "rev-parse --abbrev-ref HEAD");
        if (br.Count > 0) { return br[0]; }
        return "";
    }

    /// The path part of a porcelain status line ("XY path" or "XY a -> b",
    /// where the rename target is the interesting path).
    static string GitPathOf(string line) {
        if (line.Length < 4) { return ""; }
        string p = line.Substring(3, line.Length - 3);
        int arrow = ZanIDE.IndexOfStr(p, " -> ");
        if (arrow >= 0) { p = p.Substring(arrow + 4, p.Length - arrow - 4); }
        if (p.Length >= 2 && p.Substring(0, 1) == "\"") {
            p = p.Substring(1, p.Length - 2);
        }
        return p;
    }

    /// Row color for a porcelain status line: green when fully staged,
    /// red for untracked, orange for modified/partially staged.
    static int GitStatusColor(Theme t, string line) {
        if (line.Length < 2) { return t.textSecondary; }
        string x = line.Substring(0, 1);
        string y = line.Substring(1, 1);
        if (x == "?") { return t.error; }
        if (y == " ") { return t.success; }
        return t.warning;
    }

    /// Makes a commit message safe to embed in a double-quoted shell argument
    /// (quotes/backslashes/backticks would otherwise break out of it).
    static string GitEscape(string msg) {
        StringBuilder sb = new StringBuilder();
        int i = 0;
        while (i < msg.Length) {
            string ch = msg.Substring(i, 1);
            if (ch != "\"" && ch != "\\" && ch != "`" && ch != "$"
                && ch != "\r" && ch != "\n") {
                sb.Append(ch);
            } else if (ch == "\r" || ch == "\n") {
                sb.Append(" ");
            } else {
                sb.Append("'");
            }
            i = i + 1;
        }
        return sb.ToString();
    }

    // ================================================================
    // Debug helpers
    // ================================================================

    static bool DebugBuild(
        List<string> tabPaths,
        SignalInt activeTab,
        string root,
        List<string> log,
        CodeEditor editor
    ) {
        int a = activeTab.Get();
        if (a < 0 || a >= tabPaths.Count) { return false; }
        string activePath = tabPaths[a];
        string p = activePath;
        p = ZanIDE.RibbonRunTarget(p, root);
        if (p == "") {
            log.Add(ZanIDE.T("> [Debug] Open a source file first.", "> [调试] 请先打开源文件。"));
            return false;
        }
        string bd = ZanIDE.EnsureBuildDir(root);
        string ll = bd + "/.zandbg.ll";
        string exe = bd + "/.zandbg" + ZanIDE.ExeSuffix();
        if (File.Exists(exe)) { File.Delete(exe); }
        string inputs = ZanIDE.SmartInputs(root, ZanIDE.DirOf(p), p);
        // `-g` emits DWARF and forces -O0 so gdb (via zan-dap) sees real
        // source lines, frames and locals.
        string buildCmd = ZanIDE.CompileToExe(root, p, inputs, ll, exe, false) + " -g";
        log.Add("> [Debug] Building " + p + " ...");
        List<string> buildOut = Process.RunCapture(buildCmd);
        ZanIDE.AppendAll(log, buildOut);
        ZanIDE.ApplyDiagnostics(editor, activePath, buildOut, log);
        if (!File.Exists(exe)) {
            log.Add("> [Debug] Build failed.");
            return false;
        }
        log.Add("> [Debug] Build succeeded.");
        return true;
    }

    static int FirstDebugLine(CodeEditor editor) {
        List<string> lines = CodeEditor.SplitLines(editor.GetText());
        int i = 0;
        while (i < lines.Count) {
            string line = ZanIDE.TrimLeadSpaces(lines[i]);
            bool skip = line == "" || line == "{" || line == "}"
                || ZanIDE.Has(line, "using ")
                || ZanIDE.Has(line, "class ")
                || ZanIDE.Has(line, "static void Main")
                || ZanIDE.Has(line, "//");
            if (!skip) { return i; }
            i = i + 1;
        }
        return 0;
    }

    static List<string> DebugBuildRun(List<string> tabPaths, SignalInt activeTab,
            string root, List<string> log) {
        List<string> console = new List<string>();
        int a = activeTab.Get();
        if (a < 0 || a >= tabPaths.Count) { return console; }
        string p = tabPaths[a];
        if (p == "") {
            log.Add("> [Debug] Save the file first.");
            return console;
        }
        string bd = ZanIDE.EnsureBuildDir(root);
        string ll = bd + "/.zandbg.ll";
        string exe = bd + "/.zandbg" + ZanIDE.ExeSuffix();
        string buildCmd = ZanIDE.CompileToExe(root, p, "\"" + p + "\"", ll, exe, false);
        log.Add("> [Debug] Building ...");
        List<string> buildOut = Process.RunCapture(buildCmd);
        int bo = 0;
        while (bo < buildOut.Count) {
            log.Add("  " + buildOut[bo]);
            bo = bo + 1;
        }
        log.Add("> [Debug] Running ...");
        List<string> runOut = Process.RunCapture("\"" + exe + "\"");
        int ri = 0;
        while (ri < runOut.Count) {
            console.Add(runOut[ri]);
            ri = ri + 1;
        }
        if (console.Count == 0) {
            console.Add("(no output)");
        }
        return console;
    }

    static int FindInEditor(CodeEditor editor, string query, int afterLine) {
        if (query.Length == 0) { return -1; }
        int lc = editor.LineCount();
        int startLine = afterLine + 1;
        if (startLine < 0) { startLine = 0; }
        string text = editor.GetText();
        List<string> edLines = new List<string>();
        string cur = "";
        int ii = 0;
        while (ii < text.Length) {
            string ch = text.Substring(ii, 1);
            if (ch == "\n") { edLines.Add(cur); cur = ""; }
            else if (ch == "\r") { cur = cur; }
            else { cur = cur + ch; }
            ii = ii + 1;
        }
        edLines.Add(cur);
        int li = startLine;
        while (li < edLines.Count) {
            string ln = edLines[li];
            int fi = 0;
            while (fi + query.Length <= ln.Length) {
                string sub = ln.Substring(fi, query.Length);
                if (sub == query) {
                    editor.GoToLineCol(li, fi);
                    return li;
                }
                fi = fi + 1;
            }
            li = li + 1;
        }
        // Wrap around from beginning
        li = 0;
        while (li < startLine && li < edLines.Count) {
            string ln = edLines[li];
            int fi = 0;
            while (fi + query.Length <= ln.Length) {
                string sub = ln.Substring(fi, query.Length);
                if (sub == query) {
                    editor.GoToLineCol(li, fi);
                    return li;
                }
                fi = fi + 1;
            }
            li = li + 1;
        }
        return -1;
    }

    static int ParseInt(string s) {
        int result = 0;
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "0") { result = result * 10; }
            else if (ch == "1") { result = result * 10 + 1; }
            else if (ch == "2") { result = result * 10 + 2; }
            else if (ch == "3") { result = result * 10 + 3; }
            else if (ch == "4") { result = result * 10 + 4; }
            else if (ch == "5") { result = result * 10 + 5; }
            else if (ch == "6") { result = result * 10 + 6; }
            else if (ch == "7") { result = result * 10 + 7; }
            else if (ch == "8") { result = result * 10 + 8; }
            else if (ch == "9") { result = result * 10 + 9; }
            i = i + 1;
        }
        return result;
    }

    /// Net change in brace nesting for a line (approximate: counts { and }
    /// literally, which is good enough for well-formed source).
    static int BraceDelta(string ln) {
        int d = 0;
        int i = 0;
        while (i < ln.Length) {
            string ch = ln.Substring(i, 1);
            if (ch == "{") { d = d + 1; }
            else if (ch == "}") { d = d - 1; }
            i = i + 1;
        }
        return d;
    }

    /// Returns "" if `elem` is not a primitive the debugger can stringify in an
    /// injected `foreach`, else the element type. (bool is excluded from lists:
    /// it stringifies to -1/0.)
    static string ListElemKind(string elem) {
        if (elem == "int" || elem == "string" || elem == "long"
            || elem == "float" || elem == "double" || elem == "char") {
            return elem;
        }
        return "";
    }

    static bool StartsWith(string s, string pfx) {
        if (s.Length < pfx.Length) { return false; }
        return s.Substring(0, pfx.Length) == pfx;
    }

    /// Path of the active tab, or "" if none.
    static string PathOf(List<string> paths, SignalInt active) {
        int a = active.Get();
        if (a >= 0 && a < paths.Count) { return paths[a]; }
        return "";
    }

    /// Directory portion of a path (before the last '/' or '\'), or "." if none.
    static string DirOf(string path) {
        int last = 0 - 1;
        int i = 0;
        while (i < path.Length) {
            string ch = path.Substring(i, 1);
            if (ch == "/" || ch == "\\") { last = i; }
            i = i + 1;
        }
        if (last < 0) { return "."; }
        return path.Substring(0, last);
    }

    static string FindProjectRoot(string path) {
        string dir = ZanIDE.DirOf(path);
        int depth = 0;
        while (depth < 24) {
            if (File.Exists(dir + "/zan.proj")) { return dir; }
            string parent = ZanIDE.DirOf(dir);
            if (parent == dir || parent == ".") { break; }
            dir = parent;
            depth = depth + 1;
        }
        return "";
    }

    static bool IsZanFile(string name) {
        int n = name.Length;
        if (n < 4) { return false; }
        return name.Substring(n - 4, 4) == ".zan";
    }

    /// Recursively collects full paths of project .zan source files under `dir`,
    /// skipping IDE temp files (names starting with ".") and build/publish output
    /// directories, so a project can span multiple files.
    static void GatherZanFiles(string dir, List<string> outp) {
        List<string> files = Directory.GetFiles(dir);
        int j = 0;
        while (j < files.Count) {
            string nm = files[j];
            if (ZanIDE.IsZanFile(nm) && nm.Substring(0, 1) != ".") {
                outp.Add(dir + "/" + nm);
            }
            j = j + 1;
        }
        List<string> subs = Directory.GetDirectories(dir);
        int i = 0;
        while (i < subs.Count) {
            string sn = subs[i];
            if (sn.Substring(0, 1) != "." && sn != "publish" && sn != "build"
                && sn != "bin" && sn != "obj" && sn != "dist" && sn != "tools") {
                ZanIDE.GatherZanFiles(dir + "/" + sn, outp);
            }
            i = i + 1;
        }
    }

    /// Builds the quoted, space-joined zanc input list for a whole-project build:
    /// `entry` first (so it becomes the compiler's primary input), then every
    /// other project .zan file except `skip` (e.g. the original of a probe).
    static string ProjectInputs(string dir, string entry, string skip) {
        string args = "\"" + entry + "\"";
        List<string> all = new List<string>();
        ZanIDE.GatherZanFiles(dir, all);
        int i = 0;
        while (i < all.Count) {
            string f = all[i];
            if (f != entry && f != skip) {
                args = args + " \"" + f + "\"";
            }
            i = i + 1;
        }
        return args;
    }

    /// Resolves the runnable entry point of the project at `root`. A .zform (or
    /// its code-behind) is not independently runnable, so Run/Build always drive
    /// the project entry declared in zan.proj (`entry = ...`), falling back to
    /// src/main.zan. This keeps the compiler from ever being handed a .zform.
    static string ProjectEntry(string root) {
        string fallback = root + "/src/main.zan";
        string proj = root + "/zan.proj";
        if (!File.Exists(proj)) { return fallback; }
        List<string> ls = CodeEditor.SplitLines(File.ReadAllText(proj));
        int i = 0;
        while (i < ls.Count) {
            string tr = ZanIDE.TrimLeadSpaces(ls[i]);
            if (tr.Length >= 5 && tr.Substring(0, 5) == "entry") {
                string rest = ZanIDE.TrimLeadSpaces(tr.Substring(5, tr.Length - 5));
                if (rest.Length > 0 && rest.Substring(0, 1) == "=") {
                    string val = ZanIDE.TrimLeadSpaces(rest.Substring(1, rest.Length - 1));
                    int e = val.Length;
                    while (e > 0) {
                        string ch = val.Substring(e - 1, 1);
                        if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") { e = e - 1; }
                        else { break; }
                    }
                    if (e > 0) { return root + "/" + val.Substring(0, e); }
                }
            }
            i = i + 1;
        }
        return fallback;
    }

    static string TrimLeadSpaces(string s) {
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == " " || ch == "\t") { i = i + 1; }
            else { break; }
        }
        if (i == 0) { return s; }
        return s.Substring(i, s.Length - i);
    }

    static string ExtractIdent(string s, int start) {
        string idc = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_";
        string name = "";
        int i = start;
        while (i < s.Length && CodeEditor.InSet(idc, s.Substring(i, 1))) {
            name = name + s.Substring(i, 1);
            i = i + 1;
        }
        return name;
    }

    static string ExtractValue(string rest, int ni) {
        if (ni >= rest.Length) { return "(uninitialized)"; }
        if (rest.Substring(ni, 1) != "=") { return "(uninitialized)"; }
        ni = ni + 1;
        while (ni < rest.Length && rest.Substring(ni, 1) == " ") { ni = ni + 1; }
        string val = "";
        while (ni < rest.Length && rest.Substring(ni, 1) != ";") {
            val = val + rest.Substring(ni, 1);
            ni = ni + 1;
        }
        if (val.Length == 0) { return "(empty)"; }
        return val;
    }

    static string TrimTrailSpaces(string s) {
        int e = s.Length;
        while (e > 0 && s.Substring(e - 1, 1) == " ") { e = e - 1; }
        if (e == s.Length) { return s; }
        return s.Substring(0, e);
    }

    static void LogVarsToConsole(List<string> log, List<string> vars, int execLine) {
        log.Add("> --- Line " + Convert.ToString(execLine + 1) + " ---");
        int vi = 0;
        while (vi < vars.Count) {
            string entry = vars[vi];
            string vn = ZanIDE.GetTabField(entry, 0);
            string vt = ZanIDE.GetTabField(entry, 1);
            string vv = ZanIDE.GetTabField(entry, 2);
            log.Add(">   " + vn + " : " + vt + " = " + vv);
            vi = vi + 1;
        }
    }

    static string GetTabField(string s, int fieldIdx) {
        int fi = 0;
        int start = 0;
        int i = 0;
        while (i < s.Length) {
            if (s.Substring(i, 1) == "\t") {
                if (fi == fieldIdx) {
                    return s.Substring(start, i - start);
                }
                fi = fi + 1;
                start = i + 1;
            }
            i = i + 1;
        }
        if (fi == fieldIdx) {
            return s.Substring(start, s.Length - start);
        }
        return "";
    }

    // ================================================================
    // Designer
    // ================================================================

    static string ExampleCat(int idx) {
        if (idx == 0 || idx == 1 || idx == 2) { return "Basics"; }
        if (idx == 3 || idx == 6 || idx == 7 || idx == 8) { return "GUI & Apps"; }
        return "Network & Data";
    }

    static string ExampleDesc(int idx) {
        if (idx == 0) { return "Console I/O: print and read a line."; }
        if (idx == 1) { return "Read/write files and list a directory."; }
        if (idx == 2) { return "List operations with LINQ (OrderBy/Where/Sum)."; }
        if (idx == 3) { return "A Gui window with an event loop."; }
        if (idx == 4) { return "HTTP GET/POST with HttpClient."; }
        if (idx == 5) { return "Parse and build JSON."; }
        if (idx == 6) { return "Timers and event handling."; }
        if (idx == 7) { return "A small calculator app."; }
        if (idx == 8) { return "A minimal text editor."; }
        return "";
    }

    // The old standalone snippets were replaced by the searchable component
    // center so examples stay aligned with the current Gui.Widget API.
    /// The stdlib/ shipped next to the IDE as a collapsed tree, so the
    /// sidebar's third section doubles as a standard-library browser.
    static List<TreeNode> BuildStdlibTree() {
        List<TreeNode> n = ZanIDE.BuildDirTree(ZanIDE.StdlibDir());
        int i = 0;
        while (i < n.Count) {
            if (n[i].isDir) { n[i].expanded = false; }
            i = i + 1;
        }
        return n;
    }

    /// A generic collapsible .zan file tree for any directory (empty list
    /// when the directory does not exist).
    static List<TreeNode> BuildDirTree(string dir) {
        List<TreeNode> n = new List<TreeNode>();
        if (dir != "" && Directory.Exists(dir)) {
            ZanIDE.ScanExamplesInto(n, dir, 0);
        }
        return n;
    }

    static List<TreeNode> BuildExampleTree() {
        List<TreeNode> n = new List<TreeNode>();
        string dir = ZanIDE.ExamplesDir();
        if (dir != "") {
            // Scan the real examples/ folder so every leaf carries the actual
            // on-disk path; clicking one opens the true source and Run/Debug
            // compile it directly. Sub-directories become collapsible groups.
            ZanIDE.ScanExamplesInto(n, dir, 0);
        }
        if (n.Count == 0) {
            // No examples shipped alongside the IDE: fall back to the built-in
            // GUI component center so the panel is never empty.
            n.Add(TreeNode.Dir(ZanIDE.T("GUI Reference", "GUI 参考"), 0, true));
            n.Add(ZanIDE.ExLeaf(
                ZanIDE.T("Component Center", "组件示例中心"), 0));
        }
        return n;
    }

    /// Adds the `.zan` files and sub-directories of `dirPath` to `nodes` in
    /// pre-order, tagging every file leaf with its real path. Mirrors ScanInto
    /// but keeps only Zan sources (examples never ship manifests) and omits the
    /// redundant root directory row so the pane starts at the first example.
    static void ScanExamplesInto(List<TreeNode> nodes, string dirPath, int depth) {
        List<string> subs = Directory.GetDirectories(dirPath);
        int i = 0;
        while (i < subs.Count) {
            TreeNode d = TreeNode.Dir(subs[i], depth, true);
            d.path = dirPath + "/" + subs[i];
            nodes.Add(d);
            ZanIDE.ScanExamplesInto(nodes, dirPath + "/" + subs[i], depth + 1);
            i = i + 1;
        }
        List<string> files = Directory.GetFiles(dirPath);
        int j = 0;
        while (j < files.Count) {
            if (ZanIDE.EndsWith(files[j], ".zan")) {
                TreeNode f = TreeNode.FileIcon(files[j], depth, "file");
                f.path = dirPath + "/" + files[j];
                nodes.Add(f);
            }
            j = j + 1;
        }
    }

    static TreeNode ExLeaf(string label, int idx) {
        TreeNode f = TreeNode.FileIcon(label, 1, "file");
        f.path = "@ex:" + Convert.ToString(idx);
        return f;
    }

    // Returns the index of the first tab whose path equals p, or -1.
    static int FindTabByPath(List<string> paths, string p) {
        int i = 0;
        while (i < paths.Count) {
            if (paths[i] == p) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    // ---- Help / documentation browser ----

    /// Lowercases ASCII A-Z using only string ops (the runtime has no reliable
    /// char-code helper here), leaving other characters unchanged.
    static string ToLowerS(string s) {
        string up = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        string lo = "abcdefghijklmnopqrstuvwxyz";
        string o = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            int k = 0;
            bool done = false;
            while (k < 26 && !done) {
                if (up.Substring(k, 1) == ch) { o = o + lo.Substring(k, 1); done = true; }
                k = k + 1;
            }
            if (!done) { o = o + ch; }
            i = i + 1;
        }
        return o;
    }

    /// True if `hay` contains `needle` as a substring.
    static bool ContainsS(string hay, string needle) {
        if (needle.Length == 0) { return true; }
        if (hay.Length < needle.Length) { return false; }
        int last = hay.Length - needle.Length;
        int i = 0;
        while (i <= last) {
            if (hay.Substring(i, needle.Length) == needle) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// Word-wraps `s` (honoring embedded newlines) to fit `maxW` pixels at
    /// `fontSize`. Empty input paragraphs become blank lines (paragraph gaps).
    static List<string> WrapText(string s, int maxW, int fontSize) {
        List<string> outl = new List<string>();
        List<string> paras = CodeEditor.SplitLines(s);
        int p = 0;
        while (p < paras.Count) {
            List<string> words = ZanIDE.SplitSpaces(paras[p]);
            if (words.Count == 0) { outl.Add(""); }
            string cur = "";
            int wi = 0;
            while (wi < words.Count) {
                string cand = cur;
                if (cand != "") { cand = cand + " "; }
                cand = cand + words[wi];
                if (Canvas.MeasureText(cand, fontSize) > maxW && cur != "") {
                    outl.Add(cur);
                    cur = words[wi];
                } else {
                    cur = cand;
                }
                wi = wi + 1;
            }
            if (cur != "") { outl.Add(cur); }
            p = p + 1;
        }
        return outl;
    }

    // ================================================================
    // Example Code Library
    // ================================================================

    static void OpenNewTab(List<string> tabNames, List<string> tabBodies,
            List<string> tabPaths, SignalInt activeTab, string name, string code) {
        tabNames.Add(name);
        tabBodies.Add(code);
        tabPaths.Add("");
        activeTab.Set(tabNames.Count - 1);
    }

    static string GetExampleName(int idx) {
        if (idx == 0) { return "hello.zan"; }
        if (idx == 1) { return "fileio.zan"; }
        if (idx == 2) { return "linq.zan"; }
        if (idx == 3) { return "gui_window.zan"; }
        if (idx == 4) { return "http.zan"; }
        if (idx == 5) { return "json.zan"; }
        if (idx == 6) { return "timer.zan"; }
        if (idx == 7) { return "calculator.zan"; }
        if (idx == 8) { return "texteditor.zan"; }
        return "";
    }

    static string GetExampleCode(int idx) {
        if (idx == 0) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello, Zan!\");\n        string name = Console.ReadLine();\n        Console.WriteLine(\"Welcome, \" + name + \"!\");\n    }\n}\n";
        }
        if (idx == 1) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        // Write to file\n        File.WriteAllText(\"test.txt\", \"Hello File!\");\n        \n        // Read from file\n        string content = File.ReadAllText(\"test.txt\");\n        Console.WriteLine(content);\n        \n        // List directory\n        List<string> files = Directory.GetFiles(\".\");\n        foreach (string f in files) {\n            Console.WriteLine(f);\n        }\n    }\n}\n";
        }
        if (idx == 2) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        List<int> nums = new List<int>();\n        nums.Add(5); nums.Add(3); nums.Add(8);\n        nums.Add(1); nums.Add(9); nums.Add(2);\n        \n        // LINQ chain operations\n        var sorted = nums.OrderBy(x => x).ToList();\n        var even = nums.Where(x => x % 2 == 0).ToList();\n        int sum = nums.Sum();\n        int max = nums.Max();\n        \n        Console.WriteLine(\"Sum: \" + Convert.ToString(sum));\n        Console.WriteLine(\"Max: \" + Convert.ToString(max));\n    }\n}\n";
        }
        if (idx == 3) {
            return "using System;\nusing Gui;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"My Window\", 800, 600);\n        app.Show();\n        while (app.isRunning) {\n            if (app.BeginFrame()) {\n                Canvas c = app.canvas;\n                Theme t = app.theme;\n                app.RenderChrome();\n                c.FillRect(10, 40, 200, 100, t.primary);\n                c.DrawText(20, 60, \"Hello GUI!\",\n                    0xFFFFFFFF, t.fontSizeMedium);\n                app.PresentFrame();\n            }\n            app.ProcessEvent();\n        }\n    }\n}\n";
        }
        if (idx == 4) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        // HTTP GET request\n        HttpClient client = new HttpClient();\n        string url = \"https://api.example.com/data\";\n        string response = client.GetString(url);\n        Console.WriteLine(response);\n        \n        // HTTP POST\n        string body = \"{\\\"key\\\": \\\"value\\\"}\";\n        string result = client.PostString(url, body);\n        Console.WriteLine(result);\n    }\n}\n";
        }
        if (idx == 5) {
            return "using System;\n\nclass Program {\n    static void Main() {\n        string json = \"{\\\"name\\\": \\\"Zan\\\", \\\"version\\\": 1}\";\n        \n        // Parse JSON\n        var obj = JsonSerializer.Parse(json);\n        string name = obj.GetString(\"name\");\n        int ver = obj.GetInt(\"version\");\n        \n        Console.WriteLine(\"Name: \" + name);\n        Console.WriteLine(\"Version: \" + Convert.ToString(ver));\n        \n        // Create JSON\n        var builder = JsonSerializer.CreateObject();\n        builder.Set(\"lang\", \"Zan\");\n        builder.Set(\"year\", 2026);\n        Console.WriteLine(builder.ToString());\n    }\n}\n";
        }
        if (idx == 6) {
            return "using System;\nusing Gui;\n\nclass Program {\n    static void Main() {\n        App app = App.CreateDark(\"Timer\", 400, 300);\n        app.Show();\n        int count = 0;\n        int lastTick = 0;\n        while (app.isRunning) {\n            if (app.BeginFrame()) {\n                Canvas c = app.canvas;\n                app.RenderChrome();\n                int now = app.window.GetTickMs();\n                if (now - lastTick > 1000) {\n                    count = count + 1;\n                    lastTick = now;\n                    app.RequestRedraw();\n                }\n                c.DrawText(20, 60, \"Count: \" +\n                    Convert.ToString(count),\n                    0xFFFFFFFF, 24);\n                app.PresentFrame();\n            }\n            app.ProcessEvent();\n        }\n    }\n}\n";
        }
        if (idx == 7) {
            return "using System;\n\nclass Calculator {\n    static int Eval(string expr) {\n        // Simple expression evaluator\n        int result = 0;\n        int num = 0;\n        string op = \"+\";\n        int i = 0;\n        while (i < expr.Length) {\n            string ch = expr.Substring(i, 1);\n            if (ch == \"+\" || ch == \"-\") {\n                if (op == \"+\") { result = result + num; }\n                else { result = result - num; }\n                num = 0; op = ch;\n            } else {\n                num = num * 10 + Convert.ToInt32(ch);\n            }\n            i = i + 1;\n        }\n        if (op == \"+\") { result = result + num; }\n        else { result = result - num; }\n        return result;\n    }\n    \n    static void Main() {\n        Console.WriteLine(\"Calculator\");\n        string expr = Console.ReadLine();\n        int val = Calculator.Eval(expr);\n        Console.WriteLine(\"= \" + Convert.ToString(val));\n    }\n}\n";
        }
        if (idx == 8) {
            return "using System;\nusing Gui;\nusing Gui.Widget;\n\nclass TextEditor {\n    static void Main() {\n        App app = App.CreateDark(\"Editor\", 800, 600);\n        app.Show();\n        CodeEditor ed = CodeEditor.Create();\n        ed.LoadText(\"Hello World!\\nLine 2\\nLine 3\");\n        while (app.isRunning) {\n            if (app.BeginFrame()) {\n                app.RenderChrome();\n                Rect area = Rect.Create(0, 32, 800, 568);\n                ed.Render(app, area);\n                app.PresentFrame();\n            }\n            app.ProcessEvent();\n        }\n    }\n}\n";
        }
        return "";
    }

    // ==== Real DAP-backed debugging (P0-2) ================================
    // These helpers drive a DebugSession (a Debug Adapter Protocol client that
    // talks to a spawned zan-dap over a loopback socket), replacing the old
    // static source-instrumentation debugger. Stop locations, the call stack,
    // scopes and variables all come from a real gdb-backed inferior.

    /// Spawns zan-dap in TCP server mode, connects, and runs the launch
    /// handshake (initialize/launch/setBreakpoints/configurationDone) until the
    /// first stop or program exit. `bps0` holds 0-based breakpoint lines; when
    /// empty a single breakpoint is placed at `fallback0` so F5 still pauses.
    /// Returns the session, or null when the adapter cannot be reached.
    static DebugSession DbgBegin(string root, string srcPath, List<int> bps0,
            int fallback0, List<int> condLines0, List<string> condExprs0,
            List<string> log) {
        string exe = ZanIDE.EnsureBuildDir(root) + "/.zandbg" + ZanIDE.ExeSuffix();
        string dap = ZanIDE.ToolchainDir() + "/zan-dap" + ZanIDE.ExeSuffix();
        if (!File.Exists(dap)) { dap = ZanIDE.ExeDir() + "/zan-dap" + ZanIDE.ExeSuffix(); }
        if (!File.Exists(dap)) {
            log.Add("> [Debug] zan-dap not found in toolchain.");
            return null;
        }
        List<int> lines = new List<int>();
        List<string> conds = new List<string>();
        int bi = 0;
        while (bi < bps0.Count) {
            lines.Add(bps0[bi] + 1);
            conds.Add(ZanIDE.CondFor(condLines0, condExprs0, bps0[bi]));
            bi = bi + 1;
        }
        if (lines.Count == 0) { lines.Add(fallback0 + 1); conds.Add(""); }

        int attempt = 0;
        while (attempt < 4) {
            int port = 47113 + attempt;
            Process.RunDetached("\"" + dap + "\" --port " + Convert.ToString(port));
            DebugSession s = DebugSession.Open(port, exe, srcPath, lines, conds);
            if (s != null) { return s; }
            attempt = attempt + 1;
        }
        log.Add("> [Debug] Could not connect to zan-dap.");
        return null;
    }

    /// Reflects a session's current stop state into the editor + output log and
    /// mirrors the inferior's stdout into the debug console. Returns the debug
    /// UI state (2 = paused, 0 = not debugging).
    static int DbgSync(DebugSession dbg, CodeEditor editor, List<string> log,
            List<string> console) {
        if (dbg == null) {
            editor.SetExecLine(0 - 1);
            return 0;
        }
        while (console.Count > 0) { console.RemoveAt(console.Count - 1); }
        List<string> outp = dbg.Console();
        int oi = 0;
        while (oi < outp.Count) { console.Add(outp[oi]); oi = oi + 1; }
        if (dbg.Paused()) {
            editor.SetExecLine(dbg.CurLine() - 1);
            log.Add("> [Debug] Paused at line " + Convert.ToString(dbg.CurLine()));
            return 2;
        }
        editor.SetExecLine(0 - 1);
        log.Add("> [Debug] Program exited (code "
            + Convert.ToString(dbg.ExitCode()) + ").");
        dbg.Stop();
        return 0;
    }

    /// 0-based editor line for the current stop, or -1 when not paused.
    static int DbgLine(DebugSession dbg) {
        if (dbg == null) { return 0 - 1; }
        if (!dbg.Paused()) { return 0 - 1; }
        return dbg.CurLine() - 1;
    }

    static List<string> DbgVars(DebugSession dbg) {
        if (dbg == null) { return new List<string>(); }
        return dbg.Locals();
    }

    static List<string> DbgStack(DebugSession dbg) {
        if (dbg == null) { return new List<string>(); }
        return dbg.Stack();
    }

    /// The condition expression stored for 0-based `line` ("" when none).
    static string CondFor(List<int> lines, List<string> exprs, int line) {
        int i = 0;
        while (i < lines.Count) {
            if (lines[i] == line) { return exprs[i]; }
            i = i + 1;
        }
        return "";
    }

    /// Sets, replaces or clears (empty expr) the condition for 0-based `line`.
    static void SetCond(List<int> lines, List<string> exprs, int line,
            string expr) {
        int i = 0;
        while (i < lines.Count) {
            if (lines[i] == line) {
                if (expr.Length == 0) { lines.RemoveAt(i); exprs.RemoveAt(i); }
                else { exprs[i] = expr; }
                return;
            }
            i = i + 1;
        }
        if (expr.Length > 0) { lines.Add(line); exprs.Add(expr); }
    }

    /// Evaluates every watch expression in the paused frame; returns rows in
    /// the Variables panel format (expr\t\tvalue).
    static List<string> DbgEvalWatches(DebugSession dbg, List<string> watches) {
        List<string> rows = new List<string>();
        int i = 0;
        while (i < watches.Count) {
            string v = "";
            if (dbg != null) { v = dbg.Evaluate(watches[i]); }
            rows.Add(watches[i] + "\t\t" + v);
            i = i + 1;
        }
        return rows;
    }
}

/// A live Debug Adapter Protocol client that drives a spawned `zan-dap` over a
/// loopback TCP socket (127.0.0.1). Replaces the IDE's former static
/// source-instrumentation debugger: stop locations, the call stack, scopes and
/// variables are all produced by a real gdb-backed inferior via zan-dap. The
/// request/response model is synchronous -- each user action (start / continue
/// / step) sends a request and blocks until the next `stopped` or `exited`
/// event -- which fits the single-threaded IDE event loop (gdb steps are fast).
class DebugSession {
    #if WINDOWS
    [DllImport("ws2_32", EntryPoint = "WSAStartup")]
    static extern int ws_startup(int version, string data);
    [DllImport("ws2_32", EntryPoint = "socket")]
    static extern int ws_socket(int af, int type, int proto);
    [DllImport("ws2_32", EntryPoint = "connect")]
    static extern int ws_connect(int s, string addr, int len);
    [DllImport("ws2_32", EntryPoint = "closesocket")]
    static extern int ws_close(int s);
    [DllImport("ws2_32", EntryPoint = "send")]
    static extern int ws_send(int s, string buf, int len, int flags);
    [DllImport("ws2_32", EntryPoint = "recv")]
    static extern int ws_recv(int s, string buf, int len, int flags);
    [DllImport("ws2_32", EntryPoint = "htons")]
    static extern int ws_htons(int v);
    [DllImport("ws2_32", EntryPoint = "inet_addr")]
    static extern int ws_inet_addr(string cp);
    [DllImport("kernel32", EntryPoint = "Sleep")]
    static extern void plat_sleep(int ms);
    #else
    [DllImport("crt", EntryPoint = "socket")]
    static extern int ws_socket(int af, int type, int proto);
    [DllImport("crt", EntryPoint = "connect")]
    static extern int ws_connect(int s, string addr, int len);
    [DllImport("crt", EntryPoint = "close")]
    static extern int ws_close(int s);
    [DllImport("crt", EntryPoint = "send")]
    static extern int ws_send(int s, string buf, int len, int flags);
    [DllImport("crt", EntryPoint = "recv")]
    static extern int ws_recv(int s, string buf, int len, int flags);
    [DllImport("crt", EntryPoint = "htons")]
    static extern int ws_htons(int v);
    [DllImport("crt", EntryPoint = "inet_addr")]
    static extern int ws_inet_addr(string cp);
    [DllImport("crt", EntryPoint = "usleep")]
    static extern int plat_usleep(int us);
    #endif
    [DllImport("crt")]
    static extern string calloc(int count, int size);
    [DllImport("crt")]
    static extern void free(string ptr);
    [DllImport("crt")]
    static extern int strlen(string str);

    int sock;
    int seq;
    bool paused;
    bool alive;
    int curLine;
    int exitCode;
    int frameId;
    string curFile;
    string rbuf;
    List<string> locals;
    List<string> stack;
    List<string> console;

    // ---- lifecycle --------------------------------------------------------

    /// Connects to a zan-dap listening on 127.0.0.1:port and runs the DAP
    /// launch handshake. Returns null if the socket cannot be reached.
    static DebugSession Open(int port, string program, string source,
            List<int> bpLines, List<string> bpConds) {
        DebugSession d = new DebugSession();
        d.sock = 0 - 1;
        d.seq = 1;
        d.paused = false;
        d.alive = false;
        d.curLine = 0;
        d.exitCode = 0;
        d.frameId = 0;
        d.curFile = "";
        d.rbuf = "";
        d.locals = new List<string>();
        d.stack = new List<string>();
        d.console = new List<string>();

        #if WINDOWS
        string wsa = calloc(512, 1);
        ws_startup(514, wsa);
        free(wsa);
        #endif

        int s = ws_socket(2, 1, 6);
        if (s < 0) { return null; }
        d.sock = s;

        // zan-dap may still be binding its listener; retry the connect briefly.
        bool connected = false;
        int tries = 0;
        while (tries < 100 && !connected) {
            string addr = d.BuildAddr(port);
            int r = ws_connect(s, addr, 16);
            free(addr);
            if (r == 0) { connected = true; }
            else { d.SnoozeMs(20); tries = tries + 1; }
        }
        if (!connected) { ws_close(s); return null; }
        d.alive = true;

        d.Request("initialize",
            "{\"clientID\":\"zanide\",\"adapterID\":\"zan\","
            + "\"linesStartAt1\":true,\"columnsStartAt1\":true}");
        d.AwaitResponse("initialize");
        d.AwaitEvent("initialized");
        d.Request("launch", "{\"program\":\"" + DebugSession.JsonEsc(program)
            + "\",\"stopOnEntry\":false}");
        d.AwaitResponse("launch");
        d.Request("setBreakpoints", d.BpJson(source, bpLines, bpConds));
        d.AwaitResponse("setBreakpoints");
        d.Request("configurationDone", "");
        d.AwaitResponse("configurationDone");
        d.PumpUntilStop();
        return d;
    }

    void SnoozeMs(int ms) {
        #if WINDOWS
        plat_sleep(ms);
        #else
        plat_usleep(ms * 1000);
        #endif
    }

    string BuildAddr(int port) {
        string addr = calloc(16, 1);
        #if MACOS
        addr[0] = 16;
        addr[1] = 2;
        #else
        addr[0] = 2;
        addr[1] = 0;
        #endif
        int nport = ws_htons(port);
        addr[2] = nport & 255;
        addr[3] = (nport >> 8) & 255;
        int ip = ws_inet_addr("127.0.0.1");
        addr[4] = ip & 255;
        addr[5] = (ip >> 8) & 255;
        addr[6] = (ip >> 16) & 255;
        addr[7] = (ip >> 24) & 255;
        return addr;
    }

    string BpJson(string source, List<int> lines, List<string> conds) {
        string arr = "";
        int i = 0;
        while (i < lines.Count) {
            if (i > 0) { arr = arr + ","; }
            arr = arr + "{\"line\":" + Convert.ToString(lines[i]);
            if (i < conds.Count && conds[i].Length > 0) {
                arr = arr + ",\"condition\":\""
                    + DebugSession.JsonEsc(conds[i]) + "\"";
            }
            arr = arr + "}";
            i = i + 1;
        }
        return "{\"source\":{\"path\":\"" + DebugSession.JsonEsc(source)
            + "\"},\"breakpoints\":[" + arr + "]}";
    }

    // ---- public control ---------------------------------------------------

    bool Paused() { return this.paused; }
    bool Alive() { return this.alive; }
    int CurLine() { return this.curLine; }
    int ExitCode() { return this.exitCode; }
    string CurFile() { return this.curFile; }
    List<string> Locals() { return this.locals; }
    List<string> Stack() { return this.stack; }
    List<string> Console() { return this.console; }

    void Continue() { this.Resume("continue"); }
    void StepOver() { this.Resume("next"); }
    void StepIn() { this.Resume("stepIn"); }
    void StepOut() { this.Resume("stepOut"); }

    /// Evaluates `expr` in the current (top) frame via the DAP `evaluate`
    /// request. Returns the adapter's result string, or "<error>" when the
    /// expression cannot be evaluated.
    string Evaluate(string expr) {
        if (!this.alive || !this.paused) { return ""; }
        this.Request("evaluate",
            "{\"expression\":\"" + DebugSession.JsonEsc(expr)
            + "\",\"frameId\":" + Convert.ToString(this.frameId)
            + ",\"context\":\"watch\"}");
        string m = this.AwaitResponseMsg("evaluate");
        if (m.Length == 0) { return "<error>"; }
        if (DebugSession.IndexOf(m, "\"success\":false", 0) >= 0) {
            return "<error>";
        }
        return DebugSession.JsonStr(m, "result", 0);
    }

    void Resume(string cmd) {
        if (!this.alive) { this.paused = false; return; }
        this.paused = false;
        this.Request(cmd, "{\"threadId\":1}");
        this.AwaitResponse(cmd);
        this.PumpUntilStop();
    }

    void Stop() {
        if (this.sock >= 0) {
            if (this.alive) {
                this.Request("disconnect", "{\"terminateDebuggee\":true}");
            }
            ws_close(this.sock);
            this.sock = 0 - 1;
        }
        this.alive = false;
        this.paused = false;
    }

    // ---- transport (Content-Length framing over the socket) ---------------

    void SendAll(string data) {
        int total = strlen(data);
        int off = 0;
        while (off < total) {
            string chunk = data;
            if (off > 0) { chunk = data.Substring(off, total - off); }
            int n = ws_send(this.sock, chunk, total - off, 0);
            if (n <= 0) { this.alive = false; return; }
            off = off + n;
        }
    }

    void SendMsg(string body) {
        string msg = "Content-Length: " + Convert.ToString(strlen(body))
            + "\r\n\r\n" + body;
        this.SendAll(msg);
    }

    void Request(string cmd, string argsJson) {
        string body = "{\"seq\":" + Convert.ToString(this.seq)
            + ",\"type\":\"request\",\"command\":\"" + cmd + "\"";
        if (argsJson.Length > 0) { body = body + ",\"arguments\":" + argsJson; }
        body = body + "}";
        this.seq = this.seq + 1;
        this.SendMsg(body);
    }

    string RecvChunk() {
        int cap = 65536;
        string buf = calloc(cap + 1, 1);
        int n = ws_recv(this.sock, buf, cap, 0);
        if (n <= 0) { free(buf); return ""; }
        string res = buf.Substring(0, n);
        free(buf);
        return res;
    }

    /// Reads one Content-Length-framed message; "" on disconnect.
    string ReadMsg() {
        int guard = 0;
        while (guard < 1000000) {
            guard = guard + 1;
            int he = DebugSession.IndexOf(this.rbuf, "\r\n\r\n", 0);
            if (he >= 0) {
                string header = this.rbuf.Substring(0, he);
                int cl = DebugSession.HeaderLen(header);
                int start = he + 4;
                if (cl >= 0 && this.rbuf.Length >= start + cl) {
                    string body = this.rbuf.Substring(start, cl);
                    int rest = this.rbuf.Length - start - cl;
                    this.rbuf = this.rbuf.Substring(start + cl, rest);
                    return body;
                }
            }
            string chunk = this.RecvChunk();
            if (chunk.Length == 0) { this.alive = false; return ""; }
            this.rbuf = this.rbuf + chunk;
        }
        return "";
    }

    // ---- protocol pumps ---------------------------------------------------

    /// Handles events that may arrive between a request and its response:
    /// captured program stdout, and exit/termination.
    void Aside(string m) {
        if (DebugSession.IndexOf(m, "\"event\":\"output\"", 0) >= 0) {
            string txt = DebugSession.JsonStr(m, "output", 0);
            if (txt.Length > 0) { this.console.Add(DebugSession.RTrimNl(txt)); }
        } else if (DebugSession.IndexOf(m, "\"event\":\"exited\"", 0) >= 0) {
            this.exitCode = DebugSession.JsonInt(m, "exitCode", 0);
            this.alive = false;
            this.paused = false;
        } else if (DebugSession.IndexOf(m, "\"event\":\"terminated\"", 0) >= 0) {
            this.alive = false;
            this.paused = false;
        }
    }

    string AwaitResponseMsg(string cmd) {
        int guard = 0;
        while (guard < 100000) {
            guard = guard + 1;
            string m = this.ReadMsg();
            if (m.Length == 0) { return ""; }
            if (DebugSession.IndexOf(m, "\"type\":\"response\"", 0) >= 0
                && DebugSession.IndexOf(m, "\"command\":\"" + cmd + "\"", 0) >= 0) {
                return m;
            }
            this.Aside(m);
        }
        return "";
    }

    void AwaitResponse(string cmd) {
        this.AwaitResponseMsg(cmd);
    }

    void AwaitEvent(string name) {
        int guard = 0;
        while (guard < 100000) {
            guard = guard + 1;
            string m = this.ReadMsg();
            if (m.Length == 0) { return; }
            if (DebugSession.IndexOf(m, "\"event\":\"" + name + "\"", 0) >= 0) {
                return;
            }
            this.Aside(m);
        }
    }

    /// Reads events until the inferior stops (breakpoint/step) or exits, then
    /// refreshes the call stack + variables on a stop.
    void PumpUntilStop() {
        int guard = 0;
        while (guard < 100000) {
            guard = guard + 1;
            string m = this.ReadMsg();
            if (m.Length == 0) { this.alive = false; this.paused = false; return; }
            if (DebugSession.IndexOf(m, "\"event\":\"stopped\"", 0) >= 0) {
                this.paused = true;
                this.Refresh();
                return;
            }
            if (DebugSession.IndexOf(m, "\"event\":\"exited\"", 0) >= 0
                || DebugSession.IndexOf(m, "\"event\":\"terminated\"", 0) >= 0) {
                this.Aside(m);
                this.paused = false;
                return;
            }
            this.Aside(m);
        }
    }

    /// Pulls the current call stack, the top frame's Locals scope and its
    /// variables from the adapter into this session's lists.
    void Refresh() {
        while (this.stack.Count > 0) { this.stack.RemoveAt(this.stack.Count - 1); }
        while (this.locals.Count > 0) { this.locals.RemoveAt(this.locals.Count - 1); }
        this.frameId = 0;
        this.curLine = 0;
        this.curFile = "";

        this.Request("stackTrace",
            "{\"threadId\":1,\"startFrame\":0,\"levels\":64}");
        string st = this.AwaitResponseMsg("stackTrace");
        this.ParseFrames(st);

        this.Request("scopes", "{\"frameId\":" + Convert.ToString(this.frameId) + "}");
        string sc = this.AwaitResponseMsg("scopes");
        int reff = DebugSession.JsonInt(sc, "variablesReference", 0);
        if (reff != 0) {
            this.Request("variables",
                "{\"variablesReference\":" + Convert.ToString(reff) + "}");
            string vs = this.AwaitResponseMsg("variables");
            this.ParseVariables(vs);
        }
    }

    /// Parses the stackTrace body. Frame fields are emitted in the order
    /// id, name, line, column, source{path}; the first frame is the stop point.
    void ParseFrames(string m) {
        if (m.Length == 0) { return; }
        int p = DebugSession.IndexOf(m, "\"stackFrames\":", 0);
        if (p < 0) { return; }
        bool first = true;
        int count = 0;
        while (count < 64) {
            int idIdx = DebugSession.IndexOf(m, "\"id\":", p);
            if (idIdx < 0) { break; }
            int line = DebugSession.JsonInt(m, "line", idIdx);
            string name = DebugSession.JsonStr(m, "name", idIdx);
            if (name.Length == 0) { name = "?"; }
            this.stack.Add(name + " : line " + Convert.ToString(line));
            if (first) {
                this.frameId = DebugSession.JsonInt(m, "id", idIdx);
                this.curLine = line;
                this.curFile = DebugSession.JsonStr(m, "path", idIdx);
                first = false;
            }
            p = idIdx + 5;
            count = count + 1;
        }
    }

    /// Parses the variables body into "name\ttype\tvalue" rows (the format the
    /// IDE's Variables panel / inline hints consume). Variable fields are
    /// emitted in the order name, value, type.
    void ParseVariables(string m) {
        if (m.Length == 0) { return; }
        int p = DebugSession.IndexOf(m, "\"variables\":", 0);
        if (p < 0) { return; }
        int count = 0;
        while (count < 512) {
            int nameIdx = DebugSession.IndexOf(m, "\"name\":", p);
            if (nameIdx < 0) { break; }
            string nm = DebugSession.JsonStr(m, "name", nameIdx);
            string vv = DebugSession.JsonStr(m, "value", nameIdx);
            string vt = DebugSession.JsonStr(m, "type", nameIdx);
            this.locals.Add(nm + "\t" + vt + "\t" + vv);
            int vIdx = DebugSession.IndexOf(m, "\"value\":", nameIdx);
            if (vIdx < 0) { break; }
            p = vIdx + 8;
            count = count + 1;
        }
    }

    // ---- tiny JSON scanning helpers (ASCII payloads only) -----------------

    static int IndexOf(string hay, string needle, int from) {
        int hl = hay.Length;
        int nl = needle.Length;
        if (nl == 0) { return from; }
        int i = from;
        if (i < 0) { i = 0; }
        while (i + nl <= hl) {
            if (hay.Substring(i, nl) == needle) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    static int HeaderLen(string header) {
        int idx = DebugSession.IndexOf(header, "Content-Length:", 0);
        if (idx < 0) { idx = DebugSession.IndexOf(header, "content-length:", 0); }
        if (idx < 0) { return 0 - 1; }
        int p = idx + 15;
        int hl = header.Length;
        while (p < hl && header[p] == 32) { p = p + 1; }
        int val = 0;
        bool any = false;
        while (p < hl && header[p] >= 48 && header[p] <= 57) {
            val = val * 10 + (header[p] - 48);
            any = true;
            p = p + 1;
        }
        if (!any) { return 0 - 1; }
        return val;
    }

    static int JsonInt(string s, string key, int from) {
        int idx = DebugSession.IndexOf(s, "\"" + key + "\":", from);
        if (idx < 0) { return 0; }
        int p = idx + key.Length + 3;
        int sl = s.Length;
        while (p < sl && s[p] == 32) { p = p + 1; }
        bool neg = false;
        if (p < sl && s[p] == 45) { neg = true; p = p + 1; }
        int val = 0;
        while (p < sl && s[p] >= 48 && s[p] <= 57) {
            val = val * 10 + (s[p] - 48);
            p = p + 1;
        }
        if (neg) { return 0 - val; }
        return val;
    }

    static string JsonStr(string s, string key, int from) {
        int idx = DebugSession.IndexOf(s, "\"" + key + "\":", from);
        if (idx < 0) { return ""; }
        int p = idx + key.Length + 3;
        int sl = s.Length;
        while (p < sl && s[p] == 32) { p = p + 1; }
        if (p >= sl || s[p] != 34) { return ""; }
        p = p + 1;
        string res = "";
        while (p < sl) {
            int c = s[p];
            if (c == 92) {
                p = p + 1;
                if (p >= sl) { break; }
                int e = s[p];
                if (e == 110) { res = res + "\n"; }
                else if (e == 116) { res = res + "\t"; }
                else if (e == 114) { res = res + "\r"; }
                else if (e == 117) { p = p + 4; }
                else { res = res + s.Substring(p, 1); }
            } else if (c == 34) {
                break;
            } else {
                res = res + s.Substring(p, 1);
            }
            p = p + 1;
        }
        return res;
    }

    static string JsonEsc(string s) {
        string res = "";
        int i = 0;
        int sl = s.Length;
        while (i < sl) {
            int c = s[i];
            if (c == 92) { res = res + "\\\\"; }
            else if (c == 34) { res = res + "\\\""; }
            else if (c == 10) { res = res + "\\n"; }
            else if (c == 13) { res = res + "\\r"; }
            else if (c == 9) { res = res + "\\t"; }
            else { res = res + s.Substring(i, 1); }
            i = i + 1;
        }
        return res;
    }

    static string RTrimNl(string s) {
        int e = s.Length;
        while (e > 0) {
            int c = s[e - 1];
            if (c == 10 || c == 13) { e = e - 1; }
            else { break; }
        }
        return s.Substring(0, e);
    }
}

/// A live Language Server Protocol client that drives a spawned `zan-lsp`
/// over a loopback TCP socket (127.0.0.1), mirroring DebugSession's
/// transport. Serves semantic go-to-definition, find-references and hover
/// from the compiler front-end (binder/checker) instead of text scanning.
/// The request/response model is synchronous, matching the IDE event loop.
class LspSession {
    #if WINDOWS
    [DllImport("ws2_32", EntryPoint = "WSAStartup")]
    static extern int ws_startup(int version, string data);
    [DllImport("ws2_32", EntryPoint = "socket")]
    static extern int ws_socket(int af, int type, int proto);
    [DllImport("ws2_32", EntryPoint = "connect")]
    static extern int ws_connect(int s, string addr, int len);
    [DllImport("ws2_32", EntryPoint = "closesocket")]
    static extern int ws_close(int s);
    [DllImport("ws2_32", EntryPoint = "send")]
    static extern int ws_send(int s, string buf, int len, int flags);
    [DllImport("ws2_32", EntryPoint = "recv")]
    static extern int ws_recv(int s, string buf, int len, int flags);
    [DllImport("ws2_32", EntryPoint = "htons")]
    static extern int ws_htons(int v);
    [DllImport("ws2_32", EntryPoint = "inet_addr")]
    static extern int ws_inet_addr(string cp);
    [DllImport("kernel32", EntryPoint = "Sleep")]
    static extern void plat_sleep(int ms);
    #else
    [DllImport("crt", EntryPoint = "socket")]
    static extern int ws_socket(int af, int type, int proto);
    [DllImport("crt", EntryPoint = "connect")]
    static extern int ws_connect(int s, string addr, int len);
    [DllImport("crt", EntryPoint = "close")]
    static extern int ws_close(int s);
    [DllImport("crt", EntryPoint = "send")]
    static extern int ws_send(int s, string buf, int len, int flags);
    [DllImport("crt", EntryPoint = "recv")]
    static extern int ws_recv(int s, string buf, int len, int flags);
    [DllImport("crt", EntryPoint = "htons")]
    static extern int ws_htons(int v);
    [DllImport("crt", EntryPoint = "inet_addr")]
    static extern int ws_inet_addr(string cp);
    [DllImport("crt", EntryPoint = "usleep")]
    static extern int plat_usleep(int us);
    #endif
    [DllImport("crt")]
    static extern string calloc(int count, int size);
    [DllImport("crt")]
    static extern void free(string ptr);
    [DllImport("crt")]
    static extern int strlen(string str);

    int sock;
    int seq;
    bool alive;
    string rbuf;

    /// Spawns `zan-lsp --port N`, connects and runs the LSP initialize
    /// handshake with `root` as the workspace root (enables project-wide
    /// indexing). Returns null when the server cannot be reached.
    static LspSession Start(string root) {
        string exe = ZanIDE.ToolchainDir() + "/zan-lsp" + ZanIDE.ExeSuffix();
        if (!File.Exists(exe)) { exe = ZanIDE.ExeDir() + "/zan-lsp" + ZanIDE.ExeSuffix(); }
        if (!File.Exists(exe)) { return null; }
        int attempt = 0;
        while (attempt < 4) {
            int port = 47411 + attempt;
            Process.RunDetached("\"" + exe + "\" --port " + Convert.ToString(port));
            LspSession s = LspSession.Open(port, root);
            if (s != null) { return s; }
            attempt = attempt + 1;
        }
        return null;
    }

    static LspSession Open(int port, string root) {
        LspSession d = new LspSession();
        d.sock = 0 - 1;
        d.seq = 1;
        d.alive = false;
        d.rbuf = "";

        #if WINDOWS
        string wsa = calloc(512, 1);
        ws_startup(514, wsa);
        free(wsa);
        #endif

        int s = ws_socket(2, 1, 6);
        if (s < 0) { return null; }
        d.sock = s;

        bool connected = false;
        int tries = 0;
        while (tries < 100 && !connected) {
            string addr = d.BuildAddr(port);
            int r = ws_connect(s, addr, 16);
            free(addr);
            if (r == 0) { connected = true; }
            else { d.SnoozeMs(20); tries = tries + 1; }
        }
        if (!connected) { ws_close(s); return null; }
        d.alive = true;

        string m = d.RequestWait("initialize",
            "{\"processId\":null,\"rootUri\":\"" + LspSession.PathToUri(root)
            + "\",\"capabilities\":{}}");
        if (m.Length == 0) { d.Shutdown(); return null; }
        d.Notify("initialized", "{}");
        return d;
    }

    bool Alive() { return this.alive; }

    void Shutdown() {
        if (this.sock >= 0) {
            if (this.alive) {
                this.RequestWait("shutdown", "");
                this.Notify("exit", "");
            }
            ws_close(this.sock);
            this.sock = 0 - 1;
        }
        this.alive = false;
    }

    /// Pushes the full current buffer for `path` so subsequent semantic
    /// queries see unsaved edits (full-sync didOpen upserts the document).
    void SyncDoc(string path, string text) {
        this.Notify("textDocument/didOpen",
            "{\"textDocument\":{\"uri\":\"" + LspSession.PathToUri(path)
            + "\",\"languageId\":\"zan\",\"version\":1,\"text\":\""
            + DebugSession.JsonEsc(text) + "\"}}");
    }

    /// Semantic go-to-definition. Returns "path\tline0" (0-based line) or "".
    string Definition(string path, int line0, int col0) {
        string m = this.RequestWait("textDocument/definition",
            LspSession.PosParams(path, line0, col0));
        if (m.Length == 0) { return ""; }
        string uri = DebugSession.JsonStr(m, "uri", 0);
        if (uri.Length == 0) { return ""; }
        int ui = DebugSession.IndexOf(m, "\"uri\":", 0);
        int ln = DebugSession.JsonInt(m, "line", ui);
        return LspSession.UriToPath(uri) + "\t" + Convert.ToString(ln);
    }

    /// Semantic find-references. Returns "path\tline0" rows.
    List<string> References(string path, int line0, int col0) {
        List<string> outp = new List<string>();
        string m = this.RequestWait("textDocument/references",
            "{\"textDocument\":{\"uri\":\"" + LspSession.PathToUri(path)
            + "\"},\"position\":{\"line\":" + Convert.ToString(line0)
            + ",\"character\":" + Convert.ToString(col0)
            + "},\"context\":{\"includeDeclaration\":true}}");
        if (m.Length == 0) { return outp; }
        int p = 0;
        int count = 0;
        while (count < 1000) {
            int ui = DebugSession.IndexOf(m, "\"uri\":", p);
            if (ui < 0) { break; }
            string uri = DebugSession.JsonStr(m, "uri", ui);
            int ln = DebugSession.JsonInt(m, "line", ui);
            outp.Add(LspSession.UriToPath(uri) + "\t" + Convert.ToString(ln));
            p = ui + 6;
            count = count + 1;
        }
        return outp;
    }

    /// Hover text for the symbol at the position ("" when none).
    string Hover(string path, int line0, int col0) {
        string m = this.RequestWait("textDocument/hover",
            LspSession.PosParams(path, line0, col0));
        if (m.Length == 0) { return ""; }
        return DebugSession.JsonStr(m, "value", 0);
    }

    static string PosParams(string path, int line0, int col0) {
        return "{\"textDocument\":{\"uri\":\"" + LspSession.PathToUri(path)
            + "\"},\"position\":{\"line\":" + Convert.ToString(line0)
            + ",\"character\":" + Convert.ToString(col0) + "}}";
    }

    /// file:///-style URI from a native path (backslashes normalized).
    static string PathToUri(string path) {
        string p = "";
        int i = 0;
        while (i < path.Length) {
            string ch = path.Substring(i, 1);
            if (ch == "\\") { p = p + "/"; } else { p = p + ch; }
            i = i + 1;
        }
        if (p.Length > 0 && p.Substring(0, 1) == "/") { return "file://" + p; }
        return "file:///" + p;
    }

    static string UriToPath(string uri) {
        string p = uri;
        if (p.Length > 8 && p.Substring(0, 8) == "file:///") { p = p.Substring(8, p.Length - 8); }
        else if (p.Length > 7 && p.Substring(0, 7) == "file://") { p = p.Substring(7, p.Length - 7); }
        // %3A -> ':' (some servers percent-encode the drive colon)
        string res = "";
        int i = 0;
        while (i < p.Length) {
            if (i + 3 <= p.Length && (p.Substring(i, 3) == "%3A" || p.Substring(i, 3) == "%3a")) {
                res = res + ":";
                i = i + 3;
            } else {
                res = res + p.Substring(i, 1);
                i = i + 1;
            }
        }
        return res;
    }

    // ---- transport ----

    void SnoozeMs(int ms) {
        #if WINDOWS
        plat_sleep(ms);
        #else
        plat_usleep(ms * 1000);
        #endif
    }

    string BuildAddr(int port) {
        string addr = calloc(16, 1);
        #if MACOS
        addr[0] = 16;
        addr[1] = 2;
        #else
        addr[0] = 2;
        addr[1] = 0;
        #endif
        int nport = ws_htons(port);
        addr[2] = nport & 255;
        addr[3] = (nport >> 8) & 255;
        int ip = ws_inet_addr("127.0.0.1");
        addr[4] = ip & 255;
        addr[5] = (ip >> 8) & 255;
        addr[6] = (ip >> 16) & 255;
        addr[7] = (ip >> 24) & 255;
        return addr;
    }

    void SendAll(string data) {
        int total = strlen(data);
        int off = 0;
        while (off < total) {
            string chunk = data;
            if (off > 0) { chunk = data.Substring(off, total - off); }
            int n = ws_send(this.sock, chunk, total - off, 0);
            if (n <= 0) { this.alive = false; return; }
            off = off + n;
        }
    }

    void SendMsg(string body) {
        string msg = "Content-Length: " + Convert.ToString(strlen(body))
            + "\r\n\r\n" + body;
        this.SendAll(msg);
    }

    void Notify(string method, string paramsJson) {
        string body = "{\"jsonrpc\":\"2.0\",\"method\":\"" + method + "\"";
        if (paramsJson.Length > 0) { body = body + ",\"params\":" + paramsJson; }
        body = body + "}";
        this.SendMsg(body);
    }

    /// Sends a request and blocks until its response arrives (notifications
    /// such as publishDiagnostics that arrive in between are skipped).
    string RequestWait(string method, string paramsJson) {
        if (!this.alive) { return ""; }
        int id = this.seq;
        this.seq = this.seq + 1;
        string body = "{\"jsonrpc\":\"2.0\",\"id\":" + Convert.ToString(id)
            + ",\"method\":\"" + method + "\"";
        if (paramsJson.Length > 0) { body = body + ",\"params\":" + paramsJson; }
        body = body + "}";
        this.SendMsg(body);
        int guard = 0;
        while (guard < 100000) {
            guard = guard + 1;
            string m = this.ReadMsg();
            if (m.Length == 0) { return ""; }
            if (DebugSession.IndexOf(m, "\"id\":" + Convert.ToString(id), 0) >= 0
                && DebugSession.IndexOf(m, "\"result\"", 0) >= 0) {
                return m;
            }
        }
        return "";
    }

    string RecvChunk() {
        int cap = 65536;
        string buf = calloc(cap + 1, 1);
        int n = ws_recv(this.sock, buf, cap, 0);
        if (n <= 0) { free(buf); return ""; }
        string res = buf.Substring(0, n);
        free(buf);
        return res;
    }

    string ReadMsg() {
        int guard = 0;
        while (guard < 1000000) {
            guard = guard + 1;
            int he = DebugSession.IndexOf(this.rbuf, "\r\n\r\n", 0);
            if (he >= 0) {
                string header = this.rbuf.Substring(0, he);
                int cl = DebugSession.HeaderLen(header);
                int start = he + 4;
                if (cl >= 0 && this.rbuf.Length >= start + cl) {
                    string body = this.rbuf.Substring(start, cl);
                    int rest = this.rbuf.Length - start - cl;
                    this.rbuf = this.rbuf.Substring(start + cl, rest);
                    return body;
                }
            }
            string chunk = this.RecvChunk();
            if (chunk.Length == 0) { this.alive = false; return ""; }
            this.rbuf = this.rbuf + chunk;
        }
        return "";
    }
}
