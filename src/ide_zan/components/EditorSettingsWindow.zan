using System;
using System.Json;
using Gui;

class EditorSettingsWindow {
    App host;
    UiDoc ui;
    JsonValue model;
    int themeIndex;
    int fontSize;
    int language;
    int defaultFontSize;
    bool open;
    bool saved;
    bool languageChanged;
    static bool done;
    static bool resetFont;

    static string T(int lang, string en, string zh) {
        if (lang == 1) { return zh; }
        return en;
    }

    static string JsonEsc(string s) {
        string outp = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\\") { outp = outp + "\\\\"; }
            else if (ch == "\"") { outp = outp + "\\\""; }
            else { outp = outp + ch; }
            i = i + 1;
        }
        return outp;
    }

    static string DocJson(int lang) {
        string s = "{ \"type\":\"WindowShell\", \"text\":\""
            + EditorSettingsWindow.JsonEsc(EditorSettingsWindow.T(
                lang, "Editor Settings", "编辑器设置"))
            + "\", \"onClose\":\"done\", \"children\":[";
        s = s + "{ \"type\":\"Column\", \"dock\":\"fill\", \"pad\":18, \"gap\":8, \"children\":[";
        s = s + "{ \"type\":\"Label\", \"variant\":2, \"dock\":\"top\", \"height\":20, \"text\":\""
            + EditorSettingsWindow.JsonEsc(EditorSettingsWindow.T(
                lang, "Color Theme", "配色主题")) + "\" },";
        int i = 0;
        while (i < ZanIDE.EditorThemeCount()) {
            s = s + "{ \"type\":\"ThemeCard\", \"index\":" + Convert.ToString(i)
                + ", \"dock\":\"top\", \"height\":38, \"bind\":\"themeIdx\" },";
            i = i + 1;
        }
        s = s + "{ \"type\":\"Label\", \"variant\":2, \"dock\":\"top\", \"height\":20, \"text\":\""
            + EditorSettingsWindow.JsonEsc(EditorSettingsWindow.T(
                lang, "Font Size", "字体大小")) + "\" },";
        s = s + "{ \"type\":\"Row\", \"dock\":\"top\", \"height\":34, \"gap\":10, \"children\":[";
        s = s + "{ \"type\":\"Slider\", \"min\":9, \"max\":30, \"bind\":\"font\", \"dock\":\"left\", \"width\":300 },";
        s = s + "{ \"type\":\"Label\", \"dock\":\"left\", \"width\":44, \"bind\":{\"path\":\"font\",\"prop\":\"text\"} },";
        s = s + "{ \"type\":\"Label\", \"dock\":\"left\", \"width\":24, \"text\":\"px\" },";
        s = s + "{ \"type\":\"Button\", \"onClick\":\"resetFont\", \"dock\":\"left\", \"width\":100, \"text\":\""
            + EditorSettingsWindow.JsonEsc(EditorSettingsWindow.T(
                lang, "Default", "默认")) + "\" } ] },";
        s = s + "{ \"type\":\"Label\", \"variant\":2, \"dock\":\"top\", \"height\":20, \"text\":\""
            + EditorSettingsWindow.JsonEsc(EditorSettingsWindow.T(
                lang, "Language", "界面语言")) + "\" },";
        s = s + "{ \"type\":\"Row\", \"dock\":\"top\", \"height\":34, \"gap\":8, \"children\":[";
        int j = 0;
        while (j < 2) {
            string label = "English";
            if (j == 1) { label = "简体中文"; }
            s = s + "{ \"type\":\"Segment\", \"index\":"
                + Convert.ToString(j) + ", \"label\":\""
                + EditorSettingsWindow.JsonEsc(label)
                + "\", \"dock\":\"left\", \"width\":130, \"bind\":\"lang\" }";
            j = j + 1;
            if (j < 2) { s = s + ","; }
        }
        s = s + "] },";
        s = s + "{ \"type\":\"Row\", \"dock\":\"top\", \"height\":40, \"gap\":10, \"children\":[";
        s = s + "{ \"type\":\"Button\", \"onClick\":\"done\", \"dock\":\"right\", \"width\":120, \"text\":\""
            + EditorSettingsWindow.JsonEsc(EditorSettingsWindow.T(
                lang, "Done", "完成")) + "\" } ] }";
        s = s + "] }] }";
        return s;
    }

    static void OnDone() {
        EditorSettingsWindow.done = true;
    }

    static void OnResetFont() {
        EditorSettingsWindow.resetFont = true;
    }

    void BuildUi() {
        ui = UiDoc.FromJson(
            EditorSettingsWindow.DocJson(language)).Bind(model);
        ui.Handle("done", EditorSettingsWindow.OnDone);
        ui.Handle("resetFont", EditorSettingsWindow.OnResetFont);
        ui.Wire();
    }

    static EditorSettingsWindow Open(
            App parent, int theme, int font, int lang, int defaultFont) {
        EditorSettingsWindow w = new EditorSettingsWindow();
        w.themeIndex = theme;
        w.fontSize = font;
        w.language = lang;
        w.defaultFontSize = defaultFont;
        w.open = true;
        w.saved = false;
        w.languageChanged = false;
        EditorSettingsWindow.done = false;
        EditorSettingsWindow.resetFont = false;
        w.model = JsonValue.NewObject();
        w.model.Set("themeIdx", JsonValue.NewNum(Convert.ToString(theme)));
        w.model.Set("font", JsonValue.NewNum(Convert.ToString(
            ZanIDE.EditorFontOr(font, defaultFont))));
        w.model.Set("lang", JsonValue.NewNum(Convert.ToString(lang)));
        w.BuildUi();
        w.host = App.CreateDark(
            EditorSettingsWindow.T(lang, "Editor Settings", "编辑器设置"),
            560, 600);
        w.host.ApplySkin(parent.ThemeMenuIndex());
        w.host.Show();
        return w;
    }

    bool IsOpen() { return open; }

    bool OwnsWindow(int hwnd) {
        return open && hwnd == host.WindowHandle();
    }

    bool NeedsRedraw() {
        return open && host.needsRedraw;
    }

    void ApplyEvent(int hwnd) {
        if (!this.OwnsWindow(hwnd)) { return; }
        if (host.window.EventKind() == 8) {
            open = false;
            return;
        }
        host.ApplyEvent(hwnd);
    }

    void Render() {
        if (!this.NeedsRedraw()) { return; }
        host.BeginFrame();
        ui.RenderInto(host, 0, 0, host.canvas.Width(), host.canvas.Height());
        host.PresentFrame();

        if (EditorSettingsWindow.resetFont) {
            model.Set("font", JsonValue.NewNum(
                Convert.ToString(defaultFontSize)));
            fontSize = 0;
            EditorSettingsWindow.resetFont = false;
            host.RequestRedraw();
        }

        themeIndex = model.PathGet("themeIdx").AsInt(themeIndex);
        int boundFont = model.PathGet("font").AsInt(
            ZanIDE.EditorFontOr(fontSize, defaultFontSize));
        if (fontSize != 0 || boundFont != defaultFontSize) {
            fontSize = boundFont;
        }
        int nextLanguage = model.PathGet("lang").AsInt(language);
        if (nextLanguage != language) {
            language = nextLanguage;
            languageChanged = true;
            this.BuildUi();
            host.RequestRedraw();
        }
        if (EditorSettingsWindow.done) {
            saved = true;
            open = false;
            EditorSettingsWindow.done = false;
            host.window.Close();
        }
    }

    int ThemeIndex() { return themeIndex; }
    int FontSize() { return fontSize; }
    int Language() { return language; }

    bool TakeLanguageChanged() {
        bool v = languageChanged;
        languageChanged = false;
        return v;
    }

    bool TakeSaved() {
        bool v = saved;
        saved = false;
        return v;
    }
}
