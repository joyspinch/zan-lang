using System;
using System.Collections;
namespace Zan;

// Binder: collects top-level type declarations into a symbol table and
// resolves type/field/method names. Mirrors src/compiler/binder.c for the
// bootstrap subset. Uses linear lookup over declaration lists (no dependency
// on Dictionary, which gen0 does not fully support).
class Binder {
    public List<Node> types;   // class/struct/enum decls across all units
    public List<string> tparams; // generic type-parameter names across all units
    public List<string> delegates; // named delegate types (lowered as closures)
    public List<Node> delegDecls;  // their declaration nodes (params + return type)

    public Binder() { types = new List<Node>(); tparams = new List<string>(); delegates = new List<string>(); delegDecls = new List<Node>(); }

    // Register every type declaration in a compilation unit.
    public void Bind(Node unit) {
        int i = 0;
        while (i < unit.kids.Count) {
            Node d = unit.kids[i];
            if (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl() || d.kind == AK.EnumDecl()) {
                types.Add(d);
                int j = 0;
                while (j < d.kids.Count) {
                    Node dm = d.kids[j];
                    if (dm.kind == AK.TypeParam()) { tparams.Add(dm.sval); }
                    else {
                        int k = 0;
                        while (k < dm.kids.Count) {
                            if (dm.kids[k].kind == AK.TypeParam()) { tparams.Add(dm.kids[k].sval); }
                            k = k + 1;
                        }
                    }
                    j = j + 1;
                }
            } else if (d.kind == AK.DelegateDecl()) {
                delegates.Add(d.sval);
                delegDecls.Add(d);
            }
            i = i + 1;
        }
    }

    public Node FindDelegate(string name) {
        int i = 0;
        while (i < delegDecls.Count) {
            if (delegDecls[i].sval == name) { return delegDecls[i]; }
            i = i + 1;
        }
        return null;
    }

    public bool IsDelegateName(string name) {
        if (name == "Func") { return true; }
        if (name == "Action") { return true; }
        int i = 0;
        while (i < delegates.Count) { if (delegates[i] == name) { return true; } i = i + 1; }
        return false;
    }

    public bool IsTypeParam(string name) {
        int i = 0;
        while (i < tparams.Count) { if (tparams[i] == name) { return true; } i = i + 1; }
        return false;
    }

    public Node FindType(string name) {
        int i = 0;
        while (i < types.Count) {
            if (types[i].sval == name) { return types[i]; }
            i = i + 1;
        }
        return null;
    }

    public bool IsPrimitive(string name) {
        if (name == "int") { return true; }
        if (name == "long") { return true; }
        if (name == "bool") { return true; }
        if (name == "string") { return true; }
        if (name == "char") { return true; }
        if (name == "double") { return true; }
        if (name == "float") { return true; }
        if (name == "void") { return true; }
        if (name == "object") { return true; }
        if (name == "byte") { return true; }
        if (name == "short") { return true; }
        if (name == "uint") { return true; }
        if (name == "ulong") { return true; }
        if (name == "ushort") { return true; }
        if (name == "sbyte") { return true; }
        if (name == "decimal") { return true; }
        if (name == "var") { return true; }
        return false;
    }

    // Container generics recognised by the backend.
    public bool IsBuiltinGeneric(string name) {
        if (name == "List") { return true; }
        if (name == "Dictionary") { return true; }
        if (name == "Dict") { return true; }
        if (name == "StringBuilder") { return true; }
        if (name == "Func") { return true; }
        if (name == "Action") { return true; }
        if (name == "Tuple") { return true; }
        return false;
    }

    public Node FindField(Node cls, string name) {
        if (cls == null) { return null; }
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.FieldDecl() && m.sval == name) { return m; }
            i = i + 1;
        }
        return null;
    }

    public Node FindMethod(Node cls, string name) {
        if (cls == null) { return null; }
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.MethodDecl() && m.sval == name) { return m; }
            i = i + 1;
        }
        return null;
    }

    Node FirstParam(Node m) {
        int i = 0;
        while (i < m.kids.Count) { if (m.kids[i].kind == AK.Param()) { return m.kids[i]; } i = i + 1; }
        return null;
    }

    // Find an extension method `name` (static, marked with a `this` receiver of
    // type recvTy) anywhere in the program. ownerOut receives its class name.
    public Node FindExtension(string recvTy, string name, List<string> ownerOut) {
        int i = 0;
        while (i < types.Count) {
            Node cls = types[i];
            int j = 0;
            while (j < cls.kids.Count) {
                Node m = cls.kids[j];
                if (m.kind == AK.MethodDecl() && m.sval == name && m.ival == 1) {
                    Node p0 = FirstParam(m);
                    if (p0 != null && p0.type != null && p0.type.sval == recvTy) {
                        ownerOut.Add(cls.sval);
                        return m;
                    }
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return null;
    }

    public Node FindCtor(Node cls) {
        if (cls == null) { return null; }
        int i = 0;
        while (i < cls.kids.Count) {
            if (cls.kids[i].kind == AK.CtorDecl()) { return cls.kids[i]; }
            i = i + 1;
        }
        return null;
    }
}
