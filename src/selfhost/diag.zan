using System;
using System.Collections;
namespace Zan;

// One diagnostic message with source position.
class Diag {
    public string msg;
    public int line;
    public int col;
    public Diag(string m, int ln, int c) { msg = m; line = ln; col = c; }
}

// Diagnostic sink shared across compiler phases.
class Diags {
    public List<Diag> items;
    public Diags() { items = new List<Diag>(); }
    public void Error(string m, int line, int col) { items.Add(new Diag(m, line, col)); }
    public int Count() { return items.Count; }
    public bool HasErrors() { return items.Count > 0; }
}
