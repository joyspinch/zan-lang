using System;
using System.Collections;
namespace Zan;

// A generated value: its LLVM operand text plus the source type node it has.
class ExprVal {
    public string op;
    public Node ty;
    public ExprVal(string o, Node t) { op = o; ty = t; }
}

// IR backend: lowers the bound AST to LLVM IR text. Mirrors src/compiler/
// irgen.c for the bootstrap subset. Integer/bool/char/enum are i64; string is
// i8*; class/struct instances are heap objects referenced by %Name*; List<T>
// is a growable i64-slot runtime array referenced by i8* (pointer elements are
// stored via ptrtoint / read back via inttoptr).
class Irgen {
    public Binder binder;
    public Diags diags;
    public StringBuilder head;
    public StringBuilder body;
    public int tmp;
    public int lbl;
    public int strn;
    public bool term;
    public string curClass;
    public string curRet;
    public bool curHasThis;
    public List<string> locName;
    public List<Node> locType;
    public List<string> locReg;
    public int locSeq;
    public string curLbl;
    public int brkTarget;
    public int contTarget;
    public List<string> tparamNames;
    public StringBuilder deferred; // hoisted lambda function definitions
    public int lamCount;
    public List<string> stmtTemps;
    public List<Node> stmtTempTypes;
    public int loopScopeBase;
    public List<string> externDecls; // extern C symbols already `declare`d

    public Irgen(Binder b, Diags d) {
        binder = b; diags = d;
        head = new StringBuilder(); body = new StringBuilder();
        deferred = new StringBuilder(); lamCount = 0;
        tmp = 0; lbl = 0; strn = 0; term = false;
        curClass = ""; curRet = "void"; curHasThis = false;
        locName = new List<string>();
        locType = new List<Node>();
        locReg = new List<string>();
        locSeq = 0;
        curLbl = "entry";
        brkTarget = 0; contTarget = 0;
        tparamNames = new List<string>();
        stmtTemps = new List<string>();
        stmtTempTypes = new List<Node>();
        loopScopeBase = 0;
        externDecls = new List<string>();
    }

    // The raw C-ABI symbol an extern (DllImport) method binds to: the
    // EntryPoint override when given (stored in sval2), else the method name.
    string ExternName(Node m) {
        if (m.sval2 != "") { return m.sval2; }
        return m.sval;
    }

    // Pre-register the C symbols already `declare`d in the module header so a
    // [DllImport] of e.g. calloc/malloc does not emit a duplicate declaration.
    void SeedExternBuiltins() {
        externDecls.Add("printf"); externDecls.Add("malloc"); externDecls.Add("calloc");
        externDecls.Add("realloc"); externDecls.Add("free"); externDecls.Add("strlen");
        externDecls.Add("strcmp"); externDecls.Add("strcpy"); externDecls.Add("strcat");
        externDecls.Add("memcpy"); externDecls.Add("snprintf"); externDecls.Add("fopen");
        externDecls.Add("fseek"); externDecls.Add("ftell"); externDecls.Add("fread");
        externDecls.Add("fwrite"); externDecls.Add("fclose"); externDecls.Add("_setjmp");
        externDecls.Add("longjmp"); externDecls.Add("exit");
    }

    bool ExternSeen(string name) {
        int i = 0;
        while (i < externDecls.Count) {
            if (externDecls[i] == name) { return true; }
            i = i + 1;
        }
        return false;
    }

    // Emit `declare <ret> @<sym>(<params>)` for a [DllImport] extern method,
    // deduplicated against builtins and prior declarations. Calls route to the
    // raw symbol via MethodSym.
    void DeclareExtern(Node cls, Node m) {
        string sym = ExternName(m);
        if (ExternSeen(sym)) { return; }
        externDecls.Add(sym);
        string rt = MapType(m.type);
        string sig = "declare " + rt + " @" + sym + "(";
        int first = 1;
        int i = 0;
        while (i < m.kids.Count) {
            Node p = m.kids[i];
            if (p.kind == AK.Param()) {
                if (first == 0) { sig = sig + ", "; }
                sig = sig + MapType(p.type);
                first = 0;
            }
            i = i + 1;
        }
        sig = sig + ")";
        H(sig);
    }

    string NT() { tmp = tmp + 1; return "%t" + tmp; }
    int NL() { lbl = lbl + 1; return lbl; }
    void L(string s) { body.Append(s); body.Append("\n"); }
    void H(string s) { head.Append(s); head.Append("\n"); }
    void Label(int n) { body.Append("L" + n + ":\n"); term = false; curLbl = "L" + n; }

    Node MkType(string name) { Node t = new Node(AK.TypeRef()); t.sval = name; return t; }

    // ---- type mapping ----
    // ---- generics (type erasure) ----
    // A type is "erased" if its name is a generic type parameter of some class;
    // all such types are lowered to i64 slots (pointers packed via ptrtoint).
    bool IsErasedType(Node t) {
        if (t == null) { return false; }
        int i = 0;
        while (i < tparamNames.Count) { if (tparamNames[i] == t.sval) { return true; } i = i + 1; }
        return false;
    }

    List<string> TParams(Node cls) {
        List<string> r = new List<string>();
        if (cls == null) { return r; }
        int i = 0;
        while (i < cls.kids.Count) {
            if (cls.kids[i].kind == AK.TypeParam()) { r.Add(cls.kids[i].sval); }
            i = i + 1;
        }
        return r;
    }

    // resolve an erased type to the concrete argument supplied by a receiver's
    // static type (e.g. T in Box<int> -> int); returns t itself when unresolved.
    Node ConcreteTP(Node t, Node recvTy) {
        if (!IsErasedType(t)) { return t; }
        if (recvTy == null) { return t; }
        Node cls = binder.FindType(recvTy.sval);
        List<string> tps = TParams(cls);
        int i = 0;
        while (i < tps.Count) {
            if (tps[i] == t.sval) {
                if (i < recvTy.kids.Count) { return recvTy.kids[i]; }
                return t;
            }
            i = i + 1;
        }
        return t;
    }

    bool IsNullable(Node t) { return t != null && t.op == 1; }

    bool IsPrimValue(Node t) {
        if (t == null) { return false; }
        string n = t.sval;
        return n == "int" || n == "long" || n == "bool" || n == "char" || n == "byte" || n == "short" || n == "double" || n == "float";
    }

    bool IsNullableValue(Node t) { return IsNullable(t) && IsPrimValue(t); }

    string UnderLL(Node t) {
        if (t.sval == "double" || t.sval == "float") { return "double"; }
        return "i64";
    }

    // box a value into a heap slot, returning the i8* handle (null = no value)
    string BoxVal(ExprVal v, Node ty) {
        string ult = UnderLL(ty);
        string raw = NT();
        L("  " + raw + " = call i8* @malloc(i64 8)");
        string p = NT();
        L("  " + p + " = bitcast i8* " + raw + " to " + ult + "*");
        L("  store " + ult + " " + Coerce(v, ult) + ", " + ult + "* " + p);
        return raw;
    }

    // operand to store into a nullable value-type slot (i8*)
    string BoxFor(ExprVal v, Node ty) {
        if (v.op == "null") { return "null"; }
        if (IsNullableValue(v.ty)) { return v.op; }
        return BoxVal(v, ty);
    }

    string MapType(Node t) {
        if (t == null) { return "void"; }
        string n = t.sval;
        if (IsNullableValue(t)) { return "i8*"; }
        if (IsErasedType(t)) { return "i64"; }
        if (n == "void") { return "void"; }
        if (n == "string") { return "i8*"; }
        if (n == "double" || n == "float") { return "double"; }
        if (n == "int" || n == "long" || n == "bool" || n == "char" || n == "byte" || n == "short") { return "i64"; }
        if (n == "object" || n == "var") { return "i8*"; }
        if (n == "List" || n == "Dictionary" || n == "Dict") { return "i8*"; }
        if (n == "StringBuilder") { return "i8*"; }
        Node d = binder.FindType(n);
        if (d != null) {
            if (d.kind == AK.EnumDecl()) { return "i64"; }
            return "%" + n + "*";
        }
        return "i8*";
    }

    bool IsPtrType(Node t) {
        string m = MapType(t);
        if (m == "i8*") { return true; }
        int L2 = m.Length;
        if (L2 > 0 && m.Substring(L2 - 1, 1) == "*") { return true; }
        return false;
    }

    bool IsListType(Node t) {
        if (t == null) { return false; }
        if (t.sval == "List") { return true; }
        return false;
    }

    bool IsSbType(Node t) {
        if (t == null) { return false; }
        if (t.sval == "StringBuilder") { return true; }
        return false;
    }

    bool IsDictType(Node t) {
        if (t == null) { return false; }
        if (t.sval == "Dictionary") { return true; }
        if (t.sval == "Dict") { return true; }
        return false;
    }

    Node DictVal(Node t) {
        if (t != null && t.kids.Count > 1) { return t.kids[1]; }
        return MkType("int");
    }

    Node ListElem(Node t) {
        if (t != null && t.kids.Count > 0) { return t.kids[0]; }
        return MkType("int");
    }

    // class decl referenced by a class-pointer type, or null
    Node ClassOf(Node t) {
        if (t == null) { return null; }
        Node d = binder.FindType(t.sval);
        if (d != null && (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl())) { return d; }
        return null;
    }

    // ---- inheritance / virtual dispatch helpers ----
    Node BaseClassOf(Node cls) {
        if (cls == null) { return null; }
        if (cls.sval2 == "") { return null; }
        return binder.FindType(cls.sval2);
    }

    bool HasMod(Node m, int flag) { return (m.mods / flag) - ((m.mods / flag) / 2) * 2 == 1; }
    bool IsVirtual(Node m) { return HasMod(m, MOD.Virtual()); }
    bool IsOverride(Node m) { return HasMod(m, MOD.Override()); }
    bool IsAbstract(Node m) { return HasMod(m, MOD.Abstract()); }
    // introduces a fresh vtable slot: virtual or abstract, but not an override
    bool IsVSlotIntro(Node m) { return (IsVirtual(m) || IsAbstract(m)) && !IsOverride(m); }

    // A class is polymorphic if it or any ancestor declares a virtual/abstract/
    // override method; such classes carry a vtable pointer in field slot 0.
    // Interfaces are modelled as abstract classes and are polymorphic too.
    bool IsPolyClass(Node cls) {
        if (cls == null) { return false; }
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.MethodDecl() && (IsVirtual(m) || IsOverride(m) || IsAbstract(m))) { return true; }
            i = i + 1;
        }
        return IsPolyClass(BaseClassOf(cls));
    }

    // field slot offset: 1 when a vtable pointer occupies slot 0
    int FieldBase(Node cls) { if (IsPolyClass(cls)) { return 1; } return 0; }

    // ordered fields, base classes first (layout-compatible with base pointers)
    void CollectFields(Node cls, List<string> names, List<Node> types) {
        if (cls == null) { return; }
        CollectFields(BaseClassOf(cls), names, types);
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.FieldDecl()) { names.Add(m.sval); types.Add(m.type); }
            i = i + 1;
        }
    }

    int FieldIndex(Node cls, string name) {
        List<string> names = new List<string>();
        List<Node> types = new List<Node>();
        CollectFields(cls, names, types);
        int i = 0;
        while (i < names.Count) {
            if (names[i] == name) { return FieldBase(cls) + i; }
            i = i + 1;
        }
        return -1;
    }

    Node FieldType(Node cls, string name) {
        List<string> names = new List<string>();
        List<Node> types = new List<Node>();
        CollectFields(cls, names, types);
        int i = 0;
        while (i < names.Count) {
            if (names[i] == name) { return types[i]; }
            i = i + 1;
        }
        return null;
    }

    // ---- locals ----
    string AddLocal(string name, Node ty) {
        locSeq = locSeq + 1;
        string r = "%v." + name + "." + locSeq;
        locName.Add(name); locType.Add(ty); locReg.Add(r);
        return r;
    }
    string RegOf(string name) { int i = LocalIdx(name); if (i < 0) { return "%v." + name; } return locReg[i]; }
    int LocalIdx(string name) {
        int i = locName.Count - 1;
        while (i >= 0) { if (locName[i] == name) { return i; } i = i - 1; }
        return -1;
    }

    // ---- string helpers ----
    string HEXD(int d) { return "0123456789ABCDEF".Substring(d, 1); }
    string Hex2(int b) { int hi = b / 16; int lo = b - hi * 16; return HEXD(hi) + HEXD(lo); }

    List<int> DecodeStr(string raw) {
        List<int> r = new List<int>();
        int i = 0;
        while (i < raw.Length) {
            int c = (int)raw[i];
            if (c == 92 && i + 1 < raw.Length) {
                int nx = (int)raw[i + 1];
                int dv = nx;
                if (nx == 110) { dv = 10; }
                else if (nx == 116) { dv = 9; }
                else if (nx == 114) { dv = 13; }
                else if (nx == 48) { dv = 0; }
                r.Add(dv);
                i = i + 2;
            } else {
                r.Add(c);
                i = i + 1;
            }
        }
        return r;
    }

    ExprVal GenStr(string raw) {
        List<int> bytes = DecodeStr(raw);
        string bodytxt = "";
        int i = 0;
        while (i < bytes.Count) { bodytxt = bodytxt + "\\" + Hex2(bytes[i]); i = i + 1; }
        bodytxt = bodytxt + "\\00";
        int blen = bytes.Count + 1;
        strn = strn + 1;
        string g = "@.s" + strn;
        H(g + " = private unnamed_addr constant [" + blen + " x i8] c\"" + bodytxt + "\"");
        string t = NT();
        L("  " + t + " = getelementptr inbounds [" + blen + " x i8], [" + blen + " x i8]* " + g + ", i64 0, i64 0");
        return new ExprVal(t, MkType("string"));
    }

    void CollectTParams(Node unit) {
        int i = 0;
        while (i < unit.kids.Count) {
            Node d = unit.kids[i];
            if (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl()) {
                int j = 0;
                while (j < d.kids.Count) {
                    if (d.kids[j].kind == AK.TypeParam()) { tparamNames.Add(d.kids[j].sval); }
                    j = j + 1;
                }
            }
            i = i + 1;
        }
    }

    // ---- driver ----
    public string Gen(Node unit) {
        CollectTParams(unit);
        H("declare i32 @printf(i8*, ...)");
        H("declare i8* @malloc(i64)");
        H("declare i8* @calloc(i64, i64)");
        H("declare i8* @realloc(i8*, i64)");
        H("declare void @free(i8*)");
        H("declare i64 @strlen(i8*)");
        H("declare i32 @strcmp(i8*, i8*)");
        H("declare i8* @strcpy(i8*, i8*)");
        H("declare i8* @strcat(i8*, i8*)");
        H("declare i8* @memcpy(i8*, i8*, i64)");
        H("declare i32 @snprintf(i8*, i64, i8*, ...)");
        H("declare i8* @fopen(i8*, i8*)");
        H("declare i32 @fseek(i8*, i64, i32)");
        H("declare i64 @ftell(i8*)");
        H("declare i64 @fread(i8*, i64, i64, i8*)");
        H("declare i64 @fwrite(i8*, i64, i64, i8*)");
        H("declare i32 @fclose(i8*)");
        H("declare i32 @_setjmp(i8*, i8*)");
        H("declare void @longjmp(i8*, i32)");
        H("declare i8* @llvm.frameaddress.p0(i32)");
        H("declare void @exit(i32)");
        SeedExternBuiltins();
        H("@__exc_sp = global i64 0");
        H("@__exc_stack = global [64 x i8*] zeroinitializer");
        H("@__exc_val = global i8* null");
        H("@__zan_argc = global i32 0");
        H("@__zan_argv = global i8** null");
        H("@.mode_rb = private unnamed_addr constant [3 x i8] c\"rb\\00\"");
        H("@.mode_wb = private unnamed_addr constant [2 x i8] c\"w\\00\"");
        H("@.fmt.nl = private unnamed_addr constant [6 x i8] c\"%lld\\0A\\00\"");
        H("@.fmt.nn = private unnamed_addr constant [5 x i8] c\"%lld\\00\"");
        H("@.fmt.snl = private unnamed_addr constant [4 x i8] c\"%s\\0A\\00\"");
        H("@.fmt.sn = private unnamed_addr constant [3 x i8] c\"%s\\00\"");
        H("@.fmt.gnl = private unnamed_addr constant [4 x i8] c\"%g\\0A\\00\"");
        H("@.fmt.gn = private unnamed_addr constant [3 x i8] c\"%g\\00\"");
        H("@.msg.unhandled = private unnamed_addr constant [21 x i8] c\"Unhandled exception\\0A\\00\"");
        H("@.msg.rderr = private unnamed_addr constant [18 x i8] c\"cannot read file\\0A\\00\"");
        H("@.msg.wrerr = private unnamed_addr constant [19 x i8] c\"cannot write file\\0A\\00\"");
        EmitArcRuntime();
        EmitListRuntime();
        EmitSbRuntime();
        EmitDictRuntime();
        // struct type decls first
        int i = 0;
        while (i < unit.kids.Count) {
            Node d = unit.kids[i];
            if (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl()) { EmitStruct(d); }
            i = i + 1;
        }
        // vtables for polymorphic classes
        i = 0;
        while (i < unit.kids.Count) {
            Node d = unit.kids[i];
            if ((d.kind == AK.ClassDecl() || d.kind == AK.StructDecl()) && IsPolyClass(d) && !HasMod(d, MOD.Abstract())) { EmitVtable(d); }
            i = i + 1;
        }
        // per-class destructors (release ARC-managed fields)
        i = 0;
        while (i < unit.kids.Count) {
            Node d = unit.kids[i];
            if (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl()) { EmitClassDtor(d); }
            i = i + 1;
        }
        // function bodies
        i = 0;
        while (i < unit.kids.Count) {
            Node d = unit.kids[i];
            if (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl()) { GenClass(d); }
            i = i + 1;
        }
        GenMainWrapper(unit);
        return head.ToString() + body.ToString() + deferred.ToString();
    }

    void EmitStruct(Node cls) {
        List<string> names = new List<string>();
        List<Node> types = new List<Node>();
        CollectFields(cls, names, types);
        string s = "%" + cls.sval + " = type { ";
        int cnt = 0;
        if (IsPolyClass(cls)) { s = s + "i8*"; cnt = 1; }
        int i = 0;
        while (i < types.Count) {
            if (cnt > 0) { s = s + ", "; }
            s = s + MapType(types[i]);
            cnt = cnt + 1;
            i = i + 1;
        }
        if (cnt == 0) { s = s + "i64"; }
        s = s + " }";
        H(s);
    }

    void EmitListRuntime() {
        H("%zlist = type { i64, i64, i64*, i64 }");
        H("define void @zlist_dtor(i8* %p) {");
        H("entry:");
        H("  %l = bitcast i8* %p to %zlist*");
        H("  %optr = getelementptr %zlist, %zlist* %l, i32 0, i32 3");
        H("  %owns = load i64, i64* %optr");
        H("  %noown = icmp eq i64 %owns, 0");
        H("  br i1 %noown, label %freedata, label %loopinit");
        H("loopinit:");
        H("  %cptr = getelementptr %zlist, %zlist* %l, i32 0, i32 0");
        H("  %count = load i64, i64* %cptr");
        H("  %dptr = getelementptr %zlist, %zlist* %l, i32 0, i32 2");
        H("  %data = load i64*, i64** %dptr");
        H("  %ia = alloca i64");
        H("  store i64 0, i64* %ia");
        H("  br label %cond");
        H("cond:");
        H("  %i = load i64, i64* %ia");
        H("  %done = icmp sge i64 %i, %count");
        H("  br i1 %done, label %freedata, label %body");
        H("body:");
        H("  %slot = getelementptr i64, i64* %data, i64 %i");
        H("  %ev = load i64, i64* %slot");
        H("  %ep = inttoptr i64 %ev to i8*");
        H("  call void @zrelease(i8* %ep)");
        H("  %ni = add i64 %i, 1");
        H("  store i64 %ni, i64* %ia");
        H("  br label %cond");
        H("freedata:");
        H("  %dptr2 = getelementptr %zlist, %zlist* %l, i32 0, i32 2");
        H("  %data2 = load i64*, i64** %dptr2");
        H("  %datai8 = bitcast i64* %data2 to i8*");
        H("  call void @free(i8* %datai8)");
        H("  ret void");
        H("}");
        H("define i8* @zlist_new(i64 %owns) {");
        H("  %p = call i8* @zalloc(i64 32, i8* bitcast (void (i8*)* @zlist_dtor to i8*))");
        H("  %l = bitcast i8* %p to %zlist*");
        H("  %c = getelementptr %zlist, %zlist* %l, i32 0, i32 0");
        H("  store i64 0, i64* %c");
        H("  %cap = getelementptr %zlist, %zlist* %l, i32 0, i32 1");
        H("  store i64 0, i64* %cap");
        H("  %d = getelementptr %zlist, %zlist* %l, i32 0, i32 2");
        H("  store i64* null, i64** %d");
        H("  %op = getelementptr %zlist, %zlist* %l, i32 0, i32 3");
        H("  store i64 %owns, i64* %op");
        H("  ret i8* %p");
        H("}");
        H("define void @zlist_add(i8* %p, i64 %v) {");
        H("entry:");
        H("  %l = bitcast i8* %p to %zlist*");
        H("  %cptr = getelementptr %zlist, %zlist* %l, i32 0, i32 0");
        H("  %count = load i64, i64* %cptr");
        H("  %capptr = getelementptr %zlist, %zlist* %l, i32 0, i32 1");
        H("  %cap = load i64, i64* %capptr");
        H("  %full = icmp sge i64 %count, %cap");
        H("  br i1 %full, label %grow, label %st");
        H("grow:");
        H("  %nc0 = mul i64 %cap, 2");
        H("  %isz = icmp eq i64 %nc0, 0");
        H("  %nc = select i1 %isz, i64 4, i64 %nc0");
        H("  %dptr = getelementptr %zlist, %zlist* %l, i32 0, i32 2");
        H("  %olddata = load i64*, i64** %dptr");
        H("  %oldi8 = bitcast i64* %olddata to i8*");
        H("  %bytes = mul i64 %nc, 8");
        H("  %newi8 = call i8* @realloc(i8* %oldi8, i64 %bytes)");
        H("  %newdata = bitcast i8* %newi8 to i64*");
        H("  store i64* %newdata, i64** %dptr");
        H("  store i64 %nc, i64* %capptr");
        H("  br label %st");
        H("st:");
        H("  %dptr2 = getelementptr %zlist, %zlist* %l, i32 0, i32 2");
        H("  %data = load i64*, i64** %dptr2");
        H("  %slot = getelementptr i64, i64* %data, i64 %count");
        H("  store i64 %v, i64* %slot");
        H("  %ncount = add i64 %count, 1");
        H("  store i64 %ncount, i64* %cptr");
        H("  %optr = getelementptr %zlist, %zlist* %l, i32 0, i32 3");
        H("  %owns = load i64, i64* %optr");
        H("  %doret = icmp ne i64 %owns, 0");
        H("  br i1 %doret, label %doretain, label %done");
        H("doretain:");
        H("  %vp = inttoptr i64 %v to i8*");
        H("  call void @zretain(i8* %vp)");
        H("  br label %done");
        H("done:");
        H("  ret void");
        H("}");
        H("define i64 @zlist_get(i8* %p, i64 %i) {");
        H("  %l = bitcast i8* %p to %zlist*");
        H("  %dptr = getelementptr %zlist, %zlist* %l, i32 0, i32 2");
        H("  %data = load i64*, i64** %dptr");
        H("  %slot = getelementptr i64, i64* %data, i64 %i");
        H("  %v = load i64, i64* %slot");
        H("  ret i64 %v");
        H("}");
        H("define void @zlist_set(i8* %p, i64 %i, i64 %v) {");
        H("entry:");
        H("  %l = bitcast i8* %p to %zlist*");
        H("  %dptr = getelementptr %zlist, %zlist* %l, i32 0, i32 2");
        H("  %data = load i64*, i64** %dptr");
        H("  %slot = getelementptr i64, i64* %data, i64 %i");
        H("  %old = load i64, i64* %slot");
        H("  store i64 %v, i64* %slot");
        H("  %optr = getelementptr %zlist, %zlist* %l, i32 0, i32 3");
        H("  %owns = load i64, i64* %optr");
        H("  %doarc = icmp ne i64 %owns, 0");
        H("  br i1 %doarc, label %arc, label %done");
        H("arc:");
        H("  %nvp = inttoptr i64 %v to i8*");
        H("  call void @zretain(i8* %nvp)");
        H("  %ovp = inttoptr i64 %old to i8*");
        H("  call void @zrelease(i8* %ovp)");
        H("  br label %done");
        H("done:");
        H("  ret void");
        H("}");
        H("define i64 @zlist_count(i8* %p) {");
        H("  %l = bitcast i8* %p to %zlist*");
        H("  %cptr = getelementptr %zlist, %zlist* %l, i32 0, i32 0");
        H("  %c = load i64, i64* %cptr");
        H("  ret i64 %c");
        H("}");
    }

    // ARC: every heap object carries a hidden 8-byte refcount header that lives
    // immediately BEFORE the pointer handed out, so object field layout, vtable
    // slot 0 and container internals are all unchanged. zalloc initialises the
    // count to 1; zretain/zrelease adjust it; zrelease frees at count 0.
    void EmitArcRuntime() {
        // header layout, 16 bytes before the object pointer: [ i64 refcount ]
        // [ i8* destructor ]. zalloc records both; zrelease at count 0 runs the
        // destructor (which releases members / frees internal buffers) then frees.
        H("define i8* @zalloc(i64 %n, i8* %dtor) {");
        H("  %tot = add i64 %n, 16");
        H("  %raw = call i8* @calloc(i64 1, i64 %tot)");
        H("  %rc = bitcast i8* %raw to i64*");
        H("  store i64 1, i64* %rc");
        H("  %ds0 = getelementptr i8, i8* %raw, i64 8");
        H("  %ds = bitcast i8* %ds0 to i8**");
        H("  store i8* %dtor, i8** %ds");
        H("  %obj = getelementptr i8, i8* %raw, i64 16");
        H("  ret i8* %obj");
        H("}");
        H("define void @zretain(i8* %p) {");
        H("entry:");
        H("  %isnull = icmp eq i8* %p, null");
        H("  br i1 %isnull, label %done, label %go");
        H("go:");
        H("  %hdr = getelementptr i8, i8* %p, i64 -16");
        H("  %rc = bitcast i8* %hdr to i64*");
        H("  %c = load i64, i64* %rc");
        H("  %nc = add i64 %c, 1");
        H("  store i64 %nc, i64* %rc");
        H("  br label %done");
        H("done:");
        H("  ret void");
        H("}");
        H("define void @zrelease(i8* %p) {");
        H("entry:");
        H("  %isnull = icmp eq i8* %p, null");
        H("  br i1 %isnull, label %done, label %go");
        H("go:");
        H("  %hdr = getelementptr i8, i8* %p, i64 -16");
        H("  %rc = bitcast i8* %hdr to i64*");
        H("  %c = load i64, i64* %rc");
        H("  %nc = sub i64 %c, 1");
        H("  store i64 %nc, i64* %rc");
        H("  %dead = icmp sle i64 %nc, 0");
        H("  br i1 %dead, label %dofree, label %done");
        H("dofree:");
        H("  %ds0 = getelementptr i8, i8* %p, i64 -8");
        H("  %ds = bitcast i8* %ds0 to i8**");
        H("  %dtor = load i8*, i8** %ds");
        H("  %hasd = icmp ne i8* %dtor, null");
        H("  br i1 %hasd, label %rund, label %fr");
        H("rund:");
        H("  %fn = bitcast i8* %dtor to void (i8*)*");
        H("  call void %fn(i8* %p)");
        H("  br label %fr");
        H("fr:");
        H("  call void @free(i8* %hdr)");
        H("  br label %done");
        H("done:");
        H("  ret void");
        H("}");
    }

    // is `t` a heap object carrying an ARC header (class/struct instance or one
    // of the built-in containers routed through zalloc)? Strings, primitives,
    // erased generic slots and nullable value boxes are not ARC-managed.
    bool ArcManaged(Node t) {
        if (t == null) { return false; }
        if (IsErasedType(t)) { return false; }
        if (IsNullableValue(t)) { return false; }
        string n = t.sval;
        if (n == "List" || n == "Dictionary" || n == "Dict" || n == "StringBuilder") { return true; }
        Node d = binder.FindType(n);
        if (d != null && (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl())) { return true; }
        return false;
    }

    void EmitArcRetain(string val, Node ty) {
        if (!ArcManaged(ty)) { return; }
        string lt = MapType(ty);
        if (lt == "i8*") {
            L("  call void @zretain(i8* " + val + ")");
        } else {
            string t = NT();
            L("  " + t + " = bitcast " + lt + " " + val + " to i8*");
            L("  call void @zretain(i8* " + t + ")");
        }
    }

    void EmitArcRelease(string val, Node ty) {
        if (!ArcManaged(ty)) { return; }
        string lt = MapType(ty);
        if (lt == "i8*") {
            L("  call void @zrelease(i8* " + val + ")");
        } else {
            string t = NT();
            L("  " + t + " = bitcast " + lt + " " + val + " to i8*");
            L("  call void @zrelease(i8* " + t + ")");
        }
    }

    void EmitLocalReleases() {
        int i = 0;
        while (i < locName.Count) {
            if (ArcManaged(locType[i])) {
                string lt = MapType(locType[i]);
                string t = NT();
                L("  " + t + " = load " + lt + ", " + lt + "* " + locReg[i]);
                EmitArcRelease(t, locType[i]);
            }
            i = i + 1;
        }
    }

    void AddTemp(string op, Node ty) {
        if (ArcManaged(ty)) { stmtTemps.Add(op); stmtTempTypes.Add(ty); }
    }

    void EmitTempReleases() {
        int i = 0;
        while (i < stmtTemps.Count) {
            EmitArcRelease(stmtTemps[i], stmtTempTypes[i]);
            i = i + 1;
        }
        stmtTemps = new List<string>();
        stmtTempTypes = new List<Node>();
    }

    void ReleaseLocalsFrom(int from) {
        int i = from;
        while (i < locName.Count) {
            if (ArcManaged(locType[i])) {
                string lt = MapType(locType[i]);
                string t = NT();
                L("  " + t + " = load " + lt + ", " + lt + "* " + locReg[i]);
                EmitArcRelease(t, locType[i]);
            }
            i = i + 1;
        }
    }

    void TrimLocals(int to) {
        List<string> nn = new List<string>();
        List<Node> nt = new List<Node>();
        List<string> nr = new List<string>();
        int i = 0;
        while (i < to) {
            nn.Add(locName[i]); nt.Add(locType[i]); nr.Add(locReg[i]);
            i = i + 1;
        }
        locName = nn; locType = nt; locReg = nr;
    }

    // per-class destructor: release every ARC-managed field, then return (the
    // object storage itself is freed by zrelease after this runs).
    void EmitClassDtor(Node cls) {
        string cn = cls.sval;
        H("define void @" + cn + "_dtor(i8* %p) {");
        H("  %o = bitcast i8* %p to %" + cn + "*");
        List<string> names = new List<string>();
        List<Node> types = new List<Node>();
        CollectFields(cls, names, types);
        int fb = FieldBase(cls);
        int i = 0;
        int seq = 0;
        while (i < names.Count) {
            if (ArcManaged(types[i])) {
                int idx = fb + i;
                string lt = MapType(types[i]);
                string fp = "%f" + seq;
                string fv = "%v" + seq;
                H("  " + fp + " = getelementptr %" + cn + ", %" + cn + "* %o, i32 0, i32 " + idx);
                H("  " + fv + " = load " + lt + ", " + lt + "* " + fp);
                if (lt == "i8*") {
                    H("  call void @zrelease(i8* " + fv + ")");
                } else {
                    string fc = "%c" + seq;
                    H("  " + fc + " = bitcast " + lt + " " + fv + " to i8*");
                    H("  call void @zrelease(i8* " + fc + ")");
                }
                seq = seq + 1;
            }
            i = i + 1;
        }
        H("  ret void");
        H("}");
    }

    // StringBuilder: growable byte buffer { count, cap, i8* data }. Append is
    // amortised O(1) (capacity doubling); ToString materialises one string.
    void EmitSbRuntime() {
        H("%zsb = type { i64, i64, i8* }");
        H("define void @zsb_dtor(i8* %p) {");
        H("  %b = bitcast i8* %p to %zsb*");
        H("  %dptr = getelementptr %zsb, %zsb* %b, i32 0, i32 2");
        H("  %data = load i8*, i8** %dptr");
        H("  call void @free(i8* %data)");
        H("  ret void");
        H("}");
        H("define i8* @zsb_new() {");
        H("  %p = call i8* @zalloc(i64 24, i8* bitcast (void (i8*)* @zsb_dtor to i8*))");
        H("  %b = bitcast i8* %p to %zsb*");
        H("  %c = getelementptr %zsb, %zsb* %b, i32 0, i32 0");
        H("  store i64 0, i64* %c");
        H("  %cap = getelementptr %zsb, %zsb* %b, i32 0, i32 1");
        H("  store i64 0, i64* %cap");
        H("  %d = getelementptr %zsb, %zsb* %b, i32 0, i32 2");
        H("  store i8* null, i8** %d");
        H("  ret i8* %p");
        H("}");
        H("define void @zsb_append(i8* %p, i8* %s) {");
        H("entry:");
        H("  %b = bitcast i8* %p to %zsb*");
        H("  %slen = call i64 @strlen(i8* %s)");
        H("  %cptr = getelementptr %zsb, %zsb* %b, i32 0, i32 0");
        H("  %count = load i64, i64* %cptr");
        H("  %capptr = getelementptr %zsb, %zsb* %b, i32 0, i32 1");
        H("  %cap = load i64, i64* %capptr");
        H("  %need = add i64 %count, %slen");
        H("  %full = icmp sgt i64 %need, %cap");
        H("  br i1 %full, label %grow, label %st");
        H("grow:");
        H("  %nc0 = mul i64 %cap, 2");
        H("  %small = icmp slt i64 %nc0, %need");
        H("  %nc = select i1 %small, i64 %need, i64 %nc0");
        H("  %dptr = getelementptr %zsb, %zsb* %b, i32 0, i32 2");
        H("  %olddata = load i8*, i8** %dptr");
        H("  %newdata = call i8* @realloc(i8* %olddata, i64 %nc)");
        H("  store i8* %newdata, i8** %dptr");
        H("  store i64 %nc, i64* %capptr");
        H("  br label %st");
        H("st:");
        H("  %dptr2 = getelementptr %zsb, %zsb* %b, i32 0, i32 2");
        H("  %data = load i8*, i8** %dptr2");
        H("  %dest = getelementptr i8, i8* %data, i64 %count");
        H("  call i8* @memcpy(i8* %dest, i8* %s, i64 %slen)");
        H("  %ncount = add i64 %count, %slen");
        H("  store i64 %ncount, i64* %cptr");
        H("  ret void");
        H("}");
        H("define i8* @zsb_tostring(i8* %p) {");
        H("  %b = bitcast i8* %p to %zsb*");
        H("  %cptr = getelementptr %zsb, %zsb* %b, i32 0, i32 0");
        H("  %count = load i64, i64* %cptr");
        H("  %dptr = getelementptr %zsb, %zsb* %b, i32 0, i32 2");
        H("  %data = load i8*, i8** %dptr");
        H("  %bsz = add i64 %count, 1");
        H("  %buf = call i8* @malloc(i64 %bsz)");
        H("  call i8* @memcpy(i8* %buf, i8* %data, i64 %count)");
        H("  %endp = getelementptr i8, i8* %buf, i64 %count");
        H("  store i8 0, i8* %endp");
        H("  ret i8* %buf");
        H("}");
    }

    // Dictionary<string,V>: growable parallel arrays { count, cap, i8** keys,
    // i64* values } with linear-scan lookup. Set updates in place on an existing
    // key, otherwise appends (capacity doubling). Keys are strings (strcmp).
    void EmitDictRuntime() {
        H("%zdict = type { i64, i64, i8**, i64*, i64 }");
        H("define void @zdict_dtor(i8* %p) {");
        H("entry:");
        H("  %d = bitcast i8* %p to %zdict*");
        H("  %optr = getelementptr %zdict, %zdict* %d, i32 0, i32 4");
        H("  %owns = load i64, i64* %optr");
        H("  %noown = icmp eq i64 %owns, 0");
        H("  br i1 %noown, label %freearrs, label %loopinit");
        H("loopinit:");
        H("  %cptr = getelementptr %zdict, %zdict* %d, i32 0, i32 0");
        H("  %count = load i64, i64* %cptr");
        H("  %vptr = getelementptr %zdict, %zdict* %d, i32 0, i32 3");
        H("  %vals = load i64*, i64** %vptr");
        H("  %ia = alloca i64");
        H("  store i64 0, i64* %ia");
        H("  br label %cond");
        H("cond:");
        H("  %i = load i64, i64* %ia");
        H("  %done = icmp sge i64 %i, %count");
        H("  br i1 %done, label %freearrs, label %body");
        H("body:");
        H("  %slot = getelementptr i64, i64* %vals, i64 %i");
        H("  %ev = load i64, i64* %slot");
        H("  %ep = inttoptr i64 %ev to i8*");
        H("  call void @zrelease(i8* %ep)");
        H("  %ni = add i64 %i, 1");
        H("  store i64 %ni, i64* %ia");
        H("  br label %cond");
        H("freearrs:");
        H("  %kptr = getelementptr %zdict, %zdict* %d, i32 0, i32 2");
        H("  %keys = load i8**, i8*** %kptr");
        H("  %keysi8 = bitcast i8** %keys to i8*");
        H("  call void @free(i8* %keysi8)");
        H("  %vptr2 = getelementptr %zdict, %zdict* %d, i32 0, i32 3");
        H("  %vals2 = load i64*, i64** %vptr2");
        H("  %valsi8 = bitcast i64* %vals2 to i8*");
        H("  call void @free(i8* %valsi8)");
        H("  ret void");
        H("}");
        H("define i8* @zdict_new(i64 %owns) {");
        H("  %p = call i8* @zalloc(i64 40, i8* bitcast (void (i8*)* @zdict_dtor to i8*))");
        H("  %d = bitcast i8* %p to %zdict*");
        H("  %c = getelementptr %zdict, %zdict* %d, i32 0, i32 0");
        H("  store i64 0, i64* %c");
        H("  %cap = getelementptr %zdict, %zdict* %d, i32 0, i32 1");
        H("  store i64 0, i64* %cap");
        H("  %k = getelementptr %zdict, %zdict* %d, i32 0, i32 2");
        H("  store i8** null, i8*** %k");
        H("  %v = getelementptr %zdict, %zdict* %d, i32 0, i32 3");
        H("  store i64* null, i64** %v");
        H("  %op = getelementptr %zdict, %zdict* %d, i32 0, i32 4");
        H("  store i64 %owns, i64* %op");
        H("  ret i8* %p");
        H("}");
        H("define i64 @zdict_index(i8* %p, i8* %key) {");
        H("entry:");
        H("  %d = bitcast i8* %p to %zdict*");
        H("  %cptr = getelementptr %zdict, %zdict* %d, i32 0, i32 0");
        H("  %count = load i64, i64* %cptr");
        H("  %kptr = getelementptr %zdict, %zdict* %d, i32 0, i32 2");
        H("  %keys = load i8**, i8*** %kptr");
        H("  %ia = alloca i64");
        H("  store i64 0, i64* %ia");
        H("  br label %cond");
        H("cond:");
        H("  %i = load i64, i64* %ia");
        H("  %done = icmp sge i64 %i, %count");
        H("  br i1 %done, label %notfound, label %body");
        H("body:");
        H("  %slot = getelementptr i8*, i8** %keys, i64 %i");
        H("  %kk = load i8*, i8** %slot");
        H("  %cmp = call i32 @strcmp(i8* %kk, i8* %key)");
        H("  %eq = icmp eq i32 %cmp, 0");
        H("  br i1 %eq, label %found, label %next");
        H("found:");
        H("  ret i64 %i");
        H("next:");
        H("  %ni = add i64 %i, 1");
        H("  store i64 %ni, i64* %ia");
        H("  br label %cond");
        H("notfound:");
        H("  ret i64 -1");
        H("}");
        H("define void @zdict_set(i8* %p, i8* %key, i64 %val) {");
        H("entry:");
        H("  %idx = call i64 @zdict_index(i8* %p, i8* %key)");
        H("  %exists = icmp sge i64 %idx, 0");
        H("  br i1 %exists, label %update, label %insert");
        H("update:");
        H("  %du = bitcast i8* %p to %zdict*");
        H("  %vpu = getelementptr %zdict, %zdict* %du, i32 0, i32 3");
        H("  %valsu = load i64*, i64** %vpu");
        H("  %su = getelementptr i64, i64* %valsu, i64 %idx");
        H("  %oldval = load i64, i64* %su");
        H("  store i64 %val, i64* %su");
        H("  %opu = getelementptr %zdict, %zdict* %du, i32 0, i32 4");
        H("  %ownsu = load i64, i64* %opu");
        H("  %doarcu = icmp ne i64 %ownsu, 0");
        H("  br i1 %doarcu, label %arcu, label %doneu");
        H("arcu:");
        H("  %nvpu = inttoptr i64 %val to i8*");
        H("  call void @zretain(i8* %nvpu)");
        H("  %ovpu = inttoptr i64 %oldval to i8*");
        H("  call void @zrelease(i8* %ovpu)");
        H("  br label %doneu");
        H("doneu:");
        H("  ret void");
        H("insert:");
        H("  %d = bitcast i8* %p to %zdict*");
        H("  %cptr = getelementptr %zdict, %zdict* %d, i32 0, i32 0");
        H("  %count = load i64, i64* %cptr");
        H("  %capptr = getelementptr %zdict, %zdict* %d, i32 0, i32 1");
        H("  %cap = load i64, i64* %capptr");
        H("  %full = icmp sge i64 %count, %cap");
        H("  br i1 %full, label %grow, label %st");
        H("grow:");
        H("  %nc0 = mul i64 %cap, 2");
        H("  %isz = icmp eq i64 %nc0, 0");
        H("  %nc = select i1 %isz, i64 4, i64 %nc0");
        H("  %kptr = getelementptr %zdict, %zdict* %d, i32 0, i32 2");
        H("  %oldk = load i8**, i8*** %kptr");
        H("  %oldki8 = bitcast i8** %oldk to i8*");
        H("  %kbytes = mul i64 %nc, 8");
        H("  %newki8 = call i8* @realloc(i8* %oldki8, i64 %kbytes)");
        H("  %newk = bitcast i8* %newki8 to i8**");
        H("  store i8** %newk, i8*** %kptr");
        H("  %vptr = getelementptr %zdict, %zdict* %d, i32 0, i32 3");
        H("  %oldv = load i64*, i64** %vptr");
        H("  %oldvi8 = bitcast i64* %oldv to i8*");
        H("  %vbytes = mul i64 %nc, 8");
        H("  %newvi8 = call i8* @realloc(i8* %oldvi8, i64 %vbytes)");
        H("  %newv = bitcast i8* %newvi8 to i64*");
        H("  store i64* %newv, i64** %vptr");
        H("  store i64 %nc, i64* %capptr");
        H("  br label %st");
        H("st:");
        H("  %kptr2 = getelementptr %zdict, %zdict* %d, i32 0, i32 2");
        H("  %keys = load i8**, i8*** %kptr2");
        H("  %kslot = getelementptr i8*, i8** %keys, i64 %count");
        H("  store i8* %key, i8** %kslot");
        H("  %vptr2 = getelementptr %zdict, %zdict* %d, i32 0, i32 3");
        H("  %vals = load i64*, i64** %vptr2");
        H("  %vslot = getelementptr i64, i64* %vals, i64 %count");
        H("  store i64 %val, i64* %vslot");
        H("  %ncount = add i64 %count, 1");
        H("  store i64 %ncount, i64* %cptr");
        H("  %opi = getelementptr %zdict, %zdict* %d, i32 0, i32 4");
        H("  %ownsi = load i64, i64* %opi");
        H("  %doarci = icmp ne i64 %ownsi, 0");
        H("  br i1 %doarci, label %arci, label %donei");
        H("arci:");
        H("  %nvpi = inttoptr i64 %val to i8*");
        H("  call void @zretain(i8* %nvpi)");
        H("  br label %donei");
        H("donei:");
        H("  ret void");
        H("}");
        H("define i64 @zdict_get(i8* %p, i8* %key) {");
        H("entry:");
        H("  %idx = call i64 @zdict_index(i8* %p, i8* %key)");
        H("  %nf = icmp slt i64 %idx, 0");
        H("  br i1 %nf, label %ret0, label %load");
        H("ret0:");
        H("  ret i64 0");
        H("load:");
        H("  %d = bitcast i8* %p to %zdict*");
        H("  %vptr = getelementptr %zdict, %zdict* %d, i32 0, i32 3");
        H("  %vals = load i64*, i64** %vptr");
        H("  %slot = getelementptr i64, i64* %vals, i64 %idx");
        H("  %v = load i64, i64* %slot");
        H("  ret i64 %v");
        H("}");
        H("define i64 @zdict_contains(i8* %p, i8* %key) {");
        H("  %idx = call i64 @zdict_index(i8* %p, i8* %key)");
        H("  %ge = icmp sge i64 %idx, 0");
        H("  %r = zext i1 %ge to i64");
        H("  ret i64 %r");
        H("}");
        H("define i64 @zdict_count(i8* %p) {");
        H("  %d = bitcast i8* %p to %zdict*");
        H("  %cptr = getelementptr %zdict, %zdict* %d, i32 0, i32 0");
        H("  %c = load i64, i64* %cptr");
        H("  ret i64 %c");
        H("}");
    }

    void GenClass(Node cls) {
        curClass = cls.sval;
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.MethodDecl()) {
                // abstract/interface methods have no body: no function is emitted
                if (HasMod(m, MOD.Extern())) { DeclareExtern(cls, m); }
                else if (!IsAbstract(m)) { GenMethod(cls, m, false); }
            }
            else if (m.kind == AK.CtorDecl()) { GenCtor(cls, m); }
            i = i + 1;
        }
    }

    bool IsStatic(Node m) { return (m.mods / MOD.Static()) - ((m.mods / MOD.Static()) / 2) * 2 == 1; }

    void StartFn() {
        tmp = 0; lbl = 0; term = false;
        curLbl = "entry";
        locName = new List<string>();
        locType = new List<Node>();
        locReg = new List<string>();
        locSeq = 0;
        stmtTemps = new List<string>();
        stmtTempTypes = new List<Node>();
        loopScopeBase = 0;
    }

    void GenMethod(Node cls, Node m, bool ctor) {
        StartFn();
        curClass = cls.sval;
        curRet = MapType(m.type);
        bool stat = IsStatic(m);
        curHasThis = !stat;
        string sig = "define " + curRet + " @" + MethodSym(cls.sval, m) + "(";
        int np = 0;
        if (!stat) {
            sig = sig + "%" + cls.sval + "* %this";
            np = 1;
        }
        List<string> pn = new List<string>();
        List<Node> pt = new List<Node>();
        int i = 0;
        while (i < m.kids.Count) {
            Node p = m.kids[i];
            if (p.kind == AK.Param()) { pn.Add(p.sval); pt.Add(p.type); }
            i = i + 1;
        }
        int j = 0;
        while (j < pn.Count) {
            if (np > 0) { sig = sig + ", "; }
            sig = sig + MapType(pt[j]) + " %p" + j;
            np = np + 1;
            j = j + 1;
        }
        sig = sig + ") {";
        L(sig);
        L("entry:");
        j = 0;
        while (j < pn.Count) {
            string lt = MapType(pt[j]);
            string preg = AddLocal(pn[j], pt[j]);
            L("  " + preg + " = alloca " + lt);
            L("  store " + lt + " %p" + j + ", " + lt + "* " + preg);
            EmitArcRetain("%p" + j, pt[j]);
            j = j + 1;
        }
        if (m.d != null) { GenStmt(m.d); }
        if (!term) {
            ReleaseLocalsFrom(0);
            if (curRet == "void") { L("  ret void"); }
            else if (curRet == "i64") { L("  ret i64 0"); }
            else { L("  ret " + curRet + " null"); }
        }
        L("}");
    }

    void GenCtor(Node cls, Node m) {
        StartFn();
        curClass = cls.sval;
        curRet = "void";
        curHasThis = true;
        string sig = "define void @" + cls.sval + "_ctor(%" + cls.sval + "* %this";
        List<string> pn = new List<string>();
        List<Node> pt = new List<Node>();
        int i = 0;
        while (i < m.kids.Count) {
            Node p = m.kids[i];
            if (p.kind == AK.Param()) { pn.Add(p.sval); pt.Add(p.type); }
            i = i + 1;
        }
        int j = 0;
        while (j < pn.Count) {
            sig = sig + ", " + MapType(pt[j]) + " %p" + j;
            j = j + 1;
        }
        sig = sig + ") {";
        L(sig);
        L("entry:");
        j = 0;
        while (j < pn.Count) {
            string lt = MapType(pt[j]);
            string preg = AddLocal(pn[j], pt[j]);
            L("  " + preg + " = alloca " + lt);
            L("  store " + lt + " %p" + j + ", " + lt + "* " + preg);
            EmitArcRetain("%p" + j, pt[j]);
            j = j + 1;
        }
        if (m.d != null) { GenStmt(m.d); }
        if (!term) {
            ReleaseLocalsFrom(0);
            L("  ret void");
        }
        L("}");
    }

    // Emit: if `cond` (an i1) holds, print `msg` and exit(1) -- never falling
    // through with an invalid result. Shared by every I/O return-value check.
    void EmitAbortIf(string cond, string msg, int len) {
        int lf = NL(); int lk = NL();
        L("  br i1 " + cond + ", label %L" + lf + ", label %L" + lk);
        Label(lf);
        string em = NT(); L("  " + em + " = getelementptr inbounds [" + len + " x i8], [" + len + " x i8]* " + msg + ", i64 0, i64 0");
        L("  call i32 (i8*, ...) @printf(i8* " + em + ")");
        L("  call void @exit(i32 1)");
        L("  unreachable");
        Label(lk);
    }

    void EmitFopenCheck(string fp, string msg, int len) {
        string np = NT(); L("  " + np + " = icmp eq i8* " + fp + ", null");
        EmitAbortIf(np, msg, len);
    }

    void GenMainWrapper(Node unit) {
        string owner = "";
        int i = 0;
        while (i < unit.kids.Count) {
            Node d = unit.kids[i];
            if (d.kind == AK.ClassDecl() || d.kind == AK.StructDecl()) {
                if (binder.FindMethod(d, "Main") != null) { owner = d.sval; }
            }
            i = i + 1;
        }
        if (owner == "") { return; }
        L("define i32 @main(i32 %argc, i8** %argv) {");
        L("entry:");
        L("  store i32 %argc, i32* @__zan_argc");
        L("  store i8** %argv, i8*** @__zan_argv");
        // Install a root exception handler so an uncaught throw prints a
        // message and exits 1 instead of longjmp-ing through an empty stack.
        string rbuf = NT(); L("  " + rbuf + " = alloca [32 x i64]");
        string rbp = NT(); L("  " + rbp + " = bitcast [32 x i64]* " + rbuf + " to i8*");
        string rsp = NT(); L("  " + rsp + " = load i64, i64* @__exc_sp");
        string rslot = NT(); L("  " + rslot + " = getelementptr [64 x i8*], [64 x i8*]* @__exc_stack, i64 0, i64 " + rsp);
        L("  store i8* " + rbp + ", i8** " + rslot);
        string rsp1 = NT(); L("  " + rsp1 + " = add i64 " + rsp + ", 1");
        L("  store i64 " + rsp1 + ", i64* @__exc_sp");
        string rfp = NT(); L("  " + rfp + " = call i8* @llvm.frameaddress.p0(i32 0)");
        string rr = NT(); L("  " + rr + " = call i32 @_setjmp(i8* " + rbp + ", i8* " + rfp + ")");
        string rc = NT(); L("  " + rc + " = icmp ne i32 " + rr + ", 0");
        int lbody = NL(); int lcatch = NL();
        L("  br i1 " + rc + ", label %L" + lcatch + ", label %L" + lbody);
        Label(lbody);
        L("  call void @" + owner + "_Main()");
        L("  ret i32 0");
        Label(lcatch);
        string mp = NT(); L("  " + mp + " = getelementptr inbounds [21 x i8], [21 x i8]* @.msg.unhandled, i64 0, i64 0");
        L("  call i32 (i8*, ...) @printf(i8* " + mp + ")");
        L("  ret i32 1");
        L("}");
    }

    // ---- statements ----
    void GenStmt(Node s) {
        if (s == null) { return; }
        if (term) { return; }
        int k = s.kind;
        if (k == AK.Block()) {
            int scopeStart = locName.Count;
            int i = 0;
            while (i < s.kids.Count) { GenStmt(s.kids[i]); i = i + 1; }
            if (!term) { ReleaseLocalsFrom(scopeStart); }
            TrimLocals(scopeStart);
        } else if (k == AK.VarDecl()) {
            stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
            GenVarDecl(s);
            EmitTempReleases();
        } else if (k == AK.DeconDecl()) {
            GenDecon(s);
        } else if (k == AK.ExprStmt()) {
            stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
            GenExpr(s.a);
            EmitTempReleases();
        } else if (k == AK.ReturnStmt()) {
            if (s.a != null) {
                stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
                ExprVal v = GenExpr(s.a);
                if (curRet == "void") {
                    EmitTempReleases();
                    ReleaseLocalsFrom(0);
                    L("  ret void");
                } else {
                    string rv = Coerce(v, curRet);
                    EmitArcRetain(rv, v.ty);
                    EmitTempReleases();
                    ReleaseLocalsFrom(0);
                    L("  ret " + curRet + " " + rv);
                }
            } else {
                ReleaseLocalsFrom(0);
                L("  ret void");
            }
            term = true;
        } else if (k == AK.IfStmt()) {
            GenIf(s);
        } else if (k == AK.WhileStmt()) {
            GenWhile(s);
        } else if (k == AK.ForStmt()) {
            GenFor(s);
        } else if (k == AK.ForeachStmt()) {
            GenForeach(s);
        } else if (k == AK.TryStmt()) {
            GenTry(s);
        } else if (k == AK.ThrowStmt()) {
            GenThrow(s);
        } else if (k == AK.BreakStmt()) {
            if (brkTarget > 0) { ReleaseLocalsFrom(loopScopeBase); L("  br label %L" + brkTarget); term = true; }
        } else if (k == AK.ContinueStmt()) {
            if (contTarget > 0) { ReleaseLocalsFrom(loopScopeBase); L("  br label %L" + contTarget); term = true; }
        } else {
            GenExpr(s);
        }
    }

    bool IsClassPtr(string s) {
        if (s.Length < 2) { return false; }
        if (s.Substring(0, 1) != "%") { return false; }
        if (s.Substring(s.Length - 1, 1) != "*") { return false; }
        return true;
    }

    // Any LLVM pointer type (class pointer or the generic i8*).
    bool IsPtrLL(string s) {
        if (s == "i8*") { return true; }
        return IsClassPtr(s);
    }

    // when null literal, retype to the target LLVM type; bitcast class pointers
    // (e.g. a derived instance stored into a base-typed slot)
    string Coerce(ExprVal v, string llty) {
        if (v.op == "null") { return "null"; }
        string vt = MapType(v.ty);
        if (vt != llty && IsClassPtr(vt) && IsClassPtr(llty)) {
            string t = NT();
            L("  " + t + " = bitcast " + vt + " " + v.op + " to " + llty);
            return t;
        }
        // implicit integer -> double promotion (e.g. `double x = 5;`)
        if (vt == "i64" && llty == "double") {
            string t = NT();
            L("  " + t + " = sitofp i64 " + v.op + " to double");
            return t;
        }
        return v.op;
    }

    // ---- vtable emission for polymorphic classes ----
    void EmitVtable(Node cls) {
        List<string> slots = new List<string>();
        CollectVSlots(cls, slots);
        string s = "@" + cls.sval + "_vtable = global [" + slots.Count + " x i8*] [";
        int i = 0;
        while (i < slots.Count) {
            string sl = slots[i];
            string impl = ResolveImpl(cls, sl);
            Node m = FindMethodUp(cls, sl);
            if (i > 0) { s = s + ", "; }
            s = s + "i8* bitcast (" + MethodFnTypeThis(m, impl) + " @" + impl + "_" + sl + " to i8*)";
            i = i + 1;
        }
        s = s + "]";
        H(s);
    }

    Node FindMethodUp(Node cls, string name) {
        Node c = cls;
        while (c != null) {
            Node m = binder.FindMethod(c, name);
            if (m != null) { return m; }
            c = BaseClassOf(c);
        }
        return null;
    }

    string MethodOwner(Node cls, string name) {
        Node c = cls;
        while (c != null) {
            if (binder.FindMethod(c, name) != null) { return c.sval; }
            c = BaseClassOf(c);
        }
        return "";
    }

    // Number of methods named `name` declared directly in `cls`.
    int MethodCount(Node cls, string name) {
        if (cls == null) { return 0; }
        int n = 0;
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.MethodDecl() && m.sval == name) { n = n + 1; }
            i = i + 1;
        }
        return n;
    }

    // A type name reduced to a symbol-safe tag for overload mangling.
    string TypeTag(Node t) {
        if (t == null) { return "v"; }
        if (t.sval == "") { return "v"; }
        return t.sval;
    }

    // The LLVM symbol for a method. Non-overloaded names stay `Owner_Name`
    // (so all existing output -- including the self-host fixed point, which
    // has no overloads -- is unchanged); an overloaded name gains an arity and
    // per-parameter-type suffix so each overload is a distinct definition.
    string MethodSym(string owner, Node m) {
        if (HasMod(m, MOD.Extern())) { return ExternName(m); }
        Node oc = binder.FindType(owner);
        if (MethodCount(oc, m.sval) <= 1) { return owner + "_" + m.sval; }
        StringBuilder sb = new StringBuilder();
        sb.Append(owner);
        sb.Append("_");
        sb.Append(m.sval);
        sb.Append("__");
        int i = 0;
        while (i < m.kids.Count) {
            Node p = m.kids[i];
            if (p.kind == AK.Param()) {
                sb.Append("_");
                sb.Append(TypeTag(p.type));
            }
            i = i + 1;
        }
        return sb.ToString();
    }

    // ---- non-emitting argument typer (for overload resolution only) ----
    // Yields the static type of an argument expression without generating any
    // IR. Returns null when the type cannot be determined; callers treat that
    // as "compatible with anything" so nothing is mis-resolved.
    Node ArgTypeNode(Node e) {
        if (e == null) { return null; }
        int k = e.kind;
        if (k == AK.IntLit()) { return MkType("int"); }
        if (k == AK.FloatLit()) { return MkType("double"); }
        if (k == AK.StringLit()) { return MkType("string"); }
        if (k == AK.CharLit()) { return MkType("char"); }
        if (k == AK.BoolLit()) { return MkType("bool"); }
        if (k == AK.ThisExpr()) { return MkType(curClass); }
        if (k == AK.CastExpr()) { return e.type; }
        if (k == AK.NewExpr()) { return e.type; }
        if (k == AK.IsExpr()) { return MkType("bool"); }
        if (k == AK.Ident()) {
            int li = LocalIdx(e.sval);
            if (li >= 0) { return locType[li]; }
            return FieldType(binder.FindType(curClass), e.sval);
        }
        if (k == AK.MemberAccess()) {
            Node cls = ClassOf(ArgTypeNode(e.a));
            if (cls != null) { return FieldType(cls, e.sval); }
            return null;
        }
        if (k == AK.Unary()) { if (e.op == TK.Bang()) { return MkType("bool"); } return ArgTypeNode(e.a); }
        if (k == AK.PostfixUnary()) { return ArgTypeNode(e.a); }
        if (k == AK.Binary()) {
            int op = e.op;
            if (op == TK.EqEq() || op == TK.BangEq() || op == TK.Less() || op == TK.Greater()
                || op == TK.LessEq() || op == TK.GreaterEq() || op == TK.AmpAmp() || op == TK.PipePipe()) {
                return MkType("bool");
            }
            Node lt = ArgTypeNode(e.a);
            Node rt = ArgTypeNode(e.b);
            if (IsStr(lt) || IsStr(rt)) { return MkType("string"); }
            if (lt != null) { return lt; }
            return rt;
        }
        if (k == AK.Index()) {
            Node ot = ArgTypeNode(e.a);
            if (ot != null) {
                if (IsListType(ot)) { return ListElem(ot); }
                if (ot.sval == "string") { return MkType("char"); }
            }
            return null;
        }
        return null;
    }

    string ArgTag(Node e) { Node t = ArgTypeNode(e); if (t == null) { return ""; } return t.sval; }

    // How well candidate `m` fits the call `e`: +1 for matching the caller's
    // static/instance context, +4 for each exact argument-type match, -1 for a
    // known mismatch (an implicit conversion may still apply, so it is not
    // disqualifying). Unknown argument types are neutral.
    int ScoreCand(Node m, Node e, int argc, bool wantStatic) {
        int score = 0;
        if (IsStatic(m) == wantStatic) { score = score + 1; }
        int a = 0;
        while (a < argc) {
            string at = ArgTag(e.kids[a]);
            if (at != "") {
                if (at == TypeTag(ParamTypeNode(m, a))) { score = score + 4; }
                else { score = score - 1; }
            }
            a = a + 1;
        }
        return score;
    }

    // Select the method named `name` in `cls` for the call `e`. With a single
    // candidate the behaviour is unchanged (arity is not consulted, so
    // default-argument calls still resolve, and the self-host fixed point --
    // which has no overloads -- emits byte-identical IR). With several
    // overloads we keep those whose arity admits the call, then pick the best
    // argument-type match for the caller's static/instance context; an empty
    // candidate set or a tie is a diagnostic.
    Node ResolveMethod(Node cls, string name, Node e, bool wantStatic) {
        if (cls == null) { return null; }
        List<Node> cands = new List<Node>();
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.MethodDecl() && m.sval == name) { cands.Add(m); }
            i = i + 1;
        }
        if (cands.Count == 0) { return null; }
        if (cands.Count == 1) { return cands[0]; }
        int argc = e.kids.Count;
        List<Node> fit = new List<Node>();
        i = 0;
        while (i < cands.Count) {
            Node m = cands[i];
            int tot = 0; int req = 0; int j = 0;
            while (j < m.kids.Count) {
                if (m.kids[j].kind == AK.Param()) { tot = tot + 1; if (m.kids[j].b == null) { req = req + 1; } }
                j = j + 1;
            }
            if (argc >= req && argc <= tot) { fit.Add(m); }
            i = i + 1;
        }
        if (fit.Count == 0) {
            diags.Error("no overload of '" + name + "' takes " + argc + " argument(s)", e.line, e.col);
            return cands[0];
        }
        if (fit.Count == 1) { return fit[0]; }
        bool anyNamed = false;
        i = 0;
        while (i < e.kids.Count) { if (e.kids[i].sval2 != "") { anyNamed = true; } i = i + 1; }
        if (anyNamed) { return fit[0]; }
        int mx = -2000000000;
        List<int> sc = new List<int>();
        i = 0;
        while (i < fit.Count) { int s = ScoreCand(fit[i], e, argc, wantStatic); sc.Add(s); if (s > mx) { mx = s; } i = i + 1; }
        int cntMax = 0;
        Node best = fit[0];
        i = 0;
        while (i < fit.Count) {
            if (sc[i] == mx) { if (cntMax == 0) { best = fit[i]; } cntMax = cntMax + 1; }
            i = i + 1;
        }
        if (cntMax > 1) { diags.Error("ambiguous call to overloaded '" + name + "'", e.line, e.col); }
        return best;
    }

    // Like ResolveMethod but walks base classes, matching FindMethodUp.
    Node ResolveMethodUp(Node cls, string name, Node e, bool wantStatic) {
        Node c = cls;
        while (c != null) {
            Node m = ResolveMethod(c, name, e, wantStatic);
            if (m != null) { return m; }
            c = BaseClassOf(c);
        }
        return null;
    }

    // vtable slot method names, base classes first
    void CollectVSlots(Node cls, List<string> slots) {
        if (cls == null) { return; }
        CollectVSlots(BaseClassOf(cls), slots);
        int i = 0;
        while (i < cls.kids.Count) {
            Node m = cls.kids[i];
            if (m.kind == AK.MethodDecl() && IsVSlotIntro(m)) { slots.Add(m.sval); }
            i = i + 1;
        }
    }

    int VSlotIndex(Node cls, string name) {
        List<string> slots = new List<string>();
        CollectVSlots(cls, slots);
        int i = 0;
        while (i < slots.Count) { if (slots[i] == name) { return i; } i = i + 1; }
        return -1;
    }

    // most-derived class (from cls upward) providing a concrete body for a slot.
    // Matches explicit override AND implicit interface implementation (a plain
    // method whose name matches an inherited abstract/virtual slot).
    string ResolveImpl(Node cls, string name) {
        Node c = cls;
        while (c != null) {
            Node m = binder.FindMethod(c, name);
            if (m != null && !IsAbstract(m)) { return c.sval; }
            c = BaseClassOf(c);
        }
        return "";
    }

    string MethodFnTypeThis(Node m, string thisCls) {
        string ty = MapType(m.type) + " (%" + thisCls + "*";
        int i = 0;
        while (i < m.kids.Count) {
            if (m.kids[i].kind == AK.Param()) { ty = ty + ", " + MapType(m.kids[i].type); }
            i = i + 1;
        }
        return ty + ")*";
    }

    void GenVarDecl(Node s) {
        Node ty = s.type;
        ExprVal init;
        bool hasInit = (s.b != null);
        // propagate delegate parameter/return types onto an initialising lambda
        if (hasInit && s.b.kind == AK.Lambda() && ty != null && IsDelegate(ty)) {
            AnnotateLambda(s.b, ty);
        }
        if (hasInit) { init = GenExpr(s.b); } else { init = new ExprVal("0", MkType("int")); }
        if (ty == null) { ty = init.ty; }
        string lt = MapType(ty);
        string reg = AddLocal(s.sval, ty);
        L("  " + reg + " = alloca " + lt);
        if (hasInit) {
            if (IsNullableValue(ty)) {
                L("  store i8* " + BoxFor(init, ty) + ", i8** " + reg);
            } else {
                string sv = Coerce(init, lt);
                L("  store " + lt + " " + sv + ", " + lt + "* " + reg);
                EmitArcRetain(sv, ty);
            }
        } else {
            if (ArcManaged(ty)) { L("  store " + lt + " null, " + lt + "* " + reg); }
        }
    }

    string GenCond(Node e) {
        ExprVal v = GenExpr(e);
        string c = NT();
        if (v.op == "null") {
            L("  " + c + " = icmp ne i8* null, null");
        } else if (MapType(v.ty) == "i8*" || IsPtrType(v.ty)) {
            L("  " + c + " = icmp ne " + MapType(v.ty) + " " + v.op + ", null");
        } else {
            L("  " + c + " = icmp ne i64 " + v.op + ", 0");
        }
        return c;
    }

    void GenIf(Node s) {
        string c = GenCond(s.a);
        int lt = NL(); int le = NL(); int lend = NL();
        if (s.c != null) { L("  br i1 " + c + ", label %L" + lt + ", label %L" + le); }
        else { L("  br i1 " + c + ", label %L" + lt + ", label %L" + lend); }
        Label(lt);
        GenStmt(s.b);
        if (!term) { L("  br label %L" + lend); }
        if (s.c != null) {
            Label(le);
            GenStmt(s.c);
            if (!term) { L("  br label %L" + lend); }
        }
        Label(lend);
    }

    void GenWhile(Node s) {
        int lc = NL(); int lb = NL(); int lend = NL();
        int sb = brkTarget; int sc = contTarget;
        int sls = loopScopeBase;
        brkTarget = lend; contTarget = lc;
        loopScopeBase = locName.Count;
        L("  br label %L" + lc);
        Label(lc);
        string c = GenCond(s.a);
        L("  br i1 " + c + ", label %L" + lb + ", label %L" + lend);
        Label(lb);
        GenStmt(s.b);
        if (!term) { L("  br label %L" + lc); }
        Label(lend);
        brkTarget = sb; contTarget = sc;
        loopScopeBase = sls;
    }

    void GenFor(Node s) {
        int forScope = locName.Count;
        if (s.a != null) { GenStmt(s.a); }
        int lc = NL(); int lb = NL(); int linc = NL(); int lend = NL();
        int sb = brkTarget; int sc = contTarget;
        int sls = loopScopeBase;
        brkTarget = lend; contTarget = linc;
        loopScopeBase = locName.Count;
        L("  br label %L" + lc);
        Label(lc);
        if (s.b != null) {
            string c = GenCond(s.b);
            L("  br i1 " + c + ", label %L" + lb + ", label %L" + lend);
        } else {
            L("  br label %L" + lb);
        }
        Label(lb);
        GenStmt(s.d);
        if (!term) { L("  br label %L" + linc); }
        Label(linc);
        if (s.c != null) { GenExpr(s.c); }
        L("  br label %L" + lc);
        Label(lend);
        ReleaseLocalsFrom(forScope);
        TrimLocals(forScope);
        brkTarget = sb; contTarget = sc;
        loopScopeBase = sls;
    }

    // foreach (T x in coll) body  — lowered as an indexed walk over List<T>
    void GenForeach(Node s) {
        int feScope = locName.Count;
        ExprVal coll = GenExpr(s.b);
        if (!IsListType(coll.ty)) { return; }
        Node elemTy = s.type;
        if (elemTy == null) { elemTy = ListElem(coll.ty); }
        string elt = MapType(elemTy);
        string idx = NT();
        L("  " + idx + " = alloca i64");
        L("  store i64 0, i64* " + idx);
        string ereg = AddLocal(s.sval, elemTy);
        L("  " + ereg + " = alloca " + elt);
        if (ArcManaged(elemTy)) { L("  store " + elt + " null, " + elt + "* " + ereg); }
        int lc = NL(); int lb = NL(); int linc = NL(); int lend = NL();
        int sb = brkTarget; int sc = contTarget;
        int sls = loopScopeBase;
        brkTarget = lend; contTarget = linc;
        loopScopeBase = locName.Count;
        L("  br label %L" + lc);
        Label(lc);
        string iv = NT();
        L("  " + iv + " = load i64, i64* " + idx);
        string cnt = NT();
        L("  " + cnt + " = call i64 @zlist_count(i8* " + coll.op + ")");
        string c = NT();
        L("  " + c + " = icmp slt i64 " + iv + ", " + cnt);
        L("  br i1 " + c + ", label %L" + lb + ", label %L" + lend);
        Label(lb);
        string slot = NT();
        L("  " + slot + " = call i64 @zlist_get(i8* " + coll.op + ", i64 " + iv + ")");
        ExprVal ev = FromSlot(slot, elemTy);
        if (ArcManaged(elemTy)) {
            string old = NT();
            L("  " + old + " = load " + elt + ", " + elt + "* " + ereg);
            L("  store " + elt + " " + ev.op + ", " + elt + "* " + ereg);
            EmitArcRetain(ev.op, elemTy);
            EmitArcRelease(old, elemTy);
        } else {
            L("  store " + elt + " " + ev.op + ", " + elt + "* " + ereg);
        }
        GenStmt(s.c);
        if (!term) { L("  br label %L" + linc); }
        Label(linc);
        string iv2 = NT();
        L("  " + iv2 + " = load i64, i64* " + idx);
        string inc = NT();
        L("  " + inc + " = add i64 " + iv2 + ", 1");
        L("  store i64 " + inc + ", i64* " + idx);
        L("  br label %L" + lc);
        Label(lend);
        ReleaseLocalsFrom(feScope);
        TrimLocals(feScope);
        brkTarget = sb; contTarget = sc;
        loopScopeBase = sls;
    }

    // throw expr — store the exception object, pop the innermost handler and
    // longjmp back into its try (setjmp returns nonzero -> catch path).
    void GenThrow(Node s) {
        ExprVal v = GenExpr(s.a);
        string vt = MapType(v.ty);
        string ev = v.op;
        if (vt != "i8*") {
            string t = NT();
            L("  " + t + " = bitcast " + vt + " " + ev + " to i8*");
            ev = t;
        }
        L("  store i8* " + ev + ", i8** @__exc_val");
        string sp = NT();
        L("  " + sp + " = load i64, i64* @__exc_sp");
        string sp1 = NT();
        L("  " + sp1 + " = sub i64 " + sp + ", 1");
        L("  store i64 " + sp1 + ", i64* @__exc_sp");
        string slot = NT();
        L("  " + slot + " = getelementptr [64 x i8*], [64 x i8*]* @__exc_stack, i64 0, i64 " + sp1);
        string buf = NT();
        L("  " + buf + " = load i8*, i8** " + slot);
        L("  call void @longjmp(i8* " + buf + ", i32 1)");
        L("  unreachable");
        term = true;
    }

    void EmitExcPop() {
        string sp = NT();
        L("  " + sp + " = load i64, i64* @__exc_sp");
        string sp1 = NT();
        L("  " + sp1 + " = sub i64 " + sp + ", 1");
        L("  store i64 " + sp1 + ", i64* @__exc_sp");
    }

    // try { } catch (T e) { } finally { }  — setjmp/longjmp based
    void GenTry(Node s) {
        string buf = NT();
        L("  " + buf + " = alloca [32 x i64]");
        string bufp = NT();
        L("  " + bufp + " = bitcast [32 x i64]* " + buf + " to i8*");
        // push handler
        string sp = NT();
        L("  " + sp + " = load i64, i64* @__exc_sp");
        string slot = NT();
        L("  " + slot + " = getelementptr [64 x i8*], [64 x i8*]* @__exc_stack, i64 0, i64 " + sp);
        L("  store i8* " + bufp + ", i8** " + slot);
        string sp1 = NT();
        L("  " + sp1 + " = add i64 " + sp + ", 1");
        L("  store i64 " + sp1 + ", i64* @__exc_sp");
        // setjmp
        string fp = NT();
        L("  " + fp + " = call i8* @llvm.frameaddress.p0(i32 0)");
        string r = NT();
        L("  " + r + " = call i32 @_setjmp(i8* " + bufp + ", i8* " + fp + ")");
        string c = NT();
        L("  " + c + " = icmp ne i32 " + r + ", 0");
        int ltry = NL(); int lcatch = NL(); int lend = NL();
        L("  br i1 " + c + ", label %L" + lcatch + ", label %L" + ltry);
        Label(ltry);
        GenStmt(s.a);
        if (!term) {
            EmitExcPop();
            if (s.c != null) { GenStmt(s.c); }
            if (!term) { L("  br label %L" + lend); }
        }
        term = false;
        Label(lcatch);
        // handler already popped by throw; bind catch variable to @__exc_val
        if (s.b != null) {
            int catchScope = locName.Count;
            Node cc = s.b;
            if (cc.sval != "" && cc.type != null) {
                string exv = NT();
                L("  " + exv + " = load i8*, i8** @__exc_val");
                string ct = MapType(cc.type);
                string reg = AddLocal(cc.sval, cc.type);
                L("  " + reg + " = alloca " + ct);
                string cv = exv;
                if (ct != "i8*") {
                    string t = NT();
                    L("  " + t + " = bitcast i8* " + exv + " to " + ct);
                    cv = t;
                }
                L("  store " + ct + " " + cv + ", " + ct + "* " + reg);
            }
            GenStmt(cc.a);
            if (!term) { ReleaseLocalsFrom(catchScope); }
            TrimLocals(catchScope);
        }
        if (!term) {
            if (s.c != null) { GenStmt(s.c); }
            if (!term) { L("  br label %L" + lend); }
        }
        Label(lend);
        term = false;
    }

    // ---- expressions ----
    ExprVal GenExpr(Node e) {
        if (e == null) { return new ExprVal("0", MkType("int")); }
        int k = e.kind;
        if (k == AK.IntLit()) { return new ExprVal("" + e.ival, MkType("int")); }
        if (k == AK.FloatLit()) { return new ExprVal(e.sval, MkType("double")); }
        if (k == AK.BoolLit()) { return new ExprVal("" + e.ival, MkType("bool")); }
        if (k == AK.CharLit()) { return new ExprVal("" + e.ival, MkType("char")); }
        if (k == AK.StringLit()) { return GenStr(e.sval); }
        if (k == AK.NullLit()) { return new ExprVal("null", MkType("object")); }
        if (k == AK.ThisExpr()) { return new ExprVal("%this", MkType(curClass)); }
        if (k == AK.Ident()) { return GenIdent(e); }
        if (k == AK.Unary()) { return GenUnary(e); }
        if (k == AK.PostfixUnary()) { return GenPostfix(e); }
        if (k == AK.Binary()) { return GenBinary(e); }
        if (k == AK.Assignment()) { return GenAssign(e); }
        if (k == AK.Call()) { return GenCall(e); }
        if (k == AK.Lambda()) { return GenLambda(e); }
        if (k == AK.SwitchExpr()) { return GenSwitchExpr(e); }
        if (k == AK.TupleExpr()) { return GenTuple(e); }
        if (k == AK.IsExpr()) { return GenIs(e); }
        if (k == AK.MemberAccess()) { return GenMember(e); }
        if (k == AK.Index()) { return GenIndex(e); }
        if (k == AK.NewExpr()) { return GenNew(e); }
        if (k == AK.CastExpr()) { return GenCast(e); }
        return new ExprVal("0", MkType("int"));
    }

    ExprVal GenIdent(Node e) {
        int li = LocalIdx(e.sval);
        if (li >= 0) {
            Node ty = locType[li];
            string reg = locReg[li];
            string lt = MapType(ty);
            string t = NT();
            L("  " + t + " = load " + lt + ", " + lt + "* " + reg);
            return new ExprVal(t, ty);
        }
        // implicit this.field
        if (curHasThis) {
            Node cls = binder.FindType(curClass);
            if (cls != null && FieldIndex(cls, e.sval) >= 0) {
                return LoadField("%this", MkType(curClass), e.sval);
            }
            if (cls != null && FindMethodUp(cls, "get_" + e.sval) != null) {
                ExprVal recv = new ExprVal("%this", MkType(curClass));
                return EmitInstanceCall(recv, curClass, "get_" + e.sval, new Node(AK.Call()));
            }
        }
        return new ExprVal("0", MkType("int"));
    }

    ExprVal LoadField(string objOp, Node recvTy, string field) {
        string clsName = recvTy.sval;
        Node cls = binder.FindType(clsName);
        int idx = FieldIndex(cls, field);
        Node fty = FieldType(cls, field);
        string ft = MapType(fty);
        string p = NT();
        L("  " + p + " = getelementptr %" + clsName + ", %" + clsName + "* " + objOp + ", i32 0, i32 " + idx);
        string t = NT();
        L("  " + t + " = load " + ft + ", " + ft + "* " + p);
        // erased field: storage is i64; unpack to the concrete type when known
        if (IsErasedType(fty)) { return FromSlot(t, ConcreteTP(fty, recvTy)); }
        return new ExprVal(t, fty);
    }

    ExprVal GenUnary(Node e) {
        ExprVal v = GenExpr(e.a);
        if (e.op == TK.Bang()) {
            string c = NT();
            L("  " + c + " = icmp eq i64 " + v.op + ", 0");
            string z = NT();
            L("  " + z + " = zext i1 " + c + " to i64");
            return new ExprVal(z, MkType("bool"));
        }
        if (e.op == TK.Minus()) {
            if (IsDbl(v.ty)) {
                string t = NT();
                L("  " + t + " = fneg double " + v.op);
                return new ExprVal(t, MkType("double"));
            }
            string t = NT();
            L("  " + t + " = sub i64 0, " + v.op);
            return new ExprVal(t, MkType("int"));
        }
        return v;
    }

    ExprVal GenPostfix(Node e) {
        // x++ / x-- : return old value, update slot
        ExprVal cur = GenExpr(e.a);
        if (IsDbl(cur.ty)) {
            string t = NT();
            string opn = "fadd";
            if (e.op == TK.MinusMinus()) { opn = "fsub"; }
            L("  " + t + " = " + opn + " double " + cur.op + ", 1.0");
            StoreTo(e.a, new ExprVal(t, MkType("double")));
            return cur;
        }
        string t = NT();
        string opn = "add";
        if (e.op == TK.MinusMinus()) { opn = "sub"; }
        L("  " + t + " = " + opn + " i64 " + cur.op + ", 1");
        StoreTo(e.a, new ExprVal(t, MkType("int")));
        return cur;
    }

    string ArithOp(int op) {
        if (op == TK.Plus()) { return "add"; }
        if (op == TK.Minus()) { return "sub"; }
        if (op == TK.Star()) { return "mul"; }
        if (op == TK.Slash()) { return "sdiv"; }
        if (op == TK.Percent()) { return "srem"; }
        if (op == TK.Amp()) { return "and"; }
        if (op == TK.Caret()) { return "xor"; }
        if (op == TK.Pipe()) { return "or"; }
        return "";
    }
    string CmpOp(int op) {
        if (op == TK.EqEq()) { return "eq"; }
        if (op == TK.BangEq()) { return "ne"; }
        if (op == TK.Less()) { return "slt"; }
        if (op == TK.Greater()) { return "sgt"; }
        if (op == TK.LessEq()) { return "sle"; }
        if (op == TK.GreaterEq()) { return "sge"; }
        return "";
    }

    bool IsStr(Node ty) { if (ty == null) { return false; } return ty.sval == "string"; }
    // True for a value lowered to LLVM `double` (both double and float here).
    bool IsDbl(Node ty) { if (ty == null) { return false; } return ty.sval == "double" || ty.sval == "float"; }

    // Floating-point counterparts of ArithOp/CmpOp for `double` operands.
    string FArithOp(int op) {
        if (op == TK.Plus()) { return "fadd"; }
        if (op == TK.Minus()) { return "fsub"; }
        if (op == TK.Star()) { return "fmul"; }
        if (op == TK.Slash()) { return "fdiv"; }
        if (op == TK.Percent()) { return "frem"; }
        return "";
    }
    string FCmpOp(int op) {
        if (op == TK.EqEq()) { return "oeq"; }
        if (op == TK.BangEq()) { return "one"; }
        if (op == TK.Less()) { return "olt"; }
        if (op == TK.Greater()) { return "ogt"; }
        if (op == TK.LessEq()) { return "ole"; }
        if (op == TK.GreaterEq()) { return "oge"; }
        return "";
    }
    // Materialise `v` as an LLVM `double`, widening an integer operand via sitofp.
    string AsDouble(ExprVal v) {
        if (IsDbl(v.ty)) { return v.op; }
        string t = NT();
        L("  " + t + " = sitofp i64 " + v.op + " to double");
        return t;
    }

    bool IsFoldOp(int op) {
        return op == TK.Plus() || op == TK.Minus() || op == TK.Star() || op == TK.Slash() || op == TK.Percent();
    }

    // Is `e` a compile-time integer constant (literals and pure integer arithmetic
    // over them, with no division/modulo by zero)?
    bool IsConstInt(Node e) {
        if (e == null) { return false; }
        if (e.kind == AK.IntLit()) { return true; }
        if (e.kind == AK.Unary() && e.op == TK.Minus()) { return IsConstInt(e.a); }
        if (e.kind == AK.Binary() && IsFoldOp(e.op)) {
            if (!IsConstInt(e.a) || !IsConstInt(e.b)) { return false; }
            if (e.op == TK.Slash() || e.op == TK.Percent()) {
                if (EvalConstInt(e.b) == 0) { return false; }
            }
            return true;
        }
        return false;
    }

    long EvalConstInt(Node e) {
        if (e.kind == AK.IntLit()) { return e.ival; }
        if (e.kind == AK.Unary()) { return 0 - EvalConstInt(e.a); }
        long a = EvalConstInt(e.a);
        long b = EvalConstInt(e.b);
        int op = e.op;
        if (op == TK.Plus()) { return a + b; }
        if (op == TK.Minus()) { return a - b; }
        if (op == TK.Star()) { return a * b; }
        if (op == TK.Slash()) { return a / b; }
        if (op == TK.Percent()) { return a % b; }
        return 0;
    }

    ExprVal GenBinary(Node e) {
        int op = e.op;
        // constant folding: collapse pure integer-constant subtrees to a literal
        if (IsConstInt(e)) {
            return new ExprVal("" + EvalConstInt(e), MkType("int"));
        }
        if (op == TK.AmpAmp() || op == TK.PipePipe()) {
            List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;
            stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
            bool isAnd = (op == TK.AmpAmp());
            int lrhs = NL(); int lend = NL();
            string la = GenCond(e.a);
            string bpre = curLbl;
            if (isAnd) { L("  br i1 " + la + ", label %L" + lrhs + ", label %L" + lend); }
            else { L("  br i1 " + la + ", label %L" + lend + ", label %L" + lrhs); }
            Label(lrhs);
            string lb = GenCond(e.b);
            string bpost = curLbl;
            L("  br label %L" + lend);
            Label(lend);
            string r = NT();
            string dflt = "true"; if (isAnd) { dflt = "false"; }
            L("  " + r + " = phi i1 [ " + dflt + ", %" + bpre + " ], [ " + lb + ", %" + bpost + " ]");
            string z = NT();
            L("  " + z + " = zext i1 " + r + " to i64");
            stmtTemps = svT; stmtTempTypes = svTT;
            return new ExprVal(z, MkType("bool"));
        }
        // pointer/null comparisons (peek operand kind before evaluating)
        if (op == TK.EqEq() || op == TK.BangEq()) {
            if (e.a.kind == AK.NullLit() || e.b.kind == AK.NullLit()) {
                Node other = e.a; if (e.a.kind == AK.NullLit()) { other = e.b; }
                ExprVal ov = GenExpr(other);
                string ot = MapType(ov.ty);
                string cc = "eq"; if (op == TK.BangEq()) { cc = "ne"; }
                string c = NT();
                L("  " + c + " = icmp " + cc + " " + ot + " " + ov.op + ", null");
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
        }
        ExprVal a = GenExpr(e.a);
        ExprVal b = GenExpr(e.b);
        // user-defined operator overloading takes precedence for class operands
        ExprVal ov = TryOpOverload(op, a, b);
        if (ov != null) { return ov; }
        // floating-point arithmetic/comparison (string `+` concatenation wins)
        if ((IsDbl(a.ty) || IsDbl(b.ty)) && !(IsStr(a.ty) || IsStr(b.ty))) {
            string da = AsDouble(a);
            string db = AsDouble(b);
            string fop = FArithOp(op);
            if (fop != "") {
                string t = NT();
                L("  " + t + " = " + fop + " double " + da + ", " + db);
                return new ExprVal(t, MkType("double"));
            }
            string fcp = FCmpOp(op);
            if (fcp != "") {
                string c = NT();
                L("  " + c + " = fcmp " + fcp + " double " + da + ", " + db);
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
        }
        // addition: concatenate when either operand is a string, else integer add
        if (op == TK.Plus()) {
            if (IsStr(a.ty) || IsStr(b.ty)) {
                return StrConcat(ToCStr(a), ToCStr(b));
            }
            string t = NT();
            L("  " + t + " = add i64 " + a.op + ", " + b.op);
            return new ExprVal(t, MkType("int"));
        }
        if (op == TK.EqEq() || op == TK.BangEq()) {
            if (IsStr(a.ty) && IsStr(b.ty)) {
                string r = NT();
                L("  " + r + " = call i32 @strcmp(i8* " + a.op + ", i8* " + b.op + ")");
                string cc = "eq"; if (op == TK.BangEq()) { cc = "ne"; }
                string c = NT();
                L("  " + c + " = icmp " + cc + " i32 " + r + ", 0");
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
            // reference identity: compare pointer operands as pointers, not i64
            string alt = MapType(a.ty); string blt = MapType(b.ty);
            if (IsPtrLL(alt) && IsPtrLL(blt)) {
                string pty = alt;
                string ao = a.op; string bo = b.op;
                if (blt != pty) {
                    string tb = NT();
                    L("  " + tb + " = bitcast " + blt + " " + bo + " to " + pty);
                    bo = tb;
                }
                string ccp = "eq"; if (op == TK.BangEq()) { ccp = "ne"; }
                string cp = NT();
                L("  " + cp + " = icmp " + ccp + " " + pty + " " + ao + ", " + bo);
                string zp = NT();
                L("  " + zp + " = zext i1 " + cp + " to i64");
                return new ExprVal(zp, MkType("bool"));
            }
            string cc2 = CmpOp(op);
            string c2 = NT();
            L("  " + c2 + " = icmp " + cc2 + " i64 " + a.op + ", " + b.op);
            string z2 = NT();
            L("  " + z2 + " = zext i1 " + c2 + " to i64");
            return new ExprVal(z2, MkType("bool"));
        }
        // string ordering: `<`/`<=`/`>`/`>=` compare content via strcmp, not
        // the raw i8* pointers.
        if (IsStr(a.ty) && IsStr(b.ty)) {
            string scp = CmpOp(op);
            if (scp != "") {
                string r = NT();
                L("  " + r + " = call i32 @strcmp(i8* " + a.op + ", i8* " + b.op + ")");
                string c = NT();
                L("  " + c + " = icmp " + scp + " i32 " + r + ", 0");
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
        }
        string ar = ArithOp(op);
        if (ar != "") {
            // peephole: identity simplifications (operands already evaluated)
            if ((op == TK.Plus() || op == TK.Minus()) && b.op == "0") { return a; }
            if (op == TK.Plus() && a.op == "0") { return b; }
            if ((op == TK.Star() || op == TK.Slash()) && b.op == "1") { return a; }
            if (op == TK.Star() && a.op == "1") { return b; }
            string t = NT();
            L("  " + t + " = " + ar + " i64 " + a.op + ", " + b.op);
            return new ExprVal(t, MkType("int"));
        }
        string cp = CmpOp(op);
        if (cp != "") {
            // lexicographic ordering for strings (matches ==/!= strcmp handling)
            if (IsStr(a.ty) && IsStr(b.ty)) {
                string r = NT();
                L("  " + r + " = call i32 @strcmp(i8* " + a.op + ", i8* " + b.op + ")");
                string cs = NT();
                L("  " + cs + " = icmp " + cp + " i32 " + r + ", 0");
                string zs = NT();
                L("  " + zs + " = zext i1 " + cs + " to i64");
                return new ExprVal(zs, MkType("bool"));
            }
            string c = NT();
            L("  " + c + " = icmp " + cp + " i64 " + a.op + ", " + b.op);
            string z = NT();
            L("  " + z + " = zext i1 " + c + " to i64");
            return new ExprVal(z, MkType("bool"));
        }
        return new ExprVal("0", MkType("int"));
    }

    // Map an operator token to the mangled method name (must match parser).
    string OpName(int op) {
        if (op == TK.Plus()) { return "op_add"; }
        if (op == TK.Minus()) { return "op_sub"; }
        if (op == TK.Star()) { return "op_mul"; }
        if (op == TK.Slash()) { return "op_div"; }
        if (op == TK.Percent()) { return "op_mod"; }
        if (op == TK.EqEq()) { return "op_eq"; }
        if (op == TK.BangEq()) { return "op_ne"; }
        if (op == TK.Less()) { return "op_lt"; }
        if (op == TK.Greater()) { return "op_gt"; }
        if (op == TK.LessEq()) { return "op_le"; }
        if (op == TK.GreaterEq()) { return "op_ge"; }
        return "";
    }

    // Dispatch a binary op to a static operator method on either operand's
    // class, e.g. a + b -> @Vec_op_add(Vec, Vec). Returns null when none.
    ExprVal TryOpOverload(int op, ExprVal a, ExprVal b) {
        string mn = OpName(op);
        if (mn == "") { return null; }
        string owner = "";
        Node m = null;
        Node ca = ClassOf(a.ty);
        if (ca != null) { m = binder.FindMethod(ca, mn); if (m != null) { owner = a.ty.sval; } }
        if (m == null) {
            Node cb = ClassOf(b.ty);
            if (cb != null) { m = binder.FindMethod(cb, mn); if (m != null) { owner = b.ty.sval; } }
        }
        if (m == null) { return null; }
        Node p0 = ParamTypeNode(m, 0);
        Node p1 = ParamTypeNode(m, 1);
        string args = MapType(p0) + " " + CallArg(a, p0) + ", " + MapType(p1) + " " + CallArg(b, p1);
        string rt = MapType(m.type);
        if (rt == "void") {
            L("  call void @" + owner + "_" + mn + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + owner + "_" + mn + "(" + args + ")");
        return new ExprVal(t, m.type);
    }

    bool ExprIsStr(Node e) {
        if (e == null) { return false; }
        if (e.kind == AK.StringLit()) { return true; }
        return false;
    }

    // coerce a value to i8* string form (numbers via snprintf)
    string ToCStr(ExprVal v) {
        if (IsStr(v.ty)) { return v.op; }
        // double -> string (via snprintf "%g")
        if (IsDbl(v.ty)) {
            string dneed = NT();
            L("  " + dneed + " = call i32 (i8*, i64, i8*, ...) @snprintf(i8* null, i64 0, i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.fmt.gn, i64 0, i64 0), double " + v.op + ")");
            string dneed64 = NT();
            L("  " + dneed64 + " = sext i32 " + dneed + " to i64");
            string dbsz = NT();
            L("  " + dbsz + " = add i64 " + dneed64 + ", 1");
            string dbuf = NT();
            L("  " + dbuf + " = call i8* @malloc(i64 " + dbsz + ")");
            L("  call i32 (i8*, i64, i8*, ...) @snprintf(i8* " + dbuf + ", i64 " + dbsz + ", i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.fmt.gn, i64 0, i64 0), double " + v.op + ")");
            return dbuf;
        }
        // integer -> string
        string need = NT();
        L("  " + need + " = call i32 (i8*, i64, i8*, ...) @snprintf(i8* null, i64 0, i8* getelementptr inbounds ([5 x i8], [5 x i8]* @.fmt.nn, i64 0, i64 0), i64 " + v.op + ")");
        string need64 = NT();
        L("  " + need64 + " = sext i32 " + need + " to i64");
        string bsz = NT();
        L("  " + bsz + " = add i64 " + need64 + ", 1");
        string buf = NT();
        L("  " + buf + " = call i8* @malloc(i64 " + bsz + ")");
        L("  call i32 (i8*, i64, i8*, ...) @snprintf(i8* " + buf + ", i64 " + bsz + ", i8* getelementptr inbounds ([5 x i8], [5 x i8]* @.fmt.nn, i64 0, i64 0), i64 " + v.op + ")");
        return buf;
    }

    ExprVal StrConcat(string a, string b) {
        string la = NT(); L("  " + la + " = call i64 @strlen(i8* " + a + ")");
        string lb = NT(); L("  " + lb + " = call i64 @strlen(i8* " + b + ")");
        string tot = NT(); L("  " + tot + " = add i64 " + la + ", " + lb);
        string tot1 = NT(); L("  " + tot1 + " = add i64 " + tot + ", 1");
        string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + tot1 + ")");
        L("  call i8* @strcpy(i8* " + buf + ", i8* " + a + ")");
        L("  call i8* @strcat(i8* " + buf + ", i8* " + b + ")");
        return new ExprVal(buf, MkType("string"));
    }

    // ---- assignment ----
    ExprVal GenAssign(Node e) {
        ExprVal rhs;
        if (e.op == TK.Eq()) {
            rhs = GenExpr(e.b);
            StoreTo(e.a, rhs);
            return rhs;
        }
        // compound: load current, apply, store
        ExprVal cur = GenExpr(e.a);
        ExprVal r = GenExpr(e.b);
        if (IsStr(cur.ty) && e.op == TK.PlusEq()) {
            ExprVal cc = StrConcat(ToCStr(cur), ToCStr(r));
            StoreTo(e.a, cc);
            return cc;
        }
        if (IsDbl(cur.ty) || IsDbl(r.ty)) {
            string da = AsDouble(cur);
            string db = AsDouble(r);
            string fopn = "fadd";
            if (e.op == TK.MinusEq()) { fopn = "fsub"; }
            if (e.op == TK.StarEq()) { fopn = "fmul"; }
            if (e.op == TK.SlashEq()) { fopn = "fdiv"; }
            string ft = NT();
            L("  " + ft + " = " + fopn + " double " + da + ", " + db);
            ExprVal fnv = new ExprVal(ft, MkType("double"));
            StoreTo(e.a, fnv);
            return fnv;
        }
        string opn = "add";
        if (e.op == TK.MinusEq()) { opn = "sub"; }
        if (e.op == TK.StarEq()) { opn = "mul"; }
        if (e.op == TK.SlashEq()) { opn = "sdiv"; }
        string t = NT();
        L("  " + t + " = " + opn + " i64 " + cur.op + ", " + r.op);
        ExprVal nv = new ExprVal(t, MkType("int"));
        StoreTo(e.a, nv);
        return nv;
    }

    void StoreTo(Node lhs, ExprVal v) {
        if (lhs.kind == AK.Ident()) {
            int li = LocalIdx(lhs.sval);
            if (li >= 0) {
                Node lty = locType[li];
                if (IsNullableValue(lty)) {
                    L("  store i8* " + BoxFor(v, lty) + ", i8** " + locReg[li]);
                    return;
                }
                string lt = MapType(lty);
                if (ArcManaged(lty)) {
                    string old = NT();
                    L("  " + old + " = load " + lt + ", " + lt + "* " + locReg[li]);
                    string sv = Coerce(v, lt);
                    L("  store " + lt + " " + sv + ", " + lt + "* " + locReg[li]);
                    EmitArcRetain(sv, lty);
                    EmitArcRelease(old, lty);
                } else {
                    L("  store " + lt + " " + Coerce(v, lt) + ", " + lt + "* " + locReg[li]);
                }
                return;
            }
            if (curHasThis) {
                Node cls = binder.FindType(curClass);
                if (cls != null && FieldIndex(cls, lhs.sval) >= 0) {
                    StoreField("%this", curClass, lhs.sval, v);
                    return;
                }
                if (cls != null && EmitPropSet("%this", MkType(curClass), lhs.sval, v)) { return; }
            }
            return;
        }
        if (lhs.kind == AK.MemberAccess()) {
            ExprVal obj = GenExpr(lhs.a);
            string cn = obj.ty.sval;
            Node ocls = binder.FindType(cn);
            if (ocls != null && FieldIndex(ocls, lhs.sval) < 0
                && EmitPropSet(obj.op, obj.ty, lhs.sval, v)) { return; }
            StoreField(obj.op, cn, lhs.sval, v);
            return;
        }
        if (lhs.kind == AK.Index()) {
            ExprVal obj = GenExpr(lhs.a);
            ExprVal idx = GenExpr(lhs.b);
            if (IsListType(obj.ty)) {
                string sv = ToSlot(v, ListElem(obj.ty));
                L("  call void @zlist_set(i8* " + obj.op + ", i64 " + idx.op + ", i64 " + sv + ")");
                return;
            }
            if (IsDictType(obj.ty)) {
                string sv = ToSlot(v, DictVal(obj.ty));
                L("  call void @zdict_set(i8* " + obj.op + ", i8* " + idx.op + ", i64 " + sv + ")");
                return;
            }
            // array of i64
            string p = NT();
            L("  " + p + " = getelementptr i64, i64* " + obj.op + ", i64 " + idx.op);
            L("  store i64 " + v.op + ", i64* " + p);
            return;
        }
    }

    // obj.Name = v  ->  Owner_set_Name(obj, v). Returns false if no setter.
    bool EmitPropSet(string objOp, Node recvTy, string name, ExprVal v) {
        string clsName = recvTy.sval;
        Node cls = binder.FindType(clsName);
        Node m = FindMethodUp(cls, "set_" + name);
        if (m == null) { return false; }
        string owner = MethodOwner(cls, "set_" + name);
        if (owner == "") { owner = clsName; }
        string thisOp = objOp;
        if (owner != clsName) {
            string bc = NT();
            L("  " + bc + " = bitcast %" + clsName + "* " + objOp + " to %" + owner + "*");
            thisOp = bc;
        }
        Node pty = ParamTypeNode(m, 0);
        L("  call void @" + MethodSym(owner, m) + "(%" + owner + "* " + thisOp
            + ", " + MapType(pty) + " " + CallArg(v, pty) + ")");
        return true;
    }

    void StoreField(string objOp, string clsName, string field, ExprVal v) {
        Node cls = binder.FindType(clsName);
        int idx = FieldIndex(cls, field);
        Node fty = FieldType(cls, field);
        string p = NT();
        L("  " + p + " = getelementptr %" + clsName + ", %" + clsName + "* " + objOp + ", i32 0, i32 " + idx);
        // erased field: pack the value into an i64 slot
        if (IsErasedType(fty)) {
            string sv = ToSlot(v, v.ty);
            L("  store i64 " + sv + ", i64* " + p);
            return;
        }
        string ft = MapType(fty);
        if (ArcManaged(fty)) {
            string old = NT();
            L("  " + old + " = load " + ft + ", " + ft + "* " + p);
            string sv = Coerce(v, ft);
            L("  store " + ft + " " + sv + ", " + ft + "* " + p);
            EmitArcRetain(sv, fty);
            EmitArcRelease(old, fty);
        } else {
            L("  store " + ft + " " + Coerce(v, ft) + ", " + ft + "* " + p);
        }
    }

    // convert a value to an i64 list slot (pointers via ptrtoint)
    string ToSlot(ExprVal v, Node elemTy) {
        string lt = MapType(elemTy);
        if (lt == "i64") { return v.op; }
        if (lt == "double") {
            string tb = NT();
            L("  " + tb + " = bitcast double " + v.op + " to i64");
            return tb;
        }
        if (v.op == "null") { return "0"; }
        string t = NT();
        L("  " + t + " = ptrtoint " + lt + " " + v.op + " to i64");
        return t;
    }

    ExprVal FromSlot(string slot, Node elemTy) {
        string lt = MapType(elemTy);
        if (lt == "i64") { return new ExprVal(slot, elemTy); }
        string t = NT();
        if (lt == "double") {
            L("  " + t + " = bitcast i64 " + slot + " to double");
            return new ExprVal(t, elemTy);
        }
        L("  " + t + " = inttoptr i64 " + slot + " to " + lt);
        return new ExprVal(t, elemTy);
    }

    bool IsTuple(Node t) {
        if (t == null) { return false; }
        return t.sval == "Tuple";
    }

    bool IsItemName(string s) {
        if (s.Length < 5) { return false; }
        return s[0] == 'I' && s[1] == 't' && s[2] == 'e' && s[3] == 'm';
    }

    int ItemIndex(string s) {
        int n = 0; int i = 4;
        while (i < s.Length) { n = n * 10 + (s[i] - '0'); i = i + 1; }
        return n - 1;
    }

    // is class `sub` equal to or derived from `baseName`?
    bool IsSubclassName(string sub, string baseName) {
        Node c = binder.FindType(sub);
        while (c != null) {
            if (c.sval == baseName) { return true; }
            c = BaseClassOf(c);
        }
        return false;
    }

    // type test:  obj is T [name].  Closed-world RTTI: compare the object's
    // vtable pointer against the vtable of T and of every concrete polymorphic
    // subclass of T. Optional `name` binds obj cast to T*.
    ExprVal GenIs(Node e) {
        ExprVal obj = GenExpr(e.a);
        string tname = e.type.sval;
        string sty = obj.ty.sval;
        Node scls = binder.FindType(sty);
        if (e.sval != "") {
            string reg = AddLocal(e.sval, e.type);
            L("  " + reg + " = alloca %" + tname + "*");
            string bc = NT();
            L("  " + bc + " = bitcast " + MapType(obj.ty) + " " + obj.op + " to %" + tname + "*");
            L("  store %" + tname + "* " + bc + ", %" + tname + "** " + reg);
        }
        if (scls == null || !IsPolyClass(scls)) {
            int ok = 0;
            if (IsSubclassName(sty, tname)) { ok = 1; }
            return new ExprVal("" + ok, MkType("bool"));
        }
        string vtp = NT();
        L("  " + vtp + " = getelementptr %" + sty + ", %" + sty + "* " + obj.op + ", i32 0, i32 0");
        string vt = NT();
        L("  " + vt + " = load i8*, i8** " + vtp);
        List<Node> ts = binder.types;
        string acc = "";
        int i = 0;
        while (i < ts.Count) {
            Node c = ts[i];
            bool isCls = (c.kind == AK.ClassDecl() || c.kind == AK.StructDecl());
            if (isCls && IsPolyClass(c) && !HasMod(c, MOD.Abstract()) && IsSubclassName(c.sval, tname)) {
                List<string> vslots = new List<string>();
                CollectVSlots(c, vslots);
                string cmp = NT();
                L("  " + cmp + " = icmp eq i8* " + vt + ", bitcast ([" + vslots.Count + " x i8*]* @" + c.sval + "_vtable to i8*)");
                if (acc == "") { acc = cmp; }
                else {
                    string o = NT();
                    L("  " + o + " = or i1 " + acc + ", " + cmp);
                    acc = o;
                }
            }
            i = i + 1;
        }
        if (acc == "") { return new ExprVal("0", MkType("bool")); }
        string z = NT();
        L("  " + z + " = zext i1 " + acc + " to i64");
        return new ExprVal(z, MkType("bool"));
    }

    // tuple literal (a, b, ...) -> heap i64[N], each element packed into a slot.
    ExprVal GenTuple(Node e) {
        int n = e.kids.Count;
        Node tty = new Node(AK.TypeRef()); tty.sval = "Tuple";
        string buf = NT();
        L("  " + buf + " = call i8* @malloc(i64 " + (n * 8) + ")");
        string p = NT();
        L("  " + p + " = bitcast i8* " + buf + " to i64*");
        int i = 0;
        while (i < n) {
            ExprVal ev = GenExpr(e.kids[i]);
            tty.Add(ev.ty);
            string slot = NT();
            L("  " + slot + " = getelementptr i64, i64* " + p + ", i64 " + i);
            L("  store i64 " + ToSlot(ev, ev.ty) + ", i64* " + slot);
            i = i + 1;
        }
        return new ExprVal(buf, tty);
    }

    // deconstruction: var (a, b, ...) = tupleExpr;  unpacks each slot into a local.
    void GenDecon(Node s) {
        ExprVal rhs = GenExpr(s.b);
        List<Node> ekids = rhs.ty.kids;
        string p = NT();
        L("  " + p + " = bitcast i8* " + rhs.op + " to i64*");
        int i = 0;
        while (i < s.kids.Count) {
            Node tgt = s.kids[i];
            Node ety = tgt.type;
            if (ety == null) {
                if (i < ekids.Count) { ety = ekids[i]; } else { ety = MkType("int"); }
            }
            string slot = NT();
            L("  " + slot + " = getelementptr i64, i64* " + p + ", i64 " + i);
            string raw = NT();
            L("  " + raw + " = load i64, i64* " + slot);
            ExprVal ev = FromSlot(raw, ety);
            string lt = MapType(ety);
            string reg = AddLocal(tgt.sval, ety);
            L("  " + reg + " = alloca " + lt);
            L("  store " + lt + " " + Coerce(ev, lt) + ", " + lt + "* " + reg);
            i = i + 1;
        }
    }

    // ---- member access (field / .Length / .Count) ----
    ExprVal GenMember(Node e) {
        ExprVal obj = GenExpr(e.a);
        if (IsNullableValue(obj.ty) && e.sval == "HasValue") {
            string t = NT();
            L("  " + t + " = icmp ne i8* " + obj.op + ", null");
            string z = NT();
            L("  " + z + " = zext i1 " + t + " to i64");
            return new ExprVal(z, MkType("bool"));
        }
        if (IsNullableValue(obj.ty) && e.sval == "Value") {
            string ult = UnderLL(obj.ty);
            string p = NT();
            L("  " + p + " = bitcast i8* " + obj.op + " to " + ult + "*");
            string t = NT();
            L("  " + t + " = load " + ult + ", " + ult + "* " + p);
            Node uty = MkType(obj.ty.sval);
            return new ExprVal(t, uty);
        }
        if (IsTuple(obj.ty) && IsItemName(e.sval)) {
            int idx = ItemIndex(e.sval);
            List<Node> ekids = obj.ty.kids;
            Node ety = MkType("int");
            if (idx < ekids.Count) { ety = ekids[idx]; }
            string p = NT();
            L("  " + p + " = bitcast i8* " + obj.op + " to i64*");
            string slot = NT();
            L("  " + slot + " = getelementptr i64, i64* " + p + ", i64 " + idx);
            string raw = NT();
            L("  " + raw + " = load i64, i64* " + slot);
            return FromSlot(raw, ety);
        }
        if (e.sval == "Length" && IsStr(obj.ty)) {
            string t = NT();
            L("  " + t + " = call i64 @strlen(i8* " + obj.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        if (e.sval == "Count" && IsListType(obj.ty)) {
            string t = NT();
            L("  " + t + " = call i64 @zlist_count(i8* " + obj.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        if (e.sval == "Count" && IsDictType(obj.ty)) {
            string t = NT();
            L("  " + t + " = call i64 @zdict_count(i8* " + obj.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        Node cls = ClassOf(obj.ty);
        if (cls != null && FieldIndex(cls, e.sval) >= 0) {
            return LoadField(obj.op, obj.ty, e.sval);
        }
        // property getter: obj.Name -> obj.get_Name()
        if (cls != null && FindMethodUp(cls, "get_" + e.sval) != null) {
            return EmitInstanceCall(obj, obj.ty.sval, "get_" + e.sval, new Node(AK.Call()));
        }
        return new ExprVal("0", MkType("int"));
    }

    // ---- indexing (string char / list element / array) ----
    ExprVal GenIndex(Node e) {
        ExprVal obj = GenExpr(e.a);
        ExprVal idx = GenExpr(e.b);
        if (IsStr(obj.ty)) {
            string p = NT();
            L("  " + p + " = getelementptr i8, i8* " + obj.op + ", i64 " + idx.op);
            string ch = NT();
            L("  " + ch + " = load i8, i8* " + p);
            string z = NT();
            L("  " + z + " = zext i8 " + ch + " to i64");
            return new ExprVal(z, MkType("char"));
        }
        if (IsListType(obj.ty)) {
            string slot = NT();
            L("  " + slot + " = call i64 @zlist_get(i8* " + obj.op + ", i64 " + idx.op + ")");
            return FromSlot(slot, ListElem(obj.ty));
        }
        if (IsDictType(obj.ty)) {
            string slot = NT();
            L("  " + slot + " = call i64 @zdict_get(i8* " + obj.op + ", i8* " + idx.op + ")");
            return FromSlot(slot, DictVal(obj.ty));
        }
        string p2 = NT();
        L("  " + p2 + " = getelementptr i64, i64* " + obj.op + ", i64 " + idx.op);
        string v = NT();
        L("  " + v + " = load i64, i64* " + p2);
        return new ExprVal(v, MkType("int"));
    }

    // ---- new ----
    ExprVal GenNew(Node e) {
        Node ty = e.type;
        if (e.ival == 1) {
            // array new: T[n] as i64* (n slots)
            ExprVal nsz = new ExprVal("0", MkType("int"));
            if (e.b != null) { nsz = GenExpr(e.b); }
            string bytes = NT();
            L("  " + bytes + " = mul i64 " + nsz.op + ", 8");
            string raw = NT();
            L("  " + raw + " = call i8* @malloc(i64 " + bytes + ")");
            string arr = NT();
            L("  " + arr + " = bitcast i8* " + raw + " to i64*");
            Node at = MkType(ty.sval); at.ival = 1;
            return new ExprVal(arr, at);
        }
        if (IsListType(ty)) {
            string t = NT();
            string ow = "0"; if (ArcManaged(ListElem(ty))) { ow = "1"; }
            L("  " + t + " = call i8* @zlist_new(i64 " + ow + ")");
            if (e.ival == 2) {
                // collection initializer: append each item
                int j = 0;
                while (j < e.kids.Count) {
                    ExprVal iv = GenExpr(e.kids[j]);
                    string sv = ToSlot(iv, ListElem(ty));
                    L("  call void @zlist_add(i8* " + t + ", i64 " + sv + ")");
                    j = j + 1;
                }
            }
            AddTemp(t, ty);
            return new ExprVal(t, ty);
        }
        if (IsDictType(ty)) {
            string t = NT();
            string ow = "0"; if (ArcManaged(DictVal(ty))) { ow = "1"; }
            L("  " + t + " = call i8* @zdict_new(i64 " + ow + ")");
            AddTemp(t, ty);
            return new ExprVal(t, ty);
        }
        if (IsSbType(ty)) {
            string t = NT();
            L("  " + t + " = call i8* @zsb_new()");
            AddTemp(t, ty);
            return new ExprVal(t, ty);
        }
        // object
        string cn = ty.sval;
        Node cls = binder.FindType(cn);
        if (cls == null) { return new ExprVal("null", ty); }
        string szp = NT();
        L("  " + szp + " = getelementptr %" + cn + ", %" + cn + "* null, i32 1");
        string szi = NT();
        L("  " + szi + " = ptrtoint %" + cn + "* " + szp + " to i64");
        string raw = NT();
        L("  " + raw + " = call i8* @zalloc(i64 " + szi + ", i8* bitcast (void (i8*)* @" + cn + "_dtor to i8*))");
        string obj = NT();
        L("  " + obj + " = bitcast i8* " + raw + " to %" + cn + "*");
        if (IsPolyClass(cls)) {
            List<string> vslots = new List<string>();
            CollectVSlots(cls, vslots);
            string vtp0 = NT();
            L("  " + vtp0 + " = getelementptr %" + cn + ", %" + cn + "* " + obj + ", i32 0, i32 0");
            L("  store i8* bitcast ([" + vslots.Count + " x i8*]* @" + cn + "_vtable to i8*), i8** " + vtp0);
        }
        // call ctor if present. With an object initializer (ival == 2) the kids
        // are `Field = value` pairs, not ctor args, so only a parameterless ctor
        // is invoked and the field stores follow.
        Node ctor = binder.FindCtor(cls);
        if (ctor != null && e.ival != 2) {
            string args = "%" + cn + "* " + obj;
            int i = 0;
            while (i < e.kids.Count) {
                ExprVal av = GenExpr(e.kids[i]);
                Node pty = CtorParamType(ctor, i);
                args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
                i = i + 1;
            }
            L("  call void @" + cn + "_ctor(" + args + ")");
        } else if (ctor != null && e.ival == 2 && CtorParamCount(ctor) == 0) {
            L("  call void @" + cn + "_ctor(%" + cn + "* " + obj + ")");
        }
        // object initializer: store each `Field = value` into the instance
        if (e.ival == 2) {
            int j = 0;
            while (j < e.kids.Count) {
                Node it = e.kids[j];
                if (it.kind == AK.Assignment() && it.a != null
                    && it.a.kind == AK.Ident()) {
                    ExprVal fv = GenExpr(it.b);
                    StoreField(obj, cn, it.a.sval, fv);
                }
                j = j + 1;
            }
        }
        // preserve generic type arguments (ty may carry <...>) for the result
        AddTemp(obj, ty);
        return new ExprVal(obj, ty);
    }

    int CtorParamCount(Node ctor) {
        int n = 0; int i = 0;
        while (i < ctor.kids.Count) {
            if (ctor.kids[i].kind == AK.Param()) { n = n + 1; }
            i = i + 1;
        }
        return n;
    }

    Node CtorParamType(Node ctor, int argIdx) {
        int seen = 0; int i = 0;
        while (i < ctor.kids.Count) {
            if (ctor.kids[i].kind == AK.Param()) {
                if (seen == argIdx) { return ctor.kids[i].type; }
                seen = seen + 1;
            }
            i = i + 1;
        }
        return MkType("int");
    }

    // ---- cast ----
    ExprVal GenCast(Node e) {
        ExprVal v = GenExpr(e.b);
        Node tgt = e.type;
        bool toD = IsDbl(tgt);
        bool fromD = IsDbl(v.ty);
        // int -> double
        if (toD && !fromD && MapType(v.ty) == "i64") {
            string t = NT();
            L("  " + t + " = sitofp i64 " + v.op + " to double");
            return new ExprVal(t, tgt);
        }
        // double -> int (truncating toward zero)
        if (fromD && !toD && MapType(tgt) == "i64") {
            string t = NT();
            L("  " + t + " = fptosi double " + v.op + " to i64");
            return new ExprVal(t, tgt);
        }
        // remaining numeric casts are all i64 in this model; just retag
        return new ExprVal(v.op, tgt);
    }

    // switch expression:  subj switch { pat => e, _ => e }. Constant patterns
    // (int / string) compared against the subject; "_" is the default arm.
    // Lowered to a test cascade feeding a phi at the join block.
    string RelCmp(int op) {
        if (op == TK.Less()) { return "slt"; }
        if (op == TK.Greater()) { return "sgt"; }
        if (op == TK.LessEq()) { return "sle"; }
        if (op == TK.GreaterEq()) { return "sge"; }
        return "eq";
    }

    ExprVal GenSwitchExpr(Node e) {
        List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;
        stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
        ExprVal subj = GenExpr(e.a);
        int nend = NL();
        List<string> vals = new List<string>();
        List<string> labs = new List<string>();
        string resLL = "i64";
        Node resTy = MkType("int");
        int i = 0;
        while (i < e.kids.Count) {
            Node arm = e.kids[i];
            int bodyL = NL();
            int nextL = NL();
            if (arm.a == null) {
                if (arm.c != null) {
                    ExprVal gv = GenExpr(arm.c);
                    string gi = NT();
                    L("  " + gi + " = icmp ne i64 " + gv.op + ", 0");
                    L("  br i1 " + gi + ", label %L" + bodyL + ", label %L" + nextL);
                } else {
                    L("  br label %L" + bodyL);
                }
            } else {
                ExprVal pv = GenExpr(arm.a);
                string c = NT();
                if (arm.op != 0) {
                    L("  " + c + " = icmp " + RelCmp(arm.op) + " i64 " + subj.op + ", " + pv.op);
                } else if (IsStr(subj.ty) && IsStr(pv.ty)) {
                    string r = NT();
                    L("  " + r + " = call i32 @strcmp(i8* " + subj.op + ", i8* " + pv.op + ")");
                    L("  " + c + " = icmp eq i32 " + r + ", 0");
                } else {
                    L("  " + c + " = icmp eq i64 " + subj.op + ", " + pv.op);
                }
                if (arm.c != null) {
                    int guardL = NL();
                    L("  br i1 " + c + ", label %L" + guardL + ", label %L" + nextL);
                    Label(guardL);
                    ExprVal gv = GenExpr(arm.c);
                    string gi = NT();
                    L("  " + gi + " = icmp ne i64 " + gv.op + ", 0");
                    L("  br i1 " + gi + ", label %L" + bodyL + ", label %L" + nextL);
                } else {
                    L("  br i1 " + c + ", label %L" + bodyL + ", label %L" + nextL);
                }
            }
            Label(bodyL);
            ExprVal rv = GenExpr(arm.b);
            resLL = MapType(rv.ty);
            resTy = rv.ty;
            vals.Add(Coerce(rv, resLL));
            labs.Add(curLbl);
            L("  br label %L" + nend);
            Label(nextL);
            i = i + 1;
        }
        L("  br label %L" + nend);
        string fbLbl = curLbl;
        Label(nend);
        string t = NT();
        string zero = "0"; if (resLL == "i8*") { zero = "null"; }
        string phi = t + " = phi " + resLL;
        int j = 0;
        while (j < vals.Count) {
            if (j > 0) { phi = phi + ","; }
            phi = phi + " [ " + vals[j] + ", %" + labs[j] + " ]";
            j = j + 1;
        }
        if (vals.Count > 0) { phi = phi + ", [ " + zero + ", %" + fbLbl + " ]"; }
        else { phi = phi + " [ " + zero + ", %" + fbLbl + " ]"; }
        L("  " + phi);
        stmtTemps = svT; stmtTempTypes = svTT;
        return new ExprVal(t, resTy);
    }

    // ---- lambdas / delegates ----
    bool IsDelegate(Node t) {
        if (t == null) { return false; }
        return binder.IsDelegateName(t.sval);
    }

    Node MkIdent(string name) { Node n = new Node(AK.Ident()); n.sval = name; return n; }

    bool Contains(List<string> xs, string s) {
        int i = 0;
        while (i < xs.Count) { if (xs[i] == s) { return true; } i = i + 1; }
        return false;
    }

    void CollectIdents(Node n, List<string> outv) {
        if (n == null) { return; }
        if (n.kind == AK.Ident()) { if (!Contains(outv, n.sval)) { outv.Add(n.sval); } }
        CollectIdents(n.a, outv); CollectIdents(n.b, outv);
        CollectIdents(n.c, outv); CollectIdents(n.d, outv);
        int i = 0;
        while (i < n.kids.Count) { CollectIdents(n.kids[i], outv); i = i + 1; }
    }

    void CollectDeclared(Node n, List<string> outv) {
        if (n == null) { return; }
        if (n.kind == AK.VarDecl()) { if (!Contains(outv, n.sval)) { outv.Add(n.sval); } }
        if (n.kind == AK.Param()) { if (!Contains(outv, n.sval)) { outv.Add(n.sval); } }
        CollectDeclared(n.a, outv); CollectDeclared(n.b, outv);
        CollectDeclared(n.c, outv); CollectDeclared(n.d, outv);
        int i = 0;
        while (i < n.kids.Count) { CollectDeclared(n.kids[i], outv); i = i + 1; }
    }

    // free enclosing-scope locals referenced by the lambda body (captured by value)
    void CollectCaptures(Node lam, List<string> pnames, List<string> caps, List<Node> capTy) {
        List<string> declared = new List<string>();
        int i = 0;
        while (i < pnames.Count) { declared.Add(pnames[i]); i = i + 1; }
        Node bodyN = lam.d; if (bodyN == null) { bodyN = lam.a; }
        CollectDeclared(bodyN, declared);
        List<string> used = new List<string>();
        CollectIdents(bodyN, used);
        int j = 0;
        while (j < used.Count) {
            string nm = used[j];
            if (!Contains(declared, nm) && !Contains(caps, nm)) {
                int li = LocalIdx(nm);
                if (li >= 0) { caps.Add(nm); capTy.Add(locType[li]); }
            }
            j = j + 1;
        }
    }

    // copy delegate parameter/return types onto a lambda's params + return slot
    void AnnotateLambda(Node lam, Node dty) {
        int np = 0; int i = 0;
        while (i < lam.kids.Count) { if (lam.kids[i].kind == AK.Param()) { np = np + 1; } i = i + 1; }
        int j = 0; int pi = 0;
        while (j < lam.kids.Count) {
            if (lam.kids[j].kind == AK.Param()) {
                if (pi < dty.kids.Count) { lam.kids[j].type = dty.kids[pi]; }
                pi = pi + 1;
            }
            j = j + 1;
        }
        if (dty.sval == "Func" && dty.kids.Count > np) { lam.type = dty.kids[dty.kids.Count - 1]; }
        else { lam.type = MkType("void"); }
    }

    string LamFnType(Node retTy, List<Node> pt) {
        string s = MapType(retTy) + " (i8*";
        int i = 0;
        while (i < pt.Count) { s = s + ", " + MapType(pt[i]); i = i + 1; }
        s = s + ")*";
        return s;
    }

    Node DelegTypeOf(Node retTy, List<Node> pt) {
        Node d = new Node(AK.TypeRef());
        int i = 0;
        while (i < pt.Count) { d.Add(pt[i]); i = i + 1; }
        if (retTy != null && retTy.sval == "void") { d.sval = "Action"; }
        else { d.sval = "Func"; d.Add(retTy); }
        return d;
    }

    List<Node> DelegParams(Node dty) {
        List<Node> r = new List<Node>();
        int n = dty.kids.Count;
        int lim = n;
        if (dty.sval == "Func" && n > 0) { lim = n - 1; }
        int i = 0;
        while (i < lim) { r.Add(dty.kids[i]); i = i + 1; }
        return r;
    }

    Node DelegRet(Node dty) {
        if (dty.sval == "Func" && dty.kids.Count > 0) { return dty.kids[dty.kids.Count - 1]; }
        return MkType("void");
    }

    // A lambda lowers to a hoisted top-level function @__lambda_N(i8* env, ...)
    // plus a heap closure { i8* fn, i8* env } capturing free locals by value.
    ExprVal GenLambda(Node lam) {
        int id = lamCount; lamCount = lamCount + 1;
        string fname = "@__lambda_" + id;

        List<string> pn = new List<string>();
        List<Node> pt = new List<Node>();
        int i = 0;
        while (i < lam.kids.Count) {
            Node p = lam.kids[i];
            if (p.kind == AK.Param()) {
                pn.Add(p.sval);
                Node ptp = p.type;
                if (ptp == null || ptp.sval == "var") { ptp = MkType("int"); }
                pt.Add(ptp);
            }
            i = i + 1;
        }
        Node retTy = lam.type; if (retTy == null) { retTy = MkType("int"); }

        List<string> caps = new List<string>();
        List<Node> capTy = new List<Node>();
        CollectCaptures(lam, pn, caps, capTy);
        int nc = caps.Count;

        // build the env with the captured values (in the enclosing function)
        string env = "null";
        if (nc > 0) {
            env = NT();
            L("  " + env + " = call i8* @malloc(i64 " + (nc * 8) + ")");
            string envi = NT();
            L("  " + envi + " = bitcast i8* " + env + " to i64*");
            int c = 0;
            while (c < nc) {
                ExprVal cv = GenExpr(MkIdent(caps[c]));
                string slot = NT();
                L("  " + slot + " = getelementptr i64, i64* " + envi + ", i64 " + c);
                L("  store i64 " + ToSlot(cv, capTy[c]) + ", i64* " + slot);
                c = c + 1;
            }
        }

        // emit the hoisted lambda body into the deferred buffer
        StringBuilder savedBody = body;
        int sTmp = tmp; int sLbl = lbl; bool sTerm = term; string sCurLbl = curLbl;
        string sRet = curRet; string sClass = curClass; bool sHasThis = curHasThis;
        List<string> sLocName = locName; List<Node> sLocType = locType;
        List<string> sLocReg = locReg; int sLocSeq = locSeq;
        int sBrk = brkTarget; int sCont = contTarget;
        int sLoopScope = loopScopeBase;
        List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;

        body = new StringBuilder();
        tmp = 0; lbl = 0; term = false; curLbl = "entry";
        locName = new List<string>(); locType = new List<Node>(); locReg = new List<string>(); locSeq = 0;
        curRet = MapType(retTy); curClass = ""; curHasThis = false; brkTarget = 0; contTarget = 0;

        string sig = "define " + curRet + " " + fname + "(i8* %env";
        int a = 0;
        while (a < pn.Count) { sig = sig + ", " + MapType(pt[a]) + " %p" + a; a = a + 1; }
        sig = sig + ") {";
        L(sig);
        L("entry:");
        a = 0;
        while (a < pn.Count) {
            string lt = MapType(pt[a]);
            string preg = AddLocal(pn[a], pt[a]);
            L("  " + preg + " = alloca " + lt);
            L("  store " + lt + " %p" + a + ", " + lt + "* " + preg);
            EmitArcRetain("%p" + a, pt[a]);
            a = a + 1;
        }
        if (nc > 0) {
            string envi = NT();
            L("  " + envi + " = bitcast i8* %env to i64*");
            int c = 0;
            while (c < nc) {
                string slot = NT();
                L("  " + slot + " = getelementptr i64, i64* " + envi + ", i64 " + c);
                string raw = NT();
                L("  " + raw + " = load i64, i64* " + slot);
                ExprVal cv = FromSlot(raw, capTy[c]);
                string lt = MapType(capTy[c]);
                string creg = AddLocal(caps[c], capTy[c]);
                L("  " + creg + " = alloca " + lt);
                string csv = Coerce(cv, lt);
                L("  store " + lt + " " + csv + ", " + lt + "* " + creg);
                EmitArcRetain(csv, capTy[c]);
                c = c + 1;
            }
        }
        if (lam.d != null) {
            GenStmt(lam.d);
            if (!term) {
                ReleaseLocalsFrom(0);
                if (curRet == "void") { L("  ret void"); }
                else if (curRet == "i64") { L("  ret i64 0"); }
                else { L("  ret " + curRet + " null"); }
            }
        } else {
            stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
            ExprVal rv = GenExpr(lam.a);
            if (curRet == "void") {
                EmitTempReleases();
                ReleaseLocalsFrom(0);
                L("  ret void");
            } else {
                string rvs = Coerce(rv, curRet);
                EmitArcRetain(rvs, rv.ty);
                EmitTempReleases();
                ReleaseLocalsFrom(0);
                L("  ret " + curRet + " " + rvs);
            }
        }
        L("}");
        deferred.Append(body.ToString());

        body = savedBody;
        tmp = sTmp; lbl = sLbl; term = sTerm; curLbl = sCurLbl;
        curRet = sRet; curClass = sClass; curHasThis = sHasThis;
        locName = sLocName; locType = sLocType; locReg = sLocReg; locSeq = sLocSeq;
        brkTarget = sBrk; contTarget = sCont;
        loopScopeBase = sLoopScope;
        stmtTemps = svT; stmtTempTypes = svTT;

        // build closure { i8* fn, i8* env }
        string clo = NT();
        L("  " + clo + " = call i8* @malloc(i64 16)");
        string clop = NT();
        L("  " + clop + " = bitcast i8* " + clo + " to i8**");
        string fni8 = NT();
        L("  " + fni8 + " = bitcast " + LamFnType(retTy, pt) + " " + fname + " to i8*");
        L("  store i8* " + fni8 + ", i8** " + clop);
        string clop1 = NT();
        L("  " + clop1 + " = getelementptr i8*, i8** " + clop + ", i64 1");
        L("  store i8* " + env + ", i8** " + clop1);
        return new ExprVal(clo, DelegTypeOf(retTy, pt));
    }

    // invoke a closure value:  f(args) -> load {fn,env}, bitcast fn, call fn(env, args)
    ExprVal EmitDelegateCall(Node calleeExpr, Node dty, Node e) {
        ExprVal clo = GenExpr(calleeExpr);
        List<Node> pt = DelegParams(dty);
        Node retTy = DelegRet(dty);
        string clop = NT();
        L("  " + clop + " = bitcast i8* " + clo.op + " to i8**");
        string fni8 = NT();
        L("  " + fni8 + " = load i8*, i8** " + clop);
        string envp = NT();
        L("  " + envp + " = getelementptr i8*, i8** " + clop + ", i64 1");
        string env = NT();
        L("  " + env + " = load i8*, i8** " + envp);
        string fn = NT();
        L("  " + fn + " = bitcast i8* " + fni8 + " to " + LamFnType(retTy, pt));
        string args = "i8* " + env;
        int i = 0;
        while (i < e.kids.Count) {
            ExprVal av = GenExpr(e.kids[i]);
            Node pty = MkType("int"); if (i < pt.Count) { pty = pt[i]; }
            args = args + ", " + MapType(pty) + " " + Coerce(av, MapType(pty));
            i = i + 1;
        }
        string rt = MapType(retTy);
        if (rt == "void") { L("  call void " + fn + "(" + args + ")"); return new ExprVal("0", MkType("void")); }
        string t = NT();
        L("  " + t + " = call " + rt + " " + fn + "(" + args + ")");
        AddTemp(t, retTy);
        return new ExprVal(t, retTy);
    }

    // ---- calls ----
    ExprVal GenCall(Node e) {
        Node callee = e.a;
        // Environment / File builtins: ClassName.Method(...)
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()) {
            string cn = callee.a.sval;
            string mn = callee.sval;
            if (cn == "Environment" && mn == "ArgCount") {
                string a = NT(); L("  " + a + " = load i32, i32* @__zan_argc");
                string a64 = NT(); L("  " + a64 + " = sext i32 " + a + " to i64");
                string r = NT(); L("  " + r + " = sub i64 " + a64 + ", 1");
                return new ExprVal(r, MkType("int"));
            }
            if (cn == "Environment" && mn == "ArgAt") {
                ExprVal idx = GenExpr(e.kids[0]);
                string i1 = NT(); L("  " + i1 + " = add i64 " + idx.op + ", 1");
                string av = NT(); L("  " + av + " = load i8**, i8*** @__zan_argv");
                string sp = NT(); L("  " + sp + " = getelementptr i8*, i8** " + av + ", i64 " + i1);
                string r = NT(); L("  " + r + " = load i8*, i8** " + sp);
                return new ExprVal(r, MkType("string"));
            }
            if (cn == "File" && mn == "ReadAllText") {
                ExprVal path = GenExpr(e.kids[0]);
                string rb = NT(); L("  " + rb + " = getelementptr inbounds [3 x i8], [3 x i8]* @.mode_rb, i64 0, i64 0");
                string fp = NT(); L("  " + fp + " = call i8* @fopen(i8* " + path.op + ", i8* " + rb + ")");
                EmitFopenCheck(fp, "@.msg.rderr", 18);
                string se0 = NT(); L("  " + se0 + " = call i32 @fseek(i8* " + fp + ", i64 0, i32 2)");
                string se0c = NT(); L("  " + se0c + " = icmp ne i32 " + se0 + ", 0"); EmitAbortIf(se0c, "@.msg.rderr", 18);
                string sz = NT(); L("  " + sz + " = call i64 @ftell(i8* " + fp + ")");
                string szc = NT(); L("  " + szc + " = icmp slt i64 " + sz + ", 0"); EmitAbortIf(szc, "@.msg.rderr", 18);
                string se1 = NT(); L("  " + se1 + " = call i32 @fseek(i8* " + fp + ", i64 0, i32 0)");
                string se1c = NT(); L("  " + se1c + " = icmp ne i32 " + se1 + ", 0"); EmitAbortIf(se1c, "@.msg.rderr", 18);
                string bsz = NT(); L("  " + bsz + " = add i64 " + sz + ", 1");
                string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + bsz + ")");
                string bufc = NT(); L("  " + bufc + " = icmp eq i8* " + buf + ", null"); EmitAbortIf(bufc, "@.msg.rderr", 18);
                string got = NT(); L("  " + got + " = call i64 @fread(i8* " + buf + ", i64 1, i64 " + sz + ", i8* " + fp + ")");
                string gotc = NT(); L("  " + gotc + " = icmp ne i64 " + got + ", " + sz); EmitAbortIf(gotc, "@.msg.rderr", 18);
                string ep = NT(); L("  " + ep + " = getelementptr i8, i8* " + buf + ", i64 " + sz);
                L("  store i8 0, i8* " + ep);
                string rc = NT(); L("  " + rc + " = call i32 @fclose(i8* " + fp + ")");
                string rcc = NT(); L("  " + rcc + " = icmp ne i32 " + rc + ", 0"); EmitAbortIf(rcc, "@.msg.rderr", 18);
                return new ExprVal(buf, MkType("string"));
            }
            if (cn == "File" && mn == "WriteAllText") {
                ExprVal path = GenExpr(e.kids[0]);
                ExprVal content = GenExpr(e.kids[1]);
                string wb = NT(); L("  " + wb + " = getelementptr inbounds [2 x i8], [2 x i8]* @.mode_wb, i64 0, i64 0");
                string fp = NT(); L("  " + fp + " = call i8* @fopen(i8* " + path.op + ", i8* " + wb + ")");
                EmitFopenCheck(fp, "@.msg.wrerr", 19);
                string ln = NT(); L("  " + ln + " = call i64 @strlen(i8* " + content.op + ")");
                string wr = NT(); L("  " + wr + " = call i64 @fwrite(i8* " + content.op + ", i64 1, i64 " + ln + ", i8* " + fp + ")");
                string wrc = NT(); L("  " + wrc + " = icmp ne i64 " + wr + ", " + ln); EmitAbortIf(wrc, "@.msg.wrerr", 19);
                string wrcl = NT(); L("  " + wrcl + " = call i32 @fclose(i8* " + fp + ")");
                string wrclc = NT(); L("  " + wrclc + " = icmp ne i32 " + wrcl + ", 0"); EmitAbortIf(wrclc, "@.msg.wrerr", 19);
                return new ExprVal("0", MkType("void"));
            }
        }
        // Console.Write / WriteLine
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && callee.a.sval == "Console") {
            ExprVal arg = new ExprVal("0", MkType("int"));
            bool has = (e.kids.Count > 0);
            if (has) { arg = GenExpr(e.kids[0]); }
            bool nl = (callee.sval == "WriteLine");
            if (has && IsStr(arg.ty)) {
                string fg = "@.fmt.sn"; int fl = 3;
                if (nl) { fg = "@.fmt.snl"; fl = 4; }
                string gp = NT();
                L("  " + gp + " = getelementptr inbounds [" + fl + " x i8], [" + fl + " x i8]* " + fg + ", i64 0, i64 0");
                L("  call i32 (i8*, ...) @printf(i8* " + gp + ", i8* " + arg.op + ")");
            } else if (has && IsDbl(arg.ty)) {
                string fg = "@.fmt.gn"; int fl = 3;
                if (nl) { fg = "@.fmt.gnl"; fl = 4; }
                string gp = NT();
                L("  " + gp + " = getelementptr inbounds [" + fl + " x i8], [" + fl + " x i8]* " + fg + ", i64 0, i64 0");
                L("  call i32 (i8*, ...) @printf(i8* " + gp + ", double " + arg.op + ")");
            } else {
                string fg = "@.fmt.nn"; int fl = 5;
                if (nl) { fg = "@.fmt.nl"; fl = 6; }
                string gp = NT();
                L("  " + gp + " = getelementptr inbounds [" + fl + " x i8], [" + fl + " x i8]* " + fg + ", i64 0, i64 0");
                string a0 = "0"; if (has) { a0 = arg.op; }
                L("  call i32 (i8*, ...) @printf(i8* " + gp + ", i64 " + a0 + ")");
            }
            return new ExprVal("0", MkType("void"));
        }
        // Convert.ToString(x) -> heap string via snprintf; Convert.ToInt32(s) -> atoi
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && callee.a.sval == "Convert") {
            if (callee.sval == "ToString" && e.kids.Count == 1) {
                ExprVal a = GenExpr(e.kids[0]);
                string s = ToCStr(a);
                return new ExprVal(s, MkType("string"));
            }
            if ((callee.sval == "ToInt32" || callee.sval == "ToInt") && e.kids.Count == 1) {
                ExprVal a = GenExpr(e.kids[0]);
                string r = NT();
                L("  " + r + " = call i64 @atoi(i8* " + a.op + ")");
                return new ExprVal(r, MkType("int"));
            }
        }
        // method access forms
        if (callee.kind == AK.MemberAccess()) {
            Node obj = callee.a;
            string mname = callee.sval;
            // static call: ClassName.Method(...)
            if (obj.kind == AK.Ident() && binder.FindType(obj.sval) != null && LocalIdx(obj.sval) < 0) {
                return EmitStaticCall(obj.sval, mname, e);
            }
            // evaluate receiver
            ExprVal recv = GenExpr(obj);
            // extension methods: static method with a `this` receiver of recv's type
            List<string> extOwner = new List<string>();
            Node extm = binder.FindExtension(recv.ty.sval, mname, extOwner);
            if (extm != null) { return EmitExtensionCall(recv, extOwner[0], extm, e); }
            // string methods
            if (IsStr(recv.ty)) { return EmitStrMethod(recv, mname, e); }
            // list methods
            if (IsListType(recv.ty)) { return EmitListMethod(recv, mname, e); }
            // dictionary methods
            if (IsDictType(recv.ty)) { return EmitDictMethod(recv, mname, e); }
            // string-builder methods
            if (IsSbType(recv.ty)) { return EmitSbMethod(recv, mname, e); }
            // instance method
            Node cls = ClassOf(recv.ty);
            if (cls != null) { return EmitInstanceCall(recv, cls.sval, mname, e); }
            return new ExprVal("0", MkType("int"));
        }
        // bare call
        if (callee.kind == AK.Ident()) {
            string name = callee.sval;
            // delegate invocation: a local of Func/Action type
            int dli = LocalIdx(name);
            if (dli >= 0 && IsDelegate(locType[dli])) {
                return EmitDelegateCall(callee, locType[dli], e);
            }
            if (curHasThis) {
                Node cls = binder.FindType(curClass);
                Node bm = FindMethodUp(cls, name);
                if (bm != null && !IsStatic(bm)) {
                    ExprVal recv = new ExprVal("%this", MkType(curClass));
                    return EmitInstanceCall(recv, curClass, name, e);
                }
            }
            return EmitStaticCall(curClass, name, e);
        }
        return new ExprVal("0", MkType("int"));
    }

    string ParamTypeStr(Node m, int idx) {
        int seen = 0; int i = 0;
        while (i < m.kids.Count) {
            if (m.kids[i].kind == AK.Param()) {
                if (seen == idx) { return MapType(m.kids[i].type); }
                seen = seen + 1;
            }
            i = i + 1;
        }
        return "i64";
    }

    Node ParamTypeNode(Node m, int idx) {
        int seen = 0; int i = 0;
        while (i < m.kids.Count) {
            if (m.kids[i].kind == AK.Param()) {
                if (seen == idx) { return m.kids[i].type; }
                seen = seen + 1;
            }
            i = i + 1;
        }
        return MkType("int");
    }

    // build a call argument for a (possibly erased) parameter type
    string CallArg(ExprVal av, Node pty) {
        if (IsErasedType(pty)) { return ToSlot(av, av.ty); }
        return Coerce(av, MapType(pty));
    }

    int IndexOfStr(List<string> xs, string s) {
        int i = 0;
        while (i < xs.Count) { if (xs[i] == s) { return i; } i = i + 1; }
        return -1;
    }

    // Reorder a call's arguments to positional order, applying named-argument
    // placement and filling omitted trailing parameters with their defaults.
    // When there are no named args and every parameter is supplied, the call's
    // own argument list is returned unchanged (keeps existing IR byte-identical).
    List<Node> OrderArgs(Node m, Node e) {
        if (m == null) { return e.kids; }
        List<string> pnames = new List<string>();
        List<Node> pdefault = new List<Node>();
        int i = 0;
        while (i < m.kids.Count) {
            if (m.kids[i].kind == AK.Param()) { pnames.Add(m.kids[i].sval); pdefault.Add(m.kids[i].b); }
            i = i + 1;
        }
        int np = pnames.Count;
        if (e.kids.Count > np) {
            diags.Error("too many arguments to '" + m.sval + "' (expected "
                + np + ", got " + e.kids.Count + ")", e.line, e.col);
        }
        bool anyNamed = false;
        int j = 0;
        while (j < e.kids.Count) { if (e.kids[j].sval2 != "") { anyNamed = true; } j = j + 1; }
        if (!anyNamed && e.kids.Count >= np) { return e.kids; }
        List<Node> slots = new List<Node>();
        int s = 0; while (s < np) { slots.Add(null); s = s + 1; }
        int pos = 0;
        j = 0;
        while (j < e.kids.Count) {
            Node arg = e.kids[j];
            if (arg.sval2 != "") {
                int idx = IndexOfStr(pnames, arg.sval2);
                if (idx >= 0 && idx < np) { slots[idx] = arg; }
            } else {
                if (pos < np) { slots[pos] = arg; }
                pos = pos + 1;
            }
            j = j + 1;
        }
        int k = 0;
        while (k < np) {
            if (slots[k] == null) {
                if (pdefault[k] != null) { slots[k] = pdefault[k]; }
                else {
                    diags.Error("missing required argument for parameter '"
                        + pnames[k] + "' of '" + m.sval + "'", e.line, e.col);
                    Node z = new Node(AK.IntLit()); z.ival = 0; slots[k] = z;
                }
            }
            k = k + 1;
        }
        return slots;
    }

    ExprVal EmitStaticCall(string clsName, string name, Node e) {
        Node cls = binder.FindType(clsName);
        Node m = ResolveMethod(cls, name, e, true);
        string sym = clsName + "_" + name;
        if (m != null) { sym = MethodSym(clsName, m); }
        string rt = "i64";
        if (m != null) { rt = MapType(m.type); }
        string args = "";
        List<Node> aargs = OrderArgs(m, e);
        int i = 0;
        while (i < aargs.Count) {
            ExprVal av = GenExpr(aargs[i]);
            Node pty = MkType("int"); if (m != null) { pty = ParamTypeNode(m, i); }
            if (i > 0) { args = args + ", "; }
            args = args + MapType(pty) + " " + CallArg(av, pty);
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void @" + sym + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + sym + "(" + args + ")");
        if (m != null && IsErasedType(m.type)) { return FromSlot(t, m.type); }
        Node retTy = MkType("int"); if (m != null) { retTy = m.type; }
        AddTemp(t, retTy);
        return new ExprVal(t, retTy);
    }

    // extension call: static method invoked as recv.M(args) -> M(recv, args).
    ExprVal EmitExtensionCall(ExprVal recv, string owner, Node m, Node e) {
        string rt = MapType(m.type);
        Node p0 = ParamTypeNode(m, 0);
        string args = MapType(p0) + " " + CallArg(recv, p0);
        int i = 0;
        while (i < e.kids.Count) {
            ExprVal av = GenExpr(e.kids[i]);
            Node pty = ParamTypeNode(m, i + 1);
            args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void @" + MethodSym(owner, m) + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + MethodSym(owner, m) + "(" + args + ")");
        if (IsErasedType(m.type)) { return FromSlot(t, m.type); }
        AddTemp(t, m.type);
        return new ExprVal(t, m.type);
    }

    ExprVal EmitInstanceCall(ExprVal recv, string clsName, string name, Node e) {
        Node cls = binder.FindType(clsName);
        Node m = ResolveMethodUp(cls, name, e, false);
        if (m != null && IsPolyClass(cls) && VSlotIndex(cls, name) >= 0) {
            return EmitVirtualCall(recv, cls, name, m, e);
        }
        string owner = MethodOwner(cls, name);
        if (owner == "") { owner = clsName; }
        string sym = owner + "_" + name;
        if (m != null) { sym = MethodSym(owner, m); }
        string thisOp = recv.op;
        if (owner != clsName) {
            string bc = NT();
            L("  " + bc + " = bitcast %" + clsName + "* " + recv.op + " to %" + owner + "*");
            thisOp = bc;
        }
        string rt = "i64";
        if (m != null) { rt = MapType(m.type); }
        string args = "%" + owner + "* " + thisOp;
        List<Node> aargs = OrderArgs(m, e);
        int i = 0;
        while (i < aargs.Count) {
            ExprVal av = GenExpr(aargs[i]);
            Node pty = MkType("int"); if (m != null) { pty = ParamTypeNode(m, i); }
            args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void @" + sym + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + sym + "(" + args + ")");
        if (m != null && IsErasedType(m.type)) { return FromSlot(t, ConcreteTP(m.type, recv.ty)); }
        Node retTy = MkType("int"); if (m != null) { retTy = m.type; }
        AddTemp(t, retTy);
        return new ExprVal(t, retTy);
    }

    ExprVal EmitVirtualCall(ExprVal recv, Node cls, string name, Node m, Node e) {
        string clsName = cls.sval;
        int slot = VSlotIndex(cls, name);
        string rt = MapType(m.type);
        string vtp = NT();
        L("  " + vtp + " = getelementptr %" + clsName + ", %" + clsName + "* " + recv.op + ", i32 0, i32 0");
        string vt = NT();
        L("  " + vt + " = load i8*, i8** " + vtp);
        string vta = NT();
        L("  " + vta + " = bitcast i8* " + vt + " to i8**");
        string slotp = NT();
        L("  " + slotp + " = getelementptr i8*, i8** " + vta + ", i64 " + slot);
        string fni8 = NT();
        L("  " + fni8 + " = load i8*, i8** " + slotp);
        string fn = NT();
        L("  " + fn + " = bitcast i8* " + fni8 + " to " + MethodFnTypeThis(m, clsName));
        string args = "%" + clsName + "* " + recv.op;
        List<Node> aargs = OrderArgs(m, e);
        int i = 0;
        while (i < aargs.Count) {
            ExprVal av = GenExpr(aargs[i]);
            Node pty = ParamTypeNode(m, i);
            args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void " + fn + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " " + fn + "(" + args + ")");
        if (IsErasedType(m.type)) { return FromSlot(t, ConcreteTP(m.type, recv.ty)); }
        AddTemp(t, m.type);
        return new ExprVal(t, m.type);
    }

    ExprVal EmitStrMethod(ExprVal recv, string name, Node e) {
        if (name == "Substring") {
            ExprVal start = GenExpr(e.kids[0]);
            string lenOp;
            if (e.kids.Count >= 2) { ExprVal l = GenExpr(e.kids[1]); lenOp = l.op; }
            else {
                string sl = NT(); L("  " + sl + " = call i64 @strlen(i8* " + recv.op + ")");
                string rem = NT(); L("  " + rem + " = sub i64 " + sl + ", " + start.op);
                lenOp = rem;
            }
            string bsz = NT(); L("  " + bsz + " = add i64 " + lenOp + ", 1");
            string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + bsz + ")");
            string srcp = NT(); L("  " + srcp + " = getelementptr i8, i8* " + recv.op + ", i64 " + start.op);
            L("  call i8* @memcpy(i8* " + buf + ", i8* " + srcp + ", i64 " + lenOp + ")");
            string endp = NT(); L("  " + endp + " = getelementptr i8, i8* " + buf + ", i64 " + lenOp);
            L("  store i8 0, i8* " + endp);
            return new ExprVal(buf, MkType("string"));
        }
        // unknown string method: return receiver
        return recv;
    }

    ExprVal EmitListMethod(ExprVal recv, string name, Node e) {
        if (name == "Add") {
            ExprVal v = GenExpr(e.kids[0]);
            string sv = ToSlot(v, ListElem(recv.ty));
            L("  call void @zlist_add(i8* " + recv.op + ", i64 " + sv + ")");
            return new ExprVal("0", MkType("void"));
        }
        if (name == "get_Count" || name == "Count") {
            string t = NT();
            L("  " + t + " = call i64 @zlist_count(i8* " + recv.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        return new ExprVal("0", MkType("int"));
    }

    ExprVal EmitDictMethod(ExprVal recv, string name, Node e) {
        if (name == "Add" || name == "set_Item") {
            ExprVal key = GenExpr(e.kids[0]);
            ExprVal val = GenExpr(e.kids[1]);
            string sv = ToSlot(val, DictVal(recv.ty));
            L("  call void @zdict_set(i8* " + recv.op + ", i8* " + key.op + ", i64 " + sv + ")");
            return new ExprVal("0", MkType("void"));
        }
        if (name == "ContainsKey") {
            ExprVal key = GenExpr(e.kids[0]);
            string t = NT();
            L("  " + t + " = call i64 @zdict_contains(i8* " + recv.op + ", i8* " + key.op + ")");
            return new ExprVal(t, MkType("bool"));
        }
        if (name == "get_Count" || name == "Count") {
            string t = NT();
            L("  " + t + " = call i64 @zdict_count(i8* " + recv.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        return new ExprVal("0", MkType("int"));
    }

    ExprVal EmitSbMethod(ExprVal recv, string name, Node e) {
        if (name == "Append") {
            ExprVal a = GenExpr(e.kids[0]);
            L("  call void @zsb_append(i8* " + recv.op + ", i8* " + a.op + ")");
            return recv;
        }
        if (name == "ToString") {
            string t = NT();
            L("  " + t + " = call i8* @zsb_tostring(i8* " + recv.op + ")");
            return new ExprVal(t, MkType("string"));
        }
        return recv;
    }
}
