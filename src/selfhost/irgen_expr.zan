using System;
using System.Collections;
namespace Zan;

// Irgen part: expression codegen -- assignment, member access, indexing,
// object construction, casts, lambdas/delegates and calls.
partial class Irgen {
    // ---- expressions ----
    ExprVal GenExpr(Node e) {
        if (e == null) { return new ExprVal("0", MkType("int")); }
        int k = e.kind;
        if (k == AK.IntLit()) { return new ExprVal("" + e.ival, MkType("int")); }
        if (k == AK.FloatLit()) { return new ExprVal(FloatConst(e.sval), MkType("double")); }
        if (k == AK.BoolLit()) { return new ExprVal("" + e.ival, MkType("bool")); }
        if (k == AK.CharLit()) { return new ExprVal("" + e.ival, MkType("char")); }
        if (k == AK.StringLit()) { return GenStr(e.sval); }
        if (k == AK.NullLit()) { return new ExprVal("null", MkType("object")); }
        if (k == AK.ThisExpr()) { return new ExprVal("%this", MkType(curClass)); }
        if (k == AK.Ident()) { return GenIdent(e); }
        if (k == AK.Unary()) { return GenUnary(e); }
        if (k == AK.PostfixUnary()) { return GenPostfix(e); }
        if (k == AK.Binary()) { return GenBinary(e); }
        if (k == AK.Assignment()) { return GenAssign(e); }
        if (k == AK.Call()) {
            if (e.a != null && e.a.kind == AK.MemberAccess() && e.a.ival == 1) {
                return GenNullCond(e, e.a);
            }
            return GenCall(e);
        }
        if (k == AK.Lambda()) { return GenLambda(e); }
        if (k == AK.SwitchExpr()) { return GenSwitchExpr(e); }
        if (k == AK.Conditional()) { return GenConditional(e); }
        if (k == AK.TupleExpr()) { return GenTuple(e); }
        if (k == AK.IsExpr()) { return GenIs(e); }
        if (k == AK.MemberAccess()) {
            if (e.ival == 1) { return GenNullCond(e, e); }
            return GenMember(e);
        }
        if (k == AK.QueryExpr()) { return GenQuery(e); }
        if (k == AK.Index()) { return GenIndex(e); }
        if (k == AK.NewExpr()) { return GenNew(e); }
        if (k == AK.CastExpr()) { return GenCast(e); }
        if (k == AK.AwaitExpr()) {
            diags.Error("async/await is parsed but not yet lowered by the self-host compiler", e.line, e.col);
            return GenExpr(e.a);
        }
        return new ExprVal("0", MkType("int"));
    }

    ExprVal GenIdent(Node e) {
        int li = LocalIdx(e.sval);
        if (li >= 0) {
            Node ty = locType[li];
            string reg = locReg[li];
            string lt = MapType(ty);
            string t = NT();
            L("  " + t + " = load " + lt + ", " + lt + "* " + reg);
            return new ExprVal(t, ty);
        }
        // implicit this.field
        if (curHasThis) {
            Node cls = binder.FindType(curClass);
            if (cls != null && FieldIndex(cls, e.sval) >= 0) {
                return LoadField("%this", MkType(curClass), e.sval);
            }
            if (cls != null && FindMethodUp(cls, "get_" + e.sval) != null) {
                ExprVal recv = new ExprVal("%this", MkType(curClass));
                return EmitInstanceCall(recv, curClass, "get_" + e.sval, new Node(AK.Call()));
            }
        }
        if (curClass != "") {
            Node scls = binder.FindType(curClass);
            if (scls != null && FindStaticField(scls, e.sval) != null) {
                return LoadStaticField(scls, e.sval);
            }
            // bare static method group used as a delegate value
            if (scls != null) {
                Node mg = FindMethodUp(scls, e.sval);
                if (mg != null && HasMod(mg, MOD.Static()) && !HasMod(mg, MOD.Extern())) {
                    return EmitMethodGroup(curClass, scls, mg);
                }
            }
        }
        return new ExprVal("0", MkType("int"));
    }

    ExprVal LoadField(string objOp, Node recvTy, string field) {
        string clsName = recvTy.sval;
        Node cls = binder.FindType(clsName);
        int idx = FieldIndex(cls, field);
        Node fty = FieldType(cls, field);
        string ft = MapType(fty);
        string p = NT();
        L("  " + p + " = getelementptr %" + clsName + ", %" + clsName + "* " + objOp + ", i32 0, i32 " + idx);
        string t = NT();
        L("  " + t + " = load " + ft + ", " + ft + "* " + p);
        // erased field: storage is i64; unpack to the concrete type when known
        if (IsErasedType(fty)) { return FromSlot(t, ConcreteTP(fty, recvTy)); }
        return new ExprVal(t, fty);
    }

    ExprVal GenUnary(Node e) {
        ExprVal v = GenExpr(e.a);
        if (e.op == TK.Bang()) {
            string c = NT();
            L("  " + c + " = icmp eq i64 " + v.op + ", 0");
            string z = NT();
            L("  " + z + " = zext i1 " + c + " to i64");
            return new ExprVal(z, MkType("bool"));
        }
        if (e.op == TK.Minus()) {
            if (IsDbl(v.ty)) {
                string t = NT();
                L("  " + t + " = fneg double " + v.op);
                return new ExprVal(t, MkType("double"));
            }
            string t = NT();
            L("  " + t + " = sub i64 0, " + v.op);
            return new ExprVal(t, MkType("int"));
        }
        return v;
    }

    ExprVal GenPostfix(Node e) {
        // x++ / x-- : return old value, update slot
        ExprVal cur = GenExpr(e.a);
        if (IsDbl(cur.ty)) {
            string t = NT();
            string opn = "fadd";
            if (e.op == TK.MinusMinus()) { opn = "fsub"; }
            L("  " + t + " = " + opn + " double " + cur.op + ", 1.0");
            StoreTo(e.a, new ExprVal(t, MkType("double")));
            return cur;
        }
        string t = NT();
        string opn = "add";
        if (e.op == TK.MinusMinus()) { opn = "sub"; }
        L("  " + t + " = " + opn + " i64 " + cur.op + ", 1");
        StoreTo(e.a, new ExprVal(t, MkType("int")));
        return cur;
    }

    string ArithOp(int op) {
        if (op == TK.Plus()) { return "add"; }
        if (op == TK.Minus()) { return "sub"; }
        if (op == TK.Star()) { return "mul"; }
        if (op == TK.Slash()) { return "sdiv"; }
        if (op == TK.Percent()) { return "srem"; }
        if (op == TK.Amp()) { return "and"; }
        if (op == TK.Caret()) { return "xor"; }
        if (op == TK.Pipe()) { return "or"; }
        if (op == TK.LessLess()) { return "shl"; }
        if (op == TK.GreaterGreater()) { return "ashr"; }
        return "";
    }
    string CmpOp(int op) {
        if (op == TK.EqEq()) { return "eq"; }
        if (op == TK.BangEq()) { return "ne"; }
        if (op == TK.Less()) { return "slt"; }
        if (op == TK.Greater()) { return "sgt"; }
        if (op == TK.LessEq()) { return "sle"; }
        if (op == TK.GreaterEq()) { return "sge"; }
        return "";
    }
    // Unsigned integer comparison predicates (for ulong operands).
    string UCmpOp(int op) {
        if (op == TK.EqEq()) { return "eq"; }
        if (op == TK.BangEq()) { return "ne"; }
        if (op == TK.Less()) { return "ult"; }
        if (op == TK.Greater()) { return "ugt"; }
        if (op == TK.LessEq()) { return "ule"; }
        if (op == TK.GreaterEq()) { return "uge"; }
        return "";
    }

    // A valid LLVM floating constant: ensure a decimal point / exponent so
    // integer-looking literals (e.g. the `3` from `3m`) are emitted as doubles.
    string FloatConst(string s) {
        if (s == "") { return "0.0"; }
        int i = 0;
        bool hasDot = false;
        while (i < s.Length) {
            int c = (int)s[i];
            if (c == 46 || c == 101 || c == 69) { hasDot = true; }
            i = i + 1;
        }
        if (hasDot) { return s; }
        return s + ".0";
    }

    bool IsStr(Node ty) { if (ty == null) { return false; } return ty.sval == "string"; }
    // ulong is the one integer type whose value can set the high bit of the i64
    // slot, so it selects unsigned division/remainder/shift/compare and %llu.
    bool IsUlong(Node ty) { if (ty == null) { return false; } return ty.sval == "ulong"; }
    // True for a value lowered to LLVM `double` (both double and float here).
    bool IsDbl(Node ty) { if (ty == null) { return false; } return ty.sval == "double" || ty.sval == "float"; }

    // Floating-point counterparts of ArithOp/CmpOp for `double` operands.
    string FArithOp(int op) {
        if (op == TK.Plus()) { return "fadd"; }
        if (op == TK.Minus()) { return "fsub"; }
        if (op == TK.Star()) { return "fmul"; }
        if (op == TK.Slash()) { return "fdiv"; }
        if (op == TK.Percent()) { return "frem"; }
        return "";
    }
    string FCmpOp(int op) {
        if (op == TK.EqEq()) { return "oeq"; }
        if (op == TK.BangEq()) { return "one"; }
        if (op == TK.Less()) { return "olt"; }
        if (op == TK.Greater()) { return "ogt"; }
        if (op == TK.LessEq()) { return "ole"; }
        if (op == TK.GreaterEq()) { return "oge"; }
        return "";
    }
    // Materialise `v` as an LLVM `double`, widening an integer operand via sitofp.
    string AsDouble(ExprVal v) {
        if (IsDbl(v.ty)) { return v.op; }
        string t = NT();
        L("  " + t + " = sitofp i64 " + v.op + " to double");
        return t;
    }

    bool IsFoldOp(int op) {
        return op == TK.Plus() || op == TK.Minus() || op == TK.Star() || op == TK.Slash() || op == TK.Percent();
    }

    // Is `e` a compile-time integer constant (literals and pure integer arithmetic
    // over them, with no division/modulo by zero)?
    bool IsConstInt(Node e) {
        if (e == null) { return false; }
        if (e.kind == AK.IntLit()) { return true; }
        if (e.kind == AK.Unary() && e.op == TK.Minus()) { return IsConstInt(e.a); }
        if (e.kind == AK.Binary() && IsFoldOp(e.op)) {
            if (!IsConstInt(e.a) || !IsConstInt(e.b)) { return false; }
            if (e.op == TK.Slash() || e.op == TK.Percent()) {
                if (EvalConstInt(e.b) == 0) { return false; }
            }
            return true;
        }
        return false;
    }

    long EvalConstInt(Node e) {
        if (e.kind == AK.IntLit()) { return e.ival; }
        if (e.kind == AK.Unary()) { return 0 - EvalConstInt(e.a); }
        long a = EvalConstInt(e.a);
        long b = EvalConstInt(e.b);
        int op = e.op;
        if (op == TK.Plus()) { return a + b; }
        if (op == TK.Minus()) { return a - b; }
        if (op == TK.Star()) { return a * b; }
        if (op == TK.Slash()) { return a / b; }
        if (op == TK.Percent()) { return a % b; }
        return 0;
    }

    ExprVal GenBinary(Node e) {
        int op = e.op;
        // constant folding: collapse pure integer-constant subtrees to a literal
        if (IsConstInt(e)) {
            return new ExprVal("" + EvalConstInt(e), MkType("int"));
        }
        if (op == TK.AmpAmp() || op == TK.PipePipe()) {
            List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;
            stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
            bool isAnd = (op == TK.AmpAmp());
            int lrhs = NL(); int lend = NL();
            string la = GenCond(e.a);
            string bpre = curLbl;
            if (isAnd) { L("  br i1 " + la + ", label %L" + lrhs + ", label %L" + lend); }
            else { L("  br i1 " + la + ", label %L" + lend + ", label %L" + lrhs); }
            Label(lrhs);
            string lb = GenCond(e.b);
            string bpost = curLbl;
            L("  br label %L" + lend);
            Label(lend);
            string r = NT();
            string dflt = "true"; if (isAnd) { dflt = "false"; }
            L("  " + r + " = phi i1 [ " + dflt + ", %" + bpre + " ], [ " + lb + ", %" + bpost + " ]");
            string z = NT();
            L("  " + z + " = zext i1 " + r + " to i64");
            stmtTemps = svT; stmtTempTypes = svTT;
            return new ExprVal(z, MkType("bool"));
        }
        // null-coalescing "a ?? b": if a is non-null use a, else b. Result is
        // normalised to a single owned (+1) temp so ARC release is balanced in
        // both branches (no leak, no double-free); no-op retains for non-ARC types.
        if (op == TK.QQ()) {
            ExprVal a = GenExpr(e.a);
            string at = MapType(a.ty);
            int lb = NL(); int la = NL(); int lend = NL();
            string isn = NT();
            L("  " + isn + " = icmp eq " + at + " " + a.op + ", null");
            L("  br i1 " + isn + ", label %L" + lb + ", label %L" + la);
            // a non-null: retain a so the merged result carries +1
            Label(la);
            EmitArcRetain(a.op, a.ty);
            string apost = curLbl;
            L("  br label %L" + lend);
            // a null: evaluate b in an isolated temp scope, retain the chosen
            // value, release bs own temporaries within the branch.
            Label(lb);
            List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;
            stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
            ExprVal b = GenExpr(e.b);
            EmitArcRetain(b.op, b.ty);
            string bop = b.op;
            if (MapType(b.ty) != at) {
                string bc = NT();
                L("  " + bc + " = bitcast " + MapType(b.ty) + " " + bop + " to " + at);
                bop = bc;
            }
            EmitTempReleases();
            stmtTemps = svT; stmtTempTypes = svTT;
            string bpost = curLbl;
            L("  br label %L" + lend);
            Label(lend);
            string r = NT();
            L("  " + r + " = phi " + at + " [ " + a.op + ", %" + apost + " ], [ " + bop + ", %" + bpost + " ]");
            Node rty = a.ty;
            if (rty == null || rty.sval == "object" || rty.sval == "var") { rty = b.ty; }
            AddTemp(r, rty);
            return new ExprVal(r, rty);
        }
        // pointer/null comparisons (peek operand kind before evaluating)
        if (op == TK.EqEq() || op == TK.BangEq()) {
            if (e.a.kind == AK.NullLit() || e.b.kind == AK.NullLit()) {
                Node other = e.a; if (e.a.kind == AK.NullLit()) { other = e.b; }
                ExprVal ov = GenExpr(other);
                string ot = MapType(ov.ty);
                string cc = "eq"; if (op == TK.BangEq()) { cc = "ne"; }
                string c = NT();
                L("  " + c + " = icmp " + cc + " " + ot + " " + ov.op + ", null");
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
        }
        // A chain of 3+ string `+` parts is emitted as one flattened
        // allocation instead of pairwise (see StrConcatN). Only chains whose
        // string-ness is provable (a string literal or string-typed local in
        // the subtree) are flattened; anything else keeps the pairwise
        // path that decides from the evaluated operand types.
        if (op == TK.Plus() && IsStrChain(e)) {
            List<Node> parts = new List<Node>();
            CollectConcat(e, parts);
            if (parts.Count > 2) { return StrConcatN(parts); }
        }
        ExprVal a = GenExpr(e.a);
        ExprVal b = GenExpr(e.b);
        // ulong operands select unsigned div/rem/shift/compare and carry the
        // unsigned type through so results print with %llu.
        bool uns = IsUlong(a.ty) || IsUlong(b.ty);
        // user-defined operator overloading takes precedence for class operands
        ExprVal ov = TryOpOverload(op, a, b);
        if (ov != null) { return ov; }
        // floating-point arithmetic/comparison (string `+` concatenation wins)
        if ((IsDbl(a.ty) || IsDbl(b.ty)) && !(IsStr(a.ty) || IsStr(b.ty))) {
            string da = AsDouble(a);
            string db = AsDouble(b);
            string fop = FArithOp(op);
            if (fop != "") {
                string t = NT();
                L("  " + t + " = " + fop + " double " + da + ", " + db);
                return new ExprVal(t, MkType("double"));
            }
            string fcp = FCmpOp(op);
            if (fcp != "") {
                string c = NT();
                L("  " + c + " = fcmp " + fcp + " double " + da + ", " + db);
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
        }
        // addition: concatenate when either operand is a string, else integer add
        if (op == TK.Plus()) {
            if (IsStr(a.ty) || IsStr(b.ty)) {
                return StrConcat(ToCStr(a), ToCStr(b));
            }
            string t = NT();
            L("  " + t + " = add i64 " + a.op + ", " + b.op);
            if (uns) { return new ExprVal(t, MkType("ulong")); }
            return new ExprVal(t, MkType("int"));
        }
        if (op == TK.EqEq() || op == TK.BangEq()) {
            if (IsStr(a.ty) && IsStr(b.ty)) {
                string r = NT();
                L("  " + r + " = call i32 @strcmp(i8* " + a.op + ", i8* " + b.op + ")");
                string cc = "eq"; if (op == TK.BangEq()) { cc = "ne"; }
                string c = NT();
                L("  " + c + " = icmp " + cc + " i32 " + r + ", 0");
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
            // reference identity: compare pointer operands as pointers, not i64
            string alt = MapType(a.ty); string blt = MapType(b.ty);
            if (IsPtrLL(alt) && IsPtrLL(blt)) {
                string pty = alt;
                string ao = a.op; string bo = b.op;
                if (blt != pty) {
                    string tb = NT();
                    L("  " + tb + " = bitcast " + blt + " " + bo + " to " + pty);
                    bo = tb;
                }
                string ccp = "eq"; if (op == TK.BangEq()) { ccp = "ne"; }
                string cp = NT();
                L("  " + cp + " = icmp " + ccp + " " + pty + " " + ao + ", " + bo);
                string zp = NT();
                L("  " + zp + " = zext i1 " + cp + " to i64");
                return new ExprVal(zp, MkType("bool"));
            }
            string cc2 = CmpOp(op);
            string c2 = NT();
            L("  " + c2 + " = icmp " + cc2 + " i64 " + a.op + ", " + b.op);
            string z2 = NT();
            L("  " + z2 + " = zext i1 " + c2 + " to i64");
            return new ExprVal(z2, MkType("bool"));
        }
        // string ordering: `<`/`<=`/`>`/`>=` compare content via strcmp, not
        // the raw i8* pointers.
        if (IsStr(a.ty) && IsStr(b.ty)) {
            string scp = CmpOp(op);
            if (scp != "") {
                string r = NT();
                L("  " + r + " = call i32 @strcmp(i8* " + a.op + ", i8* " + b.op + ")");
                string c = NT();
                L("  " + c + " = icmp " + scp + " i32 " + r + ", 0");
                string z = NT();
                L("  " + z + " = zext i1 " + c + " to i64");
                return new ExprVal(z, MkType("bool"));
            }
        }
        string ar = ArithOp(op);
        if (ar != "") {
            // peephole: identity simplifications (operands already evaluated)
            if ((op == TK.Plus() || op == TK.Minus()) && b.op == "0") { return a; }
            if (op == TK.Plus() && a.op == "0") { return b; }
            if ((op == TK.Star() || op == TK.Slash()) && b.op == "1") { return a; }
            if (op == TK.Star() && a.op == "1") { return b; }
            if (uns) {
                if (op == TK.Slash()) { ar = "udiv"; }
                else if (op == TK.Percent()) { ar = "urem"; }
                else if (op == TK.GreaterGreater()) { ar = "lshr"; }
            }
            string t = NT();
            L("  " + t + " = " + ar + " i64 " + a.op + ", " + b.op);
            if (uns) { return new ExprVal(t, MkType("ulong")); }
            return new ExprVal(t, MkType("int"));
        }
        string cp = CmpOp(op);
        if (uns) { cp = UCmpOp(op); }
        if (cp != "") {
            // lexicographic ordering for strings (matches ==/!= strcmp handling)
            if (IsStr(a.ty) && IsStr(b.ty)) {
                string r = NT();
                L("  " + r + " = call i32 @strcmp(i8* " + a.op + ", i8* " + b.op + ")");
                string cs = NT();
                L("  " + cs + " = icmp " + cp + " i32 " + r + ", 0");
                string zs = NT();
                L("  " + zs + " = zext i1 " + cs + " to i64");
                return new ExprVal(zs, MkType("bool"));
            }
            string c = NT();
            L("  " + c + " = icmp " + cp + " i64 " + a.op + ", " + b.op);
            string z = NT();
            L("  " + z + " = zext i1 " + c + " to i64");
            return new ExprVal(z, MkType("bool"));
        }
        return new ExprVal("0", MkType("int"));
    }

    // Map an operator token to the mangled method name (must match parser).
    string OpName(int op) {
        if (op == TK.Plus()) { return "op_add"; }
        if (op == TK.Minus()) { return "op_sub"; }
        if (op == TK.Star()) { return "op_mul"; }
        if (op == TK.Slash()) { return "op_div"; }
        if (op == TK.Percent()) { return "op_mod"; }
        if (op == TK.EqEq()) { return "op_eq"; }
        if (op == TK.BangEq()) { return "op_ne"; }
        if (op == TK.Less()) { return "op_lt"; }
        if (op == TK.Greater()) { return "op_gt"; }
        if (op == TK.LessEq()) { return "op_le"; }
        if (op == TK.GreaterEq()) { return "op_ge"; }
        return "";
    }

    // Dispatch a binary op to a static operator method on either operand's
    // class, e.g. a + b -> @Vec_op_add(Vec, Vec). Returns null when none.
    ExprVal TryOpOverload(int op, ExprVal a, ExprVal b) {
        string mn = OpName(op);
        if (mn == "") { return null; }
        string owner = "";
        Node m = null;
        Node ca = ClassOf(a.ty);
        if (ca != null) { m = binder.FindMethod(ca, mn); if (m != null) { owner = a.ty.sval; } }
        if (m == null) {
            Node cb = ClassOf(b.ty);
            if (cb != null) { m = binder.FindMethod(cb, mn); if (m != null) { owner = b.ty.sval; } }
        }
        if (m == null) { return null; }
        Node p0 = ParamTypeNode(m, 0);
        Node p1 = ParamTypeNode(m, 1);
        string args = MapType(p0) + " " + CallArg(a, p0) + ", " + MapType(p1) + " " + CallArg(b, p1);
        string rt = MapType(m.type);
        if (rt == "void") {
            L("  call void @" + owner + "_" + mn + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + owner + "_" + mn + "(" + args + ")");
        return new ExprVal(t, m.type);
    }

    bool ExprIsStr(Node e) {
        if (e == null) { return false; }
        if (e.kind == AK.StringLit()) { return true; }
        return false;
    }

    // coerce a value to i8* string form (numbers via snprintf)
    string ToCStr(ExprVal v) {
        if (IsStr(v.ty)) { return v.op; }
        // double -> string (via snprintf "%g")
        if (IsDbl(v.ty)) {
            string dneed = NT();
            L("  " + dneed + " = call i32 (i8*, i64, i8*, ...) @snprintf(i8* null, i64 0, i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.fmt.gn, i64 0, i64 0), double " + v.op + ")");
            string dneed64 = NT();
            L("  " + dneed64 + " = sext i32 " + dneed + " to i64");
            string dbsz = NT();
            L("  " + dbsz + " = add i64 " + dneed64 + ", 1");
            string dbuf = NT();
            L("  " + dbuf + " = call i8* @malloc(i64 " + dbsz + ")");
            L("  call i32 (i8*, i64, i8*, ...) @snprintf(i8* " + dbuf + ", i64 " + dbsz + ", i8* getelementptr inbounds ([3 x i8], [3 x i8]* @.fmt.gn, i64 0, i64 0), double " + v.op + ")");
            return dbuf;
        }
        // integer -> string ("%llu" for ulong so the high bit prints unsigned)
        string ifmt = "@.fmt.nn";
        if (IsUlong(v.ty)) { ifmt = "@.fmt.unn"; }
        string need = NT();
        L("  " + need + " = call i32 (i8*, i64, i8*, ...) @snprintf(i8* null, i64 0, i8* getelementptr inbounds ([5 x i8], [5 x i8]* " + ifmt + ", i64 0, i64 0), i64 " + v.op + ")");
        string need64 = NT();
        L("  " + need64 + " = sext i32 " + need + " to i64");
        string bsz = NT();
        L("  " + bsz + " = add i64 " + need64 + ", 1");
        string buf = NT();
        L("  " + buf + " = call i8* @malloc(i64 " + bsz + ")");
        L("  call i32 (i8*, i64, i8*, ...) @snprintf(i8* " + buf + ", i64 " + bsz + ", i8* getelementptr inbounds ([5 x i8], [5 x i8]* " + ifmt + ", i64 0, i64 0), i64 " + v.op + ")");
        return buf;
    }

    // True when `e` provably yields a string: a string literal, or a `+`
    // with a provably-string side.
    bool StrNodeish(Node e) {
        if (e == null) { return false; }
        if (e.kind == AK.StringLit()) { return true; }
        if (e.kind == AK.Ident()) {
            int li = LocalIdx(e.sval);
            if (li >= 0) { return IsStr(locType[li]); }
            return false;
        }
        if (e.kind == AK.Binary() && e.op == TK.Plus()) {
            return StrNodeish(e.a) || StrNodeish(e.b);
        }
        return false;
    }

    // A concatenation-chain link: `+` whose either side is provably string.
    bool IsStrChain(Node e) {
        if (e == null) { return false; }
        if (e.kind != AK.Binary() || e.op != TK.Plus()) { return false; }
        return StrNodeish(e.a) || StrNodeish(e.b);
    }

    // Collect the leaves of a `+` concatenation chain in evaluation order.
    // A sub-tree that is not itself a provable string chain stays one leaf
    // (it is evaluated with its own semantics, e.g. numeric addition).
    void CollectConcat(Node e, List<Node> outParts) {
        if (outParts.Count < 40 && IsStrChain(e)) {
            CollectConcat(e.a, outParts);
            CollectConcat(e.b, outParts);
        } else {
            outParts.Add(e);
        }
    }

    // n-way concatenation with a single allocation: sum the part lengths,
    // malloc once, memcpy each part in order and NUL-terminate. Replaces the
    // O(n^2) copying of emitting a chain pairwise.
    ExprVal StrConcatN(List<Node> parts) {
        List<string> vals = new List<string>();
        List<string> lens = new List<string>();
        string tot = "1";
        int i = 0;
        while (i < parts.Count) {
            ExprVal v = GenExpr(parts[i]);
            string s = ToCStr(v);
            vals.Add(s);
            string ln = NT(); L("  " + ln + " = call i64 @strlen(i8* " + s + ")");
            lens.Add(ln);
            string nt = NT(); L("  " + nt + " = add i64 " + tot + ", " + ln);
            tot = nt;
            i = i + 1;
        }
        string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + tot + ")");
        string off = "0";
        i = 0;
        while (i < parts.Count) {
            string dst = NT(); L("  " + dst + " = getelementptr i8, i8* " + buf + ", i64 " + off);
            L("  call i8* @memcpy(i8* " + dst + ", i8* " + vals[i] + ", i64 " + lens[i] + ")");
            string no = NT(); L("  " + no + " = add i64 " + off + ", " + lens[i]);
            off = no;
            i = i + 1;
        }
        string endp = NT(); L("  " + endp + " = getelementptr i8, i8* " + buf + ", i64 " + off);
        L("  store i8 0, i8* " + endp);
        return new ExprVal(buf, MkType("string"));
    }

    ExprVal StrConcat(string a, string b) {
        string la = NT(); L("  " + la + " = call i64 @strlen(i8* " + a + ")");
        string lb = NT(); L("  " + lb + " = call i64 @strlen(i8* " + b + ")");
        string tot = NT(); L("  " + tot + " = add i64 " + la + ", " + lb);
        string tot1 = NT(); L("  " + tot1 + " = add i64 " + tot + ", 1");
        string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + tot1 + ")");
        L("  call i8* @strcpy(i8* " + buf + ", i8* " + a + ")");
        L("  call i8* @strcat(i8* " + buf + ", i8* " + b + ")");
        return new ExprVal(buf, MkType("string"));
    }

    // ---- assignment ----
    ExprVal GenAssign(Node e) {
        ExprVal rhs;
        if (e.op == TK.Eq()) {
            rhs = GenExpr(e.b);
            StoreTo(e.a, rhs);
            return rhs;
        }
        // "a ??= b" lowers to "a = (a ?? b)" reusing the ARC-safe ?? codegen.
        if (e.op == TK.QQEq()) {
            Node q = new Node(AK.Binary());
            q.op = TK.QQ(); q.a = e.a; q.b = e.b;
            q.line = e.line; q.col = e.col;
            ExprVal qv = GenBinary(q);
            StoreTo(e.a, qv);
            return qv;
        }
        // compound: load current, apply, store
        ExprVal cur = GenExpr(e.a);
        ExprVal r = GenExpr(e.b);
        // user-defined operator: a += b -> a = T.op_add(a, b)
        if (ClassOf(cur.ty) != null) {
            int bop = 0;
            if (e.op == TK.PlusEq()) { bop = TK.Plus(); }
            if (e.op == TK.MinusEq()) { bop = TK.Minus(); }
            if (e.op == TK.StarEq()) { bop = TK.Star(); }
            if (e.op == TK.SlashEq()) { bop = TK.Slash(); }
            if (bop != 0) {
                ExprVal ov = TryOpOverload(bop, cur, r);
                if (ov != null) {
                    StoreTo(e.a, ov);
                    return ov;
                }
            }
        }
        if (IsStr(cur.ty) && e.op == TK.PlusEq()) {
            ExprVal cc = StrConcat(ToCStr(cur), ToCStr(r));
            StoreTo(e.a, cc);
            return cc;
        }
        if (IsDbl(cur.ty) || IsDbl(r.ty)) {
            string da = AsDouble(cur);
            string db = AsDouble(r);
            string fopn = "fadd";
            if (e.op == TK.MinusEq()) { fopn = "fsub"; }
            if (e.op == TK.StarEq()) { fopn = "fmul"; }
            if (e.op == TK.SlashEq()) { fopn = "fdiv"; }
            string ft = NT();
            L("  " + ft + " = " + fopn + " double " + da + ", " + db);
            ExprVal fnv = new ExprVal(ft, MkType("double"));
            StoreTo(e.a, fnv);
            return fnv;
        }
        string opn = "add";
        if (e.op == TK.MinusEq()) { opn = "sub"; }
        if (e.op == TK.StarEq()) { opn = "mul"; }
        if (e.op == TK.SlashEq()) { opn = "sdiv"; }
        if (e.op == TK.PercentEq()) { opn = "srem"; }
        if (e.op == TK.AmpEq()) { opn = "and"; }
        if (e.op == TK.PipeEq()) { opn = "or"; }
        if (e.op == TK.CaretEq()) { opn = "xor"; }
        if (e.op == TK.LessLessEq()) { opn = "shl"; }
        if (e.op == TK.GreaterGreaterEq()) { opn = "ashr"; }
        string t = NT();
        L("  " + t + " = " + opn + " i64 " + cur.op + ", " + r.op);
        ExprVal nv = new ExprVal(t, MkType("int"));
        StoreTo(e.a, nv);
        return nv;
    }

    void StoreTo(Node lhs, ExprVal v) {
        if (lhs.kind == AK.Ident()) {
            int li = LocalIdx(lhs.sval);
            if (li >= 0) {
                Node lty = locType[li];
                if (IsNullableValue(lty)) {
                    L("  store i8* " + BoxFor(v, lty) + ", i8** " + locReg[li]);
                    return;
                }
                string lt = MapType(lty);
                if (ArcManaged(lty)) {
                    string old = NT();
                    L("  " + old + " = load " + lt + ", " + lt + "* " + locReg[li]);
                    string sv = Coerce(v, lt);
                    L("  store " + lt + " " + sv + ", " + lt + "* " + locReg[li]);
                    EmitArcRetain(sv, lty);
                    EmitArcRelease(old, lty);
                } else {
                    L("  store " + lt + " " + Coerce(v, lt) + ", " + lt + "* " + locReg[li]);
                }
                return;
            }
            if (curHasThis) {
                Node cls = binder.FindType(curClass);
                if (cls != null && FieldIndex(cls, lhs.sval) >= 0) {
                    StoreField("%this", curClass, lhs.sval, v);
                    return;
                }
                if (cls != null && EmitPropSet("%this", MkType(curClass), lhs.sval, v)) { return; }
            }
            if (curClass != "") {
                Node scls = binder.FindType(curClass);
                if (scls != null && FindStaticField(scls, lhs.sval) != null) {
                    StoreStaticField(scls, lhs.sval, v);
                    return;
                }
            }
            return;
        }
        if (lhs.kind == AK.MemberAccess()) {
            if (lhs.a.kind == AK.Ident() && LocalIdx(lhs.a.sval) < 0) {
                Node tc = binder.FindType(lhs.a.sval);
                if (tc != null && FindStaticField(tc, lhs.sval) != null) {
                    StoreStaticField(tc, lhs.sval, v);
                    return;
                }
            }
            ExprVal obj = GenExpr(lhs.a);
            string cn = obj.ty.sval;
            Node ocls = binder.FindType(cn);
            if (ocls != null && FieldIndex(ocls, lhs.sval) < 0
                && EmitPropSet(obj.op, obj.ty, lhs.sval, v)) { return; }
            StoreField(obj.op, cn, lhs.sval, v);
            return;
        }
        if (lhs.kind == AK.Index()) {
            ExprVal obj = GenExpr(lhs.a);
            ExprVal idx = GenExpr(lhs.b);
            if (IsListType(obj.ty)) {
                string sv = ToSlot(v, ListElem(obj.ty));
                L("  call void @zlist_set(i8* " + obj.op + ", i64 " + idx.op + ", i64 " + sv + ")");
                return;
            }
            if (IsDictType(obj.ty)) {
                string sv = ToSlot(v, DictVal(obj.ty));
                L("  call void @zdict_set(i8* " + obj.op + ", i8* " + DictKeyOp(idx) + ", i64 " + sv + ")");
                return;
            }
            if (IsStr(obj.ty)) {
                string sp = NT();
                L("  " + sp + " = getelementptr i8, i8* " + obj.op + ", i64 " + idx.op);
                string sb = NT();
                L("  " + sb + " = trunc i64 " + v.op + " to i8");
                L("  store i8 " + sb + ", i8* " + sp);
                return;
            }
            // array of i64 slots; pointer/double values are packed into the slot
            string p = NT();
            L("  " + p + " = getelementptr i64, i64* " + obj.op + ", i64 " + idx.op);
            if (ArcManaged(v.ty)) { EmitArcRetain(v.op, v.ty); }
            L("  store i64 " + ToI64(v.op, MapType(v.ty)) + ", i64* " + p);
            return;
        }
    }

    // obj.Name = v  ->  Owner_set_Name(obj, v). Returns false if no setter.
    bool EmitPropSet(string objOp, Node recvTy, string name, ExprVal v) {
        string clsName = recvTy.sval;
        Node cls = binder.FindType(clsName);
        Node m = FindMethodUp(cls, "set_" + name);
        if (m == null) { return false; }
        string owner = MethodOwner(cls, "set_" + name);
        if (owner == "") { owner = clsName; }
        string thisOp = objOp;
        if (owner != clsName) {
            string bc = NT();
            L("  " + bc + " = bitcast %" + clsName + "* " + objOp + " to %" + owner + "*");
            thisOp = bc;
        }
        Node pty = ParamTypeNode(m, 0);
        L("  call void @" + MethodSym(owner, m) + "(%" + owner + "* " + thisOp
            + ", " + MapType(pty) + " " + CallArg(v, pty) + ")");
        return true;
    }

    void StoreField(string objOp, string clsName, string field, ExprVal v) {
        Node cls = binder.FindType(clsName);
        int idx = FieldIndex(cls, field);
        Node fty = FieldType(cls, field);
        string p = NT();
        L("  " + p + " = getelementptr %" + clsName + ", %" + clsName + "* " + objOp + ", i32 0, i32 " + idx);
        // erased field: pack the value into an i64 slot
        if (IsErasedType(fty)) {
            string sv = ToSlot(v, v.ty);
            L("  store i64 " + sv + ", i64* " + p);
            return;
        }
        string ft = MapType(fty);
        if (ArcManaged(fty) && !WeakTy(fty)) {
            string old = NT();
            L("  " + old + " = load " + ft + ", " + ft + "* " + p);
            string sv = Coerce(v, ft);
            L("  store " + ft + " " + sv + ", " + ft + "* " + p);
            EmitArcRetain(sv, fty);
            EmitArcRelease(old, fty);
        } else {
            L("  store " + ft + " " + Coerce(v, ft) + ", " + ft + "* " + p);
        }
    }

    // convert a value to an i64 list slot (pointers via ptrtoint)
    string ToSlot(ExprVal v, Node elemTy) {
        string lt = MapType(elemTy);
        if (lt == "i64") { return v.op; }
        if (lt == "double") {
            string tb = NT();
            L("  " + tb + " = bitcast double " + v.op + " to i64");
            return tb;
        }
        if (v.op == "null" || v.op == "0") { return "0"; }
        string t = NT();
        L("  " + t + " = ptrtoint " + lt + " " + v.op + " to i64");
        return t;
    }

    ExprVal FromSlot(string slot, Node elemTy) {
        string lt = MapType(elemTy);
        if (lt == "i64") { return new ExprVal(slot, elemTy); }
        string t = NT();
        if (lt == "double") {
            L("  " + t + " = bitcast i64 " + slot + " to double");
            return new ExprVal(t, elemTy);
        }
        L("  " + t + " = inttoptr i64 " + slot + " to " + lt);
        return new ExprVal(t, elemTy);
    }

    bool IsTuple(Node t) {
        if (t == null) { return false; }
        return t.sval == "Tuple";
    }

    bool IsItemName(string s) {
        if (s.Length < 5) { return false; }
        return s[0] == 'I' && s[1] == 't' && s[2] == 'e' && s[3] == 'm';
    }

    int ItemIndex(string s) {
        int n = 0; int i = 4;
        while (i < s.Length) { n = n * 10 + (s[i] - '0'); i = i + 1; }
        return n - 1;
    }

    // is class `sub` equal to or derived from `baseName`?
    bool IsSubclassName(string sub, string baseName) {
        Node c = binder.FindType(sub);
        while (c != null) {
            if (c.sval == baseName) { return true; }
            c = BaseClassOf(c);
        }
        return false;
    }

    // type test:  obj is T [name].  Closed-world RTTI: compare the object's
    // vtable pointer against the vtable of T and of every concrete polymorphic
    // subclass of T. Optional `name` binds obj cast to T*.
    ExprVal GenIs(Node e) {
        ExprVal obj = GenExpr(e.a);
        string tname = e.type.sval;
        string sty = obj.ty.sval;
        Node scls = binder.FindType(sty);
        if (e.sval != "") {
            string reg = AddLocal(e.sval, e.type);
            EA(reg, "%" + tname + "*");
            string bc = NT();
            L("  " + bc + " = bitcast " + MapType(obj.ty) + " " + obj.op + " to %" + tname + "*");
            L("  store %" + tname + "* " + bc + ", %" + tname + "** " + reg);
        }
        if (scls == null || !IsPolyClass(scls)) {
            int ok = 0;
            if (IsSubclassName(sty, tname)) { ok = 1; }
            return new ExprVal("" + ok, MkType("bool"));
        }
        string vtp = NT();
        L("  " + vtp + " = getelementptr %" + sty + ", %" + sty + "* " + obj.op + ", i32 0, i32 0");
        string vt = NT();
        L("  " + vt + " = load i8*, i8** " + vtp);
        List<Node> ts = binder.types;
        string acc = "";
        int i = 0;
        while (i < ts.Count) {
            Node c = ts[i];
            bool isCls = (c.kind == AK.ClassDecl() || c.kind == AK.StructDecl());
            if (isCls && IsPolyClass(c) && !HasMod(c, MOD.Abstract()) && IsSubclassName(c.sval, tname)) {
                List<string> vslots = new List<string>();
                CollectVSlots(c, vslots);
                string cmp = NT();
                L("  " + cmp + " = icmp eq i8* " + vt + ", bitcast ([" + vslots.Count + " x i8*]* @" + c.sval + "_vtable to i8*)");
                if (acc == "") { acc = cmp; }
                else {
                    string o = NT();
                    L("  " + o + " = or i1 " + acc + ", " + cmp);
                    acc = o;
                }
            }
            i = i + 1;
        }
        if (acc == "") { return new ExprVal("0", MkType("bool")); }
        string z = NT();
        L("  " + z + " = zext i1 " + acc + " to i64");
        return new ExprVal(z, MkType("bool"));
    }

    // tuple literal (a, b, ...) -> heap i64[N], each element packed into a slot.
    ExprVal GenTuple(Node e) {
        int n = e.kids.Count;
        Node tty = new Node(AK.TypeRef()); tty.sval = "Tuple";
        string buf = NT();
        L("  " + buf + " = call i8* @malloc(i64 " + (n * 8) + ")");
        string p = NT();
        L("  " + p + " = bitcast i8* " + buf + " to i64*");
        int i = 0;
        while (i < n) {
            ExprVal ev = GenExpr(e.kids[i]);
            tty.Add(ev.ty);
            string slot = NT();
            L("  " + slot + " = getelementptr i64, i64* " + p + ", i64 " + i);
            L("  store i64 " + ToSlot(ev, ev.ty) + ", i64* " + slot);
            i = i + 1;
        }
        return new ExprVal(buf, tty);
    }

    // deconstruction: var (a, b, ...) = tupleExpr;  unpacks each slot into a local.
    void GenDecon(Node s) {
        ExprVal rhs = GenExpr(s.b);
        List<Node> ekids = rhs.ty.kids;
        string p = NT();
        L("  " + p + " = bitcast i8* " + rhs.op + " to i64*");
        int i = 0;
        while (i < s.kids.Count) {
            Node tgt = s.kids[i];
            Node ety = tgt.type;
            if (ety == null) {
                if (i < ekids.Count) { ety = ekids[i]; } else { ety = MkType("int"); }
            }
            string slot = NT();
            L("  " + slot + " = getelementptr i64, i64* " + p + ", i64 " + i);
            string raw = NT();
            L("  " + raw + " = load i64, i64* " + slot);
            ExprVal ev = FromSlot(raw, ety);
            string lt = MapType(ety);
            string reg = AddLocal(tgt.sval, ety);
            EA(reg, lt);
            L("  store " + lt + " " + Coerce(ev, lt) + ", " + lt + "* " + reg);
            i = i + 1;
        }
    }

    // ---- member access (field / .Length / .Count) ----
    // Null-conditional `a?.b` / `a?.M(...)`: evaluate the receiver once, bind
    // it to a synthetic local, and only evaluate the member/call when it is
    // non-null; a null receiver yields the result type's zero value. The
    // member node is temporarily rewired to read the synthetic local so the
    // ordinary member/call codegen applies unchanged, then restored.
    ExprVal GenNullCond(Node full, Node qmem) {
        ExprVal obj = GenExpr(qmem.a);
        string ot = MapType(obj.ty);
        if (!IsPtrLL(ot)) {
            qmem.ival = 0;
            ExprVal pv = GenExpr(full);
            qmem.ival = 1;
            return pv;
        }
        qdotSeq = qdotSeq + 1;
        string nm = "__qdot" + qdotSeq;
        string reg = AddLocal(nm, obj.ty);
        EA(reg, ot);
        L("  store " + ot + " " + obj.op + ", " + ot + "* " + reg);
        Node ident = new Node(AK.Ident());
        ident.sval = nm; ident.line = qmem.line; ident.col = qmem.col;
        Node saved = qmem.a;
        qmem.a = ident; qmem.ival = 0;
        int lthen = NL(); int lend = NL();
        string isn = NT();
        L("  " + isn + " = icmp eq " + ot + " " + obj.op + ", null");
        string bpre = curLbl;
        L("  br i1 " + isn + ", label %L" + lend + ", label %L" + lthen);
        Label(lthen);
        List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;
        stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
        ExprVal v = GenExpr(full);
        EmitArcRetain(v.op, v.ty);
        EmitTempReleases();
        stmtTemps = svT; stmtTempTypes = svTT;
        qmem.a = saved; qmem.ival = 1;
        string bthen = curLbl;
        L("  br label %L" + lend);
        Label(lend);
        string vt = MapType(v.ty);
        if (vt == "void") { return new ExprVal("0", MkType("int")); }
        string dflt = "0";
        if (IsPtrLL(vt)) { dflt = "null"; }
        if (vt == "double") { dflt = "0.0"; }
        string r = NT();
        L("  " + r + " = phi " + vt + " [ " + dflt + ", %" + bpre + " ], [ " + v.op + ", %" + bthen + " ]");
        AddTemp(r, v.ty);
        return new ExprVal(r, v.ty);
    }

    ExprVal GenMember(Node e) {
        if (e.a.kind == AK.Ident() && LocalIdx(e.a.sval) < 0) {
            Node tc = binder.FindType(e.a.sval);
            if (tc != null && FindStaticField(tc, e.sval) != null) {
                return LoadStaticField(tc, e.sval);
            }
            // enum member constant: Color.Red -> its ordinal (or explicit value)
            if (tc != null && tc.kind == AK.EnumDecl()) {
                int cur = 0;
                int j = 0;
                while (j < tc.kids.Count) {
                    Node mem = tc.kids[j];
                    if (mem.kind == AK.EnumMember()) {
                        if (mem.a != null && mem.a.kind == AK.IntLit()) { cur = mem.a.ival; }
                        if (mem.sval == e.sval) { return new ExprVal("" + cur, MkType("int")); }
                        cur = cur + 1;
                    }
                    j = j + 1;
                }
            }
            // static method group used as a delegate value: Prog.AddOne
            if (tc != null) {
                Node mg = FindMethodUp(tc, e.sval);
                if (mg != null && HasMod(mg, MOD.Static()) && !HasMod(mg, MOD.Extern())) {
                    return EmitMethodGroup(e.a.sval, tc, mg);
                }
            }
        }
        ExprVal obj = GenExpr(e.a);
        if (IsNullableValue(obj.ty) && e.sval == "HasValue") {
            string t = NT();
            L("  " + t + " = icmp ne i8* " + obj.op + ", null");
            string z = NT();
            L("  " + z + " = zext i1 " + t + " to i64");
            return new ExprVal(z, MkType("bool"));
        }
        if (IsNullableValue(obj.ty) && e.sval == "Value") {
            string ult = UnderLL(obj.ty);
            string p = NT();
            L("  " + p + " = bitcast i8* " + obj.op + " to " + ult + "*");
            string t = NT();
            L("  " + t + " = load " + ult + ", " + ult + "* " + p);
            Node uty = MkType(obj.ty.sval);
            return new ExprVal(t, uty);
        }
        if (IsTuple(obj.ty) && IsItemName(e.sval)) {
            int idx = ItemIndex(e.sval);
            List<Node> ekids = obj.ty.kids;
            Node ety = MkType("int");
            if (idx < ekids.Count) { ety = ekids[idx]; }
            string p = NT();
            L("  " + p + " = bitcast i8* " + obj.op + " to i64*");
            string slot = NT();
            L("  " + slot + " = getelementptr i64, i64* " + p + ", i64 " + idx);
            string raw = NT();
            L("  " + raw + " = load i64, i64* " + slot);
            return FromSlot(raw, ety);
        }
        if ((e.sval == "Length" || e.sval == "Count") && obj.ty != null && obj.ty.ival == 1) {
            string lp = NT();
            L("  " + lp + " = getelementptr i64, i64* " + obj.op + ", i64 -1");
            string t = NT();
            L("  " + t + " = load i64, i64* " + lp);
            return new ExprVal(t, MkType("int"));
        }
        if (e.sval == "Length" && IsSbType(obj.ty)) {
            string bp = NT();
            L("  " + bp + " = bitcast i8* " + obj.op + " to %zsb*");
            string cp = NT();
            L("  " + cp + " = getelementptr %zsb, %zsb* " + bp + ", i32 0, i32 0");
            string t = NT();
            L("  " + t + " = load i64, i64* " + cp);
            return new ExprVal(t, MkType("int"));
        }
        if (e.sval == "Length" && IsStr(obj.ty)) {
            string t = NT();
            L("  " + t + " = call i64 @strlen(i8* " + obj.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        if (e.sval == "Count" && IsListType(obj.ty)) {
            string t = NT();
            L("  " + t + " = call i64 @zlist_count(i8* " + obj.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        if (e.sval == "Count" && IsDictType(obj.ty)) {
            string t = NT();
            L("  " + t + " = call i64 @zdict_count(i8* " + obj.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        if ((e.sval == "Keys" || e.sval == "Values") && IsDictType(obj.ty)) {
            string t = NT();
            if (e.sval == "Keys") { L("  " + t + " = call i8* @zdict_keys(i8* " + obj.op + ")"); }
            else { L("  " + t + " = call i8* @zdict_values(i8* " + obj.op + ")"); }
            Node lt = MkType("List");
            Node et = MkType("string");
            if (obj.ty.kids.Count >= 2) {
                if (e.sval == "Keys") { et = obj.ty.kids[0]; } else { et = obj.ty.kids[1]; }
            }
            lt.kids.Add(et);
            AddTemp(t, lt);
            return new ExprVal(t, lt);
        }
        Node cls = ClassOf(obj.ty);
        if (cls != null && FieldIndex(cls, e.sval) >= 0) {
            return LoadField(obj.op, obj.ty, e.sval);
        }
        // property getter: obj.Name -> obj.get_Name()
        if (cls != null && FindMethodUp(cls, "get_" + e.sval) != null) {
            return EmitInstanceCall(obj, obj.ty.sval, "get_" + e.sval, new Node(AK.Call()));
        }
        return new ExprVal("0", MkType("int"));
    }

    // ---- indexing (string char / list element / array) ----
    ExprVal GenIndex(Node e) {
        ExprVal obj = GenExpr(e.a);
        ExprVal idx = GenExpr(e.b);
        if (IsStr(obj.ty)) {
            string p = NT();
            L("  " + p + " = getelementptr i8, i8* " + obj.op + ", i64 " + idx.op);
            string ch = NT();
            L("  " + ch + " = load i8, i8* " + p);
            string z = NT();
            L("  " + z + " = zext i8 " + ch + " to i64");
            return new ExprVal(z, MkType("char"));
        }
        if (IsListType(obj.ty)) {
            string slot = NT();
            L("  " + slot + " = call i64 @zlist_get(i8* " + obj.op + ", i64 " + idx.op + ")");
            return FromSlot(slot, ListElem(obj.ty));
        }
        if (IsDictType(obj.ty)) {
            string slot = NT();
            L("  " + slot + " = call i64 @zdict_get(i8* " + obj.op + ", i8* " + DictKeyOp(idx) + ")");
            return FromSlot(slot, DictVal(obj.ty));
        }
        string p2 = NT();
        L("  " + p2 + " = getelementptr i64, i64* " + obj.op + ", i64 " + idx.op);
        string v = NT();
        L("  " + v + " = load i64, i64* " + p2);
        // T[] element: unpack the i64 slot to the declared element type
        if (obj.ty != null && obj.ty.ival == 1) { return FromSlot(v, MkType(obj.ty.sval)); }
        return new ExprVal(v, MkType("int"));
    }

    // ---- new ----
    ExprVal GenNew(Node e) {
        Node ty = e.type;
        if (e.ival == 1) {
            // array new: T[n] as i64* (n zeroed slots after an i64 length header)
            ExprVal nsz = new ExprVal("0", MkType("int"));
            if (e.b != null) { nsz = GenExpr(e.b); }
            string bytes = NT();
            L("  " + bytes + " = mul i64 " + nsz.op + ", 8");
            string tot = NT();
            L("  " + tot + " = add i64 " + bytes + ", 8");
            string raw = NT();
            L("  " + raw + " = call i8* @calloc(i64 1, i64 " + tot + ")");
            string hdr = NT();
            L("  " + hdr + " = bitcast i8* " + raw + " to i64*");
            L("  store i64 " + nsz.op + ", i64* " + hdr);
            string arr = NT();
            L("  " + arr + " = getelementptr i64, i64* " + hdr + ", i64 1");
            Node at = MkType(ty.sval); at.ival = 1;
            return new ExprVal(arr, at);
        }
        if (IsListType(ty)) {
            string t = NT();
            string ow = "0"; if (ArcManaged(ListElem(ty))) { ow = "1"; }
            L("  " + t + " = call i8* @zlist_new(i64 " + ow + ")");
            if (e.ival == 2) {
                // collection initializer: append each item
                int j = 0;
                while (j < e.kids.Count) {
                    ExprVal iv = GenExpr(e.kids[j]);
                    string sv = ToSlot(iv, ListElem(ty));
                    L("  call void @zlist_add(i8* " + t + ", i64 " + sv + ")");
                    j = j + 1;
                }
            }
            AddTemp(t, ty);
            return new ExprVal(t, ty);
        }
        if (IsDictType(ty)) {
            string t = NT();
            string ow = "0"; if (ArcManaged(DictVal(ty))) { ow = "1"; }
            L("  " + t + " = call i8* @zdict_new(i64 " + ow + ")");
            AddTemp(t, ty);
            return new ExprVal(t, ty);
        }
        if (IsSbType(ty)) {
            string t = NT();
            L("  " + t + " = call i8* @zsb_new()");
            AddTemp(t, ty);
            return new ExprVal(t, ty);
        }
        // object
        string cn = ty.sval;
        Node cls = binder.FindType(cn);
        if (cls == null) { return new ExprVal("null", ty); }
        string szp = NT();
        L("  " + szp + " = getelementptr %" + cn + ", %" + cn + "* null, i32 1");
        string szi = NT();
        L("  " + szi + " = ptrtoint %" + cn + "* " + szp + " to i64");
        string raw = NT();
        L("  " + raw + " = call i8* @zalloc(i64 " + szi + ", i8* bitcast (void (i8*)* @" + cn + "_dtor to i8*))");
        string obj = NT();
        L("  " + obj + " = bitcast i8* " + raw + " to %" + cn + "*");
        if (IsPolyClass(cls)) {
            List<string> vslots = new List<string>();
            CollectVSlots(cls, vslots);
            string vtp0 = NT();
            L("  " + vtp0 + " = getelementptr %" + cn + ", %" + cn + "* " + obj + ", i32 0, i32 0");
            L("  store i8* bitcast ([" + vslots.Count + " x i8*]* @" + cn + "_vtable to i8*), i8** " + vtp0);
        }
        // call ctor if present. With an object initializer (ival == 2) the kids
        // are `Field = value` pairs, not ctor args, so only a parameterless ctor
        // is invoked and the field stores follow.
        Node ctor = binder.FindCtor(cls);
        if (ctor != null && e.ival != 2) {
            string args = "%" + cn + "* " + obj;
            int i = 0;
            while (i < e.kids.Count) {
                Node pty = CtorParamType(ctor, i);
                ExprVal av = GenArgExpr(e.kids[i], pty);
                args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
                i = i + 1;
            }
            L("  call void @" + cn + "_ctor(" + args + ")");
        } else if (ctor != null && e.ival == 2 && CtorParamCount(ctor) == 0) {
            L("  call void @" + cn + "_ctor(%" + cn + "* " + obj + ")");
        }
        // object initializer: store each `Field = value` into the instance
        if (e.ival == 2) {
            int j = 0;
            while (j < e.kids.Count) {
                Node it = e.kids[j];
                if (it.kind == AK.Assignment() && it.a != null
                    && it.a.kind == AK.Ident()) {
                    ExprVal fv = GenExpr(it.b);
                    StoreField(obj, cn, it.a.sval, fv);
                }
                j = j + 1;
            }
        }
        // preserve generic type arguments (ty may carry <...>) for the result
        AddTemp(obj, ty);
        return new ExprVal(obj, ty);
    }

    int CtorParamCount(Node ctor) {
        int n = 0; int i = 0;
        while (i < ctor.kids.Count) {
            if (ctor.kids[i].kind == AK.Param()) { n = n + 1; }
            i = i + 1;
        }
        return n;
    }

    Node CtorParamType(Node ctor, int argIdx) {
        int seen = 0; int i = 0;
        while (i < ctor.kids.Count) {
            if (ctor.kids[i].kind == AK.Param()) {
                if (seen == argIdx) { return ctor.kids[i].type; }
                seen = seen + 1;
            }
            i = i + 1;
        }
        return MkType("int");
    }

    // ---- cast ----
    ExprVal GenCast(Node e) {
        ExprVal v = GenExpr(e.b);
        Node tgt = e.type;
        bool toD = IsDbl(tgt);
        bool fromD = IsDbl(v.ty);
        // int -> double
        if (toD && !fromD && MapType(v.ty) == "i64") {
            string t = NT();
            L("  " + t + " = sitofp i64 " + v.op + " to double");
            return new ExprVal(t, tgt);
        }
        // double -> int (truncating toward zero)
        if (fromD && !toD && MapType(tgt) == "i64") {
            string t = NT();
            L("  " + t + " = fptosi double " + v.op + " to i64");
            return new ExprVal(t, tgt);
        }
        // unsigned / small-width targets share the i64 slot, so their cast is a
        // wrap-to-width mask (zero-extend for uint/ushort, sign-extend from 8
        // bits for sbyte) applied to the i64 value.
        if (!toD && !fromD && tgt != null && MapType(v.ty) == "i64") {
            string tn = tgt.sval;
            if (tn == "uint") {
                string t = NT();
                L("  " + t + " = and i64 " + v.op + ", 4294967295");
                return new ExprVal(t, tgt);
            }
            if (tn == "ushort") {
                string t = NT();
                L("  " + t + " = and i64 " + v.op + ", 65535");
                return new ExprVal(t, tgt);
            }
            if (tn == "sbyte") {
                string s1 = NT();
                L("  " + s1 + " = shl i64 " + v.op + ", 56");
                string s2 = NT();
                L("  " + s2 + " = ashr i64 " + s1 + ", 56");
                return new ExprVal(s2, tgt);
            }
        }
        // remaining numeric casts are all i64 in this model; just retag
        return new ExprVal(v.op, tgt);
    }

    // switch expression:  subj switch { pat => e, _ => e }. Constant patterns
    // (int / string) compared against the subject; "_" is the default arm.
    // Lowered to a test cascade feeding a phi at the join block.
    string RelCmp(int op) {
        if (op == TK.Less()) { return "slt"; }
        if (op == TK.Greater()) { return "sgt"; }
        if (op == TK.LessEq()) { return "sle"; }
        if (op == TK.GreaterEq()) { return "sge"; }
        return "eq";
    }

    // conditional expression: cond ? a : b, lowered to branches + phi
    ExprVal GenConditional(Node e) {
        ExprVal c = GenExpr(e.a);
        string ci = NT();
        L("  " + ci + " = icmp ne i64 " + c.op + ", 0");
        int lt = NL(); int lf = NL(); int lend = NL();
        L("  br i1 " + ci + ", label %L" + lt + ", label %L" + lf);
        Label(lt);
        ExprVal tv = GenExpr(e.b);
        Node rty = tv.ty;
        string rll = MapType(rty);
        string tvo = Coerce(tv, rll);
        string tlbl = curLbl;
        L("  br label %L" + lend);
        Label(lf);
        ExprVal fv = GenExpr(e.c);
        string fvo = Coerce(fv, rll);
        string flbl = curLbl;
        L("  br label %L" + lend);
        Label(lend);
        string r = NT();
        L("  " + r + " = phi " + rll + " [ " + tvo + ", %" + tlbl + " ], [ " + fvo + ", %" + flbl + " ]");
        return new ExprVal(r, rty);
    }

    // switch statement: case bodies as an if-else cascade; `break` jumps to
    // the end label (C# switch cases cannot fall through).
    void GenSwitchStmt(Node s) {
        stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
        ExprVal subj = GenExpr(s.a);
        int lend = NL();
        int sBrk = brkTarget; int sLoop = loopScopeBase;
        brkTarget = lend; loopScopeBase = locName.Count;
        Node deflt = null;
        int i = 0;
        while (i < s.kids.Count) {
            Node cse = s.kids[i];
            if (cse.a == null) { deflt = cse; i = i + 1; continue; }
            int bodyL = NL(); int nextL = NL();
            ExprVal pv = GenExpr(cse.a);
            string c = NT();
            if (IsStr(subj.ty) && IsStr(pv.ty)) {
                string r = NT();
                L("  " + r + " = call i32 @strcmp(i8* " + subj.op + ", i8* " + pv.op + ")");
                L("  " + c + " = icmp eq i32 " + r + ", 0");
            } else {
                L("  " + c + " = icmp eq i64 " + subj.op + ", " + pv.op);
            }
            L("  br i1 " + c + ", label %L" + bodyL + ", label %L" + nextL);
            Label(bodyL);
            int scopeStart = locName.Count;
            GenStmt(cse.b);
            if (!term) { ReleaseLocalsFrom(scopeStart); L("  br label %L" + lend); }
            term = false;
            TrimLocals(scopeStart);
            Label(nextL);
            i = i + 1;
        }
        if (deflt != null) {
            int scopeStart2 = locName.Count;
            GenStmt(deflt.b);
            if (!term) { ReleaseLocalsFrom(scopeStart2); L("  br label %L" + lend); }
            term = false;
            TrimLocals(scopeStart2);
        } else {
            L("  br label %L" + lend);
        }
        Label(lend);
        brkTarget = sBrk; loopScopeBase = sLoop;
    }

    ExprVal GenSwitchExpr(Node e) {
        List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;
        stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
        ExprVal subj = GenExpr(e.a);
        int nend = NL();
        List<string> vals = new List<string>();
        List<string> labs = new List<string>();
        string resLL = "i64";
        Node resTy = MkType("int");
        int i = 0;
        while (i < e.kids.Count) {
            Node arm = e.kids[i];
            int bodyL = NL();
            int nextL = NL();
            if (arm.a == null) {
                if (arm.c != null) {
                    ExprVal gv = GenExpr(arm.c);
                    string gi = NT();
                    L("  " + gi + " = icmp ne i64 " + gv.op + ", 0");
                    L("  br i1 " + gi + ", label %L" + bodyL + ", label %L" + nextL);
                } else {
                    L("  br label %L" + bodyL);
                }
            } else {
                ExprVal pv = GenExpr(arm.a);
                string c = NT();
                if (arm.op != 0) {
                    L("  " + c + " = icmp " + RelCmp(arm.op) + " i64 " + subj.op + ", " + pv.op);
                } else if (IsStr(subj.ty) && IsStr(pv.ty)) {
                    string r = NT();
                    L("  " + r + " = call i32 @strcmp(i8* " + subj.op + ", i8* " + pv.op + ")");
                    L("  " + c + " = icmp eq i32 " + r + ", 0");
                } else {
                    L("  " + c + " = icmp eq i64 " + subj.op + ", " + pv.op);
                }
                if (arm.c != null) {
                    int guardL = NL();
                    L("  br i1 " + c + ", label %L" + guardL + ", label %L" + nextL);
                    Label(guardL);
                    ExprVal gv = GenExpr(arm.c);
                    string gi = NT();
                    L("  " + gi + " = icmp ne i64 " + gv.op + ", 0");
                    L("  br i1 " + gi + ", label %L" + bodyL + ", label %L" + nextL);
                } else {
                    L("  br i1 " + c + ", label %L" + bodyL + ", label %L" + nextL);
                }
            }
            Label(bodyL);
            ExprVal rv = GenExpr(arm.b);
            resLL = MapType(rv.ty);
            resTy = rv.ty;
            vals.Add(Coerce(rv, resLL));
            labs.Add(curLbl);
            L("  br label %L" + nend);
            Label(nextL);
            i = i + 1;
        }
        L("  br label %L" + nend);
        string fbLbl = curLbl;
        Label(nend);
        string t = NT();
        string zero = "0"; if (resLL == "i8*") { zero = "null"; }
        string phi = t + " = phi " + resLL;
        int j = 0;
        while (j < vals.Count) {
            if (j > 0) { phi = phi + ","; }
            phi = phi + " [ " + vals[j] + ", %" + labs[j] + " ]";
            j = j + 1;
        }
        if (vals.Count > 0) { phi = phi + ", [ " + zero + ", %" + fbLbl + " ]"; }
        else { phi = phi + " [ " + zero + ", %" + fbLbl + " ]"; }
        L("  " + phi);
        stmtTemps = svT; stmtTempTypes = svTT;
        return new ExprVal(t, resTy);
    }

    // ---- lambdas / delegates ----
    bool IsDelegate(Node t) {
        if (t == null) { return false; }
        return binder.IsDelegateName(t.sval);
    }

    Node MkIdent(string name) { Node n = new Node(AK.Ident()); n.sval = name; return n; }

    bool Contains(List<string> xs, string s) {
        int i = 0;
        while (i < xs.Count) { if (xs[i] == s) { return true; } i = i + 1; }
        return false;
    }

    void CollectIdents(Node n, List<string> outv) {
        if (n == null) { return; }
        if (n.kind == AK.Ident()) { if (!Contains(outv, n.sval)) { outv.Add(n.sval); } }
        CollectIdents(n.a, outv); CollectIdents(n.b, outv);
        CollectIdents(n.c, outv); CollectIdents(n.d, outv);
        int i = 0;
        while (i < n.kids.Count) { CollectIdents(n.kids[i], outv); i = i + 1; }
    }

    void CollectDeclared(Node n, List<string> outv) {
        if (n == null) { return; }
        if (n.kind == AK.VarDecl()) { if (!Contains(outv, n.sval)) { outv.Add(n.sval); } }
        if (n.kind == AK.Param()) { if (!Contains(outv, n.sval)) { outv.Add(n.sval); } }
        CollectDeclared(n.a, outv); CollectDeclared(n.b, outv);
        CollectDeclared(n.c, outv); CollectDeclared(n.d, outv);
        int i = 0;
        while (i < n.kids.Count) { CollectDeclared(n.kids[i], outv); i = i + 1; }
    }

    // free enclosing-scope locals referenced by the lambda body (captured by value)
    void CollectCaptures(Node lam, List<string> pnames, List<string> caps, List<Node> capTy) {
        List<string> declared = new List<string>();
        int i = 0;
        while (i < pnames.Count) { declared.Add(pnames[i]); i = i + 1; }
        Node bodyN = lam.d; if (bodyN == null) { bodyN = lam.a; }
        CollectDeclared(bodyN, declared);
        List<string> used = new List<string>();
        CollectIdents(bodyN, used);
        int j = 0;
        while (j < used.Count) {
            string nm = used[j];
            if (!Contains(declared, nm) && !Contains(caps, nm)) {
                int li = LocalIdx(nm);
                if (li >= 0) { caps.Add(nm); capTy.Add(locType[li]); }
            }
            j = j + 1;
        }
    }

    // copy delegate parameter/return types onto a lambda's params + return slot
    void AnnotateLambda(Node lam, Node dty) {
        List<Node> pts = DelegParams(dty);
        int j = 0; int pi = 0;
        while (j < lam.kids.Count) {
            if (lam.kids[j].kind == AK.Param()) {
                if (pi < pts.Count) { lam.kids[j].type = pts[pi]; }
                pi = pi + 1;
            }
            j = j + 1;
        }
        lam.type = DelegRet(dty);
    }

    string LamFnType(Node retTy, List<Node> pt) {
        string s = MapType(retTy) + " (i8*";
        int i = 0;
        while (i < pt.Count) { s = s + ", " + MapType(pt[i]); i = i + 1; }
        s = s + ")*";
        return s;
    }

    Node DelegTypeOf(Node retTy, List<Node> pt) {
        Node d = new Node(AK.TypeRef());
        int i = 0;
        while (i < pt.Count) { d.Add(pt[i]); i = i + 1; }
        if (retTy != null && retTy.sval == "void") { d.sval = "Action"; }
        else { d.sval = "Func"; d.Add(retTy); }
        return d;
    }

    List<Node> DelegParams(Node dty) {
        List<Node> r = new List<Node>();
        // named delegate: signature comes from its declaration, with the
        // delegate's own type parameters bound to the use-site type arguments
        if (dty.sval != "Func" && dty.sval != "Action") {
            Node d = binder.FindDelegate(dty.sval);
            if (d != null) {
                List<string> dtn = TParams(d);
                List<Node> dta = DelegTArgs(d, dty, dtn);
                int j = 0;
                while (j < d.kids.Count) {
                    if (d.kids[j].kind == AK.Param()) { r.Add(SubstTP(d.kids[j].type, dtn, dta)); }
                    j = j + 1;
                }
                return r;
            }
        }
        int n = dty.kids.Count;
        int lim = n;
        if (dty.sval == "Func" && n > 0) { lim = n - 1; }
        int i = 0;
        while (i < lim) { r.Add(dty.kids[i]); i = i + 1; }
        return r;
    }

    // positional type arguments for a named delegate use (missing args stay
    // as the declared type-parameter names so unbound uses keep erased slots)
    List<Node> DelegTArgs(Node d, Node dty, List<string> dtn) {
        List<Node> dta = new List<Node>();
        int q = 0;
        while (q < dtn.Count) {
            if (q < dty.kids.Count) { dta.Add(dty.kids[q]); }
            else { dta.Add(MkType(dtn[q])); }
            q = q + 1;
        }
        return dta;
    }

    Node DelegRet(Node dty) {
        if (dty.sval != "Func" && dty.sval != "Action") {
            Node d = binder.FindDelegate(dty.sval);
            if (d != null && d.type != null) {
                List<string> dtn = TParams(d);
                return SubstTP(d.type, dtn, DelegTArgs(d, dty, dtn));
            }
        }
        if (dty.sval == "Func" && dty.kids.Count > 0) { return dty.kids[dty.kids.Count - 1]; }
        return MkType("void");
    }

    // A lambda lowers to a hoisted top-level function @__lambda_N(i8* env, ...)
    // plus a heap closure { i8* fn, i8* env } capturing free locals by value.
    // static method group as a delegate value: emit a thunk with the lambda
    // ABI (i8* env first) that forwards to the static method, and wrap it in
    // a {fn, env=null} closure.
    ExprVal EmitMethodGroup(string clsName, Node cls, Node m) {
        string owner = MethodOwner(cls, m.sval);
        if (owner == "") { owner = clsName; }
        string target = MethodSym(owner, m);
        List<Node> pt = new List<Node>();
        int i = 0;
        while (i < m.kids.Count) {
            Node p = m.kids[i];
            if (p.kind == AK.Param()) { pt.Add(p.type); }
            i = i + 1;
        }
        Node retTy = m.type; if (retTy == null) { retTy = MkType("void"); }
        string rt = MapType(retTy);
        string fname = "@__mg_" + target;
        string gname = "@__mg_clo_" + target;
        // one shared closure per target so delegate equality (e.g. `-=`
        // removal) sees the same value for repeated method-group mentions
        if (IndexOfStr(mgTargets, target) >= 0) {
            return new ExprVal("bitcast ([2 x i8*]* " + gname + " to i8*)", DelegTypeOf(retTy, pt));
        }
        mgTargets.Add(target);
        string sig = "define " + rt + " " + fname + "(i8* %env";
        int a = 0;
        while (a < pt.Count) { sig = sig + ", " + MapType(pt[a]) + " %p" + a; a = a + 1; }
        sig = sig + ") {";
        deferred.Append(sig); deferred.Append("\n");
        deferred.Append("entry:\n");
        string args = "";
        a = 0;
        while (a < pt.Count) {
            if (a > 0) { args = args + ", "; }
            args = args + MapType(pt[a]) + " %p" + a;
            a = a + 1;
        }
        if (rt == "void") {
            deferred.Append("  call void @" + target + "(" + args + ")\n");
            deferred.Append("  ret void\n");
        } else {
            deferred.Append("  %r = call " + rt + " @" + target + "(" + args + ")\n");
            deferred.Append("  ret " + rt + " %r\n");
        }
        deferred.Append("}\n");
        deferred.Append(gname + " = global [2 x i8*] [i8* bitcast ("
            + LamFnType(retTy, pt) + " " + fname + " to i8*), i8* null]\n");
        return new ExprVal("bitcast ([2 x i8*]* " + gname + " to i8*)", DelegTypeOf(retTy, pt));
    }

    ExprVal GenLambda(Node lam) {
        int id = lamCount; lamCount = lamCount + 1;
        string fname = "@__lambda_" + id;

        List<string> pn = new List<string>();
        List<Node> pt = new List<Node>();
        int i = 0;
        while (i < lam.kids.Count) {
            Node p = lam.kids[i];
            if (p.kind == AK.Param()) {
                pn.Add(p.sval);
                Node ptp = p.type;
                if (ptp == null || ptp.sval == "var") { ptp = MkType("int"); }
                pt.Add(ptp);
            }
            i = i + 1;
        }
        Node retTy = lam.type; if (retTy == null) { retTy = MkType("int"); }

        List<string> caps = new List<string>();
        List<Node> capTy = new List<Node>();
        CollectCaptures(lam, pn, caps, capTy);
        int nc = caps.Count;

        // build the env with the captured values (in the enclosing function)
        string env = "null";
        if (nc > 0) {
            env = NT();
            L("  " + env + " = call i8* @malloc(i64 " + (nc * 8) + ")");
            string envi = NT();
            L("  " + envi + " = bitcast i8* " + env + " to i64*");
            int c = 0;
            while (c < nc) {
                ExprVal cv = GenExpr(MkIdent(caps[c]));
                string slot = NT();
                L("  " + slot + " = getelementptr i64, i64* " + envi + ", i64 " + c);
                L("  store i64 " + ToSlot(cv, capTy[c]) + ", i64* " + slot);
                c = c + 1;
            }
        }

        // emit the hoisted lambda body into the deferred buffer
        StringBuilder savedBody = body;
        int sTmp = tmp; int sLbl = lbl; bool sTerm = term; string sCurLbl = curLbl;
        string sRet = curRet; string sClass = curClass; bool sHasThis = curHasThis;
        List<string> sLocName = locName; List<Node> sLocType = locType;
        List<string> sLocReg = locReg; int sLocSeq = locSeq;
        int sBrk = brkTarget; int sCont = contTarget;
        int sLoopScope = loopScopeBase;
        List<string> svT = stmtTemps; List<Node> svTT = stmtTempTypes;

        StringBuilder sEa = entryAllocas; bool sEaAct = eaActive;
        bool sAsync = curAsync;
        body = new StringBuilder();
        entryAllocas = new StringBuilder(); eaActive = true;
        tmp = 0; lbl = 0; term = false; curLbl = "entry"; curAsync = false;
        locName = new List<string>(); locType = new List<Node>(); locReg = new List<string>(); locSeq = 0;
        curRet = MapType(retTy); curClass = ""; curHasThis = false; brkTarget = 0; contTarget = 0;

        string sig = "define " + curRet + " " + fname + "(i8* %env";
        int a = 0;
        while (a < pn.Count) { sig = sig + ", " + MapType(pt[a]) + " %p" + a; a = a + 1; }
        sig = sig + ") {";
        a = 0;
        while (a < pn.Count) {
            string lt = MapType(pt[a]);
            string preg = AddLocal(pn[a], pt[a]);
            L("  " + preg + " = alloca " + lt);
            L("  store " + lt + " %p" + a + ", " + lt + "* " + preg);
            EmitArcRetain("%p" + a, pt[a]);
            a = a + 1;
        }
        if (nc > 0) {
            string envi = NT();
            L("  " + envi + " = bitcast i8* %env to i64*");
            int c = 0;
            while (c < nc) {
                string slot = NT();
                L("  " + slot + " = getelementptr i64, i64* " + envi + ", i64 " + c);
                string raw = NT();
                L("  " + raw + " = load i64, i64* " + slot);
                ExprVal cv = FromSlot(raw, capTy[c]);
                string lt = MapType(capTy[c]);
                string creg = AddLocal(caps[c], capTy[c]);
                L("  " + creg + " = alloca " + lt);
                string csv = Coerce(cv, lt);
                L("  store " + lt + " " + csv + ", " + lt + "* " + creg);
                EmitArcRetain(csv, capTy[c]);
                c = c + 1;
            }
        }
        if (lam.d != null) {
            GenStmt(lam.d);
            if (!term) {
                ReleaseLocalsFrom(0);
                if (curRet == "void") { L("  ret void"); }
                else if (curRet == "i64") { L("  ret i64 0"); }
                else { L("  ret " + curRet + " null"); }
            }
        } else {
            stmtTemps = new List<string>(); stmtTempTypes = new List<Node>();
            ExprVal rv = GenExpr(lam.a);
            if (curRet == "void") {
                EmitTempReleases();
                ReleaseLocalsFrom(0);
                L("  ret void");
            } else {
                string rvs = "";
                if (IsErasedType(retTy) && MapType(rv.ty) != "i64") {
                    // erased return slot: pack the concrete value (double via
                    // bitcast, pointers via ptrtoint) instead of Coerce
                    EmitArcRetain(rv.op, rv.ty);
                    rvs = ToSlot(rv, rv.ty);
                } else {
                    rvs = Coerce(rv, curRet);
                    EmitArcRetain(rvs, rv.ty);
                }
                EmitTempReleases();
                ReleaseLocalsFrom(0);
                L("  ret " + curRet + " " + rvs);
            }
        }
        L("}");
        // append the whole function at once so a nested lambda emitted while
        // this body was being generated does not interleave with our text
        deferred.Append(sig); deferred.Append("\n");
        deferred.Append("entry:\n");
        deferred.Append(entryAllocas.ToString());
        deferred.Append(body.ToString());

        entryAllocas = sEa; eaActive = sEaAct;
        curAsync = sAsync;
        body = savedBody;
        tmp = sTmp; lbl = sLbl; term = sTerm; curLbl = sCurLbl;
        curRet = sRet; curClass = sClass; curHasThis = sHasThis;
        locName = sLocName; locType = sLocType; locReg = sLocReg; locSeq = sLocSeq;
        brkTarget = sBrk; contTarget = sCont;
        loopScopeBase = sLoopScope;
        stmtTemps = svT; stmtTempTypes = svTT;

        // build closure { i8* fn, i8* env }
        string clo = NT();
        L("  " + clo + " = call i8* @malloc(i64 16)");
        string clop = NT();
        L("  " + clop + " = bitcast i8* " + clo + " to i8**");
        string fni8 = NT();
        L("  " + fni8 + " = bitcast " + LamFnType(retTy, pt) + " " + fname + " to i8*");
        L("  store i8* " + fni8 + ", i8** " + clop);
        string clop1 = NT();
        L("  " + clop1 + " = getelementptr i8*, i8** " + clop + ", i64 1");
        L("  store i8* " + env + ", i8** " + clop1);
        return new ExprVal(clo, DelegTypeOf(retTy, pt));
    }

    // invoke a closure value:  f(args) -> load {fn,env}, bitcast fn, call fn(env, args)
    ExprVal EmitDelegateCall(Node calleeExpr, Node dty, Node e) {
        ExprVal clo = GenExpr(calleeExpr);
        List<Node> pt = DelegParams(dty);
        Node retTy = DelegRet(dty);
        string clop = NT();
        L("  " + clop + " = bitcast i8* " + clo.op + " to i8**");
        string fni8 = NT();
        L("  " + fni8 + " = load i8*, i8** " + clop);
        string envp = NT();
        L("  " + envp + " = getelementptr i8*, i8** " + clop + ", i64 1");
        string env = NT();
        L("  " + env + " = load i8*, i8** " + envp);
        string fn = NT();
        L("  " + fn + " = bitcast i8* " + fni8 + " to " + LamFnType(retTy, pt));
        string args = "i8* " + env;
        int i = 0;
        while (i < e.kids.Count) {
            Node pty = MkType("int"); if (i < pt.Count) { pty = pt[i]; }
            ExprVal av = GenArgExpr(e.kids[i], pty);
            args = args + ", " + MapType(pty) + " " + Coerce(av, MapType(pty));
            i = i + 1;
        }
        string rt = MapType(retTy);
        if (rt == "void") { L("  call void " + fn + "(" + args + ")"); return new ExprVal("0", MkType("void")); }
        string t = NT();
        L("  " + t + " = call " + rt + " " + fn + "(" + args + ")");
        AddTemp(t, retTy);
        return new ExprVal(t, retTy);
    }

    // ---- calls ----
    ExprVal GenCall(Node e) {
        Node callee = e.a;
        // Environment / File builtins: ClassName.Method(...)
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()) {
            string cn = callee.a.sval;
            string mn = callee.sval;
            if (cn == "Task" && mn == "Spawn" && e.kids.Count == 1) {
                usesAsync = true;
                ExprVal sub = GenExpr(e.kids[0]);
                string subv = sub.op;
                string subh = NT(); L("  " + subh + " = bitcast i8* " + subv + " to i64*");
                string selfi = NT(); L("  " + selfi + " = ptrtoint i8* " + subv + " to i64");
                L("  store i64 " + selfi + ", i64* " + FrameGep(subh, 2));
                string reapi = NT(); L("  " + reapi + " = ptrtoint void(i8*)* @__zan_co_reap to i64");
                L("  store i64 " + reapi + ", i64* " + FrameGep(subh, 3));
                string orp = FrameGep(subh, 5);
                string ori = NT(); L("  " + ori + " = load i64, i64* " + orp);
                string orfn = NT(); L("  " + orfn + " = inttoptr i64 " + ori + " to void(i8*)*");
                L("  call void @zan_co_ready(i8* " + subv + ", void(i8*)* " + orfn + ")");
                return new ExprVal("0", MkType("int"));
            }
            if (cn == "Environment" && mn == "ArgCount") {
                string a = NT(); L("  " + a + " = load i32, i32* @__zan_argc");
                string a64 = NT(); L("  " + a64 + " = sext i32 " + a + " to i64");
                string r = NT(); L("  " + r + " = sub i64 " + a64 + ", 1");
                return new ExprVal(r, MkType("int"));
            }
            if (cn == "Environment" && mn == "ArgAt") {
                ExprVal idx = GenExpr(e.kids[0]);
                string i1 = NT(); L("  " + i1 + " = add i64 " + idx.op + ", 1");
                string av = NT(); L("  " + av + " = load i8**, i8*** @__zan_argv");
                string sp = NT(); L("  " + sp + " = getelementptr i8*, i8** " + av + ", i64 " + i1);
                string r = NT(); L("  " + r + " = load i8*, i8** " + sp);
                return new ExprVal(r, MkType("string"));
            }
            if (cn == "File" && mn == "ReadAllText") {
                ExprVal path = GenExpr(e.kids[0]);
                string rb = NT(); L("  " + rb + " = getelementptr inbounds [3 x i8], [3 x i8]* @.mode_rb, i64 0, i64 0");
                string fp = NT(); L("  " + fp + " = call i8* @fopen(i8* " + path.op + ", i8* " + rb + ")");
                EmitFopenCheck(fp, "@.msg.rderr", 18);
                string se0 = NT(); L("  " + se0 + " = call i32 @fseek(i8* " + fp + ", i64 0, i32 2)");
                string se0c = NT(); L("  " + se0c + " = icmp ne i32 " + se0 + ", 0"); EmitAbortIf(se0c, "@.msg.rderr", 18);
                string sz = NT(); L("  " + sz + " = call i64 @ftell(i8* " + fp + ")");
                string szc = NT(); L("  " + szc + " = icmp slt i64 " + sz + ", 0"); EmitAbortIf(szc, "@.msg.rderr", 18);
                string se1 = NT(); L("  " + se1 + " = call i32 @fseek(i8* " + fp + ", i64 0, i32 0)");
                string se1c = NT(); L("  " + se1c + " = icmp ne i32 " + se1 + ", 0"); EmitAbortIf(se1c, "@.msg.rderr", 18);
                string bsz = NT(); L("  " + bsz + " = add i64 " + sz + ", 1");
                string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + bsz + ")");
                string bufc = NT(); L("  " + bufc + " = icmp eq i8* " + buf + ", null"); EmitAbortIf(bufc, "@.msg.rderr", 18);
                string got = NT(); L("  " + got + " = call i64 @fread(i8* " + buf + ", i64 1, i64 " + sz + ", i8* " + fp + ")");
                string gotc = NT(); L("  " + gotc + " = icmp ne i64 " + got + ", " + sz); EmitAbortIf(gotc, "@.msg.rderr", 18);
                string ep = NT(); L("  " + ep + " = getelementptr i8, i8* " + buf + ", i64 " + sz);
                L("  store i8 0, i8* " + ep);
                string rc = NT(); L("  " + rc + " = call i32 @fclose(i8* " + fp + ")");
                string rcc = NT(); L("  " + rcc + " = icmp ne i32 " + rc + ", 0"); EmitAbortIf(rcc, "@.msg.rderr", 18);
                return new ExprVal(buf, MkType("string"));
            }
            if (cn == "File" && mn == "Exists") {
                ExprVal path = GenExpr(e.kids[0]);
                string rb = NT(); L("  " + rb + " = getelementptr inbounds [3 x i8], [3 x i8]* @.mode_rb, i64 0, i64 0");
                string fp = NT(); L("  " + fp + " = call i8* @fopen(i8* " + path.op + ", i8* " + rb + ")");
                string ok = NT(); L("  " + ok + " = icmp ne i8* " + fp + ", null");
                int lcl = NL(); int lend2 = NL();
                string okx = NT(); L("  " + okx + " = zext i1 " + ok + " to i64");
                L("  br i1 " + ok + ", label %L" + lcl + ", label %L" + lend2);
                Label(lcl);
                string fc = NT(); L("  " + fc + " = call i32 @fclose(i8* " + fp + ")");
                L("  br label %L" + lend2);
                Label(lend2);
                return new ExprVal(okx, MkType("bool"));
            }
            if (cn == "Environment" && mn == "ExeDir") {
                usesDirList = true;
                string t = NT(); L("  " + t + " = call i8* @zan_exe_dir()");
                return new ExprVal(t, MkType("string"));
            }
            if (cn == "Directory" && mn == "ListNames") {
                usesDirList = true;
                ExprVal pat = GenExpr(e.kids[0]);
                string t = NT(); L("  " + t + " = call i8* @zan_dir_list(i8* " + pat.op + ")");
                return new ExprVal(t, MkType("string"));
            }
            if (cn == "File" && mn == "WriteAllText") {
                ExprVal path = GenExpr(e.kids[0]);
                ExprVal content = GenExpr(e.kids[1]);
                string wb = NT(); L("  " + wb + " = getelementptr inbounds [2 x i8], [2 x i8]* @.mode_wb, i64 0, i64 0");
                string fp = NT(); L("  " + fp + " = call i8* @fopen(i8* " + path.op + ", i8* " + wb + ")");
                EmitFopenCheck(fp, "@.msg.wrerr", 19);
                string ln = NT(); L("  " + ln + " = call i64 @strlen(i8* " + content.op + ")");
                string wr = NT(); L("  " + wr + " = call i64 @fwrite(i8* " + content.op + ", i64 1, i64 " + ln + ", i8* " + fp + ")");
                string wrc = NT(); L("  " + wrc + " = icmp ne i64 " + wr + ", " + ln); EmitAbortIf(wrc, "@.msg.wrerr", 19);
                string wrcl = NT(); L("  " + wrcl + " = call i32 @fclose(i8* " + fp + ")");
                string wrclc = NT(); L("  " + wrclc + " = icmp ne i32 " + wrcl + ", 0"); EmitAbortIf(wrclc, "@.msg.wrerr", 19);
                return new ExprVal("0", MkType("void"));
            }
        }
        // Console.Write / WriteLine
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && callee.a.sval == "Console") {
            ExprVal arg = new ExprVal("0", MkType("int"));
            bool has = (e.kids.Count > 0);
            if (has) { arg = GenExpr(e.kids[0]); }
            bool nl = (callee.sval == "WriteLine");
            if (has && IsStr(arg.ty)) {
                string fg = "@.fmt.sn"; int fl = 3;
                if (nl) { fg = "@.fmt.snl"; fl = 4; }
                string gp = NT();
                L("  " + gp + " = getelementptr inbounds [" + fl + " x i8], [" + fl + " x i8]* " + fg + ", i64 0, i64 0");
                L("  call i32 (i8*, ...) @printf(i8* " + gp + ", i8* " + arg.op + ")");
            } else if (has && IsDbl(arg.ty)) {
                string fg = "@.fmt.gn"; int fl = 3;
                if (nl) { fg = "@.fmt.gnl"; fl = 4; }
                string gp = NT();
                L("  " + gp + " = getelementptr inbounds [" + fl + " x i8], [" + fl + " x i8]* " + fg + ", i64 0, i64 0");
                L("  call i32 (i8*, ...) @printf(i8* " + gp + ", double " + arg.op + ")");
            } else {
                string fg = "@.fmt.nn"; int fl = 5;
                if (nl) { fg = "@.fmt.nl"; fl = 6; }
                if (has && IsUlong(arg.ty)) {
                    fg = "@.fmt.unn"; fl = 5;
                    if (nl) { fg = "@.fmt.unl"; fl = 6; }
                }
                string gp = NT();
                L("  " + gp + " = getelementptr inbounds [" + fl + " x i8], [" + fl + " x i8]* " + fg + ", i64 0, i64 0");
                string a0 = "0"; if (has) { a0 = arg.op; }
                L("  call i32 (i8*, ...) @printf(i8* " + gp + ", i64 " + a0 + ")");
            }
            return new ExprVal("0", MkType("void"));
        }
        // Convert.ToString(x) -> heap string via snprintf; Convert.ToInt32(s) -> atoi
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && callee.a.sval == "Convert") {
            if (callee.sval == "ToString" && e.kids.Count == 1) {
                ExprVal a = GenExpr(e.kids[0]);
                string s = ToCStr(a);
                return new ExprVal(s, MkType("string"));
            }
            if (callee.sval == "ToDouble" && e.kids.Count == 1) {
                ExprVal a = GenExpr(e.kids[0]);
                if (IsStr(a.ty)) {
                    if (!ExternSeen("strtod")) { externDecls.Add("strtod"); H("declare double @strtod(i8*, i8**)"); }
                    string r = NT();
                    L("  " + r + " = call double @strtod(i8* " + a.op + ", i8** null)");
                    return new ExprVal(r, MkType("double"));
                }
                if (IsDbl(a.ty)) { return a; }
                string c = NT();
                L("  " + c + " = sitofp i64 " + a.op + " to double");
                return new ExprVal(c, MkType("double"));
            }
            if ((callee.sval == "ToInt32" || callee.sval == "ToInt") && e.kids.Count == 1) {
                ExprVal a = GenExpr(e.kids[0]);
                string r0 = NT();
                L("  " + r0 + " = call i64 @atoi(i8* " + a.op + ")");
                string r = NT();
                L("  " + r + " = and i64 " + r0 + ", 4294967295");
                string r2 = NT();
                L("  " + r2 + " = shl i64 " + r + ", 32");
                string r3 = NT();
                L("  " + r3 + " = ashr i64 " + r2 + ", 32");
                return new ExprVal(r3, MkType("int"));
            }
        }
        // int/long.Parse(s), double/float.Parse(s) and matching
        // TryParse(s, out v) -> strtoll/strtod (mirrors the C host)
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && LocalIdx(callee.a.sval) < 0) {
            string prn = callee.a.sval;
            bool intRecv = prn == "int" || prn == "long" || prn == "Int32" || prn == "Int64";
            bool dblRecv = prn == "double" || prn == "float" || prn == "Double" || prn == "Single";
            if ((intRecv || dblRecv) && callee.sval == "Parse" && e.kids.Count == 1) {
                ExprVal a = GenExpr(e.kids[0]);
                string r = NT();
                if (intRecv) {
                    if (!ExternSeen("strtoll")) { externDecls.Add("strtoll"); H("declare i64 @strtoll(i8*, i8**, i32)"); }
                    L("  " + r + " = call i64 @strtoll(i8* " + a.op + ", i8** null, i32 10)");
                    return new ExprVal(r, MkType("int"));
                }
                if (!ExternSeen("strtod")) { externDecls.Add("strtod"); H("declare double @strtod(i8*, i8**)"); }
                L("  " + r + " = call double @strtod(i8* " + a.op + ", i8** null)");
                return new ExprVal(r, MkType("double"));
            }
            if ((intRecv || dblRecv) && callee.sval == "TryParse" && e.kids.Count == 2
                && e.kids[1].kind == AK.OutArg()) {
                ExprVal a = GenExpr(e.kids[0]);
                Node oa = e.kids[1];
                Node oty = null;
                string outp = "";
                if (oa.type != null) {
                    oty = oa.type;
                    outp = AddLocal(oa.sval, oty);
                    EA(outp, MapType(oty));
                } else {
                    int li = LocalIdx(oa.sval);
                    if (li >= 0) { oty = locType[li]; outp = locReg[li]; }
                }
                string endp = NT();
                EA(endp, "i8*");
                L("  store i8* null, i8** " + endp);
                string v = NT();
                if (intRecv) {
                    if (!ExternSeen("strtoll")) { externDecls.Add("strtoll"); H("declare i64 @strtoll(i8*, i8**, i32)"); }
                    L("  " + v + " = call i64 @strtoll(i8* " + a.op + ", i8** " + endp + ", i32 10)");
                } else {
                    if (!ExternSeen("strtod")) { externDecls.Add("strtod"); H("declare double @strtod(i8*, i8**)"); }
                    L("  " + v + " = call double @strtod(i8* " + a.op + ", i8** " + endp + ")");
                }
                string ep = NT();
                L("  " + ep + " = load i8*, i8** " + endp);
                string moved = NT();
                L("  " + moved + " = icmp ne i8* " + ep + ", " + a.op);
                string ch = NT();
                L("  " + ch + " = load i8, i8* " + ep);
                string atend = NT();
                L("  " + atend + " = icmp eq i8 " + ch + ", 0");
                string ok = NT();
                L("  " + ok + " = and i1 " + moved + ", " + atend);
                if (outp != "") {
                    string zero = "0";
                    string vty = "i64";
                    if (dblRecv) { zero = "0.0"; vty = "double"; }
                    string stv = NT();
                    L("  " + stv + " = select i1 " + ok + ", " + vty + " " + v + ", " + vty + " " + zero);
                    L("  store " + vty + " " + stv + ", " + vty + "* " + outp);
                }
                string okz = NT();
                L("  " + okz + " = zext i1 " + ok + " to i64");
                return new ExprVal(okz, MkType("bool"));
            }
        }
        // Math.Round(x[, digits]) -> libm round; digits scale by 10^d
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && callee.a.sval == "Math" && LocalIdx("Math") < 0 && binder.FindType("Math") == null
            && callee.sval == "Round" && e.kids.Count >= 1 && e.kids.Count <= 2) {
            if (!ExternSeen("round")) { externDecls.Add("round"); H("declare double @round(double)"); }
            ExprVal a = GenExpr(e.kids[0]);
            string av = a.op;
            if (!IsDbl(a.ty)) { string c = NT(); L("  " + c + " = sitofp i64 " + av + " to double"); av = c; }
            if (e.kids.Count == 1) {
                string r = NT();
                L("  " + r + " = call double @round(double " + av + ")");
                return new ExprVal(r, MkType("double"));
            }
            if (!ExternSeen("pow")) { externDecls.Add("pow"); H("declare double @pow(double, double)"); }
            ExprVal d = GenExpr(e.kids[1]);
            string dv = d.op;
            if (!IsDbl(d.ty)) { string dc = NT(); L("  " + dc + " = sitofp i64 " + dv + " to double"); dv = dc; }
            string sc = NT();
            L("  " + sc + " = call double @pow(double 1.0e1, double " + dv + ")");
            string sd = NT();
            L("  " + sd + " = fmul double " + av + ", " + sc);
            string rr = NT();
            L("  " + rr + " = call double @round(double " + sd + ")");
            string res = NT();
            L("  " + res + " = fdiv double " + rr + ", " + sc);
            return new ExprVal(res, MkType("double"));
        }
        // string.IsNullOrEmpty / string.Join / string.Format statics
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && (callee.a.sval == "string" || callee.a.sval == "String") && LocalIdx(callee.a.sval) < 0) {
            if (callee.sval == "IsNullOrEmpty" && e.kids.Count == 1) {
                ExprVal a = GenExpr(e.kids[0]);
                usesStrOps = true;
                string r = NT();
                L("  " + r + " = call i64 @zstr_isempty(i8* " + a.op + ")");
                return new ExprVal(r, MkType("bool"));
            }
            if (callee.sval == "Join" && e.kids.Count == 2) {
                ExprVal sep = GenExpr(e.kids[0]);
                ExprVal lst = GenExpr(e.kids[1]);
                usesStrOps = true;
                string r = NT();
                L("  " + r + " = call i8* @zstr_join(i8* " + sep.op + ", i8* " + lst.op + ")");
                return new ExprVal(r, MkType("string"));
            }
            if (callee.sval == "Format" && e.kids.Count >= 1 && e.kids[0].kind == AK.StringLit()) {
                return EmitStrFormat(e);
            }
        }
        // NativeMemory.* -> inline raw-memory intrinsics (no external symbol)
        if (callee.kind == AK.MemberAccess() && callee.a != null && callee.a.kind == AK.Ident()
            && callee.a.sval == "NativeMemory" && LocalIdx("NativeMemory") < 0) {
            ExprVal nm = GenNativeMemory(callee, e);
            if (nm != null) { return nm; }
        }
        // method access forms
        if (callee.kind == AK.MemberAccess()) {
            Node obj = callee.a;
            string mname = callee.sval;
            // static call: ClassName.Method(...)
            if (obj.kind == AK.Ident() && binder.FindType(obj.sval) != null && LocalIdx(obj.sval) < 0) {
                Node stc = binder.FindType(obj.sval);
                // delegate-typed static field invoked as Cls.f(args)
                if (FindMethodUp(stc, mname) == null) {
                    Node sf = FindStaticField(stc, mname);
                    if (sf != null && sf.type != null && IsDelegate(sf.type)) {
                        return EmitDelegateCall(callee, sf.type, e);
                    }
                }
                return EmitStaticCall(obj.sval, mname, e);
            }
            // evaluate receiver
            ExprVal recv = GenExpr(obj);
            // scalar ToString: bool -> "true"/"false", numbers via snprintf
            if (mname == "ToString" && e.kids.Count == 0 && !IsStr(recv.ty)
                && ClassOf(recv.ty) == null && !IsListType(recv.ty) && !IsDictType(recv.ty) && !IsSbType(recv.ty)) {
                if (recv.ty.sval == "bool") {
                    ExprVal ts = GenStr("true");
                    ExprVal fs = GenStr("false");
                    string c = NT(); L("  " + c + " = icmp ne i64 " + recv.op + ", 0");
                    string r = NT(); L("  " + r + " = select i1 " + c + ", i8* " + ts.op + ", i8* " + fs.op);
                    return new ExprVal(r, MkType("string"));
                }
                return new ExprVal(ToCStr(recv), MkType("string"));
            }
            // builtin in-place List.Reverse wins over the copying extension
            if (IsListType(recv.ty) && mname == "Reverse" && e.kids.Count == 0) {
                L("  call void @zlist_reverse(i8* " + recv.op + ")");
                return new ExprVal("0", MkType("void"));
            }
            // extension methods: static method with a `this` receiver of recv's type
            List<Node> extMs = new List<Node>();
            List<string> extOwners = new List<string>();
            binder.FindExtensionAll(recv.ty.sval, mname, extMs, extOwners);
            if (extMs.Count > 0) {
                int pick = PickExtension(extMs, recv.ty, e);
                return EmitExtensionCall(recv, extOwners[pick], extMs[pick], e);
            }
            // string methods
            if (IsStr(recv.ty)) { return EmitStrMethod(recv, mname, e); }
            // list methods
            if (IsListType(recv.ty)) { return EmitListMethod(recv, mname, e); }
            // dictionary methods
            if (IsDictType(recv.ty)) { return EmitDictMethod(recv, mname, e); }
            // string-builder methods
            if (IsSbType(recv.ty)) { return EmitSbMethod(recv, mname, e); }
            // instance method
            Node cls = ClassOf(recv.ty);
            if (cls != null) {
                // delegate-typed field invoked as obj.f(args)
                if (FindMethodUp(cls, mname) == null) {
                    Node fdty = FieldType(cls, mname);
                    if (fdty != null && IsDelegate(fdty)) {
                        return EmitDelegateCall(callee, fdty, e);
                    }
                }
                return EmitInstanceCall(recv, cls.sval, mname, e);
            }
            return new ExprVal("0", MkType("int"));
        }
        // bare call
        if (callee.kind == AK.Ident()) {
            string name = callee.sval;
            // delegate invocation: a local of Func/Action type
            int dli = LocalIdx(name);
            if (dli >= 0 && IsDelegate(locType[dli])) {
                return EmitDelegateCall(callee, locType[dli], e);
            }
            if (curHasThis) {
                Node cls = binder.FindType(curClass);
                Node bm = FindMethodUp(cls, name);
                if (bm != null && !IsStatic(bm)) {
                    ExprVal recv = new ExprVal("%this", MkType(curClass));
                    return EmitInstanceCall(recv, curClass, name, e);
                }
                // delegate-typed field invoked without `this.`
                if (bm == null) {
                    Node fdty2 = FieldType(cls, name);
                    if (fdty2 != null && IsDelegate(fdty2)) {
                        return EmitDelegateCall(callee, fdty2, e);
                    }
                }
            }
            return EmitStaticCall(curClass, name, e);
        }
        return new ExprVal("0", MkType("int"));
    }

    string ParamTypeStr(Node m, int idx) {
        int seen = 0; int i = 0;
        while (i < m.kids.Count) {
            if (m.kids[i].kind == AK.Param()) {
                if (seen == idx) { return MapType(m.kids[i].type); }
                seen = seen + 1;
            }
            i = i + 1;
        }
        return "i64";
    }

    Node ParamTypeNode(Node m, int idx) {
        int seen = 0; int i = 0;
        while (i < m.kids.Count) {
            if (m.kids[i].kind == AK.Param()) {
                if (seen == idx) { return m.kids[i].type; }
                seen = seen + 1;
            }
            i = i + 1;
        }
        return MkType("int");
    }

    // evaluate a call argument, first pushing a delegate parameter's
    // signature onto a bare lambda argument
    ExprVal GenArgExpr(Node a, Node pty) {
        if (a != null && a.kind == AK.Lambda() && pty != null && IsDelegate(pty)) {
            AnnotateLambda(a, pty);
        }
        return GenExpr(a);
    }

    // build a call argument for a (possibly erased) parameter type
    string CallArg(ExprVal av, Node pty) {
        if (IsErasedType(pty)) { return ToSlot(av, av.ty); }
        return Coerce(av, MapType(pty));
    }

    int IndexOfStr(List<string> xs, string s) {
        int i = 0;
        while (i < xs.Count) { if (xs[i] == s) { return i; } i = i + 1; }
        return -1;
    }

    // Reorder a call's arguments to positional order, applying named-argument
    // placement and filling omitted trailing parameters with their defaults.
    // When there are no named args and every parameter is supplied, the call's
    // own argument list is returned unchanged (keeps existing IR byte-identical).
    List<Node> OrderArgs(Node m, Node e) {
        if (m == null) { return e.kids; }
        List<string> pnames = new List<string>();
        List<Node> pdefault = new List<Node>();
        int i = 0;
        while (i < m.kids.Count) {
            if (m.kids[i].kind == AK.Param()) { pnames.Add(m.kids[i].sval); pdefault.Add(m.kids[i].b); }
            i = i + 1;
        }
        int np = pnames.Count;
        // `params T[] rest` tail: bundle extra positional args into a List<T>
        // collection-initializer node (the parameter type is already List<T>).
        // A single trailing List value (or explicit `new List<T>{...}`) passes
        // through unpacked.
        Node lastParam = null;
        i = m.kids.Count - 1;
        while (i >= 0) {
            if (m.kids[i].kind == AK.Param()) { lastParam = m.kids[i]; break; }
            i = i - 1;
        }
        if (lastParam != null && lastParam.op == 1 && np > 0) {
            bool named0 = false;
            int q = 0;
            while (q < e.kids.Count) { if (e.kids[q].sval2 != "") { named0 = true; } q = q + 1; }
            if (!named0 && e.kids.Count >= np - 1) {
                bool passthrough = false;
                if (e.kids.Count == np) {
                    Node la = e.kids[np - 1];
                    if (la.kind == AK.NewExpr()) { passthrough = true; }
                    if (la.kind == AK.Ident()) {
                        int li = LocalIdx(la.sval);
                        if (li >= 0 && IsListType(locType[li])) { passthrough = true; }
                    }
                }
                if (!passthrough) {
                    Node packed = new Node(AK.NewExpr());
                    packed.ival = 2;
                    packed.type = lastParam.type;
                    packed.line = e.line; packed.col = e.col;
                    int w = np - 1;
                    while (w < e.kids.Count) { packed.Add(e.kids[w]); w = w + 1; }
                    List<Node> outk = new List<Node>();
                    w = 0;
                    while (w < np - 1) { outk.Add(e.kids[w]); w = w + 1; }
                    outk.Add(packed);
                    return outk;
                }
            }
        }
        if (e.kids.Count > np) {
            diags.Error("too many arguments to '" + m.sval + "' (expected "
                + np + ", got " + e.kids.Count + ")", e.line, e.col);
        }
        bool anyNamed = false;
        int j = 0;
        while (j < e.kids.Count) { if (e.kids[j].sval2 != "") { anyNamed = true; } j = j + 1; }
        if (!anyNamed && e.kids.Count >= np) { return e.kids; }
        List<Node> slots = new List<Node>();
        int s = 0; while (s < np) { slots.Add(null); s = s + 1; }
        int pos = 0;
        j = 0;
        while (j < e.kids.Count) {
            Node arg = e.kids[j];
            if (arg.sval2 != "") {
                int idx = IndexOfStr(pnames, arg.sval2);
                if (idx >= 0 && idx < np) { slots[idx] = arg; }
            } else {
                if (pos < np) { slots[pos] = arg; }
                pos = pos + 1;
            }
            j = j + 1;
        }
        int k = 0;
        while (k < np) {
            if (slots[k] == null) {
                if (pdefault[k] != null) { slots[k] = pdefault[k]; }
                else {
                    diags.Error("missing required argument for parameter '"
                        + pnames[k] + "' of '" + m.sval + "'", e.line, e.col);
                    Node z = new Node(AK.IntLit()); z.ival = 0; slots[k] = z;
                }
            }
            k = k + 1;
        }
        return slots;
    }

    ExprVal EmitStaticCall(string clsName, string name, Node e) {
        Node cls = binder.FindType(clsName);
        Node m = ResolveMethod(cls, name, e, true);
        string sym = clsName + "_" + name;
        if (m != null) { sym = MethodSym(clsName, m); }
        bool spec = false;
        List<string> stns = new List<string>();
        List<Node> strs = new List<Node>();
        if (m != null && CanSpecialize(m)) {
            List<string> mtps = TParams(m);
            if (mtps.Count > 0) {
                BindFromArgs(m, e, 0, mtps, stns, strs);
                string tag = SpecTag(m, mtps, stns, strs);
                if (tag != "") { sym = SpecQueue(clsName, m, stns, strs, tag); spec = true; }
            }
        }
        string rt = "i64";
        if (m != null) { rt = MapType(m.type); }
        if (spec) { rt = MapType(SubstTP(m.type, stns, strs)); }
        bool isAsyncCall = (m != null && IsAsync(m));
        if (isAsyncCall) { rt = "i8*"; }
        string args = "";
        List<Node> aargs = OrderArgs(m, e);
        bool freeArgIsStr = false;
        int i = 0;
        while (i < aargs.Count) {
            Node pty = MkType("int"); if (m != null) { pty = ParamTypeNode(m, i); }
            if (spec) { pty = SubstTP(pty, stns, strs); }
            ExprVal av = GenArgExpr(aargs[i], pty);
            if (i == 0 && IsStr(av.ty)) { freeArgIsStr = true; }
            if (i > 0) { args = args + ", "; }
            if (m != null && HasMod(m, MOD.Extern()) && IsDelegate(pty)) {
                // extern C fn-pointer parameter: pass the closure's code pointer
                string cp = NT();
                L("  " + cp + " = bitcast i8* " + av.op + " to i8**");
                string fp = NT();
                L("  " + fp + " = load i8*, i8** " + cp);
                args = args + "i8* " + fp;
            } else {
                args = args + MapType(pty) + " " + CallArg(av, pty);
            }
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void @" + sym + "(" + args + ")");
            // C `free(s)` consumes the string: null out the freed lvalue so
            // ARC never touches the dangling pointer again
            if (m != null && HasMod(m, MOD.Extern()) && ExternName(m) == "free"
                && aargs.Count == 1 && aargs[0] != null && freeArgIsStr
                && (aargs[0].kind == AK.Ident() || aargs[0].kind == AK.MemberAccess())) {
                StoreTo(aargs[0], new ExprVal("null", MkType("string")));
            }
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + sym + "(" + args + ")");
        if (m != null && HasMod(m, MOD.Extern()) && IsDelegate(m.type)) {
            // extern C returns a bare fn pointer: rewrap as a {fn, env} closure
            string clo = NT();
            L("  " + clo + " = call i8* @malloc(i64 16)");
            string clop = NT();
            L("  " + clop + " = bitcast i8* " + clo + " to i8**");
            L("  store i8* " + t + ", i8** " + clop);
            string clop1 = NT();
            L("  " + clop1 + " = getelementptr i8*, i8** " + clop + ", i64 1");
            L("  store i8* null, i8** " + clop1);
            string isn = NT();
            L("  " + isn + " = icmp eq i8* " + t + ", null");
            string res = NT();
            L("  " + res + " = select i1 " + isn + ", i8* null, i8* " + clo);
            return new ExprVal(res, m.type);
        }
        if (isAsyncCall) { Node tt = MkType("__task"); tt.a = m.type; return new ExprVal(t, tt); }
        if (spec) {
            Node srt = SubstTP(m.type, stns, strs);
            AddTemp(t, srt);
            return new ExprVal(t, srt);
        }
        if (m != null && IsErasedType(m.type)) { return FromSlot(t, m.type); }
        Node retTy = MkType("int"); if (m != null) { retTy = m.type; }
        AddTemp(t, retTy);
        return new ExprVal(t, retTy);
    }

    // choose the extension overload matching the call's arg count, preferring
    // receivers whose concrete type arguments match over generic wildcards
    int PickExtension(List<Node> ms, Node recvTy, Node e) {
        int best = 0; int bestScore = -1;
        int i = 0;
        while (i < ms.Count) {
            Node m = ms[i];
            int np = 0;
            int k = 0;
            while (k < m.kids.Count) { if (m.kids[k].kind == AK.Param()) { np = np + 1; } k = k + 1; }
            int score = 0;
            if (np - 1 == e.kids.Count) { score = 100; }
            score = score + MatchTypeScore(ParamTypeNode(m, 0), recvTy, TParams(m));
            score = score + LambdaArgScore(m, recvTy, e);
            if (score > bestScore) { bestScore = score; best = i; }
            i = i + 1;
        }
        return best;
    }

    // score an extension candidate's lambda arguments: bind the method type
    // parameters from the receiver, then compare each expression-bodied
    // lambda's inferred result type against the delegate's return type so
    // same-name overloads differing only in key type resolve correctly
    int LambdaArgScore(Node m, Node recvTy, Node e) {
        List<string> mtps = TParams(m);
        List<string> tns = new List<string>();
        List<Node> trs = new List<Node>();
        UnifyTP(ParamTypeNode(m, 0), recvTy, mtps, tns, trs);
        int score = 0;
        int k = 0;
        while (k < e.kids.Count) {
            Node arg = e.kids[k];
            if (arg != null && arg.kind == AK.Lambda() && arg.d == null) {
                Node pty = SubstTP(ParamTypeNode(m, k + 1), tns, trs);
                Node dd = null;
                if (pty != null) { dd = binder.FindDelegate(pty.sval); }
                if (dd != null) {
                    List<string> dtn = TParams(dd);
                    Node drt = SubstTP(dd.type, dtn, DelegTArgs(dd, pty, dtn));
                    if (drt != null && !MentionsTypeParam(drt)) {
                        List<Node> dps = DelegParams(pty);
                        int mark = locName.Count;
                        int pi = 0; int j = 0;
                        while (j < arg.kids.Count) {
                            if (arg.kids[j].kind == AK.Param()) {
                                Node pt2 = null;
                                if (pi < dps.Count) { pt2 = dps[pi]; }
                                locName.Add(arg.kids[j].sval); locType.Add(pt2); locReg.Add("");
                                pi = pi + 1;
                            }
                            j = j + 1;
                        }
                        Node lrt = ArgTypeNode(arg.a);
                        while (locName.Count > mark) {
                            locName.RemoveAt(locName.Count - 1);
                            locType.RemoveAt(locType.Count - 1);
                            locReg.RemoveAt(locReg.Count - 1);
                        }
                        if (lrt != null) {
                            if (TypeTag(lrt) == TypeTag(drt)) { score = score + 8; }
                            else { score = score - 4; }
                        }
                    }
                }
            }
            k = k + 1;
        }
        return score;
    }

    // deep receiver-shape match: concrete equality scores above a
    // type-parameter wildcard; a mismatch scores zero
    int MatchTypeScore(Node shape, Node conc, List<string> mtps) {
        if (shape == null || conc == null) { return 0; }
        if (IndexOfStr(mtps, shape.sval) >= 0 && shape.kids.Count == 0) { return 1; }
        if (shape.sval != conc.sval) { return 0; }
        int s = 2;
        int i = 0;
        while (i < shape.kids.Count && i < conc.kids.Count) {
            s = s + MatchTypeScore(shape.kids[i], conc.kids[i], mtps);
            i = i + 1;
        }
        return s;
    }

    // bind a generic shape (e.g. List<T>) against a concrete type
    // (List<User>), recording each method type-parameter binding found
    void UnifyTP(Node shape, Node conc, List<string> mtps, List<string> names, List<Node> reps) {
        if (shape == null || conc == null) { return; }
        if (IndexOfStr(mtps, shape.sval) >= 0 && shape.kids.Count == 0) {
            if (IndexOfStr(names, shape.sval) < 0) { names.Add(shape.sval); reps.Add(conc); }
            return;
        }
        int i = 0;
        while (i < shape.kids.Count && i < conc.kids.Count) {
            UnifyTP(shape.kids[i], conc.kids[i], mtps, names, reps);
            i = i + 1;
        }
    }

    Node SubstTP(Node t, List<string> names, List<Node> reps) {
        if (t == null) { return null; }
        if (t.kids.Count == 0) {
            int hit = IndexOfStr(names, t.sval);
            if (hit >= 0) { return reps[hit]; }
            return t;
        }
        Node n = new Node(t.kind);
        n.sval = t.sval;
        int i = 0;
        while (i < t.kids.Count) { n.Add(SubstTP(t.kids[i], names, reps)); i = i + 1; }
        return n;
    }

    // ---- method-level monomorphization ----
    // deep-clone a method AST substituting its type parameters with the
    // concrete bindings so the specialized body lowers with concrete types
    Node CloneSubst(Node n, List<string> tns, List<Node> trs) {
        if (n == null) { return null; }
        Node c = new Node(n.kind);
        c.op = n.op; c.ival = n.ival; c.sval = n.sval; c.sval2 = n.sval2;
        c.mods = n.mods; c.line = n.line; c.col = n.col;
        c.type = SubstTP(n.type, tns, trs);
        c.a = CloneSubst(n.a, tns, trs);
        c.b = CloneSubst(n.b, tns, trs);
        c.c = CloneSubst(n.c, tns, trs);
        c.d = CloneSubst(n.d, tns, trs);
        int i = 0;
        while (i < n.kids.Count) { c.Add(CloneSubst(n.kids[i], tns, trs)); i = i + 1; }
        return c;
    }

    // "" when the binding is incomplete or still generic; otherwise a tag
    // encoding both the concrete type arguments and the declared param shapes
    // (so same-name overloads specialize to distinct symbols)
    string SpecTag(Node m, List<string> mtps, List<string> tns, List<Node> trs) {
        StringBuilder sb = new StringBuilder();
        int i = 0;
        while (i < mtps.Count) {
            int hit = IndexOfStr(tns, mtps[i]);
            if (hit < 0) { return ""; }
            if (MentionsTypeParam(trs[hit])) { return ""; }
            sb.Append("_");
            sb.Append(TypeTag(trs[hit]));
            i = i + 1;
        }
        i = 0;
        while (i < m.kids.Count) {
            Node p = m.kids[i];
            if (p.kind == AK.Param()) { sb.Append("_"); sb.Append(TypeTag(p.type)); }
            i = i + 1;
        }
        return sb.ToString();
    }

    // queue (once) a specialized clone of `m` under owner and return the
    // specialized symbol; the drain loop in Gen emits the bodies
    string SpecQueue(string owner, Node m, List<string> tns, List<Node> trs, string tag) {
        string sname = m.sval + "__SP" + tag;
        string sym = owner + "_" + sname;
        if (IndexOfStr(specSyms, sym) < 0) {
            specSyms.Add(sym);
            Node clone = CloneSubst(m, tns, trs);
            clone.sval = sname;
            specMs.Add(clone);
            specClss.Add(binder.FindType(owner));
        }
        return sym;
    }

    // infer the static type of an expression-bodied lambda's result with its
    // parameters bound to the delegate's (possibly substituted) param types
    Node LambdaBodyType(Node lam, List<Node> dps) {
        int mark = locName.Count;
        int pi = 0; int j = 0;
        while (j < lam.kids.Count) {
            if (lam.kids[j].kind == AK.Param()) {
                Node pt2 = lam.kids[j].type;
                if (pt2 == null && pi < dps.Count) { pt2 = dps[pi]; }
                locName.Add(lam.kids[j].sval); locType.Add(pt2); locReg.Add("");
                pi = pi + 1;
            }
            j = j + 1;
        }
        Node lrt = ArgTypeNode(lam.a);
        while (locName.Count > mark) {
            locName.RemoveAt(locName.Count - 1);
            locType.RemoveAt(locType.Count - 1);
            locReg.RemoveAt(locReg.Count - 1);
        }
        return lrt;
    }

    // extend a receiver-derived binding with bindings inferred from the call
    // arguments: plain args unify their static type against the declared
    // param shape; expression-bodied lambdas unify their inferred body type
    // against the delegate's return shape
    void BindFromArgs(Node m, Node e, int base0, List<string> mtps, List<string> tns, List<Node> trs) {
        int k = 0;
        while (k < e.kids.Count) {
            Node arg = e.kids[k];
            Node pty = SubstTP(ParamTypeNode(m, k + base0), tns, trs);
            if (arg != null && pty != null) {
                if (arg.kind == AK.Lambda()) {
                    Node dd = binder.FindDelegate(pty.sval);
                    if (dd != null && arg.d == null && arg.a != null) {
                        List<Node> dps = DelegParams(pty);
                        Node lrt = LambdaBodyType(arg, dps);
                        List<string> dtn = TParams(dd);
                        Node drs = SubstTP(dd.type, dtn, DelegTArgs(dd, pty, dtn));
                        if (lrt != null) { UnifyTP(drs, lrt, mtps, tns, trs); }
                    }
                } else {
                    Node aty = ArgTypeNode(arg);
                    if (aty != null) { UnifyTP(pty, aty, mtps, tns, trs); }
                }
            }
            k = k + 1;
        }
    }

    bool CanSpecialize(Node m) {
        if (m == null || m.d == null) { return false; }
        if (HasMod(m, MOD.Extern())) { return false; }
        if (IsAsync(m)) { return false; }
        return true;
    }

    // extension call: static method invoked as recv.M(args) -> M(recv, args).
    // The method's own type parameters are bound from the receiver's static
    // type so lambda arguments and the result see concrete types; the call
    // ABI itself stays on the declared (erased) parameter types.
    ExprVal EmitExtensionCall(ExprVal recv, string owner, Node m, Node e) {
        List<string> mtps = TParams(m);
        List<string> tns = new List<string>();
        List<Node> trs = new List<Node>();
        UnifyTP(ParamTypeNode(m, 0), recv.ty, mtps, tns, trs);
        string sym = MethodSym(owner, m);
        bool spec = false;
        if (mtps.Count > 0 && CanSpecialize(m)) {
            BindFromArgs(m, e, 1, mtps, tns, trs);
            string tag = SpecTag(m, mtps, tns, trs);
            if (tag != "") { sym = SpecQueue(owner, m, tns, trs, tag); spec = true; }
        }
        Node mrt = m.type;
        Node p0 = ParamTypeNode(m, 0);
        if (spec) { mrt = SubstTP(m.type, tns, trs); p0 = SubstTP(p0, tns, trs); }
        string rt = MapType(mrt);
        string args = MapType(p0) + " " + CallArg(recv, p0);
        int i = 0;
        while (i < e.kids.Count) {
            Node pty = ParamTypeNode(m, i + 1);
            Node spty = SubstTP(pty, tns, trs);
            if (spec) { pty = spty; }
            ExprVal av = GenArgExpr(e.kids[i], spty);
            args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void @" + sym + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + sym + "(" + args + ")");
        Node retTy = SubstTP(m.type, tns, trs);
        if (!spec && IsErasedType(m.type)) { return FromSlot(t, retTy); }
        AddTemp(t, retTy);
        return new ExprVal(t, retTy);
    }

    ExprVal EmitInstanceCall(ExprVal recv, string clsName, string name, Node e) {
        Node cls = binder.FindType(clsName);
        Node m = ResolveMethodUp(cls, name, e, false);
        if (m != null && IsPolyClass(cls) && VSlotIndexM(cls, m) >= 0) {
            return EmitVirtualCall(recv, cls, name, m, e);
        }
        string owner = MethodOwner(cls, name);
        if (owner == "") { owner = clsName; }
        string sym = owner + "_" + name;
        if (m != null) { sym = MethodSym(owner, m); }
        string thisOp = recv.op;
        if (owner != clsName) {
            string bc = NT();
            L("  " + bc + " = bitcast %" + clsName + "* " + recv.op + " to %" + owner + "*");
            thisOp = bc;
        }
        string rt = "i64";
        if (m != null) { rt = MapType(m.type); }
        bool isAsyncCall = (m != null && IsAsync(m));
        if (isAsyncCall) { rt = "i8*"; }
        string args = "%" + owner + "* " + thisOp;
        List<Node> aargs = OrderArgs(m, e);
        int i = 0;
        while (i < aargs.Count) {
            Node pty = MkType("int"); if (m != null) { pty = ParamTypeNode(m, i); }
            ExprVal av = GenArgExpr(aargs[i], pty);
            args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void @" + sym + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " @" + sym + "(" + args + ")");
        if (isAsyncCall) { Node tt = MkType("__task"); tt.a = m.type; return new ExprVal(t, tt); }
        if (m != null && IsErasedType(m.type)) { return FromSlot(t, ConcreteTP(m.type, recv.ty)); }
        Node retTy = MkType("int"); if (m != null) { retTy = m.type; }
        AddTemp(t, retTy);
        return new ExprVal(t, retTy);
    }

    ExprVal EmitVirtualCall(ExprVal recv, Node cls, string name, Node m, Node e) {
        string clsName = cls.sval;
        int slot = VSlotIndexM(cls, m);
        string rt = MapType(m.type);
        string vtp = NT();
        L("  " + vtp + " = getelementptr %" + clsName + ", %" + clsName + "* " + recv.op + ", i32 0, i32 0");
        string vt = NT();
        L("  " + vt + " = load i8*, i8** " + vtp);
        string vta = NT();
        L("  " + vta + " = bitcast i8* " + vt + " to i8**");
        string slotp = NT();
        L("  " + slotp + " = getelementptr i8*, i8** " + vta + ", i64 " + slot);
        string fni8 = NT();
        L("  " + fni8 + " = load i8*, i8** " + slotp);
        string fn = NT();
        L("  " + fn + " = bitcast i8* " + fni8 + " to " + MethodFnTypeThis(m, clsName));
        string args = "%" + clsName + "* " + recv.op;
        List<Node> aargs = OrderArgs(m, e);
        int i = 0;
        while (i < aargs.Count) {
            Node pty = ParamTypeNode(m, i);
            ExprVal av = GenArgExpr(aargs[i], pty);
            args = args + ", " + MapType(pty) + " " + CallArg(av, pty);
            i = i + 1;
        }
        if (rt == "void") {
            L("  call void " + fn + "(" + args + ")");
            return new ExprVal("0", MkType("void"));
        }
        string t = NT();
        L("  " + t + " = call " + rt + " " + fn + "(" + args + ")");
        if (IsErasedType(m.type)) { return FromSlot(t, ConcreteTP(m.type, recv.ty)); }
        AddTemp(t, m.type);
        return new ExprVal(t, m.type);
    }

    // literal format string: expand {N} placeholders through a StringBuilder
    ExprVal EmitStrFormat(Node e) {
        string sb = NT();
        L("  " + sb + " = call i8* @zsb_new()");
        string f = e.kids[0].sval;
        string seg = "";
        int i = 0;
        while (i < f.Length) {
            bool subst = false;
            if (f[i] == 123) {
                int j = i + 1;
                int idx = 0;
                bool has = false;
                while (j < f.Length && f[j] >= 48 && f[j] <= 57) { idx = idx * 10 + (f[j] - 48); j = j + 1; has = true; }
                if (has && j < f.Length && f[j] == 125 && idx + 1 < e.kids.Count) {
                    if (seg != "") {
                        ExprVal sl = GenStr(seg);
                        L("  call void @zsb_append(i8* " + sb + ", i8* " + sl.op + ")");
                        seg = "";
                    }
                    ExprVal av = GenExpr(e.kids[idx + 1]);
                    string s = ToCStr(av);
                    L("  call void @zsb_append(i8* " + sb + ", i8* " + s + ")");
                    i = j + 1;
                    subst = true;
                }
            }
            if (!subst) { seg = seg + f.Substring(i, 1); i = i + 1; }
        }
        if (seg != "") {
            ExprVal sl = GenStr(seg);
            L("  call void @zsb_append(i8* " + sb + ", i8* " + sl.op + ")");
        }
        string r = NT();
        L("  " + r + " = call i8* @zsb_tostring(i8* " + sb + ")");
        L("  call void @zrelease(i8* " + sb + ")");
        return new ExprVal(r, MkType("string"));
    }

    ExprVal EmitStrMethod(ExprVal recv, string name, Node e) {
        if (name == "Substring") {
            ExprVal start = GenExpr(e.kids[0]);
            string lenOp;
            if (e.kids.Count >= 2) { ExprVal l = GenExpr(e.kids[1]); lenOp = l.op; }
            else {
                string sl = NT(); L("  " + sl + " = call i64 @strlen(i8* " + recv.op + ")");
                string rem = NT(); L("  " + rem + " = sub i64 " + sl + ", " + start.op);
                lenOp = rem;
            }
            string bsz = NT(); L("  " + bsz + " = add i64 " + lenOp + ", 1");
            string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + bsz + ")");
            string srcp = NT(); L("  " + srcp + " = getelementptr i8, i8* " + recv.op + ", i64 " + start.op);
            L("  call i8* @memcpy(i8* " + buf + ", i8* " + srcp + ", i64 " + lenOp + ")");
            string endp = NT(); L("  " + endp + " = getelementptr i8, i8* " + buf + ", i64 " + lenOp);
            L("  store i8 0, i8* " + endp);
            return new ExprVal(buf, MkType("string"));
        }
        if (name == "Contains" && e.kids.Count == 1) {
            ExprVal sub = GenExpr(e.kids[0]);
            DeclStrstr();
            string hit = NT(); L("  " + hit + " = call i8* @strstr(i8* " + recv.op + ", i8* " + sub.op + ")");
            string r = NT(); L("  " + r + " = icmp ne i8* " + hit + ", null");
            string z = NT(); L("  " + z + " = zext i1 " + r + " to i64");
            return new ExprVal(z, MkType("bool"));
        }
        if (name == "IndexOf" && e.kids.Count == 1) {
            ExprVal sub = GenExpr(e.kids[0]);
            DeclStrstr();
            string hit = NT(); L("  " + hit + " = call i8* @strstr(i8* " + recv.op + ", i8* " + sub.op + ")");
            string hi = NT(); L("  " + hi + " = ptrtoint i8* " + hit + " to i64");
            string si = NT(); L("  " + si + " = ptrtoint i8* " + recv.op + " to i64");
            string diff = NT(); L("  " + diff + " = sub i64 " + hi + ", " + si);
            string miss = NT(); L("  " + miss + " = icmp eq i8* " + hit + ", null");
            string r = NT(); L("  " + r + " = select i1 " + miss + ", i64 -1, i64 " + diff);
            return new ExprVal(r, MkType("int"));
        }
        if (name == "LastIndexOf" && e.kids.Count == 1) {
            ExprVal sub = GenExpr(e.kids[0]);
            usesStrOps = true;
            string r = NT(); L("  " + r + " = call i64 @zstr_lastidx(i8* " + recv.op + ", i8* " + sub.op + ")");
            return new ExprVal(r, MkType("int"));
        }
        if ((name == "StartsWith" || name == "EndsWith") && e.kids.Count == 1) {
            ExprVal p = GenExpr(e.kids[0]);
            DeclStrncmp();
            string lp = NT(); L("  " + lp + " = call i64 @strlen(i8* " + p.op + ")");
            string z = NT();
            if (name == "StartsWith") {
                string cmp = NT(); L("  " + cmp + " = call i32 @strncmp(i8* " + recv.op + ", i8* " + p.op + ", i64 " + lp + ")");
                string r = NT(); L("  " + r + " = icmp eq i32 " + cmp + ", 0");
                L("  " + z + " = zext i1 " + r + " to i64");
            } else {
                string ls = NT(); L("  " + ls + " = call i64 @strlen(i8* " + recv.op + ")");
                string off = NT(); L("  " + off + " = sub i64 " + ls + ", " + lp);
                string fits = NT(); L("  " + fits + " = icmp sge i64 " + off + ", 0");
                string offc = NT(); L("  " + offc + " = select i1 " + fits + ", i64 " + off + ", i64 0");
                string tail = NT(); L("  " + tail + " = getelementptr i8, i8* " + recv.op + ", i64 " + offc);
                string cmp = NT(); L("  " + cmp + " = call i32 @strcmp(i8* " + tail + ", i8* " + p.op + ")");
                string eq = NT(); L("  " + eq + " = icmp eq i32 " + cmp + ", 0");
                string r = NT(); L("  " + r + " = and i1 " + fits + ", " + eq);
                L("  " + z + " = zext i1 " + r + " to i64");
            }
            return new ExprVal(z, MkType("bool"));
        }
        if (name == "Replace" && e.kids.Count == 2) {
            ExprVal from = GenExpr(e.kids[0]);
            ExprVal to = GenExpr(e.kids[1]);
            usesStrOps = true;
            string r = NT(); L("  " + r + " = call i8* @zstr_replace(i8* " + recv.op + ", i8* " + from.op + ", i8* " + to.op + ")");
            return new ExprVal(r, MkType("string"));
        }
        if (name == "Trim" && e.kids.Count == 0) {
            usesStrOps = true;
            string r = NT(); L("  " + r + " = call i8* @zstr_trim(i8* " + recv.op + ")");
            return new ExprVal(r, MkType("string"));
        }
        if ((name == "ToUpper" || name == "ToLower") && e.kids.Count == 0) {
            usesStrOps = true;
            string up = "1"; if (name == "ToLower") { up = "0"; }
            string r = NT(); L("  " + r + " = call i8* @zstr_case(i8* " + recv.op + ", i64 " + up + ")");
            return new ExprVal(r, MkType("string"));
        }
        if (name == "Split" && e.kids.Count == 1) {
            ExprVal sep = GenExpr(e.kids[0]);
            usesStrOps = true;
            string r = NT(); L("  " + r + " = call i8* @zstr_split(i8* " + recv.op + ", i8* " + sep.op + ")");
            Node lt = MkType("List");
            lt.kids.Add(MkType("string"));
            AddTemp(r, lt);
            return new ExprVal(r, lt);
        }
        if (name == "ToString" && e.kids.Count == 0) {
            // owned copy of the receiver
            string n = NT(); L("  " + n + " = call i64 @strlen(i8* " + recv.op + ")");
            string bsz = NT(); L("  " + bsz + " = add i64 " + n + ", 1");
            string buf = NT(); L("  " + buf + " = call i8* @malloc(i64 " + bsz + ")");
            L("  call i8* @memcpy(i8* " + buf + ", i8* " + recv.op + ", i64 " + bsz + ")");
            return new ExprVal(buf, MkType("string"));
        }
        // unknown string method: return receiver
        return recv;
    }

    void DeclStrstr() {
        if (!ExternSeen("strstr")) { externDecls.Add("strstr"); H("declare i8* @strstr(i8*, i8*)"); }
    }
    void DeclStrncmp() {
        if (!ExternSeen("strncmp")) { externDecls.Add("strncmp"); H("declare i32 @strncmp(i8*, i8*, i64)"); }
    }

    ExprVal EmitListMethod(ExprVal recv, string name, Node e) {
        if (name == "Add") {
            ExprVal v = GenExpr(e.kids[0]);
            string sv = ToSlot(v, ListElem(recv.ty));
            L("  call void @zlist_add(i8* " + recv.op + ", i64 " + sv + ")");
            return new ExprVal("0", MkType("void"));
        }
        if (name == "get_Count" || name == "Count") {
            string t = NT();
            L("  " + t + " = call i64 @zlist_count(i8* " + recv.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        if (name == "RemoveAt") {
            ExprVal idx = GenExpr(e.kids[0]);
            L("  call void @zlist_removeat(i8* " + recv.op + ", i64 " + idx.op + ")");
            return new ExprVal("0", MkType("void"));
        }
        if (name == "Clear") {
            L("  call void @zlist_clear(i8* " + recv.op + ")");
            return new ExprVal("0", MkType("void"));
        }
        return new ExprVal("0", MkType("int"));
    }

    // dict keys are stored as C strings; scalar keys use their decimal image
    string DictKeyOp(ExprVal k) {
        if (IsStr(k.ty)) { return k.op; }
        return ToCStr(k);
    }

    ExprVal EmitDictMethod(ExprVal recv, string name, Node e) {
        if (name == "Add" || name == "set_Item") {
            ExprVal key = GenExpr(e.kids[0]);
            ExprVal val = GenExpr(e.kids[1]);
            string sv = ToSlot(val, DictVal(recv.ty));
            L("  call void @zdict_set(i8* " + recv.op + ", i8* " + DictKeyOp(key) + ", i64 " + sv + ")");
            return new ExprVal("0", MkType("void"));
        }
        if (name == "ContainsKey") {
            ExprVal key = GenExpr(e.kids[0]);
            string t = NT();
            L("  " + t + " = call i64 @zdict_contains(i8* " + recv.op + ", i8* " + DictKeyOp(key) + ")");
            return new ExprVal(t, MkType("bool"));
        }
        if (name == "Remove") {
            ExprVal key = GenExpr(e.kids[0]);
            string t = NT();
            L("  " + t + " = call i64 @zdict_remove(i8* " + recv.op + ", i8* " + DictKeyOp(key) + ")");
            return new ExprVal(t, MkType("bool"));
        }
        if (name == "get_Count" || name == "Count") {
            string t = NT();
            L("  " + t + " = call i64 @zdict_count(i8* " + recv.op + ")");
            return new ExprVal(t, MkType("int"));
        }
        return new ExprVal("0", MkType("int"));
    }

    ExprVal EmitSbMethod(ExprVal recv, string name, Node e) {
        if (name == "AppendLine") {
            if (e.kids.Count >= 1) {
                ExprVal a = GenExpr(e.kids[0]);
                string s = a.op;
                if (!IsStr(a.ty)) { s = ToCStr(a); }
                L("  call void @zsb_append(i8* " + recv.op + ", i8* " + s + ")");
            }
            ExprVal nl = GenStr("\n");
            L("  call void @zsb_append(i8* " + recv.op + ", i8* " + nl.op + ")");
            return recv;
        }
        if (name == "Append") {
            ExprVal a = GenExpr(e.kids[0]);
            string s = a.op;
            if (!IsStr(a.ty)) { s = ToCStr(a); }
            L("  call void @zsb_append(i8* " + recv.op + ", i8* " + s + ")");
            return recv;
        }
        if (name == "ToString") {
            string t = NT();
            L("  " + t + " = call i8* @zsb_tostring(i8* " + recv.op + ")");
            return new ExprVal(t, MkType("string"));
        }
        return recv;
    }
}
