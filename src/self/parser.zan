using System;

namespace ZanCompiler;

class Parser {
    public int Pos;
    public int Count;
    public int ErrorCount;

    public Parser(int tokenCount) {
        Pos = 0;
        Count = tokenCount;
        ErrorCount = 0;
    }

    int AtEnd() {
        if (Pos >= Count) { return 1; }
        return 0;
    }

    int Advance() {
        var old = Pos;
        if (Pos < Count) {
            Pos = Pos + 1;
        }
        return old;
    }

    int Expect(int kind, int actual) {
        if (actual != kind) {
            ErrorCount = ErrorCount + 1;
            return 0;
        }
        Advance();
        return 1;
    }

    int Match(int kind, int actual) {
        if (actual == kind) {
            Advance();
            return 1;
        }
        return 0;
    }

    // Precedence table for binary operators
    int GetPrecedence(int tokenKind) {
        // || = 1
        if (tokenKind == 113) { return 1; }
        // && = 2
        if (tokenKind == 112) { return 2; }
        // == != = 3
        if (tokenKind == 106) { return 3; }
        if (tokenKind == 107) { return 3; }
        // < <= > >= = 4
        if (tokenKind == 108) { return 4; }
        if (tokenKind == 109) { return 4; }
        if (tokenKind == 110) { return 4; }
        if (tokenKind == 111) { return 4; }
        // + - = 5
        if (tokenKind == 100) { return 5; }
        if (tokenKind == 101) { return 5; }
        // * / % = 6
        if (tokenKind == 102) { return 6; }
        if (tokenKind == 103) { return 6; }
        if (tokenKind == 104) { return 6; }
        return 0;
    }

    int IsBinaryOp(int tokenKind) {
        if (GetPrecedence(tokenKind) > 0) { return 1; }
        return 0;
    }

    int IsUnaryOp(int tokenKind) {
        if (tokenKind == 101) { return 1; }
        if (tokenKind == 114) { return 1; }
        return 0;
    }

    int IsAssignOp(int tokenKind) {
        if (tokenKind == 105) { return 1; }
        return 0;
    }

    // Statement detection
    int IsStmtStart(int tokenKind) {
        if (tokenKind == 28) { return 1; }  // var
        if (tokenKind == 29) { return 1; }  // if
        if (tokenKind == 31) { return 1; }  // while
        if (tokenKind == 32) { return 1; }  // for
        if (tokenKind == 33) { return 1; }  // return
        if (tokenKind == 34) { return 1; }  // break
        if (tokenKind == 35) { return 1; }  // continue
        if (tokenKind == 47) { return 1; }  // switch
        if (tokenKind == 202) { return 1; } // {
        return 0;
    }

    // Declaration detection
    int IsDeclStart(int tokenKind) {
        if (tokenKind == 20) { return 1; }  // class
        if (tokenKind == 21) { return 1; }  // struct
        if (tokenKind == 22) { return 1; }  // interface
        if (tokenKind == 23) { return 1; }  // enum
        if (tokenKind == 40) { return 1; }  // public
        if (tokenKind == 41) { return 1; }  // private
        if (tokenKind == 42) { return 1; }  // static
        if (tokenKind == 45) { return 1; }  // using
        if (tokenKind == 46) { return 1; }  // namespace
        return 0;
    }

    // Type keyword detection
    int IsTypeKeyword(int tokenKind) {
        if (tokenKind == 24) { return 1; }  // void
        if (tokenKind == 25) { return 1; }  // int
        if (tokenKind == 26) { return 1; }  // string
        if (tokenKind == 27) { return 1; }  // bool
        if (tokenKind == 10) { return 1; }  // identifier (user type)
        return 0;
    }
}

class CodeGen {
    public int TempCount;
    public int LabelCount;
    public int StringCount;
    public int InstrCount;

    public CodeGen() {
        TempCount = 0;
        LabelCount = 0;
        StringCount = 0;
        InstrCount = 0;
    }

    int NextTemp() {
        TempCount = TempCount + 1;
        return TempCount;
    }

    int NextLabel() {
        LabelCount = LabelCount + 1;
        return LabelCount;
    }

    int AddString() {
        var idx = StringCount;
        StringCount = StringCount + 1;
        return idx;
    }

    // Map Zan types to LLVM IR type codes
    // 0=i64, 1=double, 2=ptr, 3=i1, 4=void
    int MapType(int typeKind) {
        if (typeKind == 25) { return 0; }  // int -> i64
        if (typeKind == 26) { return 2; }  // string -> ptr
        if (typeKind == 27) { return 3; }  // bool -> i1
        if (typeKind == 24) { return 4; }  // void
        return 2;  // reference types -> ptr
    }

    // Emit binary operation IR instruction code
    // Returns opcode: 0=add, 1=sub, 2=mul, 3=sdiv, 4=srem
    //                 5=icmp eq, 6=icmp ne, 7=icmp slt, 8=icmp sle, 9=icmp sgt, 10=icmp sge
    int MapBinaryOp(int tokenKind) {
        if (tokenKind == 100) { return 0; }  // + -> add
        if (tokenKind == 101) { return 1; }  // - -> sub
        if (tokenKind == 102) { return 2; }  // * -> mul
        if (tokenKind == 103) { return 3; }  // / -> sdiv
        if (tokenKind == 104) { return 4; }  // % -> srem
        if (tokenKind == 106) { return 5; }  // == -> icmp eq
        if (tokenKind == 107) { return 6; }  // != -> icmp ne
        if (tokenKind == 108) { return 7; }  // < -> icmp slt
        if (tokenKind == 109) { return 8; }  // <= -> icmp sle
        if (tokenKind == 110) { return 9; }  // > -> icmp sgt
        if (tokenKind == 111) { return 10; } // >= -> icmp sge
        return 0;
    }
}

class Program {
    static void Main() {
        // Parser test
        var p = new Parser(50);
        Console.WriteLine(p.Pos);            // 0
        Console.WriteLine(p.Count);          // 50
        Console.WriteLine(p.AtEnd());        // 0
        
        var old = p.Advance();
        Console.WriteLine(old);              // 0
        Console.WriteLine(p.Pos);            // 1
        
        // Precedence tests
        Console.WriteLine(p.GetPrecedence(100));  // 5 (+)
        Console.WriteLine(p.GetPrecedence(102));  // 6 (*)
        Console.WriteLine(p.GetPrecedence(106));  // 3 (==)
        Console.WriteLine(p.GetPrecedence(108));  // 4 (<)
        Console.WriteLine(p.GetPrecedence(113));  // 1 (||)
        Console.WriteLine(p.IsBinaryOp(100));     // 1
        Console.WriteLine(p.IsBinaryOp(200));     // 0
        
        // Statement/decl detection
        Console.WriteLine(p.IsStmtStart(29));     // 1 (if)
        Console.WriteLine(p.IsStmtStart(10));     // 0 (ident)
        Console.WriteLine(p.IsDeclStart(20));     // 1 (class)
        Console.WriteLine(p.IsTypeKeyword(25));   // 1 (int)

        // CodeGen test
        var cg = new CodeGen();
        Console.WriteLine(cg.NextTemp());         // 1
        Console.WriteLine(cg.NextTemp());         // 2
        Console.WriteLine(cg.NextLabel());        // 1
        Console.WriteLine(cg.MapType(25));        // 0 (int->i64)
        Console.WriteLine(cg.MapType(26));        // 2 (string->ptr)
        Console.WriteLine(cg.MapBinaryOp(100));   // 0 (add)
        Console.WriteLine(cg.MapBinaryOp(102));   // 2 (mul)
        Console.WriteLine(cg.MapBinaryOp(106));   // 5 (icmp eq)
    }
}
