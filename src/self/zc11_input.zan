// real Zan source: string values (locals, parameters, Console.Write/WriteLine)
using System;

namespace Demo;

class Program {
    static void Banner(string label, int n) {
        Console.Write(label);
        Console.WriteLine(n);
    }

    static void Main() {
        string hi = "count = ";
        Banner(hi, 3);

        string tt = "total = ";
        Banner(tt, 42);

        string bye = "done";
        Console.WriteLine(bye);
    }
}
