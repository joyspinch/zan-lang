// real Zan source: class with fields + instance methods (implicit this)
using System;

namespace Demo;

class Rect {
    public int w;
    public int h;
    public int Area() { return w * h; }
    public int Scaled(int k) { return w * h * k; }
}

class Program {
    static void Main() {
        var r = new Rect();
        r.w = 10;
        r.h = 5;
        Console.WriteLine(r.Area());
        Console.WriteLine(r.Scaled(3));
    }
}
