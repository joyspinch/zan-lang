        a[52] = 40; // '('
        a[53] = 53; // '5'
        a[54] = 41; // ')'
        a[55] = 59; // ';'
        Eval(a, 56);

        // recursive fibonacci(10) -> 55
        var b = new int[62];
        b[0] = 102; // 'f'
