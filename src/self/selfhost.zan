using System;

namespace ZanCompiler;

// Self-hosted tokenizer -- unlike the earlier bootstrap models that
// *estimated* token counts from source length, this scans a real buffer of
// character codes and produces an exact token classification.
//
// This version exercises language features that only became usable once the
// backend codegen bugs were fixed:
//   * short-circuit && / ||          (range checks, `i < len && src[i]...`)
//   * array-typed method parameters  (Scan(int[] src, int len, int[] counts))
// so the self-hosting front-end can be written in idiomatic Zan.

class CharClass {
    public CharClass() { }

    int IsAlpha(int ch) {
        if (ch >= 65 && ch <= 90) { return 1; }
        if (ch >= 97 && ch <= 122) { return 1; }
        if (ch == 95) { return 1; }
        return 0;
    }

    int IsDigit(int ch) {
        if (ch >= 48 && ch <= 57) { return 1; }
        return 0;
    }

    int IsAlphaNum(int ch) {
        if (IsAlpha(ch) == 1 || IsDigit(ch) == 1) { return 1; }
        return 0;
    }

    int IsWhitespace(int ch) {
        if (ch == 32 || ch == 9 || ch == 13 || ch == 10) { return 1; }
        return 0;
    }

    // Two-character operators: == != <= >= && ||
    int IsDoubleOp(int c0, int c1) {
        if (c0 == 61 && c1 == 61) { return 1; }
        if (c0 == 33 && c1 == 61) { return 1; }
        if (c0 == 60 && c1 == 61) { return 1; }
        if (c0 == 62 && c1 == 61) { return 1; }
        if (c0 == 38 && c1 == 38) { return 1; }
        if (c0 == 124 && c1 == 124) { return 1; }
        return 0;
    }

    // Returns 1 if an identifier run is actually a keyword.
    int IsKeyword(int c0, int c1, int c2, int len) {
        if (c0 == 105 && c1 == 110 && c2 == 116 && len == 3) { return 1; } // int
        if (c0 == 105 && c1 == 102 && len == 2) { return 1; }              // if
        if (c0 == 99 && c1 == 108 && c2 == 97 && len == 5) { return 1; }   // class
        if (c0 == 118 && c1 == 111 && c2 == 105 && len == 4) { return 1; } // void
        if (c0 == 98 && c1 == 111 && c2 == 111 && len == 4) { return 1; }  // bool
        if (c0 == 114 && c1 == 101 && c2 == 116 && len == 6) { return 1; } // return
        if (c0 == 119 && c1 == 104 && len == 5) { return 1; }             // while
        if (c0 == 102 && c1 == 111 && c2 == 114 && len == 3) { return 1; } // for
        if (c0 == 101 && c1 == 108 && c2 == 115 && len == 4) { return 1; } // else
        if (c0 == 116 && c1 == 114 && c2 == 117 && len == 4) { return 1; } // true
        if (c0 == 112 && c1 == 117 && c2 == 98 && len == 6) { return 1; }  // public
        if (c0 == 115 && c1 == 116 && c2 == 97 && len == 6) { return 1; }  // static
        if (c0 == 115 && c1 == 116 && c2 == 114 && len == 6) { return 1; } // struct
        if (c0 == 110 && c1 == 97 && c2 == 109 && len == 9) { return 1; }  // namespace
        if (c0 == 117 && c1 == 115 && c2 == 105 && len == 5) { return 1; } // using
        return 0;
    }
}

class Program {
    // counts layout: [0]=tokens [1]=idents [2]=keywords [3]=numbers [4]=operators
    static void Scan(int[] src, int len, int[] counts) {
        var cc = new CharClass();
        var i = 0;

        while (i < len) {
            var c = src[i];

            if (cc.IsWhitespace(c) == 1) {
                i = i + 1;
            } else {
                if (cc.IsAlpha(c) == 1) {
                    var start = i;
                    // short-circuit && guards the array read past the end
                    while (i < len && cc.IsAlphaNum(src[i]) == 1) { i = i + 1; }
                    var wlen = i - start;
                    var k0 = src[start];
                    var k1 = 0;
                    var k2 = 0;
                    if (wlen > 1) { k1 = src[start + 1]; }
                    if (wlen > 2) { k2 = src[start + 2]; }
                    if (cc.IsKeyword(k0, k1, k2, wlen) == 1) { counts[2] = counts[2] + 1; }
                    else { counts[1] = counts[1] + 1; }
                    counts[0] = counts[0] + 1;
                } else {
                    if (cc.IsDigit(c) == 1) {
                        while (i < len && cc.IsDigit(src[i]) == 1) { i = i + 1; }
                        counts[3] = counts[3] + 1;
                        counts[0] = counts[0] + 1;
                    } else {
                        var c1 = 0;
                        if (i + 1 < len) { c1 = src[i + 1]; }
                        if (cc.IsDoubleOp(c, c1) == 1) { i = i + 2; }
                        else { i = i + 1; }
                        counts[4] = counts[4] + 1;
                        counts[0] = counts[0] + 1;
                    }
                }
            }
        }
    }

    static void Main() {
        Console.WriteLine(8888); // self-host tokenizer start marker

        // Real source buffer: "class C { int x = 42 + y; }"
        var len = 27;
        var src = new int[27];
        src[0] = 99;
        src[1] = 108;
        src[2] = 97;
        src[3] = 115;
        src[4] = 115;
        src[5] = 32;
        src[6] = 67;
        src[7] = 32;
        src[8] = 123;
        src[9] = 32;
        src[10] = 105;
        src[11] = 110;
        src[12] = 116;
        src[13] = 32;
        src[14] = 120;
        src[15] = 32;
        src[16] = 61;
        src[17] = 32;
        src[18] = 52;
        src[19] = 50;
        src[20] = 32;
        src[21] = 43;
        src[22] = 32;
        src[23] = 121;
        src[24] = 59;
        src[25] = 32;
        src[26] = 125;

        var counts = new int[5];
        counts[0] = 0;
        counts[1] = 0;
        counts[2] = 0;
        counts[3] = 0;
        counts[4] = 0;

        Scan(src, len, counts);

        Console.WriteLine(counts[0]); // tokens    = 11
        Console.WriteLine(counts[1]); // idents    = 3
        Console.WriteLine(counts[2]); // keywords  = 2
        Console.WriteLine(counts[3]); // numbers   = 1
        Console.WriteLine(counts[4]); // operators = 5

        Console.WriteLine(7777); // end marker
    }
}
