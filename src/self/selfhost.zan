using System;

namespace ZanCompiler;

// Self-hosted tokenizer -- unlike the earlier bootstrap models that
// *estimated* token counts from source length, this scans a real buffer of
// character codes and produces an exact token classification, exercising the
// Zan language (local arrays, loops, break, method dispatch) on compiler work.

class CharClass {
    public CharClass() { }

    int IsAlpha(int ch) {
        if (ch >= 65) { if (ch <= 90) { return 1; } }
        if (ch >= 97) { if (ch <= 122) { return 1; } }
        if (ch == 95) { return 1; }
        return 0;
    }

    int IsDigit(int ch) {
        if (ch >= 48) { if (ch <= 57) { return 1; } }
        return 0;
    }

    int IsAlphaNum(int ch) {
        if (IsAlpha(ch) == 1) { return 1; }
        if (IsDigit(ch) == 1) { return 1; }
        return 0;
    }

    int IsWhitespace(int ch) {
        if (ch == 32) { return 1; }
        if (ch == 9) { return 1; }
        if (ch == 13) { return 1; }
        if (ch == 10) { return 1; }
        return 0;
    }

    // Two-character operators: == != <= >= && ||
    int IsDoubleOp(int c0, int c1) {
        if (c0 == 61) { if (c1 == 61) { return 1; } }
        if (c0 == 33) { if (c1 == 61) { return 1; } }
        if (c0 == 60) { if (c1 == 61) { return 1; } }
        if (c0 == 62) { if (c1 == 61) { return 1; } }
        if (c0 == 38) { if (c1 == 38) { return 1; } }
        if (c0 == 124) { if (c1 == 124) { return 1; } }
        return 0;
    }

    // Returns 1 if an identifier run is actually a keyword.
    int IsKeyword(int c0, int c1, int c2, int len) {
        if (c0 == 105) { if (c1 == 110) { if (c2 == 116) { if (len == 3) { return 1; } } } } // int
        if (c0 == 105) { if (c1 == 102) { if (len == 2) { return 1; } } }                    // if
        if (c0 == 99) { if (c1 == 108) { if (c2 == 97) { if (len == 5) { return 1; } } } }    // class
        if (c0 == 118) { if (c1 == 111) { if (c2 == 105) { if (len == 4) { return 1; } } } }  // void
        if (c0 == 98) { if (c1 == 111) { if (c2 == 111) { if (len == 4) { return 1; } } } }   // bool
        if (c0 == 114) { if (c1 == 101) { if (c2 == 116) { if (len == 6) { return 1; } } } }  // return
        if (c0 == 119) { if (c1 == 104) { if (len == 5) { return 1; } } }                     // while
        if (c0 == 102) { if (c1 == 111) { if (c2 == 114) { if (len == 3) { return 1; } } } }  // for
        if (c0 == 101) { if (c1 == 108) { if (c2 == 115) { if (len == 4) { return 1; } } } }  // else
        if (c0 == 116) { if (c1 == 114) { if (c2 == 117) { if (len == 4) { return 1; } } } }  // true
        if (c0 == 112) { if (c1 == 117) { if (c2 == 98) { if (len == 6) { return 1; } } } }   // public
        if (c0 == 115) { if (c1 == 116) { if (c2 == 97) { if (len == 6) { return 1; } } } }   // static
        if (c0 == 115) { if (c1 == 116) { if (c2 == 114) { if (len == 6) { return 1; } } } }  // struct
        if (c0 == 110) { if (c1 == 97) { if (c2 == 109) { if (len == 9) { return 1; } } } }   // namespace
        if (c0 == 117) { if (c1 == 115) { if (c2 == 105) { if (len == 5) { return 1; } } } }  // using
        return 0;
    }
}

class Program {
    static void Main() {
        Console.WriteLine(8888); // self-host tokenizer start marker

        var cc = new CharClass();

        // Real source buffer: "class C { int x = 42 + y; }"
        var len = 27;
        var src = new int[27];
        src[0] = 99;
        src[1] = 108;
        src[2] = 97;
        src[3] = 115;
        src[4] = 115;
        src[5] = 32;
        src[6] = 67;
        src[7] = 32;
        src[8] = 123;
        src[9] = 32;
        src[10] = 105;
        src[11] = 110;
        src[12] = 116;
        src[13] = 32;
        src[14] = 120;
        src[15] = 32;
        src[16] = 61;
        src[17] = 32;
        src[18] = 52;
        src[19] = 50;
        src[20] = 32;
        src[21] = 43;
        src[22] = 32;
        src[23] = 121;
        src[24] = 59;
        src[25] = 32;
        src[26] = 125;

        var i = 0;
        var tokens = 0;
        var idents = 0;
        var keywords = 0;
        var numbers = 0;
        var operators = 0;

        while (i < len) {
            var c = src[i];

            if (cc.IsWhitespace(c) == 1) {
                i = i + 1;
            } else {
                if (cc.IsAlpha(c) == 1) {
                    var start = i;
                    while (i < len) {
                        if (cc.IsAlphaNum(src[i]) == 1) { i = i + 1; }
                        else { break; }
                    }
                    var wlen = i - start;
                    var k0 = src[start];
                    var k1 = 0;
                    var k2 = 0;
                    if (wlen > 1) { k1 = src[start + 1]; }
                    if (wlen > 2) { k2 = src[start + 2]; }
                    if (cc.IsKeyword(k0, k1, k2, wlen) == 1) { keywords = keywords + 1; }
                    else { idents = idents + 1; }
                    tokens = tokens + 1;
                } else {
                    if (cc.IsDigit(c) == 1) {
                        while (i < len) {
                            if (cc.IsDigit(src[i]) == 1) { i = i + 1; }
                            else { break; }
                        }
                        numbers = numbers + 1;
                        tokens = tokens + 1;
                    } else {
                        var c1 = 0;
                        if (i + 1 < len) { c1 = src[i + 1]; }
                        if (cc.IsDoubleOp(c, c1) == 1) { i = i + 2; }
                        else { i = i + 1; }
                        operators = operators + 1;
                        tokens = tokens + 1;
                    }
                }
            }
        }

        Console.WriteLine(tokens);    // 11
        Console.WriteLine(idents);    // 3
        Console.WriteLine(keywords);  // 2
        Console.WriteLine(numbers);   // 1
        Console.WriteLine(operators); // 5

        Console.WriteLine(7777); // end marker
    }
}
