// real Zan source: local integer arrays (alloc, element write, element read)
using System;

namespace Demo;

class Program {
    static void Main() {
        int[] a = new int[5];
        int i = 0;
        while (i < 5) {
            a[i] = i * i;
            i = i + 1;
        }
        int s = 0;
        int j = 0;
        while (j < 5) {
            s = s + a[j];
            j = j + 1;
        }
        Console.WriteLine("squares sum:");
        Console.WriteLine(s);
        Console.WriteLine(a[3]);
    }
}
