        c[65] = 105; // 'i'
        c[66] = 110; // 'n'
        c[67] = 116; // 't'
        c[68] = 32; // ' '
        c[69] = 101; // 'e'
        c[70] = 40; // '('
        c[71] = 55; // '7'
        c[72] = 41; // ')'
        c[73] = 59; // ';'
        Eval(c, 74);
        Console.WriteLine(700); // else stage end
    }
}
