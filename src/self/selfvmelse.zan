using System;

namespace ZanCompiler;

// Eleventh self-hosting stage: the arrays bytecode compiler + VM (stage 10)
// extended with `else` clauses on the embedded `if` statement. This completes
// two-way control flow in the self-hosted mini-language, compiled purely with
// the existing JZ/JMP opcodes and backpatching: JZ jumps over the then-block
// to the else-block, and an unconditional JMP at the end of the then-block
// skips the else-block. No new opcodes are needed.
//
// Opcodes:
//   0 HALT 1 PUSH 2 LOAD 3 STORE 4 ADD 5 SUB 6 MUL 7 DIV 8 PRINT
//   9 JMP 10 JZ 11 LT 12 GT 13 CALL 14 RET 15 MOD 16 EQ 17 NE
//   18 ALOAD 19 ASTORE
//
// Token kinds:
//   0 end 1 num 2 + 3 - 4 * 5 / 6 ( 7 ) 8 ident 9 = 10 ;
//   11 { 12 } 13 if 14 while 15 print 16 < 17 > 18 func 19 , 20 return
//   21 % 22 == 23 != 24 [ 25 ] 26 else
class Lexer {
    public int[] src;
    public int len;
    public int pos;

    public Lexer() { }

    void Init(int[] s, int n) { src = s; len = n; pos = 0; }

    int WordKind(int st, int wlen) {
        if (wlen == 2 && src[st] == 105 && src[st + 1] == 102) { return 13; }
        if (wlen == 5 && src[st] == 119 && src[st + 1] == 104 &&
            src[st + 2] == 105 && src[st + 3] == 108 && src[st + 4] == 101) { return 14; }
        if (wlen == 5 && src[st] == 112 && src[st + 1] == 114 &&
            src[st + 2] == 105 && src[st + 3] == 110 && src[st + 4] == 116) { return 15; }
        if (wlen == 4 && src[st] == 102 && src[st + 1] == 117 &&
            src[st + 2] == 110 && src[st + 3] == 99) { return 18; }
        if (wlen == 6 && src[st] == 114 && src[st + 1] == 101 && src[st + 2] == 116 &&
            src[st + 3] == 117 && src[st + 4] == 114 && src[st + 5] == 110) { return 20; }
        if (wlen == 4 && src[st] == 101 && src[st + 1] == 108 &&
            src[st + 2] == 115 && src[st + 3] == 101) { return 26; }
        return 8;
    }

    int Tokenize(int[] kinds, int[] vals) {
        var n = 0;
        while (pos < len) {
            var c = src[pos];
            if (c == 32) {
                pos = pos + 1;
            } else if (c >= 48 && c <= 57) {
                var v = 0;
                while (pos < len && src[pos] >= 48 && src[pos] <= 57) {
                    v = v * 10 + (src[pos] - 48);
                    pos = pos + 1;
                }
                kinds[n] = 1; vals[n] = v; n = n + 1;
            } else if (c >= 97 && c <= 122) {
                var st = pos;
                while (pos < len && src[pos] >= 97 && src[pos] <= 122) { pos = pos + 1; }
                var wlen = pos - st;
                var wk = WordKind(st, wlen);
                kinds[n] = wk;
                if (wk == 8) { vals[n] = src[st] - 97; }
                else { vals[n] = 0; }
                n = n + 1;
            } else {
                var k = 0;
                if (c == 43) { k = 2; }
                else if (c == 45) { k = 3; }
                else if (c == 42) { k = 4; }
                else if (c == 47) { k = 5; }
                else if (c == 40) { k = 6; }
                else if (c == 41) { k = 7; }
                else if (c == 61) {
                    if (pos + 1 < len && src[pos + 1] == 61) { k = 22; pos = pos + 1; }
                    else { k = 9; }
                }
                else if (c == 33) {
                    if (pos + 1 < len && src[pos + 1] == 61) { k = 23; pos = pos + 1; }
                    else { k = 0; }
                }
                else if (c == 59) { k = 10; }
                else if (c == 123) { k = 11; }
                else if (c == 125) { k = 12; }
                else if (c == 60) { k = 16; }
                else if (c == 62) { k = 17; }
                else if (c == 44) { k = 19; }
                else if (c == 37) { k = 21; }
                else if (c == 91) { k = 24; }
                else if (c == 93) { k = 25; }
                kinds[n] = k; vals[n] = 0; n = n + 1;
                pos = pos + 1;
            }
        }
        kinds[n] = 0; vals[n] = 0;
        return n;
    }
}

class Compiler {
    public int[] kinds;
    public int[] vals;
    public int n;
    public int pos;
    public int[] code;
    public int clen;
    public int[] funcAddr;

    public Compiler() { }

    void Init(int[] k, int[] v, int count, int[] buf, int[] fa) {
        kinds = k; vals = v; n = count; pos = 0; code = buf; clen = 0; funcAddr = fa;
    }

    int Kind() { if (pos < n) { return kinds[pos]; } return 0; }
    int PeekKind() { if (pos + 1 < n) { return kinds[pos + 1]; } return 0; }
    int Val() { if (pos < n) { return vals[pos]; } return 0; }
    void Next() { pos = pos + 1; }

    void Emit(int op) { code[clen] = op; clen = clen + 1; }

    void Factor() {
        if (Kind() == 6) {
            Next();
            Add();
            if (Kind() == 7) { Next(); }
        } else if (Kind() == 8) {
            if (PeekKind() == 6) {
                var f = Val();
                Next();
                Next();
                if (Kind() != 7) {
                    Cmp();
                    while (Kind() == 19) { Next(); Cmp(); }
                }
                if (Kind() == 7) { Next(); }
                Emit(13); Emit(funcAddr[f]);
            } else if (PeekKind() == 24) {
                var bs = Val();
                Next();
                Next();
                Emit(2); Emit(bs);
                Cmp();
                if (Kind() == 25) { Next(); }
                Emit(4);
                Emit(18);
            } else {
                var idx = Val();
                Next();
                Emit(2); Emit(idx);
            }
        } else {
            var x = Val();
            Next();
            Emit(1); Emit(x);
        }
    }

    void Term() {
        Factor();
        while (Kind() == 4 || Kind() == 5 || Kind() == 21) {
            var op = Kind();
            Next();
            Factor();
            if (op == 4) { Emit(6); }
            else if (op == 5) { Emit(7); }
            else { Emit(15); }
        }
    }

    void Add() {
        Term();
        while (Kind() == 2 || Kind() == 3) {
            var op = Kind();
            Next();
            Term();
            if (op == 2) { Emit(4); }
            else { Emit(5); }
        }
    }

    void Cmp() {
        Add();
        if (Kind() == 16) { Next(); Add(); Emit(11); }
        else if (Kind() == 17) { Next(); Add(); Emit(12); }
        else if (Kind() == 22) { Next(); Add(); Emit(16); }
        else if (Kind() == 23) { Next(); Add(); Emit(17); }
    }

    void Block() {
        if (Kind() == 11) { Next(); }
        while (Kind() != 12 && Kind() != 0) { Stmt(); }
        if (Kind() == 12) { Next(); }
    }

    void FuncDef() {
        Next();
        var f = Val();
        Next();
        var p0 = 0;
        var p1 = 0;
        var pc2 = 0;
        if (Kind() == 6) { Next(); }
        if (Kind() == 8) {
            p0 = Val(); Next(); pc2 = 1;
            if (Kind() == 19) { Next(); p1 = Val(); Next(); pc2 = 2; }
        }
        if (Kind() == 7) { Next(); }
        if (Kind() == 11) { Next(); }

        Emit(9); Emit(0);
        var skip = clen - 1;
        funcAddr[f] = clen;

        if (pc2 == 2) {
            Emit(3); Emit(p1);
            Emit(3); Emit(p0);
        } else if (pc2 == 1) {
            Emit(3); Emit(p0);
        }

        while (Kind() != 12 && Kind() != 0) { Stmt(); }
        if (Kind() == 12) { Next(); }

        Emit(1); Emit(0); Emit(14);
        code[skip] = clen;
    }

    void Stmt() {
        var kd = Kind();
        if (kd == 18) {
            FuncDef();
        } else if (kd == 20) {
            Next();
            Cmp();
            if (Kind() == 10) { Next(); }
            Emit(14);
        } else if (kd == 13) {
            Next();
            if (Kind() == 6) { Next(); }
            Cmp();
            if (Kind() == 7) { Next(); }
            Emit(10); Emit(0);
            var q = clen - 1;
            Block();
            if (Kind() == 26) {
                Emit(9); Emit(0);
                var j = clen - 1;
                code[q] = clen;
                Next();
                Block();
                code[j] = clen;
            } else {
                code[q] = clen;
            }
        } else if (kd == 14) {
            var loopStart = clen;
            Next();
            if (Kind() == 6) { Next(); }
            Cmp();
            if (Kind() == 7) { Next(); }
            Emit(10); Emit(0);
            var q = clen - 1;
            Block();
            Emit(9); Emit(loopStart);
            code[q] = clen;
        } else if (kd == 15) {
            Next();
            Cmp();
            if (Kind() == 10) { Next(); }
            Emit(8);
        } else if (kd == 8) {
            if (PeekKind() == 9) {
                var idx = Val();
                Next();
                Next();
                Cmp();
                Emit(3); Emit(idx);
                if (Kind() == 10) { Next(); }
            } else if (PeekKind() == 24) {
                var bs = Val();
                Next();
                Next();
                Emit(2); Emit(bs);
                Cmp();
                if (Kind() == 25) { Next(); }
                Emit(4);
                if (Kind() == 9) {
                    Next();
                    Cmp();
                    Emit(19);
                } else {
                    Emit(18);
                }
                if (Kind() == 10) { Next(); }
            } else {
                Cmp();
                if (Kind() == 10) { Next(); }
            }
        } else {
            Cmp();
            if (Kind() == 10) { Next(); }
        }
    }

    int Compile() {
        while (Kind() != 0) { Stmt(); }
        Emit(0);
        return clen;
    }
}

class VM {
    public int[] code;
    public int clen;
    public int[] stack;
    public int sp;
    public int[] locals;
    public int fp;
    public int[] retStack;
    public int[] fpStack;
    public int csp;
    public int pc;
    public int[] heap;

    public VM() { }

    void Init(int[] c, int len, int[] st, int[] lo, int[] rs, int[] fs, int[] hp) {
        code = c; clen = len; stack = st; sp = 0;
        locals = lo; fp = 0; retStack = rs; fpStack = fs; csp = 0; pc = 0; heap = hp;
    }

    void Run() {
        while (pc < clen) {
            var op = code[pc];
            pc = pc + 1;
            if (op == 0) { return; }
            else if (op == 1) { stack[sp] = code[pc]; pc = pc + 1; sp = sp + 1; }
            else if (op == 2) { stack[sp] = locals[fp + code[pc]]; pc = pc + 1; sp = sp + 1; }
            else if (op == 3) { sp = sp - 1; locals[fp + code[pc]] = stack[sp]; pc = pc + 1; }
            else if (op == 4) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a + b; }
            else if (op == 5) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a - b; }
            else if (op == 6) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a * b; }
            else if (op == 7) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a / b; }
            else if (op == 8) { sp = sp - 1; Console.WriteLine(stack[sp]); }
            else if (op == 9) { pc = code[pc]; }
            else if (op == 10) { var t = code[pc]; pc = pc + 1; sp = sp - 1; if (stack[sp] == 0) { pc = t; } }
            else if (op == 11) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; if (a < b) { stack[sp - 1] = 1; } else { stack[sp - 1] = 0; } }
            else if (op == 12) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; if (a > b) { stack[sp - 1] = 1; } else { stack[sp - 1] = 0; } }
            else if (op == 13) { var target = code[pc]; pc = pc + 1; retStack[csp] = pc; fpStack[csp] = fp; csp = csp + 1; fp = fp + 26; pc = target; }
            else if (op == 14) { csp = csp - 1; pc = retStack[csp]; fp = fpStack[csp]; }
            else if (op == 15) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a - a / b * b; }
            else if (op == 16) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; if (a == b) { stack[sp - 1] = 1; } else { stack[sp - 1] = 0; } }
            else if (op == 17) { var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; if (a != b) { stack[sp - 1] = 1; } else { stack[sp - 1] = 0; } }
            else if (op == 18) { stack[sp - 1] = heap[stack[sp - 1]]; }
            else if (op == 19) { sp = sp - 1; var val = stack[sp]; sp = sp - 1; var addr = stack[sp]; heap[addr] = val; }
        }
    }
}

class Program {
    static void Eval(int[] src, int len) {
        var lex = new Lexer();
        lex.Init(src, len);
        var kinds = new int[512];
        var vals = new int[512];
        var cnt = lex.Tokenize(kinds, vals);

        var code = new int[2048];
        var funcAddr = new int[26];
        var comp = new Compiler();
        comp.Init(kinds, vals, cnt, code, funcAddr);
        var clen = comp.Compile();

        var stack = new int[256];
        var locals = new int[2048];
        var retStack = new int[256];
        var fpStack = new int[256];
        var heap = new int[4096];
        var vm = new VM();
        vm.Init(code, clen, stack, locals, retStack, fpStack, heap);
        vm.Run();
    }

