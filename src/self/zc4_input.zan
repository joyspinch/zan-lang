using System;

namespace Demo;

class Program {
    static int add(int a, int b) {
        return a + b;
    }

    static void Main() {
        Console.WriteLine("hello from zan");
        Console.WriteLine(add(3, 4));
        int i = 0;
        while (i < 3) {
            Console.WriteLine("tick");
            i = i + 1;
        }
        Console.WriteLine("done");
    }
}
