using System;

// zc1.zan — a real Zan compiler (imperative integer subset), written in Zan,
// emitting real LLVM IR. Extends zc0 with:
//   * integer local variables:   int name = <expr>;
//   * assignment:                name = <expr>;
//   * variable references inside expressions
//   * control flow:              while (<cond>) { ... }   if (<cond>) { ... }
//   * comparisons in conditions: == != < <= > >=
//
// It reads src/self/zc1_input.zan, lexes it, parses the body of Main with a
// real recursive-descent parser, and emits LLVM IR (alloca/load/store for
// variables, icmp + conditional/unconditional br for control flow, printf for
// output). clang lowers the IR to a native exe whose output matches the same
// source compiled by the C zanc.
//
// Verified primitives only: File.ReadAllText, s[i] char indexing, int[]
// arrays passed to static methods (mutated in place), 1-element int[] cursors,
// Convert.ToString, Console.Write with \n / \" / \\ escapes.

namespace ZanSelfCompiler1;

class Program {
    static int MatchKw(string src, int start, int len, string kw) {
        int kl = kw.Length;
        if (kl != len) { return 0; }
        int k = 0;
        while (k < len) {
            if (src[start + k] != kw[k]) { return 0; }
            k = k + 1;
        }
        return 1;
    }

    static int SliceEq(string src, int a, int alen, int b, int blen) {
        if (alen != blen) { return 0; }
        int k = 0;
        while (k < alen) {
            if (src[a + k] != src[b + k]) { return 0; }
            k = k + 1;
        }
        return 1;
    }

    static int IsWord(string src, int[] kind, int[] av, int[] bv, int i, string w) {
        if (kind[i] != 1) { return 0; }
        return MatchKw(src, av[i], bv[i], w);
    }

    static int IsOp(int[] kind, int[] av, int i, int code) {
        if (kind[i] != 4) { return 0; }
        if (av[i] != code) { return 0; }
        return 1;
    }

    static int NextT(int[] tc) { tc[0] = tc[0] + 1; return tc[0]; }
    static int NextL(int[] lc) { lc[0] = lc[0] + 1; return lc[0]; }

    static int FindVar(string src, int[] vStart, int[] vLen, int[] vc, int start, int len) {
        int i = 0;
        while (i < vc[0]) {
            if (SliceEq(src, vStart[i], vLen[i], start, len) == 1) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    // ---- lexer ----
    static int Lex(string src, int[] kind, int[] av, int[] bv) {
        int n = src.Length;
        int i = 0;
        int nt = 0;
        while (i < n) {
            int c = src[i];

            int isWs = 0;
            if (c == 32) { isWs = 1; }
            if (c == 9) { isWs = 1; }
            if (c == 10) { isWs = 1; }
            if (c == 13) { isWs = 1; }

            int isDigit = 0;
            if (c >= 48) { if (c <= 57) { isDigit = 1; } }

            int isAlpha = 0;
            if (c >= 97) { if (c <= 122) { isAlpha = 1; } }
            if (c >= 65) { if (c <= 90) { isAlpha = 1; } }
            if (c == 95) { isAlpha = 1; }

            if (isWs == 1) {
                i = i + 1;
            } else if (c == 47) {
                int nx = 0;
                if (i + 1 < n) { nx = src[i + 1]; }
                if (nx == 47) {
                    int cont = 1;
                    while (cont == 1) {
                        if (i < n) {
                            if (src[i] == 10) { cont = 0; } else { i = i + 1; }
                        } else { cont = 0; }
                    }
                } else {
                    kind[nt] = 4; av[nt] = 47; bv[nt] = 0; nt = nt + 1; i = i + 1;
                }
            } else if (isDigit == 1) {
                int val = 0;
                int cont = 1;
                while (cont == 1) {
                    if (i < n) {
                        int d = src[i];
                        int ok = 0;
                        if (d >= 48) { if (d <= 57) { ok = 1; } }
                        if (ok == 1) { val = val * 10 + (d - 48); i = i + 1; }
                        else { cont = 0; }
                    } else { cont = 0; }
                }
                kind[nt] = 2; av[nt] = val; bv[nt] = 0; nt = nt + 1;
            } else if (isAlpha == 1) {
                int start = i;
                int cont = 1;
                while (cont == 1) {
                    if (i < n) {
                        int d = src[i];
                        int ok = 0;
                        if (d >= 97) { if (d <= 122) { ok = 1; } }
                        if (d >= 65) { if (d <= 90) { ok = 1; } }
                        if (d >= 48) { if (d <= 57) { ok = 1; } }
                        if (d == 95) { ok = 1; }
                        if (ok == 1) { i = i + 1; } else { cont = 0; }
                    } else { cont = 0; }
                }
                kind[nt] = 1; av[nt] = start; bv[nt] = i - start; nt = nt + 1;
            } else if (c == 34) {
                int start = i + 1;
                i = i + 1;
                int cont = 1;
                while (cont == 1) {
                    if (i < n) {
                        if (src[i] == 34) { cont = 0; } else { i = i + 1; }
                    } else { cont = 0; }
                }
                kind[nt] = 3; av[nt] = start; bv[nt] = i - start; i = i + 1; nt = nt + 1;
            } else {
                int nx = 0;
                if (i + 1 < n) { nx = src[i + 1]; }
                int code = c;
                int adv = 1;
                if (c == 61) {
                    if (nx == 61) { code = 1061; adv = 2; }
                    else if (nx == 62) { code = 1062; adv = 2; }
                } else if (c == 33) {
                    if (nx == 61) { code = 1033; adv = 2; }
                } else if (c == 60) {
                    if (nx == 61) { code = 1060; adv = 2; }
                } else if (c == 62) {
                    if (nx == 61) { code = 1063; adv = 2; }
                } else if (c == 38) {
                    if (nx == 38) { code = 1038; adv = 2; }
                } else if (c == 124) {
                    if (nx == 124) { code = 1124; adv = 2; }
                }
                kind[nt] = 4; av[nt] = code; bv[nt] = 0; nt = nt + 1; i = i + adv;
            }
        }
        return nt;
    }

    // ---- IR emit helpers ----
    static void EmitConst(int d, int val) {
        Console.Write("  %t"); Console.Write(Convert.ToString(d));
        Console.Write(" = add i64 0, "); Console.Write(Convert.ToString(val));
        Console.Write("\n");
    }
    static void EmitBin(int d, string op, int l, int r) {
        Console.Write("  %t"); Console.Write(Convert.ToString(d));
        Console.Write(" = "); Console.Write(op); Console.Write(" i64 %t");
        Console.Write(Convert.ToString(l)); Console.Write(", %t");
        Console.Write(Convert.ToString(r)); Console.Write("\n");
    }
    static void EmitICmp(int d, string pred, int l, int r) {
        Console.Write("  %t"); Console.Write(Convert.ToString(d));
        Console.Write(" = icmp "); Console.Write(pred); Console.Write(" i64 %t");
        Console.Write(Convert.ToString(l)); Console.Write(", %t");
        Console.Write(Convert.ToString(r)); Console.Write("\n");
    }
    static void EmitAlloca(int vIdx) {
        Console.Write("  %v"); Console.Write(Convert.ToString(vIdx));
        Console.Write(" = alloca i64\n");
    }
    static void EmitStore(int vIdx, int tmp) {
        Console.Write("  store i64 %t"); Console.Write(Convert.ToString(tmp));
        Console.Write(", ptr %v"); Console.Write(Convert.ToString(vIdx));
        Console.Write("\n");
    }
    static void EmitLoad(int d, int vIdx) {
        Console.Write("  %t"); Console.Write(Convert.ToString(d));
        Console.Write(" = load i64, ptr %v"); Console.Write(Convert.ToString(vIdx));
        Console.Write("\n");
    }
    static void EmitLabel(int n) {
        Console.Write("L"); Console.Write(Convert.ToString(n)); Console.Write(":\n");
    }
    static void EmitBr(int n) {
        Console.Write("  br label %L"); Console.Write(Convert.ToString(n)); Console.Write("\n");
    }
    static void EmitBrCond(int c, int t, int f) {
        Console.Write("  br i1 %t"); Console.Write(Convert.ToString(c));
        Console.Write(", label %L"); Console.Write(Convert.ToString(t));
        Console.Write(", label %L"); Console.Write(Convert.ToString(f));
        Console.Write("\n");
    }
    static void EmitPrint(int v) {
        Console.Write("  call i32 (ptr, ...) @printf(ptr @.fmt, i64 %t");
        Console.Write(Convert.ToString(v)); Console.Write(")\n");
    }
    static void Header() {
        Console.Write("declare i32 @printf(ptr, ...)\n");
        Console.Write("@.fmt = private unnamed_addr constant [6 x i8] c\"%lld\\0A\\00\"\n");
        Console.Write("define i32 @main() {\n");
        Console.Write("entry:\n");
    }
    static void Footer() {
        Console.Write("  ret i32 0\n");
        Console.Write("}\n");
    }

    // ---- expression parser (emits IR, returns temp id holding value) ----
    static int ParsePrimary(string src, int[] kind, int[] av, int[] bv,
                            int[] vStart, int[] vLen, int[] vc,
                            int[] pc, int[] tc, int[] lc) {
        int p = pc[0];
        if (kind[p] == 2) {
            pc[0] = p + 1;
            int d = NextT(tc);
            EmitConst(d, av[p]);
            return d;
        }
        if (kind[p] == 1) {
            pc[0] = p + 1;
            int idx = FindVar(src, vStart, vLen, vc, av[p], bv[p]);
            int d = NextT(tc);
            if (idx >= 0) { EmitLoad(d, idx); } else { EmitConst(d, 0); }
            return d;
        }
        if (kind[p] == 4) {
            if (av[p] == 40) {
                pc[0] = p + 1;
                int e = ParseExpr(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
                if (IsOp(kind, av, pc[0], 41) == 1) { pc[0] = pc[0] + 1; }
                return e;
            }
        }
        pc[0] = p + 1;
        int z = NextT(tc);
        EmitConst(z, 0);
        return z;
    }

    static int ParseMul(string src, int[] kind, int[] av, int[] bv,
                        int[] vStart, int[] vLen, int[] vc,
                        int[] pc, int[] tc, int[] lc) {
        int l = ParsePrimary(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
        int cont = 1;
        while (cont == 1) {
            int p = pc[0];
            int isM = 0;
            if (IsOp(kind, av, p, 42) == 1) { isM = 1; }
            if (IsOp(kind, av, p, 47) == 1) { isM = 1; }
            if (IsOp(kind, av, p, 37) == 1) { isM = 1; }
            if (isM == 1) {
                pc[0] = p + 1;
                int r = ParsePrimary(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
                int d = NextT(tc);
                if (av[p] == 42) { EmitBin(d, "mul", l, r); }
                else if (av[p] == 47) { EmitBin(d, "sdiv", l, r); }
                else { EmitBin(d, "srem", l, r); }
                l = d;
            } else { cont = 0; }
        }
        return l;
    }

    static int ParseAdd(string src, int[] kind, int[] av, int[] bv,
                        int[] vStart, int[] vLen, int[] vc,
                        int[] pc, int[] tc, int[] lc) {
        int l = ParseMul(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
        int cont = 1;
        while (cont == 1) {
            int p = pc[0];
            int isA = 0;
            if (IsOp(kind, av, p, 43) == 1) { isA = 1; }
            if (IsOp(kind, av, p, 45) == 1) { isA = 1; }
            if (isA == 1) {
                pc[0] = p + 1;
                int r = ParseMul(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
                int d = NextT(tc);
                if (av[p] == 43) { EmitBin(d, "add", l, r); }
                else { EmitBin(d, "sub", l, r); }
                l = d;
            } else { cont = 0; }
        }
        return l;
    }

    static int ParseExpr(string src, int[] kind, int[] av, int[] bv,
                         int[] vStart, int[] vLen, int[] vc,
                         int[] pc, int[] tc, int[] lc) {
        return ParseAdd(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
    }

    static int ParseCond(string src, int[] kind, int[] av, int[] bv,
                         int[] vStart, int[] vLen, int[] vc,
                         int[] pc, int[] tc, int[] lc) {
        int l = ParseExpr(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
        int p = pc[0];
        int op = 0;
        if (kind[p] == 4) { op = av[p]; }
        pc[0] = p + 1;
        int r = ParseExpr(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
        int d = NextT(tc);
        if (op == 1061) { EmitICmp(d, "eq", l, r); }
        else if (op == 1033) { EmitICmp(d, "ne", l, r); }
        else if (op == 60) { EmitICmp(d, "slt", l, r); }
        else if (op == 1060) { EmitICmp(d, "sle", l, r); }
        else if (op == 62) { EmitICmp(d, "sgt", l, r); }
        else if (op == 1063) { EmitICmp(d, "sge", l, r); }
        else { EmitICmp(d, "ne", l, r); }
        return d;
    }

    // ---- statement / block parser ----
    static void ParseStmt(string src, int[] kind, int[] av, int[] bv,
                          int[] vStart, int[] vLen, int[] vc,
                          int[] pc, int[] tc, int[] lc, int count) {
        int p = pc[0];

        if (IsWord(src, kind, av, bv, p, "int") == 1) {
            int idx = vc[0];
            vStart[idx] = av[p + 1];
            vLen[idx] = bv[p + 1];
            vc[0] = idx + 1;
            EmitAlloca(idx);
            pc[0] = p + 3; // skip: int name =
            int v = ParseExpr(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
            EmitStore(idx, v);
            if (IsOp(kind, av, pc[0], 59) == 1) { pc[0] = pc[0] + 1; }
        } else if (IsWord(src, kind, av, bv, p, "while") == 1) {
            int lcond = NextL(lc);
            int lbody = NextL(lc);
            int lend = NextL(lc);
            EmitBr(lcond);
            EmitLabel(lcond);
            pc[0] = p + 2; // skip: while (
            int c = ParseCond(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
            if (IsOp(kind, av, pc[0], 41) == 1) { pc[0] = pc[0] + 1; }
            EmitBrCond(c, lbody, lend);
            EmitLabel(lbody);
            if (IsOp(kind, av, pc[0], 123) == 1) { pc[0] = pc[0] + 1; }
            ParseBlock(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc, count);
            EmitBr(lcond);
            EmitLabel(lend);
        } else if (IsWord(src, kind, av, bv, p, "if") == 1) {
            int lthen = NextL(lc);
            int lend = NextL(lc);
            pc[0] = p + 2; // skip: if (
            int c = ParseCond(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
            if (IsOp(kind, av, pc[0], 41) == 1) { pc[0] = pc[0] + 1; }
            EmitBrCond(c, lthen, lend);
            EmitLabel(lthen);
            if (IsOp(kind, av, pc[0], 123) == 1) { pc[0] = pc[0] + 1; }
            ParseBlock(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc, count);
            EmitBr(lend);
            EmitLabel(lend);
        } else if (IsWord(src, kind, av, bv, p, "Console") == 1) {
            pc[0] = p + 4; // skip: Console . WriteLine (
            int v = ParseExpr(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
            EmitPrint(v);
            if (IsOp(kind, av, pc[0], 41) == 1) { pc[0] = pc[0] + 1; }
            if (IsOp(kind, av, pc[0], 59) == 1) { pc[0] = pc[0] + 1; }
        } else if (kind[p] == 1) {
            // assignment: name = expr ;
            if (IsOp(kind, av, p + 1, 61) == 1) {
                int idx = FindVar(src, vStart, vLen, vc, av[p], bv[p]);
                pc[0] = p + 2;
                int v = ParseExpr(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc);
                if (idx >= 0) { EmitStore(idx, v); }
                if (IsOp(kind, av, pc[0], 59) == 1) { pc[0] = pc[0] + 1; }
            } else {
                pc[0] = p + 1;
            }
        } else {
            pc[0] = p + 1;
        }
    }

    static void ParseBlock(string src, int[] kind, int[] av, int[] bv,
                           int[] vStart, int[] vLen, int[] vc,
                           int[] pc, int[] tc, int[] lc, int count) {
        int cont = 1;
        while (cont == 1) {
            int p = pc[0];
            if (p >= count) {
                cont = 0;
            } else if (IsOp(kind, av, p, 125) == 1) {
                pc[0] = p + 1; // consume '}'
                cont = 0;
            } else {
                ParseStmt(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc, count);
            }
        }
    }

    static void Main() {
        string src = File.ReadAllText("src/self/zc1_input.zan");
        int[] kind = new int[8192];
        int[] av = new int[8192];
        int[] bv = new int[8192];
        int count = Lex(src, kind, av, bv);

        int[] vStart = new int[1024];
        int[] vLen = new int[1024];
        int[] vc = new int[1];
        vc[0] = 0;
        int[] pc = new int[1];
        int[] tc = new int[1];
        tc[0] = 0;
        int[] lc = new int[1];
        lc[0] = 0;

        // locate `Main ( ) {`
        int p = 0;
        int found = 0;
        while (p < count) {
            if (found == 0) {
                if (IsWord(src, kind, av, bv, p, "Main") == 1) {
                    if (IsOp(kind, av, p + 1, 40) == 1) {
                        if (IsOp(kind, av, p + 2, 41) == 1) {
                            if (IsOp(kind, av, p + 3, 123) == 1) {
                                found = 1;
                                pc[0] = p + 4;
                            }
                        }
                    }
                }
            }
            p = p + 1;
        }

        Header();
        if (found == 1) {
            ParseBlock(src, kind, av, bv, vStart, vLen, vc, pc, tc, lc, count);
        }
        Footer();
    }
}
