// real Zan source with user-defined functions + recursion, compiled by zc2.zan
using System;

namespace Demo;

class Program {
    static int fib(int n) {
        if (n < 2) {
            return n;
        }
        return fib(n - 1) + fib(n - 2);
    }

    static int gcd(int a, int b) {
        while (b != 0) {
            int t = a % b;
            a = b;
            b = t;
        }
        return a;
    }

    static void Main() {
        Console.WriteLine(fib(10));
        Console.WriteLine(gcd(48, 36));
        int s = 0;
        int i = 0;
        while (i < 5) {
            s = s + fib(i);
            i = i + 1;
        }
        Console.WriteLine(s);
    }
}
