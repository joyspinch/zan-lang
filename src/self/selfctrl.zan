using System;

namespace ZanCompiler;

// Fifth self-hosting stage: a mini-language interpreter with control flow,
// written in Zan. Adds keywords (if/while/print), comparison operators and
// brace-delimited blocks on top of the variable-aware evaluator. `while` is
// implemented by rewinding the token cursor and re-evaluating the condition;
// untaken branches are skipped via brace matching. This is enough to run real
// iterative programs (e.g. factorial), exercising nested control flow,
// array-backed symbol tables and mutually-recursive precedence methods.
//
// Token kinds:
//   0 end   1 num    2 +   3 -   4 *   5 /   6 (   7 )
//   8 ident 9 =     10 ;  11 {  12 }  13 if 14 while 15 print
//   16 <    17 >
class Lexer {
    public int[] src;
    public int len;
    public int pos;

    public Lexer() { }

    void Init(int[] s, int n) {
        src = s;
        len = n;
        pos = 0;
    }

    int Tokenize(int[] kinds, int[] vals) {
        var n = 0;
        while (pos < len) {
            var c = src[pos];
            if (c == 32) {
                pos = pos + 1;
            } else if (c >= 48 && c <= 57) {          // number
                var v = 0;
                while (pos < len && src[pos] >= 48 && src[pos] <= 57) {
                    v = v * 10 + (src[pos] - 48);
                    pos = pos + 1;
                }
                kinds[n] = 1;
                vals[n] = v;
                n = n + 1;
            } else if (c >= 97 && c <= 122) {         // word: keyword or var
                var st = pos;
                while (pos < len && src[pos] >= 97 && src[pos] <= 122) {
                    pos = pos + 1;
                }
                var wlen = pos - st;
                if (wlen == 2 && src[st] == 105 && src[st + 1] == 102) {
                    kinds[n] = 13;                    // if
                    vals[n] = 0;
                } else if (wlen == 5 && src[st] == 119 && src[st + 1] == 104 &&
                           src[st + 2] == 105 && src[st + 3] == 108 && src[st + 4] == 101) {
                    kinds[n] = 14;                    // while
                    vals[n] = 0;
                } else if (wlen == 5 && src[st] == 112 && src[st + 1] == 114 &&
                           src[st + 2] == 105 && src[st + 3] == 110 && src[st + 4] == 116) {
                    kinds[n] = 15;                    // print
                    vals[n] = 0;
                } else {
                    kinds[n] = 8;                     // variable (first letter)
                    vals[n] = src[st] - 97;
                }
                n = n + 1;
            } else {                                  // operator / punctuation
                var k = 0;
                if (c == 43) { k = 2; }
                else if (c == 45) { k = 3; }
                else if (c == 42) { k = 4; }
                else if (c == 47) { k = 5; }
                else if (c == 40) { k = 6; }
                else if (c == 41) { k = 7; }
                else if (c == 61) { k = 9; }
                else if (c == 59) { k = 10; }
                else if (c == 123) { k = 11; }
                else if (c == 125) { k = 12; }
                else if (c == 60) { k = 16; }
                else if (c == 62) { k = 17; }
                kinds[n] = k;
                vals[n] = 0;
                n = n + 1;
                pos = pos + 1;
            }
        }
        kinds[n] = 0;
        vals[n] = 0;
        return n;
    }
}

class Interp {
    public int[] kinds;
    public int[] vals;
    public int n;
    public int pos;
    public int[] env;

    public Interp() { }

    void Init(int[] k, int[] v, int count, int[] e) {
        kinds = k;
        vals = v;
        n = count;
        pos = 0;
        env = e;
    }

    int Kind() {
        if (pos < n) { return kinds[pos]; }
        return 0;
    }

    int Val() {
        if (pos < n) { return vals[pos]; }
        return 0;
    }

    void Next() { pos = pos + 1; }

    // factor := number | ident | '(' add ')'
    int Factor() {
        if (Kind() == 6) {
            Next();
            var r = Add();
            if (Kind() == 7) { Next(); }
            return r;
        }
        if (Kind() == 8) {
            var idx = Val();
            Next();
            return env[idx];
        }
        var x = Val();
        Next();
        return x;
    }

    int Term() {
        var v = Factor();
        while (Kind() == 4 || Kind() == 5) {
            var op = Kind();
            Next();
            var r = Factor();
            if (op == 4) { v = v * r; }
            else { v = v / r; }
        }
        return v;
    }

    int Add() {
        var v = Term();
        while (Kind() == 2 || Kind() == 3) {
            var op = Kind();
            Next();
            var r = Term();
            if (op == 2) { v = v + r; }
            else { v = v - r; }
        }
        return v;
    }

    // cmp := add (('<' | '>') add)?
    int Cmp() {
        var v = Add();
        if (Kind() == 16) {
            Next();
            var r = Add();
            if (v < r) { return 1; }
            return 0;
        }
        if (Kind() == 17) {
            Next();
            var r = Add();
            if (v > r) { return 1; }
            return 0;
        }
        return v;
    }

    void ExecBlock() {
        if (Kind() == 11) { Next(); }
        while (Kind() != 12 && Kind() != 0) { Stmt(); }
        if (Kind() == 12) { Next(); }
    }

    void SkipBlock() {
        if (Kind() == 11) { Next(); }
        var depth = 1;
        while (depth > 0 && Kind() != 0) {
            if (Kind() == 11) { depth = depth + 1; }
            else if (Kind() == 12) { depth = depth - 1; }
            Next();
        }
    }

    void Stmt() {
        var kd = Kind();
        if (kd == 13) {                 // if (cond) { ... }
            Next();
            if (Kind() == 6) { Next(); }
            var c = Cmp();
            if (Kind() == 7) { Next(); }
            if (c != 0) { ExecBlock(); }
            else { SkipBlock(); }
        } else if (kd == 14) {          // while (cond) { ... }
            var start = pos;
            while (1 == 1) {
                pos = start;
                Next();
                if (Kind() == 6) { Next(); }
                var c = Cmp();
                if (Kind() == 7) { Next(); }
                if (c == 0) { SkipBlock(); return; }
                ExecBlock();
            }
        } else if (kd == 15) {          // print expr ;
            Next();
            var v = Cmp();
            if (Kind() == 10) { Next(); }
            Console.WriteLine(v);
        } else if (kd == 8) {           // ident = expr ;
            var idx = Val();
            Next();
            if (Kind() == 9) {
                Next();
                var v = Cmp();
                env[idx] = v;
            }
            if (Kind() == 10) { Next(); }
        } else {
            var v = Cmp();
            if (Kind() == 10) { Next(); }
        }
    }

    void Run() {
        while (Kind() != 0) { Stmt(); }
    }
}

class Program {
    static void Eval(int[] src, int len) {
        var lex = new Lexer();
        lex.Init(src, len);
        var kinds = new int[256];
        var vals = new int[256];
        var cnt = lex.Tokenize(kinds, vals);
        var env = new int[26];
        var ip = new Interp();
        ip.Init(kinds, vals, cnt, env);
        ip.Run();
    }

    static void Main() {
        Console.WriteLine(9999); // control-flow stage start

        // factorial(5) -> 120
        var a = new int[40];
        a[0] = 102; // 'f'
        a[1] = 61; // '='
        a[2] = 49; // '1'
