// real Zan source: class with fields, a constructor taking args, and a method
using System;

namespace Demo;

class Rect {
    public int w;
    public int h;
    public Rect(int a, int b) {
        w = a;
        h = b;
    }
    public int Area() { return w * h; }
}

class Program {
    static void Main() {
        var r = new Rect(10, 5);
        Console.WriteLine(r.Area());
        Console.WriteLine(r.w);
        Console.WriteLine(r.h);
    }
}
