// real Zan source: a class with int fields, object construction, field r/w
using System;

namespace Demo;

class Box {
    public int n;
    public int m;
}

class Program {
    static void Main() {
        var b = new Box();
        b.n = 42;
        b.m = 7;
        Console.WriteLine(b.n);
        Console.WriteLine(b.m);
        b.n = b.n + b.m;
        Console.WriteLine(b.n);
    }
}
