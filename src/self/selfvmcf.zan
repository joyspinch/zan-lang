using System;

namespace ZanCompiler;

// Seventh self-hosting stage: a bytecode compiler + stack VM WITH control
// flow, written in Zan. The compiler lowers if/while into jump instructions
// using backpatching (emit a placeholder jump target, then fill it in once the
// block's end address is known), and the VM implements JMP/JZ plus comparison
// opcodes. This is a genuine compiler backend: it can compile and run looping
// programs (e.g. factorial) as real bytecode rather than tree-walking.
//
// Opcodes:
//   0 HALT   1 PUSH n   2 LOAD idx   3 STORE idx
//   4 ADD    5 SUB      6 MUL        7 DIV        8 PRINT
//   9 JMP a  10 JZ a    11 LT        12 GT
//
// Token kinds:
//   0 end 1 num 2 + 3 - 4 * 5 / 6 ( 7 ) 8 ident 9 = 10 ;
//   11 { 12 } 13 if 14 while 15 print 16 < 17 >
class Lexer {
    public int[] src;
    public int len;
    public int pos;

    public Lexer() { }

    void Init(int[] s, int n) { src = s; len = n; pos = 0; }

    int Tokenize(int[] kinds, int[] vals) {
        var n = 0;
        while (pos < len) {
            var c = src[pos];
            if (c == 32) {
                pos = pos + 1;
            } else if (c >= 48 && c <= 57) {
                var v = 0;
                while (pos < len && src[pos] >= 48 && src[pos] <= 57) {
                    v = v * 10 + (src[pos] - 48);
                    pos = pos + 1;
                }
                kinds[n] = 1; vals[n] = v; n = n + 1;
            } else if (c >= 97 && c <= 122) {
                var st = pos;
                while (pos < len && src[pos] >= 97 && src[pos] <= 122) { pos = pos + 1; }
                var wlen = pos - st;
                if (wlen == 2 && src[st] == 105 && src[st + 1] == 102) {
                    kinds[n] = 13; vals[n] = 0;             // if
                } else if (wlen == 5 && src[st] == 119 && src[st + 1] == 104 &&
                           src[st + 2] == 105 && src[st + 3] == 108 && src[st + 4] == 101) {
                    kinds[n] = 14; vals[n] = 0;             // while
                } else if (wlen == 5 && src[st] == 112 && src[st + 1] == 114 &&
                           src[st + 2] == 105 && src[st + 3] == 110 && src[st + 4] == 116) {
                    kinds[n] = 15; vals[n] = 0;             // print
                } else {
                    kinds[n] = 8; vals[n] = src[st] - 97;
                }
                n = n + 1;
            } else {
                var k = 0;
                if (c == 43) { k = 2; }
                else if (c == 45) { k = 3; }
                else if (c == 42) { k = 4; }
                else if (c == 47) { k = 5; }
                else if (c == 40) { k = 6; }
                else if (c == 41) { k = 7; }
                else if (c == 61) { k = 9; }
                else if (c == 59) { k = 10; }
                else if (c == 123) { k = 11; }
                else if (c == 125) { k = 12; }
                else if (c == 60) { k = 16; }
                else if (c == 62) { k = 17; }
                kinds[n] = k; vals[n] = 0; n = n + 1;
                pos = pos + 1;
            }
        }
        kinds[n] = 0; vals[n] = 0;
        return n;
    }
}

class Compiler {
    public int[] kinds;
    public int[] vals;
    public int n;
    public int pos;
    public int[] code;
    public int clen;

    public Compiler() { }

    void Init(int[] k, int[] v, int count, int[] buf) {
        kinds = k; vals = v; n = count; pos = 0; code = buf; clen = 0;
    }

    int Kind() { if (pos < n) { return kinds[pos]; } return 0; }
    int Val() { if (pos < n) { return vals[pos]; } return 0; }
    void Next() { pos = pos + 1; }

    void Emit(int op) { code[clen] = op; clen = clen + 1; }

    // factor := number | ident | '(' add ')'
    void Factor() {
        if (Kind() == 6) {
            Next();
            Add();
            if (Kind() == 7) { Next(); }
        } else if (Kind() == 8) {
            var idx = Val();
            Next();
            Emit(2); Emit(idx);         // LOAD
        } else {
            var x = Val();
            Next();
            Emit(1); Emit(x);           // PUSH
        }
    }

    void Term() {
        Factor();
        while (Kind() == 4 || Kind() == 5) {
            var op = Kind();
            Next();
            Factor();
            if (op == 4) { Emit(6); }   // MUL
            else { Emit(7); }           // DIV
        }
    }

    void Add() {
        Term();
        while (Kind() == 2 || Kind() == 3) {
            var op = Kind();
            Next();
            Term();
            if (op == 2) { Emit(4); }   // ADD
            else { Emit(5); }           // SUB
        }
    }

    // cmp := add (('<' | '>') add)?
    void Cmp() {
        Add();
        if (Kind() == 16) {
            Next();
            Add();
            Emit(11);                   // LT
        } else if (Kind() == 17) {
            Next();
            Add();
            Emit(12);                   // GT
        }
    }

    void Block() {
        if (Kind() == 11) { Next(); }
        while (Kind() != 12 && Kind() != 0) { Stmt(); }
        if (Kind() == 12) { Next(); }
    }

    void Stmt() {
        var kd = Kind();
        if (kd == 13) {                 // if (cmp) { block }
            Next();
            if (Kind() == 6) { Next(); }
            Cmp();
            if (Kind() == 7) { Next(); }
            Emit(10); Emit(0);          // JZ placeholder
            var p1 = clen - 1;
            Block();
            code[p1] = clen;            // backpatch exit target
        } else if (kd == 14) {          // while (cmp) { block }
            var loopStart = clen;
            Next();
            if (Kind() == 6) { Next(); }
            Cmp();
            if (Kind() == 7) { Next(); }
            Emit(10); Emit(0);          // JZ placeholder
            var p1 = clen - 1;
            Block();
            Emit(9); Emit(loopStart);   // JMP back to condition
            code[p1] = clen;            // backpatch loop exit
        } else if (kd == 15) {          // print cmp ;
            Next();
            Cmp();
            if (Kind() == 10) { Next(); }
            Emit(8);                    // PRINT
        } else if (kd == 8) {           // ident = cmp ;
            var idx = Val();
            Next();
            if (Kind() == 9) {
                Next();
                Cmp();
                Emit(3); Emit(idx);     // STORE
            }
            if (Kind() == 10) { Next(); }
        } else {
            Cmp();
            if (Kind() == 10) { Next(); }
        }
    }

    int Compile() {
        while (Kind() != 0) { Stmt(); }
        Emit(0);                        // HALT
        return clen;
    }
}

class VM {
    public int[] code;
    public int clen;
    public int[] stack;
    public int sp;
    public int[] env;
    public int pc;

    public VM() { }

    void Init(int[] c, int len, int[] st, int[] e) {
        code = c; clen = len; stack = st; sp = 0; env = e; pc = 0;
    }

    void Run() {
        while (pc < clen) {
            var op = code[pc];
            pc = pc + 1;
            if (op == 0) { return; }                 // HALT
            else if (op == 1) {                      // PUSH n
                stack[sp] = code[pc]; pc = pc + 1; sp = sp + 1;
            } else if (op == 2) {                    // LOAD idx
                stack[sp] = env[code[pc]]; pc = pc + 1; sp = sp + 1;
            } else if (op == 3) {                    // STORE idx
                sp = sp - 1; env[code[pc]] = stack[sp]; pc = pc + 1;
            } else if (op == 4) {                    // ADD
                var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a + b;
            } else if (op == 5) {                    // SUB
                var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a - b;
            } else if (op == 6) {                    // MUL
                var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a * b;
            } else if (op == 7) {                    // DIV
                var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1; stack[sp - 1] = a / b;
            } else if (op == 8) {                    // PRINT
                sp = sp - 1; Console.WriteLine(stack[sp]);
            } else if (op == 9) {                    // JMP a
                pc = code[pc];
            } else if (op == 10) {                   // JZ a
                var t = code[pc]; pc = pc + 1; sp = sp - 1;
                if (stack[sp] == 0) { pc = t; }
            } else if (op == 11) {                   // LT
                var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1;
                if (a < b) { stack[sp - 1] = 1; } else { stack[sp - 1] = 0; }
            } else if (op == 12) {                   // GT
                var b = stack[sp - 1]; var a = stack[sp - 2]; sp = sp - 1;
                if (a > b) { stack[sp - 1] = 1; } else { stack[sp - 1] = 0; }
            }
        }
    }
}

class Program {
    static void Eval(int[] src, int len) {
        var lex = new Lexer();
        lex.Init(src, len);
        var kinds = new int[256];
        var vals = new int[256];
        var cnt = lex.Tokenize(kinds, vals);

        var code = new int[1024];
        var comp = new Compiler();
        comp.Init(kinds, vals, cnt, code);
        var clen = comp.Compile();

        var env = new int[26];
        var stack = new int[128];
        var vm = new VM();
        vm.Init(code, clen, stack, env);
        vm.Run();
    }

    static void Main() {
        Console.WriteLine(5000); // bytecode control-flow stage start

        // factorial(5) compiled to bytecode -> 120
        var a = new int[40];
        a[0] = 102; // 'f'
