        a[21] = 102; // 'f'
        a[22] = 42; // '*'
        a[23] = 105; // 'i'
        a[24] = 59; // ';'
        a[25] = 105; // 'i'
        a[26] = 61; // '='
        a[27] = 105; // 'i'
        a[28] = 43; // '+'
        a[29] = 49; // '1'
        a[30] = 59; // ';'
        a[31] = 125; // '}'
        a[32] = 112; // 'p'
        a[33] = 114; // 'r'
        a[34] = 105; // 'i'
        a[35] = 110; // 'n'
        a[36] = 116; // 't'
        a[37] = 32; // ' '
        a[38] = 102; // 'f'
        a[39] = 59; // ';'
        Eval(a, 40);

        // sum 1..10 -> 55
        var b = new int[41];
        b[0] = 115; // 's'
        b[1] = 61; // '='
