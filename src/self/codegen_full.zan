using System;

namespace ZanCompiler;

class IREmitter {
    public int TempCount;
    public int LabelCount;
    public int GlobalCount;
    public int FuncCount;
    public int InstrCount;

    public IREmitter() {
        TempCount = 0;
        LabelCount = 0;
        GlobalCount = 0;
        FuncCount = 0;
        InstrCount = 0;
    }

    int NextTemp() {
        TempCount = TempCount + 1;
        return TempCount;
    }

    int NextLabel() {
        var l = LabelCount;
        LabelCount = LabelCount + 1;
        return l;
    }

    int NextGlobal() {
        var g = GlobalCount;
        GlobalCount = GlobalCount + 1;
        return g;
    }

    int BeginFunc(int paramCount) {
        var f = FuncCount;
        FuncCount = FuncCount + 1;
        return f;
    }

    int Emit(int opcode) {
        InstrCount = InstrCount + 1;
        return InstrCount;
    }

    // Map Zan types to LLVM IR type codes
    int MapLLVMType(int zanType) {
        // 1=int -> i64, 2=bool -> i1, 3=string -> ptr, 4=void
        if (zanType == 1) { return 64; }
        if (zanType == 2) { return 1; }
        if (zanType == 3) { return 8; }
        if (zanType == 4) { return 0; }
        return 8;
    }

    // Map binary operator to LLVM instruction
    int MapLLVMOp(int zanOp) {
        if (zanOp == 100) { return 1; }
        if (zanOp == 101) { return 2; }
        if (zanOp == 102) { return 3; }
        if (zanOp == 103) { return 4; }
        if (zanOp == 104) { return 5; }
        if (zanOp == 106) { return 32; }
        if (zanOp == 107) { return 33; }
        if (zanOp == 108) { return 40; }
        if (zanOp == 109) { return 41; }
        if (zanOp == 110) { return 38; }
        if (zanOp == 111) { return 39; }
        return 0;
    }

    int IsCompareOp(int zanOp) {
        if (zanOp >= 106) {
            if (zanOp <= 111) { return 1; }
        }
        return 0;
    }

    int IsArithOp(int zanOp) {
        if (zanOp >= 100) {
            if (zanOp <= 104) { return 1; }
        }
        return 0;
    }
}

class FunctionIR {
    public int ParamCount;
    public int LocalCount;
    public int BlockCount;
    public int RetType;
    public int HasAlloca;

    public FunctionIR(int params, int retType) {
        ParamCount = params;
        LocalCount = 0;
        BlockCount = 1;
        RetType = retType;
        HasAlloca = 0;
    }

    int AddLocal(int typeId) {
        var idx = LocalCount;
        LocalCount = LocalCount + 1;
        HasAlloca = 1;
        return idx;
    }

    int NewBlock() {
        var b = BlockCount;
        BlockCount = BlockCount + 1;
        return b;
    }

    int GetSlotOffset(int index) {
        return (ParamCount + index) * 8;
    }

    int TotalSlots() {
        return ParamCount + LocalCount;
    }

    int NeedsReturn() {
        if (RetType != 4) { return 1; }
        return 0;
    }
}

class StructIR {
    public int FieldCount;
    public int TotalSize;
    public int Align;
    public int HasVtable;
    public int HasRefFields;

    public StructIR(int fields, int align) {
        FieldCount = fields;
        TotalSize = fields * align;
        Align = align;
        HasVtable = 0;
        HasRefFields = 0;
    }

    int GetOffset(int fieldIdx) {
        var offset = fieldIdx * Align;
        if (HasVtable == 1) {
            offset = offset + 8;
        }
        return offset;
    }

    int EnableVtable() {
        HasVtable = 1;
        TotalSize = TotalSize + 8;
        return TotalSize;
    }

    int MarkRefField() {
        HasRefFields = 1;
        return 1;
    }

    int GetAllocSize() {
        if (HasVtable == 1) {
            return TotalSize + 16;
        }
        return TotalSize + 8;
    }
}

class ModuleIR {
    public int FuncCount;
    public int GlobalCount;
    public int StringCount;
    public int StructCount;
    public int ExternCount;

    public ModuleIR() {
        FuncCount = 0;
        GlobalCount = 0;
        StringCount = 0;
        StructCount = 0;
        ExternCount = 0;
    }

    int AddFunction() {
        var f = FuncCount;
        FuncCount = FuncCount + 1;
        return f;
    }

    int AddGlobal() {
        var g = GlobalCount;
        GlobalCount = GlobalCount + 1;
        return g;
    }

    int AddString() {
        var s = StringCount;
        StringCount = StringCount + 1;
        return s;
    }

    int AddStruct() {
        var s = StructCount;
        StructCount = StructCount + 1;
        return s;
    }

    int AddExtern() {
        var e = ExternCount;
        ExternCount = ExternCount + 1;
        return e;
    }

    int TotalEntities() {
        return FuncCount + GlobalCount + StringCount + StructCount + ExternCount;
    }
}

class Program {
    static void Main() {
        // IREmitter tests
        var ir = new IREmitter();
        Console.WriteLine(ir.NextTemp());      // 1
        Console.WriteLine(ir.NextTemp());      // 2
        Console.WriteLine(ir.NextLabel());     // 0
        Console.WriteLine(ir.NextLabel());     // 1
        Console.WriteLine(ir.BeginFunc(2));    // 0
        Console.WriteLine(ir.BeginFunc(1));    // 1
        Console.WriteLine(ir.MapLLVMType(1));  // 64 (i64)
        Console.WriteLine(ir.MapLLVMType(2));  // 1 (i1)
        Console.WriteLine(ir.MapLLVMType(4));  // 0 (void)
        Console.WriteLine(ir.MapLLVMOp(100));  // 1 (add)
        Console.WriteLine(ir.MapLLVMOp(102));  // 3 (mul)
        Console.WriteLine(ir.MapLLVMOp(106));  // 32 (eq)
        Console.WriteLine(ir.IsCompareOp(106)); // 1
        Console.WriteLine(ir.IsCompareOp(100)); // 0
        Console.WriteLine(ir.IsArithOp(100));   // 1
        Console.WriteLine(ir.IsArithOp(106));   // 0

        // FunctionIR tests
        var fn = new FunctionIR(3, 1);
        Console.WriteLine(fn.AddLocal(1));     // 0
        Console.WriteLine(fn.AddLocal(1));     // 1
        Console.WriteLine(fn.HasAlloca);       // 1
        Console.WriteLine(fn.NewBlock());      // 1
        Console.WriteLine(fn.GetSlotOffset(0)); // 24
        Console.WriteLine(fn.TotalSlots());    // 5
        Console.WriteLine(fn.NeedsReturn());   // 1

        var vfn = new FunctionIR(0, 4);
        Console.WriteLine(vfn.NeedsReturn());  // 0

        // StructIR tests
        var si = new StructIR(4, 8);
        Console.WriteLine(si.TotalSize);       // 32
        Console.WriteLine(si.GetOffset(0));    // 0
        Console.WriteLine(si.GetOffset(2));    // 16
        Console.WriteLine(si.EnableVtable());  // 40
        Console.WriteLine(si.GetOffset(0));    // 8 (vtable shifts)
        Console.WriteLine(si.GetAllocSize());  // 56

        // ModuleIR tests
        var mod = new ModuleIR();
        Console.WriteLine(mod.AddFunction());  // 0
        Console.WriteLine(mod.AddFunction());  // 1
        Console.WriteLine(mod.AddString());    // 0
        Console.WriteLine(mod.AddStruct());    // 0
        Console.WriteLine(mod.AddExtern());    // 0
        Console.WriteLine(mod.TotalEntities()); // 5

        Console.WriteLine(9999);  // end marker
    }
}
