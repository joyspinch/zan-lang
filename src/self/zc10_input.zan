using System;
namespace Demo;
class Rect {
    public int w;
    public int h;
    public int Show() {
        Console.WriteLine(w);
        Console.WriteLine(h);
        return 0;
    }
}
class Program {
    static void Fill(int[] a, int n) {
        int i = 0;
        while (i < n) { a[i] = i * i; i = i + 1; }
    }
    static int SumArr(int[] a, int n) {
        int s = 0; int i = 0;
        while (i < n) { s = s + a[i]; i = i + 1; }
        return s;
    }
    static void Main() {
        int[] b = new int[5];
        Fill(b, 5);
        Console.WriteLine(SumArr(b, 5));
        var r = new Rect();
        r.w = 6;
        r.h = 7;
        r.Show();
    }
}
