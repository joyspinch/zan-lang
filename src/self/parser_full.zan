using System;

namespace ZanCompiler;

class AstBuilder {
    public int NodeCount;
    public int MaxDepth;
    public int CurrentDepth;
    public int ErrorCount;

    public AstBuilder() {
        NodeCount = 0;
        MaxDepth = 0;
        CurrentDepth = 0;
        ErrorCount = 0;
    }

    int CreateNode(int kind, int line) {
        var idx = NodeCount;
        NodeCount = NodeCount + 1;
        return idx;
    }

    int PushScope() {
        CurrentDepth = CurrentDepth + 1;
        if (CurrentDepth > MaxDepth) {
            MaxDepth = CurrentDepth;
        }
        return CurrentDepth;
    }

    int PopScope() {
        CurrentDepth = CurrentDepth - 1;
        return CurrentDepth;
    }

    int ReportError(int code, int line) {
        ErrorCount = ErrorCount + 1;
        return ErrorCount;
    }
}

class FullParser {
    public int TokenPos;
    public int TokenCount;
    public int NodeCount;
    public int ErrorCount;
    public int CurrentLine;

    public FullParser(int tokenCount) {
        TokenPos = 0;
        TokenCount = tokenCount;
        NodeCount = 0;
        ErrorCount = 0;
        CurrentLine = 1;
    }

    int Peek(int offset) {
        var idx = TokenPos + offset;
        if (idx >= TokenCount) { return 300; }
        return idx;
    }

    int Advance() {
        TokenPos = TokenPos + 1;
        return TokenPos;
    }

    int Expect(int expectedKind, int actualKind) {
        if (expectedKind == actualKind) {
            TokenPos = TokenPos + 1;
            return 1;
        }
        ErrorCount = ErrorCount + 1;
        return 0;
    }

    int AtEnd() {
        if (TokenPos >= TokenCount) { return 1; }
        return 0;
    }

    int CreateNode(int kind) {
        var idx = NodeCount;
        NodeCount = NodeCount + 1;
        return idx;
    }

    // Precedence table for operators
    int GetPrecedence(int tokenKind) {
        // || 
        if (tokenKind == 113) { return 1; }
        // &&
        if (tokenKind == 112) { return 2; }
        // == !=
        if (tokenKind == 106) { return 3; }
        if (tokenKind == 107) { return 3; }
        // < <= > >=
        if (tokenKind == 108) { return 4; }
        if (tokenKind == 109) { return 4; }
        if (tokenKind == 110) { return 4; }
        if (tokenKind == 111) { return 4; }
        // + -
        if (tokenKind == 100) { return 5; }
        if (tokenKind == 101) { return 5; }
        // * / %
        if (tokenKind == 102) { return 6; }
        if (tokenKind == 103) { return 6; }
        if (tokenKind == 104) { return 6; }
        return 0;
    }

    int IsBinaryOp(int tokenKind) {
        if (tokenKind >= 100) {
            if (tokenKind <= 113) { return 1; }
        }
        return 0;
    }

    int IsAssignment(int tokenKind) {
        if (tokenKind == 105) { return 1; }
        return 0;
    }

    int IsTypeKeyword(int tokenKind) {
        if (tokenKind == 25) { return 1; }
        if (tokenKind == 26) { return 1; }
        if (tokenKind == 27) { return 1; }
        if (tokenKind == 24) { return 1; }
        return 0;
    }

    int IsDeclarationStart(int tokenKind) {
        // class, struct, interface, enum, using, namespace
        if (tokenKind == 20) { return 1; }
        if (tokenKind == 21) { return 1; }
        if (tokenKind == 22) { return 1; }
        if (tokenKind == 23) { return 1; }
        if (tokenKind == 45) { return 1; }
        if (tokenKind == 46) { return 1; }
        if (tokenKind == 40) { return 1; }
        if (tokenKind == 41) { return 1; }
        return 0;
    }

    int IsStatementStart(int tokenKind) {
        // if, while, for, return, break, continue, var
        if (tokenKind == 29) { return 1; }
        if (tokenKind == 31) { return 1; }
        if (tokenKind == 32) { return 1; }
        if (tokenKind == 33) { return 1; }
        if (tokenKind == 34) { return 1; }
        if (tokenKind == 35) { return 1; }
        if (tokenKind == 28) { return 1; }
        return 0;
    }

    // Parse a primary expression (literals, identifiers, parens)
    int ParsePrimary(int tokenKind) {
        // Integer literal
        if (tokenKind == 0) {
            Advance();
            return CreateNode(50);
        }
        // String literal
        if (tokenKind == 1) {
            Advance();
            return CreateNode(51);
        }
        // Identifier
        if (tokenKind == 10) {
            Advance();
            return CreateNode(52);
        }
        // true/false
        if (tokenKind == 38) {
            Advance();
            return CreateNode(53);
        }
        if (tokenKind == 39) {
            Advance();
            return CreateNode(53);
        }
        // ( expr )
        if (tokenKind == 200) {
            Advance();
            var inner = CreateNode(54);
            return inner;
        }
        // new
        if (tokenKind == 36) {
            Advance();
            return CreateNode(55);
        }
        ErrorCount = ErrorCount + 1;
        return CreateNode(99);
    }

    // Parse binary expression with precedence climbing
    int ParseBinary(int minPrec, int leftKind) {
        var left = ParsePrimary(leftKind);
        return left;
    }
}

class Program {
    static void Main() {
        // AstBuilder tests
        var ast = new AstBuilder();
        Console.WriteLine(ast.CreateNode(1, 1));   // 0
        Console.WriteLine(ast.CreateNode(2, 2));   // 1
        Console.WriteLine(ast.NodeCount);          // 2
        Console.WriteLine(ast.PushScope());        // 1
        Console.WriteLine(ast.PushScope());        // 2
        Console.WriteLine(ast.MaxDepth);           // 2
        Console.WriteLine(ast.PopScope());         // 1

        // FullParser tests
        var p = new FullParser(50);
        Console.WriteLine(p.TokenCount);           // 50
        Console.WriteLine(p.Peek(0));              // 0
        Console.WriteLine(p.Peek(100));            // 300 (EOF)
        Console.WriteLine(p.Advance());            // 1
        Console.WriteLine(p.Expect(20, 20));       // 1 (match)
        Console.WriteLine(p.TokenPos);             // 2
        Console.WriteLine(p.Expect(20, 10));       // 0 (mismatch)
        Console.WriteLine(p.ErrorCount);           // 1

        // Precedence tests
        Console.WriteLine(p.GetPrecedence(100));   // 5 (+)
        Console.WriteLine(p.GetPrecedence(102));   // 6 (*)
        Console.WriteLine(p.GetPrecedence(106));   // 3 (==)
        Console.WriteLine(p.GetPrecedence(112));   // 2 (&&)
        Console.WriteLine(p.GetPrecedence(113));   // 1 (||)
        Console.WriteLine(p.GetPrecedence(200));   // 0 (not op)

        // Classification tests
        Console.WriteLine(p.IsBinaryOp(100));      // 1
        Console.WriteLine(p.IsBinaryOp(200));      // 0
        Console.WriteLine(p.IsAssignment(105));    // 1
        Console.WriteLine(p.IsTypeKeyword(25));    // 1
        Console.WriteLine(p.IsDeclarationStart(20)); // 1 (class)
        Console.WriteLine(p.IsStatementStart(29));   // 1 (if)
        Console.WriteLine(p.IsStatementStart(20));   // 0 (class not stmt)

        // ParsePrimary tests
        Console.WriteLine(p.ParsePrimary(0));      // 2 (int literal -> node)
        Console.WriteLine(p.ParsePrimary(10));     // 3 (identifier -> node)
        Console.WriteLine(p.ParsePrimary(36));     // 4 (new -> node)
        Console.WriteLine(p.NodeCount);            // 5

        Console.WriteLine(9999);  // end marker
    }
}
