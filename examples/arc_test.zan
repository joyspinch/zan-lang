using System;

namespace ARCTest;

class Counter {
    public int Value;
    
    public Counter(int val) {
        Value = val;
    }
    
    int Increment() {
        Value = Value + 1;
        return Value;
    }
}

class Program {
    static void Main() {
        var c = new Counter(10);
        Console.WriteLine(c.Value);    // 10
        var v = c.Increment();
        Console.WriteLine(v);          // 11
        Console.WriteLine(c.Value);    // 11
    }
}
