using System;
using System.IO;

namespace MyApp;

class Program {
    static void Main() {
        FileOps.WriteAllText("build/test_real.txt", "Written by Zan stdlib!");
        string content = FileOps.ReadAllText("build/test_real.txt");
        Console.WriteLine(content);

        if (FileOps.Exists("build/test_real.txt")) {
            Console.WriteLine("File exists!");
        }

        FileOps.AppendAllText("build/test_real.txt", " More content.");
        string content2 = FileOps.ReadAllText("build/test_real.txt");
        Console.WriteLine(content2);

        FileOps.Delete("build/test_real.txt");
        if (!FileOps.Exists("build/test_real.txt")) {
            Console.WriteLine("File deleted!");
        }

        Console.WriteLine("Stdlib test passed!");
    }
}
