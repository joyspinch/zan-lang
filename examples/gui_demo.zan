                Chart.Bar(app, x, cy, chW, chH, "Monthly Revenue vs Cost", chLabels, chSeries);
                Chart.StackedBar(app, col2, cy, chW, chH, "Monthly Revenue vs Cost", chLabels, chSeries);
                cy = cy + chH + t.gapLarge;

                Label.Small(app, x, cy, "HORIZONTAL BAR");
