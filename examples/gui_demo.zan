                cy = cy + capGap;
                Chart.Line(app, x, cy, chW, chH, "Monthly Revenue vs Cost", chLabels, chSeries);
                Chart.Area(app, col2, cy, chW, chH, "Monthly Revenue vs Cost", chLabels, chSeries);
