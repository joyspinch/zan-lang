                List<int> scX = new List<int>();
                List<int> scY = new List<int>();
                scX.Add(10); scX.Add(25); scX.Add(40); scX.Add(55); scX.Add(70); scX.Add(85); scX.Add(95);
                scY.Add(30); scY.Add(80); scY.Add(55); scY.Add(120); scY.Add(90); scY.Add(160); scY.Add(140);
                Chart.Scatter(app, col2, cy, chW, chH, "Correlation", scX, scY, Chart.Palette(t, 4));
                cy = cy + chH + t.gapLarge;

                // pie & donut share a categorical breakdown
                List<string> pNames = new List<string>();
                pNames.Add("Search"); pNames.Add("Direct"); pNames.Add("Email");
                pNames.Add("Social"); pNames.Add("Ads");
                List<int> pVals = new List<int>();
                pVals.Add(1048); pVals.Add(735); pVals.Add(580); pVals.Add(484); pVals.Add(300);

                Label.Small(app, x, cy, "PIE");
                Label.Small(app, col2, cy, "DONUT");
                cy = cy + capGap;
                Chart.Pie(app, x, cy, chW, chH, "Traffic Sources", pNames, pVals);
                Chart.Donut(app, col2, cy, chW, chH, "Traffic Sources", pNames, pVals);
                cy = cy + chH + rowGap;
            }

            int consumed = (cy + app.scrollY) - top + pad;
            app.SetContentHeight(consumed);

            // ---- Content scrollbar (draggable) ----
            int viewH = H - top;
            if (consumed > viewH) {
                int trackTop = top;
                int maxScroll = consumed - viewH;
                if (maxScroll < 1) { maxScroll = 1; }
                int thumbH = viewH * viewH / consumed;
                if (thumbH < app.Scale(36)) { thumbH = app.Scale(36); }
                int denom = viewH - thumbH;
                if (denom < 1) { denom = 1; }

                int sbId = app.focus.AllocId();
                if (app.focus.IsPressed(sbId)) {
                    int ns = (app.mouseY - trackTop - thumbH / 2) * maxScroll / denom;
                    if (ns < 0) { ns = 0; }
                    if (ns > maxScroll) { ns = maxScroll; }
                    app.scrollY = ns;
                    app.RequestRedraw();
                }
                int thumbY = trackTop + denom * app.scrollY / maxScroll;
                int scrollW = app.Scale(6);
                int thumbColor = t.scrollbar;
                if (app.focus.IsHovered(sbId) || app.focus.IsPressed(sbId)) { thumbColor = t.scrollbarHover; }
                c.FillRoundRect(W - scrollW - app.Scale(4), thumbY, scrollW, thumbH, scrollW / 2, thumbColor);
                app.hitTester.Register(HitRegion.Create(sbId, W - scrollW - app.Scale(8), thumbY, scrollW + app.Scale(12), thumbH, 3));
            }

            // ==================== LEFT: sidebar navigation ====================
            c.FillRect(0, top, sidebarW, H - top, t.bgSecondary);
            c.FillRect(sidebarW - 1, top, 1, H - top, t.divider);

            int sbInner = top + app.Scale(14);
            Label.Small(app, t.paddingLarge, sbInner, "COMPONENTS");

            int menuTop = sbInner + app.Scale(24);
            int itemH = app.Scale(38);
            int menuFirst = Menu.RenderVertical(app, 0, menuTop, sidebarW, H, itemH, names, nav, app.sidebarScrollY);
            Menu.HandleClick(app, menuFirst, names.Count, nav);
            app.sidebarContentHeight = (menuTop - top) + names.Count * itemH + app.Scale(20);

            // ==================== Popup overlay layer ====================
            // Rendered after all content + sidebar + scrollbar, so open popups
            // always draw on top and their options are the last-registered (thus
            // topmost) hit regions — clicks never pass through to widgets beneath.
            if (ovKind == 1 || ovKind == 2) {
                SignalInt ovModel = selectVal;
                SignalBool ovOpen = selectOpen;
                if (ovKind == 2) { ovModel = selectVal2; ovOpen = selectOpen2; }
                int of = Select.RenderOptions(app, ovX, ovY, ovW, selectOpts, ovModel);
                if (app.window.EventKind() == 3) {
                    int hh = app.hitTester.HitTest(app.mouseX, app.mouseY);
                    if (hh >= of && hh < of + selectOpts.Count) {
                        ovModel.Set(hh - of);
                        ovOpen.Set(false);
                        app.RequestRedraw();
                    } else if (hh != ovTrig) {
                        ovOpen.Set(false);
                        app.RequestRedraw();
                    }
                }
            } else if (ovKind == 3) {
                List<string> acts = new List<string>();
                acts.Add("Edit");
                acts.Add("Duplicate");
                acts.Add("Delete");
                int af = Dropdown.RenderMenu(app, ovX, ovY, ovW, acts);
                if (app.window.EventKind() == 3) {
                    int hh = app.hitTester.HitTest(app.mouseX, app.mouseY);
                    if (hh >= af && hh < af + acts.Count) {
                        dropdownMsg.Set(acts[hh - af]);
                        dropdownOpen.Set(false);
                        app.RequestRedraw();
                    } else if (hh != ovTrig) {
                        dropdownOpen.Set(false);
                        app.RequestRedraw();
                    }
                }
            }

            // ---- Top-layer feedback overlays (modal / dialog / drawer / message) ----
            if (modalOpen.Get()) {
                int mw = app.Scale(420);
                int mh = app.Scale(230);
                int mc = Modal.Render(app, mw, mh, "Modal Title");
                int mx = (W - mw) / 2;
                int my = (H - mh) / 2;
                c.DrawText(mx + t.paddingLarge, my + t.heightMedium + t.paddingLarge,
                           "This is a modal body. Click the X to close.", t.textSecondary, t.fontSizeMedium);
                if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == mc) {
                    modalOpen.Set(false);
                    app.RequestRedraw();
                }
            }
            if (dialogOpen.Get()) {
                int dr = Dialog.Render(app, app.Scale(448), app.Scale(200), 2, "Confirm",
                                       "Are you sure you want to proceed?", "Confirm", "Cancel");
                if (dr == 1) { dialogMsg.Set("Confirmed"); dialogOpen.Set(false); app.RequestRedraw(); }
                if (dr == 2) { dialogMsg.Set("Cancelled"); dialogOpen.Set(false); app.RequestRedraw(); }
                if (dr == 3) { dialogMsg.Set("Closed"); dialogOpen.Set(false); app.RequestRedraw(); }
            }
            if (drawerOpen.Get()) {
                int dside = drawerSide.Get();
                int dsize = app.Scale(320);
                if (dside == 3) { dsize = app.Scale(220); }
                int dcl = Drawer.Render(app, dside, dsize, "Drawer Panel");
                int dpx = 0;
                if (dside == 0) { dpx = W - dsize; }
                int dby = Drawer.BodyTop(app, dside, dsize);
                c.DrawText(dpx + t.paddingLarge, dby, "Drawer content goes here.", t.textSecondary, t.fontSizeMedium);
                if (app.window.EventKind() == 3 && app.hitTester.HitTest(app.mouseX, app.mouseY) == dcl) {
                    drawerOpen.Set(false);
                    app.RequestRedraw();
                }
            }
            if (sel == 36) {
                Message.Render(app, 0, "This is an info message", 2);
                Message.Render(app, 1, "Saved successfully", 3);
                Message.Render(app, 2, "Warning: please check your input", 4);
                Message.Render(app, 3, "Something went wrong", 5);
            }

            // ==================== Title bar overlay ====================
            app.RenderChrome("Zan UI  —  NaiveUI-style components");

            app.PresentFrame();
        }
    }
}
