            } else {
                // ----- Chart demo: shared monthly categories, two series -----
                List<string> chLabels = new List<string>();
                chLabels.Add("Jan"); chLabels.Add("Feb"); chLabels.Add("Mar");
                chLabels.Add("Apr"); chLabels.Add("May"); chLabels.Add("Jun");
                List<int> sA = new List<int>();
                sA.Add(120); sA.Add(200); sA.Add(150); sA.Add(280); sA.Add(240); sA.Add(360);
                List<int> sB = new List<int>();
                sB.Add(80); sB.Add(140); sB.Add(210); sB.Add(180); sB.Add(300); sB.Add(260);
                List<ChartSeries> chSeries = new List<ChartSeries>();
                chSeries.Add(ChartSeries.Create("Revenue", sA, Chart.Palette(t, 0)));
                chSeries.Add(ChartSeries.Create("Cost", sB, Chart.Palette(t, 1)));

                int chW = app.Scale(520);
                int chH = app.Scale(240);
                int gap2 = app.Scale(24);
                int col2 = x + chW + gap2;

                Label.Small(app, x, cy, "LINE");
