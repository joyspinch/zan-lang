using System;
using System.IO;
using System.Json;
using System.Threading;

namespace FullTest;

class Program {
    static void Main() {
        // IO tests
        File.WriteAllText("build/full_test.txt", "Full stdlib test");
        string content = File.ReadAllText("build/full_test.txt");
        Console.WriteLine(content);
        File.Delete("build/full_test.txt");

        // Path tests
        Console.WriteLine(Path.GetFileName("a/b/c.txt"));
        Console.WriteLine(Path.GetExtension("a/b/c.txt"));
        Console.WriteLine(Path.Combine("foo", "bar.zan"));

        // JSON tests
        string json = "{\"name\":\"Zan\",\"version\":3,\"active\":true}";
        string name = JsonParser.GetString(json, "name");
        Console.WriteLine(name);
        int ver = JsonParser.GetInt(json, "version");
        Console.WriteLine(ver);
        if (JsonParser.GetBool(json, "active")) {
            Console.WriteLine("active: true");
        }
        if (JsonParser.HasKey(json, "name")) {
            Console.WriteLine("has name: true");
        }

        // JSON builder
        string j = JsonBuilder.ObjectStart();
        j = JsonBuilder.AddString(j, "lang", "Zan");
        j = JsonBuilder.AddInt(j, "year", 2026);
        j = JsonBuilder.AddBool(j, "compiled", true);
        j = JsonBuilder.ObjectEnd(j);
        Console.WriteLine(j);

        // Threading - basic
        int tid = Thread.CurrentId();
        if (tid > 0) {
            Console.WriteLine("Thread ID: ok");
        }
        int t1 = Stopwatch.GetMilliseconds();
        Thread.Sleep(10);
        int t2 = Stopwatch.GetMilliseconds();
        if (t2 >= t1) {
            Console.WriteLine("Stopwatch: ok");
        }

        Console.WriteLine("=== Full stdlib test passed! ===");
    }
}
