using System;
using System.Data;
using System.Data.Postgres;

class PgProbe {
    static void Main() {
        // Does not require a running server: only verifies the libpq binding
        // links and the connection-failure path is handled gracefully.
        PgConnection db = PgConnection.Open("host=127.0.0.1 port=1 dbname=none connect_timeout=1");
        Console.WriteLine("connected=" + Convert.ToString(db.IsConnected()));
    }
}
