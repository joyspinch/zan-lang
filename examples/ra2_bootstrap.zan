using System;
using Game.Ra2;

namespace Examples.Ra2Bootstrap;

class Program {
    static void Main() {
        string path = ".";

        Ra2Config config = Ra2Config.Create(path);
        Ra2Engine engine = Ra2Engine.Create(config);
        if (!engine.HasValidInstall()) {
            Console.WriteLine("Not a complete RA2 install: " + path);
            int i = 0;
            while (i < engine.MissingAssetCount()) {
                Console.WriteLine("Missing: " + engine.MissingAssetAt(i));
                i = i + 1;
            }
            return;
        }

        Console.WriteLine("RA2 install accepted");
    }
}
