using System;

namespace CtorTest;

struct Rectangle {
    public int Width;
    public int Height;

    public Rectangle(int w, int h) {
        Width = w;
        Height = h;
    }

    public int Area() {
        return Width * Height;
    }
}

class Program {
    static void Main() {
        var r = new Rectangle(10, 5);
        Console.WriteLine($"Rectangle: {r.Width} x {r.Height}");
        Console.WriteLine($"Area: {r.Area()}");
    }
}
