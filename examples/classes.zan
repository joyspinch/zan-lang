using System;

namespace ClassDemo;

// Interface
interface IDrawable {
    void Draw();
    float Area();
}

// Struct (value type, stack allocated)
struct Color {
    public byte R;
    public byte G;
    public byte B;

    public static Color Red => Color { R = 255, G = 0, B = 0 };
    public static Color Green => Color { R = 0, G = 255, B = 0 };
    public static Color Blue => Color { R = 0, G = 0, B = 255 };
}

// Base class (reference type, ARC managed)
class Shape {
    public Color Fill;

    public Shape(Color fill) {
        Fill = fill;
    }

    public virtual string Name => "Shape";

    ~Shape() {
        Console.WriteLine($"{Name} destroyed");
    }
}

// Derived class
class Circle : Shape, IDrawable {
    public float Radius;

    public Circle(float radius, Color fill) : base(fill) {
        Radius = radius;
    }

    public override string Name => "Circle";

    public void Draw() {
        Console.WriteLine($"Drawing circle r={Radius}");
    }

    public float Area() => Math.PI * Radius * Radius;
}

class Rectangle : Shape, IDrawable {
    public float Width;
    public float Height;

    public Rectangle(float w, float h, Color fill) : base(fill) {
        Width = w;
        Height = h;
    }

    public override string Name => "Rectangle";

    public void Draw() {
        Console.WriteLine($"Drawing rect {Width}x{Height}");
    }

    public float Area() => Width * Height;
}

class Program {
    static void Main(string[] args) {
        // ARC manages lifetimes automatically
        var shapes = new List<IDrawable>();
        shapes.Add(new Circle(5.0, Color.Red));
        shapes.Add(new Rectangle(3.0, 4.0, Color.Blue));

        foreach (var shape in shapes) {
            shape.Draw();
            Console.WriteLine($"  Area: {shape.Area()}");
        }
        // shapes goes out of scope → all objects released automatically
    }
}

