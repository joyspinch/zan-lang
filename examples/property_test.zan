// property_test.zan -- M2.7 Property support test
// Tests: auto-properties as backing fields in structs

struct Rectangle {
    public int Width { get; set; }
    public int Height { get; set; }
}

class Program {
    static void Main() {
        // Create struct with auto-properties
        var rect = new Rectangle();
        rect.Width = 10;
        rect.Height = 5;

        Console.WriteLine(rect.Width);   // 10
        Console.WriteLine(rect.Height);  // 5

        // Compute area using properties
        var area = rect.Width * rect.Height;
        Console.WriteLine(area);         // 50
    }
}
