using System;

namespace InheritTest;

struct Animal {
    public int Age;
    public int Weight;
}

struct Dog {
    public int Age;
    public int Weight;
    public int Tricks;
}

class Program {
    static void Main() {
        // Test basic struct field inheritance concept
        var dog = Dog { Age = 3, Weight = 25, Tricks = 5 };
        Console.WriteLine(dog.Age);      // 3
        Console.WriteLine(dog.Weight);   // 25
        Console.WriteLine(dog.Tricks);   // 5
        
        // Test inherited method calls
        var sum = dog.Age + dog.Weight + dog.Tricks;
        Console.WriteLine(sum);          // 33
    }
}
