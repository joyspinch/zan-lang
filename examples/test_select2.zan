using System;
using System.Net.Sockets;

class Program {
    [DllImport("crt")]
    static extern string calloc(int count, int size);
    
    [DllImport("crt")]
    static extern void free(string ptr);

    [DllImport("ws2_32")]
    static extern int select(int nfds, string readfds, string writefds, string exceptfds, string timeout);

    [DllImport("ws2_32")]
    static extern int WSAGetLastError();

    [DllImport("ws2_32")]
    static extern int ioctlsocket(int s, int cmd, string argp);

    static void Main() {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.SetReuseAddr(sock);
        Socket.Bind(sock, "0.0.0.0", 8899);
        Socket.Listen(sock, 128);
        Console.WriteLine("sock=" + Convert.ToString(sock));

        // Set non-blocking
        string nb = calloc(4, 1);
        nb[0] = 1;
        ioctlsocket(sock, -2147195266, nb);
        free(nb);

        // Use exact same structure as IsReadable (works)
        string readfds = calloc(68, 1);
        readfds[0] = 1;
        readfds[4] = sock & 255;
        readfds[5] = (sock >> 8) & 255;
        readfds[6] = (sock >> 16) & 255;
        readfds[7] = (sock >> 24) & 255;
        string timeout = calloc(8, 1);

        int result = select(0, readfds, "", "", timeout);
        int err = WSAGetLastError();
        Console.WriteLine("select=" + Convert.ToString(result) + " err=" + Convert.ToString(err));
        free(readfds);
        free(timeout);

        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
