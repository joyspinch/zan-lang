using System;

namespace InterfaceTest;

interface IShape {
    int Area();
}

class Square : IShape {
    public int Side;
    
    public Square(int side) {
        Side = side;
    }
    
    int Area() {
        return Side * Side;
    }
}

class Rect : IShape {
    public int W;
    public int H;
    
    public Rect(int w, int h) {
        W = w;
        H = h;
    }
    
    int Area() {
        return W * H;
    }
}

class Program {
    static void Main() {
        var sq = new Square(5);
        var area1 = sq.Area();
        Console.WriteLine(area1);   // 25
        
        var r = new Rect(3, 4);
        var area2 = r.Area();
        Console.WriteLine(area2);   // 12
    }
}
