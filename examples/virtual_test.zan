using System;

namespace VirtualTest;

class Animal {
    public int Legs;
    
    public Animal(int legs) {
        Legs = legs;
    }
    
    virtual int Speak() {
        return 0;
    }
}

class Dog : Animal {
    public int Tricks;
    
    public Dog(int legs, int tricks) {
        Legs = legs;
        Tricks = tricks;
    }
    
    override int Speak() {
        return 1;
    }
    
    int GetTotal() {
        return Legs + Tricks;
    }
}

class Program {
    static void Main() {
        var dog = new Dog(4, 7);
        Console.WriteLine(dog.Legs);     // 4
        Console.WriteLine(dog.Tricks);   // 7
        var total = dog.GetTotal();
        Console.WriteLine(total);        // 11
        var speak = dog.Speak();
        Console.WriteLine(speak);        // 1 (override)
    }
}
