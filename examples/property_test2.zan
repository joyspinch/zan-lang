using System;

namespace PropertyTest2;

struct Rectangle {
    public int Width { get; set; }
    public int Height { get; set; }
}

class Program {
    static void Main() {
        var rect = new Rectangle();
        rect.Width = 8;
        rect.Height = 6;
        
        Console.WriteLine(rect.Width);   // 8
        Console.WriteLine(rect.Height);  // 6
        
        var area = rect.Width * rect.Height;
        Console.WriteLine(area);          // 48
        
        var perimeter = 2 * (rect.Width + rect.Height);
        Console.WriteLine(perimeter);     // 28
    }
}
