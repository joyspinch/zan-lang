using System;
using System.Net.Sockets;

class Program {
    static void Main() {
        Console.WriteLine("Step 1: Init");
        Socket.Initialize();
        Console.WriteLine("Step 2: Create socket");
        int sock = Socket.CreateTcp();
        Console.WriteLine("Step 3: Socket = " + Convert.ToString(sock));
        Socket.SetReuseAddr(sock);
        Console.WriteLine("Step 4: Bind");
        Socket.Bind(sock, "0.0.0.0", 8899);
        Console.WriteLine("Step 5: Listen");
        Socket.Listen(sock, 128);
        Console.WriteLine("Step 6: Waiting for connection...");
        int client = Socket.Accept(sock);
        Console.WriteLine("Step 7: Got client = " + Convert.ToString(client));
        Socket.Close(client);
        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
