using System;
using System.Net.Sockets;
using System.Net.Http;
using System.Data;
using System.Data.MySql;
using System.Security.Cryptography;

namespace Board;

/// <summary>
/// Concurrency acceptance harness for the message board. Drives the running
/// server (http://127.0.0.1:8080) with many simultaneous coroutine clients and
/// then verifies the outcome directly against MySQL. It asserts the three
/// properties the pool/session design must guarantee:
///
///   A. cross-user isolation -- each client's /api/me returns ITS OWN identity
///      under heavy interleaving (no request-local/session contamination);
///   B. no lost writes      -- K*M concurrent posts produce exactly K*M rows,
///      each unique (no dropped or duplicated inserts on the shared pool);
///   C. dup-register race    -- K concurrent registrations of the same username
///      yield exactly ONE success and ONE row (UNIQUE index, not check-then-insert).
///
/// A run tag isolates each execution so counts are exact regardless of history.
/// </summary>
class HttpResult {
    int status;
    string token;
    string body;
    HttpResult() { this.status = 0; this.token = ""; this.body = ""; }
}

class Http {
    static async HttpResult req(string method, string path, string body, string cookie) {
        HttpResult res = new HttpResult();
        TcpClient c = await TcpClient.ConnectAsync("127.0.0.1", 8080);
        if (c == null) { return res; }
        string h = method + " " + path + " HTTP/1.1\r\nHost: x\r\n";
        if (cookie.Length > 0) { h = h + "Cookie: zsession=" + cookie + "\r\n"; }
        if (method == "POST") {
            h = h + "Content-Type: application/x-www-form-urlencoded\r\n";
            h = h + "Content-Length: " + Convert.ToString(body.Length) + "\r\n";
        }
        h = h + "Connection: close\r\n\r\n" + body;
        int _s = await c.SendAsync(h);
        string resp = "";
        while (true) {
            string part = await c.RecvAsync(65536);
            if (part.Length == 0) { break; }
            resp = resp + part;
        }
        c.Close();
        res.status = Http.parseStatus(resp);
        res.token = Http.parseCookie(resp);
        int he = resp.IndexOf("\r\n\r\n");
        if (he >= 0) { res.body = resp.Substring(he + 4, resp.Length - he - 4); }
        return res;
    }

    static int parseStatus(string resp) {
        int sp = resp.IndexOf(" ");
        if (sp < 0) { return 0; }
        return Convert.ToInt32(resp.Substring(sp + 1, 3));
    }

    static string parseCookie(string resp) {
        int k = resp.IndexOf("zsession=");
        if (k < 0) { return ""; }
        int start = k + 9;
        int end = start;
        while (end < resp.Length) {
            int ch = resp[end] & 255;
            if (ch == 59 || ch == 13 || ch == 10) { break; }   // ';' CR LF
            end = end + 1;
        }
        return resp.Substring(start, end - start);
    }
}

class Stress {
    static string runTag;
    static int K;
    static int M;

    static List<string> tokens;
    static List<string> unames;

    static int regDone;
    static int regOk;
    static int meMismatch;
    static int postDone;
    static int postOk;
    static int raceDone;
    static int raceOk;

    static async void regWorker(int i) {
        string u = Stress.runTag + "_u" + Convert.ToString(i);
        HttpResult r = await Http.req("POST", "/api/register",
            "username=" + u + "&password=secret123", "");
        if (r.status == 200) { Stress.regOk = Stress.regOk + 1; }
        Stress.tokens[i] = r.token;
        Stress.unames[i] = u;
        // immediately assert identity isolation under concurrency
        HttpResult me = await Http.req("GET", "/api/me", "", r.token);
        string needle = "\"user\":\"" + u + "\"";
        if (me.body.IndexOf(needle) < 0) { Stress.meMismatch = Stress.meMismatch + 1; }
        Stress.regDone = Stress.regDone + 1;
    }

    static async void postWorker(int i, int j) {
        string content = Stress.runTag + "-" + Convert.ToString(i) + "-" + Convert.ToString(j);
        HttpResult r = await Http.req("POST", "/api/post",
            "text=" + content, Stress.tokens[i]);
        if (r.status == 200) { Stress.postOk = Stress.postOk + 1; }
        Stress.postDone = Stress.postDone + 1;
    }

    static async void raceWorker(string uname) {
        HttpResult r = await Http.req("POST", "/api/register",
            "username=" + uname + "&password=secret123", "");
        if (r.status == 200) { Stress.raceOk = Stress.raceOk + 1; }
        Stress.raceDone = Stress.raceDone + 1;
    }

    static async int run() {
        Stress.runTag = "st" + Hex.Encode(RandomNumberGenerator.GetBytes(3), 3);
        Stress.K = 15;
        Stress.M = 8;
        Stress.tokens = new List<string>();
        Stress.unames = new List<string>();
        int t = 0;
        while (t < Stress.K) { Stress.tokens.Add(""); Stress.unames.Add(""); t = t + 1; }

        Console.WriteLine("[stress] tag=" + Stress.runTag + " K=" + Convert.ToString(Stress.K) + " M=" + Convert.ToString(Stress.M));

        // ---- Phase A: concurrent registration + identity check ----
        int i = 0;
        while (i < Stress.K) { Task.Spawn(Stress.regWorker(i)); i = i + 1; }
        int g = 0;
        while (Stress.regDone < Stress.K && g < 60000) { await Task.Delay(1); g = g + 1; }

        // ---- Phase B: K*M concurrent posts ----
        i = 0;
        while (i < Stress.K) {
            int j = 0;
            while (j < Stress.M) { Task.Spawn(Stress.postWorker(i, j)); j = j + 1; }
            i = i + 1;
        }
        g = 0;
        int total = Stress.K * Stress.M;
        while (Stress.postDone < total && g < 120000) { await Task.Delay(1); g = g + 1; }

        // ---- Phase C: dup-register race ----
        string raceName = Stress.runTag + "_race";
        int rc = 0;
        int RK = 25;
        while (rc < RK) { Task.Spawn(Stress.raceWorker(raceName)); rc = rc + 1; }
        g = 0;
        while (Stress.raceDone < RK && g < 60000) { await Task.Delay(1); g = g + 1; }

        // ---- Verify directly against MySQL ----
        MySqlConnection db = await MySqlConnection.OpenParamsAsync("127.0.0.1", 3306, "msgboard", "root", "root");
        string like = Stress.runTag + "-%";
        string cnt = await db.ExecuteScalarAsync("SELECT COUNT(*) FROM messages WHERE content LIKE '" + like + "'");
        string dist = await db.ExecuteScalarAsync("SELECT COUNT(DISTINCT content) FROM messages WHERE content LIKE '" + like + "'");
        // cross-user attribution: any message whose username != its author's users.username?
        string bad = await db.ExecuteScalarAsync(
            "SELECT COUNT(*) FROM messages m JOIN users u ON u.id=m.user_id "
            + "WHERE m.content LIKE '" + like + "' AND m.username<>u.username");
        string raceRows = await db.ExecuteScalarAsync("SELECT COUNT(*) FROM users WHERE username='" + raceName + "'");
        db.Close();

        Console.WriteLine("A regOk=" + Convert.ToString(Stress.regOk) + "/" + Convert.ToString(Stress.K)
            + " me_mismatch=" + Convert.ToString(Stress.meMismatch) + " (want 0)");
        Console.WriteLine("B postOk=" + Convert.ToString(Stress.postOk) + "/" + Convert.ToString(total)
            + " db_rows=" + cnt + " db_distinct=" + dist + " (want " + Convert.ToString(total) + ")"
            + " mis_attributed=" + bad + " (want 0)");
        Console.WriteLine("C race_http_ok=" + Convert.ToString(Stress.raceOk) + " db_rows=" + raceRows + " (want 1/1)");

        bool pass = (Stress.regOk == Stress.K) && (Stress.meMismatch == 0)
            && (Stress.postOk == total) && (cnt == Convert.ToString(total))
            && (dist == Convert.ToString(total)) && (bad == "0")
            && (Stress.raceOk == 1) && (raceRows == "1");
        if (pass) { Console.WriteLine("STRESS_PASS"); } else { Console.WriteLine("STRESS_FAIL"); }
        return 0;
    }

    static void Main() { int x = await run(); }
}
