using System;
using System.IO;
using System.Threading;

namespace GateProbe;

class Probe {
    static int woke;
    static int woke2;

    static void T(string s) { File.AppendAllText("_scratch/gate.trace", s + "\n"); }

    static async void waiter(AsyncGate g) {
        Probe.T("waiter: about to Wait");
        bool ok = await g.Wait();
        Probe.T("waiter: woke ok=" + Convert.ToString(ok));
        Probe.woke = 1;
    }

    static async void waiter2(AsyncGate g) {
        Probe.T("waiter2: about to Wait");
        bool ok = await g.Wait();
        Probe.T("waiter2: woke");
        Probe.woke2 = 1;
    }

    static async int run() {
        File.WriteAllText("_scratch/gate.trace", "start\n");
        AsyncGate g = AsyncGate.Create();
        Probe.T("open=" + Convert.ToString(g.IsOpen()));

        Task.Spawn(Probe.waiter(g));
        Probe.T("spawned waiter; delay 80");
        await Task.Delay(80);
        Probe.T("T1 before_signal woke=" + Convert.ToString(Probe.woke) + " (want 0)");
        g.Signal();
        Probe.T("signalled; delay 80");
        await Task.Delay(80);
        Probe.T("T1 after_signal woke=" + Convert.ToString(Probe.woke) + " (want 1)");

        AsyncGate g2 = AsyncGate.Create();
        g2.Signal();
        Task.Spawn(Probe.waiter2(g2));
        await Task.Delay(80);
        Probe.T("T2 surplus woke2=" + Convert.ToString(Probe.woke2) + " (want 1)");

        g.Close(); g2.Close();
        bool pass = (Probe.woke == 1) && (Probe.woke2 == 1);
        Probe.T(pass ? "GATE_PASS" : "GATE_FAIL");
        return 0;
    }

    static void Main() { int x = await run(); }
}
