using System;
using System.Text;

namespace Board;

/// <summary>
/// Message board endpoints. Posting requires an authenticated principal
/// (enforced centrally by Server.route); the post is always attributed to
/// ctx.uid/uname from the validated session, never to a client-supplied id, so
/// one user cannot write as another.
/// </summary>
class MessageController {

    static async int post(Ctx ctx) {
        string text = ctx.In("text");
        if (text.Length == 0) { ctx.Fail(400, "text is required"); return 0; }
        if (text.Length > 1000) { ctx.Fail(400, "text too long (max 1000)"); return 0; }
        int rc = await Message.Insert(App.pool, ctx.uid, ctx.uname, text);
        if (rc < 1) { ctx.Fail(500, "failed to store message"); return 0; }
        ctx.Json("{\"ok\":true}");
        return 0;
    }

    static async int list(Ctx ctx) {
        string limStr = ctx.In("limit");
        int limit = 50;
        if (limStr.Length > 0) {
            int n = Convert.ToInt32(limStr);
            if (n > 0 && n <= 200) { limit = n; }
        }
        string arr = await Message.ListJson(App.pool, limit);
        ctx.Json("{\"ok\":true,\"messages\":" + arr + "}");
        return 0;
    }
}
