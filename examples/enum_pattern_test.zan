using System;

namespace EnumPatternTest;

enum Direction {
    North,
    South,
    East,
    West
}

class Program {
    static void Main() {
        var dir = Direction.East;
        
        switch (dir) {
            case 0: Console.WriteLine("North"); break;
            case 1: Console.WriteLine("South"); break;
            case 2: Console.WriteLine("East"); break;
            case 3: Console.WriteLine("West"); break;
        }
        
        // Test with computed enum value
        var next = Direction.West;
        switch (next) {
            case 3: Console.WriteLine("Going West"); break;
            default: Console.WriteLine("Other"); break;
        }
        
        // Enum arithmetic
        Console.WriteLine(dir);   // 2
        Console.WriteLine(next);  // 3
    }
}
