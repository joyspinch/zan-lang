using System;
using System.Json;
using Gui;
using Gui.Widget;

/// Headless end-to-end check of the JSON->UI pipeline: parse a layout document
/// into a retained Control tree, register a named handler, wire `on<Event>`
/// names to Actions, then fire the button's Click to prove the handler runs.
/// No window is opened (console build), so it verifies the loader/registry
/// logic independently of rendering.
class JsonUiTest {
    static int fired;

    static void OnSave() {
        JsonUiTest.fired = JsonUiTest.fired + 1;
        Console.WriteLine("HANDLER_FIRED");
    }

    static void Main() {
        JsonUiTest.fired = 0;
        string src = "{ \"type\": \"Column\", \"gap\": 12, \"pad\": 20, \"children\": [ { \"type\": \"H1\", \"text\": \"Profile\" }, { \"type\": \"Label\", \"text\": \"Name\", \"variant\": 1 }, { \"type\": \"Button\", \"name\": \"saveBtn\", \"text\": \"Save\", \"onClick\": \"save\" } ] }";

        UiDoc ui = UiDoc.FromJson(src);
        ui.Handle("save", JsonUiTest.OnSave);
        ui.Wire();

        Control root = ui.Root();
        Console.WriteLine("root " + root.Kind());
        Console.WriteLine("children " + Convert.ToString(root.ChildCount()));

        Control btn = root.Find("saveBtn");
        if (btn == null) { Console.WriteLine("NO_BUTTON"); return; }
        Console.WriteLine("btn " + btn.Kind() + " onClick=" + btn.GetHandler("Click"));

        // Firing the button's common Click event should invoke OnSave, proving
        // the on* name resolved through the registry and attached via BindEvent.
        btn.On.Click.Raise();
        Console.WriteLine("fired " + Convert.ToString(JsonUiTest.fired));
        if (JsonUiTest.fired == 1) { Console.WriteLine("UIDOC_OK"); }

        // Two-way binding round trip: an Input bound to `user.name`. Seeding
        // from the model pushes state -> control; editing + SyncToModel pushes
        // control -> state (dotted PathGet/PathSet).
        string src2 = "{ \"type\": \"Column\", \"children\": [ { \"type\": \"Input\", \"name\": \"nm\", \"bind\": \"user.name\", \"hint\": \"Name\" } ] }";
        UiDoc ui2 = UiDoc.FromJson(src2);
        JsonValue m = JsonValue.Parse("{ \"user\": { \"name\": \"Ann\" } }");
        ui2.Bind(m);
        ui2.SyncFromModel();
        Control nm = ui2.Root().Find("nm");
        if (nm == null) { Console.WriteLine("NO_INPUT"); return; }
        string seeded = nm.GetProp("value");
        Console.WriteLine("seed " + seeded);
        nm.SetProp("value", "Bob");
        ui2.SyncToModel();
        string wb = m.PathGet("user.name").AsString("");
        Console.WriteLine("wb " + wb);
        if (seeded == "Ann" && wb == "Bob") { Console.WriteLine("BIND_OK"); }

        // Bool binding round trip on a Switch bound to `agree`.
        string src3 = "{ \"type\": \"Column\", \"children\": [ { \"type\": \"Switch\", \"name\": \"ag\", \"bind\": \"agree\" } ] }";
        UiDoc ui3 = UiDoc.FromJson(src3);
        JsonValue m3 = JsonValue.Parse("{ \"agree\": true }");
        ui3.Bind(m3);
        ui3.SyncFromModel();
        Control ag = ui3.Root().Find("ag");
        if (ag == null) { Console.WriteLine("NO_SWITCH"); return; }
        string sSeed = ag.GetProp("value");
        ag.SetProp("value", "false");
        ui3.SyncToModel();
        string sWb = m3.PathGet("agree").AsString("");
        Console.WriteLine("sw " + sSeed + "->" + sWb);
        if (sSeed == "true" && sWb == "false") { Console.WriteLine("BIND_BOOL_OK"); }
    }
}
