using System;
using System.Collections;
namespace Zc;

class Program {
    static void Main() {
        string src = "12 + 3 * 4 - 5";
        Lexer lx = new Lexer();
        List<Token> toks = lx.Lex(src);
        Console.WriteLine(toks.Count);
        Parser p = new Parser(toks);
        int result = p.ParseExpr();
        Console.WriteLine(result);
    }
}
