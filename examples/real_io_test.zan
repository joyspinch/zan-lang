using System;

namespace RealIOTest;

class CRT {
    [DllImport("msvcrt", EntryPoint = "fopen")]
    static extern int FOpen(string path, string mode);

    [DllImport("msvcrt", EntryPoint = "fputs")]
    static extern int FPuts(string str, int fp);

    [DllImport("msvcrt", EntryPoint = "fclose")]
    static extern int FClose(int fp);

    [DllImport("msvcrt", EntryPoint = "fseek")]
    static extern int FSeek(int fp, int offset, int origin);

    [DllImport("msvcrt", EntryPoint = "ftell")]
    static extern int FTell(int fp);

    [DllImport("msvcrt", EntryPoint = "fread")]
    static extern int FRead(string buf, int size, int count, int fp);

    [DllImport("msvcrt", EntryPoint = "remove")]
    static extern int Remove(string path);

    [DllImport("msvcrt", EntryPoint = "malloc")]
    static extern string Malloc(int size);
}

class Program {
    static void Main() {
        // Write a file using real DllImport FFI
        int fp = CRT.FOpen("build/real_test.txt", "w");
        CRT.FPuts("Hello from real Zan FFI!", fp);
        CRT.FClose(fp);

        // Read it back
        int fp2 = CRT.FOpen("build/real_test.txt", "rb");
        CRT.FSeek(fp2, 0, 2);
        int size = CRT.FTell(fp2);
        CRT.FSeek(fp2, 0, 0);
        string buf = CRT.Malloc(size + 1);
        CRT.FRead(buf, 1, size, fp2);
        CRT.FClose(fp2);
        Console.WriteLine(buf);

        // Clean up
        CRT.Remove("build/real_test.txt");
        Console.WriteLine("Real IO test passed!");
    }
}
