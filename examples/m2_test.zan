using System;

namespace M2Test;

class MathUtils {
    static int Add(int a, int b) {
        return a + b;
    }

    static int Factorial(int n) {
        if (n <= 1) {
            return 1;
        }
        return n * MathUtils.Factorial(n - 1);
    }
}

struct Vector2 {
    public float X;
    public float Y;

    public float Magnitude() => Math.Sqrt(X * X + Y * Y);
}

class Program {
    static void Main() {
        Console.WriteLine("=== M2 Feature Test ===");

        // String interpolation with expressions
        var a = 10;
        var b = 20;
        Console.WriteLine($"a={a}, b={b}, a+b={a + b}");

        // Struct with fields and methods
        var v = Vector2 { X = 3.0, Y = 4.0 };
        Console.WriteLine($"Vector magnitude: {v.Magnitude()}");

        // Static method calls
        var sum = MathUtils.Add(100, 200);
        Console.WriteLine($"100 + 200 = {sum}");

        // Recursive static method
        var fact = MathUtils.Factorial(6);
        Console.WriteLine($"6! = {fact}");

        // Switch/case
        var grade = 85;
        switch (grade) {
            case 100:
                Console.WriteLine("Perfect!");
                break;
            case 85:
                Console.WriteLine("Grade: B+");
                break;
            default:
                Console.WriteLine("Other grade");
                break;
        }

        // Control flow
        for (var i = 0; i < 3; i = i + 1) {
            Console.WriteLine($"loop {i}");
        }

        // Nested expressions
        var result = (a + b) * 2 - 5;
        Console.WriteLine($"(10+20)*2-5 = {result}");

        Console.WriteLine("=== All tests passed ===");
    }
}
