using System;
using System.Net.Sockets;

class Program {
    static void Main() {
        Console.WriteLine("Step 1: Init");
        Socket.Initialize();
        Console.WriteLine("Step 2: CreateTcp");
        int sock = Socket.CreateTcp();
        Console.WriteLine("Step 3: sock=" + Convert.ToString(sock));
        Console.WriteLine("Step 4: SetReuseAddr");
        Socket.SetReuseAddr(sock);
        Console.WriteLine("Step 5: Bind");
        int bindResult = Socket.Bind(sock, "0.0.0.0", 8899);
        Console.WriteLine("Step 6: bind=" + Convert.ToString(bindResult));
        Console.WriteLine("Step 7: Listen");
        int listenResult = Socket.Listen(sock, 128);
        Console.WriteLine("Step 8: listen=" + Convert.ToString(listenResult));
        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
