using System;

namespace Hello;

class Program {
    static void Main(string[] args) {
        Console.WriteLine("Hello, Zan!");

        var x = 40 + 2;
        Console.WriteLine($"The answer is {x}");

        var p = Point { X = 3.0, Y = 4.0 };
        Console.WriteLine($"Point length: {p.Length()}");
    }
}

struct Point {
    public float X;
    public float Y;

    public float Length() => Math.Sqrt(X * X + Y * Y);
}

