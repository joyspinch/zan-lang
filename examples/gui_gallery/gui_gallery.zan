            // Row 1: colour variants.
            Tag.Render(app, px, py, "Default", 0);
            Tag.Render(app, px + app.Scale(84), py, "Primary", 1);
            Tag.Render(app, px + app.Scale(168), py, "Info", 2);
            Tag.Render(app, px + app.Scale(240), py, "Success", 3);
            Tag.Render(app, px + app.Scale(330), py, "Warning", 4);
            Tag.Render(app, px + app.Scale(426), py, "Error", 5);
            // Row 2: interactive closable chips + an "+ Add" action.
            Label.Secondary(app, px, py + app.Scale(30), "Closable · click x to remove, + Add to append");
            int ty2 = py + app.Scale(54);
            int tx = px;
            int ti = 0;
            while (ti < Gallery.demoTags.Count) {
                string tg = Gallery.demoTags[ti];
                int cid = Tag.RenderClosable(app, tx, ty2, tg, 1);
                int tgw = Canvas.MeasureText(tg, t.fontSizeSmall) + t.paddingSmall * 2 + app.Scale(16);
                if (Ui.Clicked(app, cid)) {
                    Gallery.demoTags.RemoveAt(ti);
                    app.RequestRedraw();
                } else {
                    tx = tx + tgw + app.Scale(8);
                    ti = ti + 1;
                }
            }
            Button addBtn = Button.Styled("+ Add", 1, 1);
            addBtn.SetSize(1);
            int abId = addBtn.Render(app, tx, ty2 - app.Scale(2), app.Scale(64));
            if (Button.WasClicked(app, abId)) {
                Gallery.demoTags.Add("Tag " + Convert.ToString(Gallery.demoTags.Count + 1));
                app.RequestRedraw();
            }
        } else if (name == "Avatar.text") {
