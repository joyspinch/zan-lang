            Gallery.tbCard.Render(app, px, py + app.Scale(136), app.Scale(320));

            // Vertical rail with its own page region drawn by the caller —
            // header and page are fully decoupled.
            int vy = py + app.Scale(210);
            int railW = app.Scale(150);
            int railH = Gallery.tbVert.HeaderHeight(app) * Gallery.tbVert.Count();
            Gallery.tbVert.RenderVertical(app, px, vy, railW, railH);
            int pageX = px + railW + app.Scale(16);
            int pageW = app.Scale(300);
            Rect page = Panel.Section(app, pageX, vy, pageW, railH, Gallery.tbVert.ActiveLabel());
            Label.Secondary(app, page.x, page.y, "Active page: " + Gallery.tbVert.ActiveLabel());
        } else if (name == "Steps") {
            // WYSIWYG: retained instances laid out by a column — no coordinates.
            Steps s1 = new Steps(Gallery.demoInt);
            s1.AddStep("Details"); s1.AddStep("Review"); s1.AddStep("Done");
            Steps s2 = new Steps(SignalInt.Create(1));
            s2.AddStep("Upload"); s2.AddStep("Verify"); s2.AddStep("Publish");
            s2.Error(1);
            Steps s3 = new Steps(SignalInt.Create(1));
            s3.AddStepDesc("Account", "Email and password");
            s3.AddStepDesc("Profile", "Name and avatar");
            s3.AddStepDesc("Finish", "Review and submit");
            s3.Vertical();
            Panel col = Panel.Column().Gap(app.Scale(12));
            col.With(new Label("Horizontal · bound current step").Variant(1));
            col.With(s1);
            col.With(new Label("Error state").Variant(1));
            col.With(s2);
            col.With(new Label("Vertical · with descriptions").Variant(1));
            col.With(s3);
            col.MeasureTree(app);
            col.Arrange(px, py - app.Scale(20), w - app.Scale(36), app.Scale(380));
            col.RenderTree(app);
        } else if (name == "Breadcrumb") {
            // WYSIWYG: a retained Breadcrumb instance, auto-measured/placed.
            Breadcrumb bc = new Breadcrumb();
            bc.AddItem("Home"); bc.AddItem("Components"); bc.AddItem("Breadcrumb");
            bc.MeasureTree(app);
            bc.Arrange(px, py, w - app.Scale(36), Canvas.FontHeight(t.fontSizeMedium));
            bc.RenderTree(app);
        } else if (name == "Menu") {
            List<string> menuItems = new List<string>();
