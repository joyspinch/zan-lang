using System;
using System.Threading;
using Gui;
using Gui.Widget;

// Zan GUI component gallery.
//
// A NaiveUI-style component showcase: a scrollable component navigation on the
// left, and a detail pane on the right with a short description, a live preview
// of the component's real states, and a copyable code snippet showing the exact
// current API. Click "Copy" to place the snippet on the clipboard.
//
// Run it from the IDE (Run / F5) or:
//   zanc --emit-ir examples/gui_gallery/gui_gallery.zan > gallery.ll
//   clang gallery.ll -o gallery <gui link args>

/// One catalog entry: which category it belongs to, its display name, a short
/// description, and the code snippet shown (and copied) in the detail pane.
class Comp {
    string category;
    string name;
    string desc;
    string code;
    // Optional JSON config version of the snippet (the data-driven form of the
    // same demo). Empty when a component has no JSON representation yet.
    string json;
    // Multiple demo cards for this component (Naive-UI style). When empty the
    // page falls back to a single card built from desc/code/json.
    List<Demo> demos;
    // Bottom-of-page API documentation.
    List<ApiRow> props;
    List<ApiRow> events;

    // Memoised wrap of the page description (fontSizeMedium), rebuilt only when
    // the content width or font size changes -- see Demo.EnsureCache.
    string descSig;
    List<string> descLines;

    static Comp Create(string category, string name, string desc, string code) {
        Comp e = new Comp();
        e.category = category;
        e.name = name;
        e.desc = desc;
        e.code = code;
        e.json = "";
        e.demos = new List<Demo>();
        e.props = new List<ApiRow>();
        e.events = new List<ApiRow>();
        e.descSig = "";
        return e;
    }

    /// Wrapped page-description lines, recomputed only when (width, font) change.
    List<string> DescLines(int cw, int fs) {
        string sig = Convert.ToString(cw) + "|" + Convert.ToString(fs);
        if (sig != descSig) {
            descSig = sig;
            descLines = Gallery.WrapText(desc, cw, fs);
        }
        return descLines;
    }

    Comp AddDemo(string title, string desc, string previewId, int previewH,
            string code, string json) {
        demos.Add(Demo.Create(title, desc, previewId, previewH, code, json));
        return this;
    }

    Comp AddProp(string name, string type, string deflt, string desc) {
        props.Add(ApiRow.Create(name, type, deflt, desc));
        return this;
    }

    Comp AddEvent(string name, string sig, string desc) {
        events.Add(ApiRow.Create(name, sig, "", desc));
        return this;
    }

    static Comp CreateJson(string category, string name, string desc,
            string code, string json) {
        Comp e = Comp.Create(category, name, desc, code);
        e.json = json;
        return e;
    }
}

/// One row in a component's API table: a property (name/type/default/desc) or
/// an event (name = event, type = signature, deflt unused).
class ApiRow {
    string name;
    string type;
    string deflt;
    string desc;

    static ApiRow Create(string name, string type, string deflt, string desc) {
        ApiRow r = new ApiRow();
        r.name = name;
        r.type = type;
        r.deflt = deflt;
        r.desc = desc;
        return r;
    }
}

/// One demo card on a component page: a titled block with its own description,
/// a live preview (keyed by previewId), and its own Zan / JSON snippets.
class Demo {
    string title;
    string desc;
    string previewId;
    int previewH;   // unscaled preview box height
    string code;
    string json;
    // Active code tab for THIS card only: 0 = Zan, 1 = JSON. Each card owns
    // its own tab so toggling one demo's JSON view leaves the others alone.
    int tab;
    // Stable identity for this card, so the shared code-selection state knows
    // which single code box owns the current selection (no cross-box bleed).
    static int seq;
    int uid;

    // --- Per-frame render cache -------------------------------------------
    // Wrapping the description and tokenising the code snippet for syntax
    // highlighting are pure functions of (content width, code tab, font size),
    // yet they were recomputed every frame. Memoise them here and only rebuild
    // when one of those inputs changes (window resize, DPI/theme, tab switch).
    // Demo objects are retained in Comp.demos, so the cache survives frames.
    // Highlight spans are stored flat (segText/segColor across all lines, with
    // segPerLine giving each line's span count) to avoid nested generics.
    string cacheSig;
    string cacheSrc;
    List<string> cacheDescLines;
    List<string> cacheCodeLines;
    List<string> cacheSegText;
    List<int> cacheSegColor;
    List<int> cacheSegPerLine;

    static Demo Create(string title, string desc, string previewId,
            int previewH, string code, string json) {
        Demo d = new Demo();
        d.title = title;
        d.desc = desc;
        d.previewId = previewId;
        d.previewH = previewH;
        d.code = code;
        d.json = json;
        d.tab = 0;
        d.uid = Demo.seq;
        Demo.seq = Demo.seq + 1;
        d.cacheSig = "";
        return d;
    }

    /// Rebuilds the wrap/highlight cache when (width, tab, font size) change.
    /// Idempotent within a frame, so callers can invoke it freely.
    void EnsureCache(App app, Theme t, int cw, int tab) {
        int fs = t.fontSizeSmall;
        string sig = Convert.ToString(cw) + "|" + Convert.ToString(tab)
            + "|" + Convert.ToString(fs) + "|" + Convert.ToString(t.bgPrimary);
        if (sig == cacheSig) { return; }
        cacheSig = sig;

        cacheDescLines = Gallery.WrapText(desc, cw, fs);

        string src = code;
        if (tab == 1) {
            if (json != "") { src = json; }
            else { src = "// This demo has no JSON config version yet."; }
        }
        cacheSrc = src;
        cacheCodeLines = CodeEditor.SplitLines(src);
        cacheSegText = new List<string>();
        cacheSegColor = new List<int>();
        cacheSegPerLine = new List<int>();
        int ci = 0;
        while (ci < cacheCodeLines.Count) {
            List<string> segT = new List<string>();
            List<int> segC = new List<int>();
            CodeEditor.HighlightSpans(cacheCodeLines[ci], t.info, t.success,
                t.warning, t.textTertiary, t.primary, t.textPrimary, segT, segC);
            int si = 0;
            while (si < segT.Count) {
                cacheSegText.Add(segT[si]);
                cacheSegColor.Add(segC[si]);
                si = si + 1;
            }
            cacheSegPerLine.Add(segT.Count);
            ci = ci + 1;
        }
    }

}

class Gallery {
    // Shared demo state. Only the selected component's preview renders each
    // frame, so a single set of signals is enough to drive every interactive
    // example.
    static SignalBool demoBool;
    static SignalInt demoInt;
    static Input demoInput;
    static TextArea demoArea;
    static SelectBox demoSelect;
    static SelectBox demoMulti;
    static SelectBox demoLong;
    static Select demoSelectLow;
    static Dropdown demoDropdown;
    static Popover demoPopover;
    static FilePicker filePicker;
    static string pickerResult;
    static string pendingPicker;
    static VirtualList demoVList;
    static CarouselAnim demoCarousel;
    static SignalInt demoCarBasic;
    static SignalInt demoCar2;
    static CarouselAnim carAnim2;

    // Delegate/event demo state. Retained buttons register their handlers once
    // with the C#-style `Click += handler`; a background Thread reports progress
    // back to the UI thread through app.Post, which mutates these signals on the
    // UI thread.
    static App app;
    static SignalInt evtValue;
    static SignalBool evtRunning;
    static Button evtButton;
    static Button evtStartButton;
    static int evtClicks;

    // Showcase navigation / scroll state.
    static SignalInt selected;
    static SignalInt navScroll;
    static SignalInt codeScroll;
    // Active code tab: 0 = Zan API, 1 = JSON config.
    static SignalInt codeTab;
    // The detail page is a scroll container that owns wheel/clip/scrollbar.
    static ScrollView detailView;
    // Content height measured on the previous frame (fed back to the view).
    static SignalInt detailContentH;
    // Visible detail viewport bounds (set each frame by RenderDetail) so the
    // glass backdrop blur can be clamped to it -- BlurRect ignores the clip
    // rect, so without this a scrolled card would smear pixels above/below.
    static int detailClipTop;
    static int detailClipBottom;
    // Wall-clock of the last mouse-motion-driven repaint, used to throttle
    // hover refreshes so dragging the pointer never spins the CPU.
    static int lastMotionMs;
    static ScrollView navView;
    static Tabs tbLine;
    static Tabs tbCard;
    static Tabs tbSeg;
    static Tabs tbVert;
    static List<Comp> comps;

    // Read-only code selection (line/col anchor..focus into the current
    // snippet's split lines). selDrag is true while the mouse button is held.
    static bool selHas;
    static bool selDrag;
    // uid of the Demo whose code box currently owns the selection (-1 = none),
    // combined with the tab so a Zan/JSON switch doesn't reuse stale offsets.
    static int selOwner;
    static int selTab;
    // Retained state for the deferred-overlay / interactive demos.
    static string copiedIcon;
    static DataTableState demoTableState;
    // Retained state for the unified Layer demo: draggable windows, the modal
    // alert/confirm/prompt dialogs, plus the loading / tips / photos toggles.
    static List<LayerState> demoLayers;
    static int layerSeq;
    static LayerState dlgAlert;
    static LayerState dlgConfirm;
    static LayerState dlgPrompt;
    static SignalBool tipsOn;
    static SignalBool tipClickOn;
    static SignalInt pagePill;
    static SignalInt pageSmall;
    static SignalInt pageSimple;
    static SignalInt scrollOff;
    static SignalInt tipScroll;
    static SignalBool photosOpen;
    static int loadStartMs;
    static SignalInt photoIdx;
    static CarouselAnim photoAnim;
    static List<string> photoSlides;
    static string popupResult;
    static int selAL;
    static int selAC;
    static int selFL;
    static int selFC;
    static int copiedFrame;
    // API-table (Properties / Events) row selection. Independent from the code
    // panel selection above so the two never clobber each other. kind: 0 none,
    // 1 Properties, 2 Events. anchor/focus are inclusive row indices.
    static int apiSelKind;
    static int apiSelA;
    static int apiSelB;
    static bool apiSelDrag;
    static int apiCopiedFrame;
    // Interactive Tag demo: closable chips the user can remove (x) or append (+ Add).
    static List<string> demoTags;

    // Bilingual demos: 0 = English, 1 = 中文. Toggled from the header; mirrored
    // into Wizard.lang / FilePicker.lang so their child windows follow suit.
    static SignalInt lang;

    // Persistent demo models (must survive across frames so interaction sticks).
    static List<string> tabViewLabels;   // TabView add/close/select demo
    static int tabViewSeq;               // running counter for new tab names
    static SignalInt splitVFirst;        // left pane width  (left|right split)
    static SignalInt splitHFirst;        // top pane height  (top|bottom split)
    static List<TreeNode> treeNodes;     // TreeView demo tree
    static SignalInt treeSel;            // TreeView selected row
    static SignalBool treeMenuOpen;      // TreeView context-menu visibility
    static SignalInt treeMenuAction;     // TreeView context-menu picked action
    static SignalInt treeMenuSub;        // TreeView context-menu open submenu
    static int treeMenuX;                // TreeView context-menu anchor X
    static int treeMenuY;                // TreeView context-menu anchor Y
    static int treeMenuNode;             // TreeView row the menu targets
    static int treeMenuBaseId;           // TreeView context-menu hit-id block
    static SignalInt ribbonTab;          // Ribbon active tab index
    static Input wizName;                // Wizard demo name field
    static Input wizLoc;                 // Wizard demo location field
    static SignalInt wizSel;             // Wizard demo template selection
    static SignalInt fbScroll;           // FloatButton back-to-top demo scroll
    static Input navSearch;              // component-navigation search box

    // Reusable visual component designer (framework component).
    static Designer designer;

    static void Main() {
        App app = App.CreateDark("Zan GUI Components", 1120, 720);
        Gallery.demoBool = SignalBool.Create(true);
        Gallery.demoInt = SignalInt.Create(1);
        Gallery.demoInput = Input.Bind(SignalString.Create("Zan"), "type here");
        Gallery.demoArea = TextArea.Bind(
            SignalString.Create("Multiline input.\nType, press Enter for a new line,\nuse arrows / Home / End to move.\nIt scrolls itself when it overflows."),
            "Write something...");
        Gallery.demoSelect = SelectBox.Create("Pick a status").Clearable(true);
        Gallery.demoSelect.AddOption("Default");
        Gallery.demoSelect.AddOption("Success");
        Gallery.demoSelect.AddOption("Warning");
        Gallery.demoSelect.AddOption("Error");
        Gallery.demoMulti = SelectBox.Multi("Pick languages");
        Gallery.demoMulti.AddOption("Zan");
        Gallery.demoMulti.AddOption("C");
        Gallery.demoMulti.AddOption("Rust");
        Gallery.demoMulti.AddOption("Go");
        Gallery.demoLong = SelectBox.Create("Long list (scrolls)");
        Gallery.demoLong.AddOption("January");
        Gallery.demoLong.AddOption("February");
        Gallery.demoLong.AddOption("March");
        Gallery.demoLong.AddOption("April");
        Gallery.demoLong.AddOption("May");
        Gallery.demoLong.AddOption("June");
        Gallery.demoLong.AddOption("July");
        Gallery.demoLong.AddOption("August");
        Gallery.demoLong.AddOption("September");
        Gallery.demoLong.AddOption("October");
        Gallery.demoLong.AddOption("November");
        Gallery.demoLong.AddOption("December");
        Gallery.demoCarousel = CarouselAnim.Create();
        Gallery.demoCarBasic = SignalInt.Create(0);
        Gallery.demoCar2 = SignalInt.Create(0);
        Gallery.carAnim2 = CarouselAnim.Create();
        Gallery.demoVList = VirtualList.Create();
        int vli = 0;
        while (vli < 2000) {
            Gallery.demoVList.Add("Row " + Convert.ToString(vli + 1) + " · virtualized");
            vli = vli + 1;
        }
        Gallery.selected = SignalInt.Create(0);
        Gallery.navScroll = SignalInt.Create(0);
        Gallery.codeTab = SignalInt.Create(0);
        Gallery.detailView = ScrollView.Create();
        Gallery.detailView.SetEdgeInset(true);
        Gallery.detailContentH = SignalInt.Create(0);
        Gallery.codeScroll = SignalInt.Create(0);
        Gallery.navView = ScrollView.Create();
        Gallery.tbLine = Tabs.Create(Tabs.Line());
        Gallery.tbLine.Add("Overview", false);
        Gallery.tbLine.Add("API", false);
        Gallery.tbLine.Add("Examples", false);
        Gallery.tbSeg = Tabs.Create(Tabs.Segment());
        Gallery.tbSeg.Add("Day", false);
        Gallery.tbSeg.Add("Week", false);
        Gallery.tbSeg.Add("Month", false);
        // Card style: closable tabs + a trailing "+" to add tabs, with enough
        // tabs to overflow the demo width (chevrons / wheel scroll / right-click
        // context menu all reachable).
        Gallery.tbCard = Tabs.Create(Tabs.Card());
        Gallery.tbCard.SetShowAdd(true);
        Gallery.tbCard.Add("index.zan", true);
        Gallery.tbCard.Add("parser.c", true);
        Gallery.tbCard.Add("irgen.c", true);
        Gallery.tbCard.Add("Render.zan", true);
        Gallery.tbCard.Add("ScrollView.zan", true);
        Gallery.tbCard.Add("Tabs.zan", true);
        // Vertical rail: header strip on the side, page content drawn separately.
        Gallery.tbVert = Tabs.CreateVertical(Tabs.Line());
        Gallery.tbVert.Add("Files", false);
        Gallery.tbVert.Add("Search", false);
        Gallery.tbVert.Add("Source Control", false);
        Gallery.tbVert.Add("Run", false);
        Gallery.selHas = false;
        Gallery.selDrag = false;
        Gallery.demoTags = new List<string>();
        Gallery.demoTags.Add("Design"); Gallery.demoTags.Add("Frontend");
        Gallery.demoTags.Add("Urgent");
        List<string> lowOpts = new List<string>();
        lowOpts.Add("Default"); lowOpts.Add("Success"); lowOpts.Add("Warning");
        Gallery.demoSelectLow = Select.Bind(lowOpts, Gallery.demoInt, "Choose a state");
        List<string> ddItems = new List<string>();
        ddItems.Add("Edit"); ddItems.Add("Duplicate"); ddItems.Add("Delete");
        Gallery.demoDropdown = Dropdown.Create("Actions", ddItems);
        Gallery.demoPopover = Popover.Create("More info",
            "Popover", "Anchored, word-wrapped content that stays on screen and blocks clicks to the widgets beneath it.", app.Scale(260));
        Gallery.filePicker = FilePicker.Create();
        Gallery.pickerResult = "";
        Gallery.pendingPicker = "";
        Gallery.copiedIcon = "";
        Gallery.demoTableState = DataTableState.Create();
        Gallery.demoLayers = new List<LayerState>();
        Gallery.layerSeq = 0;
        Gallery.dlgAlert = LayerState.Alert("Notice", "Your changes have been saved.", 1);
        Gallery.dlgConfirm = LayerState.Confirm("Please confirm", "Delete this item permanently?", 2);
        Gallery.dlgPrompt = LayerState.Prompt("Rename item", "new name");
        Gallery.tipsOn = SignalBool.Create(false);
        Gallery.tipClickOn = SignalBool.Create(false);
        Gallery.pagePill = SignalInt.Create(2);
        Gallery.pageSmall = SignalInt.Create(3);
        Gallery.pageSimple = SignalInt.Create(1);
        Gallery.scrollOff = SignalInt.Create(0);
        Gallery.tipScroll = SignalInt.Create(0);
        Gallery.photosOpen = SignalBool.Create(false);
        Gallery.loadStartMs = 0;
        Gallery.photoIdx = SignalInt.Create(0);
        Gallery.photoAnim = CarouselAnim.Create();
        Gallery.photoSlides = new List<string>();
        Gallery.photoSlides.Add("Aurora");
        Gallery.photoSlides.Add("Canyon");
        Gallery.photoSlides.Add("Harbor");
        Gallery.photoSlides.Add("Meadow");
        Gallery.photoSlides.Add("Skyline");
        Gallery.popupResult = "";
        Gallery.copiedFrame = 0;
        Gallery.apiSelKind = 0;
        Gallery.apiSelA = 0;
        Gallery.apiSelB = 0;
        Gallery.apiSelDrag = false;
        Gallery.apiCopiedFrame = 0;
        Gallery.designer = Designer.Create();
        Gallery.designer.Seed(app);

        // Bilingual + persistent demo models.
        Gallery.lang = SignalInt.Create(0);
        Gallery.tabViewLabels = new List<string>();
        Gallery.tabViewLabels.Add("main.zan");
        Gallery.tabViewLabels.Add("gui.zan");
        Gallery.tabViewLabels.Add("README.md");
        Gallery.tabViewSeq = 0;
        Gallery.splitVFirst = SignalInt.Create(app.Scale(150));
        Gallery.splitHFirst = SignalInt.Create(app.Scale(70));
        Gallery.treeSel = SignalInt.Create(2);
        Gallery.treeNodes = Gallery.BuildTree();
        Gallery.treeMenuOpen = SignalBool.Create(false);
        Gallery.treeMenuAction = SignalInt.Create(0 - 1);
        Gallery.treeMenuSub = SignalInt.Create(0 - 1);
        Gallery.treeMenuX = 0;
        Gallery.treeMenuY = 0;
        Gallery.treeMenuNode = 0 - 1;
        Gallery.treeMenuBaseId = WidgetId.Block(256);
        Gallery.ribbonTab = SignalInt.Create(0);
        Gallery.wizName = Input.Bind(SignalString.Create("MyApp"), "project name");
        Gallery.wizLoc = Input.Bind(SignalString.Create("d:/projects"), "location");
        Gallery.wizSel = SignalInt.Create(1);
        Gallery.fbScroll = SignalInt.Create(0);
        Gallery.navSearch = Input.Bind(SignalString.Create(""), "Search components");

        Gallery.comps = new List<Comp>();
        Gallery.BuildComps(Gallery.comps);

        // Title-bar skin picker is now a built-in window feature: App.Create/
        // CreateDark call EnableSkins() so the theme caption button is the
        // shared Theme.PresetNames dropdown and App applies the pick itself.
        Gallery.app = app;
        // Optional deep-link: `gallery_test.exe <ComponentName>` lands directly
        // on that component (used for screenshot/verification and handy nav).
        if (Environment.ArgCount() > 0) {
            string want = Environment.ArgAt(0);
            int ci = 0;
            while (ci < Gallery.comps.Count) {
                if (Gallery.comps[ci].name == want) {
                    Gallery.selected.Set(ci);
                    ci = Gallery.comps.Count;
                } else {
                    ci = ci + 1;
                }
            }
            // Second arg "open" pre-opens the selected popup demo so its
            // open state can be captured for verification screenshots.
            int ti = 0;
            while (ti < Environment.ArgCount()) {
                string a = Environment.ArgAt(ti);
                if (a == "light") { Gallery.SelectTheme(app, 1); }
                else if (a == "dark") { Gallery.SelectTheme(app, 0); }
                else if (a == "liquidglass") { Gallery.SelectTheme(app, 2); }
                else if (a == "custom") { Gallery.designer.ScrollPaletteToEnd(); }
                else if (a == "glass") { Gallery.SelectTheme(app, 2); }
                else if (a == "neon") { Gallery.SelectTheme(app, 3); }
                else if (a == "brutalism") { Gallery.SelectTheme(app, 4); }
                else if (a == "chinese") { Gallery.SelectTheme(app, 5); }
                ti = ti + 1;
            }
            if (Environment.ArgCount() > 1 && Environment.ArgAt(1) == "open") {
                if (want == "Layer") {
                    string st = "window";
                    if (Environment.ArgCount() > 2) { st = Environment.ArgAt(2); }
                    if (st == "alert") { Gallery.dlgAlert.Open(); }
                    else if (st == "confirm") { Gallery.dlgConfirm.Open(); }
                    else if (st == "prompt") { Gallery.dlgPrompt.Open(); }
                    else if (st == "msg") {
                        Layer.Msg("Saved successfully", 3);
                        Layer.Msg("Unsaved changes", 4);
                        Layer.Msg("Network error", 5);
                    } else if (st == "notify") {
                        Layer.Notify("Build completed", 3);
                        Layer.Notify("New version available", 2);
                    } else if (st == "load") {
                        Gallery.loadStartMs = Window.GetTickMs();
                    } else if (st == "tips") {
                        Gallery.tipsOn.Set(true);
                    } else if (st == "photos") {
                        Gallery.photosOpen.Set(true);
                    } else {
                        Gallery.SpawnLayer(app);
                        if (st == "two") { Gallery.SpawnLayer(app); }
                    }
                } else if (want == "FilePicker") {
                    Gallery.pendingPicker = "file";
                    if (Environment.ArgCount() > 2) {
                        Gallery.pendingPicker = Environment.ArgAt(2);
                    }
                } else if (want == "Dropdown") {
                    Gallery.demoDropdown.Open();
                }
            }
        }

        // Delegate/event demo wiring: keep the app handle for background threads
        // and register the click handler once (retained, like OnClick += ...).
        Gallery.app = app;
        Gallery.evtValue = SignalInt.Create(0);
        Gallery.evtRunning = SignalBool.Create(false);
        Gallery.evtClicks = 0;
        Gallery.evtButton = Button.Primary("Click me");
        Gallery.evtButton.Click += Gallery.OnDemoClick;
        Gallery.evtStartButton = Button.Primary("Start background task");
        Gallery.evtStartButton.Click += Gallery.StartTask;

        app.Show();
        // Freeze the id baseline after all retained ids (chrome etc.) exist, so
        // the per-frame ResetFrame() below never reissues one of them.
        WidgetId.Mark();
        // Deep-link dialog opens are deferred to here: paint the main window once
        // so it owns the OS foreground, then open the child so its show-time
        // focus grab succeeds (opening before the parent is foreground lets the
        // parent steal focus straight back).
        if (Gallery.pendingPicker != "") {
            app.BeginFrame();
            WidgetId.ResetFrame();
            Gallery.Render(app);
            app.RenderChrome("Zan GUI Components");
            app.PresentFrame();
            if (Gallery.pendingPicker == "folder") {
                Gallery.filePicker.BeginFolder("", "Open folder");
            } else if (Gallery.pendingPicker == "save") {
                Gallery.filePicker.BeginSaveFile("", ".zan", "untitled.zan", "Save file");
            } else {
                Gallery.filePicker.BeginOpenFile("", ".zan", "Open file");
            }
            Gallery.pendingPicker = "";
        }
        while (app.isRunning) {
            // One shared event pump drives BOTH the main window and the
            // FilePicker's child dialog window (open/save file/folder). Poll (to
            // keep animating) when either wants a repaint; otherwise block.
            Gallery.filePicker.ApplySkin(app.ThemeMenuIndex());
            int r;
            if (Gallery.filePicker.NeedsRedraw()
                || (!Gallery.filePicker.IsOpen() && app.needsRedraw)) {
                int since = Window.GetTickMs() - app.lastPresentMs;
                if (app.lastPresentMs > 0 && since < 16) {
                    Window.SleepMs(16 - since);
                }
                r = app.window.PollEvent();
            } else if (!Gallery.filePicker.IsOpen()
                       && (app.animNextMs >= 0 || app.fxNextMs >= 0)) {
                // A throttled animation (spinner/skeleton) and/or the skin
                // effect layer wants its next frame; idle until the earliest
                // deadline, but poll in slices so input still wakes the loop
                // promptly. An effect-only tick is served in place by
                // App.FxPresent (frame-snapshot restore + re-composite).
                r = 1;
                bool waiting = true;
                while (waiting) {
                    int now = Window.GetTickMs();
                    int deadline = app.animNextMs;
                    if (deadline < 0
                        || (app.fxNextMs >= 0 && app.fxNextMs < deadline)) {
                        deadline = app.fxNextMs;
                    }
                    if (deadline < 0) { waiting = false; }
                    else if (now >= deadline) {
                        bool fxOnly = app.animNextMs < 0 || now < app.animNextMs;
                        if (!(fxOnly && app.FxPresent())) {
                            app.RequestRedraw();
                            waiting = false;
                        }
                    } else {
                        int remain = deadline - now;
                        if (remain > 15) { remain = 15; }
                        Window.SleepMs(remain);
                        r = app.window.PollEvent();
                        if (r != 1) { waiting = false; }
                    }
                }
            } else {
                r = app.window.WaitEvent();
            }
            if (r < 0) { break; }
            app.DrainPosts();

            int evh = Window.EventHwnd();
            int kind = app.window.EventKind();

            if (kind == 8) {
                if (Gallery.filePicker.OwnsWindow(evh)) {
                    Gallery.filePicker.ApplyEvent(evh);
                } else if (evh == app.WindowHandle()) {
                    break;
                }
            } else if (Gallery.filePicker.OwnsWindow(evh)) {
                // Route each input frame to whichever window OWNS it (by native
                // hwnd), not merely to the dialog whenever it is open. Native
                // events already carry their originating window, and each App
                // only acts on its own (App.ApplyEvent ignores foreign hwnds),
                // so the parent stays fully responsive while the child dialog is
                // open and there is still no cross-window click-through.
                Gallery.filePicker.ApplyEvent(evh);
            } else {
                // The gallery handles wheel scrolling and code selection inside
                // its own Render pass, so it paints on every input event rather
                // than only when the framework flags a repaint. Pointer motion
                // (kind 1) is throttled to ~30fps so moving over a busy page (or
                // the glass theme's per-frame blur) can't peg the CPU.
                bool inputEv = kind == 2 || kind == 3 || kind == 13
                    || kind == 4 || kind == 6;
                bool doFrame = true;
                if (!app.needsRedraw && !inputEv) {
                    if (kind != 1) {
                        doFrame = false;
                    } else {
                        int nowMotion = Window.GetTickMs();
                        if (nowMotion - Gallery.lastMotionMs < 33) {
                            doFrame = false;
                        } else {
                            Gallery.lastMotionMs = nowMotion;
                        }
                    }
                }
                app.ApplyEvent(evh);
                if (doFrame) {
                    app.BeginFrame();
                    // Pure immediate-mode page: every preview widget is rebuilt
                    // each frame, so rewind the widget-id counter here to keep
                    // ids stable across frames -- otherwise hover/press/click
                    // never match the pointer target resolved last frame.
                    WidgetId.ResetFrame();
                    Gallery.Render(app);
                    app.RenderChrome("Zan GUI Components");
                    app.PresentFrame();
                }
            }

            // Paint the dialog window (if open) and harvest its result.
            Gallery.filePicker.RenderWindow();
            int pr = Gallery.filePicker.TakeResult();
            if (pr == 1) {
                Gallery.pickerResult = Gallery.filePicker.SelectedPath();
                app.RequestRedraw();
            } else if (pr == 2) {
                app.RequestRedraw();
            }
        }
    }

    // ------------------------------------------------------------------
    // Delegate / thread-safe event demo callbacks
    // ------------------------------------------------------------------

    // Handler registered with `button.Click += ...`. Fires on the UI thread.
    static void OnDemoClick() {
        Gallery.evtClicks = Gallery.evtClicks + 1;
    }

    // Click handler registered on the EventHub. Spawns a background worker
    // thread once (ignored while one is already running).
    static void StartTask() {
        if (!Gallery.evtRunning.Get()) {
            Gallery.evtValue.Set(0);
            Gallery.evtRunning.Set(true);
            Thread.Start(Gallery.EventsWorker);
        }
    }

    // Runs on a background OS thread: it must NOT touch UI state directly, so it
    // hands each update back to the UI thread with app.Post (Control.Invoke).
    static void EventsWorker() {
        int i = 0;
        while (i < 5) {
            Thread.Sleep(140);
            Gallery.app.Post(Gallery.Tick);
            i = i + 1;
        }
        Gallery.app.Post(Gallery.Finish);
    }

    // These run on the UI thread when the queue is drained each frame.
    static void Tick() { Gallery.evtValue.Set(Gallery.evtValue.Get() + 1); }
    static void Finish() { Gallery.evtRunning.Set(false); }

    // ------------------------------------------------------------------
    // Theme switching
    // ------------------------------------------------------------------

    /// Programmatic switch (deep-link args): applies the built-in skin and keeps
    /// the title-bar picker model in sync (App owns the index -> Theme mapping).
    static void SelectTheme(App app, int i) {
        app.ApplySkin(i);
    }

    // ------------------------------------------------------------------
    // Bilingual helpers
    // ------------------------------------------------------------------

    /// Pick the English or Chinese string for the current demo language.
    static string T(string en, string zh) {
        if (Gallery.lang.Get() == 1) { return zh; }
        return en;
    }

    /// Switch language and rebuild the catalog so descriptions, snippets and
    /// demo data (all built through T() at catalog time) pick up the new
    /// language. Live widget state lives in stable static signals, so it is
    /// untouched by the rebuild.
    static void SetLang(int lang) {
        if (Gallery.lang.Get() == lang) { return; }
        Gallery.lang.Set(lang);
        Gallery.comps = new List<Comp>();
        Gallery.BuildComps(Gallery.comps);
    }

    /// One cell of the EN / 中 language toggle.
    static void RenderLangChip(App app, Canvas c, Theme t, int x, int y,
                               int w, int h, string label, bool active) {
        int bg = t.bgTertiary;
        int fg = t.textSecondary;
        if (active) { bg = t.primary; fg = t.textInverse; }
        c.FillRoundRect(x, y, w, h, app.Scale(4), bg);
        int tw = Canvas.MeasureText(label, t.fontSizeSmall);
        c.DrawText(x + (w - tw) / 2, y + app.Scale(3), label, fg, t.fontSizeSmall);
    }

    /// Keep the child-window widgets (Wizard / FilePicker draw in their own
    /// windows) on the same language as the gallery.
    static void SyncLang() {
        Wizard.lang = Gallery.lang.Get();
        FilePicker.lang = Gallery.lang.Get();
        Tabs.lang = Gallery.lang.Get();
    }

    /// Seed tree for the TreeView demo: a small but multi-level project tree
    /// exercising nested directories, mixed file icons, expand/collapse and
    /// selection. Built once so toggles persist across frames.
    static List<TreeNode> BuildTree() {
        List<TreeNode> n = new List<TreeNode>();
        n.Add(TreeNode.Dir("src", 0, true));
        n.Add(TreeNode.Dir("compiler", 1, true));
        n.Add(TreeNode.FileIcon("lexer.c", 2, "file"));
        n.Add(TreeNode.FileIcon("parser.c", 2, "file"));
        n.Add(TreeNode.FileIcon("irgen.c", 2, "file"));
        n.Add(TreeNode.Dir("gui", 1, false));
        n.Add(TreeNode.FileIcon("App.zan", 2, "file"));
        n.Add(TreeNode.FileIcon("Canvas.zan", 2, "file"));
        n.Add(TreeNode.FileIcon("main.zan", 1, "file"));
        n.Add(TreeNode.Dir("tests", 0, false));
        n.Add(TreeNode.FileIcon("lexer_test.zan", 1, "file"));
        n.Add(TreeNode.FileIcon("parser_test.zan", 1, "file"));
        n.Add(TreeNode.FileIcon("README.md", 0, "file"));
        n.Add(TreeNode.FileIcon("build.ps1", 0, "file"));
        return n;
    }

    // ------------------------------------------------------------------
    // Layout
    // ------------------------------------------------------------------

    static void Render(App app) {
        Gallery.SyncLang();
        Canvas c = app.canvas;
        Theme t = app.theme;
        int top = app.titlebarH;
        int w = c.Width();
        int h = c.Height();
        Rect area = Rect.Create(0, top, w, h - top);
        // Themed backdrop (gradient/glass wallpaper or flat fill) is a built-in
        // window feature now, so every window renders skins identically.
        app.RenderBackground(area.x, area.y, area.width, area.height, 0);

        int sw = app.Scale(272);
        Rect content = Rect.Create(0, top, w, h - top);
        Gallery.RenderNav(app, c, t, content, sw);
        Gallery.RenderDetail(app, c, t, content, sw);
    }

    /// Left navigation: category headers interleaved with clickable component
    /// rows, wheel-scrollable, with the active row highlighted.
    static void RenderNav(App app, Canvas c, Theme t, Rect area, int sw) {
        c.FillRect(area.x, area.y, sw, area.height, t.bgSecondary);
        c.FillRect(area.x + sw - 1, area.y, 1, area.height, t.divider);

        int pad = app.Scale(14);
        c.DrawText(area.x + pad, area.y + app.Scale(20),
            Gallery.T("COMPONENTS", "组件"),
            t.textTertiary, t.fontSizeSmall);

        // EN / 中 language toggle, right-aligned in the header row.
        int lgW = app.Scale(34);
        int lgH = app.Scale(20);
        int lgY = area.y + app.Scale(15);
        int enX = area.x + sw - pad - lgW * 2 - app.Scale(2);
        int zhX = area.x + sw - pad - lgW;
        int curLang = Gallery.lang.Get();
        Gallery.RenderLangChip(app, c, t, enX, lgY, lgW, lgH, "EN", curLang == 0);
        Gallery.RenderLangChip(app, c, t, zhX, lgY, lgW, lgH, "中", curLang == 1);
        bool navClick = app.window.EventKind() == 3;
        if (navClick) {
            if (app.mouseX >= enX && app.mouseX < enX + lgW
                    && app.mouseY >= lgY && app.mouseY < lgY + lgH) {
                Gallery.SetLang(0); app.RequestRedraw();
            } else if (app.mouseX >= zhX && app.mouseX < zhX + lgW
                    && app.mouseY >= lgY && app.mouseY < lgY + lgH) {
                Gallery.SetLang(1); app.RequestRedraw();
            }
        }

        // Search box: filters components by name or category.
        int searchY = area.y + app.Scale(48);
        Gallery.navSearch.Render(app, area.x + pad, searchY,
            sw - pad * 2, app.Scale(30));
        string q = Gallery.navSearch.GetText();

        // Build display rows: -1 marks a category header row. When searching we
        // only keep matching components (and headers that still have children).
        List<int> rowComp = new List<int>();
        List<string> rowText = new List<string>();
        string lastCat = "";
        int i = 0;
        while (i < Gallery.comps.Count) {
            Comp e = Gallery.comps[i];
            bool match = q.Length == 0
                || Gallery.ContainsCI(e.name, q)
                || Gallery.ContainsCI(e.category, q);
            if (match) {
                if (e.category != lastCat) {
                    rowComp.Add(0 - 1);
                    rowText.Add(e.category);
                    lastCat = e.category;
                }
                rowComp.Add(i);
                rowText.Add(e.name);
            }
            i = i + 1;
        }

        int listTop = area.y + app.Scale(92);
        int listBottom = area.y + area.height - app.Scale(8);
        int rowH = app.Scale(26);
        int viewH = listBottom - listTop;
        int contentH = rowComp.Count * rowH;

        // The ScrollView owns wheel handling, clipping and the scrollbar; the
        // list just draws every row at its natural position minus the returned
        // offset and lets the container clip whatever falls outside.
        Rect view = Rect.Create(area.x, listTop, sw, viewH);
        int dy = Gallery.navView.Begin(app, view, contentH);

        int sel = Gallery.selected.Get();
        bool click = app.window.EventKind() == 3;
        int sx = area.x + pad;
        int swid = sw - pad * 2;
        int idx = 0;
        while (idx < rowComp.Count) {
            int ry = listTop + idx * rowH - dy;
            if (ry + rowH > listTop && ry < listBottom) {
                int d = rowComp[idx];
                if (d < 0) {
                    c.DrawText(sx, ry + app.Scale(8), rowText[idx],
                        t.textTertiary, t.fontSizeSmall);
                } else {
                    bool selRow = d == sel;
                    bool hot = !app.PointerCaptured()
                        && app.mouseX >= area.x && app.mouseX < area.x + sw
                        && app.mouseY >= listTop && app.mouseY < listBottom
                        && app.mouseY >= ry && app.mouseY < ry + rowH;
                    if (selRow) {
                        c.FillRoundRect(sx - app.Scale(4), ry,
                            swid + app.Scale(8), rowH - app.Scale(2),
                            app.Scale(4), t.primary);
                    } else if (hot) {
                        c.FillRoundRect(sx - app.Scale(4), ry,
                            swid + app.Scale(8), rowH - app.Scale(2),
                            app.Scale(4), t.bgHover);
                    }
                    int tc = t.textPrimary;
                    if (selRow) { tc = t.textInverse; }
                    c.DrawText(sx + app.Scale(8), ry + app.Scale(5),
                        rowText[idx], tc, t.fontSizeSmall);
                    if (click && hot) {
                        Gallery.selected.Set(d);
                        Gallery.codeScroll.Set(0);
                        Gallery.detailView.ScrollTo(0);
                        Gallery.selHas = false;
                        Gallery.selDrag = false;
                        Gallery.apiSelKind = 0;
                        Gallery.apiSelDrag = false;
                        app.RequestRedraw();
                    }
                }
            }
            idx = idx + 1;
        }

        Gallery.navView.End(app, view);
    }

    /// Effective demo cards for a component: its own list, or a single card
    /// synthesised from the legacy desc/code/json fields.
    static List<Demo> EffectiveDemos(Comp e) {
        if (e.demos.Count > 0) { return e.demos; }
        // Synthesise the single card once and retain it on the Comp. Building a
        // fresh Demo each frame would reset its per-card tab (and render cache)
        // every frame, so toggling Zan/JSON would never stick.
        e.demos.Add(Demo.Create("Basic usage", "", e.name,
            Gallery.PreviewHeight(e.name), e.code, e.json));
        return e.demos;
    }

    static int CardCodeH(App app, Theme t, Demo d, int tab) {
        string src = d.code;
        if (tab == 1) {
            if (d.json != "") { src = d.json; }
            else { src = "// x"; }
        }
        int lineH = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(4);
        return app.Scale(28) + CodeEditor.SplitLines(src).Count * lineH
            + app.Scale(16);
    }

    static int DescBlockH(App app, Theme t, string desc, int cw) {
        if (desc == "") { return 0; }
        int lineH = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(4);
        return Gallery.WrapText(desc, cw, t.fontSizeSmall).Count * lineH;
    }

    static int CardH(App app, Theme t, Demo d, int cw, int tab) {
        int h = app.Scale(22);
        int db = Gallery.DescBlockH(app, t, d.desc, cw);
        if (db > 0) { h = h + db + app.Scale(4); }
        h = h + app.Scale(10) + app.Scale(d.previewH) + app.Scale(12)
            + Gallery.CardCodeH(app, t, d, tab);
        return h;
    }

    static int TableH(App app, Theme t, List<ApiRow> rows) {
        if (rows.Count == 0) { return 0; }
        return app.Scale(30) + app.Scale(26) + rows.Count * app.Scale(24)
            + app.Scale(16);
    }

    /// Exact laid-out height of one demo card, matching the draw order in
    /// RenderDetail. Reads the wrap/highlight cache (call EnsureCache first),
    /// so it is cheap enough to run for every card each frame -- it lets the
    /// detail page cull off-screen cards instead of drawing then clipping them.
    static int DemoCardHeight(App app, Theme t, Demo d, int cw) {
        int lineH = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(4);
        int h = app.Scale(22);
        if (d.desc != "") {
            h = h + d.cacheDescLines.Count * lineH + app.Scale(4);
        }
        h = h + app.Scale(10)
            + Gallery.PreviewBoxH(app, d.previewId, d.previewH, cw)
            + app.Scale(12);
        int panelH = app.Scale(28) + d.cacheCodeLines.Count * lineH
            + app.Scale(16);
        h = h + panelH + app.Scale(26);
        return h;
    }

    /// Right detail pane: scrollable Naive-UI style page -- title, page
    /// description, a stack of demo cards (each with its own preview and
    /// Zan/JSON code), and Properties / Events API tables at the bottom.
    static void RenderDetail(App app, Canvas c, Theme t, Rect area, int sw) {
        int sel = Gallery.selected.Get();
        if (sel < 0 || sel >= Gallery.comps.Count) { return; }
        Comp e = Gallery.comps[sel];

        int cx = area.x + sw + app.Scale(28);
        int cw = area.x + area.width - app.Scale(28) - cx - app.Scale(14);
        if (cw < app.Scale(220)) { cw = app.Scale(220); }
        int contentTop = area.y + app.Scale(26);
        int viewBottom = area.y + area.height - app.Scale(8);
        int viewH = viewBottom - contentTop;
        Gallery.detailClipTop = contentTop;
        Gallery.detailClipBottom = viewBottom;
        List<Demo> demos = Gallery.EffectiveDemos(e);

        int bodyLineH = Canvas.FontHeight(t.fontSizeMedium) + app.Scale(4);
        List<string> pl = e.DescLines(cw, t.fontSizeMedium);

        // The whole page lives inside a ScrollView: that parent container owns
        // the wheel, the clip and the scrollbar and shows it automatically when
        // the content (measured last frame) overflows the viewport -- demos and
        // previews never handle scrolling themselves.
        int clipX = cx - app.Scale(12);
        Rect view = Rect.Create(clipX, contentTop,
            area.x + area.width - clipX, viewH);
        int scroll = Gallery.detailView.Begin(app, view,
            Gallery.detailContentH.Get());
        int yy = contentTop - scroll;

        c.DrawText(cx, yy, e.category, t.info, t.fontSizeSmall);
        yy = yy + app.Scale(20);
        c.DrawText(cx, yy, e.name, t.textPrimary, t.fontSizeLarge);
        yy = yy + app.Scale(30);
        c.FillRect(cx, yy, cw, 1, t.divider);
        yy = yy + app.Scale(16);
        int pi = 0;
        while (pi < pl.Count) {
            c.DrawText(cx, yy, pl[pi], t.textSecondary, t.fontSizeMedium);
            yy = yy + bodyLineH;
            pi = pi + 1;
        }
        yy = yy + app.Scale(14);

        int overlayPX = 0; int overlayPY = 0; int overlayPW = 0;
        bool haveOverlay = false;
        int dj = 0;
        while (dj < demos.Count) {
            Demo d = demos[dj];
            d.EnsureCache(app, t, cw, d.tab);
            int cardTop = yy;
            int cardBottom = cardTop + Gallery.DemoCardHeight(app, t, d, cw);
            // Viewport culling: a card fully above/below the visible area still
            // costs one GDI text render + alpha blend per DrawText if drawn, so
            // skip its draws entirely and just advance past it. This keeps
            // scrolling cheap regardless of how many cards the page has.
            if (cardBottom >= contentTop && cardTop <= viewBottom) {
                c.DrawText(cx, yy, d.title, t.textPrimary, t.fontSizeMedium);
                yy = yy + app.Scale(22);
                if (d.desc != "") {
                    int dLineH = Canvas.FontHeight(t.fontSizeSmall) + app.Scale(4);
                    List<string> dl = d.cacheDescLines;
                    int ddi = 0;
                    while (ddi < dl.Count) {
                        c.DrawText(cx, yy, dl[ddi], t.textSecondary,
                            t.fontSizeSmall);
                        yy = yy + dLineH;
                        ddi = ddi + 1;
                    }
                    yy = yy + app.Scale(4);
                }
                yy = yy + app.Scale(10);
                int pvY = yy;
                Gallery.RenderPreview(app, c, t, d.previewId, cx, pvY, cw,
                    d.previewH);
                if (Gallery.IsOverlayComp(d.previewId)) {
                    overlayPX = cx; overlayPY = pvY; overlayPW = cw;
                    haveOverlay = true;
                }
                yy = yy + Gallery.PreviewBoxH(app, d.previewId, d.previewH, cw)
                    + app.Scale(12);
                Gallery.RenderCardCode(app, c, t, d, cx, yy, cw, d.tab);
            }
            yy = cardBottom;
            dj = dj + 1;
        }

        int propsH = Gallery.TableH(app, t, e.props);
        if (propsH > 0 && yy + propsH >= contentTop && yy <= viewBottom) {
            Gallery.RenderApiTable(app, c, t, "Properties", e.props, true,
                cx, yy, cw);
        }
        yy = yy + propsH;
        int eventsH = Gallery.TableH(app, t, e.events);
        if (eventsH > 0 && yy + eventsH >= contentTop && yy <= viewBottom) {
            Gallery.RenderApiTable(app, c, t, "Events", e.events, false,
                cx, yy, cw);
        }
        yy = yy + eventsH;
        yy = yy + app.Scale(20);

        int contentH = yy - (contentTop - scroll);
        Gallery.detailView.End(app, view);

        int prevH = Gallery.detailContentH.Get();
        if (contentH != prevH) {
            Gallery.detailContentH.Set(contentH);
            app.RequestRedraw();
        }

        if (haveOverlay) {
            Gallery.RenderOverlay(app, c, t, e.name, overlayPX, overlayPY,
                overlayPW);
        }
    }

    /// Case-insensitive substring test. The Zan string type has no reliable
    /// ToLower()/Contains(), so fold ASCII case manually (mirrors DataTable).
    static int FoldC(int cc) {
        if (cc >= 65 && cc <= 90) { return cc + 32; }
        return cc;
    }

    static bool MatchAt(string hay, string needle, int off) {
        int j = 0;
        while (j < needle.Length) {
            char ch = hay[off + j];
            char cn = needle[j];
            if (Gallery.FoldC((int)ch) != Gallery.FoldC((int)cn)) { return false; }
            j = j + 1;
        }
        return true;
    }

    static bool ContainsCI(string hay, string needle) {
        int nl = needle.Length;
        int hl = hay.Length;
        if (nl == 0) { return true; }
        if (nl > hl) { return false; }
        int i = 0;
        while (i <= hl - nl) {
            if (Gallery.MatchAt(hay, needle, i)) { return true; }
            i = i + 1;
        }
        return false;
    }

    /// One API row as a tab-separated line (used for selection copy).
    static string ApiRowText(ApiRow r, bool isProps) {
        if (isProps) {
            return r.name + "\t" + r.type + "\t" + r.deflt + "\t" + r.desc;
        }
        return r.name + "\t" + r.type + "\t" + r.desc;
    }

    /// Bottom API table (Properties or Events). Returns the y below the table.
    /// Rows are drag-selectable and a Copy button yields the selected rows (or
    /// the whole table) as tab-separated text.
    static int RenderApiTable(App app, Canvas c, Theme t, string title,
            List<ApiRow> rows, bool isProps, int cx, int yy, int cw) {
        if (rows.Count == 0) { return yy; }
        int kind = 2;
        if (isProps) { kind = 1; }
        int fh = t.fontSizeSmall;
        c.DrawText(cx, yy, title, t.textPrimary, t.fontSizeMedium);

        // Copy button on the title row (right-aligned).
        int cpW = app.Scale(74);
        int cpH = app.Scale(20);
        int cpX = cx + cw - cpW;
        int cpY = yy - app.Scale(2);
        bool cpHot = !app.PointerCaptured()
            && app.mouseX >= cpX && app.mouseX < cpX + cpW
            && app.mouseY >= cpY && app.mouseY < cpY + cpH;
        int cpBg = t.bgTertiary;
        if (cpHot) { cpBg = t.bgHover; }
        c.FillRoundRect(cpX, cpY, cpW, cpH, app.Scale(3), cpBg);
        int cpIconSz = app.Scale(13);
        string cpLabel = Gallery.T("Copy", "复制");
        int cpTxtW = Canvas.MeasureText(cpLabel, fh);
        int cpGap = app.Scale(6);
        int cpContentX = cpX + (cpW - (cpIconSz + cpGap + cpTxtW)) / 2;
        Icon.Draw(c, "copy", cpContentX, cpY + (cpH - cpIconSz) / 2,
            cpIconSz, t.textSecondary);
        c.DrawText(cpContentX + cpIconSz + cpGap,
            cpY + (cpH - Canvas.FontHeight(fh)) / 2, cpLabel, t.textSecondary, fh);

        yy = yy + app.Scale(30);
        int nameX = cx + app.Scale(6);
        int col1 = cx + cw * 24 / 100;
        int col2 = cx + cw * 44 / 100;
        int descX = cx + cw * 62 / 100;
        if (!isProps) { descX = cx + cw * 44 / 100; }
        c.FillRect(cx, yy, cw, app.Scale(26), t.bgSecondary);
        c.DrawText(nameX, yy + app.Scale(6), Gallery.T("Name", "名称"),
            t.textTertiary, fh);
        if (isProps) {
            c.DrawText(col1 + app.Scale(6), yy + app.Scale(6),
                Gallery.T("Type", "类型"), t.textTertiary, fh);
            c.DrawText(col2 + app.Scale(6), yy + app.Scale(6),
                Gallery.T("Default", "默认值"), t.textTertiary, fh);
        } else {
            c.DrawText(col1 + app.Scale(6), yy + app.Scale(6),
                Gallery.T("Signature", "签名"), t.textTertiary, fh);
        }
        c.DrawText(descX + app.Scale(6), yy + app.Scale(6),
            Gallery.T("Description", "说明"), t.textTertiary, fh);
        yy = yy + app.Scale(26);
        int rowH = app.Scale(24);
        int bodyTop = yy;

        // Drag selection over the row body (row-granular).
        int bodyBottom = bodyTop + rows.Count * rowH;
        int ek = app.window.EventKind();
        bool inBody = !app.PointerCaptured()
            && app.mouseX >= cx && app.mouseX < cx + cw
            && app.mouseY >= bodyTop && app.mouseY < bodyBottom;
        if (ek == 2 && inBody) {
            int hitRow = (app.mouseY - bodyTop) / rowH;
            if (hitRow < 0) { hitRow = 0; }
            if (hitRow >= rows.Count) { hitRow = rows.Count - 1; }
            Gallery.apiSelKind = kind;
            Gallery.apiSelA = hitRow;
            Gallery.apiSelB = hitRow;
            Gallery.apiSelDrag = true;
            app.RequestRedraw();
        } else if (ek == 1 && Gallery.apiSelDrag && Gallery.apiSelKind == kind) {
            int hitRow = (app.mouseY - bodyTop) / rowH;
            if (hitRow < 0) { hitRow = 0; }
            if (hitRow >= rows.Count) { hitRow = rows.Count - 1; }
            Gallery.apiSelB = hitRow;
            app.RequestRedraw();
        } else if (ek == 3 && Gallery.apiSelDrag) {
            Gallery.apiSelDrag = false;
            app.RequestRedraw();
        }

        int selLo = Gallery.apiSelA;
        int selHi = Gallery.apiSelB;
        if (selHi < selLo) { selLo = Gallery.apiSelB; selHi = Gallery.apiSelA; }
        bool hasSel = Gallery.apiSelKind == kind;

        int ri = 0;
        while (ri < rows.Count) {
            ApiRow r = rows[ri];
            if (hasSel && ri >= selLo && ri <= selHi) {
                c.FillRect(cx, yy, cw, rowH, 0x553B82F6);
            } else if (ri % 2 == 1) {
                c.FillRect(cx, yy, cw, rowH, t.bgSecondary);
            }
            c.DrawText(nameX, yy + app.Scale(5), r.name, t.textPrimary, fh);
            c.DrawText(col1 + app.Scale(6), yy + app.Scale(5), r.type,
                t.info, fh);
            if (isProps) {
                c.DrawText(col2 + app.Scale(6), yy + app.Scale(5), r.deflt,
                    t.textSecondary, fh);
            }
            c.DrawText(descX + app.Scale(6), yy + app.Scale(5), r.desc,
                t.textSecondary, fh);
            yy = yy + rowH;
            ri = ri + 1;
        }

        // Copy: selected rows for this table, else the whole table.
        if (app.window.EventKind() == 3 && cpHot) {
            int from = 0;
            int to = rows.Count - 1;
            if (hasSel) { from = selLo; to = selHi; }
            string outp = "";
            int k = from;
            while (k <= to) {
                if (k > from) { outp = outp + "\n"; }
                outp = outp + Gallery.ApiRowText(rows[k], isProps);
                k = k + 1;
            }
            Clipboard.SetText(outp);
            Gallery.apiCopiedFrame = 8;
            app.RequestRedraw();
        }

        return yy + app.Scale(16);
    }

    /// Per-card code panel: Zan / JSON tabs, a Copy button (copies the active
    /// tab), line-number gutter and syntax highlighting. Sized to fit all lines
    /// (the whole page scrolls, so the panel never needs its own scrollbar).
    static int RenderCardCode(App app, Canvas c, Theme t, Demo d,
            int cx, int cy, int cw, int tab) {
        d.EnsureCache(app, t, cw, tab);
        string src = d.cacheSrc;
        List<string> codeLines = d.cacheCodeLines;
        int fs = t.fontSizeSmall;
        int codeLineH = Canvas.FontHeight(fs) + app.Scale(4);
        int hdrH = app.Scale(28);
        int panelH = hdrH + codeLines.Count * codeLineH + app.Scale(16);
        c.FillRoundRect(cx, cy, cw, panelH, app.Scale(6), t.bgSecondary);
        c.DrawRect(cx, cy, cw, panelH, t.borderPrimary, 1);
        c.FillRect(cx, cy + hdrH, cw, 1, t.divider);

        int gnW = Canvas.MeasureText(Convert.ToString(codeLines.Count), fs);
        int gutterW = gnW + app.Scale(20);
        int textX = cx + gutterW + app.Scale(8);
        int codeY0 = cy + hdrH + app.Scale(8);
        c.FillRect(cx + 1, cy + hdrH + 1, gutterW, panelH - hdrH - 2, t.bgTertiary);

        int tabY = cy + app.Scale(4);
        int tabH = app.Scale(20);
        int t0W = app.Scale(46);
        int t1W = app.Scale(52);
        int t0X = cx + app.Scale(8);
        int t1X = t0X + t0W + app.Scale(4);
        Gallery.DrawCodeTab(app, c, t, "Zan", t0X, tabY, t0W, tabH, tab == 0);
        Gallery.DrawCodeTab(app, c, t, "JSON", t1X, tabY, t1W, tabH, tab == 1);
        if (app.window.EventKind() == 3 && !app.PointerCaptured()) {
            if (app.mouseX >= t0X && app.mouseX < t0X + t0W
                && app.mouseY >= tabY && app.mouseY < tabY + tabH) {
                d.tab = 0; app.RequestRedraw();
            } else if (app.mouseX >= t1X && app.mouseX < t1X + t1W
                && app.mouseY >= tabY && app.mouseY < tabY + tabH) {
                d.tab = 1; app.RequestRedraw();
            }
        }

        int cpW = app.Scale(74);
        int cpH = app.Scale(20);
        int cpX = cx + cw - cpW - app.Scale(8);
        int cpY = cy + app.Scale(4);
        bool cpHot = !app.PointerCaptured()
            && app.mouseX >= cpX && app.mouseX < cpX + cpW
            && app.mouseY >= cpY && app.mouseY < cpY + cpH;
        int cpBg = t.primary;
        if (cpHot) { cpBg = t.primaryHover; }
        c.FillRoundRect(cpX, cpY, cpW, cpH, app.Scale(3), cpBg);
        // Icon + label vertically centered as one group in the pill.
        int cpIconSz = app.Scale(13);
        int cpTxtW = Canvas.MeasureText("Copy", fs);
        int cpGap = app.Scale(6);
        int cpContentX = cpX + (cpW - (cpIconSz + cpGap + cpTxtW)) / 2;
        Icon.Draw(c, "copy", cpContentX, cpY + (cpH - cpIconSz) / 2,
            cpIconSz, 0xFFFFFFFF);
        c.DrawText(cpContentX + cpIconSz + cpGap,
            cpY + (cpH - Canvas.FontHeight(fs)) / 2, "Copy", 0xFFFFFFFF, fs);
        // This code box owns the selection only if its uid+tab match.
        bool selMine = Gallery.selOwner == d.uid && Gallery.selTab == tab;
        if (app.window.EventKind() == 3 && cpHot) {
            // Copy the current selection when there is one, else the whole snippet.
            string toCopy = src;
            if (selMine && Gallery.SelNonEmpty()) { toCopy = Gallery.SelectedText(codeLines); }
            Clipboard.SetText(toCopy);
            app.RequestRedraw();
        }

        // Drag to select text in the code body: press sets the anchor, moving
        // with the button held extends the selection, release finalises it.
        int textTop = codeY0;
        int textBottom = codeY0 + codeLines.Count * codeLineH;
        int ek = app.window.EventKind();
        bool inCode = !app.PointerCaptured()
            && app.mouseX >= cx && app.mouseX < cx + cw
            && app.mouseY >= textTop && app.mouseY < textBottom;
        if (ek == 2 && inCode) {
            int ll = Gallery.HitLine(codeLines, 0, app.mouseY, codeY0, codeLineH);
            int cc = Gallery.ColAt(codeLines[ll], fs, app.mouseX - textX);
            Gallery.selAL = ll; Gallery.selAC = cc;
            Gallery.selFL = ll; Gallery.selFC = cc;
            Gallery.selDrag = true;
            Gallery.selOwner = d.uid; Gallery.selTab = tab;
            selMine = true;
            app.RequestRedraw();
        } else if (ek == 1 && Gallery.selDrag && selMine) {
            int ll = Gallery.HitLine(codeLines, 0, app.mouseY, codeY0, codeLineH);
            int cc = Gallery.ColAt(codeLines[ll], fs, app.mouseX - textX);
            Gallery.selFL = ll; Gallery.selFC = cc;
            app.RequestRedraw();
        } else if (ek == 3 && Gallery.selDrag && selMine) {
            Gallery.selDrag = false;
            app.RequestRedraw();
        }

        // Normalised selection bounds (start <= end) for the highlight pass.
        // Only the owning box (matching uid+tab) paints the highlight.
        bool showSel = selMine && Gallery.SelNonEmpty();
        int nl0 = Gallery.selAL; int nc0 = Gallery.selAC;
        int nl1 = Gallery.selFL; int nc1 = Gallery.selFC;
        if (nl1 < nl0 || (nl1 == nl0 && nc1 < nc0)) {
            nl0 = Gallery.selFL; nc0 = Gallery.selFC;
            nl1 = Gallery.selAL; nc1 = Gallery.selAC;
        }

        int codeY = codeY0;
        int ci = 0;
        int segBase = 0;
        while (ci < codeLines.Count) {
            // Selection highlight behind this line's text.
            if (showSel && ci >= nl0 && ci <= nl1) {
                int lineLen = codeLines[ci].Length;
                int sc = 0;
                if (ci == nl0) { sc = nc0; }
                int ec = lineLen;
                if (ci == nl1) { ec = nc1; }
                if (sc < 0) { sc = 0; }
                if (sc > lineLen) { sc = lineLen; }
                if (ec > lineLen) { ec = lineLen; }
                if (ec < sc) { ec = sc; }
                int hx0 = textX + Canvas.MeasureText(codeLines[ci].Substring(0, sc), fs);
                int hx1 = textX + Canvas.MeasureText(codeLines[ci].Substring(0, ec), fs);
                if (hx1 < hx0 + app.Scale(2)) { hx1 = hx0 + app.Scale(4); }
                c.FillRect(hx0, codeY - app.Scale(1), hx1 - hx0,
                    codeLineH, 0x553B82F6);
            }
            c.DrawText(cx + gutterW - gnW - app.Scale(6), codeY,
                Convert.ToString(ci + 1), t.textTertiary, fs);
            // Cached highlight spans for this line: [segBase, segBase+n).
            int n = d.cacheSegPerLine[ci];
            int sx = textX;
            int si = 0;
            while (si < n) {
                string seg = d.cacheSegText[segBase + si];
                c.DrawText(sx, codeY, seg, d.cacheSegColor[segBase + si], fs);
                sx = sx + Canvas.MeasureText(seg, fs);
                si = si + 1;
            }
            segBase = segBase + n;
            codeY = codeY + codeLineH;
            ci = ci + 1;
        }
        return panelH;
    }

    /// A small pill tab in the code panel header (Zan / JSON switch).
    static void DrawCodeTab(App app, Canvas c, Theme t, string label,
            int x, int y, int w, int h, bool active) {
        bool hot = !app.PointerCaptured()
            && app.mouseX >= x && app.mouseX < x + w
            && app.mouseY >= y && app.mouseY < y + h;
        int bg = 0xFF2D2D30;
        int fg = t.textTertiary;
        if (active) { bg = 0xFF0E639C; fg = 0xFFFFFFFF; }
        else if (hot) { bg = 0xFF3E3E42; fg = 0xFFFFFFFF; }
        c.FillRoundRect(x, y, w, h, app.Scale(3), bg);
        int tw = Canvas.MeasureText(label, t.fontSizeSmall);
        c.DrawText(x + (w - tw) / 2,
            y + (h - Canvas.FontHeight(t.fontSizeSmall)) / 2, label,
            fg, t.fontSizeSmall);
    }

    /// Maps a mouse y to a code line index (clamped to the snippet).
    static int HitLine(List<string> lines, int scroll, int my,
            int codeY0, int lineH) {
        int hl = scroll + (my - codeY0) / lineH;
        if (hl < 0) { hl = 0; }
        if (hl >= lines.Count) { hl = lines.Count - 1; }
        return hl;
    }

    /// Maps a horizontal offset (px, relative to the text origin) to a caret
    /// column inside `line`, snapping to the nearer character boundary.
    static int ColAt(string line, int fs, int localX) {
        if (localX <= 0) { return 0; }
        int n = line.Length;
        int col = 0;
        int prevW = 0;
        while (col < n) {
            int w = Canvas.MeasureText(line.Substring(0, col + 1), fs);
            if (localX < (prevW + w) / 2) { return col; }
            prevW = w;
            col = col + 1;
        }
        return n;
    }

    /// True when the current selection spans at least one character.
    static bool SelNonEmpty() {
        if (Gallery.selAL != Gallery.selFL) { return true; }
        return Gallery.selAC != Gallery.selFC;
    }

    /// Extracts the selected substring from the split snippet lines.
    static string SelectedText(List<string> lines) {
        int sL = Gallery.selAL; int sC = Gallery.selAC;
        int eL = Gallery.selFL; int eC = Gallery.selFC;
        if (sL > eL || (sL == eL && sC > eC)) {
            sL = Gallery.selFL; sC = Gallery.selFC;
            eL = Gallery.selAL; eC = Gallery.selAC;
        }
        if (sL < 0) { sL = 0; }
        if (eL >= lines.Count) { eL = lines.Count - 1; }
        if (sL == eL) {
            string only = lines[sL];
            if (sC < 0) { sC = 0; }
            if (eC > only.Length) { eC = only.Length; }
            return only.Substring(sC, eC - sC);
        }
        string first = lines[sL];
        if (sC < 0) { sC = 0; }
        string res = first.Substring(sC, first.Length - sC);
        int i = sL + 1;
        while (i < eL) {
            res = res + "\n" + lines[i];
            i = i + 1;
        }
        string last = lines[eL];
        if (eC > last.Length) { eC = last.Length; }
        res = res + "\n" + last.Substring(0, eC);
        return res;
    }

    // ------------------------------------------------------------------
    // Live previews (real widget states for the selected component)
    // ------------------------------------------------------------------

    /// Preview box height (unscaled) for a component: complex widgets that
    /// need more vertical room get a taller box so they aren't clipped.
    static void StateSwatch(App app, int x, int y, int w, int h, string label,
            bool hov, bool pr, bool sel, bool dis) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        c.FillRoundRect(x, y, w, h, t.borderRadiusMedium,
            States.Bg(t, hov, pr, sel, dis));
        c.DrawRect(x, y, w, h, States.Border(t, hov, pr, false, dis), 1);
        if (sel) { c.FillRect(x, y, app.Scale(3), h, States.Accent(t)); }
        c.DrawTextCentered(x, y, w, h, label, States.Text(t, sel, dis), t.fontSizeSmall);
    }

    /// One Ellipsis demo row: a fixed-width guide box with the text truncated to
    /// fit, plus the pixel width label to its right.
    static void EllipsisRow(App app, int x, int y, int w, string text) {
        Canvas c = app.canvas;
        Theme t = app.theme;
        c.DrawRect(x, y - app.Scale(2), w, app.Scale(24), t.borderSecondary, 1);
        Ellipsis.Render(app, x + app.Scale(5), y + app.Scale(3), w - app.Scale(10), text);
        Label.Secondary(app, x + w + app.Scale(10), y + app.Scale(3),
            Convert.ToString(w) + "px");
    }

    static int PreviewHeight(string name) {
        if (name == "Button") { return 470; }
        if (name == "Icon") { return 360; }
        if (name == "States") { return 150; }
        if (name == "Tabs") { return 400; }
        if (name == "TextArea") { return 190; }
        if (name == "SelectBox") { return 240; }
        if (name == "VirtualList") { return 210; }
        if (name == "ClickEvent") { return 120; }
        if (name == "DataTable") { return 200; }
        if (name == "PivotTable") { return 200; }
        if (name == "Chart") { return 210; }
        if (name == "Alert") { return 360; }
        if (name == "Ellipsis") { return 180; }
        if (name == "Timeline") { return 240; }
        if (name == "TreeView") { return 300; }
        if (name == "Collapse") { return 190; }
        if (name == "Table") { return 240; }
        if (name == "ListView") { return 340; }
        if (name == "Carousel") { return 300; }
        if (name == "Layer") { return 360; }
        if (name == "Menu") { return 190; }
        if (name == "Steps") { return 420; }
        if (name == "Tooltip") { return 500; }
        if (name == "Pagination") { return 300; }
        if (name == "Scrollbar") { return 180; }
        if (name == "FloatButton") { return 300; }
        if (name == "FilePicker") { return 220; }
        if (name == "Ribbon") { return 210; }
        if (name == "TabView") { return 230; }
        if (name == "Wizard") { return 320; }
        if (name == "Split") { return 320; }
        if (name == "Result") { return 210; }
        if (name == "Tag") { return 170; }
        if (name == "Progress") { return 210; }
        if (name == "Compose") { return 230; }
        if (name == "Card") { return 420; }
        if (name == "Designer") { return 860; }
        return 150;
    }

    /// Scaled (device-px) height of a demo's preview box for a given card width.
    /// Most previews are a fixed design height, but content that wraps to a
    /// width-dependent number of rows (the Icon gallery grid) must grow taller
    /// as the window narrows, otherwise its lower rows spill past the fixed box
    /// and get clipped. Callers use this for both layout and the drawn frame so
    /// the box, the card height and the grid always agree.
    static int PreviewBoxH(App app, string name, int previewHUnscaled, int w) {
        if (name == "Icon") {
            int cell = app.Scale(62);
            int gcols = (w - app.Scale(24)) / cell;
            if (gcols < 1) { gcols = 1; }
            int n = Icon.Names().Count;
            int rows = (n + gcols - 1) / gcols;
            if (rows < 1) { rows = 1; }
            return app.Scale(34) + rows * cell + app.Scale(12);
        }
        return app.Scale(previewHUnscaled);
    }

    /// Lays out and paints a retained-mode subtree inside a rect -- the same
    /// three calls a Form makes for the whole window, scoped to the preview box.
    /// The demos use this so their preview is the retained tree the snippet
    /// builds (no hand-placed x/y), matching what an app developer would copy.
    static void LayoutIn(App app, Control root, int x, int y, int w, int h) {
        root.MeasureTree(app);
        root.Arrange(x, y, w, h);
        root.RenderTree(app);
    }

    static int RenderPreview(App app, Canvas c, Theme t, string name,
            int x, int y, int w, int previewHUnscaled) {
        int h = Gallery.PreviewBoxH(app, name, previewHUnscaled, w);
        if (t.glass != 0) {
            // Real frosted glass: blur the wallpaper behind the box (clamped to
            // the scroll viewport so it never smears the fixed header), then a
            // light translucent tint + white frost veil + top sheen + rim.
            int by = y;
            int bh = h;
            if (by < Gallery.detailClipTop) {
                bh = bh - (Gallery.detailClipTop - by);
                by = Gallery.detailClipTop;
            }
            if (by + bh > Gallery.detailClipBottom) {
                bh = Gallery.detailClipBottom - by;
            }
            if (bh > 0) {
                c.BlurRectCached(x, by, w, bh, app.Scale(22),
                    app.NextBlurSlot(), app.BackdropDirty());
            }
            c.FillRoundRect(x, y, w, h, app.Scale(6), Layer.Fade(t.bgSecondary, 300));
            c.FillRoundRect(x, y, w, h, app.Scale(6), Layer.Fade(t.textPrimary, 40));
            c.FillRoundRect(x, y, w, app.Scale(2), app.Scale(6),
                            Layer.Fade(t.textPrimary, 140));
            c.DrawRect(x, y, w, h, Layer.Fade(t.textPrimary, 85), 1);
        } else {
            c.FillRoundRect(x, y, w, h, app.Scale(6), t.bgSecondary);
            c.DrawRect(x, y, w, h, t.borderPrimary, 1);
        }
        c.DrawText(x + app.Scale(12), y + app.Scale(9), "LIVE STATES",
            t.textTertiary, t.fontSizeSmall);
        // Floating/interactive components are drawn later in the deferred
        // overlay pass (above the code panel); the base pass only frames them.
        if (Gallery.IsOverlayComp(name)) { return h; }
        // Clip every base demo to the preview box so nothing bleeds into the
        // title, description or the code panel below (fixes the overflow and
        // scroll "see-through" artifacts).
        c.PushClip(x, y, w, h);
        int px = x + app.Scale(18);
        int py = y + app.Scale(48);
        bool rendered = true;
        if (name == "Button.types") {
            Panel row = Panel.Row().Gap(app.Scale(10));
            row.With(Button.Create("Default"));
            row.With(Button.Typed("Primary", 1));
            row.With(Button.Typed("Info", 2));
            row.With(Button.Typed("Success", 3));
            row.With(Button.Typed("Warning", 4));
            row.With(Button.Typed("Error", 5));
            Gallery.LayoutIn(app, row, px, y + app.Scale(34), w - app.Scale(36), app.Scale(34));
        } else if (name == "Button.styles") {
            Panel row = Panel.Row().Gap(app.Scale(10));
            row.With(Button.Styled("Solid", 1, 0));
            row.With(Button.Styled("Outline", 1, 1));
            row.With(Button.Styled("Text", 1, 2));
            row.With(Button.Styled("Dashed", 1, 3));
            row.With(Button.Secondary("Secondary", 1));
            row.With(Button.Ghost("Ghost", 1));
            Gallery.LayoutIn(app, row, px, y + app.Scale(34), w - app.Scale(36), app.Scale(34));
        } else if (name == "Button.specular") {
            Panel row = Panel.Row().Gap(app.Scale(10));
            row.With(Button.Specular("Hover me", 1));
            row.With(Button.Specular("Success", 3));
            row.With(Button.Specular("Error", 5));
            row.With(Button.Specular("Default", 0));
            Gallery.LayoutIn(app, row, px, y + app.Scale(34), w - app.Scale(36), app.Scale(34));
        } else if (name == "Button.secondary") {
            Panel row = Panel.Row().Gap(app.Scale(10));
            row.With(Button.Secondary("Default", 0));
            row.With(Button.Secondary("Primary", 1));
            row.With(Button.Secondary("Info", 2));
            row.With(Button.Secondary("Success", 3));
            row.With(Button.Secondary("Warning", 4));
            row.With(Button.Secondary("Error", 5));
            Gallery.LayoutIn(app, row, px, y + app.Scale(34), w - app.Scale(36), app.Scale(34));
        } else if (name == "Button.states") {
            Panel row = Panel.Row().Gap(app.Scale(10));
            row.With(Button.Loading("Loading", 1));
            Button bldg = Button.Loading("", 3);
            bldg.SetCircle(true);
            row.With(bldg);
            Button bdis = Button.Create("Disabled");
            bdis.SetDisabled(true);
            row.With(bdis);
            row.With(Button.Colored("Pink", 0xFFE91E63));
            row.With(Button.Colored("Teal", 0xFF13C2C2));
            Gallery.LayoutIn(app, row, px, y + app.Scale(34), w - app.Scale(36), app.Scale(34));
        } else if (name == "Button.shapes") {
            Panel row = Panel.Row().Gap(app.Scale(10));
            row.With(Button.Round("Round", 1));
            row.With(Button.IconTextTyped("Save", "save", 3));
            row.With(Button.IconTyped("plus", 1));
            row.With(Button.IconTyped("settings", 0));
            Gallery.LayoutIn(app, row, px, y + app.Scale(34), w - app.Scale(36), app.Scale(34));
        } else if (name == "Button.sizes") {
            Panel row = Panel.Row().Gap(app.Scale(10));
            Button btn = Button.Create("Tiny"); btn.SetSize(0);
            row.With(btn);
            Button bsm = Button.Create("Small"); bsm.SetSize(1);
            row.With(bsm);
            row.With(Button.Create("Medium"));
            Button blg = Button.Create("Large"); blg.SetSize(3);
            row.With(blg);
            Gallery.LayoutIn(app, row, px, y + app.Scale(34), w - app.Scale(36), app.Scale(40));
        } else if (name == "Button.group") {
            int cur = y + app.Scale(34);
            ButtonGroup g1 = ButtonGroup.Create(1);
            g1.Add("Left"); g1.Add("Middle"); g1.Add("Right");
            g1.Render(app, px, cur);
            ButtonGroup g2 = ButtonGroup.Create(2).Outline(true);
            g2.Add("Day"); g2.Add("Week"); g2.Add("Month"); g2.Add("Year");
            g2.Render(app, px + app.Scale(240), cur);
        } else if (name == "Icon") {
            List<string> icons = Icon.Names();
            int cell = app.Scale(62);
            int iconSz = app.Scale(22);
            int gcols = (w - app.Scale(24)) / cell;
            if (gcols < 1) { gcols = 1; }
            bool iconClick = app.window.EventKind() == 3;
            int gx0 = x + app.Scale(12);
            int gy0 = y + app.Scale(34);
            int gi = 0;
            while (gi < icons.Count) {
                int gr = gi / gcols;
                int gc = gi % gcols;
                int gx = gx0 + gc * cell;
                int gy = gy0 + gr * cell;
                bool hot = !app.PointerCaptured()
                    && app.mouseX >= gx && app.mouseX < gx + cell
                    && app.mouseY >= gy && app.mouseY < gy + cell;
                if (hot) {
                    c.FillRoundRect(gx, gy, cell - app.Scale(4), cell - app.Scale(4),
                        app.Scale(4), t.bgHover);
                }
                Icon.DrawCenteredIn(c, icons[gi], gx, gy + app.Scale(6),
                    cell - app.Scale(4), iconSz, iconSz, t.textPrimary);
                c.DrawTextCentered(gx, gy + iconSz + app.Scale(12), cell - app.Scale(4),
                    Canvas.FontHeight(t.fontSizeSmall),
                    Ellipsis.Fit(icons[gi], cell - app.Scale(6), t.fontSizeSmall),
                    t.textTertiary, t.fontSizeSmall);
                if (hot && iconClick) {
                    Clipboard.SetText("Icon.Draw(c, \"" + icons[gi] + "\", x, y, 24, color);");
                    Gallery.copiedIcon = icons[gi];
                    app.RequestRedraw();
                }
                gi = gi + 1;
            }
            if (Gallery.copiedIcon != "") {
                c.DrawText(x + app.Scale(110), y + app.Scale(9),
                    "copied  Icon.Draw(c, \"" + Gallery.copiedIcon + "\", ...)",
                    t.success, t.fontSizeSmall);
            }
        } else if (name == "Label") {
            Label.Title(app, px, py - app.Scale(12), "Title");
