        Gallery.Add(list, "Basic", "States",
            "Canonical interaction-state colours shared by every component via the States helper. Precedence: disabled > pressed > selected > hovered > normal. Use it so widgets tint states identically instead of hand-picking theme fields.",
            "int bg = States.Bg(t, hovered, pressed, selected, disabled);\nint fg = States.Text(t, selected, disabled);\nint bd = States.Border(t, hovered, pressed, focused, disabled);\nc.FillRoundRect(x, y, w, h, t.borderRadiusMedium, bg);\nc.DrawRect(x, y, w, h, bd, 1);");
