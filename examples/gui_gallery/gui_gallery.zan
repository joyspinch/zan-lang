        } else if (name == "Card") {
            int cy0 = py - app.Scale(12);
            int cw = app.Scale(380);
            int ch = app.Scale(150);
            int lx = app.Scale(14);
            // Row 1, card 1 — reactbits "border-glow", via the declarative
            // FxOptions config (Card.RenderFx / card.WithFx(o)).
            FxOptions fxGlow = FxOptions.Create();
            fxGlow.borderGlow = true;
            Card.RenderFx(app, px, cy0, cw, ch, "BorderGlow", fxGlow);
            Label.Render(app, px + lx, Card.ContentY(cy0, t), "Animated border light");
            // Row 1, card 2 — magic-bento spotlight: a soft glow follows the cursor.
            int px2 = px + cw + app.Scale(24);
            int id2 = app.focus.AllocId();
            Card.Render(app, px2, cy0, cw, ch, "Spotlight");
            Label.Render(app, px2 + lx, Card.ContentY(cy0, t), "Hover — light follows cursor");
            int hv2 = Ui.HoverLevel(app, id2);
            Fx.SpotlightHv(app, px2, cy0, cw, ch, t.primary, app.Scale(120), 90, hv2);
            app.hitTester.Register(HitRegion.Create(id2, px2, cy0, cw, ch, 0));
            // Row 2 — four opt-in card motion variants, each clipped in-bounds.
            int ry = cy0 + ch + app.Scale(22);
            int cw2 = app.Scale(184);
            int g2 = app.Scale(16);
            int rh = app.Scale(150);
            int cxa = px;
            FxOptions fxSheen = FxOptions.Create();
            fxSheen.sheen = true;
            fxSheen.glowPeriodMs = 1600;
            Card.RenderFx(app, cxa, ry, cw2, rh, "Sheen", fxSheen);
            Label.Render(app, cxa + lx, Card.ContentY(ry, t), "Diagonal sheen");
            int cxb = cxa + cw2 + g2;
            FxOptions fxAur = FxOptions.Create();
            fxAur.aurora = true;
            Card.RenderFx(app, cxb, ry, cw2, rh, "Aurora", fxAur);
            Label.Render(app, cxb + lx, Card.ContentY(ry, t), "Drifting aurora");
            int cxc = cxb + cw2 + g2;
            FxOptions fxBr = FxOptions.Create();
            fxBr.breath = true;
            fxBr.glowPeriodMs = 2800;
            Card.RenderFx(app, cxc, ry, cw2, rh, "Breath", fxBr);
            Label.Render(app, cxc + lx, Card.ContentY(ry, t), "Breathing rim");
            int cxd = cxc + cw2 + g2;
            FxOptions fxMo = FxOptions.Create();
            fxMo.motes = true;
            Card.RenderFx(app, cxd, ry, cw2, rh, "Motes", fxMo);
            Label.Render(app, cxd + lx, Card.ContentY(ry, t), "Rising motes");
        } else if (name == "Panel") {
            // Panel is a titleless container surface (fill + border + padding);
