            List<string> t0 = new List<string>();
            t0.Add(Gallery.T("Lexer", "词法分析"));
            t0.Add("Ada"); t0.Add(Gallery.T("Done", "完成"));
            List<string> t1 = new List<string>();
            t1.Add(Gallery.T("Parser", "语法分析"));
            t1.Add("Bjarne"); t1.Add(Gallery.T("Review", "评审中"));
            List<string> t2 = new List<string>();
            t2.Add(Gallery.T("IR codegen", "IR 生成"));
            t2.Add("Chris"); t2.Add(Gallery.T("WIP", "进行中"));
            List<string> t3 = new List<string>();
            t3.Add(Gallery.T("Linker", "链接器"));
            t3.Add("Dennis"); t3.Add(Gallery.T("Blocked", "受阻"));
            int rh = t.heightMedium;
            Table.RenderRow(app, px, ty0 + rh, t0, widths, false);
            Table.RenderRow(app, px, ty0 + rh * 2, t1, widths, true);
            Table.RenderRow(app, px, ty0 + rh * 3, t2, widths, false);
            Table.RenderRow(app, px, ty0 + rh * 4, t3, widths, true);
        } else if (name == "PivotTable") {
            List<DataRow> rows = new List<DataRow>();
            DataRow p0 = DataRow.Create();
            p0.Push("North"); p0.Push("2026"); p0.Push("42"); rows.Add(p0);
            DataRow p1 = DataRow.Create();
            p1.Push("South"); p1.Push("2026"); p1.Push("35"); rows.Add(p1);
            PivotConfig cfg = PivotConfig.Create(0, 1, 2, 0);
            PivotTable.Render(app, px, py - app.Scale(20), w - app.Scale(36), app.Scale(100), rows, cfg);
        } else if (name == "TreeView") {
            // Multi-level tree with selection checkboxes: click a folder to
            // expand/collapse, click a row to select, click a box to (de)select
            // (folders cascade to descendants), right-click for the action menu.
            int tact = Gallery.treeMenuAction.Get();
            if (tact >= 0) {
                Gallery.treeMenuAction.Set(0 - 1);
                Gallery.treeMenuSub.Set(0 - 1);
                Gallery.treeMenuOpen.Set(false);
                if (tact == 0) { TreeView.ExpandAll(Gallery.treeNodes); }
                else if (tact == 1) { TreeView.CollapseAll(Gallery.treeNodes); }
                else if (tact == 2) { TreeView.SetAllChecked(Gallery.treeNodes, true); }
                else if (tact == 3) { TreeView.SetAllChecked(Gallery.treeNodes, false); }
                else if (tact == 4) {
                    if (Gallery.treeMenuNode >= 0
                        && Gallery.treeMenuNode < Gallery.treeNodes.Count) {
                        TreeView.ToggleCheck(Gallery.treeNodes, Gallery.treeMenuNode);
                    }
                }
                app.RequestRedraw();
            }

            Rect tvArea = Rect.Create(px, py - app.Scale(16),
                app.Scale(320), app.Scale(250));
            int rIdx = TreeView.RenderChecked(app, tvArea, Gallery.treeNodes,
                Gallery.treeSel, 0);
            if (rIdx >= 0) {
                Gallery.treeMenuOpen.Set(true);
                Gallery.treeMenuNode = rIdx;
                Gallery.treeMenuX = app.mouseX;
                Gallery.treeMenuY = app.mouseY;
                Gallery.treeMenuSub.Set(0 - 1);
                app.RequestRedraw();
            }
            if (Gallery.treeMenuOpen.Get()) {
                List<MenuItem> items = new List<MenuItem>();
                items.Add(MenuItem.Header(Gallery.T("Tree actions", "树操作")));
                items.Add(MenuItem.Item(Gallery.T("Toggle check", "勾选 / 取消"), "check", 4));
                items.Add(MenuItem.Item(Gallery.T("Expand all", "全部展开"), "chevron-down", 0));
                items.Add(MenuItem.Item(Gallery.T("Collapse all", "全部折叠"), "chevron-right", 1));
                items.Add(MenuItem.Separator());
                List<MenuItem> sub = new List<MenuItem>();
                sub.Add(MenuItem.Item(Gallery.T("Check all", "全选"), "check", 2));
                sub.Add(MenuItem.Item(Gallery.T("Clear", "清空"), "close", 3));
                items.Add(MenuItem.Submenu(Gallery.T("Selection", "选择"), "copy", sub));
                app.AddOverlay(OverlayPopup.RichMenu(Gallery.treeMenuX,
                    Gallery.treeMenuY, items, Gallery.treeMenuBaseId,
                    Gallery.treeMenuAction, Gallery.treeMenuOpen,
                    Gallery.treeMenuSub));
            }

            int tsel = Gallery.treeSel.Get();
            string picked = "";
            if (tsel >= 0 && tsel < Gallery.treeNodes.Count) {
                picked = Gallery.treeNodes[tsel].label;
            }
            int infoX = px + app.Scale(340);
            Label.Secondary(app, infoX, py - app.Scale(16),
                Gallery.T("Selected: ", "已选择：") + picked);
            List<string> chk = TreeView.CheckedLabels(Gallery.treeNodes);
            Label.Secondary(app, infoX, py + app.Scale(8),
                Gallery.T("Checked: ", "已勾选：") + Convert.ToString(chk.Count));
            int cli = 0;
            int cly = py + app.Scale(32);
            while (cli < chk.Count && cli < 7) {
                Label.Secondary(app, infoX, cly, "• " + chk[cli]);
                cly = cly + app.Scale(20);
                cli = cli + 1;
            }
            Label.Secondary(app, infoX, cly + app.Scale(6),
                Gallery.T("Right-click a row for actions",
                    "右键任意行打开操作菜单"));
        } else if (name == "Collapse") {
            List<string> heads = new List<string>();
            heads.Add("General"); heads.Add("Advanced");
            List<string> content = new List<string>();
            content.Add("General settings"); content.Add("Advanced settings");
            int id = Collapse.Render(app, px, py - app.Scale(20), w - app.Scale(36), heads, content, Gallery.demoInt);
            Collapse.HandleClick(app, id, heads.Count, Gallery.demoInt);
        } else if (name == "Carousel.basic") {
            List<string> slides = new List<string>();
            slides.Add("First slide"); slides.Add("Second slide"); slides.Add("Third slide");
            int id = Carousel.Render(app, px, py - app.Scale(10), w - app.Scale(36), app.Scale(110), slides, Gallery.demoCarBasic);
            Carousel.HandleClick(app, id, slides.Count, Gallery.demoCarBasic);
        } else if (name == "Carousel.anim") {
            List<string> slides = new List<string>();
            slides.Add("Overview"); slides.Add("Metrics"); slides.Add("Reports"); slides.Add("Settings");
            int id = Carousel.RenderAnimated(app, px, py - app.Scale(10), w - app.Scale(36), app.Scale(110), slides, Gallery.demoInt, Gallery.demoCarousel);
            Carousel.HandleClick(app, id, slides.Count, Gallery.demoInt);
        } else if (name == "Carousel.many") {
            List<string> slides = new List<string>();
            slides.Add("Aurora"); slides.Add("Canyon"); slides.Add("Harbor");
            slides.Add("Meadow"); slides.Add("Skyline"); slides.Add("Tundra");
            int id = Carousel.RenderAnimated(app, px, py - app.Scale(10), w - app.Scale(36), app.Scale(110), slides, Gallery.demoCar2, Gallery.carAnim2);
            Carousel.HandleClick(app, id, slides.Count, Gallery.demoCar2);
        } else if (name == "Chart.line" || name == "Chart.area"
                || name == "Chart.bar" || name == "Chart.smooth"
                || name == "Chart.stacked") {
            List<int> rev = new List<int>();
            rev.Add(12); rev.Add(28); rev.Add(20); rev.Add(35);
            List<int> cost = new List<int>();
            cost.Add(8); cost.Add(14); cost.Add(16); cost.Add(22);
            ChartModel cm = ChartModel.Create("Quarterly revenue");
            cm.AddLabel("Q1"); cm.AddLabel("Q2"); cm.AddLabel("Q3"); cm.AddLabel("Q4");
            cm.AddColored("Revenue", rev, t.primary);
            cm.AddColored("Cost", cost, Chart.Palette(t, 1));
            int cX = x + app.Scale(14);
            int cY = y + app.Scale(30);
            int cW = w - app.Scale(28);
            int cH = app.Scale(170);
            ChartOptions co = ChartOptions.Line();
            int ck = 8110;
            if (name == "Chart.area") { co = ChartOptions.Area(); ck = 8111; }
            else if (name == "Chart.smooth") { co = ChartOptions.Smooth(); ck = 8112; }
            else if (name == "Chart.bar") { co = ChartOptions.Bar(); co.showValues = true; ck = 8113; }
            else if (name == "Chart.stacked") { co = ChartOptions.Stacked(); ck = 8114; }
            ChartView cv = ChartView.Keyed(cm, co, ck);
            cv.Render(app, cX, cY, cW, cH);
        } else if (name == "Chart.pie") {
            // Part-of-whole charts are small: show pie + donut side by side
            // (two per row) instead of one stretched across the full width.
            List<int> p0 = new List<int>(); p0.Add(45);
            List<int> p1 = new List<int>(); p1.Add(30);
            List<int> p2 = new List<int>(); p2.Add(25);
            int cY = y + app.Scale(30);
            int cH = app.Scale(170);
            int halfW = (w - app.Scale(28) - app.Scale(12)) / 2;
            int c0X = x + app.Scale(14);
            int c1X = c0X + halfW + app.Scale(12);

            ChartModel pm = ChartModel.Create("Language share");
            pm.Add("Zan", p0); pm.Add("C", p1); pm.Add("Rust", p2);
            ChartView.Keyed(pm, ChartOptions.Pie(), 8120).Render(app, c0X, cY, halfW, cH);

            ChartModel dm = ChartModel.Create("Language share");
            List<int> d0 = new List<int>(); d0.Add(45);
            List<int> d1 = new List<int>(); d1.Add(30);
            List<int> d2 = new List<int>(); d2.Add(25);
            dm.Add("Zan", d0); dm.Add("C", d1); dm.Add("Rust", d2);
            ChartView.Keyed(dm, ChartOptions.Donut(), 8121).Render(app, c1X, cY, halfW, cH);
        } else if (name == "Chart.radial") {
            // Gauge + radial-bars, two per row (both are compact by nature).
            int cY = y + app.Scale(30);
            int cH = app.Scale(170);
            int halfW = (w - app.Scale(28) - app.Scale(12)) / 2;
            int c0X = x + app.Scale(14);
            int c1X = c0X + halfW + app.Scale(12);

            ChartModel gm = ChartModel.Create("CPU load");
            List<int> gv = new List<int>(); gv.Add(72);
            gm.AddColored("load", gv, t.primary);
            ChartOptions go = ChartOptions.Gauge();
            go.gaugeMax = 100;
            ChartView.Keyed(gm, go, 8130).Render(app, c0X, cY, halfW, cH);

            ChartModel rm = ChartModel.Create("Quota used");
            List<int> r0 = new List<int>(); r0.Add(80);
            List<int> r1 = new List<int>(); r1.Add(55);
            List<int> r2 = new List<int>(); r2.Add(30);
            rm.Add("CPU", r0); rm.Add("RAM", r1); rm.Add("Disk", r2);
            ChartOptions ro = ChartOptions.RadialBars();
            ro.gaugeMax = 100;
            ChartView.Keyed(rm, ro, 8131).Render(app, c1X, cY, halfW, cH);
        } else if (name == "Chart.heatmap") {
            ChartModel hm = ChartModel.Create("Weekly activity");
            hm.AddLabel("Mon"); hm.AddLabel("Tue"); hm.AddLabel("Wed");
            hm.AddLabel("Thu"); hm.AddLabel("Fri"); hm.AddLabel("Sat"); hm.AddLabel("Sun");
            List<int> wk1 = new List<int>();
            wk1.Add(12); wk1.Add(35); wk1.Add(50); wk1.Add(28); wk1.Add(64); wk1.Add(18); wk1.Add(8);
            List<int> wk2 = new List<int>();
            wk2.Add(40); wk2.Add(22); wk2.Add(70); wk2.Add(90); wk2.Add(55); wk2.Add(30); wk2.Add(15);
            List<int> wk3 = new List<int>();
            wk3.Add(5); wk3.Add(60); wk3.Add(45); wk3.Add(38); wk3.Add(80); wk3.Add(52); wk3.Add(20);
            hm.AddColored("Team A", wk1, t.primary);
            hm.AddColored("Team B", wk2, Chart.Palette(t, 2));
            hm.AddColored("Team C", wk3, Chart.Palette(t, 4));
            ChartView.Keyed(hm, ChartOptions.Heatmap(), 8140).Render(
                app, x + app.Scale(14), y + app.Scale(30),
                w - app.Scale(28), app.Scale(170));
        } else if (name == "Chart.json") {
            // The exact same chart, driven entirely by a JSON data document
            // instead of imperative Add() calls (color 0 = auto palette).
            string doc = "{\"title\":\"Monthly active users\","
                + "\"labels\":[\"Jan\",\"Feb\",\"Mar\",\"Apr\",\"May\",\"Jun\"],"
                + "\"series\":[{\"name\":\"Web\",\"color\":0,\"values\":[30,45,38,60,72,85]},"
                + "{\"name\":\"Mobile\",\"color\":0,\"values\":[20,32,40,52,64,80]}]}";
            ChartModel cm = ChartModel.FromJson(doc);
            ChartOptions co = ChartOptions.Smooth();
            co.showValues = false;
            ChartView cv = ChartView.Keyed(cm, co, 8115);
            cv.Render(app, x + app.Scale(14), y + app.Scale(30),
                w - app.Scale(28), app.Scale(170));
        } else if (name == "Chart.scatter") {
            List<int> xs = new List<int>();
            xs.Add(5); xs.Add(12); xs.Add(18); xs.Add(24); xs.Add(31); xs.Add(40);
            List<int> ys = new List<int>();
            ys.Add(8); ys.Add(14); ys.Add(11); ys.Add(26); ys.Add(22); ys.Add(34);
            Chart.Scatter(app, x + app.Scale(14), y + app.Scale(30),
                w - app.Scale(28), app.Scale(170), "Samples", xs, ys, t.primary);
        } else if (name == "Ellipsis") {
            string longText = "A very long component description that will not fit a narrow column";
            Gallery.EllipsisRow(app, px, py - app.Scale(6), app.Scale(160), longText);
            Gallery.EllipsisRow(app, px, py + app.Scale(30), app.Scale(280), longText);
            Gallery.EllipsisRow(app, px, py + app.Scale(66), app.Scale(440), longText);
        } else if (name == "States") {
            int sw2 = app.Scale(84);
            int sh = app.Scale(40);
            int gap = app.Scale(10);
            Gallery.StateSwatch(app, px + 0 * (sw2 + gap), py, sw2, sh, "Normal", false, false, false, false);
            Gallery.StateSwatch(app, px + 1 * (sw2 + gap), py, sw2, sh, "Hover", true, false, false, false);
            Gallery.StateSwatch(app, px + 2 * (sw2 + gap), py, sw2, sh, "Pressed", false, true, false, false);
            Gallery.StateSwatch(app, px + 3 * (sw2 + gap), py, sw2, sh, "Selected", false, false, true, false);
            Gallery.StateSwatch(app, px + 4 * (sw2 + gap), py, sw2, sh, "Disabled", false, false, false, true);
            int fx = px + 5 * (sw2 + gap);
            c.FillRoundRect(fx, py, sw2, sh, t.borderRadiusMedium, States.Bg(t, false, false, false, false));
            c.DrawRect(fx, py, sw2, sh, States.Border(t, false, false, true, false), 2);
            c.DrawTextCentered(fx, py, sw2, sh, "Focus", t.textPrimary, t.fontSizeSmall);
        } else if (name == "Divider") {
            Divider.RenderText(app, px, py, w - app.Scale(36), "Section", 0);
        } else if (name == "Progress.line") {
            int barW = w - app.Scale(120);
            Progress.RenderText(app, px, py - app.Scale(6), barW, 72, 0);
            Progress.RenderText(app, px, py + app.Scale(24), barW, 45, 2);
            Progress.RenderText(app, px, py + app.Scale(54), barW, 90, 3);
            Progress.RenderText(app, px, py + app.Scale(84), barW, 30, 4);
        } else if (name == "Progress.circle") {
            int rr = app.Scale(34);
            int rcy = py + app.Scale(24);
            Progress.Circle(app, px + app.Scale(50), rcy, rr, 72, 0);
            Progress.Circle(app, px + app.Scale(150), rcy, rr, 90, 3);
            Progress.Circle(app, px + app.Scale(250), rcy, rr, 45, 4);
        } else if (name == "Alert") {
            int aw = w - app.Scale(36);
            int aay = py - app.Scale(20);
            // Uniform banner height + equal outer gaps for every type variant.
            int step = Alert.Height(app, true) + app.Scale(12);
            Alert.Render(app, px, aay, aw, "Heads up", "Additional context for the info alert.", 2);
            Alert.Render(app, px, aay + step, aw, "Build succeeded", "The executable is ready.", 3);
            Alert.Render(app, px, aay + step * 2, aw, "Low disk space", "Free up room before the next build.", 4);
            Alert.Render(app, px, aay + step * 3, aw, "Deployment failed", "Check the logs for details.", 5);
        } else if (name == "Result") {
            // Every status side by side: success / warning / error.
            int rw = (w - app.Scale(36)) / 3;
            int rya = py - app.Scale(20);
            Result.Render(app, px, rya, rw, 1, "Success", "Changes saved.");
            Result.Render(app, px + rw, rya, rw, 2, "Warning", "Review the config.");
            Result.Render(app, px + rw * 2, rya, rw, 3, "Error", "The build failed.");
        } else if (name == "Tooltip") {
            // Triggers: hover shows the tip while the pointer is over the target;
            // click toggles it. Both drive the same Tooltip.RenderAt renderer.
            Label.Secondary(app, px, py - app.Scale(28), "Triggers · hover / click");
            int bw = app.Scale(120);
            int hoverId = Button.Create("Hover me").Render(app, px, py, bw);
            if (app.focus.IsHovered(hoverId)) {
                Tooltip.RenderAt(app, px + bw / 2, py, "Shown on hover", 0, 0);
            }
            int clickX = px + bw + app.Scale(16);
            int clickId = Button.Create("Click me").Render(app, clickX, py, bw);
            if (Button.WasClicked(app, clickId)) {
                Gallery.tipClickOn.Set(!Gallery.tipClickOn.Get());
            }
            if (Gallery.tipClickOn.Get()) {
                Tooltip.RenderAt(app, clickX + bw / 2, py, "Toggled by click", 1, 0);
            }

            // Placements: four widely-spaced anchors, each always-on so all four
            // sides are visible at once without overlapping.
            int rowY = py + app.Scale(120);
            Label.Secondary(app, px, rowY - app.Scale(30), "Placements · top / bottom / left / right");
            int dot = app.Scale(7);
            int pw = w - app.Scale(52);
            int p0 = px + app.Scale(30);
            int pstep = pw / 4;
            c.FillCircle(p0, rowY, dot, t.primary);
            Tooltip.RenderAt(app, p0, rowY - dot, "Top", 0, 0);
            c.FillCircle(p0 + pstep, rowY, dot, t.primary);
            Tooltip.RenderAt(app, p0 + pstep, rowY + dot, "Bottom", 1, 0);
            c.FillCircle(p0 + pstep * 2, rowY, dot, t.primary);
            Tooltip.RenderAt(app, p0 + pstep * 2 - dot, rowY, "Left", 2, 0);
            c.FillCircle(p0 + pstep * 3, rowY, dot, t.primary);
            Tooltip.RenderAt(app, p0 + pstep * 3 + dot, rowY, "Right", 3, 0);

            // Long text: wraps automatically; a scrollbar appears past the cap
            // and the wheel scrolls the bubble content while the pointer is over it.
            int longY = py + app.Scale(250);
            Label.Secondary(app, px, longY - app.Scale(8), "Long text · auto-wrap + wheel scroll");
            c.FillCircle(p0, longY + app.Scale(18), dot, t.info);
            string longTip = "Long text wraps automatically onto multiple lines. When it grows past the height cap a scrollbar appears on the right and the mouse wheel scrolls the content while the pointer is over the bubble, so nothing is clipped away and the bubble still stays fully on screen no matter which edge it is near.";
            int tipMaxW = app.Scale(140);
            int tipAX = p0 + dot;
            int tipAY = longY + app.Scale(18);
            Rect tipBox = Tooltip.BoxRect(app, tipAX, tipAY, longTip, 3, tipMaxW);
            if (app.CaptureWheel(tipBox.x, tipBox.y, tipBox.width, tipBox.height)) {
                int wd = app.window.EventKeyCode();
                int cur = Gallery.tipScroll.Get() - wd * app.Scale(24) / 120;
                int tmax = Tooltip.MaxScroll(app, longTip, tipMaxW);
                if (cur < 0) { cur = 0; }
                if (cur > tmax) { cur = tmax; }
                Gallery.tipScroll.Set(cur);
                app.RequestRedraw();
            }
            Tooltip.RenderScroll(app, tipAX, tipAY, longTip, 3, tipMaxW, Gallery.tipScroll.Get());
        } else if (name == "Spin.plain") {
            Spin.Render(app, px + app.Scale(26), py + app.Scale(24), app.Scale(14), t.primary);
            Spin.Render(app, px + app.Scale(80), py + app.Scale(24), app.Scale(20), t.primary);
            Spin.Render(app, px + app.Scale(150), py + app.Scale(24), app.Scale(28), t.info);
        } else if (name == "Spin.tip") {
            Spin.WithTip(app, px, py - app.Scale(20), app.Scale(300), app.Scale(110), "Loading data...");
        } else if (name == "Loading") {
            Loading.Render(app, px + app.Scale(30), py + app.Scale(24), app.Scale(18));
        } else if (name == "Skeleton") {
            Skeleton.Circle(app, px + app.Scale(20), py + app.Scale(20), app.Scale(20));
            Skeleton.Text(app, px + app.Scale(58), py, app.Scale(260));
            Skeleton.Rect(app, px + app.Scale(58), py + app.Scale(30), app.Scale(180), app.Scale(14));
        } else if (name == "FloatButton") {
            // A fixed utility rail (like a page's bottom-right dock): a stack of
            // quick actions plus a "back to top" that only appears once the
            // content has been scrolled, and jumps the viewport home when hit.
            int vx = px;
            int vy = py - app.Scale(16);
            int vw = w - app.Scale(120);
            int vh = app.Scale(250);
            int rowH = app.Scale(30);
            int rows = 24;
            int contentH = rowH * rows;
            c.FillRoundRect(vx, vy, vw, vh, app.Scale(4), t.bgPrimary);
            c.DrawRoundRect(vx, vy, vw, vh, app.Scale(4), t.borderPrimary, 1);
            Scrollbar.HandleWheel(app, vx, vy, vw, vh, contentH, Gallery.fbScroll);
            int fbo = Gallery.fbScroll.Get();
            int fbmo = contentH - vh;
            if (fbmo < 0) { fbmo = 0; }
            if (fbo > fbmo) { fbo = fbmo; }
            c.PushClip(vx, vy, vw - app.Scale(16), vh);
            int fri = 0;
            while (fri < rows) {
                int ry = vy + fri * rowH - fbo + app.Scale(7);
                Label.Render(app, vx + app.Scale(14), ry,
                    Gallery.T("Scrollable content line ", "可滚动内容第 ")
                        + Convert.ToString(fri + 1)
                        + Gallery.T("", " 行"));
                fri = fri + 1;
            }
            c.PopClip();
            Scrollbar.RenderVerticalScroll(app, vx + vw - app.Scale(13), vy,
                vh, vh, contentH, Gallery.fbScroll);

            // The floating dock, anchored bottom-right of the viewport.
            int fbSz = app.Scale(46);
            int fbGap = app.Scale(12);
            int stackX = vx + vw + app.Scale(20);
            int stackY = vy + vh - fbSz;
            int settId = FloatButton.Render(app, stackX, stackY, fbSz, "settings", 0);
            int helpId = FloatButton.Render(app, stackX,
                stackY - (fbSz + fbGap), fbSz, "info", 0);
            int bellId = FloatButton.Render(app, stackX,
                stackY - (fbSz + fbGap) * 2, fbSz, "bell", 0);
            if (fbo > 0) {
                int topId = FloatButton.Render(app, stackX,
                    stackY - (fbSz + fbGap) * 3, fbSz, "arrow-up", 1);
                if (app.window.EventKind() == 3
                        && app.hitTester.HitTest(app.mouseX, app.mouseY) == topId) {
                    Gallery.fbScroll.Set(0);
                    app.RequestRedraw();
                }
            }
        } else if (name == "Scrollbar") {
            // Interactive: mouse-wheel over the list, drag the thumb, or click
            // the track to scroll.
            int vx = px;
            int vy = py - app.Scale(16);
            int vw = app.Scale(300);
            int vh = app.Scale(130);
            int rowH = app.Scale(28);
            int contentH = rowH * 16;
            c.FillRoundRect(vx, vy, vw, vh, app.Scale(4), t.bgPrimary);
            c.DrawRoundRect(vx, vy, vw, vh, app.Scale(4), t.borderPrimary, 1);
            Scrollbar.HandleWheel(app, vx, vy, vw, vh, contentH, Gallery.scrollOff);
            int off = Gallery.scrollOff.Get();
            int mo = contentH - vh;
            if (mo < 0) { mo = 0; }
            if (off > mo) { off = mo; }
            c.PushClip(vx, vy, vw - app.Scale(16), vh);
            int ri = 0;
            while (ri < 16) {
                int ry = vy + ri * rowH - off + app.Scale(6);
                Label.Render(app, vx + app.Scale(14), ry,
                    Gallery.T("List row ", "列表行 ") + Convert.ToString(ri + 1));
                ri = ri + 1;
            }
            c.PopClip();
            Scrollbar.RenderVerticalScroll(app, vx + vw - app.Scale(13), vy,
                vh, vh, contentH, Gallery.scrollOff);
        } else if (name == "TabView") {
            // Persistent label list so add (+) / close (x) / select stick across
            // frames; returns a TabHit that Apply() folds back into the model.
            int th = TabView.Height(app);
            TabHit hit = TabView.Render(app, px, py - app.Scale(16),
                w - app.Scale(36), th, Gallery.tabViewLabels, Gallery.demoInt, true);
            if (hit.action == 3) {
                Gallery.tabViewSeq = Gallery.tabViewSeq + 1;
                TabView.Apply(hit, Gallery.tabViewLabels, Gallery.demoInt,
                    Gallery.T("untitled-", "未命名-")
                        + Convert.ToString(Gallery.tabViewSeq));
            } else {
                TabView.Apply(hit, Gallery.tabViewLabels, Gallery.demoInt, "");
            }
            int act = Gallery.demoInt.Get();
            string open = "";
            if (act >= 0 && act < Gallery.tabViewLabels.Count) {
                open = Gallery.tabViewLabels[act];
            }
            Label.Secondary(app, px, py - app.Scale(16) + th + app.Scale(16),
                Gallery.T("Active tab: ", "当前标签：") + open
                    + Gallery.T("  ·  + adds, x closes, click selects",
                        "  ·  + 新增，x 关闭，点击切换"));
        } else if (name == "Ribbon") {
            List<string> rtabs = new List<string>{
                Gallery.T("Home", "开始"),
                Gallery.T("Insert", "插入"),
                Gallery.T("View", "视图")
            };
            // Each tab shows a different set of groups so switching is visible.
            List<RibbonGroup> rgroups = new List<RibbonGroup>();
            int rtab = Gallery.ribbonTab.Get();
            if (rtab == 1) {
                rgroups = new List<RibbonGroup>{
                    RibbonGroup.Of(Gallery.T("Insert", "插入"), new List<RibbonItem>{
                        RibbonItem.Large("table", Gallery.T("Table", "表格")),
                        RibbonItem.Large("grid", Gallery.T("Grid", "网格"))
                    }),
                    RibbonGroup.Of(Gallery.T("Links", "链接"), new List<RibbonItem>{
                        RibbonItem.Small("globe", Gallery.T("Link", "链接")),
                        RibbonItem.Small("mail", Gallery.T("Mail", "邮件")),
                        RibbonItem.Small("file", Gallery.T("File", "文件"))
                    })
                };
            } else if (rtab == 2) {
                rgroups = new List<RibbonGroup>{
                    RibbonGroup.Of(Gallery.T("Show", "显示"), new List<RibbonItem>{
                        RibbonItem.Small("eye", Gallery.T("Preview", "预览")),
                        RibbonItem.Small("menu", Gallery.T("Sidebar", "侧栏")),
                        RibbonItem.Small("grid", Gallery.T("Grid", "网格"))
                    }),
                    RibbonGroup.Of(Gallery.T("Zoom", "缩放"), new List<RibbonItem>{
                        RibbonItem.Large("plus", Gallery.T("Zoom In", "放大")),
                        RibbonItem.Large("minus", Gallery.T("Zoom Out", "缩小"))
                    }),
                    RibbonGroup.Of(Gallery.T("Theme", "主题"), new List<RibbonItem>{
                        RibbonItem.Small("sun", Gallery.T("Light", "浅色")),
                        RibbonItem.Small("moon", Gallery.T("Dark", "深色"))
                    })
                };
            } else {
                rgroups = new List<RibbonGroup>{
                    RibbonGroup.Of(Gallery.T("File", "文件"), new List<RibbonItem>{
                        RibbonItem.Large("folder", Gallery.T("Open", "打开")),
                        RibbonItem.Large("save", Gallery.T("Save", "保存"))
                    }),
                    RibbonGroup.Of(Gallery.T("Edit", "编辑"), new List<RibbonItem>{
                        RibbonItem.Small("copy", Gallery.T("Copy", "复制")),
                        RibbonItem.Small("edit", Gallery.T("Rename", "重命名")),
                        RibbonItem.Small("trash", Gallery.T("Delete", "删除"))
                    }),
                    RibbonGroup.Of(Gallery.T("Run", "运行"), new List<RibbonItem>{
                        RibbonItem.Large("play", Gallery.T("Run", "运行")),
                        RibbonItem.Small("bug", Gallery.T("Debug", "调试")),
                        RibbonItem.Small("settings", Gallery.T("Config", "配置"))
                    })
                };
            }
            Ribbon.RenderTabbed(app, px, py - app.Scale(20),
                w - app.Scale(36), rtabs, Gallery.ribbonTab, rgroups);
        } else if (name == "Wizard") {
            // Full inline wizard: template list + name/location fields + a live
            // description + Create/Cancel. (Wizard.Render draws the same layout
            // full-window inside its own dialog -- see the Examples snippet.)
            List<string> names = new List<string>();
            names.Add(Gallery.T("Console app", "控制台应用"));
            names.Add(Gallery.T("GUI app", "图形界面应用"));
            names.Add(Gallery.T("Library", "库项目"));
            List<string> icons = new List<string>();
            icons.Add("code"); icons.Add("grid"); icons.Add("file");
            List<string> descs = new List<string>();
            descs.Add(Gallery.T("A terminal program with a main() entry point.",
                "带有 main() 入口的终端程序。"));
            descs.Add(Gallery.T("A windowed app built on the Zan GUI toolkit.",
                "基于 Zan GUI 工具包的窗口应用。"));
            descs.Add(Gallery.T("A reusable library with no entry point.",
                "无入口点的可复用库。"));
            int wListW = app.Scale(240);
            int wy = py - app.Scale(8);
            int wListH = app.Scale(180);
            Wizard.RenderList(app, px, wy, wListW, wListH, names, icons, Gallery.wizSel);
            int wfx = px + wListW + app.Scale(24);
            int wfw = w - app.Scale(36) - (wListW + app.Scale(24));
            Label.Secondary(app, wfx, wy, Gallery.T("Name", "名称"));
            Gallery.wizName.Render(app, wfx, wy + app.Scale(20), wfw, t.heightMedium);
            int wny = wy + app.Scale(20) + t.heightMedium + app.Scale(12);
            Label.Secondary(app, wfx, wny, Gallery.T("Location", "位置"));
            Gallery.wizLoc.Render(app, wfx, wny + app.Scale(20), wfw, t.heightMedium);
            int wdy = wny + app.Scale(20) + t.heightMedium + app.Scale(14);
            int wsel = Gallery.wizSel.Get();
            if (wsel >= 0 && wsel < descs.Count) {
                Label.Secondary(app, wfx, wdy, descs[wsel]);
            }
            int wby = wy + wListH + app.Scale(16);
            int wbw = app.Scale(104);
            Button.Create(Gallery.T("Cancel", "取消")).Render(app, wfx, wby, wbw);
            Button.Primary(Gallery.T("Create", "创建")).Render(
                app, wfx + wbw + t.gapMedium, wby, wbw);
        } else if (name == "Split") {
            // Two real, draggable Split widgets: a vertical divider (left|right)
            // and a horizontal one (top|bottom). Drag the coloured handle.
            int sy = py - app.Scale(16);
            int sh = app.Scale(250);
            int colW = (w - app.Scale(56)) / 2;
            Rect a1 = Rect.Create(px, sy, colW, sh);
            Split sp = Split.Vertical(app, a1, Gallery.splitVFirst,
                app.Scale(70), app.Scale(70));
            c.FillRect(sp.first.x, sp.first.y, sp.first.width, sp.first.height,
                t.bgSecondary);
            c.FillRect(sp.second.x, sp.second.y, sp.second.width,
                sp.second.height, t.bgTertiary);
            Label.Secondary(app, sp.first.x + app.Scale(10),
                sp.first.y + app.Scale(8), Gallery.T("Left", "左侧"));
            Label.Secondary(app, sp.second.x + app.Scale(10),
                sp.second.y + app.Scale(8), Gallery.T("Right", "右侧"));

            Rect a2 = Rect.Create(px + colW + app.Scale(24), sy, colW, sh);
            Split sp2 = Split.Horizontal(app, a2, Gallery.splitHFirst,
                app.Scale(50), app.Scale(50));
            c.FillRect(sp2.first.x, sp2.first.y, sp2.first.width,
                sp2.first.height, t.bgSecondary);
            c.FillRect(sp2.second.x, sp2.second.y, sp2.second.width,
                sp2.second.height, t.bgTertiary);
            Label.Secondary(app, sp2.first.x + app.Scale(10),
                sp2.first.y + app.Scale(8), Gallery.T("Top", "上部"));
            Label.Secondary(app, sp2.second.x + app.Scale(10),
                sp2.second.y + app.Scale(8), Gallery.T("Bottom", "下部"));
        } else if (name == "FilePicker") {
            // Live: each button opens the real modal dialog window; the chosen
            // path is read back from TakeResult() in the main loop. The open-file
            // dialog offers several extension filters (see BeginOpenFileFilters).
            int fbw = app.Scale(160);
            int fbh = t.heightMedium;
            int fgap = app.Scale(10);
            int ofId = Button.Create(
                Gallery.T("Open file...", "打开文件...")).Render(app, px, py, fbw);
            if (Button.WasClicked(app, ofId)) {
                List<string> flabels = new List<string>();
                List<string> fpats = new List<string>();
                flabels.Add(Gallery.T("Zan source (*.zan)", "Zan 源文件 (*.zan)"));
                fpats.Add(".zan");
                flabels.Add(Gallery.T("Text (*.txt;*.md)", "文本 (*.txt;*.md)"));
                fpats.Add(".txt;.md");
                flabels.Add(Gallery.T("Data (*.json)", "数据 (*.json)"));
                fpats.Add(".json");
                flabels.Add(Gallery.T("All files (*.*)", "所有文件 (*.*)"));
                fpats.Add("");
                Gallery.filePicker.BeginOpenFileFilters("", flabels, fpats,
                    Gallery.T("Open file", "打开文件"));
            }
            int odId = Button.Create(
                Gallery.T("Open folder...", "打开文件夹...")).Render(
                app, px + fbw + fgap, py, fbw);
            if (Button.WasClicked(app, odId)) {
                Gallery.filePicker.BeginFolder("",
                    Gallery.T("Open folder", "打开文件夹"));
            }
            int fr2 = py + fbh + fgap;
            int sfId = Button.Create(
                Gallery.T("Save file...", "保存文件...")).Render(app, px, fr2, fbw);
            if (Button.WasClicked(app, sfId)) {
                Gallery.filePicker.BeginSaveFile("", ".zan", "untitled.zan",
                    Gallery.T("Save file", "保存文件"));
            }
            int sdId = Button.Create(
                Gallery.T("Save to folder...", "保存到文件夹...")).Render(
                app, px + fbw + fgap, fr2, fbw);
            if (Button.WasClicked(app, sdId)) {
                Gallery.filePicker.BeginFolder("",
                    Gallery.T("Save to folder", "保存到文件夹"));
            }
            int fry = fr2 + fbh + app.Scale(16);
            if (Gallery.pickerResult != "") {
                Label.Render(app, px, fry, Gallery.T("Selected path:", "已选路径："));
                Label.Secondary(app, px, fry + app.Scale(20),
                    Ellipsis.Fit(Gallery.pickerResult, w - app.Scale(52), t.fontSizeMedium));
            } else {
                Label.Secondary(app, px, fry,
                    Gallery.T("No selection yet -- click a button to open a dialog.",
                        "尚未选择 —— 点击按钮打开对话框。"));
            }
        } else if (name == "CodeEditor") {
            Label.Render(app, px, py - app.Scale(12),
                "The code panel below is a read-only CodeEditor view.");
            Label.Secondary(app, px, py + app.Scale(16),
                "CodeEditor powers this IDE's editor: highlighting,");
            Label.Secondary(app, px, py + app.Scale(38),
                "line numbers, selection, completion and diagnostics.");
        } else if (name == "ClickEvent") {
            Gallery.evtButton.Render(app, px, py - app.Scale(8), app.Scale(200));
            Label.Render(app, px, py + app.Scale(34),
                "Click fired on the UI thread · count: "
                    + Convert.ToString(Gallery.evtClicks));
            Label.Secondary(app, px, py + app.Scale(62),
                "registered once with  button.Click += handler");
        } else if (name == "Events") {
            Gallery.evtStartButton.Render(app, px, py - app.Scale(8), app.Scale(210));
            Label.Render(app, px, py + app.Scale(34),
                "Ticks posted from worker thread: "
                    + Convert.ToString(Gallery.evtValue.Get()));
            if (Gallery.evtRunning.Get()) {
                Label.Secondary(app, px, py + app.Scale(62),
                    "running - app.Post marshals each tick to the UI thread");
            } else {
                Label.Secondary(app, px, py + app.Scale(62),
                    "idle - click to spawn a Thread that reports back safely");
            }
        } else {
            rendered = false;
        }
        if (!rendered) {
            Icon.Draw(c, "code", px, py, app.Scale(30), t.primary);
            c.DrawText(px + app.Scale(46), py, "Overlay / interactive component", t.textPrimary, t.fontSizeMedium);
            c.DrawText(px + app.Scale(46), py + app.Scale(28), "Copy the API example below to use it.", t.textSecondary, t.fontSizeSmall);
        }
        c.PopClip();
        return h;
    }

    /// Components whose live demo floats outside the preview box (dropdowns,
    /// menus, popovers, a table with a filter panel). They are drawn in the
    /// deferred overlay pass so their popups sit above the code panel.
    static bool IsOverlayComp(string name) {
        if (name == "Select") { return true; }
        if (name == "SelectBox") { return true; }
        if (name == "Dropdown") { return true; }
        if (name == "Popover") { return true; }
        if (name == "DataTable") { return true; }
        if (name == "Layer") { return true; }
        if (name == "Designer") { return true; }
        return false;
    }

    static void RenderOverlay(App app, Canvas c, Theme t, string name,
            int x, int y, int w) {
        int px = x + app.Scale(18);
        int py = y + app.Scale(48);
        if (name == "SelectBox") {
            Label.Secondary(app, px, py - app.Scale(24), "single · clearable");
            Gallery.demoSelect.Render(app, px, py, app.Scale(180));
            Label.Secondary(app, px + app.Scale(200), py - app.Scale(24), "multi-select");
            Gallery.demoMulti.Render(app, px + app.Scale(200), py, app.Scale(180));
            Label.Secondary(app, px + app.Scale(400), py - app.Scale(24), "long · scrolls");
            Gallery.demoLong.Render(app, px + app.Scale(400), py, app.Scale(180));
        } else if (name == "Select") {
            // Retained instance: owns its open state and defers the option list
            // to the framework overlay layer (draws above the code panel, one
            // centralized dispatch). No manual hit-testing here.
            Gallery.demoSelectLow.Render(app, px, py, app.Scale(220), t.heightMedium);
            Label.Secondary(app, px, py + t.heightMedium + app.Scale(10),
                "click to open · Change fires on select");
        } else if (name == "Dropdown") {
            // Retained: click to open; the menu defers to the overlay layer so
            // it draws on top, blocks click-through and closes on outside press.
            Gallery.demoDropdown.Render(app, px, py, app.Scale(160), t.heightMedium);
            Label.Secondary(app, px, py + t.heightMedium + app.Scale(10),
                "click to open · Change fires on choose");
        } else if (name == "Popover") {
            // Retained: click the trigger to open an anchored, word-wrapped,
            // click-blocking panel that closes on an outside press or Esc.
            Gallery.demoPopover.Render(app, px, py, app.Scale(150), t.heightMedium);
        } else if (name == "DataTable") {
            List<DataColumn> cols = new List<DataColumn>();
            cols.Add(DataColumn.Text("Name", app.Scale(160)));
            cols.Add(DataColumn.Numeric("Score", app.Scale(100)));
            List<DataRow> rows = new List<DataRow>();
            DataRow row = DataRow.Create();
            row.Push("Zan"); row.Push("98"); rows.Add(row);
            DataRow row2 = DataRow.Create();
            row2.Push("Lang"); row2.Push("87"); rows.Add(row2);
            DataTable.Render(app, px, py - app.Scale(20), w - app.Scale(36),
                app.Scale(110), cols, rows, Gallery.demoTableState);
        } else if (name == "Compose") {
            // Fluent retained-mode composition: a titled card holding a column
            // of a label, a progress bar and a row of buttons — all nested with
            // With(), auto-docked and auto-measured.
            Panel card = new Panel("card");
            card.Titled("Create account");
            card.Add(
                Panel.Column().Gap(app.Scale(10))
                    .With(new Label("Fill in the details below.").Variant(1))
                    .With(new Progress(66, 3))
                    .With(Panel.Row().Gap(app.Scale(10))
                        .With(Button.Create("Cancel"))
                        .With(Button.Primary("Save"))));
            // Round-trip through the serializer: what you see is rebuilt from the
            // saved document, proving save/load preserves the whole tree + props.
            string doc = Serialize.Save(card);
            Control loaded = Serialize.Load(doc);
            loaded.MeasureTree(app);
            loaded.Arrange(px, py - app.Scale(8), w - app.Scale(36), app.Scale(190));
            loaded.RenderTree(app);
        } else if (name == "Designer") {
            Gallery.designer.Render(app, x, y, w, app.Scale(Gallery.PreviewHeight(name)));
        } else if (name == "Layer") {
            Gallery.RenderLayerDemo(app, t, px, py, w);
        }
    }

    /// The unified Layer demo: a layui-style grid of trigger buttons that open
    /// every overlay flavour, then the active layers drawn above everything.
    static void RenderLayerDemo(App app, Theme t, int px, int py, int w) {
        int bx = px;
        int by = py;
        int bw = app.Scale(118);
        int bh = t.heightMedium;
        int gap = app.Scale(10);
        int rowGap = app.Scale(34);

        Label.Secondary(app, bx, by - app.Scale(22), "Dialogs");
        int a1 = Button.Create("Alert").Render(app, bx, by, bw);
        if (Button.WasClicked(app, a1)) { Gallery.dlgAlert.Open(); }
        int a2 = Button.Create("Confirm").Render(app, bx + (bw + gap), by, bw);
        if (Button.WasClicked(app, a2)) { Gallery.dlgConfirm.Open(); }
        int a3 = Button.Create("Prompt").Render(app, bx + (bw + gap) * 2, by, bw);
        if (Button.WasClicked(app, a3)) { Gallery.dlgPrompt.Open(); }
        by = by + bh + rowGap;

        Label.Secondary(app, bx, by - app.Scale(22),
            "Message toasts · queue, auto-dismiss, collapse upward");
        int m1 = Button.Create("Success msg").Render(app, bx, by, bw);
        if (Button.WasClicked(app, m1)) { Layer.Msg("Saved successfully", 3); }
        int m2 = Button.Create("Warning msg").Render(app, bx + (bw + gap), by, bw);
        if (Button.WasClicked(app, m2)) { Layer.Msg("Unsaved changes", 4); }
        int m3 = Button.Create("Error msg").Render(app, bx + (bw + gap) * 2, by, bw);
        if (Button.WasClicked(app, m3)) { Layer.Msg("Network error", 5); }
        by = by + bh + rowGap;

        Label.Secondary(app, bx, by - app.Scale(22), "Notification · loading · tips");
        int n1 = Button.Create("Notify").Render(app, bx, by, bw);
        if (Button.WasClicked(app, n1)) { Layer.Notify("Build completed", 3); }
        int n2 = Button.Create("Loading").Render(app, bx + (bw + gap), by, bw);
        if (Button.WasClicked(app, n2)) { Gallery.loadStartMs = Window.GetTickMs(); }
        int tipsX = bx + (bw + gap) * 2;
        bool tipsNow = Gallery.tipsOn.Get();
        string tlbl = "Tips";
        if (tipsNow) { tlbl = "Hide tips"; }
        int n3 = Button.Create(tlbl).Render(app, tipsX, by, bw);
        if (Button.WasClicked(app, n3)) { Gallery.tipsOn.Set(!tipsNow); }
        int tipAX = tipsX + bw / 2;
        // Anchor the tip to the button's TOP edge so the top-placed bubble sits
        // above the whole button (notch touching the top edge) instead of
        // growing up from the bottom edge and covering the label.
        int tipAY = by;
        by = by + bh + rowGap;

        Label.Secondary(app, bx, by - app.Scale(22),
            "Draggable windows · full-screen photo carousel");
        int w1 = Button.Primary("Open window").Render(app, bx, by, bw);
        if (Button.WasClicked(app, w1)) { Gallery.SpawnLayer(app); }
        int w2 = Button.Create("Photos").Render(app, bx + (bw + gap), by, bw);
        if (Button.WasClicked(app, w2)) {
            Gallery.photoIdx.Set(0);
            Gallery.photosOpen.Set(true);
        }
        Gallery.PopupHint(app, bx + (bw + gap) * 2, by);

        // ---- active layers (drawn above the buttons and the code panel) ----
        Layer.RenderStack(app, Gallery.demoLayers);

        if (Gallery.dlgAlert.open) {
            Layer.Render(app, Gallery.dlgAlert);
            if (Gallery.dlgAlert.action != 0) {
                Gallery.dlgAlert.open = false;
                Gallery.popupResult = "alert: OK";
            }
        }
        if (Gallery.dlgConfirm.open) {
            Layer.Render(app, Gallery.dlgConfirm);
            int ca = Gallery.dlgConfirm.action;
            if (ca == 1) { Gallery.dlgConfirm.open = false; Gallery.popupResult = "confirm: yes"; }
            else if (ca == 2 || ca == 3) { Gallery.dlgConfirm.open = false; Gallery.popupResult = "confirm: no"; }
        }
        if (Gallery.dlgPrompt.open) {
            Layer.Render(app, Gallery.dlgPrompt);
            int pa = Gallery.dlgPrompt.action;
            if (pa == 1) {
                Gallery.dlgPrompt.open = false;
                Gallery.popupResult = "prompt: " + Gallery.dlgPrompt.PromptText();
            } else if (pa == 2 || pa == 3) {
                Gallery.dlgPrompt.open = false;
                Gallery.popupResult = "prompt: cancelled";
            }
        }

        if (Gallery.loadStartMs > 0) {
            int el = Window.GetTickMs() - Gallery.loadStartMs;
            if (el >= 3000) {
                Gallery.loadStartMs = 0;
                Gallery.popupResult = "loading: done";
            } else {
                Layer.RenderLoad(app, px - app.Scale(6), py - app.Scale(6),
                    w - app.Scale(24), app.Scale(300), "Loading data...");
                app.RequestAnimationFrame(16);
            }
        }

        if (Gallery.tipsOn.Get()) {
            Layer.Tips(app, tipAX, tipAY, "This is a tip bubble.");
        }

        if (Gallery.photosOpen.Get()) {
            bool close = Layer.RenderPhotos(app, Gallery.photoSlides,
                Gallery.photoIdx, Gallery.photoAnim);
            if (close) { Gallery.photosOpen.Set(false); }
        }

        Layer.RenderToasts(app);
        Layer.RenderNotifs(app);
    }

    /// Spawns a new floating Layer window, cascaded down-right from the last
    /// one so several are visibly stacked. Each is independent and draggable.
    static void SpawnLayer(App app) {
        int n = Gallery.layerSeq;
        Gallery.layerSeq = n + 1;
        int off = (n % 6) * app.Scale(28);
        LayerState win = LayerState.Create(
            "Window " + Convert.ToString(n + 1),
            app.Scale(360) + off, app.Scale(150) + off,
            app.Scale(400), app.Scale(230));
        win.body = "Drag the title bar. Click a window to raise it.";
        win.Open();
        Gallery.demoLayers.Add(win);
    }

    /// Shows the last popup action beneath the trigger button in a demo.
    static void PopupHint(App app, int px, int py) {
        if (Gallery.popupResult != "") {
            Label.Secondary(app, px, py + app.Scale(46), "last: " + Gallery.popupResult);
        } else {
            Label.Secondary(app, px, py + app.Scale(46), "click the button to open");
        }
    }

    // ------------------------------------------------------------------
    // Text wrapping helper
    // ------------------------------------------------------------------

    static List<string> WrapText(string text, int width, int fontSize) {
        List<string> lines = new List<string>();
        string cur = "";
        string word = "";
        int i = 0;
        while (i <= text.Length) {
            string ch = "";
            if (i < text.Length) { ch = text.Substring(i, 1); }
            if (i == text.Length || ch == " ") {
                string trial = cur;
                if (trial != "") { trial = trial + " "; }
                trial = trial + word;
                if (Canvas.MeasureText(trial, fontSize) > width && cur != "") {
                    lines.Add(cur);
                    cur = word;
                } else {
                    cur = trial;
                }
                word = "";
            } else {
                word = word + ch;
            }
            i = i + 1;
        }
        if (cur != "") { lines.Add(cur); }
        if (lines.Count == 0) { lines.Add(""); }
        return lines;
    }

    // ------------------------------------------------------------------
    // Catalog
    // ------------------------------------------------------------------

    static Comp Add(List<Comp> list, string cat, string name, string desc, string code) {
        Comp e = Comp.Create(cat, name, desc, code);
        list.Add(e);
        return e;
    }

    static Comp AddJson(List<Comp> list, string cat, string name, string desc,
            string code, string json) {
        Comp e = Comp.CreateJson(cat, name, desc, code, json);
        list.Add(e);
        return e;
    }

    static void BuildComps(List<Comp> list) {
        Gallery.BuildBasic(list);
        Gallery.BuildDataEntry(list);
        Gallery.BuildDataDisplay(list);
        Gallery.BuildFeedback(list);
        Gallery.BuildNavigation(list);
        Gallery.BuildLayout(list);
        Gallery.BuildEvents(list);
    }

    static void BuildEvents(List<Comp> list) {
        Gallery.Add(list, "Events", "ClickEvent",
            Gallery.T("Widgets expose C#-style events. Register handlers with the delegate += operator (lambda or method group); the handler fires from inside Render on the UI thread, so it is always safe to touch UI state -- no id polling. Use -= to remove one, or myEvent.Post() to raise from a worker thread (marshals each handler to the UI thread).",
                "组件暴露 C# 风格的事件。用委托 += 运算符注册处理器（lambda 或方法组）；处理器在 UI 线程的 Render 内触发，因此随时可安全操作 UI 状态，无需轮询 id。用 -= 移除，或用 myEvent.Post() 从工作线程触发（每个处理器都会封送回 UI 线程）。"),
            "Button save = Button.Create(\"Save\");   // retained\nsave.Click += () => { Console.WriteLine(\"saved\"); };\nsave.Click += Store.Commit;             // method group\n// each frame:\nsave.Render(app, 40, 80, 120);          // fires Click on click\n// remove: save.Click -= Store.Commit;");
        Gallery.Add(list, "Events", "Events",
            Gallery.T("C#-style delegates and thread-safe events. A retained Button registers its handler once with  Click += StartTask; a background Thread reports progress back through app.Post, which runs the delegate on the UI thread (the Control.Invoke equivalent) so widget state is never touched off-thread.",
                "C# 风格的委托与线程安全事件。保留态 Button 用 Click += StartTask 注册一次处理器；后台线程通过 app.Post 回报进度，委托在 UI 线程上执行（相当于 Control.Invoke），从而绝不在非 UI 线程操作组件状态。"),
            "// Retained button: register the handler once, like C# OnClick += ...\nButton start = Button.Primary(\"Start background task\");\nstart.Click += StartTask;        // method group (Action)\n\n// each frame:\nstart.Render(app, 40, 80, 210);  // fires Click on click\n\nstatic void StartTask() {\n    Thread.Start(Worker);       // real OS thread\n}\n\n// Runs off the UI thread: hand results back with app.Post.\nstatic void Worker() {\n    Thread.Sleep(140);\n    app.Post(() => { value.Set(value.Get() + 1); });\n}");
    }

    static void BuildLayout(List<Comp> list) {
        Gallery.Add(list, "Layout", "Split",
            Gallery.T("A draggable split view. Create it over an area with the first pane size bound to a SignalInt, then draw into its two rects.",
                "可拖动的分隔视图。在一块区域上创建，第一个窗格的尺寸绑定到 SignalInt，然后分别绘制它的两个矩形区域。"),
            "// left|right divider, size kept in a persistent signal\nSplit sp = Split.Vertical(app, area, firstW, 70, 70);\n// draw into sp.first and sp.second each frame\n\n// top|bottom divider uses the same widget\nSplit sp2 = Split.Horizontal(app, area2, firstH, 50, 50);")
            .AddProp("firstW", "SignalInt", "-", "First pane size (two-way, drag updates it).")
            .AddProp("minFirst", "int", "-", "Minimum size of the first pane.")
            .AddProp("minSecond", "int", "-", "Minimum size of the second pane.")
            .AddEvent("first / second", "Rect", "The two pane rectangles to draw into.");
        Gallery.Add(list, "Layout", "TabView",
            Gallery.T("An editor-style tab strip with an optional add button. Render returns a TabHit; Apply switches, closes or adds tabs.",
                "编辑器风格的标签栏，可选新增按钮。Render 返回 TabHit；Apply 负责切换、关闭或新增标签。"),
            "// keep labels in retained state so add/close/select stick\nTabHit hit = TabView.Render(app, area.x, area.y, area.width,\n    TabView.Height(app), labels, active, true);\nif (hit.action == 3) {\n    TabView.Apply(hit, labels, active, \"untitled\");\n} else {\n    TabView.Apply(hit, labels, active, \"\");\n}")
            .AddProp("labels", "List<string>", "-", "Open tab labels.")
            .AddProp("active", "SignalInt", "-", "Active tab index (two-way).")
            .AddProp("addButton", "bool", "false", "Show the trailing + button.")
            .AddEvent("Render(...)", "TabHit", "Apply() then switches, closes or adds a tab.");
        Gallery.Add(list, "Layout", "Ribbon",
            Gallery.T("An Office-style tabbed ribbon: a tab strip over captioned groups mixing large and small commands. RenderTabbed returns the clicked global command index or -1.",
                "Office 风格的选项卡式功能区：标签栏下方是带标题的分组，混排大、小命令按钮。RenderTabbed 返回被点击命令的全局索引，未点击则为 -1。"),
            "List<string> tabs = new List<string>{ \"Home\", \"View\" };\n\nList<RibbonGroup> groups = new List<RibbonGroup>{\n    RibbonGroup.Of(\"File\", new List<RibbonItem>{\n        RibbonItem.Large(\"folder\", \"Open\"),\n        RibbonItem.Large(\"save\", \"Save\")\n    }),\n    RibbonGroup.Of(\"Edit\", new List<RibbonItem>{\n        RibbonItem.Small(\"copy\", \"Copy\"),\n        RibbonItem.Small(\"trash\", \"Delete\")\n    })\n};\n\nint cmd = Ribbon.RenderTabbed(app, x, top, w, tabs, activeTab, groups);\nif (cmd == 0) { /* Open */ }")
            .AddProp("tabs", "List<string>", "-", "Ribbon tab captions.")
            .AddProp("activeTab", "SignalInt", "-", "Active tab index (two-way).")
            .AddProp("groups", "List<RibbonGroup>", "-", "Captioned command groups (large + small items).")
            .AddEvent("RenderTabbed(...)", "int", "Returns the clicked global command index, or -1.");
        Gallery.Add(list, "Layout", "Wizard",
            Gallery.T("A categorized launcher list (e.g. project templates) with a selected index bound to a SignalInt.",
                "分类的启动列表（例如项目模板），选中项索引绑定到 SignalInt。"),
            "// full-window wizard: template list + name/location fields\n// + live description + Create / Cancel buttons\nint r = Wizard.Render(app, \"New project\", names, icons, descs,\n    sel, nameInput, locInput, true);\nif (r == 1) {\n    // create\n} else if (r == 2) {\n    // cancel / close\n}")
            .AddProp("names", "List<string>", "-", "Template labels.")
            .AddProp("icons", "List<string>", "-", "Per-template icon names.")
            .AddProp("descs", "List<string>", "-", "Per-template descriptions.")
            .AddProp("sel", "SignalInt", "-", "Selected template index (two-way).")
            .AddProp("nameInput / locInput", "Input", "-", "Retained name / location fields.")
            .AddEvent("Render(...)", "int", "0 none, 1 create, 2 cancel/close.");
        Gallery.Add(list, "Layout", "FilePicker",
            Gallery.T("An open/save/folder dialog in its own OS window. Begin a session, route its window events in your loop, and read the chosen path from TakeResult(). Route each event to whichever window owns it (by hwnd) so the parent stays responsive while the dialog is open.",
                "在独立系统窗口中弹出的“打开/保存/选择文件夹”对话框。开启一个会话，在事件循环中转发它的窗口事件，再从 TakeResult() 读取所选路径。按 hwnd 把每个事件分派给对应窗口，这样对话框打开时父窗口仍可正常响应。"),
            "FilePicker fp = FilePicker.Create();\n// open with several extension filters (label + pattern list):\nList<string> labels = new List<string>{ \"Zan source (*.zan)\", \"Text (*.txt;*.md)\", \"All files (*.*)\" };\nList<string> pats = new List<string>{ \".zan\", \".txt;.md\", \"\" };\nfp.BeginOpenFileFilters(\"\", labels, pats, \"Open file\");\n\n// in the event loop, route by the OWNING window (native hwnd) so the parent\n// keeps responding while the dialog is open -- do NOT gate on fp.IsOpen():\nint evh = Window.EventHwnd();\nif (fp.OwnsWindow(evh)) {\n    fp.ApplyEvent(evh);\n} else {\n    app.ApplyEvent(evh);\n}\nfp.RenderWindow();\nif (fp.TakeResult() == 1) {\n    string path = fp.SelectedPath();\n}")
            .AddProp("mode", "BeginOpenFile/Filters/Save/Folder", "-", "Which dialog to start.")
            .AddProp("filters", "List<string>", "-", "Label + pattern lists (e.g. \".txt;.md\").")
            .AddProp("title", "string", "-", "Dialog title.")
            .AddEvent("IsOpen()", "bool", "False once the user confirms or cancels.")
            .AddEvent("SelectedPath()", "string", "The chosen path after it closes.");
        Gallery.Add(list, "Layout", "CodeEditor",
            Gallery.T("The full text editor widget: Zan syntax highlighting, line numbers, multi-cursor, selection, autocomplete and inline diagnostics.",
                "完整的文本编辑器组件：Zan 语法高亮、行号、多光标、选区、自动补全与内联诊断。"),
            "CodeEditor ed = new CodeEditor();\ned.SetText(\"class Main {\\n}\\n\");\nRect area = Rect.Create(0, top, w, h - top);\ned.Render(app, area);\nstring src = ed.GetText();")
            .AddProp("area", "Rect", "-", "Editor bounds (Render).")
            .AddProp("text", "string", "-", "Buffer contents (SetText/GetText).")
            .AddEvent("GetText()", "string", "The current edited source.");
    }

    static void BuildBasic(List<Comp> list) {
        Comp bt = Comp.Create("Basic", "Button",
            "Button is a retained Control: build one with a factory (Create/Typed/Styled/...), add it to a container (Panel.Row/Column or a Form) and layout is automatic -- no x/y/width. Wire a handler with `b.Click += ...`. Every look is a factory/config on the component -- types, styles, secondary, ghost, loading, shapes and sizes -- so demos only compose, no custom drawing.", "");
        bt.AddDemo("Types", "Six semantic types via Button.Typed(text, type). Type 0=default,1=primary,2=info,3=success,4=warning,5=error.", "Button.types", 78,
            "// Retained: a Row lays the buttons out -- no x/y/width.\nPanel row = Panel.Row().Gap(10);\nrow.With(Button.Create(\"Default\"))\n   .With(Button.Typed(\"Primary\", 1))\n   .With(Button.Typed(\"Info\", 2))\n   .With(Button.Typed(\"Success\", 3))\n   .With(Button.Typed(\"Warning\", 4))\n   .With(Button.Typed(\"Error\", 5));\nform.Add(row);",
            "[\n  { \"kind\": \"Button\", \"text\": \"Default\", \"type\": \"default\" },\n  { \"kind\": \"Button\", \"text\": \"Primary\", \"type\": \"primary\" },\n  { \"kind\": \"Button\", \"text\": \"Info\",    \"type\": \"info\" },\n  { \"kind\": \"Button\", \"text\": \"Success\", \"type\": \"success\" },\n  { \"kind\": \"Button\", \"text\": \"Warning\", \"type\": \"warning\" },\n  { \"kind\": \"Button\", \"text\": \"Error\",   \"type\": \"error\" }\n]");
        bt.AddDemo("Styles", "Button.Styled(text, type, style) picks the fill treatment: 0=solid,1=outline,2=text,3=dashed. Secondary and Ghost are their own factories.", "Button.styles", 78,
            "Panel row = Panel.Row().Gap(10);\nrow.With(Button.Styled(\"Solid\", 1, 0))\n   .With(Button.Styled(\"Outline\", 1, 1))\n   .With(Button.Styled(\"Text\", 1, 2))\n   .With(Button.Styled(\"Dashed\", 1, 3))\n   .With(Button.Secondary(\"Secondary\", 1))\n   .With(Button.Ghost(\"Ghost\", 1));\nform.Add(row);",
            "[\n  { \"kind\": \"Button\", \"text\": \"Solid\",     \"type\": \"primary\", \"style\": \"solid\" },\n  { \"kind\": \"Button\", \"text\": \"Outline\",   \"type\": \"primary\", \"style\": \"outline\" },\n  { \"kind\": \"Button\", \"text\": \"Text\",      \"type\": \"primary\", \"style\": \"text\" },\n  { \"kind\": \"Button\", \"text\": \"Dashed\",    \"type\": \"primary\", \"style\": \"dashed\" },\n  { \"kind\": \"Button\", \"text\": \"Secondary\", \"type\": \"primary\", \"secondary\": true },\n  { \"kind\": \"Button\", \"text\": \"Ghost\",     \"type\": \"primary\", \"ghost\": true }\n]");
        bt.AddDemo("流光效果 (cursor-driven)", "Opt-in border light -- Button.Specular(text, type). A small symmetric pair of glints rides the button's border, brightest at the edge nearest the cursor and mirrored on the opposite side; it moves only when the pointer moves (no auto-spin, zero repaints when still), stays on the border so it never covers the label, and is clipped to the button so nothing spills onto neighbours.", "Button.specular", 78,
            "Panel row = Panel.Row().Gap(10);\nrow.With(Button.Specular(\"Hover me\", 1))\n   .With(Button.Specular(\"Success\", 3))\n   .With(Button.Specular(\"Error\", 5))\n   .With(Button.Specular(\"Default\", 0));\nform.Add(row);",
            "[\n  { \"kind\": \"Button\", \"text\": \"Hover me\", \"type\": \"primary\", \"specular\": true },\n  { \"kind\": \"Button\", \"text\": \"Success\",  \"type\": \"success\", \"specular\": true },\n  { \"kind\": \"Button\", \"text\": \"Error\",    \"type\": \"error\",   \"specular\": true }\n]");
        bt.AddDemo("Secondary buttons", "A subtly tinted fill with type-colored text -- Button.Secondary(text, type) -- for lower-emphasis actions.", "Button.secondary", 78,
            "Panel row = Panel.Row().Gap(10);\nrow.With(Button.Secondary(\"Default\", 0))\n   .With(Button.Secondary(\"Primary\", 1))\n   .With(Button.Secondary(\"Info\", 2))\n   .With(Button.Secondary(\"Success\", 3))\n   .With(Button.Secondary(\"Warning\", 4))\n   .With(Button.Secondary(\"Error\", 5));\nform.Add(row);",
            "[\n  { \"kind\": \"Button\", \"text\": \"Default\", \"type\": \"default\", \"secondary\": true },\n  { \"kind\": \"Button\", \"text\": \"Primary\", \"type\": \"primary\", \"secondary\": true },\n  { \"kind\": \"Button\", \"text\": \"Info\",    \"type\": \"info\",    \"secondary\": true },\n  { \"kind\": \"Button\", \"text\": \"Success\", \"type\": \"success\", \"secondary\": true },\n  { \"kind\": \"Button\", \"text\": \"Warning\", \"type\": \"warning\", \"secondary\": true },\n  { \"kind\": \"Button\", \"text\": \"Error\",   \"type\": \"error\",   \"secondary\": true }\n]");
        bt.AddDemo("Loading, disabled & custom color", "Loading shows a built-in spinner and ignores clicks; SetDisabled greys it out; Button.Colored(text, argb) paints any brand color.", "Button.states", 78,
            "Panel row = Panel.Row().Gap(10);\nrow.With(Button.Loading(\"Loading\", 1))\n   .With(Button.Loading(\"\", 3).SetCircle(true))\n   .With(Button.Create(\"Disabled\").SetDisabled(true))\n   .With(Button.Colored(\"Pink\", 0xFFE91E63))\n   .With(Button.Colored(\"Teal\", 0xFF13C2C2));\nform.Add(row);",
            "[\n  { \"kind\": \"Button\", \"text\": \"Loading\",  \"type\": \"primary\", \"loading\": true },\n  { \"kind\": \"Button\", \"text\": \"\",         \"type\": \"success\", \"loading\": true, \"circle\": true },\n  { \"kind\": \"Button\", \"text\": \"Disabled\", \"type\": \"default\", \"disabled\": true },\n  { \"kind\": \"Button\", \"text\": \"Pink\",     \"color\": \"#E91E63\" },\n  { \"kind\": \"Button\", \"text\": \"Teal\",     \"color\": \"#13C2C2\" }\n]");
        bt.AddDemo("Icons & shapes", "Round(text,type), IconTextTyped(text,icon,type) for icon+label, and IconTyped(icon,type) for icon-only square buttons.", "Button.shapes", 78,
            "Panel row = Panel.Row().Gap(10);\nrow.With(Button.Round(\"Round\", 1))\n   .With(Button.IconTextTyped(\"Save\", \"save\", 3))\n   .With(Button.IconTyped(\"plus\", 1))\n   .With(Button.IconTyped(\"settings\", 0));\nform.Add(row);",
            "[\n  { \"kind\": \"Button\", \"text\": \"Round\", \"type\": \"primary\", \"round\": true },\n  { \"kind\": \"Button\", \"text\": \"Save\",  \"type\": \"success\", \"icon\": \"save\" },\n  { \"kind\": \"Button\", \"text\": \"\",      \"type\": \"primary\", \"icon\": \"plus\" },\n  { \"kind\": \"Button\", \"text\": \"\",      \"type\": \"default\", \"icon\": \"settings\" }\n]");
        bt.AddDemo("Sizes", "SetSize(size) scales the control: 0=tiny,1=small,2=medium (default),3=large.", "Button.sizes", 78,
            "Panel row = Panel.Row().Gap(10);\nrow.With(Button.Create(\"Tiny\").SetSize(0))\n   .With(Button.Create(\"Small\").SetSize(1))\n   .With(Button.Create(\"Medium\").SetSize(2))\n   .With(Button.Create(\"Large\").SetSize(3));\nform.Add(row);",
            "[\n  { \"kind\": \"Button\", \"text\": \"Tiny\",   \"size\": \"tiny\" },\n  { \"kind\": \"Button\", \"text\": \"Small\",  \"size\": \"small\" },\n  { \"kind\": \"Button\", \"text\": \"Medium\", \"size\": \"medium\" },\n  { \"kind\": \"Button\", \"text\": \"Large\",  \"size\": \"large\" }\n]");
        bt.AddDemo("Button group", "ButtonGroup.Create(type) welds buttons together with shared borders (rounded only on the outer corners). Add(label) appends a segment; Outline(true) for an outlined group; Render returns the clicked index or -1.", "Button.group", 78,
            "ButtonGroup g = ButtonGroup.Create(1);\ng.Add(\"Left\"); g.Add(\"Middle\"); g.Add(\"Right\");\nint hit = g.Render(app, 0, 40);   // clicked index, or -1\n\nButtonGroup seg = ButtonGroup.Create(2).Outline(true);\nseg.Add(\"Day\"); seg.Add(\"Week\"); seg.Add(\"Month\"); seg.Add(\"Year\");\nseg.Render(app, 240, 40);",
            "[\n  { \"kind\": \"ButtonGroup\", \"type\": \"primary\",\n    \"buttons\": [\"Left\", \"Middle\", \"Right\"] },\n  { \"kind\": \"ButtonGroup\", \"type\": \"info\", \"outline\": true,\n    \"buttons\": [\"Day\", \"Week\", \"Month\", \"Year\"] }\n]");
        bt.AddProp("text", "string", "\"\"", "Button label.");
        bt.AddProp("icon", "string", "\"\"", "Optional leading icon name.");
        bt.AddProp("type", "int", "0", "0 default,1 primary,2 info,3 success,4 warning,5 error.");
        bt.AddProp("style", "int", "0", "0 solid,1 outline,2 text,3 dashed.");
        bt.AddProp("size", "int", "2", "0 tiny,1 small,2 medium,3 large.");
        bt.AddProp("secondary", "bool", "false", "Tinted low-emphasis fill.");
        bt.AddProp("ghost", "bool", "false", "Transparent fill, colored border+text.");
        bt.AddProp("loading", "bool", "false", "Show spinner and ignore clicks.");
        bt.AddProp("round", "bool", "false", "Fully rounded pill shape.");
        bt.AddProp("circle", "bool", "false", "Square icon-only circular button.");
        bt.AddProp("disabled", "bool", "false", "Non-interactive, greyed out.");
        bt.AddProp("customColor", "int", "0", "ARGB brand color (Button.Colored).");
        bt.AddEvent("Click", "() => void", "Fires once per frame the button is clicked (unless disabled/loading).");
        list.Add(bt);
        Gallery.Add(list, "Basic", "Label",
            Gallery.T("Labels draw static text in several styles: normal, Title and Secondary.",
                "标签以多种样式绘制静态文本：普通、标题（Title）与次要（Secondary）。"),
            "Label.Title(app, 40, 40, \"A big title\");\nLabel.Render(app, 40, 74, \"Normal text\");\nLabel.Secondary(app, 40, 104, \"subtle caption\");")
            .AddProp("text", "string", "-", "The text to draw.")
            .AddProp("variant", "Title/Render/Secondary", "Render", "Style factory to call.");
        Gallery.Add(list, "Basic", "Typography",
            Gallery.T("Headings and paragraphs for documentation and application content.",
                "用于文档和应用内容的标题与段落排版。"),
            "Typography.Heading(app, 40, 40, \"Heading\", 2);\nTypography.Paragraph(app, 40, 84, \"Readable body text.\");")
            .AddProp("text", "string", "-", "Heading / paragraph text.")
            .AddProp("level", "int", "-", "Heading level (Heading).");
        Gallery.Add(list, "Basic", "Divider",
            Gallery.T("Separate content with a plain line or a labelled divider.",
                "用一条普通分隔线或带文字的分隔线来分隔内容。"),
            "Divider.Render(app, 40, 80, 420);\nDivider.RenderText(app, 40, 120, 420, \"Section\", 0);")
            .AddProp("w", "int", "-", "Line width in px.")
            .AddProp("label", "string", "-", "Inline text (RenderText).")
            .AddProp("align", "int", "0", "Label alignment: 0 left, 1 center, 2 right.");
        Gallery.Add(list, "Basic", "Icon",
            Gallery.T("Draw a named vector icon at a given size and colour.",
                "按指定尺寸和颜色绘制一个具名矢量图标。"),
            "Icon.Draw(app.canvas, \"check\", 40, 60, 24, app.theme.primary);")
            .AddProp("name", "string", "-", "Icon name (see the grid above).")
            .AddProp("size", "int", "-", "Glyph size in px.")
            .AddProp("color", "int", "-", "ARGB stroke/fill color.")
            .AddEvent("Names()", "List<string>", "All available icon names.");
        Gallery.Add(list, "Basic", "States",
            Gallery.T("Canonical interaction-state colours shared by every component via the States helper. Precedence: disabled > pressed > selected > hovered > normal. Use it so widgets tint states identically instead of hand-picking theme fields.",
                "所有组件通过 States 助手共享的标准交互状态配色。优先级：禁用 > 按下 > 选中 > 悬停 > 常态。使用它可让各组件对状态着色保持一致，而不必手动挑选主题字段。"),
            "int bg = States.Bg(t, hovered, pressed, selected, disabled);\nint fg = States.Text(t, selected, disabled);\nint bd = States.Border(t, hovered, pressed, focused, disabled);\nc.FillRoundRect(x, y, w, h, t.borderRadiusMedium, bg);\nc.DrawRect(x, y, w, h, bd, 1);")
            .AddProp("hovered", "bool", "false", "Pointer is over the widget.")
            .AddProp("pressed", "bool", "false", "Being pressed.")
            .AddProp("selected", "bool", "false", "Currently selected/active.")
            .AddProp("focused", "bool", "false", "Has keyboard focus (Border).")
            .AddProp("disabled", "bool", "false", "Non-interactive; wins precedence.");
    }

    static void BuildDataEntry(List<Comp> list) {
        Comp inp = Comp.Create("Data Entry", "Input",
            "A single-line text field bound to a SignalString. Bind() gives it a hint and a two-way value; Render(app, x, y, w, h) draws it and owns focus, caret movement and text editing; GetText()/SetText() read and replace the value.", "");
        inp.AddDemo("Basic", "Bind to a SignalString, Render each frame, then read GetText().",
            "Input", 120,
            "Input name = Input.Bind(SignalString.Create(\"\"), \"your name\");\nname.Render(app, 40, 40, 260, 34);\nstring value = name.GetText();", "");
        inp.AddProp("hint", "string", "\"\"", "Placeholder shown while the field is empty.");
        inp.AddProp("model", "SignalString", "-", "Two-way bound text value (Bind).");
        inp.AddProp("w", "int", "-", "Field width in pixels (Render argument).");
        inp.AddProp("h", "int", "-", "Field height in pixels (Render argument).");
        list.Add(inp);
        Gallery.Add(list, "Data Entry", "TextArea",
            Gallery.T("Multiline text input. Owns caret movement (arrows / Home / End), newline editing (Enter) and its own viewport clipping + vertical scrolling (mouse wheel and an auto scrollbar; it keeps the caret in view). Binds to a SignalString.",
                "多行文本输入。自带光标移动（方向键 / Home / End）、换行编辑（Enter），以及自身的视口裁剪与垂直滚动（鼠标滚轮加自动滚动条，并保持光标可见）。绑定到 SignalString。"),
            "TextArea notes = TextArea.Create(\"Write something...\");\nnotes.Render(app, 40, 80, 360, 120);\nstring value = notes.GetText();")
            .AddProp("hint", "string", "\"\"", "Placeholder shown while empty.")
            .AddProp("model", "SignalString", "-", "Two-way bound text (Bind).")
            .AddProp("w", "int", "-", "Box width in px (Render).")
            .AddProp("h", "int", "-", "Box height in px (Render).");
        Gallery.Add(list, "Data Entry", "Checkbox",
            Gallery.T("Checkbox binds to a SignalBool. Call Render then HandleClick to toggle it.",
                "复选框绑定到 SignalBool。先调用 Render，再调用 HandleClick 来切换选中状态。"),
            "SignalBool agree = SignalBool.Create(false);\nint id = Checkbox.Render(app, 40, 80, \"I agree\", agree);\nCheckbox.HandleClick(app, id, agree);\nif (agree.Get()) {\n    // enabled\n}")
            .AddProp("label", "string", "\"\"", "Text drawn next to the box.")
            .AddProp("model", "SignalBool", "-", "Checked state (two-way).")
            .AddEvent("Change", "HandleClick(app, id, model)", "Toggles model when the row is clicked.");
        Gallery.Add(list, "Data Entry", "Radio",
            Gallery.T("Radio buttons share one SignalInt; each has a distinct option value.",
                "单选按钮共享一个 SignalInt；每个按钮对应一个不同的选项值。"),
            "SignalInt choice = SignalInt.Create(0);\nint a = Radio.Render(app, 40, 80, \"Option A\", choice, 0);\nint b = Radio.Render(app, 40, 110, \"Option B\", choice, 1);\nRadio.HandleClick(app, a, choice, 0);\nRadio.HandleClick(app, b, choice, 1);")
            .AddProp("label", "string", "\"\"", "Text drawn next to the dot.")
            .AddProp("model", "SignalInt", "-", "Shared selected value across the group.")
            .AddProp("value", "int", "-", "This option's value.")
            .AddEvent("Change", "HandleClick(app, id, model, value)", "Sets model to value when clicked.");
        Gallery.Add(list, "Data Entry", "Switch",
            Gallery.T("A toggle switch bound to a SignalBool.",
                "绑定到 SignalBool 的开关。"),
            "SignalBool on = SignalBool.Create(true);\nint id = Switch.Render(app, 40, 80, on);\nSwitch.HandleClick(app, id, on);")
            .AddProp("model", "SignalBool", "-", "On/off state (two-way).")
            .AddEvent("Change", "HandleClick(app, id, model)", "Flips model when clicked.");
        Gallery.Add(list, "Data Entry", "Slider",
            Gallery.T("Slider.Render(app, x, y, width, min, max, model) edits a SignalInt within a range.",
                "Slider.Render(app, x, y, width, min, max, model) 在给定范围内编辑一个 SignalInt。"),
            "SignalInt volume = SignalInt.Create(50);\nSlider.Render(app, 40, 80, 200, 0, 100, volume);")
            .AddProp("width", "int", "-", "Track width in px.")
            .AddProp("min", "int", "-", "Range minimum.")
            .AddProp("max", "int", "-", "Range maximum.")
            .AddProp("model", "SignalInt", "-", "Bound value within [min, max].")
            .AddEvent("Change", "() => void", "Dragging or clicking the track updates model.");
        Gallery.Add(list, "Data Entry", "Select",
            Gallery.T("Retained dropdown. Bind() gives it a stable identity; it owns its open state and defers the option list to the framework overlay layer, so the popup always draws above later content. Change fires on select (C#-style delegate).",
                "保留态下拉框。Bind() 赋予它稳定标识；它自持展开状态，并把选项列表交给框架的覆盖层绘制，因此弹窗始终显示在后续内容之上。选择时触发 Change（C# 风格委托）。"),
            "List<string> opts = new List<string>{ \"Red\", \"Green\", \"Blue\" };\nSignalInt sel = SignalInt.Create(0);\nSelect color = Select.Bind(opts, sel, \"pick a color\");\ncolor.Change += () => { /* sel.Get() changed */ };\n// each frame:\ncolor.Render(app, 40, 80, 200, 28);")
            .AddProp("options", "List<string>", "-", "Choices shown in the popup.")
            .AddProp("model", "SignalInt", "-", "Selected option index.")
            .AddProp("hint", "string", "\"\"", "Placeholder when nothing is chosen.")
            .AddEvent("Change", "() => void", "Fires when the selected option changes.");
        Gallery.Add(list, "Data Entry", "SelectBox",
            Gallery.T("High-level select. Owns open/close, the popup (with its own clipping + scrolling for long lists), single- or multi-selection, an optional clear button, plus size and status variants. One Render() call does everything.",
                "高级选择框。自持展开/收起、弹窗（对长列表自带裁剪与滚动）、单选或多选、可选清除按钮，以及尺寸和状态变体。一次 Render() 调用即可完成全部功能。"),
            "SelectBox city = SelectBox.Create(\"Pick a city\").Clearable(true);\ncity.AddOption(\"London\"); city.AddOption(\"Paris\");\ncity.Render(app, 40, 80, 200);\nint i = city.Selected();      // -1 if none\n// multi-select: SelectBox.Multi(hint) + city.IsChosen(i)")
            .AddProp("hint", "string", "\"\"", "Placeholder text.")
            .AddProp("clearable", "bool", "false", "Show a clear button (Clearable).")
            .AddProp("multi", "bool", "false", "Multi-selection (SelectBox.Multi).")
            .AddProp("options", "List<string>", "-", "Added via AddOption.")
            .AddEvent("Selected()", "int", "Current selection index, or -1 if none.");
        Gallery.Add(list, "Data Entry", "Rate",
            Gallery.T("An interactive star rating bound to a SignalInt.",
                "绑定到 SignalInt 的可交互星级评分。"),
            "SignalInt rating = SignalInt.Create(3);\nint id = Rate.Render(app, 40, 60, rating, 5);\nRate.HandleClick(app, id, 5, rating);")
            .AddProp("model", "SignalInt", "-", "Current rating (0..count).")
            .AddProp("count", "int", "5", "Number of stars.")
            .AddEvent("Change", "HandleClick(app, id, count, model)", "Sets model to the clicked star.");
    }

    static void BuildDataDisplay(List<Comp> list) {
        Gallery.Add(list, "Data Display", "Card",
            Gallery.T("Card draws a titled panel. Card.ContentY gives the y where your content should start. The preview shows opt-in motion effects that all draw clipped inside the card so they never shift layout or spill onto neighbours: BorderGlow (travelling border comet), Spotlight (cursor-follow glow), Sheen (diagonal light sweep), Aurora (drifting soft blobs), Breath (breathing rim) and Motes (rising dust).",
                "Card 绘制带标题的面板。Card.ContentY 给出内容应当起始的 y 坐标。预览展示了可选的动效，全部裁剪在卡片内部绘制，不会挤动布局或溢出到相邻组件：BorderGlow(边框流光)、Spotlight(跟随光标)、Sheen(斜向扫光)、Aurora(漂移柔光)、Breath(呼吸边框)、Motes(上升光尘)。"),
            "Card.Render(app, 40, 40, 260, 160, \"Profile\");\nint cy = Card.ContentY(40, app.theme);\nLabel.Render(app, 56, cy, \"Card body goes here\");")
            .AddProp("title", "string", "-", "Header text.")
            .AddProp("w", "int", "-", "Card width in px.")
            .AddProp("h", "int", "-", "Card height in px.")
            .AddEvent("ContentY(y, theme)", "int", "Y where your body content should start.");
        Gallery.Add(list, "Data Display", "Panel",
            Gallery.T("Panel is a titleless container surface (fill + border + padding) for grouping content. Use Card when you need a titled surface with a header divider. As a retained Control it auto-sizes and needs no coordinates.",
                "Panel 是无标题的容器面板（填充 + 边框 + 内边距），用于分组内容。若需要带标题栏分隔线的面板请用 Card。作为保留态 Control，它会自动测量尺寸，无需坐标。"),
            "// retained: nest content, no x/y/w/h\nPanel box = new Panel(\"section\");\nbox.With(new Label(\"Grouped content\"));\nbox.With(new Button(\"Action\"));\n// or immediate: returns the padded inner rect\nRect inner = Panel.Card(app, x, y, w, h);\nLabel.Render(app, inner.x, inner.y, \"Inside the panel\");")
            .AddProp("With(child)", "builder", "-", "Append a child (retained mode).")
            .AddEvent("Card(app,x,y,w,h)", "Rect", "Paints a titleless surface; returns the inner content rect.");
        Gallery.Add(list, "Data Display", "Compose",
            Gallery.T("Fluent retained-mode composition: containers nest children with .With(a).With(b), auto-docked along a Column/Row flow and auto-measured, so building trees needs no hand-computed x/y/w/h.",
                "流式保留态组合：容器用 .With(a).With(b) 嵌套子节点，沿 Column/Row 流自动停靠并自动测量，因此构建界面树无需手工计算 x/y/w/h。"),
            "Panel card = new Panel(\"card\");\ncard.Titled(\"Create account\");\ncard.Add(\n    Panel.Column().Gap(10)\n        .With(new Label(\"Fill in the details below.\").Variant(1))\n        .With(new Progress(66, 3))\n        .With(Panel.Row().Gap(10)\n            .With(Button.Create(\"Cancel\"))\n            .With(Button.Primary(\"Save\"))));\n// each frame:\ncard.MeasureTree(app);\ncard.Arrange(x, y, w, h);\ncard.RenderTree(app);")
            .AddProp("Titled(text)", "builder", "-", "Give a container a title.")
            .AddProp("Column()/Row()", "builder", "-", "Flow direction for children.")
            .AddProp("Gap(px)", "builder", "0", "Space between children.")
            .AddProp("With(child)", "builder", "-", "Append a child node.");
        Gallery.Add(list, "Data Display", "Designer",
            Gallery.T("A reusable FormCreate-style form builder (stdlib Gui.Designer). Click a field type in the left palette to append a labelled row; click a row to select it; reorder/delete it from the toolbar. The right inspector switches between per-field properties (label, name, placeholder, required, options, change handler) and form-level config (label position, size, label width, required star, submit/reset buttons, submit handler). Save/Load round-trips the whole form (config + ordered fields + options + handlers); Preview hides the editing chrome.",
                "可复用的 FormCreate 风格表单构建器（stdlib Gui.Designer）。点击左侧面板中的字段类型即可追加一行带标签的字段；点击某行进行选中；用工具栏重排或删除。右侧检查器在“每个字段的属性”（标签、名称、占位符、是否必填、选项、变更处理器）与“表单级配置”（标签位置、尺寸、标签宽度、必填星号、提交/重置按钮、提交处理器）之间切换。Save/Load 可完整往返整个表单（配置 + 有序字段 + 选项 + 处理器）；Preview 隐藏编辑界面。"),
            "// once\nDesigner d = Designer.Create();\nd.Seed(app);\n// each frame\nd.Render(app, x, y, w, h);\n\n// each row is a FormField control carrying what to collect:\nFormField f = FormField.New(6, 0);   // 6 = select\nf.SetProp(\"label\", \"Category\");\nf.SetProp(\"options\", \"News|Blog|Docs\");")
            .AddProp("fields", "List<FormField>", "-", "Ordered rows the form collects.")
            .AddProp("labelPosition", "int", "0", "Label placement (top/left).")
            .AddProp("size", "int", "1", "Control size for all fields.")
            .AddEvent("Save()/Load()", "string", "Round-trip the whole form definition.");
        Gallery.Add(list, "Data Display", "Tag",
            Gallery.T("Tag draws a small coloured chip. The last argument selects the colour variant (0 default, 1 primary, 2 info, 3 success, 4 warning, 5 error). RenderClosable adds an x and returns its hit id so you can remove the tag on click.",
                "Tag 绘制一个彩色小标签。最后一个参数选择颜色变体（0 默认，1 primary，2 info，3 success，4 warning，5 error）。RenderClosable 会加上一个关闭“x”，并返回其命中 id，便于点击时移除该标签。"),
            "Tag.Render(app, x, y, \"Primary\", 1);\n// closable + add:\nint xid = Tag.RenderClosable(app, x, y, tag, 1);\nif (Ui.Clicked(app, xid)) { tags.RemoveAt(i); }\n// append a new chip from a button\nif (Button.WasClicked(app, addId)) { tags.Add(\"New\"); }")
            .AddProp("text", "string", "-", "Tag label.")
            .AddProp("variant", "int", "0", "0 default, 1 primary, 2 info, 3 success, 4 warning, 5 error.")
            .AddEvent("RenderClosable(...)", "int", "Draws an x; returns the close hit id for Ui.Clicked.");
        Comp av = Comp.Create("Data Display", "Avatar",
            "A circular avatar showing either a text initial or a named icon. size sets the diameter.", "");
        av.AddDemo("Initials", "Avatar.Render(app, x, y, size, text) centres an initial; pass a larger size for a bigger circle.", "Avatar.text", 130,
            "Avatar.Render(app, 40, 40, 32, \"A\");\nAvatar.Render(app, 100, 40, 42, \"Z\");\nAvatar.Render(app, 170, 40, 52, \"GK\");", "");
        av.AddDemo("Icon", "Avatar.RenderWithIcon(app, x, y, size, icon) draws a named icon instead of text.", "Avatar.icon", 130,
            "Avatar.RenderWithIcon(app, 40, 40, 42, \"user\");\nAvatar.RenderWithIcon(app, 112, 40, 42, \"settings\");", "");
        av.AddProp("size", "int", "-", "Diameter in px.");
        av.AddProp("text", "string", "-", "Initial shown (Render).");
        av.AddProp("icon", "string", "-", "Icon name (RenderWithIcon).");
        list.Add(av);
        Comp bg = Comp.Create("Data Display", "Badge",
            "A small status marker placed next to another control: a plain dot or a numeric count.", "");
        bg.AddDemo("Dot", "Badge.Dot(app, x, y) marks an unread or active state without a number.", "Badge.dot", 120,
            "Badge.Dot(app, 40, 40);", "");
        bg.AddDemo("Count", "Badge.Count(app, x, y, n) shows a number; large values are capped with a plus.", "Badge.count", 120,
            "Badge.Count(app, 40, 40, 5);\nBadge.Count(app, 100, 40, 12);\nBadge.Count(app, 170, 40, 99);", "");
        bg.AddProp("count", "int", "-", "Number shown (Count); Dot() has no count.");
        list.Add(bg);
        Gallery.Add(list, "Data Display", "Statistic",
            Gallery.T("Show a highlighted numeric value with a descriptive label.",
                "以醒目的数值配合说明文字进行展示。"),
            "Statistic.Render(app, 40, 60, \"Active users\", \"12,480\");")
            .AddProp("label", "string", "-", "Descriptive caption.")
            .AddProp("value", "string", "-", "Highlighted value.");
        Gallery.Add(list, "Data Display", "Timeline",
            Gallery.T("Display ordered events with titles and descriptions.",
                "按顺序展示带标题和描述的事件时间线。"),
            "List<TimelineItem> items = new List<TimelineItem>{ TimelineItem.Create(\"09:00\", \"Created\", \"Project initialized\"), TimelineItem.Create(\"12:30\", \"Published\", \"Executable generated\") };\nTimeline.Render(app, 40, 60, items);")
            .AddProp("titles", "List<string>", "-", "Per-event titles.")
            .AddProp("descs", "List<string>", "-", "Per-event descriptions.");
        Gallery.Add(list, "Data Display", "ListView",
            Gallery.T("Render a compact vertical list of strings.",
                "渲染一个紧凑的字符串垂直列表。"),
            "List<string> items = new List<string>{ \"Inbox\", \"Starred\", \"Sent\", \"Drafts\" };\nListView.Render(app, x, y, 300, items);")
            .AddProp("w", "int", "-", "List width in px.")
            .AddProp("items", "List<string>", "-", "Row labels.");
        Gallery.Add(list, "Data Display", "VirtualList",
            Gallery.T("High-level virtualized list: a fixed-height viewport over an arbitrarily large item list that draws ONLY the visible rows (constant cost for 100k rows). Owns pixel scrolling, the scrollbar and hover/selection by composing a ScrollView. Use this instead of ListView for large data.",
                "高级虚拟化列表：在任意大的数据集上使用固定高度视口，只绘制可见行（即使 10 万行也是常量开销）。通过组合 ScrollView 自带像素级滚动、滚动条与悬停/选中。大数据量时请用它替代 ListView。"),
            "VirtualList list = VirtualList.Create();\nlist.SetItems(rows);         // any number of rows\nlist.Render(app, 40, 60, 300, 150);\nint sel = list.Selected();   // -1 if none\nint hit = list.TakeActivated(); // clicked row, or -1")
            .AddProp("items", "List<string>", "-", "Rows (SetItems); any size.")
            .AddProp("w", "int", "-", "Viewport width in px.")
            .AddProp("h", "int", "-", "Viewport height in px.")
            .AddEvent("Selected()", "int", "Selected row index, or -1.")
            .AddEvent("TakeActivated()", "int", "Row clicked this frame, or -1.");
        Gallery.Add(list, "Data Display", "Table",
            Gallery.T("Render a lightweight table header and striped rows.",
                "渲染轻量的表头与斑马纹行。"),
            "List<string> cols = new List<string>{ \"Task\", \"Owner\", \"Status\" };\nList<int> widths = new List<int>{ 200, 140, 120 };\nint rh = app.theme.heightMedium;\nTable.RenderHeader(app, x, y, cols, widths);\nTable.RenderRow(app, x, y + rh, row0, widths, false);\nTable.RenderRow(app, x, y + rh * 2, row1, widths, true);")
            .AddProp("cols/cells", "List<string>", "-", "Header labels / row cells.")
            .AddProp("widths", "List<int>", "-", "Per-column widths in px.")
            .AddProp("striped", "bool", "false", "Alternate-row background (RenderRow).");
        Gallery.Add(list, "Data Display", "DataTable",
            Gallery.T("A stateful table with typed columns, sorting, filtering and CSV export.",
                "带状态的表格，支持类型化列、排序、筛选与 CSV 导出。"),
            "List<DataColumn> cols = new List<DataColumn>{ DataColumn.Text(\"Name\", 180), DataColumn.Numeric(\"Score\", 100) };\nList<DataRow> rows = new List<DataRow>();\nDataRow row = DataRow.Create();\nrow.Push(\"Zan\"); row.Push(\"98\"); rows.Add(row);\nDataTableState state = DataTableState.Create();\nDataTable.Render(app, 40, 60, 520, 260, cols, rows, state);")
            .AddProp("cols", "List<DataColumn>", "-", "Typed columns (Text/Numeric).")
            .AddProp("rows", "List<DataRow>", "-", "Row data (Push per cell).")
            .AddProp("state", "DataTableState", "-", "Sort/filter state (retained).")
            .AddEvent("sort / filter", "via state", "Header clicks mutate state and re-order rows.");
        Gallery.Add(list, "Data Display", "PivotTable",
            Gallery.T("Summarize rows by configured row, column and value fields.",
                "按配置的行、列与值字段对数据进行汇总透视。"),
            "PivotConfig cfg = PivotConfig.Create(0, 1, 2, 0);\nList<DataRow> rows = new List<DataRow>();\nPivotTable.Render(app, 40, 60, 560, 280, rows, cfg);")
            .AddProp("cfg", "PivotConfig", "-", "Row/column/value fields + aggregation.")
            .AddProp("rows", "List<DataRow>", "-", "Source rows to summarize.");
        Gallery.Add(list, "Data Display", "TreeView",
            Gallery.T("Expandable dir/file tree with selection checkboxes, get-selected APIs and a right-click action menu.",
                "可展开的目录/文件树，带选择复选框、获取选中项 API 和右键操作菜单。"),
            "List<TreeNode> nodes = new List<TreeNode>{ TreeNode.Dir(\"src\", 0, true), TreeNode.Dir(\"compiler\", 1, true), TreeNode.FileIcon(\"lexer.c\", 2, \"file\"), TreeNode.FileIcon(\"main.zan\", 1, \"file\") };\n\n// draw with checkboxes; returns a right-clicked row (or -1)\nint hit = TreeView.RenderChecked(app, area, nodes, selected, 0);\n\n// read / drive the selection state\nList<string> picked = TreeView.CheckedLabels(nodes);\nint n = TreeView.CheckedCount(nodes);\nTreeView.SetAllChecked(nodes, false);\nTreeView.ExpandAll(nodes);")
            .AddProp("nodes", "List<TreeNode>", "-", "Dir/file nodes with depth + checked flag.")
            .AddProp("selected", "SignalInt", "-", "Selected node index (two-way).")
            .AddEvent("checkbox", "TreeNode.checked", "Clicking a box toggles a node (dirs cascade).")
            .AddEvent("CheckedLabels()", "List<string>", "Returns checked leaf labels.")
            .AddEvent("right-click", "returns row index", "RenderChecked returns the right-clicked row for a menu.")
            .AddEvent("select", "via selected", "Clicking a node updates selected.");
        Gallery.Add(list, "Data Display", "Collapse",
            Gallery.T("Display expandable sections controlled by a SignalInt open index.",
                "展示可折叠的分区，由 SignalInt 的展开索引控制。"),
            "List<string> heads = new List<string>{ \"General\", \"Advanced\" };\nList<string> content = new List<string>{ \"General settings\", \"Advanced settings\" };\nSignalInt open = SignalInt.Create(0);\nint first = Collapse.Render(app, 40, 60, 420, heads, content, open);\nCollapse.HandleClick(app, first, heads.Count, open);")
            .AddProp("heads", "List<string>", "-", "Section headers.")
            .AddProp("content", "List<string>", "-", "Section bodies.")
            .AddProp("open", "SignalInt", "-", "Index of the expanded section.")
            .AddEvent("Change", "HandleClick(...)", "Clicking a header sets the open index.");
        Comp car = Comp.Create("Data Display", "Carousel",
            "A slide panel with prev/next arrows and indicator dots, driven by a SignalInt active index. Carousel.Render swaps slides instantly; Carousel.RenderAnimated slides the outgoing/incoming panels horizontally via a caller-owned CarouselAnim. Arrows and dots are wired with Carousel.HandleClick. For an immersive full-screen viewer, wrap it in Layer.RenderPhotos.", "");
        car.AddDemo("Basic", "Carousel.Render(app, x, y, w, h, slides, idx) draws the current slide with arrows + dots; the index jumps instantly.", "Carousel.basic", 150,
            "List<string> slides = new List<string>{ \"First\", \"Second\", \"Third\" };\nSignalInt idx = SignalInt.Create(0);\nint id = Carousel.Render(app, 40, 60, 460, 150, slides, idx);\nCarousel.HandleClick(app, id, slides.Count, idx);", "");
        car.AddDemo("Animated slide", "Carousel.RenderAnimated slides between panels. Pass a CarouselAnim so the transition survives immediate-mode frames.", "Carousel.anim", 150,
            "CarouselAnim anim = CarouselAnim.Create();\nint id = Carousel.RenderAnimated(app, 40, 60, 460, 150, slides, idx, anim);\nCarousel.HandleClick(app, id, slides.Count, idx);", "");
        car.AddDemo("Many slides", "The indicator dots scale to the slide count; the active dot widens. Handy for a gallery of images or steps.", "Carousel.many", 150,
            "// six labelled slides -- dots grow with the count:\nCarousel.RenderAnimated(app, 40, 60, 460, 150, slides, idx, anim);", "");
        car.AddProp("slides", "List<string>", "-", "Slide labels (one panel each).");
        car.AddProp("idx", "SignalInt", "-", "Active slide index (two-way).");
        car.AddProp("anim", "CarouselAnim", "-", "Caller-owned slide-transition state (RenderAnimated).");
        car.AddEvent("Change", "HandleClick(...)", "Arrows / dots advance the active slide.");
        list.Add(car);
        Comp ch = Comp.Create("Data Display", "Chart",
            "Componentized charts (LiveCharts-style): bind a strongly-typed ChartModel (title + labels + ChartSeries, or scatter x/y) to a declarative ChartOptions, then ChartView.Of(model, opts).Render(app, x, y, w, h). Data can be built in code (ChartModel.Create().Add(...)) or parsed from a JSON document (ChartModel.FromJson) so the same chart is code- or data-driven. ChartView plays a grow-in intro, draws gradient/smoothed series and an optional hover crosshair + value tooltip. The one-shot static Chart.Line/Bar/Pie/... renderers remain for quick draws.", "");
        ch.AddDemo("Line", "A ChartView with ChartOptions.Line() plots one polyline per series over the model's shared category labels, animating up on first render.", "Chart.line", 210,
            "ChartModel m = ChartModel.Create(\"Quarterly revenue\");\nm.AddLabel(\"Q1\"); m.AddLabel(\"Q2\"); m.AddLabel(\"Q3\"); m.AddLabel(\"Q4\");\nm.Add(\"Revenue\", new List<int>{ 12, 28, 20, 35 });\nm.Add(\"Cost\", new List<int>{ 8, 14, 16, 22 });\nChartView.Of(m, ChartOptions.Line()).Render(app, 40, 40, 480, 200);",
            "{\n  \"title\": \"Quarterly revenue\",\n  \"labels\": [\"Q1\", \"Q2\", \"Q3\", \"Q4\"],\n  \"series\": [\n    { \"name\": \"Revenue\", \"color\": 0, \"values\": [12, 28, 20, 35] },\n    { \"name\": \"Cost\", \"color\": 0, \"values\": [8, 14, 16, 22] }\n  ]\n}");
        ch.AddDemo("Area", "ChartOptions.Area() fills a vertical gradient under each line -- same ChartModel shape as Line.", "Chart.area", 210,
            "ChartView.Of(m, ChartOptions.Area()).Render(app, 40, 40, 480, 200);", "");
        ch.AddDemo("Smooth", "ChartOptions.Smooth() draws Catmull-Rom curved lines with a gradient area fill for a softer, LiveCharts-like look.", "Chart.smooth", 210,
            "ChartView.Of(m, ChartOptions.Smooth()).Render(app, 40, 40, 480, 200);", "");
        ch.AddDemo("Bar", "ChartOptions.Bar() draws grouped, rounded, gradient-filled vertical bars. Set opts.showValues = true to label bar tops.", "Chart.bar", 210,
            "ChartOptions o = ChartOptions.Bar();\no.showValues = true;\nChartView.Of(m, o).Render(app, 40, 40, 480, 200);", "");
        ch.AddDemo("Stacked", "ChartOptions.Stacked() stacks the series per category into a single bar.", "Chart.stacked", 210,
            "ChartView.Of(m, ChartOptions.Stacked()).Render(app, 40, 40, 480, 200);", "");
        ch.AddDemo("From JSON", "Parse a data document into a ChartModel (color 0 = auto palette) and render it -- no imperative Add() calls. Ideal for server- or file-driven dashboards.", "Chart.json", 210,
            "string doc = \"{\\\"title\\\":\\\"Monthly active users\\\",\\\"labels\\\":[...],\\\"series\\\":[...] }\";\nChartModel m = ChartModel.FromJson(doc);\nChartView.Of(m, ChartOptions.Smooth()).Render(app, 40, 40, 480, 200);",
            "{\n  \"title\": \"Monthly active users\",\n  \"labels\": [\"Jan\", \"Feb\", \"Mar\", \"Apr\", \"May\", \"Jun\"],\n  \"series\": [\n    { \"name\": \"Web\", \"color\": 0, \"values\": [30, 45, 38, 60, 72, 85] },\n    { \"name\": \"Mobile\", \"color\": 0, \"values\": [20, 32, 40, 52, 64, 80] }\n  ]\n}");
        ch.AddDemo("Pie & Donut", "Part-of-whole charts are compact, so lay them two-per-row instead of stretching one across the width. ChartOptions.Pie()/Donut() render each single-value series as a slice; the sweep grows in on first render and the donut prints the total in its hole.", "Chart.pie", 210,
            "ChartModel m = ChartModel.Create(\"Language share\");\nm.Add(\"Zan\", new List<int>{ 45 });\nm.Add(\"C\", new List<int>{ 30 });\nm.Add(\"Rust\", new List<int>{ 25 });\n// two per row: pie on the left, donut on the right\nChartView.Of(m, ChartOptions.Pie()).Render(app, 40, 40, 236, 200);\nChartView.Of(m, ChartOptions.Donut()).Render(app, 288, 40, 236, 200);", "");
        ch.AddDemo("Gauge & Radial", "Gauge (half-ring speedometer) and RadialBars (concentric progress rings) are KPI charts -- also two-per-row. opts.gaugeMax sets full scale; each ring/needle sweeps in with the intro animation.", "Chart.radial", 210,
            "ChartModel g = ChartModel.Create(\"CPU load\");\ng.AddColored(\"load\", new List<int>{ 72 }, t.primary);\nChartOptions go = ChartOptions.Gauge(); go.gaugeMax = 100;\nChartView.Of(g, go).Render(app, 40, 40, 236, 200);\n\nChartModel r = ChartModel.Create(\"Quota used\");\nr.Add(\"CPU\", new List<int>{ 80 }); r.Add(\"RAM\", new List<int>{ 55 }); r.Add(\"Disk\", new List<int>{ 30 });\nChartView.Of(r, ChartOptions.RadialBars()).Render(app, 288, 40, 236, 200);", "");
        ch.AddDemo("Heatmap", "A heatmap maps each series to a row and each value index to a column, colouring every cell by intensity (min->max ramps bgTertiary -> the series colour). Cells fade in with the intro animation. Good for calendars / correlation grids.", "Chart.heatmap", 210,
            "ChartModel m = ChartModel.Create(\"Weekly activity\");\nm.AddLabel(\"Mon\"); /* ...Sun */\nm.AddColored(\"Team A\", new List<int>{ 12, 35, 50, 28, 64, 18, 8 }, t.primary);\nm.AddColored(\"Team B\", new List<int>{ 40, 22, 70, 90, 55, 30, 15 }, Chart.Palette(t, 2));\nChartView.Of(m, ChartOptions.Heatmap()).Render(app, 40, 40, 480, 200);", "");
        ch.AddDemo("Scatter", "A scatter ChartModel carries x/y point arrays (AddPoint) rendered on value axes.", "Chart.scatter", 210,
            "ChartModel m = ChartModel.Create(\"Samples\");\nm.AddPoint(5, 8); m.AddPoint(12, 14); m.AddPoint(18, 11);\nChartView.Of(m, ChartOptions.Scatter()).Render(app, 40, 40, 480, 200);", "");
        ch.AddProp("model", "ChartModel", "-", "Typed data: title, labels, series (or scatter x/y). Build in code or via ChartModel.FromJson.");
        ch.AddProp("options", "ChartOptions", "-", "Declarative presentation: kind, smooth, area, gradient, showValues, showTooltip, animate, ...");
        ch.AddProp("kind", "int", "0", "Chart family from ChartType.* (Line/Area/Bar/StackedBar/HBar/Pie/Donut/Scatter).");
        ch.AddProp("smooth", "bool", "false", "Catmull-Rom curved lines (line family).");
        ch.AddProp("gradient", "bool", "true", "Vertical gradient fills for areas / bars.");
        ch.AddProp("showValues", "bool", "false", "Draw value labels on points / bar tops.");
        ch.AddProp("showTooltip", "bool", "true", "Hover crosshair + value tooltip (cartesian charts).");
        ch.AddProp("animate", "bool", "true", "Grow-in intro animation on first render.");
        list.Add(ch);
        Gallery.Add(list, "Data Display", "Ellipsis",
            Gallery.T("Measure and truncate long text so it fits a fixed width.",
                "测量并截断长文本，使其适配固定宽度。"),
            "string shown = Ellipsis.Fit(\"A very long file name.zan\", 160, app.theme.fontSizeMedium);\nEllipsis.Render(app, 40, 60, 160, shown);")
            .AddProp("text", "string", "-", "Full text to truncate.")
            .AddProp("w", "int", "-", "Max width in px.")
            .AddEvent("Fit(text, w, fs)", "string", "Returns the text truncated with an ellipsis.");
    }

    static void BuildFeedback(List<Comp> list) {
        Gallery.Add(list, "Feedback", "Alert",
            Gallery.T("Alert shows an inline banner with a title, optional message and type (0/1 default, 2 info, 3 success, 4 warning, 5 error). Height is content-derived with symmetric padding so banners stay uniform. As a retained Control it needs no coordinates.",
                "Alert 显示一条内联横幅，带标题、可选正文和类型（0/1 默认，2 info，3 success，4 warning，5 error）。高度由内容决定并保持上下对称内边距，使横幅整齐统一。作为保留态 Control，无需坐标。"),
            "// retained, auto-sized:\nnew Alert(\"Saved\", \"Your changes were saved.\", 3);\n// immediate:\nAlert.Render(app, x, y, w, \"Saved\", \"Your changes were saved.\", 3);")
            .AddProp("w", "int", "-", "Banner width in px.")
            .AddProp("title", "string", "-", "Bold heading.")
            .AddProp("message", "string", "-", "Body text.")
            .AddProp("type", "int", "0", "0/1 default, 2 info, 3 success, 4 warning, 5 error.");
        Comp pr = Comp.Create("Feedback", "Progress",
            "Progress indicators. A line bar shows a labelled percentage; a ring gauge shows the same value as a circle. type selects the colour (0 default, 2 info, 3 success, 4 warning).", "");
        pr.AddDemo("Line", "Progress.RenderText(app, x, y, w, percent, type) draws a labelled horizontal bar.", "Progress.line", 170,
            "Progress.RenderText(app, 40, 40, 300, 72, 0);\nProgress.RenderText(app, 40, 70, 300, 45, 2);\nProgress.RenderText(app, 40, 100, 300, 90, 3);", "");
        pr.AddDemo("Circle", "Progress.Circle(app, cx, cy, radius, percent, type) draws a ring gauge.", "Progress.circle", 150,
            "Progress.Circle(app, 90, 70, 34, 72, 0);\nProgress.Circle(app, 190, 70, 34, 90, 3);\nProgress.Circle(app, 290, 70, 34, 45, 4);", "");
        pr.AddProp("w", "int", "-", "Bar width in px (line).");
        pr.AddProp("radius", "int", "-", "Ring radius in px (circle).");
        pr.AddProp("percent", "int", "-", "Filled fraction, 0-100.");
        pr.AddProp("type", "int", "0", "Colour: 0 default, 2 info, 3 success, 4 warning.");
        list.Add(pr);
        Gallery.Add(list, "Feedback", "Result",
            Gallery.T("A centered status block (icon + title + description) for full-page outcomes. status: 0 info, 1 success, 2 warning, 3 error. As a retained Control it needs no coordinates.",
                "居中的状态区块（图标 + 标题 + 描述），用于整页结果展示。status：0 info，1 success，2 warning，3 error。作为保留态 Control，无需坐标。"),
            "// retained, auto-sized:\nnew Result(1, \"Published\", \"The executable is ready.\");\n// immediate:\nResult.Render(app, x, y, w, 1, \"Published\", \"The executable is ready.\");")
            .AddProp("w", "int", "-", "Block width in px.")
            .AddProp("status", "int", "0", "0 info, 1 success, 2 warning, 3 error.")
            .AddProp("title", "string", "-", "Result heading.")
            .AddProp("desc", "string", "-", "Supporting description.");
        Comp sp = Comp.Create("Feedback", "Spin",
            "An animated spinner, on its own at any size or centred over a region with a caption.", "");
        sp.AddDemo("Spinner", "Spin.Render(app, cx, cy, radius, color) draws a bare spinner.", "Spin.plain", 130,
            "Spin.Render(app, 60, 50, 14, app.theme.primary);\nSpin.Render(app, 120, 50, 20, app.theme.primary);\nSpin.Render(app, 190, 50, 28, app.theme.info);", "");
        sp.AddDemo("With tip", "Spin.WithTip(app, x, y, w, h, tip) centres a spinner and caption inside a box.", "Spin.tip", 150,
            "Spin.WithTip(app, 40, 40, 300, 110, \"Loading data...\");", "");
        sp.AddProp("radius", "int", "-", "Spinner radius in px.");
        sp.AddProp("color", "int", "-", "ARGB stroke color.");
        sp.AddProp("tip", "string", "\"\"", "Caption below the spinner (WithTip).");
        list.Add(sp);
        Gallery.Add(list, "Feedback", "Loading",
            Gallery.T("Draw an animated loading indicator.",
                "绘制一个动画加载指示器。"),
            "Loading.Render(app, 80, 80, 18);")
            .AddProp("radius", "int", "-", "Indicator radius in px.");
        Gallery.Add(list, "Feedback", "Skeleton",
            Gallery.T("Compose rectangle, circle and text placeholders while content loads.",
                "在内容加载时，用矩形、圆形和文本占位块进行组合展示。"),
            "Skeleton.Circle(app, 60, 80, 20);\nSkeleton.Text(app, 96, 62, 240);\nSkeleton.Rect(app, 96, 90, 180, 14);")
            .AddProp("Circle(x, y, r)", "helper", "-", "Round placeholder.")
            .AddProp("Text(x, y, w)", "helper", "-", "Single text-line placeholder.")
            .AddProp("Rect(x, y, w, h)", "helper", "-", "Rectangular block placeholder.");
        Gallery.Add(list, "Feedback", "Tooltip",
            Gallery.T("A floating hint anchored to a point. Four placements (Top/Bottom/Left/Right, auto-flipping near a screen edge), automatic word wrapping when a max width is given, and a scrollbar when the wrapped text is taller than the height cap. Show it from any trigger: on hover, or toggled by a click.",
                "锚定到某个点的浮动提示。四种方位（上/下/左/右，靠近屏幕边缘时自动翻转），给定最大宽度时自动换行，换行文本超过高度上限时显示滚动条。可由任意触发方式弹出：悬停，或点击切换。"),
            "// hover trigger:\nint id = Button.Create(\"Hover me\").Render(app, 40, 60, 120);\nif (app.focus.IsHovered(id)) {\n    Tooltip.RenderAt(app, 100, 60, \"Shown on hover\", Tooltip.Top(), 0);\n}\n// click trigger (toggle a SignalBool):\nif (Button.WasClicked(app, clickId)) { open.Set(!open.Get()); }\nif (open.Get()) { Tooltip.RenderAt(app, x, y, \"Toggled\", Tooltip.Bottom(), 0); }\n// long text: pass a max width (px) to wrap; a scrollbar appears past the cap:\nTooltip.RenderAt(app, x, y, longText, Tooltip.Right(), 190);")
            .AddProp("text", "string", "-", "Hint text shown in the bubble.")
            .AddProp("placement", "int", "Top()", "Top / Bottom / Left / Right (auto-flips near an edge).")
            .AddProp("maxW", "int", "0", "Wrap width in px; 0 = single line.");
        Gallery.Add(list, "Feedback", "Popover",
            Gallery.T("Retained popover. Owns its open state and paints in the overlay pass, so the panel draws above other content, blocks clicks to the widgets beneath it (no click-through), word-wraps its body, clamps to the window on every edge and closes on an outside press or Esc.",
                "保留态气泡卡片。自持展开状态并在覆盖层绘制，因此面板显示在其他内容之上，拦截对下方组件的点击（不穿透），正文自动换行，各边都会限制在窗口内，点击外部或按 Esc 关闭。"),
            "Popover pop = Popover.Create(\"More info\", \"Title\", \"Body text that wraps.\", 260);\n// each frame (in the overlay pass so it sits on top):\npop.Render(app, x, y, w, h);")
            .AddProp("title", "string", "-", "Heading.")
            .AddProp("body", "string", "-", "Word-wrapped body text.")
            .AddProp("w", "int", "-", "Panel width in px (clamped to the window).")
            .AddEvent("open / close", "click / outside / Esc", "Trigger toggles; outside press or Esc closes.");
        Gallery.Add(list, "Feedback", "Dropdown",
            Gallery.T("Retained dropdown. Owns its open state and defers the action list to the framework overlay layer, so the menu always draws on top, blocks clicks to the widgets beneath it (no click-through) and closes on an outside press or Esc. Change fires on choose; Chosen() is the picked index.",
                "保留态下拉菜单。自持展开状态，并把操作项列表交给框架覆盖层，因此菜单始终显示在最上层，拦截对下方组件的点击（不穿透），点击外部或按 Esc 关闭。选择时触发 Change；Chosen() 为所选索引。"),
            "List<string> items = new List<string>{ \"Edit\", \"Duplicate\", \"Delete\" };\nDropdown menu = Dropdown.Create(\"Actions\", items);\nmenu.Change += () => { int a = menu.Chosen(); ... };\n// each frame:\nmenu.Render(app, x, y, w, h);")
            .AddProp("label", "string", "-", "Trigger button text.")
            .AddProp("items", "List<string>", "-", "Menu actions.")
            .AddProp("Chosen()", "int", "-", "Index of the last chosen action, or -1.")
            .AddEvent("Change", "menu.Change += h", "Fires when an action is chosen.");
        Gallery.Add(list, "Feedback", "Layer",
            Gallery.T("The unified overlay component (layui `layer` style): one API for every popup. Message toasts and corner notifications are animated auto-dismissing queues that collapse upward; Alert / Confirm / Prompt are centered modal dialogs; Load is a masked spinner; Tips is an anchored bubble; draggable windows (min / max / restore / close) act as page layers; Photos is a full-screen image carousel. Every layer animates on open.",
                "统一的覆盖层组件（layui `layer` 风格）：一套 API 覆盖所有弹层。消息提示与角落通知是带动画、自动消失并向上收拢的队列；Alert / Confirm / Prompt 是居中的模态对话框；Load 是带遮罩的加载动画；Tips 是锚定的气泡；可拖动窗口（最小化 / 最大化 / 还原 / 关闭）作为页面层；Photos 是全屏图片轮播。每个弹层打开时都有动画。"),
            "// transient queues (auto-dismiss + animate):\nLayer.Msg(\"Saved successfully\", 3);\nLayer.Notify(\"Build completed\", 3);\n// centered modal dialogs:\nLayerState ask = LayerState.Confirm(\"Delete?\", \"This cannot be undone.\", 2);\nask.Open();\nLayerState edit = LayerState.Prompt(\"Rename\", \"new name\");\nedit.Open();\n// draggable page window:\nLayerState win = LayerState.Create(\"Window\", 360, 150, 400, 230);\nwin.Open();\nwins.Add(win);\n// each frame, in the overlay pass:\nLayer.RenderStack(app, wins);\nLayer.Render(app, ask);\nLayer.RenderToasts(app);\nLayer.RenderNotifs(app);")
            .AddProp("Msg(text, type)", "void", "-", "Queue a top-centered toast (auto-dismisses).")
            .AddProp("Notify(title, type)", "void", "-", "Queue a corner notification.")
            .AddProp("RenderLoad(x,y,w,h,tip)", "void", "-", "Masked spinner over a region.")
            .AddProp("Tips(ax, ay, text)", "void", "-", "Anchored tip bubble.")
            .AddProp("RenderPhotos(slides,idx,anim)", "bool", "-", "Full-screen carousel; true on close.")
            .AddProp("type", "int", "1", "1 default, 2 info, 3 success, 4 warning, 5 error.")
            .AddEvent("LayerState.Alert/Confirm/Prompt", "LayerState", "Build a centered modal dialog; read state.action (1 OK, 2 cancel, 3 close).")
            .AddEvent("RenderStack(wins)", "void", "Draw the z-ordered, draggable window stack.");
        Gallery.Add(list, "Feedback", "FloatButton",
            Gallery.T("A compact circular floating action button with an icon.",
                "带图标的紧凑圆形浮动操作按钮。"),
            "// a bottom-right utility rail: quick actions + back-to-top\nFloatButton.Render(app, dockX, y0, 46, \"settings\", 0);\nFloatButton.Render(app, dockX, y0 - gap, 46, \"info\", 0);\nif (offset.Get() > 0) {\n    int top = FloatButton.Render(app, dockX, y0 - gap * 2, 46, \"arrow-up\", 1);\n    if (Ui.Clicked(app, top)) { offset.Set(0); }\n}")
            .AddProp("size", "int", "-", "Button diameter in px.")
            .AddProp("icon", "string", "-", "Icon name.")
            .AddProp("type", "int", "0", "Color type.")
            .AddEvent("Click", "Ui.Clicked(app, id)", "True the frame the button is clicked.");
    }

    static void BuildNavigation(List<Comp> list) {
        Gallery.Add(list, "Navigation", "Tabs",
            Gallery.T("Retained, self-contained tab component (an enhanced TabView). Owns its tab list, active index and closable state; draws only the header strip so the caller renders the active page into a separate region. Styles: Line, Card, Segment. Orientation: horizontal top strip or vertical side rail. Supports add (+), close, right-click context menu (Close / Close others / Close all) and horizontal overflow (mouse wheel + chevrons).",
                "保留态、自包含的标签组件（增强版 TabView）。自持标签列表、当前索引和可关闭状态；只绘制头部标签栏，由调用方将当前页渲染到单独区域。样式：Line、Card、Segment。方向：顶部水平标签栏或侧边垂直标签栏。支持新增（+）、关闭、右键上下文菜单（关闭 / 关闭其他 / 关闭全部）以及水平溢出（鼠标滚轮 + 箭头）。"),
            "Tabs tabs = Tabs.Create(Tabs.Card());   // or Tabs.CreateVertical(...)\ntabs.SetShowAdd(true);                   // trailing \"+\" button\ntabs.Add(\"Overview\", false);             // (label, closable)\ntabs.Add(\"Details\", true);\n// each frame - header only:\ntabs.Render(app, 40, 40, 360);           // or RenderVertical(app, x, y, w, h)\n// ...then draw your own page for tabs.Active() in the body region.\nint now   = tabs.Active();\nint added = tabs.TakeAdded();            // index appended, or -1\nint shut  = tabs.TakeClosed();           // index removed, or -1")
            .AddProp("style", "int", "-", "Line, Card or Segment.")
            .AddProp("orient", "int", "-", "Horizontal or Vertical.")
            .AddProp("tabs", "(label, closable)", "-", "Added via Add().")
            .AddEvent("Active()", "int", "Current active tab index.")
            .AddEvent("TakeAdded()", "int", "Tab appended this frame, or -1.")
            .AddEvent("TakeClosed()", "int", "Tab removed this frame, or -1.");
        Gallery.Add(list, "Navigation", "Steps",
            Gallery.T("Show progress through a sequence of labeled steps.",
                "以一串带标签的步骤展示流程进度。"),
            "// Retained: auto-measured/placed by its parent container -- no coordinates.\nSteps s = new Steps(SignalInt.Create(1));\ns.AddStep(\"Details\"); s.AddStep(\"Review\"); s.AddStep(\"Done\");\npanel.Add(s);\n// variants (fluent):\ns.Vertical();          // stack top-to-bottom\ns.Error(1);            // mark step 1 as errored (red !)\ns.AddStepDesc(\"Account\", \"Email and password\"); // step + description")
            .AddProp("current", "SignalInt", "-", "Index of the active step (constructor).")
            .AddProp("AddStep(label)", "void", "-", "Append a step.")
            .AddProp("AddStepDesc(label, desc)", "void", "-", "Append a step with a description line.")
            .AddProp("Vertical()", "Steps", "horizontal", "Stack vertically instead.")
            .AddProp("Error(i)", "Steps", "-1", "Mark step i as errored.");
        Gallery.Add(list, "Navigation", "Breadcrumb",
            Gallery.T("Show the current location as a sequence of navigation labels.",
                "以一串导航标签展示当前所在位置。"),
            "// Retained: chevron separators, vertically centred, auto-placed.\nBreadcrumb bc = new Breadcrumb();\nbc.AddItem(\"Home\"); bc.AddItem(\"Projects\"); bc.AddItem(\"Zan\");\npanel.Add(bc);")
            .AddProp("AddItem(label)", "void", "-", "Append a path segment (root first).");
        Gallery.Add(list, "Navigation", "Menu",
            Gallery.T("A vertical application menu with a SignalInt active item.",
                "垂直的应用菜单，当前项由 SignalInt 表示。"),
            "List<string> labels = new List<string>{ \"Home\", \"Settings\" };\nSignalInt active = SignalInt.Create(0);\nint first = Menu.RenderVertical(app, 40, 60, 220, 300, 36, labels, active, 0);\nMenu.HandleClick(app, first, labels.Count, active);")
            .AddProp("labels", "List<string>", "-", "Menu item labels.")
            .AddProp("active", "SignalInt", "-", "Active item index (two-way).")
            .AddProp("rowH", "int", "-", "Row height in px.")
            .AddEvent("Change", "HandleClick(...)", "Clicking an item sets active.");
        Gallery.Add(list, "Navigation", "PageHeader",
            Gallery.T("Render a page title, subtitle and back action.",
                "渲染页面标题、副标题和返回操作。"),
            "int backId = PageHeader.Render(app, 40, 40, 520, \"Components\", \"GUI reference\");")
            .AddProp("w", "int", "-", "Header width in px.")
            .AddProp("title", "string", "-", "Page title.")
            .AddProp("subtitle", "string", "-", "Secondary line.")
            .AddEvent("Render(...)", "int", "Returns the back-action id (use Ui.Clicked).");
        Gallery.Add(list, "Navigation", "Pagination",
            Gallery.T("Navigate pages with a SignalInt current page. Styles: Render (windowed numbers with ellipses), RenderPill (rounded), RenderSmall (compact) and RenderSimple (prev / total / next).",
                "用 SignalInt 表示当前页进行翻页。样式：Render（带省略号的窗口式页码）、RenderPill（圆角）、RenderSmall（紧凑）和 RenderSimple（上一页 / 总数 / 下一页）。"),
            "SignalInt page = SignalInt.Create(1);\n// pick a style:\nint id = Pagination.Render(app, 40, 60, 12, page);       // windowed numbers\n// int id = Pagination.RenderPill(app, 40, 60, 12, page);  // rounded\n// int id = Pagination.RenderSmall(app, 40, 60, 12, page); // compact\nPagination.HandleClick(app, id, 12, page);\n// the minimal style has its own click handler:\nint sid = Pagination.RenderSimple(app, 40, 100, 12, page);\nPagination.HandleClickSimple(app, sid, 12, page);")
            .AddProp("total", "int", "-", "Number of pages.")
            .AddProp("page", "SignalInt", "-", "Current page (two-way).")
            .AddProp("RenderPill / RenderSmall", "int", "-", "Rounded / compact styles (use HandleClick).")
            .AddProp("RenderSimple", "int", "-", "prev / total / next (use HandleClickSimple).")
            .AddEvent("Change", "HandleClick(...)", "Clicking a page sets page.");
        Gallery.Add(list, "Navigation", "Scrollbar",
            Gallery.T("A vertical scrollbar for a custom scrollable surface. RenderVerticalScroll is interactive: drag the thumb or click the track (the thumb centres on the pointer) to update a bound scroll-offset signal. RenderVertical is the static, display-only variant.",
                "用于自定义可滚动区域的垂直滚动条。RenderVerticalScroll 可交互：拖动滑块或点击轨道（滑块会居中到指针处）以更新绑定的滚动偏移信号。RenderVertical 是静态、仅显示的变体。"),
            "SignalInt off = SignalInt.Create(0);\n// mouse-wheel over the whole viewport:\nScrollbar.HandleWheel(app, vx, vy, vw, vh, contentH, off);\n// clip + draw your content shifted up by off.Get(), then:\nScrollbar.RenderVerticalScroll(app, x, y, barH, viewH, contentH, off);")
            .AddProp("viewH", "int", "-", "Visible viewport height in px.")
            .AddProp("contentH", "int", "-", "Total content height in px.")
            .AddProp("offset", "SignalInt", "-", "Bound scroll offset (drag/click/wheel update it).")
            .AddEvent("Drag / click / wheel", "RenderVerticalScroll / HandleWheel", "Updates offset in [0, contentH - viewH].");
    }
}
