        } else if (name == "Pagination") {
            // Multiple styles, each bound to its own current-page signal.
            Label.Secondary(app, px, py - app.Scale(18), "Default · windowed with ellipses");
            int id = Pagination.Render(app, px, py, 12, Gallery.demoInt);
            Pagination.HandleClick(app, id, 12, Gallery.demoInt);

            int r2 = py + app.Scale(58);
