using System;
using Gui;

namespace Gallery.Custom;

/// @component Custom success
class StatusPill : Control {
    StatusPill() {
        InitControl("StatusPill", 1);
    }

    override string Kind() {
        return "StatusPill";
    }

    override void OnMeasure(App app) {
        prefW = app.Scale(112);
        prefH = app.Scale(28);
    }

    override void OnPaint(App app) {
        Theme t = app.theme;
        int radius = bh / 2;
        app.canvas.FillRoundRect(bx, by, bw, bh, radius, t.success);
        app.canvas.DrawTextCentered(
            bx, by, bw, bh, "Custom", t.textInverse, t.fontSizeSmall);
    }
}
