using System;

namespace CollectionsTest;

class Program {
    static void Main() {
        Console.WriteLine("=== List tests ===");

        List<int> nums = new List<int>();
        nums.Add(10);
        nums.Add(20);
        nums.Add(30);
        nums.Add(40);
        nums.Add(50);
        Console.WriteLine(nums.Count);

        // Contains
        if (nums.Contains(30)) {
            Console.WriteLine("Contains 30: true");
        }
        if (!nums.Contains(99)) {
            Console.WriteLine("Contains 99: false");
        }

        // IndexOf
        int idx = nums.IndexOf(30);
        Console.WriteLine(idx);

        // Insert
        nums.Insert(2, 25);
        Console.WriteLine(nums[2]);
        Console.WriteLine(nums.Count);

        // RemoveAt
        nums.RemoveAt(2);
        Console.WriteLine(nums[2]);
        Console.WriteLine(nums.Count);

        // Reverse
        nums.Reverse();
        Console.WriteLine(nums[0]);
        Console.WriteLine(nums[4]);

        // Clear
        nums.Clear();
        Console.WriteLine(nums.Count);

        Console.WriteLine("=== Dict tests ===");

        Dict<string, int> ages = new Dict<string, int>();
        ages["Alice"] = 30;
        ages["Bob"] = 25;
        ages["Charlie"] = 35;
        Console.WriteLine(ages.Count);

        if (ages.ContainsKey("Bob")) {
            Console.WriteLine("Has Bob: true");
        }

        // Remove
        ages.Remove("Bob");
        Console.WriteLine(ages.Count);
        if (!ages.ContainsKey("Bob")) {
            Console.WriteLine("Bob removed: true");
        }

        // Clear
        ages.Clear();
        Console.WriteLine(ages.Count);

        Console.WriteLine("=== All collection tests passed! ===");
    }
}
