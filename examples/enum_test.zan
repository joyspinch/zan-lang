// enum_test.zan -- M2.6 Enum support test
// Tests: enum declaration, member access, switch on enum values

enum Color {
    Red,
    Green,
    Blue
}

enum Priority {
    Low = 1,
    Medium = 5,
    High = 10,
    Critical = 100
}

class Program {
    static void Main() {
        // Basic enum member access
        var color = Color.Red;
        Console.WriteLine(color);      // 0

        var g = Color.Green;
        Console.WriteLine(g);          // 1

        var b = Color.Blue;
        Console.WriteLine(b);          // 2

        // Enum with explicit values
        var p = Priority.Medium;
        Console.WriteLine(p);          // 5

        var h = Priority.High;
        Console.WriteLine(h);          // 10

        var c = Priority.Critical;
        Console.WriteLine(c);          // 100

        // Switch on enum value
        var status = Color.Green;
        switch (status) {
            case 0:
                Console.WriteLine("Red");
                break;
            case 1:
                Console.WriteLine("Green");
                break;
            case 2:
                Console.WriteLine("Blue");
                break;
        }
    }
}
