using System;

namespace ClassInheritTest;

class Animal {
    public int Age;
    
    public Animal(int age) {
        Age = age;
    }
    
    int GetAge() {
        return Age;
    }
}

class Dog {
    public int Age;
    public int Tricks;
    
    public Dog(int age, int tricks) {
        Age = age;
        Tricks = tricks;
    }
    
    int GetInfo() {
        return Age + Tricks;
    }
}

class Program {
    static void Main() {
        var dog = new Dog(3, 5);
        Console.WriteLine(dog.Age);      // 3
        Console.WriteLine(dog.Tricks);   // 5
        var info = dog.GetInfo();
        Console.WriteLine(info);         // 8
    }
}
