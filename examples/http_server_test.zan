using System;
using System.Net.Sockets;

delegate int RequestHandler(int sock, string buf, int len);

class Program {
    [DllImport("crt")]
    static extern int strlen(string str);

    [DllImport("crt")]
    static extern int strncmp(string a, string b, int n);

    [DllImport("zan_httpd")]
    static extern void httpd_set_route(int id, string resp, int len);

    [DllImport("zan_httpd")]
    static extern void httpd_serve_with_handler(int sock, RequestHandler handler);

    static int HandleRequest(int sock, string buf, int len) {
        if (strncmp(buf, "GET /api/hello", 14) == 0) {
            return 1;
        }
        if (strncmp(buf, "GET /api/status", 15) == 0) {
            return 2;
        }
        if (strncmp(buf, "GET /api/users", 14) == 0) {
            return 3;
        }
        if (strncmp(buf, "GET /api/", 9) == 0) {
            return 4;
        }
        return 5;
    }

    static void Main() {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.SetReuseAddr(sock);
        Socket.Bind(sock, "0.0.0.0", 8899);
        Socket.Listen(sock, 512);

        string r0 = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: 25\r\nConnection: keep-alive\r\n\r\n{\"message\":\"hello world\"}";
        httpd_set_route(0, r0, strlen(r0));

        string r1 = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: 26\r\nConnection: keep-alive\r\n\r\n{\"status\":\"ok\",\"code\":200}";
        httpd_set_route(1, r1, strlen(r1));

        string r2 = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: 47\r\nConnection: keep-alive\r\n\r\n[{\"id\":1,\"name\":\"Alice\"},{\"id\":2,\"name\":\"Bob\"}]";
        httpd_set_route(2, r2, strlen(r2));

        string r3 = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: 36\r\nConnection: keep-alive\r\n\r\n{\"api\":\"zan-webapi\",\"version\":\"1.0\"}";
        httpd_set_route(3, r3, strlen(r3));

        string r4 = "HTTP/1.1 404 Not Found\r\nContent-Type: application/json\r\nContent-Length: 21\r\nConnection: keep-alive\r\n\r\n{\"error\":\"not found\"}";
        httpd_set_route(4, r4, strlen(r4));

        Console.WriteLine("Zan WebAPI server on :8899");
        Console.WriteLine("Routes:");
        Console.WriteLine("  GET /api/hello  -> JSON hello");
        Console.WriteLine("  GET /api/status -> JSON status");
        Console.WriteLine("  GET /api/users  -> JSON users");
        Console.WriteLine("  GET /api/       -> API info");
        Console.WriteLine("  *               -> 404");

        httpd_serve_with_handler(sock, HandleRequest);
    }
}
