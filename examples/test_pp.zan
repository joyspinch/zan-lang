class TestPreprocessor {
    static void Main() {
        #if WINDOWS
        int platform = 1;
        #elif LINUX
        int platform = 2;
        #else
        int platform = 0;
        #endif

        #define DEBUG
        #ifdef DEBUG
        int debug_mode = 1;
        #else
        int debug_mode = 0;
        #endif

        #ifndef RELEASE
        int is_dev = 1;
        #else
        int is_dev = 0;
        #endif

        // Test -D flag from command line
        #ifdef CUSTOM_FLAG
        int custom = 42;
        #else
        int custom = 0;
        #endif

        printf("Platform: %d (1=Windows, 2=Linux)\n", platform);
        printf("Debug: %d\n", debug_mode);
        printf("IsDev: %d\n", is_dev);
        printf("Custom: %d\n", custom);
    }

    [DllImport("msvcrt")]
    static extern int printf(string fmt, int val);
}
