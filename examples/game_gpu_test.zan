using System;
using SDL3;
using Game.Render;

namespace Examples.GameGpuTest;

/// <summary>
/// Headless SDL_GPU verification: renders through the Game.Render sprite API
/// into an offscreen target and reads pixels back on the CPU, so it needs no
/// window or display server. Clears blue, draws an opaque red quad in the
/// middle, then asserts the center is red and a corner stayed blue.
/// </summary>
class Program {
    static void Main() {
        if (!Sdl.Init(SdlInit.Video())) {
            Console.WriteLine("init failed: " + Sdl.Error());
            return;
        }

        SdlGpu gpu = SdlGpu.CreateOffscreen(64, 64);
        if (!gpu.IsValid()) {
            Console.WriteLine("no SDL_GPU device: " + Sdl.Error());
            Sdl.Quit();
            return;
        }

        SdlGpuTexture white = gpu.SolidTexture(2, 2);

        gpu.Begin(0, 0, 255, 255);
        Sprite quad = Sprite.Create(white, 20, 20, 24, 24);
        quad.SetTint(Color.Rgba(255, 0, 0, 255));
        quad.Draw(gpu);
        gpu.End();

        int center = gpu.ReadPixel(32, 32);
        int corner = gpu.ReadPixel(2, 2);
        Console.WriteLine("center=" + Convert.ToString(center));
        Console.WriteLine("corner=" + Convert.ToString(corner));

        bool spritePass = center == 4278190335;
        bool clearPass = corner == 65535;
        Console.WriteLine("sprite=" + Convert.ToString(spritePass));
        Console.WriteLine("clear=" + Convert.ToString(clearPass));

        white.Free();
        gpu.Destroy();
        Sdl.Quit();
    }
}
