using System;
using System.Net.Sockets;

class Program {
    static void Main() {
        Console.WriteLine("Step 1");
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Console.WriteLine("Step 2: sock=" + Convert.ToString(sock));
        Socket.SetReuseAddr(sock);
        Console.WriteLine("Step 3: SetReuseAddr done");
        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
