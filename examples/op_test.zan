using System;

class Vec2 {
    int x;
    int y;

    Vec2(int x, int y) {
        this.x = x;
        this.y = y;
    }

    static Vec2 operator+(Vec2 a, Vec2 b) {
        return new Vec2(a.x + b.x, a.y + b.y);
    }

    static Vec2 operator-(Vec2 a, Vec2 b) {
        return new Vec2(a.x - b.x, a.y - b.y);
    }

    static bool operator==(Vec2 a, Vec2 b) {
        return a.x == b.x && a.y == b.y;
    }

    void Print() {
        Console.Write("(");
        Console.Write(x);
        Console.Write(", ");
        Console.Write(y);
        Console.WriteLine(")");
    }
}

class Program {
    static void Main() {
        Vec2 a = new Vec2(3, 4);
        Vec2 b = new Vec2(1, 2);
        Vec2 c = a + b;
        c.Print();
        Vec2 d = a - b;
        d.Print();
        Console.WriteLine("Operator overloading works!");
    }
}
