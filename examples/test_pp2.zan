class TestPP2 {
    static void Main() {
        // Test #elif chain
        #define TARGET_ARM
        #ifdef TARGET_X86
        int arch = 86;
        #elif TARGET_ARM
        int arch = 32;
        #elif TARGET_MIPS
        int arch = 64;
        #else
        int arch = 0;
        #endif
        printf("Arch: %d (expect 32)\n", arch);

        // Test nested #if
        #define FEATURE_A
        #define FEATURE_B
        #ifdef FEATURE_A
            #ifdef FEATURE_B
            int both = 1;
            #else
            int both = 0;
            #endif
        #else
        int both = -1;
        #endif
        printf("Both: %d (expect 1)\n", both);

        // Test #undef
        #define TEMP_FLAG
        #ifdef TEMP_FLAG
        int before_undef = 1;
        #else
        int before_undef = 0;
        #endif
        #undef TEMP_FLAG
        #ifdef TEMP_FLAG
        int after_undef = 1;
        #else
        int after_undef = 0;
        #endif
        printf("Before undef: %d (expect 1)\n", before_undef);
        printf("After undef: %d (expect 0)\n", after_undef);

        // Test #if with defined()
        #define HAS_SOCKET
        #if defined(HAS_SOCKET) && WINDOWS
        int net = 1;
        #else
        int net = 0;
        #endif
        printf("Net: %d (expect 1 on Win)\n", net);

        // Test false branch nesting - #define inside false branch should not leak
        #ifdef NONEXISTENT
            #define SHOULD_NOT_DEFINE
        #endif
        #ifdef SHOULD_NOT_DEFINE
        int leaked = 1;
        #else
        int leaked = 0;
        #endif
        printf("Leaked: %d (expect 0)\n", leaked);
    }

    [DllImport("msvcrt")]
    static extern int printf(string fmt, int a);
}
