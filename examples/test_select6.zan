using System;
using System.Net.Sockets;

class Program {
    [DllImport("crt")]
    static extern string calloc(int count, int size);
    [DllImport("crt")]
    static extern void free(string ptr);
    [DllImport("ws2_32")]
    static extern int select(int nfds, string readfds, string writefds, string exceptfds, string timeout);
    [DllImport("ws2_32")]
    static extern int WSAGetLastError();

    static void Main() {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.SetReuseAddr(sock);
        Socket.Bind(sock, "0.0.0.0", 8899);
        Socket.Listen(sock, 128);
        Console.WriteLine("sock=" + Convert.ToString(sock));

        // Test offset 8 for fd_array[0] (8-byte aligned)
        string readfds = calloc(520, 1);
        readfds[0] = 1;
        // fd_array[0] at offset 8 (after 4-byte padding)
        readfds[8] = sock & 255;
        readfds[9] = (sock >> 8) & 255;
        readfds[10] = (sock >> 16) & 255;
        readfds[11] = (sock >> 24) & 255;

        string ew = calloc(8, 1);
        string ee = calloc(8, 1);
        string tv = calloc(8, 1);
        tv[0] = 1;

        int result = select(0, readfds, ew, ee, tv);
        int err = WSAGetLastError();
        Console.WriteLine("offset8: select=" + Convert.ToString(result) + " err=" + Convert.ToString(err));

        free(readfds);
        free(ew);
        free(ee);
        free(tv);
        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
