using System;

namespace InheritanceDemo;

class Shape {
    public int X;
    public int Y;
    
    public Shape(int x, int y) {
        X = x;
        Y = y;
    }
    
    int GetX() {
        return X;
    }
    
    int GetY() {
        return Y;
    }
}

class Circle : Shape {
    public int Radius;
    
    public Circle(int x, int y, int r) {
        X = x;
        Y = y;
        Radius = r;
    }
    
    int GetArea() {
        return 3 * Radius * Radius;
    }
}

class Program {
    static void Main() {
        var c = new Circle(10, 20, 5);
        Console.WriteLine(c.X);         // 10
        Console.WriteLine(c.Y);         // 20
        Console.WriteLine(c.Radius);    // 5
        var area = c.GetArea();
        Console.WriteLine(area);         // 75 (3*5*5)
    }
}
