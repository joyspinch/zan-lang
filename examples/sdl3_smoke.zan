using System;
using SDL3;

namespace Examples.Sdl3Smoke;

class Program {
    static void Main() {
        if (!Sdl.Init(SdlInit.Timer() + SdlInit.Events())) {
            Console.WriteLine("SDL init failed: " + Sdl.Error());
            return;
        }

        Console.WriteLine("SDL version: " + Convert.ToString(Sdl.Version()));
        Console.WriteLine("SDL3 Zan bridge is ready");
        Sdl.Quit();
    }
}
