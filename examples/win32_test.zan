using System;

namespace Win32Test;

class Kernel32 {
    [DllImport("kernel32")]
    static extern int GetCurrentProcessId();

    [DllImport("kernel32")]
    static extern int GetTickCount();
}

class Msvcrt {
    [DllImport("msvcrt")]
    static extern int _getpid();

    [DllImport("msvcrt")]
    static extern int atoi(string str);
}

class Program {
    static void Main() {
        int pid = Kernel32.GetCurrentProcessId();
        Console.WriteLine("PID:");
        Console.WriteLine(pid);

        int tick = Kernel32.GetTickCount();
        Console.WriteLine("TickCount:");
        Console.WriteLine(tick);

        int val = Msvcrt.atoi("12345");
        Console.WriteLine("atoi result:");
        Console.WriteLine(val);
    }
}
