using System;
using System.Json;

namespace JsonTest;

/// Headless verification of the recursive JsonValue parser.
class Program {
    static void Main() {
        string doc = "{ \"type\": \"Column\", \"gap\": 12, \"pad\": 20, \"open\": true, \"children\": [ { \"type\": \"Label\", \"text\": \"Hi\" }, { \"type\": \"Button\", \"text\": \"Save\", \"onClick\": \"save\" } ] }";
        JsonValue root = JsonValue.Parse(doc);

        Console.WriteLine("=== root ===");
        Console.WriteLine("isObject " + Convert.ToString(root.IsObject()));
        Console.WriteLine("type " + root.Str("type", "?"));
        Console.WriteLine("gap " + Convert.ToString(root.Int("gap", -1)));
        Console.WriteLine("pad " + Convert.ToString(root.Int("pad", -1)));
        Console.WriteLine("open " + Convert.ToString(root.Bool("open", false)));

        JsonValue kids = root.Get("children");
        Console.WriteLine("=== children ===");
        Console.WriteLine("count " + Convert.ToString(kids.Count()));
        int i = 0;
        while (i < kids.Count()) {
            JsonValue k = kids.At(i);
            Console.WriteLine("[" + Convert.ToString(i) + "] type=" + k.Str("type", "?")
                + " text=" + k.Str("text", "?") + " onClick=" + k.Str("onClick", "-"));
            i = i + 1;
        }

        Console.WriteLine("=== missing ===");
        Console.WriteLine("has(role) " + Convert.ToString(root.Has("role")));
        Console.WriteLine("missing str " + root.Str("nope", "DEFLT"));
    }
}
