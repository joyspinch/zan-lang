using System;

namespace DictTest;

class Program {
    static void Main() {
        var dict = new Dict<string, int>();
        dict.Add("apple", 10);
        dict.Add("banana", 20);
        dict.Add("cherry", 30);
        
        Console.WriteLine(dict.Count);       // 3
        Console.WriteLine(dict["apple"]);    // 10
        Console.WriteLine(dict["banana"]);   // 20
        Console.WriteLine(dict["cherry"]);   // 30
    }
}
