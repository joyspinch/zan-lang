using System;
using System.Net.Sockets;

class Program {
    [DllImport("crt")]
    static extern int strlen(string str);

    [DllImport("zan_httpd")]
    static extern void httpd_set_response(string resp, int len);

    [DllImport("zan_httpd")]
    static extern void httpd_serve(int sock);

    static void Main() {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.SetReuseAddr(sock);
        Socket.Bind(sock, "0.0.0.0", 8899);
        Socket.Listen(sock, 512);

        string r0 = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: 26\r\nConnection: keep-alive\r\n\r\n{\"message\":\"hello world\"}";
        httpd_set_response(r0, strlen(r0));

        Console.WriteLine("Static response test");
        httpd_serve(sock);
    }
}
