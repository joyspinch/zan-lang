using System;

namespace FFITest;

class NativeMath {
    [DllImport("m")]
    static extern double sin(double x);

    [DllImport("m")]
    static extern double cos(double x);

    [DllImport("m")]
    static extern double sqrt(double x);
}

class Program {
    static void Main() {
        double r = NativeMath.sqrt(144.0);
        Console.WriteLine(r);

        double s = NativeMath.sin(0.0);
        Console.WriteLine(s);

        double c = NativeMath.cos(0.0);
        Console.WriteLine(c);
    }
}
