using System;

namespace LoopTest;

class Program {
    static void Main() {
        // while loop
        var i = 0;
        while (i < 5) {
            Console.WriteLine($"while: {i}");
            i = i + 1;
        }

        // for loop with break
        for (var j = 0; j < 10; j = j + 1) {
            if (j == 3) {
                break;
            }
            Console.WriteLine($"for: {j}");
        }

        // nested loops
        for (var x = 0; x < 3; x = x + 1) {
            for (var y = 0; y < 2; y = y + 1) {
                Console.WriteLine($"nested: {x},{y}");
            }
        }

        // while with computation
        var sum = 0;
        var n = 1;
        while (n <= 10) {
            sum = sum + n;
            n = n + 1;
        }
        Console.WriteLine($"sum 1..10 = {sum}");
    }
}
