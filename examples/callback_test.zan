using System;

delegate int MathOp(int a, int b);

class Program {
    [DllImport("crt")]
    static extern int strlen(string str);

    [DllImport("callback_test")]
    static extern int test_callback(MathOp fn, int a, int b);

    [DllImport("callback_test")]
    static extern int test_callback_in_thread(MathOp fn, int a, int b);

    static int Add(int a, int b) {
        return a + b;
    }

    static int AddWithCall(int a, int b) {
        int slen = strlen("test");
        return a + b + slen;
    }

    static void Main() {
        Console.WriteLine("Test 1: direct callback (no function calls in handler)");
        int r1 = test_callback(Add, 10, 20);
        Console.WriteLine(r1);

        Console.WriteLine("Test 2: callback with DllImport call in handler");
        int r2 = test_callback(AddWithCall, 10, 20);
        Console.WriteLine(r2);

        Console.WriteLine("Test 3: callback in thread (no function calls)");
        int r3 = test_callback_in_thread(Add, 100, 200);
        Console.WriteLine(r3);

        Console.WriteLine("Test 4: callback in thread with DllImport call");
        int r4 = test_callback_in_thread(AddWithCall, 100, 200);
        Console.WriteLine(r4);

        Console.WriteLine("All tests passed!");
    }
}
