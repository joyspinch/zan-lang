using System;

namespace GenericsTest;

class Pair<T> {
    public int First;
    public int Second;
    
    public Pair(int a, int b) {
        First = a;
        Second = b;
    }
    
    int Sum() {
        return First + Second;
    }
}

class Program {
    static void Main() {
        var p = new Pair(3, 7);
        Console.WriteLine(p.First);   // 3
        Console.WriteLine(p.Second);  // 7
        var s = p.Sum();
        Console.WriteLine(s);         // 10
    }
}
