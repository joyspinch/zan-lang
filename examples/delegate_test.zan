using System;

delegate int MathOp(int a, int b);

class Program {
    static int Add(int a, int b) {
        return a + b;
    }

    static int Multiply(int a, int b) {
        return a * b;
    }

    static void Main() {
        MathOp op = Add;
        int result = op(3, 4);
        Console.WriteLine(result);

        op = Multiply;
        result = op(3, 4);
        Console.WriteLine(result);
    }
}
