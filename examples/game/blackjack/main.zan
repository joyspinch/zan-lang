// Blackjack (21) -- a complete casino product on GameKit.
// Shuffled 52-card deck, hit / stand / double, dealer stands on 17, natural
// blackjack pays 3:2, chip bankroll with bet selection, deal animation,
// dynamic dealer commentary, and a persistent chips / streak profile.
using System;
using System.IO;
using SDL3;
using GameKit;

namespace Blackjack;

class Profile {
    int chips;
    int streak;
    int best;
    int wins;
    int losses;
    int pushes;
    int games;
    int hands;
    int blackjacks;

    static string Path() { return "blackjack_save.txt"; }

    static int ParseInt(string s, int start) {
        int i = start;
        int sign = 1;
        if (i < s.Length && s[i] == 45) { sign = -1; i = i + 1; }
        int v = 0;
        bool any = false;
        while (i < s.Length) {
            int c = s[i] & 255;
            if (c >= 48 && c <= 57) { v = v * 10 + (c - 48); any = true; i = i + 1; }
            else { i = s.Length; }
        }
        if (!any) { return 0; }
        return v * sign;
    }

    static int ReadKey(List<string> lines, string key, int fallback) {
        int i = 0;
        while (i < lines.Count) {
            string ln = lines[i];
            int eq = -1;
            int j = 0;
            while (j < ln.Length) { if (ln[j] == 61) { eq = j; j = ln.Length; } j = j + 1; }
            if (eq > 0) { if (ln.Substring(0, eq) == key) { return Profile.ParseInt(ln, eq + 1); } }
            i = i + 1;
        }
        return fallback;
    }

    static Profile Load() {
        Profile p = new Profile();
        p.chips = 500; p.streak = 0; p.best = 0;
        p.wins = 0; p.losses = 0; p.pushes = 0; p.games = 0; p.hands = 0; p.blackjacks = 0;
        if (File.Exists(Profile.Path())) {
            List<string> lines = File.ReadAllLines(Profile.Path());
            p.chips = Profile.ReadKey(lines, "chips", 500);
            p.streak = Profile.ReadKey(lines, "streak", 0);
            p.best = Profile.ReadKey(lines, "best", 0);
            p.wins = Profile.ReadKey(lines, "wins", 0);
            p.losses = Profile.ReadKey(lines, "losses", 0);
            p.pushes = Profile.ReadKey(lines, "pushes", 0);
            p.games = Profile.ReadKey(lines, "games", 0);
            p.hands = Profile.ReadKey(lines, "hands", 0);
            p.blackjacks = Profile.ReadKey(lines, "blackjacks", 0);
        }
        if (p.chips < 25) { p.chips = 500; }
        return p;
    }

    void Save() {
        string s = "";
        s = s + "chips=" + this.chips + "\n";
        s = s + "streak=" + this.streak + "\n";
        s = s + "best=" + this.best + "\n";
        s = s + "wins=" + this.wins + "\n";
        s = s + "losses=" + this.losses + "\n";
        s = s + "pushes=" + this.pushes + "\n";
        s = s + "games=" + this.games + "\n";
        s = s + "hands=" + this.hands + "\n";
        s = s + "blackjacks=" + this.blackjacks + "\n";
        File.WriteAllText(Profile.Path(), s);
    }
}

// Card 0..51: rank = c%13 (0=A,1=2,...,9=10,10=J,11=Q,12=K), suit = c/13
// (0 hearts, 1 diamonds, 2 clubs, 3 spades).
class Deck {
    static int Value(int card) {
        int rk = card % 13;
        if (rk == 0) { return 11; }
        if (rk >= 10) { return 10; }
        return rk + 1;
    }
    static string RankStr(int card) {
        int rk = card % 13;
        if (rk == 0) { return "A"; }
        if (rk == 9) { return "10"; }
        if (rk == 10) { return "J"; }
        if (rk == 11) { return "Q"; }
        if (rk == 12) { return "K"; }
        return "" + (rk + 1);
    }
    static string SuitStr(int card) {
        int s = card / 13;
        if (s == 0) { return "H"; }
        if (s == 1) { return "D"; }
        if (s == 2) { return "C"; }
        return "S";
    }
    static bool IsRed(int card) { int s = card / 13; return s == 0 || s == 1; }
}

class BjGame {
    Host host;
    SdlRenderer r;
    Profile prof;
    Rng rng;
    Talker talk;
    int[] deck;
    int deckPos;
    int[] player;
    int playerN;
    int[] dealer;
    int dealerN;
    int scene;
    int phase;        // 0 betting, 1 player, 2 dealer, 3 result
    int bet;
    int result;       // 0 none, 1 win, 2 lose, 3 push, 4 blackjack
    bool hidden;      // dealer hole card hidden
    bool doubled;
    int dealerAt;
    int mouseX;
    int mouseY;
    int revealN;      // cards currently revealed (deal animation)
    int revealAt;
    int payout;
    SdlTexture menuBg;
    bool menuTried;
    bool demo;
    int demoAt;

    static BjGame Create(Host h) {
        BjGame g = new BjGame();
        g.host = h;
        g.r = h.Renderer();
        g.prof = Profile.Load();
        g.rng = Rng.Seed((long)Sdl.Ticks() + 918273645);
        g.talk = Talker.Create(g.rng);
        g.deck = new int[52];
        g.player = new int[24];
        g.dealer = new int[24];
        g.scene = 0;
        g.bet = 50;
        g.SetupTalk();
        g.demo = File.Exists("blackjack_demo.txt");
        if (g.demo) { g.EnterTable(Sdl.Ticks()); g.demoAt = Sdl.Ticks() + 700; }
        return g;
    }

    void SetupTalk() {
        this.talk.Add(0, "Nice hit!");
        this.talk.Add(0, "The count favors you.");
        this.talk.Add(0, "Smooth play.");
        this.talk.Add(1, "Dealer looks strong...");
        this.talk.Add(1, "Careful, that's 12+.");
        this.talk.Add(1, "House edge is real.");
        this.talk.Add(2, "Place your bet.");
        this.talk.Add(2, "Hit or stand?");
        this.talk.Add(3, "BLACKJACK!");
        this.talk.Add(3, "Twenty-one!");
        this.talk.Add(3, "Dealer busts!");
    }

    void ShuffleDeck() {
        int i = 0;
        while (i < 52) { this.deck[i] = i; i = i + 1; }
        i = 51;
        while (i > 0) {
            int j = this.rng.Range(0, i + 1);
            int t = this.deck[i]; this.deck[i] = this.deck[j]; this.deck[j] = t;
            i = i - 1;
        }
        this.deckPos = 0;
    }

    int Draw2() {
        int c = this.deck[this.deckPos];
        this.deckPos = this.deckPos + 1;
        if (this.deckPos >= 52) { this.ShuffleDeck(); }
        return c;
    }

    static int HandValue(int[] h, int n) {
        int sum = 0;
        int aces = 0;
        int i = 0;
        while (i < n) {
            int v = Deck.Value(h[i]);
            if (h[i] % 13 == 0) { aces = aces + 1; }
            sum = sum + v;
            i = i + 1;
        }
        while (sum > 21 && aces > 0) { sum = sum - 10; aces = aces - 1; }
        return sum;
    }

    static bool IsSoft(int[] h, int n) {
        int sum = 0;
        int aces = 0;
        int i = 0;
        while (i < n) {
            sum = sum + Deck.Value(h[i]);
            if (h[i] % 13 == 0) { aces = aces + 1; }
            i = i + 1;
        }
        while (sum > 21 && aces > 0) { sum = sum - 10; aces = aces - 1; }
        return aces > 0 && sum <= 21;
    }

    void EnterTable(int now) {
        this.scene = 1;
        this.phase = 0;
        this.result = 0;
        this.ShuffleDeck();
        if (this.bet > this.prof.chips) { this.bet = this.prof.chips; }
        if (this.bet < 25) { this.bet = 25; }
        this.talk.SayExact(2, "Place your bet and deal!", now, 2600);
    }

    void Deal(int now) {
        if (this.bet > this.prof.chips) { this.bet = this.prof.chips; }
        this.playerN = 0;
        this.dealerN = 0;
        this.doubled = false;
        this.hidden = true;
        this.result = 0;
        this.player[0] = this.Draw2(); this.playerN = 1;
        this.dealer[0] = this.Draw2(); this.dealerN = 1;
        this.player[1] = this.Draw2(); this.playerN = 2;
        this.dealer[1] = this.Draw2(); this.dealerN = 2;
        this.revealN = 0;
        this.revealAt = now;
        this.phase = 1;
        int pv = BjGame.HandValue(this.player, this.playerN);
        if (pv == 21) {
            // natural -- reveal and resolve after deal animation
            this.phase = 2;
            this.hidden = false;
            this.dealerAt = now + 1400;
        }
    }

    void PlayerHit(int now) {
        if (this.phase != 1) { return; }
        this.player[this.playerN] = this.Draw2();
        this.playerN = this.playerN + 1;
        this.revealN = this.playerN + this.dealerN;   // instantly shown
        int pv = BjGame.HandValue(this.player, this.playerN);
        if (pv > 21) { this.hidden = false; this.Resolve(now); }
        else if (pv == 21) { this.Stand(now); }
        else if (this.rng.Range(0, 100) < 45) { this.talk.Say(0, now, 1800); }
    }

    void Stand(int now) {
        if (this.phase != 1) { return; }
        this.hidden = false;
        this.phase = 2;
        this.dealerAt = now + 650;
    }

    void DoubleDown(int now) {
        if (this.phase != 1 || this.playerN != 2) { return; }
        if (this.prof.chips < this.bet * 2) { return; }
        this.doubled = true;
        this.bet = this.bet * 2;
        this.player[this.playerN] = this.Draw2();
        this.playerN = this.playerN + 1;
        int pv = BjGame.HandValue(this.player, this.playerN);
        if (pv > 21) { this.hidden = false; this.Resolve(now); }
        else { this.Stand(now); }
    }

    void DealerStep(int now) {
        int dv = BjGame.HandValue(this.dealer, this.dealerN);
        if (dv < 17) {
            this.dealer[this.dealerN] = this.Draw2();
            this.dealerN = this.dealerN + 1;
            this.dealerAt = now + 700;
            return;
        }
        this.Resolve(now);
    }

    void Resolve(int now) {
        this.phase = 3;
        int pv = BjGame.HandValue(this.player, this.playerN);
        int dv = BjGame.HandValue(this.dealer, this.dealerN);
        bool pNat = (pv == 21 && this.playerN == 2);
        bool dNat = (dv == 21 && this.dealerN == 2);
        int gain = 0;
        this.prof.hands = this.prof.hands + 1;
        if (pv > 21) {
            this.result = 2; gain = -this.bet;
            this.talk.SayExact(1, "Bust! You lose " + this.bet + ".", now, 3200);
        } else if (pNat && !dNat) {
            this.result = 4; gain = this.bet * 3 / 2;
            this.prof.blackjacks = this.prof.blackjacks + 1;
            this.talk.SayExact(3, "BLACKJACK! +" + gain, now, 3600);
        } else if (dNat && !pNat) {
            this.result = 2; gain = -this.bet;
            this.talk.SayExact(1, "Dealer blackjack. -" + this.bet, now, 3200);
        } else if (dv > 21) {
            this.result = 1; gain = this.bet;
            this.talk.SayExact(3, "Dealer busts! +" + gain, now, 3200);
        } else if (pv > dv) {
            this.result = 1; gain = this.bet;
            this.talk.SayExact(0, "You win +" + gain + "!", now, 3200);
        } else if (pv < dv) {
            this.result = 2; gain = -this.bet;
            this.talk.SayExact(1, "House wins. -" + this.bet, now, 3200);
        } else {
            this.result = 3; gain = 0;
            this.talk.SayExact(2, "Push. Bet returned.", now, 3000);
        }
        this.payout = gain;
        this.prof.chips = this.prof.chips + gain;
        if (this.prof.chips < 0) { this.prof.chips = 0; }
        this.prof.games = this.prof.games + 1;
        if (gain > 0) {
            this.prof.wins = this.prof.wins + 1;
            this.prof.streak = this.prof.streak + 1;
            if (this.prof.streak > this.prof.best) { this.prof.best = this.prof.streak; }
        } else if (gain < 0) {
            this.prof.losses = this.prof.losses + 1;
            this.prof.streak = 0;
        } else {
            this.prof.pushes = this.prof.pushes + 1;
        }
        if (this.doubled) { this.bet = this.bet / 2; }
        if (this.bet > this.prof.chips) { this.bet = this.prof.chips; if (this.bet < 25) { this.bet = 25; } }
        this.prof.Save();
    }

    // ----- rendering ---------------------------------------------------------

    void DrawCard(int x, int y, int card, bool faceUp) {
        int w = 96; int h = 136;
        Draw.RoundRectFill(this.r, x + 4, y + 6, w, h, 12, 6, 8, 12, 120);
        if (!faceUp) {
            Draw.RoundRectFill(this.r, x, y, w, h, 12, 40, 60, 120, 255);
            Draw.RoundRectFill(this.r, x + 8, y + 8, w - 16, h - 16, 8, 60, 90, 170, 255);
            Draw.RingRect(this.r, x + 8, y + 8, w - 16, h - 16, 2, 130, 160, 230, 255);
            Text.DrawCentered(this.r, "Z", x + w / 2, y + h / 2 - 12, 4, 190, 210, 250, 255);
            return;
        }
        Draw.RoundRectFill(this.r, x, y, w, h, 12, 248, 246, 240, 255);
        Draw.RingRect(this.r, x, y, w, h, 2, 200, 200, 200, 255);
        int cr = 40; int cg = 44; int cb = 52;
        if (Deck.IsRed(card)) { cr = 200; cg = 50; cb = 55; }
        string rk = Deck.RankStr(card);
        string su = Deck.SuitStr(card);
        Text.Draw(this.r, rk, x + 8, y + 8, 2, cr, cg, cb, 255);
        Text.Draw(this.r, su, x + 8, y + 30, 2, cr, cg, cb, 255);
        Text.DrawCentered(this.r, su, x + w / 2, y + h / 2 - 14, 4, cr, cg, cb, 255);
        Text.Draw(this.r, rk, x + w - 24, y + h - 44, 2, cr, cg, cb, 255);
    }

    void DrawHand(int[] h, int n, int y, bool dealerRow, int now) {
        int total = n;
        int startX = 640 - (total * 60) / 2;
        int i = 0;
        while (i < n) {
            bool faceUp = true;
            if (dealerRow && i == 1 && this.hidden) { faceUp = false; }
            if (i >= this.revealN && this.revealN < 4 && this.phase <= 1) {
                // deal animation: skip cards not yet revealed
            }
            this.DrawCard(startX + i * 120, y, h[i], faceUp);
            i = i + 1;
        }
    }

    void DrawTalk(int px, int py, int w, int now) {
        string msg = this.talk.Current(now);
        if (msg.Length == 0) { return; }
        int kind = this.talk.Kind();
        int cr = 90; int cg = 150; int cb = 220;
        if (kind == 0) { cr = 90; cg = 200; cb = 130; }
        if (kind == 1) { cr = 230; cg = 130; cb = 90; }
        if (kind == 3) { cr = 250; cg = 200; cb = 70; }
        this.r.SetColor(28, 32, 42, 235);
        this.r.FillRect(px, py, w, 46);
        Draw.RingRect(this.r, px, py, w, 46, 2, cr, cg, cb, 255);
        Text.Draw(this.r, msg, px + 14, py + 16, 2, cr, cg, cb, 255);
    }

    void DrawTable(int now) {
        this.host.Begin(18, 60, 44);
        // felt
        this.r.SetColor(24, 96, 66, 255);
        this.r.FillRect(40, 40, 1040, 720);
        Draw.RingRect(this.r, 40, 40, 1040, 720, 5, 200, 170, 90, 255);
        Draw.RingRect(this.r, 56, 56, 1008, 688, 2, 40, 130, 96, 255);

        Text.DrawCentered(this.r, "DEALER", 560, 70, 2, 210, 230, 210, 255);
        int dv = BjGame.HandValue(this.dealer, this.dealerN);
        string ds = "";
        if (!this.hidden) { ds = "" + dv; } else { ds = "" + Deck.Value(this.dealer[0]); }
        if (this.dealerN > 0) { Text.DrawCentered(this.r, ds, 560, 92, 2, 250, 220, 120, 255); }
        this.DrawHand(this.dealer, this.dealerN, 120, true, now);

        Text.DrawCentered(this.r, "YOU", 560, 470, 2, 230, 220, 200, 255);
        int pv = BjGame.HandValue(this.player, this.playerN);
        if (this.playerN > 0) {
            int cr = 250; int cg = 220; int cb = 120;
            if (pv > 21) { cr = 240; cg = 100; cb = 90; }
            Text.DrawCentered(this.r, "" + pv, 560, 492, 2, cr, cg, cb, 255);
        }
        this.DrawHand(this.player, this.playerN, 520, false, now);

        // side panel
        int px = 1104;
        Text.Draw(this.r, "BLACKJACK", px, 44, 3, 240, 240, 250, 255);
        Text.Draw(this.r, "CHIPS", px, 96, 2, 150, 160, 180, 255);
        Text.DrawShadow(this.r, "" + this.prof.chips, px, 116, 4, 255, 210, 90, 2);
        Text.Draw(this.r, "BET  " + this.bet, px, 168, 2, 210, 220, 235, 255);
        Text.Draw(this.r, "STREAK " + this.prof.streak, px, 196, 2, 180, 190, 210, 255);
        Text.Draw(this.r, "W" + this.prof.wins + " L" + this.prof.losses + " P" + this.prof.pushes, px, 222, 2, 180, 190, 210, 255);

        this.DrawTalk(px, 256, 156, now);

        if (this.phase == 0) {
            Ui.Button(this.r, this.mouseX, this.mouseY, px, 330, 70, 44, "-25", 2, 0);
            Ui.Button(this.r, this.mouseX, this.mouseY, px + 86, 330, 70, 44, "+25", 2, 0);
            Ui.Button(this.r, this.mouseX, this.mouseY, px, 384, 156, 44, "MAX BET", 2, 1);
            Ui.Button(this.r, this.mouseX, this.mouseY, px, 452, 156, 64, "DEAL", 3, 1);
        } else if (this.phase == 1) {
            Ui.Button(this.r, this.mouseX, this.mouseY, px, 330, 156, 52, "HIT", 2, 1);
            Ui.Button(this.r, this.mouseX, this.mouseY, px, 392, 156, 52, "STAND", 2, 0);
            int dk = 0;
            if (this.playerN == 2 && this.prof.chips >= this.bet * 2) { dk = 2; }
            Ui.Button(this.r, this.mouseX, this.mouseY, px, 454, 156, 52, "DOUBLE", 2, dk);
        } else if (this.phase == 3) {
            string res = "PUSH";
            int rr = 200; int rg = 200; int rb = 90;
            if (this.result == 1 || this.result == 4) { res = "YOU WIN"; rr = 90; rg = 210; rb = 130; }
            if (this.result == 4) { res = "BLACKJACK"; }
            if (this.result == 2) { res = "YOU LOSE"; rr = 230; rg = 110; rb = 90; }
            Text.DrawShadow(this.r, res, px, 336, 3, rr, rg, rb, 2);
            string ps = "" + this.payout;
            if (this.payout > 0) { ps = "+" + this.payout; }
            Text.Draw(this.r, ps + " chips", px, 380, 2, 255, 210, 90, 255);
            Ui.Button(this.r, this.mouseX, this.mouseY, px, 452, 156, 64, "NEXT HAND", 2, 1);
        }

        Ui.Button(this.r, this.mouseX, this.mouseY, px, 690, 156, 50, "MENU (ESC)", 2, 0);
        this.host.End();
    }

    void EnsureMenuBg() {
        if (this.menuTried) { return; }
        this.menuTried = true;
        SdlTexture t = SdlTexture.LoadImage(this.r, "examples/game/blackjack/assets/menu_bg.png");
        if (t != null && t.IsValid()) { t.SetNearest(false); t.SetBlendMode(1); } else { t = null; }
        this.menuBg = t;
    }

    void DrawMenu(int now) {
        this.EnsureMenuBg();
        this.host.Begin(16, 40, 30);
        Ui.Backdrop(this.r, this.menuBg, 1280, 800);

        Text.DrawCenteredShadow(this.r, "BLACKJACK", 640, 82, 9, 245, 238, 220, 4);
        Text.DrawCenteredShadow(this.r, "BEAT THE DEALER TO 21", 640, 186, 3, 240, 208, 130, 3);

        Ui.Panel(this.r, 360, 270, 560, 300, 20, 24, 34, 214);
        Text.Draw(this.r, "CHIPS", 392, 300, 2, 150, 160, 180, 255);
        Text.DrawShadow(this.r, "" + this.prof.chips, 392, 322, 6, 255, 210, 90, 3);
        Text.Draw(this.r, "BEST STREAK  " + this.prof.best, 392, 402, 2, 150, 160, 180, 255);
        Text.Draw(this.r, "HANDS  " + this.prof.hands + "     BLACKJACKS  " + this.prof.blackjacks, 392, 430, 2, 150, 160, 180, 255);
        Text.DrawShadow(this.r, this.prof.wins + "W - " + this.prof.losses + "L - " + this.prof.pushes + "P", 392, 462, 3, 205, 214, 232, 2);

        Ui.Button(this.r, this.mouseX, this.mouseY, 470, 610, 340, 74, "SIT DOWN", 4, 1);
        Text.DrawCenteredShadow(this.r, "Dealer stands on 17.   Blackjack pays 3:2.   ENTER play   F11 fullscreen", 640, 726, 2, 176, 184, 200, 2);

        this.host.End();
    }

    void OnKey(int sc, int now) {
        if (sc == 41) { if (this.scene == 0) { this.host.Quit(); } else { this.scene = 0; } }
        if (this.scene == 0) {
            if (sc == 40 || sc == 44) { this.EnterTable(now); }
        } else if (this.scene == 1) {
            if (this.phase == 0 && (sc == 40 || sc == 44)) { this.Deal(now); }
            if (this.phase == 1) {
                if (sc == 11) { this.PlayerHit(now); }     // H
                if (sc == 22) { this.Stand(now); }         // S
                if (sc == 7) { this.DoubleDown(now); }     // D
            }
            if (this.phase == 3 && (sc == 40 || sc == 44)) { this.phase = 0; }
        }
    }

    void OnClick(int cx, int cy, int now) {
        if (this.scene == 0) {
            if (Draw.PointIn(cx, cy, 470, 610, 340, 74)) { this.EnterTable(now); }
            return;
        }
        int px = 1104;
        if (Draw.PointIn(cx, cy, px, 690, 156, 50)) { this.scene = 0; return; }
        if (this.phase == 0) {
            if (Draw.PointIn(cx, cy, px, 330, 70, 44)) { this.bet = this.bet - 25; if (this.bet < 25) { this.bet = 25; } }
            if (Draw.PointIn(cx, cy, px + 86, 330, 70, 44)) { this.bet = this.bet + 25; if (this.bet > this.prof.chips) { this.bet = this.prof.chips; } }
            if (Draw.PointIn(cx, cy, px, 384, 156, 44)) { this.bet = this.prof.chips; }
            if (Draw.PointIn(cx, cy, px, 452, 156, 64)) { this.Deal(now); }
        } else if (this.phase == 1) {
            if (Draw.PointIn(cx, cy, px, 330, 156, 52)) { this.PlayerHit(now); }
            if (Draw.PointIn(cx, cy, px, 392, 156, 52)) { this.Stand(now); }
            if (Draw.PointIn(cx, cy, px, 454, 156, 52)) { this.DoubleDown(now); }
        } else if (this.phase == 3) {
            if (Draw.PointIn(cx, cy, px, 452, 156, 64)) { this.phase = 0; }
        }
    }

    void Tick(int now) {
        if (this.phase == 2 && now >= this.dealerAt) { this.DealerStep(now); }
        if (this.demo) {
            if (this.scene == 1 && this.phase == 0 && now >= this.demoAt) {
                this.bet = 50; this.Deal(now); this.demoAt = now + 1200;
            } else if (this.scene == 1 && this.phase == 1 && now >= this.demoAt) {
                int pv = BjGame.HandValue(this.player, this.playerN);
                if (pv < 17) { this.PlayerHit(now); } else { this.Stand(now); }
                this.demoAt = now + 900;
            } else if (this.scene == 1 && this.phase == 3 && now >= this.demoAt) {
                if (this.prof.chips < 25) { this.prof.chips = 500; }
                this.phase = 0; this.demoAt = now + 600;
            }
        }
    }

    void Render(int now) {
        if (this.scene == 0) { this.DrawMenu(now); }
        else { this.DrawTable(now); }
    }
}

class BjApp {
    static void Main() {
        Host h = Host.Create("Blackjack - Beat the Dealer", 1280, 800);
        BjGame g = BjGame.Create(h);
        while (h.Running()) {
            int now = Sdl.Ticks();
            bool clicked = false;
            int cx = g.mouseX;
            int cy = g.mouseY;
            while (SdlEvent.Poll()) {
                int ty = SdlEvent.Type();
                if (SdlEvent.IsQuit()) { h.Quit(); }
                if (ty == SdlEventType.KeyDown()) {
                    if (!SdlEvent.IsRepeat()) {
                        int sc = SdlEvent.Scancode();
                        if (sc == 68) { h.ToggleFullscreen(); }
                        else { g.OnKey(sc, now); }
                    }
                }
                if (ty == SdlEventType.MouseMotion()) { g.mouseX = h.MouseX(); g.mouseY = h.MouseY(); }
                if (ty == SdlEventType.MouseButtonDown()) {
                    if (SdlEvent.MouseButton() == SdlMouseButton.Left()) {
                        cx = h.MouseX(); cy = h.MouseY(); g.mouseX = cx; g.mouseY = cy; clicked = true;
                    }
                }
            }
            if (clicked) { g.OnClick(cx, cy, now); }
            g.Tick(now);
            g.Render(now);
            Sdl.Delay(12);
        }
        h.Close();
    }
}
