// International Chess — a complete product built on GameKit.
// Features: premium menu (generated backdrop + frosted panels + stroked
// buttons), 8x8 board with crisp vector pieces (no bitmap art), full rules
// (castling, en passant, promotion to queen), check / checkmate / stalemate,
// an alpha-beta + quiescence engine with material + piece-square evaluation,
// four difficulties with adaptive scaling, move hints, animated last-move and
// check highlights, dynamic commentary and a persistent rank / streak profile.
using System;
using System.IO;
using SDL3;
using GameKit;

namespace Chess;

// ---------------------------------------------------------------------------
// Persistent player profile (rank / streak / record / settings).
// ---------------------------------------------------------------------------
class Profile {
    int rank;
    int streak;
    int best;
    int wins;
    int losses;
    int draws;
    int games;
    int level;
    int adaptive;

    static string Path() { return "chess_save.txt"; }

    static int ParseInt(string s, int start) {
        int i = start;
        int sign = 1;
        if (i < s.Length && s[i] == 45) { sign = -1; i = i + 1; }
        int v = 0;
        bool any = false;
        while (i < s.Length) {
            int c = s[i] & 255;
            if (c >= 48 && c <= 57) { v = v * 10 + (c - 48); any = true; i = i + 1; }
            else { i = s.Length; }
        }
        if (!any) { return 0; }
        return v * sign;
    }

    static int ReadKey(List<string> lines, string key, int fallback) {
        int i = 0;
        while (i < lines.Count) {
            string ln = lines[i];
            int eq = -1;
            int j = 0;
            while (j < ln.Length) {
                if (ln[j] == 61) { eq = j; j = ln.Length; }
                j = j + 1;
            }
            if (eq > 0) {
                string k = ln.Substring(0, eq);
                if (k == key) { return Profile.ParseInt(ln, eq + 1); }
            }
            i = i + 1;
        }
        return fallback;
    }

    static Profile Load() {
        Profile p = new Profile();
        p.rank = 1000; p.streak = 0; p.best = 0;
        p.wins = 0; p.losses = 0; p.draws = 0; p.games = 0;
        p.level = 1; p.adaptive = 1;
        if (File.Exists(Profile.Path())) {
            List<string> lines = File.ReadAllLines(Profile.Path());
            p.rank = Profile.ReadKey(lines, "rank", 1000);
            p.streak = Profile.ReadKey(lines, "streak", 0);
            p.best = Profile.ReadKey(lines, "best", 0);
            p.wins = Profile.ReadKey(lines, "wins", 0);
            p.losses = Profile.ReadKey(lines, "losses", 0);
            p.draws = Profile.ReadKey(lines, "draws", 0);
            p.games = Profile.ReadKey(lines, "games", 0);
            p.level = Profile.ReadKey(lines, "level", 1);
            p.adaptive = Profile.ReadKey(lines, "adaptive", 1);
        }
        return p;
    }

    void Save() {
        string s = "";
        s = s + "rank=" + this.rank + "\n";
        s = s + "streak=" + this.streak + "\n";
        s = s + "best=" + this.best + "\n";
        s = s + "wins=" + this.wins + "\n";
        s = s + "losses=" + this.losses + "\n";
        s = s + "draws=" + this.draws + "\n";
        s = s + "games=" + this.games + "\n";
        s = s + "level=" + this.level + "\n";
        s = s + "adaptive=" + this.adaptive + "\n";
        File.WriteAllText(Profile.Path(), s);
    }

    string TierName() {
        int r = this.rank;
        if (r < 900) { return "BRONZE"; }
        if (r < 1100) { return "SILVER"; }
        if (r < 1300) { return "GOLD"; }
        if (r < 1500) { return "PLATINUM"; }
        if (r < 1750) { return "DIAMOND"; }
        return "MASTER";
    }
}

// ---------------------------------------------------------------------------
// Board position: 64 squares, index = r*8 + c (r 0..7 top->bottom = rank 8..1,
// c 0..7 = file a..h). Value 0 empty; >0 white (human, bottom); <0 black (AI,
// top). Magnitude 1..6 = king, queen, rook, bishop, knight, pawn.
// ---------------------------------------------------------------------------
class Pos {
    int[] sq;
    int side;   // side to move: 1 white, -1 black
    int cwk;    // castling rights
    int cwq;
    int cbk;
    int cbq;
    int ep;     // en-passant target square index, or -1

    static Pos Start() {
        Pos p = new Pos();
        p.sq = new int[64];
        int i = 0;
        while (i < 64) { p.sq[i] = 0; i = i + 1; }
        // black back rank (row 0): R N B Q K B N R
        p.sq[0] = -3; p.sq[1] = -5; p.sq[2] = -4; p.sq[3] = -2;
        p.sq[4] = -1; p.sq[5] = -4; p.sq[6] = -5; p.sq[7] = -3;
        int c = 0;
        while (c < 8) { p.sq[8 + c] = -6; p.sq[48 + c] = 6; c = c + 1; }
        // white back rank (row 7)
        p.sq[56] = 3; p.sq[57] = 5; p.sq[58] = 4; p.sq[59] = 2;
        p.sq[60] = 1; p.sq[61] = 4; p.sq[62] = 5; p.sq[63] = 3;
        p.side = 1;
        p.cwk = 1; p.cwq = 1; p.cbk = 1; p.cbq = 1;
        p.ep = -1;
        return p;
    }

    Pos Clone() {
        Pos p = new Pos();
        p.sq = new int[64];
        int i = 0;
        while (i < 64) { p.sq[i] = this.sq[i]; i = i + 1; }
        p.side = this.side;
        p.cwk = this.cwk; p.cwq = this.cwq; p.cbk = this.cbk; p.cbq = this.cbq;
        p.ep = this.ep;
        return p;
    }
}

// A reusable integer buffer (used for per-ply move/score stacks; Zan has no
// jagged array literals so we wrap the inner array in an object).
class Buf {
    int[] m;
}

// Undo record for make/unmake (preallocated per search ply).
class Undo {
    int mv;
    int movedOrig;
    int cap;
    int capSq;
    int ep;
    int cwk;
    int cwq;
    int cbk;
    int cbq;
    int side;
}

// ---------------------------------------------------------------------------
// Rules + engine.
// ---------------------------------------------------------------------------
class Ch {
    static bool tablesReady;
    static int[] pstK;
    static int[] pstP;
    static int[] pstN;
    static int[] pstB;
    static int[] pstR;
    static int[] pstQ;
    static Buf[] moveStack;
    static Buf[] scoreStack;
    static Undo[] undoStack;
    static int[] knc;
    static int[] knr;
    static int nodes;
    static int nodeLimit;

    static int Abs(int v) { if (v < 0) { return -v; } return v; }
    static int Type(int v) { return Ch.Abs(v); }
    static int Side(int v) { if (v > 0) { return 1; } if (v < 0) { return -1; } return 0; }
    static int Sign(int v) { if (v < 0) { return -1; } return 1; }

    static int Val(int t) {
        if (t == 6) { return 100; }
        if (t == 5) { return 320; }
        if (t == 4) { return 330; }
        if (t == 3) { return 500; }
        if (t == 2) { return 900; }
        return 0;
    }

    // Move packing: frm(6) | to(6)<<6 | flag(4)<<12.
    // flag: 0 quiet/capture, 1 double push, 2 en-passant, 3 O-O, 4 O-O-O, 5 promo(Q)
    static int Mk(int frm, int to, int flag) { return frm | (to << 6) | (flag << 12); }
    static int Frm(int mv) { return mv & 63; }
    static int To(int mv) { return (mv >> 6) & 63; }
    static int Flag(int mv) { return (mv >> 12) & 15; }

    static void EnsureTables() {
        if (Ch.tablesReady) { return; }
        Ch.tablesReady = true;
        Ch.pstP = Ch.Tbl(
            0,0,0,0,0,0,0,0,
            5,10,10,-20,-20,10,10,5,
            5,-5,-10,0,0,-10,-5,5,
            0,0,0,20,20,0,0,0,
            5,5,10,25,25,10,5,5,
            10,10,20,30,30,20,10,10,
            50,50,50,50,50,50,50,50,
            0,0,0,0,0,0,0,0);
        Ch.pstN = Ch.Tbl(
            -50,-40,-30,-30,-30,-30,-40,-50,
            -40,-20,0,5,5,0,-20,-40,
            -30,5,10,15,15,10,5,-30,
            -30,0,15,20,20,15,0,-30,
            -30,5,15,20,20,15,5,-30,
            -30,0,10,15,15,10,0,-30,
            -40,-20,0,0,0,0,-20,-40,
            -50,-40,-30,-30,-30,-30,-40,-50);
        Ch.pstB = Ch.Tbl(
            -20,-10,-10,-10,-10,-10,-10,-20,
            -10,5,0,0,0,0,5,-10,
            -10,10,10,10,10,10,10,-10,
            -10,0,10,10,10,10,0,-10,
            -10,5,5,10,10,5,5,-10,
            -10,0,5,10,10,5,0,-10,
            -10,0,0,0,0,0,0,-10,
            -20,-10,-10,-10,-10,-10,-10,-20);
        Ch.pstR = Ch.Tbl(
            0,0,5,5,5,5,0,0,
            -5,0,0,0,0,0,0,-5,
            -5,0,0,0,0,0,0,-5,
            -5,0,0,0,0,0,0,-5,
            -5,0,0,0,0,0,0,-5,
            -5,0,0,0,0,0,0,-5,
            5,10,10,10,10,10,10,5,
            0,0,0,0,0,0,0,0);
        Ch.pstQ = Ch.Tbl(
            -20,-10,-10,-5,-5,-10,-10,-20,
            -10,0,5,0,0,0,0,-10,
            -10,5,5,5,5,5,0,-10,
            0,0,5,5,5,5,0,-5,
            -5,0,5,5,5,5,0,-5,
            -10,0,5,5,5,5,0,-10,
            -10,0,0,0,0,0,0,-10,
            -20,-10,-10,-5,-5,-10,-10,-20);
        Ch.pstK = Ch.Tbl(
            20,30,10,0,0,10,30,20,
            20,20,0,0,0,0,20,20,
            -10,-20,-20,-20,-20,-20,-20,-10,
            -20,-30,-30,-40,-40,-30,-30,-20,
            -30,-40,-40,-50,-50,-40,-40,-30,
            -30,-40,-40,-50,-50,-40,-40,-30,
            -30,-40,-40,-50,-50,-40,-40,-30,
            -30,-40,-40,-50,-50,-40,-40,-30);
        Ch.knc = new int[8];
        Ch.knc[0]=1; Ch.knc[1]=2; Ch.knc[2]=2; Ch.knc[3]=1;
        Ch.knc[4]=-1; Ch.knc[5]=-2; Ch.knc[6]=-2; Ch.knc[7]=-1;
        Ch.knr = new int[8];
        Ch.knr[0]=-2; Ch.knr[1]=-1; Ch.knr[2]=1; Ch.knr[3]=2;
        Ch.knr[4]=2; Ch.knr[5]=1; Ch.knr[6]=-1; Ch.knr[7]=-2;
        Ch.moveStack = new Buf[48];
        Ch.scoreStack = new Buf[48];
        Ch.undoStack = new Undo[48];
        int i = 0;
        while (i < 48) {
            Buf mb = new Buf(); mb.m = new int[256]; Ch.moveStack[i] = mb;
            Buf sb = new Buf(); sb.m = new int[256]; Ch.scoreStack[i] = sb;
            Ch.undoStack[i] = new Undo();
            i = i + 1;
        }
    }

    static int[] Tbl(int a0,int a1,int a2,int a3,int a4,int a5,int a6,int a7,
        int b0,int b1,int b2,int b3,int b4,int b5,int b6,int b7,
        int c0,int c1,int c2,int c3,int c4,int c5,int c6,int c7,
        int d0,int d1,int d2,int d3,int d4,int d5,int d6,int d7,
        int e0,int e1,int e2,int e3,int e4,int e5,int e6,int e7,
        int f0,int f1,int f2,int f3,int f4,int f5,int f6,int f7,
        int g0,int g1,int g2,int g3,int g4,int g5,int g6,int g7,
        int h0,int h1,int h2,int h3,int h4,int h5,int h6,int h7) {
        int[] t = new int[64];
        t[0]=a0;t[1]=a1;t[2]=a2;t[3]=a3;t[4]=a4;t[5]=a5;t[6]=a6;t[7]=a7;
        t[8]=b0;t[9]=b1;t[10]=b2;t[11]=b3;t[12]=b4;t[13]=b5;t[14]=b6;t[15]=b7;
        t[16]=c0;t[17]=c1;t[18]=c2;t[19]=c3;t[20]=c4;t[21]=c5;t[22]=c6;t[23]=c7;
        t[24]=d0;t[25]=d1;t[26]=d2;t[27]=d3;t[28]=d4;t[29]=d5;t[30]=d6;t[31]=d7;
        t[32]=e0;t[33]=e1;t[34]=e2;t[35]=e3;t[36]=e4;t[37]=e5;t[38]=e6;t[39]=e7;
        t[40]=f0;t[41]=f1;t[42]=f2;t[43]=f3;t[44]=f4;t[45]=f5;t[46]=f6;t[47]=f7;
        t[48]=g0;t[49]=g1;t[50]=g2;t[51]=g3;t[52]=g4;t[53]=g5;t[54]=g6;t[55]=g7;
        t[56]=h0;t[57]=h1;t[58]=h2;t[59]=h3;t[60]=h4;t[61]=h5;t[62]=h6;t[63]=h7;
        return t;
    }

    static int Pst(int type, int i, int side) {
        int r = i / 8; int c = i % 8;
        int rr = r;
        if (side > 0) { rr = 7 - r; }
        int idx = rr * 8 + c;
        if (type == 6) { return Ch.pstP[idx]; }
        if (type == 5) { return Ch.pstN[idx]; }
        if (type == 4) { return Ch.pstB[idx]; }
        if (type == 3) { return Ch.pstR[idx]; }
        if (type == 2) { return Ch.pstQ[idx]; }
        return Ch.pstK[idx];
    }

    static int KingIdx(int[] b, int side) {
        int i = 0;
        while (i < 64) {
            if (b[i] != 0 && Ch.Type(b[i]) == 1 && Ch.Side(b[i]) == side) { return i; }
            i = i + 1;
        }
        return -1;
    }

    static bool OnB(int c, int r) { return c >= 0 && c < 8 && r >= 0 && r < 8; }

    // Is square `i` attacked by pieces of `by`?
    static bool Attacked(int[] b, int i, int by) {
        int c = i % 8; int r = i / 8;
        // pawns: a `by` pawn attacks diagonally forward. White moves up (r-),
        // so a white pawn on (c±1, r+1) attacks (c,r). Black opposite.
        int pr = r + by;   // row where an attacking `by` pawn would stand
        if (pr >= 0 && pr < 8) {
            if (c - 1 >= 0) { if (b[pr * 8 + c - 1] == 6 * by) { return true; } }
            if (c + 1 < 8) { if (b[pr * 8 + c + 1] == 6 * by) { return true; } }
        }
        // knights
        int[] kc = Ch.KN_C(); int[] kr = Ch.KN_R();
        int k = 0;
        while (k < 8) {
            int nc = c + kc[k]; int nr = r + kr[k];
            if (Ch.OnB(nc, nr)) { if (b[nr * 8 + nc] == 5 * by) { return true; } }
            k = k + 1;
        }
        // king
        int dc = -1;
        while (dc <= 1) {
            int dr = -1;
            while (dr <= 1) {
                if (dc != 0 || dr != 0) {
                    int nc = c + dc; int nr = r + dr;
                    if (Ch.OnB(nc, nr)) { if (b[nr * 8 + nc] == 1 * by) { return true; } }
                }
                dr = dr + 1;
            }
            dc = dc + 1;
        }
        // rook/queen (orthogonal rays)
        if (Ch.RayHit(b, c, r, 1, 0, by, 3)) { return true; }
        if (Ch.RayHit(b, c, r, -1, 0, by, 3)) { return true; }
        if (Ch.RayHit(b, c, r, 0, 1, by, 3)) { return true; }
        if (Ch.RayHit(b, c, r, 0, -1, by, 3)) { return true; }
        // bishop/queen (diagonal rays)
        if (Ch.RayHit(b, c, r, 1, 1, by, 4)) { return true; }
        if (Ch.RayHit(b, c, r, 1, -1, by, 4)) { return true; }
        if (Ch.RayHit(b, c, r, -1, 1, by, 4)) { return true; }
        if (Ch.RayHit(b, c, r, -1, -1, by, 4)) { return true; }
        return false;
    }

    // Cast a ray; return true if the first piece met is `by`-side of `straight`
    // type (rook when straight==3) or the sibling queen.
    static bool RayHit(int[] b, int c, int r, int dc, int dr, int by, int straight) {
        int nc = c + dc; int nr = r + dr;
        while (Ch.OnB(nc, nr)) {
            int v = b[nr * 8 + nc];
            if (v != 0) {
                if (Ch.Side(v) == by) {
                    int t = Ch.Type(v);
                    if (t == 2) { return true; }
                    if (t == straight) { return true; }
                }
                return false;
            }
            nc = nc + dc; nr = nr + dr;
        }
        return false;
    }

    static int[] KN_C() { return Ch.knc; }
    static int[] KN_R() { return Ch.knr; }

    static bool InCheck(Pos p, int side) {
        int ki = Ch.KingIdx(p.sq, side);
        if (ki < 0) { return false; }
        return Ch.Attacked(p.sq, ki, -side);
    }

    // Pseudo-legal move generation into ml; returns count.
    static int Gen(Pos p, int side, int[] ml, bool capturesOnly) {
        int[] b = p.sq;
        int cnt = 0;
        int i = 0;
        while (i < 64) {
            int v = b[i];
            if (v != 0 && Ch.Side(v) == side) {
                int t = Ch.Type(v);
                int c = i % 8; int r = i / 8;
                if (t == 6) { cnt = Ch.GenPawn(p, side, c, r, ml, cnt, capturesOnly); }
                else if (t == 5) { cnt = Ch.GenStep(b, side, c, r, ml, cnt, Ch.KN_C(), Ch.KN_R(), capturesOnly); }
                else if (t == 1) { cnt = Ch.GenKing(p, side, c, r, ml, cnt, capturesOnly); }
                else if (t == 3) { cnt = Ch.GenRay(b, side, c, r, ml, cnt, true, false, capturesOnly); }
                else if (t == 4) { cnt = Ch.GenRay(b, side, c, r, ml, cnt, false, true, capturesOnly); }
                else if (t == 2) { cnt = Ch.GenRay(b, side, c, r, ml, cnt, true, true, capturesOnly); }
            }
            i = i + 1;
        }
        return cnt;
    }

    static int GenPawn(Pos p, int side, int c, int r, int[] ml, int cnt, bool capsOnly) {
        int[] b = p.sq;
        int frm = r * 8 + c;
        int dir = -side;               // white(side1) moves up (row -1)
        int startRow = 6; int promoRow = 0;
        if (side < 0) { startRow = 1; promoRow = 7; }
        int nr = r + dir;
        if (Ch.OnB(c, nr)) {
            if (!capsOnly && b[nr * 8 + c] == 0) {
                if (nr == promoRow) { ml[cnt] = Ch.Mk(frm, nr * 8 + c, 5); cnt = cnt + 1; }
                else {
                    ml[cnt] = Ch.Mk(frm, nr * 8 + c, 0); cnt = cnt + 1;
                    if (r == startRow) {
                        int nr2 = r + dir * 2;
                        if (b[nr2 * 8 + c] == 0) { ml[cnt] = Ch.Mk(frm, nr2 * 8 + c, 1); cnt = cnt + 1; }
                    }
                }
            }
            // captures
            int dcx = -1;
            while (dcx <= 1) {
                if (dcx != 0) {
                    int cc = c + dcx;
                    if (cc >= 0 && cc < 8) {
                        int to = nr * 8 + cc;
                        int dst = b[to];
                        if (dst != 0 && Ch.Side(dst) == -side) {
                            if (nr == promoRow) { ml[cnt] = Ch.Mk(frm, to, 5); cnt = cnt + 1; }
                            else { ml[cnt] = Ch.Mk(frm, to, 0); cnt = cnt + 1; }
                        } else if (to == p.ep && p.ep >= 0) {
                            ml[cnt] = Ch.Mk(frm, to, 2); cnt = cnt + 1;
                        }
                    }
                }
                dcx = dcx + 1;
            }
        }
        return cnt;
    }

    static int GenStep(int[] b, int side, int c, int r, int[] ml, int cnt,
                       int[] dcs, int[] drs, bool capsOnly) {
        int frm = r * 8 + c;
        int k = 0;
        while (k < 8) {
            int nc = c + dcs[k]; int nr = r + drs[k];
            if (Ch.OnB(nc, nr)) {
                int to = nr * 8 + nc; int dst = b[to];
                if (dst == 0) { if (!capsOnly) { ml[cnt] = Ch.Mk(frm, to, 0); cnt = cnt + 1; } }
                else if (Ch.Side(dst) == -side) { ml[cnt] = Ch.Mk(frm, to, 0); cnt = cnt + 1; }
            }
            k = k + 1;
        }
        return cnt;
    }

    static int GenKing(Pos p, int side, int c, int r, int[] ml, int cnt, bool capsOnly) {
        int[] b = p.sq;
        int frm = r * 8 + c;
        int dc = -1;
        while (dc <= 1) {
            int dr = -1;
            while (dr <= 1) {
                if (dc != 0 || dr != 0) {
                    int nc = c + dc; int nr = r + dr;
                    if (Ch.OnB(nc, nr)) {
                        int to = nr * 8 + nc; int dst = b[to];
                        if (dst == 0) { if (!capsOnly) { ml[cnt] = Ch.Mk(frm, to, 0); cnt = cnt + 1; } }
                        else if (Ch.Side(dst) == -side) { ml[cnt] = Ch.Mk(frm, to, 0); cnt = cnt + 1; }
                    }
                }
                dr = dr + 1;
            }
            dc = dc + 1;
        }
        if (!capsOnly) {
            int home = 60; int kr = 1; int qr = 1;
            if (side < 0) { home = 4; }
            if (frm == home) {
                if (side > 0) { kr = p.cwk; qr = p.cwq; } else { kr = p.cbk; qr = p.cbq; }
                if (!Ch.Attacked(b, home, -side)) {
                    if (kr == 1 && b[home + 1] == 0 && b[home + 2] == 0
                        && !Ch.Attacked(b, home + 1, -side) && !Ch.Attacked(b, home + 2, -side)) {
                        ml[cnt] = Ch.Mk(frm, home + 2, 3); cnt = cnt + 1;
                    }
                    if (qr == 1 && b[home - 1] == 0 && b[home - 2] == 0 && b[home - 3] == 0
                        && !Ch.Attacked(b, home - 1, -side) && !Ch.Attacked(b, home - 2, -side)) {
                        ml[cnt] = Ch.Mk(frm, home - 2, 4); cnt = cnt + 1;
                    }
                }
            }
        }
        return cnt;
    }

    static int GenRay(int[] b, int side, int c, int r, int[] ml, int cnt,
                      bool orth, bool diag, bool capsOnly) {
        int frm = r * 8 + c;
        if (orth) {
            cnt = Ch.Ray(b, side, frm, c, r, 1, 0, ml, cnt, capsOnly);
            cnt = Ch.Ray(b, side, frm, c, r, -1, 0, ml, cnt, capsOnly);
            cnt = Ch.Ray(b, side, frm, c, r, 0, 1, ml, cnt, capsOnly);
            cnt = Ch.Ray(b, side, frm, c, r, 0, -1, ml, cnt, capsOnly);
        }
        if (diag) {
            cnt = Ch.Ray(b, side, frm, c, r, 1, 1, ml, cnt, capsOnly);
            cnt = Ch.Ray(b, side, frm, c, r, 1, -1, ml, cnt, capsOnly);
            cnt = Ch.Ray(b, side, frm, c, r, -1, 1, ml, cnt, capsOnly);
            cnt = Ch.Ray(b, side, frm, c, r, -1, -1, ml, cnt, capsOnly);
        }
        return cnt;
    }

    static int Ray(int[] b, int side, int frm, int c, int r, int dc, int dr,
                   int[] ml, int cnt, bool capsOnly) {
        int nc = c + dc; int nr = r + dr;
        while (Ch.OnB(nc, nr)) {
            int to = nr * 8 + nc; int dst = b[to];
            if (dst == 0) { if (!capsOnly) { ml[cnt] = Ch.Mk(frm, to, 0); cnt = cnt + 1; } }
            else {
                if (Ch.Side(dst) == -side) { ml[cnt] = Ch.Mk(frm, to, 0); cnt = cnt + 1; }
                return cnt;
            }
            nc = nc + dc; nr = nr + dr;
        }
        return cnt;
    }

    static void Make(Pos p, int mv, Undo u) {
        int[] b = p.sq;
        int frm = Ch.Frm(mv); int to = Ch.To(mv); int flag = Ch.Flag(mv);
        int moved = b[frm];
        int side = Ch.Side(moved);
        u.mv = mv; u.movedOrig = moved; u.cap = 0; u.capSq = -1;
        u.ep = p.ep; u.cwk = p.cwk; u.cwq = p.cwq; u.cbk = p.cbk; u.cbq = p.cbq;
        u.side = p.side;
        if (flag == 2) {
            int capSq = frm - (frm % 8) + (to % 8);   // same row as frm, file of to
            u.cap = b[capSq]; u.capSq = capSq; b[capSq] = 0;
        } else if (b[to] != 0) {
            u.cap = b[to]; u.capSq = to;
        }
        b[to] = moved; b[frm] = 0;
        if (flag == 5) { b[to] = 2 * side; }
        if (flag == 3) {
            int row = frm - (frm % 8);
            b[row + 5] = b[row + 7]; b[row + 7] = 0;
        } else if (flag == 4) {
            int row = frm - (frm % 8);
            b[row + 3] = b[row + 0]; b[row + 0] = 0;
        }
        // en-passant target
        if (flag == 1) { p.ep = (frm + to) / 2; } else { p.ep = -1; }
        // castling rights
        int mt = Ch.Type(moved);
        if (mt == 1) {
            if (side > 0) { p.cwk = 0; p.cwq = 0; } else { p.cbk = 0; p.cbq = 0; }
        }
        if (frm == 63 || to == 63) { p.cwk = 0; }
        if (frm == 56 || to == 56) { p.cwq = 0; }
        if (frm == 7 || to == 7) { p.cbk = 0; }
        if (frm == 0 || to == 0) { p.cbq = 0; }
        p.side = -p.side;
    }

    static void Unmake(Pos p, Undo u) {
        int[] b = p.sq;
        int mv = u.mv;
        int frm = Ch.Frm(mv); int to = Ch.To(mv); int flag = Ch.Flag(mv);
        b[frm] = u.movedOrig; b[to] = 0;
        if (flag == 3) {
            int row = frm - (frm % 8);
            b[row + 7] = b[row + 5]; b[row + 5] = 0;
        } else if (flag == 4) {
            int row = frm - (frm % 8);
            b[row + 0] = b[row + 3]; b[row + 3] = 0;
        }
        if (u.capSq >= 0) { b[u.capSq] = u.cap; }
        p.ep = u.ep; p.cwk = u.cwk; p.cwq = u.cwq; p.cbk = u.cbk; p.cbq = u.cbq;
        p.side = u.side;
    }

    // Filtered legal moves for `side` into ml; returns count.
    static int Legal(Pos p, int side, int[] ml) {
        Ch.EnsureTables();
        int[] pl = Ch.moveStack[46].m;
        int n = Ch.Gen(p, side, pl, false);
        Undo u = Ch.undoStack[46];
        int cnt = 0;
        int i = 0;
        while (i < n) {
            Ch.Make(p, pl[i], u);
            if (!Ch.InCheck(p, side)) { ml[cnt] = pl[i]; cnt = cnt + 1; }
            Ch.Unmake(p, u);
            i = i + 1;
        }
        return cnt;
    }

    static int Eval(Pos p) {
        int[] b = p.sq;
        int score = 0;
        int i = 0;
        while (i < 64) {
            int v = b[i];
            if (v != 0) {
                int t = Ch.Type(v); int s = Ch.Side(v);
                score = score + s * (Ch.Val(t) + Ch.Pst(t, i, s));
            }
            i = i + 1;
        }
        return p.side * score;
    }

    // Order moves in place (captures / promotions first) using MVV-LVA.
    static void Order(Pos p, int[] ml, int[] sc, int n) {
        int[] b = p.sq;
        int i = 0;
        while (i < n) {
            int mv = ml[i];
            int to = Ch.To(mv); int flag = Ch.Flag(mv);
            int s = 0;
            int dst = b[to];
            if (dst != 0) { s = 1000 + Ch.Val(Ch.Type(dst)) * 8 - Ch.Val(Ch.Type(b[Ch.Frm(mv)])); }
            if (flag == 5) { s = s + 900; }
            if (flag == 2) { s = 1000; }
            sc[i] = s;
            i = i + 1;
        }
        // insertion sort by score desc
        i = 1;
        while (i < n) {
            int mv = ml[i]; int s = sc[i];
            int j = i - 1;
            while (j >= 0 && sc[j] < s) {
                sc[j + 1] = sc[j]; ml[j + 1] = ml[j]; j = j - 1;
            }
            ml[j + 1] = mv; sc[j + 1] = s;
            i = i + 1;
        }
    }

    static int Quiesce(Pos p, int alpha, int beta, int ply) {
        Ch.nodes = Ch.nodes + 1;
        int stand = Ch.Eval(p);
        if (stand >= beta) { return beta; }
        if (stand > alpha) { alpha = stand; }
        if (ply >= 44) { return alpha; }
        if (Ch.nodes > Ch.nodeLimit) { return alpha; }
        int[] ml = Ch.moveStack[ply].m;
        int[] sc = Ch.scoreStack[ply].m;
        int n = Ch.Gen(p, p.side, ml, true);
        Ch.Order(p, ml, sc, n);
        Undo u = Ch.undoStack[ply];
        int i = 0;
        while (i < n) {
            int mv = ml[i];
            Ch.Make(p, mv, u);
            if (Ch.InCheck(p, u.side)) { Ch.Unmake(p, u); i = i + 1; }
            else {
                int score = -Ch.Quiesce(p, -beta, -alpha, ply + 1);
                Ch.Unmake(p, u);
                if (score >= beta) { return beta; }
                if (score > alpha) { alpha = score; }
                i = i + 1;
            }
        }
        return alpha;
    }

    static int Negamax(Pos p, int depth, int alpha, int beta, int ply) {
        if (depth <= 0) { return Ch.Quiesce(p, alpha, beta, ply); }
        Ch.nodes = Ch.nodes + 1;
        if (Ch.nodes > Ch.nodeLimit) { return Ch.Eval(p); }
        int[] ml = Ch.moveStack[ply].m;
        int[] sc = Ch.scoreStack[ply].m;
        int n = Ch.Gen(p, p.side, ml, false);
        Ch.Order(p, ml, sc, n);
        Undo u = Ch.undoStack[ply];
        int legal = 0;
        int best = -1000000;
        int i = 0;
        while (i < n) {
            int mv = ml[i];
            Ch.Make(p, mv, u);
            if (Ch.InCheck(p, u.side)) { Ch.Unmake(p, u); i = i + 1; }
            else {
                legal = legal + 1;
                int score = -Ch.Negamax(p, depth - 1, -beta, -alpha, ply + 1);
                Ch.Unmake(p, u);
                if (score > best) { best = score; }
                if (score > alpha) { alpha = score; }
                if (alpha >= beta) { return alpha; }
                i = i + 1;
            }
        }
        if (legal == 0) {
            if (Ch.InCheck(p, p.side)) { return -100000 + ply; }
            return 0;
        }
        return best;
    }

    // Choose a move for `side` at the given depth. `slack` allows weaker play by
    // randomly picking among near-best moves. Returns -1 if none (game over).
    static int Best(Pos p, int side, int depth, int slack, Rng rng) {
        Ch.EnsureTables();
        Ch.nodes = 0;
        Ch.nodeLimit = 600000;
        int[] root = new int[256];
        int n = Ch.Legal(p, side, root);
        if (n == 0) { return -1; }
        int[] vals = new int[256];
        Undo u = new Undo();
        int bestVal = -1000000;
        int i = 0;
        while (i < n) {
            Ch.Make(p, root[i], u);
            int score = -Ch.Negamax(p, depth - 1, -1000000, 1000000, 1);
            Ch.Unmake(p, u);
            vals[i] = score;
            if (score > bestVal) { bestVal = score; }
            i = i + 1;
        }
        // collect moves within slack of best
        int[] pick = new int[256];
        int pc = 0;
        i = 0;
        while (i < n) {
            if (vals[i] >= bestVal - slack) { pick[pc] = root[i]; pc = pc + 1; }
            i = i + 1;
        }
        if (pc <= 0) { return root[0]; }
        return pick[rng.Range(0, pc)];
    }
}

// ---------------------------------------------------------------------------
// The game: menu / play / game-over scenes on GameKit.
// ---------------------------------------------------------------------------
class ChessGame {
    Host host;
    SdlRenderer r;
    Profile prof;
    Rng rng;
    Talker talk;

    Pos pos;
    int scene;      // 0 menu, 1 play, 2 game over
    int turn;       // side to move (1 human white, -1 AI black)
    int winner;     // 1 human, -1 AI, 0 draw
    int result;     // 0 checkmate, 1 stalemate, 2 resign/other
    int sel;        // selected square or -1
    int lastFrm;
    int lastTo;
    int moveCount;
    bool aiPending;
    int aiMoveAt;
    int mouseX;
    int mouseY;
    int winAdj;
    int lossAdj;
    bool inCheck;
    int[] legal;    // legal moves for the human when a piece is selected
    int legalN;
    int[] allLegal; // all legal human moves (for game-over detection)
    SdlTexture menuBg;
    bool menuTried;

    static int BX() { return 60; }
    static int BY() { return 96; }
    static int CELL() { return 84; }

    int Depth() {
        if (this.prof.level == 0) { return 2; }
        if (this.prof.level == 1) { return 3; }
        return 4;
    }
    int Slack() {
        if (this.prof.level == 0) { return 90; }
        if (this.prof.level == 1) { return 30; }
        if (this.prof.level == 2) { return 8; }
        return 0;
    }
    string LevelName() {
        if (this.prof.level == 0) { return "EASY"; }
        if (this.prof.level == 1) { return "NORMAL"; }
        if (this.prof.level == 2) { return "HARD"; }
        return "EXPERT";
    }

    static ChessGame Create(Host h) {
        ChessGame g = new ChessGame();
        g.host = h;
        g.r = h.Renderer();
        g.prof = Profile.Load();
        g.rng = Rng.Seed((long)Sdl.Ticks() + 20260718);
        g.talk = Talker.Create(g.rng);
        g.pos = Pos.Start();
        g.scene = 0;
        g.turn = 1;
        g.sel = -1;
        g.lastFrm = -1;
        g.lastTo = -1;
        g.moveCount = 0;
        g.legal = new int[256];
        g.allLegal = new int[256];
        g.legalN = 0;
        g.SetupTalk();
        return g;
    }

    void SetupTalk() {
        this.talk.Add(0, "Solid developing move.");
        this.talk.Add(0, "Nice square for it.");
        this.talk.Add(0, "Good centralization.");
        this.talk.Add(0, "Clean and principled.");
        this.talk.Add(1, "Bold... maybe too bold.");
        this.talk.Add(1, "The engine smiles.");
        this.talk.Add(1, "Careful, that hangs.");
        this.talk.Add(1, "Interesting sacrifice?");
        this.talk.Add(2, "Your move.");
        this.talk.Add(2, "Take your time.");
        this.talk.Add(3, "Check!");
        this.talk.Add(3, "The king is hunted!");
        this.talk.Add(3, "Big capture!");
    }

    void StartGame(int now) {
        this.pos = Pos.Start();
        this.turn = 1;
        this.sel = -1;
        this.lastFrm = -1; this.lastTo = -1;
        this.moveCount = 0;
        this.winner = 0; this.result = 0;
        this.aiPending = false;
        this.inCheck = false;
        this.scene = 1;
        this.legalN = 0;
        this.talk.SayExact(2, "White to move. Good luck!", now, 2200);
    }

    // ---- rank bookkeeping ----------------------------------------------------
    void EndGame(int who, int res, int now) {
        this.winner = who;
        this.result = res;
        this.scene = 2;
        this.prof.games = this.prof.games + 1;
        int lv = this.prof.level;
        if (who == 1) {
            this.winAdj = 22 + lv * 8;
            this.prof.rank = this.prof.rank + this.winAdj;
            this.prof.wins = this.prof.wins + 1;
            this.prof.streak = this.prof.streak + 1;
            if (this.prof.streak > this.prof.best) { this.prof.best = this.prof.streak; }
        } else if (who == -1) {
            this.lossAdj = 18 - lv * 2;
            if (this.lossAdj < 6) { this.lossAdj = 6; }
            this.prof.rank = this.prof.rank - this.lossAdj;
            if (this.prof.rank < 100) { this.prof.rank = 100; }
            this.prof.losses = this.prof.losses + 1;
            this.prof.streak = 0;
        } else {
            this.prof.draws = this.prof.draws + 1;
            this.prof.streak = 0;
        }
        if (this.prof.adaptive == 1 && who != 0) {
            if (who == 1 && this.prof.streak >= 2 && this.prof.level < 3) {
                this.prof.level = this.prof.level + 1; this.prof.streak = 0;
            }
            if (who == -1 && this.prof.level > 0) { this.prof.level = this.prof.level - 1; }
        }
        this.prof.Save();
    }

    // Detect end state for the side to move; returns true if game ended.
    bool CheckEnd(int now) {
        int n = Ch.Legal(this.pos, this.pos.side, this.allLegal);
        this.inCheck = Ch.InCheck(this.pos, this.pos.side);
        if (n == 0) {
            if (this.inCheck) {
                // side to move is checkmated -> the other side wins
                if (this.pos.side == 1) { this.EndGame(-1, 0, now); }
                else { this.EndGame(1, 0, now); }
            } else {
                this.EndGame(0, 1, now);
            }
            return true;
        }
        if (this.moveCount >= 400) { this.EndGame(0, 1, now); return true; }
        return false;
    }

    void ApplyMove(int mv, int now) {
        Undo u = new Undo();
        int flag = Ch.Flag(mv);
        int to = Ch.To(mv);
        bool cap = this.pos.sq[to] != 0 || flag == 2;
        Ch.Make(this.pos, mv, u);
        this.lastFrm = Ch.Frm(mv); this.lastTo = to;
        this.moveCount = this.moveCount + 1;
        this.sel = -1; this.legalN = 0;
        this.turn = this.pos.side;
        if (Ch.InCheck(this.pos, this.pos.side)) { this.talk.Say(3, now, 1800); }
        else if (cap) { this.talk.SayExact(3, "Capture!", now, 1400); }
    }

    void DoHuman(int mv, int now) {
        this.ApplyMove(mv, now);
        if (this.CheckEnd(now)) { return; }
        this.aiPending = true;
        this.aiMoveAt = now + 350;
    }

    void DoAi(int now) {
        int mv = Ch.Best(this.pos, -1, this.Depth(), this.Slack(), this.rng);
        this.aiPending = false;
        if (mv < 0) { this.CheckEnd(now); return; }
        this.ApplyMove(mv, now);
        this.CheckEnd(now);
    }

    void Tick(int now) {
        if (this.scene == 1 && this.turn == -1 && this.aiPending && now >= this.aiMoveAt) {
            this.DoAi(now);
        }
    }

    // ---- input ---------------------------------------------------------------
    int CellAt(int mx, int my) {
        int bx = ChessGame.BX(); int by = ChessGame.BY(); int cell = ChessGame.CELL();
        if (mx < bx || my < by) { return -1; }
        int c = (mx - bx) / cell; int r = (my - by) / cell;
        if (c < 0 || c > 7 || r < 0 || r > 7) { return -1; }
        return r * 8 + c;
    }

    void SelectPiece(int idx) {
        this.sel = idx;
        // filter allLegal for this from-square
        int n = Ch.Legal(this.pos, 1, this.allLegal);
        this.legalN = 0;
        int i = 0;
        while (i < n) {
            if (Ch.Frm(this.allLegal[i]) == idx) {
                this.legal[this.legalN] = this.allLegal[i];
                this.legalN = this.legalN + 1;
            }
            i = i + 1;
        }
        if (this.legalN == 0) { this.sel = -1; }
    }

    int FindMove(int frm, int to) {
        int i = 0;
        while (i < this.legalN) {
            if (Ch.Frm(this.legal[i]) == frm && Ch.To(this.legal[i]) == to) { return this.legal[i]; }
            i = i + 1;
        }
        return -1;
    }

    void OnClick(int cx, int cy, int now) {
        if (this.scene == 0) {
            int i = 0;
            while (i < 4) {
                if (Draw.PointIn(cx, cy, 792 + i * 100, 300, 96, 54)) { this.prof.level = i; }
                i = i + 1;
            }
            if (Draw.PointIn(cx, cy, 792, 378, 240, 46)) { this.prof.adaptive = 1 - this.prof.adaptive; }
            if (Draw.PointIn(cx, cy, 792, 452, 400, 78)) { this.StartGame(now); }
            return;
        }
        if (this.scene == 2) {
            if (Draw.PointIn(cx, cy, 430, 470, 200, 62)) { this.StartGame(now); return; }
            if (Draw.PointIn(cx, cy, 660, 470, 200, 62)) { this.scene = 0; return; }
            return;
        }
        // play
        if (Draw.PointIn(cx, cy, 792, 640, 180, 50)) { this.StartGame(now); return; }
        if (Draw.PointIn(cx, cy, 992, 640, 180, 50)) { this.scene = 0; return; }
        if (Draw.PointIn(cx, cy, 792, 700, 180, 50)) { this.Hint(now); return; }
        if (this.turn != 1) { return; }
        int idx = this.CellAt(cx, cy);
        if (idx < 0) { return; }
        if (this.sel >= 0) {
            int mv = this.FindMove(this.sel, idx);
            if (mv >= 0) { this.DoHuman(mv, now); return; }
        }
        if (this.pos.sq[idx] != 0 && Ch.Side(this.pos.sq[idx]) == 1) { this.SelectPiece(idx); }
        else { this.sel = -1; this.legalN = 0; }
    }

    void Hint(int now) {
        if (this.turn != 1) { return; }
        int mv = Ch.Best(this.pos, 1, this.Depth(), 0, this.rng);
        if (mv >= 0) { this.SelectPiece(Ch.Frm(mv)); }
    }

    void OnKey(int scn, int now) {
        if (scn == 21) { if (this.scene == 1) { this.StartGame(now); } }   // R
        if (scn == 11) { this.Hint(now); }                                 // H
        if (scn == 41) { if (this.scene != 0) { this.scene = 0; } }        // ESC
        if (this.scene == 0) {
            if (scn == 30) { this.prof.level = 0; }
            if (scn == 31) { this.prof.level = 1; }
            if (scn == 32) { this.prof.level = 2; }
            if (scn == 33) { this.prof.level = 3; }
            if (scn == 40) { this.StartGame(now); }   // ENTER
        }
    }

    // ---- rendering -----------------------------------------------------------
    void EnsureMenuBg() {
        if (this.menuTried) { return; }
        this.menuTried = true;
        SdlTexture t = SdlTexture.LoadImage(this.r, "examples/game/chess/assets/menu_bg.png");
        if (t != null && t.IsValid()) { t.SetNearest(false); t.SetBlendMode(1); } else { t = null; }
        this.menuBg = t;
    }

    void Render(int now) {
        if (this.scene == 0) { this.DrawMenu(now); }
        else if (this.scene == 1) { this.DrawPlay(now); }
        else { this.DrawOver(now); }
    }

    void DrawMenu(int now) {
        this.EnsureMenuBg();
        this.host.Begin(16, 20, 28);
        Ui.Backdrop(this.r, this.menuBg, 1280, 800);

        Text.DrawCenteredShadow(this.r, "CHESS", 400, 150, 12, 245, 240, 226, 5);
        Text.DrawCenteredShadow(this.r, "INTERNATIONAL", 400, 300, 3, 232, 200, 132, 3);

        // preview board bottom-left already in art; keep left clear for title.
        Ui.Panel(this.r, 760, 250, 460, 500, 20, 24, 34, 214);

        Text.DrawShadow(this.r, "DIFFICULTY", 792, 268, 2, 190, 198, 214, 2);
        int i = 0;
        while (i < 4) {
            string nm = "EASY";
            if (i == 1) { nm = "NORMAL"; }
            if (i == 2) { nm = "HARD"; }
            if (i == 3) { nm = "EXPERT"; }
            int kind = 0;
            if (this.prof.level == i) { kind = 2; }
            Ui.Button(this.r, this.mouseX, this.mouseY, 792 + i * 100, 300, 96, 54, nm, 2, kind);
            i = i + 1;
        }

        string adv = "ADAPTIVE: OFF";
        if (this.prof.adaptive == 1) { adv = "ADAPTIVE: ON"; }
        int akind = 0;
        if (this.prof.adaptive == 1) { akind = 1; }
        Ui.Button(this.r, this.mouseX, this.mouseY, 792, 378, 240, 46, adv, 2, akind);
        Text.Draw(this.r, "AI scales to you", 1046, 392, 2, 150, 160, 178, 255);

        Ui.Button(this.r, this.mouseX, this.mouseY, 792, 452, 400, 78, "PLAY vs AI", 4, 1);

        Ui.Panel(this.r, 792, 556, 400, 150, 14, 18, 26, 200);
        Text.Draw(this.r, "RANK", 814, 574, 2, 150, 160, 180, 255);
        Text.DrawShadow(this.r, this.prof.TierName() + "  " + this.prof.rank, 814, 596, 4, 255, 210, 90, 2);
        Text.Draw(this.r, "STREAK  " + this.prof.streak + "   BEST  " + this.prof.best, 814, 648, 2, 160, 170, 190, 255);
        Text.Draw(this.r, this.prof.wins + "W  " + this.prof.losses + "L  " + this.prof.draws + "D   GAMES " + this.prof.games, 814, 676, 2, 160, 170, 190, 255);

        Text.DrawCenteredShadow(this.r, "You play White.   1-4 difficulty   ENTER play   F11 fullscreen", 640, 764, 2, 176, 184, 200, 2);
        this.host.End();
    }

    void DrawPlay(int now) {
        this.host.Begin(16, 20, 28);
        this.EnsureMenuBg();
        Ui.Backdrop(this.r, this.menuBg, 1280, 800);
        this.DrawBoard(now);
        this.DrawSidePanel(now);
        this.host.End();
    }

    void DrawOver(int now) {
        this.host.Begin(16, 20, 28);
        this.EnsureMenuBg();
        Ui.Backdrop(this.r, this.menuBg, 1280, 800);
        this.DrawBoard(now);
        this.DrawSidePanel(now);
        this.r.SetColor(0, 0, 0, 170);
        this.r.FillRect(0, 0, 1280, 800);
        string title = "DRAW";
        int cr = 240; int cg = 220; int cb = 120;
        if (this.winner == 1) { title = "CHECKMATE - YOU WIN!"; cr = 120; cg = 220; cb = 140; }
        else if (this.winner == -1) { title = "CHECKMATE - AI WINS"; cr = 235; cg = 120; cb = 92; }
        else { if (this.result == 1) { title = "STALEMATE - DRAW"; } }
        Text.DrawCenteredShadow(this.r, title, 640, 292, 6, cr, cg, cb, 3);
        if (this.winner == 1) { Text.DrawCenteredShadow(this.r, "RANK +" + this.winAdj, 640, 396, 3, 205, 214, 232, 2); }
        else if (this.winner == -1) { Text.DrawCenteredShadow(this.r, "RANK -" + this.lossAdj, 640, 396, 3, 205, 214, 232, 2); }
        Ui.Button(this.r, this.mouseX, this.mouseY, 430, 470, 200, 62, "REMATCH", 3, 1);
        Ui.Button(this.r, this.mouseX, this.mouseY, 660, 470, 200, 62, "MENU", 3, 0);
        this.host.End();
    }

    void DrawSidePanel(int now) {
        int px = 792;
        Ui.Panel(this.r, px - 16, 40, 468, 560, 18, 22, 32, 205);
        Text.DrawShadow(this.r, "CHESS", px, 58, 5, 245, 240, 226, 3);
        Text.Draw(this.r, "INTERNATIONAL", px, 110, 2, 150, 160, 180, 255);

        string status = "YOUR MOVE (WHITE)";
        int sr = 120; int sg = 205; int sb = 150;
        if (this.turn == -1) {
            int dots = (now / 300) % 4;
            status = "AI THINKING";
            int d = 0;
            while (d < dots) { status = status + "."; d = d + 1; }
            sr = 232; sg = 182; sb = 92;
        }
        if (this.inCheck && this.scene == 1) {
            if (this.turn == 1) { status = "CHECK! DEFEND"; sr = 235; sg = 120; sb = 100; }
        }
        Ui.Panel(this.r, px, 150, 420, 46, 12, 16, 24, 210);
        Text.DrawShadow(this.r, status, px + 16, 164, 2, sr, sg, sb, 2);

        Text.Draw(this.r, "DIFFICULTY  " + this.LevelName(), px, 220, 2, 184, 194, 214, 255);
        Text.Draw(this.r, "MOVE  " + (this.moveCount / 2 + 1), px, 246, 2, 184, 194, 214, 255);

        Ui.Panel(this.r, px, 288, 420, 128, 12, 16, 24, 200);
        Text.Draw(this.r, "RANK", px + 22, 306, 2, 150, 160, 180, 255);
        Text.DrawShadow(this.r, this.prof.TierName() + "  " + this.prof.rank, px + 22, 328, 3, 255, 210, 90, 2);
        Text.Draw(this.r, "STREAK  " + this.prof.streak + "   BEST  " + this.prof.best, px + 22, 372, 2, 150, 160, 180, 255);
        Text.Draw(this.r, this.prof.wins + "W  " + this.prof.losses + "L  " + this.prof.draws + "D", px + 260, 372, 2, 150, 160, 180, 255);

        this.DrawTalk(px, 440, 420, now);

        Ui.Button(this.r, this.mouseX, this.mouseY, px, 640, 180, 50, "RESTART (R)", 2, 0);
        Ui.Button(this.r, this.mouseX, this.mouseY, 992, 640, 180, 50, "MENU (ESC)", 2, 0);
        Ui.Button(this.r, this.mouseX, this.mouseY, px, 700, 180, 50, "HINT (H)", 2, 0);
    }

    void DrawTalk(int px, int py, int w, int now) {
        string msg = this.talk.Current(now);
        if (msg.Length == 0) { return; }
        int kind = this.talk.Kind();
        int cr = 120; int cg = 170; int cb = 230;
        if (kind == 0) { cr = 120; cg = 210; cb = 150; }
        if (kind == 1) { cr = 235; cg = 150; cb = 100; }
        if (kind == 3) { cr = 250; cg = 205; cb = 90; }
        Ui.Panel(this.r, px, py, w, 48, 16, 20, 28, 210);
        Draw.RoundRectStroke(this.r, px, py, w, 48, 12, 1, cr, cg, cb, 150);
        Text.Draw(this.r, msg, px + 16, py + 16, 2, cr, cg, cb, 255);
    }

    void DrawBoard(int now) {
        int bx = ChessGame.BX(); int by = ChessGame.BY(); int cell = ChessGame.CELL();
        int bw = cell * 8;
        // frame
        Draw.RoundRectFill(this.r, bx - 20, by - 20, bw + 40, bw + 40, 16, 32, 24, 18, 255);
        Draw.RoundRectStroke(this.r, bx - 20, by - 20, bw + 40, bw + 40, 16, 3, 92, 70, 44, 255);
        // squares
        int r0 = 0;
        while (r0 < 8) {
            int c0 = 0;
            while (c0 < 8) {
                int x = bx + c0 * cell; int y = by + r0 * cell;
                bool light = ((r0 + c0) % 2) == 0;
                if (light) { this.r.SetColor(238, 223, 194, 255); }
                else { this.r.SetColor(122, 92, 66, 255); }
                this.r.FillRect(x, y, cell, cell);
                c0 = c0 + 1;
            }
            r0 = r0 + 1;
        }
        // last move highlight
        if (this.lastFrm >= 0) {
            this.HiCell(this.lastFrm, 232, 210, 90, 90);
            this.HiCell(this.lastTo, 232, 210, 90, 120);
        }
        // check highlight on king in check
        if (this.inCheck) {
            int ki = Ch.KingIdx(this.pos.sq, this.pos.side);
            if (ki >= 0) { this.HiCell(ki, 230, 70, 60, 150); }
        }
        // selection + legal targets
        if (this.sel >= 0) {
            this.HiCell(this.sel, 120, 200, 250, 130);
            int i = 0;
            while (i < this.legalN) {
                int to = Ch.To(this.legal[i]);
                int tx = bx + (to % 8) * cell + cell / 2;
                int ty = by + (to / 8) * cell + cell / 2;
                if (this.pos.sq[to] != 0 || Ch.Flag(this.legal[i]) == 2) {
                    Draw.RoundRectStroke(this.r, bx + (to % 8) * cell + 4, by + (to / 8) * cell + 4, cell - 8, cell - 8, 8, 4, 90, 200, 250, 200);
                } else {
                    Draw.FillCircle(this.r, tx, ty, cell / 8, 90, 200, 250, 200);
                }
                i = i + 1;
            }
        }
        // coordinate labels
        int f = 0;
        while (f < 8) {
            string file = this.FileChar(f);
            Text.Draw(this.r, file, bx + f * cell + cell - 16, by + bw - 22, 1, 40, 30, 20, 200);
            string rk = "" + (8 - f);
            Text.Draw(this.r, rk, bx + 6, by + f * cell + 6, 1, 40, 30, 20, 200);
            f = f + 1;
        }
        // pieces
        int idx = 0;
        while (idx < 64) {
            int v = this.pos.sq[idx];
            if (v != 0) {
                int x = bx + (idx % 8) * cell + cell / 2;
                int y = by + (idx / 8) * cell + cell / 2;
                this.DrawPiece(Ch.Type(v), x, y, cell, v > 0);
            }
            idx = idx + 1;
        }
    }

    string FileChar(int f) {
        if (f == 0) { return "a"; }
        if (f == 1) { return "b"; }
        if (f == 2) { return "c"; }
        if (f == 3) { return "d"; }
        if (f == 4) { return "e"; }
        if (f == 5) { return "f"; }
        if (f == 6) { return "g"; }
        return "h";
    }

    void HiCell(int idx, int cr, int cg, int cb, int ca) {
        int bx = ChessGame.BX(); int by = ChessGame.BY(); int cell = ChessGame.CELL();
        this.r.SetColor(cr, cg, cb, ca);
        this.r.FillRect(bx + (idx % 8) * cell, by + (idx / 8) * cell, cell, cell);
    }

    // ---- vector pieces -------------------------------------------------------
    // Clean two-tone silhouettes with a dark edge and a soft highlight, so both
    // colors read on light and dark squares. `s` is the cell size.
    void DrawPiece(int type, int cx, int cy, int s, bool white) {
        int bodyR = 244; int bodyG = 242; int bodyB = 234;
        int shR = 206; int shG = 202; int shB = 190;
        int hiR = 255; int hiG = 255; int hiB = 255;
        if (!white) { bodyR = 66; bodyG = 70; bodyB = 80; shR = 44; shG = 47; shB = 55; hiR = 120; hiG = 126; hiB = 140; }
        int edR = 24; int edG = 26; int edB = 32;
        if (!white) { edR = 10; edG = 11; edB = 14; }

        int baseY = cy + s * 30 / 100;
        int hw = s * 30 / 100;
        // ground shadow
        Draw.FillEllipse(this.r, cx, baseY + s * 8 / 100, hw + s * 3 / 100, s * 7 / 100, 0, 0, 0, 55);
        // base (two stacked tiers) with edge
        this.Tier(cx, baseY, hw, s * 8 / 100, edR, edG, edB, bodyR, bodyG, bodyB);
        this.Tier(cx, baseY - s * 9 / 100, hw * 82 / 100, s * 6 / 100, edR, edG, edB, bodyR, bodyG, bodyB);

        if (type == 6) { this.PcPawn(cx, cy, s, bodyR, bodyG, bodyB, edR, edG, edB, hiR, hiG, hiB); }
        else if (type == 3) { this.PcRook(cx, cy, s, bodyR, bodyG, bodyB, edR, edG, edB, hiR, hiG, hiB); }
        else if (type == 5) { this.PcKnight(cx, cy, s, bodyR, bodyG, bodyB, edR, edG, edB, hiR, hiG, hiB); }
        else if (type == 4) { this.PcBishop(cx, cy, s, bodyR, bodyG, bodyB, edR, edG, edB, hiR, hiG, hiB); }
        else if (type == 2) { this.PcQueen(cx, cy, s, bodyR, bodyG, bodyB, edR, edG, edB, hiR, hiG, hiB); }
        else { this.PcKing(cx, cy, s, bodyR, bodyG, bodyB, edR, edG, edB, hiR, hiG, hiB); }
    }

    void Tier(int cx, int y, int hw, int h, int er, int eg, int eb, int br, int bg, int bb) {
        Draw.RoundRectFill(this.r, cx - hw - 2, y - h - 2, hw * 2 + 4, h * 2 + 4, h + 2, er, eg, eb, 255);
        Draw.RoundRectFill(this.r, cx - hw, y - h, hw * 2, h * 2, h, br, bg, bb, 255);
    }

    // body trapezoid helper (edge then fill), from top width tw to bottom width bw
    void Trap(int cx, int topY, int botY, int tw, int bw, int er, int eg, int eb, int br, int bg, int bb) {
        Draw.FillTriangle(this.r, cx - tw - 2, topY - 1, cx + tw + 2, topY - 1, cx - bw - 2, botY + 1, er, eg, eb, 255);
        Draw.FillTriangle(this.r, cx + tw + 2, topY - 1, cx - bw - 2, botY + 1, cx + bw + 2, botY + 1, er, eg, eb, 255);
        Draw.FillTriangle(this.r, cx - tw, topY, cx + tw, topY, cx - bw, botY, br, bg, bb, 255);
        Draw.FillTriangle(this.r, cx + tw, topY, cx - bw, botY, cx + bw, botY, br, bg, bb, 255);
    }

    void PcPawn(int cx, int cy, int s, int br, int bg, int bb, int er, int eg, int eb, int hr, int hg, int hb) {
        int headY = cy - s * 16 / 100; int headR = s * 12 / 100;
        this.Trap(cx, cy - s * 4 / 100, cy + s * 22 / 100, s * 8 / 100, s * 18 / 100, er, eg, eb, br, bg, bb);
        Draw.FillCircle(this.r, cx, headY, headR + 2, er, eg, eb, 255);
        Draw.FillCircle(this.r, cx, headY, headR, br, bg, bb, 255);
        Draw.FillCircle(this.r, cx - headR / 3, headY - headR / 3, headR / 3, hr, hg, hb, 90);
    }

    void PcRook(int cx, int cy, int s, int br, int bg, int bb, int er, int eg, int eb, int hr, int hg, int hb) {
        int topY = cy - s * 20 / 100;
        this.Trap(cx, cy - s * 10 / 100, cy + s * 22 / 100, s * 15 / 100, s * 19 / 100, er, eg, eb, br, bg, bb);
        // crown block
        Draw.RoundRectFill(this.r, cx - s * 20 / 100 - 2, topY - 2, s * 40 / 100 + 4, s * 14 / 100 + 4, 4, er, eg, eb, 255);
        Draw.RoundRectFill(this.r, cx - s * 20 / 100, topY, s * 40 / 100, s * 14 / 100, 3, br, bg, bb, 255);
        // merlons (notches drawn as edge-colored gaps on top)
        int i = 0;
        while (i < 2) {
            int gx = cx - s * 8 / 100 + i * s * 12 / 100;
            this.r.SetColor(er, eg, eb, 255);
            this.r.FillRect(gx, topY - 2, s * 5 / 100, s * 7 / 100);
            i = i + 1;
        }
    }

    void PcKnight(int cx, int cy, int s, int br, int bg, int bb, int er, int eg, int eb, int hr, int hg, int hb) {
        // neck/base column
        this.Trap(cx, cy - s * 6 / 100, cy + s * 22 / 100, s * 12 / 100, s * 18 / 100, er, eg, eb, br, bg, bb);
        // horse head: edge pass then body pass using a small polygon of triangles
        int topY = cy - s * 30 / 100;
        // edge (slightly larger)
        this.KnightHead(cx, cy, s, 2, er, eg, eb);
        this.KnightHead(cx, cy, s, 0, br, bg, bb);
        // eye
        Draw.FillCircle(this.r, cx + s * 6 / 100, topY + s * 10 / 100, s * 2 / 100 + 1, er, eg, eb, 255);
    }

    void KnightHead(int cx, int cy, int s, int o, int cr, int cg, int cb) {
        int topY = cy - s * 32 / 100;
        // skull
        Draw.FillEllipse(this.r, cx + s * 2 / 100, topY + s * 10 / 100, s * 13 / 100 + o, s * 12 / 100 + o, cr, cg, cb, 255);
        // muzzle triangle pointing left
        Draw.FillTriangle(this.r,
            cx - s * 18 / 100 - o, topY + s * 16 / 100,
            cx + s * 6 / 100, topY + s * 2 / 100 - o,
            cx + s * 8 / 100, topY + s * 20 / 100 + o,
            cr, cg, cb, 255);
        // jaw block down to neck
        Draw.RoundRectFill(this.r, cx - s * 10 / 100 - o, topY + s * 14 / 100, s * 22 / 100 + o * 2, s * 16 / 100, 4, cr, cg, cb, 255);
        // ear
        Draw.FillTriangle(this.r,
            cx + s * 6 / 100, topY - s * 4 / 100 - o,
            cx + s * 12 / 100 + o, topY + s * 6 / 100,
            cx, topY + s * 4 / 100,
            cr, cg, cb, 255);
    }

    void PcBishop(int cx, int cy, int s, int br, int bg, int bb, int er, int eg, int eb, int hr, int hg, int hb) {
        this.Trap(cx, cy - s * 2 / 100, cy + s * 22 / 100, s * 9 / 100, s * 17 / 100, er, eg, eb, br, bg, bb);
        // mitre
        int mY = cy - s * 12 / 100;
        Draw.FillEllipse(this.r, cx, mY, s * 12 / 100 + 2, s * 20 / 100 + 2, er, eg, eb, 255);
        Draw.FillEllipse(this.r, cx, mY, s * 12 / 100, s * 20 / 100, br, bg, bb, 255);
        // top ball
        Draw.FillCircle(this.r, cx, mY - s * 22 / 100, s * 4 / 100 + 2, er, eg, eb, 255);
        Draw.FillCircle(this.r, cx, mY - s * 22 / 100, s * 4 / 100, br, bg, bb, 255);
        // slit
        this.r.SetColor(er, eg, eb, 255);
        this.r.FillRect(cx - 1, mY - s * 14 / 100, s * 6 / 100, s * 3 / 100);
        Draw.FillCircle(this.r, cx - s * 4 / 100, mY - s * 6 / 100, s * 3 / 100, hr, hg, hb, 70);
    }

    void PcQueen(int cx, int cy, int s, int br, int bg, int bb, int er, int eg, int eb, int hr, int hg, int hb) {
        this.Trap(cx, cy - s * 8 / 100, cy + s * 22 / 100, s * 12 / 100, s * 20 / 100, er, eg, eb, br, bg, bb);
        int bandY = cy - s * 12 / 100;
        Draw.RoundRectFill(this.r, cx - s * 18 / 100 - 2, bandY - 2, s * 36 / 100 + 4, s * 8 / 100 + 4, 4, er, eg, eb, 255);
        Draw.RoundRectFill(this.r, cx - s * 18 / 100, bandY, s * 36 / 100, s * 8 / 100, 3, br, bg, bb, 255);
        // five pearls on spikes
        int i = 0;
        while (i < 5) {
            int gx = cx - s * 16 / 100 + i * s * 8 / 100;
            int gy = bandY - s * 12 / 100;
            if (i == 0 || i == 4) { gy = bandY - s * 8 / 100; }
            Draw.FillTriangle(this.r, gx - s * 3 / 100, bandY, gx + s * 3 / 100, bandY, gx, gy, er, eg, eb, 255);
            Draw.FillCircle(this.r, gx, gy, s * 4 / 100 + 1, er, eg, eb, 255);
            Draw.FillCircle(this.r, gx, gy, s * 4 / 100, br, bg, bb, 255);
            i = i + 1;
        }
    }

    void PcKing(int cx, int cy, int s, int br, int bg, int bb, int er, int eg, int eb, int hr, int hg, int hb) {
        this.Trap(cx, cy - s * 8 / 100, cy + s * 22 / 100, s * 12 / 100, s * 20 / 100, er, eg, eb, br, bg, bb);
        int bandY = cy - s * 12 / 100;
        Draw.RoundRectFill(this.r, cx - s * 18 / 100 - 2, bandY - 2, s * 36 / 100 + 4, s * 9 / 100 + 4, 4, er, eg, eb, 255);
        Draw.RoundRectFill(this.r, cx - s * 18 / 100, bandY, s * 36 / 100, s * 9 / 100, 3, br, bg, bb, 255);
        // crown cross
        int crossY = bandY - s * 20 / 100;
        this.r.SetColor(er, eg, eb, 255);
        this.r.FillRect(cx - s * 3 / 100 - 2, crossY - 2, s * 6 / 100 + 4, s * 24 / 100 + 4);
        this.r.FillRect(cx - s * 9 / 100 - 2, crossY + s * 4 / 100 - 2, s * 18 / 100 + 4, s * 6 / 100 + 4);
        this.r.SetColor(br, bg, bb, 255);
        this.r.FillRect(cx - s * 3 / 100, crossY, s * 6 / 100, s * 24 / 100);
        this.r.FillRect(cx - s * 9 / 100, crossY + s * 4 / 100, s * 18 / 100, s * 6 / 100);
    }
}

class ChessApp {
    static void Main() {
        Host h = Host.Create("Chess - International Chess", 1280, 800);
        ChessGame g = ChessGame.Create(h);
        while (h.Running()) {
            int now = Sdl.Ticks();
            bool clicked = false;
            int cx = g.mouseX; int cy = g.mouseY;
            while (SdlEvent.Poll()) {
                int ty = SdlEvent.Type();
                if (SdlEvent.IsQuit()) { h.Quit(); }
                if (ty == SdlEventType.KeyDown()) {
                    if (!SdlEvent.IsRepeat()) {
                        int scn = SdlEvent.Scancode();
                        if (scn == 68) { h.ToggleFullscreen(); }
                        else { g.OnKey(scn, now); }
                    }
                }
                if (ty == SdlEventType.MouseMotion()) {
                    g.mouseX = h.MouseX(); g.mouseY = h.MouseY();
                }
                if (ty == SdlEventType.MouseButtonDown()) {
                    if (SdlEvent.MouseButton() == SdlMouseButton.Left()) {
                        cx = h.MouseX(); cy = h.MouseY();
                        g.mouseX = cx; g.mouseY = cy;
                        clicked = true;
                    }
                }
            }
            if (clicked) { g.OnClick(cx, cy, now); }
            g.Tick(now);
            g.Render(now);
            Sdl.Delay(12);
        }
        h.Close();
    }
}
