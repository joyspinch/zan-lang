using System;
using System.IO;
using System.Json;
using System.Diagnostics;
using System.Net.Sockets;
using System.Threading;

/// Minimal MCP (Model Context Protocol) server for the Zan IDE project,
/// using the streamable-HTTP transport: external AI tools POST JSON-RPC
/// to http://127.0.0.1:8848/ (methods: initialize, tools/list, tools/call).
///
/// Run it from the project root (the IDE Tools pane runs tools there).
/// Exposed tools (all sandboxed to the current project root):
///   list_files(path)          - list a project directory
///   read_file(path)           - read a project file
///   write_file(path, content) - write a project file
///   build()                   - zanc build of src/main.zan (template layout)
///
/// SECURITY: binds to localhost only; every path is validated to stay
/// inside the project root (no absolute paths, no `..` traversal).
class McpServer {
    static string root;

    static void Main() {
        McpServer.root = ".";
        Console.WriteLine("Zan MCP server: project root = current directory");
        Console.WriteLine("MCP endpoint: http://127.0.0.1:8848/ (streamable HTTP JSON-RPC)");
        int r = await McpServer.Serve();
    }

    static async int Serve() {
        Socket.Initialize();
        int listener = Socket.CreateTcp();
        Socket.SetReuseAddr(listener);
        Socket.Bind(listener, "127.0.0.1", 8848);
        Socket.Listen(listener, 16);
        Socket.SetNonBlocking(listener);
        while (true) {
            int client = await AsyncSocket.Accept(listener);
            Socket.SetNonBlocking(client);
            Task.Spawn(McpServer.HandleConn(client));
        }
        return 0;
    }

    /// One request per connection ("Connection: close"): reads the request
    /// until Content-Length bytes of body have arrived, answers, closes.
    static async void HandleConn(int client) {
        string raw = "";
        int need = 0 - 1;
        int rounds = 0;
        while (rounds < 200) {
            string chunk = await AsyncSocket.Receive(client, 65536);
            if (chunk.Length == 0) { break; }
            raw = raw + chunk;
            int hdrEnd = McpServer.Find(raw, "\r\n\r\n");
            if (hdrEnd >= 0) {
                if (need < 0) { need = McpServer.ContentLength(raw); }
                if (raw.Length - hdrEnd - 4 >= need) { break; }
            }
            rounds = rounds + 1;
        }
        string body = "";
        int he = McpServer.Find(raw, "\r\n\r\n");
        if (he >= 0) { body = raw.Substring(he + 4, raw.Length - he - 4); }
        string method = "GET";
        if (raw.Length >= 4 && raw.Substring(0, 4) == "POST") { method = "POST"; }
        string respBody = McpServer.Handle(method, body);
        string resp = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\n"
            + "Content-Length: " + Convert.ToString(respBody.Length)
            + "\r\nConnection: close\r\n\r\n" + respBody;
        int _sent = await AsyncSocket.SendString(client, resp);
        Socket.Close(client);
    }

    /// First index of `pat` in `s`, or -1.
    static int Find(string s, string pat) {
        if (pat.Length == 0 || s.Length < pat.Length) { return 0 - 1; }
        int i = 0;
        while (i <= s.Length - pat.Length) {
            if (s.Substring(i, pat.Length) == pat) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    static int ContentLength(string raw) {
        int p = McpServer.Find(raw, "Content-Length:");
        if (p < 0) { p = McpServer.Find(raw, "content-length:"); }
        if (p < 0) { return 0; }
        int i = p + 15;
        while (i < raw.Length && raw.Substring(i, 1) == " ") { i = i + 1; }
        int n = 0;
        while (i < raw.Length) {
            string ch = raw.Substring(i, 1);
            if (ch < "0" || ch > "9") { break; }
            n = n * 10 + Convert.ToInt32(ch);
            i = i + 1;
        }
        return n;
    }

    static string Handle(string method, string body) {
        if (method != "POST") {
            return "{\"error\": \"POST JSON-RPC to this endpoint\"}";
        }
        JsonValue v = JsonValue.Parse(body);
        if (v == null) {
            return McpServer.RpcError("null", 0 - 32700, "parse error");
        }
        string id = v.Str("id", "");
        JsonValue idv = v.Get("id");
        if (idv != null) { id = idv.AsString(id); }
        string rpc = v.Str("method", "");
        if (rpc == "initialize") {
            return McpServer.RpcResult(id,
                "{\"protocolVersion\": \"2024-11-05\", \"capabilities\": {\"tools\": {}}, "
                + "\"serverInfo\": {\"name\": \"zan-ide-mcp\", \"version\": \"1.0\"}}");
        }
        if (rpc == "notifications/initialized" || rpc == "initialized") {
            return "{}";
        }
        if (rpc == "tools/list") {
            return McpServer.RpcResult(id, McpServer.ToolsJson());
        }
        if (rpc == "tools/call") {
            JsonValue p = v.Get("params");
            string name = "";
            JsonValue targs = null;
            if (p != null) {
                name = p.Str("name", "");
                targs = p.Get("arguments");
            }
            string text = McpServer.CallTool(name, targs);
            return McpServer.RpcResult(id,
                "{\"content\": [{\"type\": \"text\", \"text\": \"" + McpServer.Esc(text) + "\"}]}");
        }
        return McpServer.RpcError(id, 0 - 32601, "method not found: " + rpc);
    }

    static string CallTool(string name, JsonValue args) {
        string path = "";
        if (args != null) { path = args.Str("path", ""); }
        if (name == "list_files") {
            string full = McpServer.Safe(path);
            if (full == "") { return "error: path outside project root"; }
            List<string> dirs = Directory.GetDirectories(full);
            List<string> files = Directory.GetFiles(full);
            StringBuilder sb = new StringBuilder();
            int i = 0;
            while (i < dirs.Count) { sb.Append(dirs[i] + "/\n"); i = i + 1; }
            i = 0;
            while (i < files.Count) { sb.Append(files[i] + "\n"); i = i + 1; }
            return sb.ToString();
        }
        if (name == "read_file") {
            string full = McpServer.Safe(path);
            if (full == "") { return "error: path outside project root"; }
            if (!File.Exists(full)) { return "error: file not found: " + path; }
            return File.ReadAllText(full);
        }
        if (name == "write_file") {
            string full = McpServer.Safe(path);
            if (full == "") { return "error: path outside project root"; }
            string content = "";
            if (args != null) { content = args.Str("content", ""); }
            File.WriteAllText(full, content);
            return "ok: wrote " + path;
        }
        if (name == "build") {
            List<string> outp = Process.RunCapture(
                "cd \"" + McpServer.root + "\" && zanc build src/main.zan 2>&1");
            StringBuilder sb = new StringBuilder();
            int i = 0;
            while (i < outp.Count) { sb.Append(outp[i] + "\n"); i = i + 1; }
            return sb.ToString();
        }
        return "error: unknown tool " + name;
    }

    /// Resolves a project-relative path, rejecting absolute paths and any
    /// `..` traversal so access stays inside the project root.
    static string Safe(string rel) {
        if (rel.Length > 0 && (rel.Substring(0, 1) == "/" || rel.Substring(0, 1) == "\\")) {
            return "";
        }
        if (rel.Length > 1 && rel.Substring(1, 1) == ":") { return ""; }
        int i = 0;
        while (i + 1 < rel.Length) {
            if (rel.Substring(i, 2) == "..") { return ""; }
            i = i + 1;
        }
        if (rel == "..") { return ""; }
        if (rel == "" || rel == ".") { return McpServer.root; }
        return McpServer.root + "/" + rel;
    }

    static string ToolsJson() {
        string pathProp = "{\"type\": \"object\", \"properties\": {\"path\": {\"type\": \"string\"}}, \"required\": [\"path\"]}";
        string writeProp = "{\"type\": \"object\", \"properties\": {\"path\": {\"type\": \"string\"}, \"content\": {\"type\": \"string\"}}, \"required\": [\"path\", \"content\"]}";
        string noProp = "{\"type\": \"object\", \"properties\": {}}";
        return "{\"tools\": ["
            + "{\"name\": \"list_files\", \"description\": \"List a directory inside the Zan project (path is project-relative).\", \"inputSchema\": " + pathProp + "}, "
            + "{\"name\": \"read_file\", \"description\": \"Read a text file inside the Zan project.\", \"inputSchema\": " + pathProp + "}, "
            + "{\"name\": \"write_file\", \"description\": \"Write a text file inside the Zan project.\", \"inputSchema\": " + writeProp + "}, "
            + "{\"name\": \"build\", \"description\": \"Build the Zan project (zanc build src/main.zan) and return the compiler output.\", \"inputSchema\": " + noProp + "}"
            + "]}";
    }

    static string RpcResult(string id, string resultJson) {
        return "{\"jsonrpc\": \"2.0\", \"id\": " + McpServer.IdJson(id)
            + ", \"result\": " + resultJson + "}";
    }

    static string RpcError(string id, int code, string msg) {
        return "{\"jsonrpc\": \"2.0\", \"id\": " + McpServer.IdJson(id)
            + ", \"error\": {\"code\": " + Convert.ToString(code)
            + ", \"message\": \"" + McpServer.Esc(msg) + "\"}}";
    }

    static string IdJson(string id) {
        if (id == "") { return "null"; }
        bool numeric = true;
        int i = 0;
        while (i < id.Length) {
            string ch = id.Substring(i, 1);
            if (ch < "0" || ch > "9") { numeric = false; }
            i = i + 1;
        }
        if (numeric) { return id; }
        return "\"" + McpServer.Esc(id) + "\"";
    }

    static string Esc(string s) {
        StringBuilder sb = new StringBuilder();
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch == "\"") { sb.Append("\\\""); }
            else if (ch == "\\") { sb.Append("\\\\"); }
            else if (ch == "\n") { sb.Append("\\n"); }
            else if (ch == "\r") { sb.Append("\\r"); }
            else if (ch == "\t") { sb.Append("\\t"); }
            else { sb.Append(ch); }
            i = i + 1;
        }
        return sb.ToString();
    }

}
