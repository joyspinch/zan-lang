using System;
using System.IO;
using System.Diagnostics;

namespace ProcTest;

class Program {
    static void Main() {
        Directory.CreateDirectory("proc_ws");
        File.WriteAllText("proc_ws/ok.zan",
            "using System;\nclass P { static void Main() { Console.WriteLine(\"hi\"); } }\n");
        File.WriteAllText("proc_ws/bad.zan",
            "using System;\nclass P { static void Main() { int x = ; } }\n");

        Console.WriteLine("=== compile ok.zan (emit-ir, capture head) ===");
        List<string> a = Process.RunCapture("zanc.exe --emit-ir \"proc_ws/ok.zan\" > \"proc_ws/ok.ll\"");
        Console.WriteLine("ok lines=" + a.Count);

        Console.WriteLine("=== compile bad.zan (expect diagnostics) ===");
        List<string> b = Process.RunCapture("zanc.exe --emit-ir \"proc_ws/bad.zan\" > \"proc_ws/bad.ll\"");
        int i = 0;
        while (i < b.Count) {
            Console.WriteLine("[" + i + "] " + b[i]);
            i = i + 1;
        }
    }
}
