using System;

namespace ListTest;

class Program {
    static void Main() {
        Console.WriteLine("=== List tests ===");

        List<int> nums = new List<int>();
        nums.Add(10);
        nums.Add(20);
        nums.Add(30);
        nums.Add(40);
        nums.Add(50);
        Console.WriteLine(nums.Count);

        // Contains
        if (nums.Contains(30)) {
            Console.WriteLine("Contains 30: true");
        }
        if (!nums.Contains(99)) {
            Console.WriteLine("Contains 99: false");
        }

        // IndexOf
        int idx = nums.IndexOf(30);
        Console.WriteLine(idx);

        // Insert
        nums.Insert(2, 25);
        Console.WriteLine(nums[2]);
        Console.WriteLine(nums.Count);

        // RemoveAt
        nums.RemoveAt(2);
        Console.WriteLine(nums[2]);
        Console.WriteLine(nums.Count);

        // Reverse
        nums.Reverse();
        Console.WriteLine(nums[0]);
        Console.WriteLine(nums[4]);

        // Clear
        nums.Clear();
        Console.WriteLine(nums.Count);

        // Dict with int keys (should work)
        Dict<string, int> d = new Dict<string, int>();
        d.Add("x", 42);
        Console.WriteLine(d.Count);
        if (d.ContainsKey("x")) {
            Console.WriteLine("Has x: true");
        }
        d.Remove("x");
        Console.WriteLine(d.Count);
        d.Clear();
        Console.WriteLine(d.Count);

        Console.WriteLine("=== All tests passed! ===");
    }
}
