using System;

namespace ListTest;

class Program {
    static void Main() {
        var list = new List<int>();
        list.Add(10);
        list.Add(20);
        list.Add(30);
        
        Console.WriteLine(list.Count);    // 3
        Console.WriteLine(list[0]);       // 10
        Console.WriteLine(list[1]);       // 20
        Console.WriteLine(list[2]);       // 30
        
        // Add more to test growth
        list.Add(40);
        list.Add(50);
        Console.WriteLine(list.Count);    // 5
        Console.WriteLine(list[4]);       // 50
    }
}
