using System;
using Gui;

namespace TextTest;

/// Headless verification of the Gui.Text string helpers used by the editor
/// widgets. Prints results so they can be diffed against a golden file.
class Program {
    static void Main() {
        Console.WriteLine("=== charstr ===");
        Console.WriteLine(Text.CharStr(65));
        Console.WriteLine(Text.CharStr(97));
        Console.WriteLine(Text.CharStr(126));
        Console.WriteLine($"ctrl {Text.CharStr(10).Length}");

        Console.WriteLine("=== slice ===");
        Console.WriteLine(Text.Left("abcdef", 3));
        Console.WriteLine(Text.Right("abcdef", 3));
        Console.WriteLine(Text.DropLast("abc"));

        Console.WriteLine("=== edit ===");
        Console.WriteLine(Text.InsertAt("Hello", 5, " World"));
        Console.WriteLine(Text.InsertAt("ac", 1, "b"));
        Console.WriteLine(Text.InsertAt("bc", 0, "a"));
        Console.WriteLine(Text.RemoveAt("abc", 1));
        Console.WriteLine(Text.RemoveAt("abc", 0));
        Console.WriteLine(Text.RemoveAt("abc", 2));
    }
}
