using System;

namespace M5Test;

class Program {
    static void Main() {
        // Ternary operator
        int x = 10;
        int y = 20;
        int max = x > y ? x : y;
        Console.WriteLine(max);

        // Postfix increment
        int i = 5;
        int old = i++;
        Console.WriteLine(old);
        Console.WriteLine(i);

        // Do-while
        int count = 0;
        do {
            count = count + 1;
        } while (count < 3);
        Console.WriteLine(count);
    }
}
