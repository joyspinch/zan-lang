using System;
using System.Net.Sockets;

class Program {
    static void Main() {
        Console.WriteLine("Step 1: Initialize");
        Socket.Initialize();
        Console.WriteLine("Step 2: CreateTcp");
        int sock = Socket.CreateTcp();
        Console.WriteLine("Step 3: sock=" + Convert.ToString(sock));
        Console.WriteLine("Step 4: SetReuseAddr");
        Socket.SetReuseAddr(sock);
        Console.WriteLine("Step 5: Bind");
        Socket.Bind(sock, "0.0.0.0", 8899);
        Console.WriteLine("Step 6: Listen");
        Socket.Listen(sock, 128);
        Console.WriteLine("Step 7: Listening! Close now.");
        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
