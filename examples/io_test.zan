using System;

namespace IOTest;

class Program {
    static void Main() {
        // Test File.WriteAllText + ReadAllText
        File.WriteAllText("build/test_io.txt", "Hello from Zan IO!");
        string content = File.ReadAllText("build/test_io.txt");
        Console.WriteLine(content);

        // Test File.AppendAllText
        File.AppendAllText("build/test_io.txt", "\nAppended line");
        string content2 = File.ReadAllText("build/test_io.txt");
        Console.WriteLine(content2);

        // Test File.Exists
        if (File.Exists("build/test_io.txt")) {
            Console.WriteLine("File exists: true");
        }
        if (!File.Exists("build/nonexistent.txt")) {
            Console.WriteLine("Nonexistent: false");
        }

        // Test File.GetSize
        int sz = File.GetSize("build/test_io.txt");
        Console.WriteLine("Size > 0: true");

        // Test File.Copy
        File.Copy("build/test_io.txt", "build/test_io_copy.txt");
        string copied = File.ReadAllText("build/test_io_copy.txt");
        Console.WriteLine(copied);

        // Test File.Move
        File.Move("build/test_io_copy.txt", "build/test_io_moved.txt");
        if (File.Exists("build/test_io_moved.txt")) {
            Console.WriteLine("Move: ok");
        }

        // Test File.Delete
        File.Delete("build/test_io.txt");
        File.Delete("build/test_io_moved.txt");
        if (!File.Exists("build/test_io.txt")) {
            Console.WriteLine("Delete: ok");
        }

        // Test Path operations
        string fn = Path.GetFileName("src/compiler/irgen.c");
        Console.WriteLine(fn);

        string ext = Path.GetExtension("src/compiler/irgen.c");
        Console.WriteLine(ext);

        string dir = Path.GetDirectoryName("src/compiler/irgen.c");
        Console.WriteLine(dir);

        if (Path.HasExtension("test.txt")) {
            Console.WriteLine("HasExtension: true");
        }

        string combined = Path.Combine("src", "main.c");
        Console.WriteLine(combined);

        // Test Directory
        string cwd = Directory.GetCurrentDirectory();
        Console.WriteLine("CWD ok");

        Console.WriteLine("All IO tests passed!");
    }
}
