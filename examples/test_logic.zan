using System;

namespace T;

class Program {
    static void Main() {
        var a = 1;
        var b = 0;

        if (a == 1 && b == 0) { Console.WriteLine(111); } else { Console.WriteLine(222); }
        if (a == 1 && b == 1) { Console.WriteLine(333); } else { Console.WriteLine(444); }
        if (a == 2 || b == 0) { Console.WriteLine(555); } else { Console.WriteLine(666); }
        if (a == 2 || b == 1) { Console.WriteLine(777); } else { Console.WriteLine(888); }

        var i = 0;
        var count = 0;
        while (i < 5 && count < 100) { i = i + 1; count = count + i; }
        Console.WriteLine(count);

        var arr = new int[3];
        arr[0] = 10;
        arr[1] = 20;
        arr[2] = 30;
        var j = 0;
        var sum = 0;
        while (j < 3 && arr[j] > 0) { sum = sum + arr[j]; j = j + 1; }
        Console.WriteLine(sum);
    }
}
