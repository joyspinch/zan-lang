using System;
using System.Net.Sockets;

class Program {
    [DllImport("ws2_32")]
    static extern int ioctlsocket(int s, int cmd, string argp);
    [DllImport("crt")]
    static extern string calloc(int count, int size);
    [DllImport("crt")]
    static extern void free(string ptr);

    static void Main() {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.SetReuseAddr(sock);
        Socket.Bind(sock, "0.0.0.0", 8899);
        Socket.Listen(sock, 128);
        Console.WriteLine("sock=" + Convert.ToString(sock));

        string nb = calloc(4, 1);
        nb[0] = 1;
        ioctlsocket(sock, -2147195266, nb);
        free(nb);

        // Use Socket.IsReadable which already works
        bool r = Socket.IsReadable(sock);
        Console.WriteLine("IsReadable=" + Convert.ToString(r));

        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
