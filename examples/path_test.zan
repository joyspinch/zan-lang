using System;

namespace PathTest;

class Program {
    static void Main() {
        var full = "C:\\Users\\test\\hello.txt";
        var name = Path.GetFileName(full);
        Console.WriteLine(name);

        var ext = Path.GetExtension(full);
        Console.WriteLine(ext);

        var combined = Path.Combine("dir1", "file.txt");
        Console.WriteLine(combined);

        var unix = "/home/user/data.csv";
        var uname = Path.GetFileName(unix);
        Console.WriteLine(uname);

        var uext = Path.GetExtension(unix);
        Console.WriteLine(uext);
    }
}
