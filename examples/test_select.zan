using System;
using System.Net.Sockets;

class Program {
    [DllImport("crt")]
    static extern string calloc(int count, int size);
    
    [DllImport("crt")]
    static extern void free(string ptr);

    [DllImport("ws2_32")]
    static extern int select(int nfds, string readfds, string writefds, string exceptfds, string timeout);

    [DllImport("ws2_32")]
    static extern int ioctlsocket(int s, int cmd, string argp);

    static void Main() {
        Socket.Initialize();
        int sock = Socket.CreateTcp();
        Socket.SetReuseAddr(sock);
        Socket.Bind(sock, "0.0.0.0", 8899);
        Socket.Listen(sock, 128);
        Console.WriteLine("sock=" + Convert.ToString(sock));

        // Set non-blocking
        string nb = calloc(4, 1);
        nb[0] = 1;
        ioctlsocket(sock, -2147195266, nb);
        free(nb);

        // Test select with 4-byte SOCKET entries
        // timeval: tv_sec=1, tv_usec=0 (1 second timeout)
        string tv = calloc(8, 1);
        tv[0] = 1;

        // fd_set with 4-byte entries: fd_count(4) + sock(4)
        string fds4 = calloc(12, 1);
        fds4[0] = 1;
        fds4[4] = sock & 255;
        fds4[5] = (sock >> 8) & 255;
        fds4[6] = (sock >> 16) & 255;
        fds4[7] = (sock >> 24) & 255;

        int r4 = select(0, fds4, "", "", tv);
        Console.WriteLine("select(4-byte)=" + Convert.ToString(r4));
        free(fds4);
        free(tv);

        // fd_set with 8-byte entries: fd_count(4) + sock(8)
        string tv2 = calloc(8, 1);
        tv2[0] = 1;

        string fds8 = calloc(16, 1);
        fds8[0] = 1;
        fds8[4] = sock & 255;
        fds8[5] = (sock >> 8) & 255;
        fds8[6] = (sock >> 16) & 255;
        fds8[7] = (sock >> 24) & 255;
        fds8[8] = 0;
        fds8[9] = 0;
        fds8[10] = 0;
        fds8[11] = 0;

        int r8 = select(0, fds8, "", "", tv2);
        Console.WriteLine("select(8-byte)=" + Convert.ToString(r8));
        free(fds8);
        free(tv2);

        Socket.Close(sock);
        Console.WriteLine("Done");
    }
}
