using System;
using System.IO;

namespace StdlibTest;

class Program {
    static void Main() {
        Console.WriteLine("=== System.IO.File tests ===");

        // WriteAllText + ReadAllText
        File.WriteAllText("build/stdlib_test.txt", "Hello Zan stdlib!");
        string content = File.ReadAllText("build/stdlib_test.txt");
        Console.WriteLine(content);

        // AppendAllText
        File.AppendAllText("build/stdlib_test.txt", "\nSecond line");
        string content2 = File.ReadAllText("build/stdlib_test.txt");
        Console.WriteLine(content2);

        // Exists
        if (File.Exists("build/stdlib_test.txt")) {
            Console.WriteLine("Exists: true");
        }
        if (!File.Exists("build/no_such_file.xyz")) {
            Console.WriteLine("Not exists: true");
        }

        // GetSize
        int sz = File.GetSize("build/stdlib_test.txt");
        if (sz > 0) {
            Console.WriteLine("Size > 0: true");
        }

        // Copy
        File.Copy("build/stdlib_test.txt", "build/stdlib_copy.txt");
        string copied = File.ReadAllText("build/stdlib_copy.txt");
        Console.WriteLine(copied);

        // Move
        File.Move("build/stdlib_copy.txt", "build/stdlib_moved.txt");
        if (File.Exists("build/stdlib_moved.txt") && !File.Exists("build/stdlib_copy.txt")) {
            Console.WriteLine("Move: ok");
        }

        // Delete
        File.Delete("build/stdlib_test.txt");
        File.Delete("build/stdlib_moved.txt");
        if (!File.Exists("build/stdlib_test.txt")) {
            Console.WriteLine("Delete: ok");
        }

        Console.WriteLine("=== System.IO.Path tests ===");

        string fn = Path.GetFileName("src/compiler/irgen.c");
        Console.WriteLine(fn);

        string ext = Path.GetExtension("src/compiler/irgen.c");
        Console.WriteLine(ext);

        string dir = Path.GetDirectoryName("src/compiler/irgen.c");
        Console.WriteLine(dir);

        string fnwe = Path.GetFileNameWithoutExtension("src/compiler/irgen.c");
        Console.WriteLine(fnwe);

        string combined = Path.Combine("src", "main.c");
        Console.WriteLine(combined);

        if (Path.HasExtension("test.txt")) {
            Console.WriteLine("HasExtension: true");
        }
        if (!Path.HasExtension("noext")) {
            Console.WriteLine("No extension: true");
        }

        string changed = Path.ChangeExtension("hello.txt", ".md");
        Console.WriteLine(changed);

        string tmp = Path.GetTempPath();
        if (tmp.Length > 0) {
            Console.WriteLine("TempPath: ok");
        }

        Console.WriteLine("=== System.IO.Directory tests ===");

        string cwd = Directory.GetCurrentDirectory();
        if (cwd.Length > 0) {
            Console.WriteLine("CWD: ok");
        }

        Directory.CreateDirectory("build/test_dir");
        if (Directory.Exists("build/test_dir")) {
            Console.WriteLine("CreateDir: ok");
        }

        Directory.Delete("build/test_dir");
        if (!Directory.Exists("build/test_dir")) {
            Console.WriteLine("DeleteDir: ok");
        }

        Console.WriteLine("=== All stdlib tests passed! ===");
    }
}
