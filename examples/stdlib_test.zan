using System;

namespace StdlibTest;

class Program {
    static void Main() {
        // M3.1 Console.Write (no newline)
        Console.Write("Hello ");
        Console.Write("World");
        Console.WriteLine("");
        
        // M3.3 Math functions
        var max = Math.Max(10, 20);
        Console.WriteLine(max);          // 20
        
        var min = Math.Min(10, 20);
        Console.WriteLine(min);          // 10
        
        var abs = Math.Abs(-42);
        Console.WriteLine(abs);          // 42
        
        // M3.8 Convert.ToString
        var s = Convert.ToString(123);
        Console.WriteLine(s);            // 123
    }
}
