using System;

namespace FileIOTest;

class Program {
    static void Main() {
        // Write a file
        File.WriteAllText("test_output.txt", "Hello from Zan!");
        
        // Read it back
        var content = File.ReadAllText("test_output.txt");
        Console.WriteLine(content);   // Hello from Zan!
        
        // Test string length
        var len = content.Length;
        Console.WriteLine(len);       // 15
    }
}
