using System;

namespace ArrayTest;

class Program {
    static void Main() {
        // array creation and indexing
        var nums = new int[5];
        nums[0] = 10;
        nums[1] = 20;
        nums[2] = 30;
        nums[3] = 40;
        nums[4] = 50;

        // array access
        Console.WriteLine($"nums[0] = {nums[0]}");
        Console.WriteLine($"nums[2] = {nums[2]}");
        Console.WriteLine($"nums[4] = {nums[4]}");

        // sum array elements
        var sum = 0;
        for (var i = 0; i < 5; i = i + 1) {
            sum = sum + nums[i];
        }
        Console.WriteLine($"sum = {sum}");
    }
}
