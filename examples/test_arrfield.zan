using System;

namespace T;

class Box {
    public int[] data;
    public int n;
}

class Program {
    static void Main() {
        var b = new Box();
        b.data = new int[4];
        b.n = 4;
        var i = 0;
        while (i < b.n) { b.data[i] = i + 100; i = i + 1; }
        var s = 0;
        var j = 0;
        while (j < b.n) { s = s + b.data[j]; j = j + 1; }
        Console.WriteLine(s);
    }
}
