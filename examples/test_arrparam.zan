using System;

namespace T;

class Program {
    static int SumArr(int[] a, int n) {
        var s = 0;
        var i = 0;
        while (i < n) { s = s + a[i]; i = i + 1; }
        return s;
    }

    static void FillArr(int[] a, int n) {
        var i = 0;
        while (i < n) { a[i] = i * 10; i = i + 1; }
    }

    static void Main() {
        var arr = new int[4];
        arr[0] = 5;
        arr[1] = 6;
        arr[2] = 7;
        arr[3] = 8;
        Console.WriteLine(SumArr(arr, 4));

        var buf = new int[4];
        FillArr(buf, 4);
        Console.WriteLine(SumArr(buf, 4));
    }
}
